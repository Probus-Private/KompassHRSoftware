                                            <tr><td>Special Allowance</td><td class="text-end">₹@ViewBag.CTCDetails.Special</td></tr>
                                            <tr><td>Food</td><td class="text-end">₹@ViewBag.CTCDetails.Food</td></tr>
                                            <tr><td>Uniform</td><td class="text-end">₹@ViewBag.CTCDetails.Uniform</td></tr>
                                            <tr><td>Phone</td><td class="text-end">₹@ViewBag.CTCDetails.Phone</td></tr>
