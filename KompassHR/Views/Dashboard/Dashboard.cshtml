<script>
    function previewFile(ID,Origin)
    {

        $.ajax({
            url: "@Url.Action("GetFile", "Dashboard")",
            type: 'GET',
            data: { DocId: ID,DocOrigin:Origin },
            success: function (response)
            {
                if (response.extension==".pdf")
                {
                    showPDF(response.filePath);
                }
                else
                {
                    showImage(response.filePath);
                }
            }
        });
    }

    function showPDF(base64Data) {

        if (!base64Data) {
            Swal.fire({
                text: 'file not found!.',
                icon: 'info',
                allowOutsideClick: false
            });
            return false;
        }
        // Directly use base64 string
        const iframe = `<iframe src="${base64Data}#toolbar=0&navpanes=0&scrollbar=0"
                             width="100%" height="600px" style="border:none;"></iframe>`;

        $('#modalContent1').html(iframe);
        new bootstrap.Modal(document.getElementById('mediaModal')).show();
    }

    function showImage(base64Data) {
        if (!base64Data) {
            Swal.fire({
                text: 'Image not found!.',
                icon: 'info',
                allowOutsideClick: false
            });
            return false;
        }
        const img = `<img src="${base64Data}" class="img-fluid rounded" />`;
        $('#modalContent1').html(img);
        new bootstrap.Modal(document.getElementById('mediaModal')).show();
    }


</script>

