    var maxDays = @ViewBag.MaxDateDays;
    var daysSince = @ViewBag.DaysSinceChange;

    // Open modal based on conditions
    if (daysSince >= minDays) {
        const modalEl = document.getElementById('mfaModal');
        if (modalEl) {
            modalEl.style.display = 'block';
            modalEl.classList.add('show');

            // Prevent the modal from closing when clicking outside (on backdrop)
            modalEl.addEventListener('click', function(e) {
                if (e.target === modalEl) {
                    e.stopPropagation();
                }
            });

            // Prevent Escape key from closing the modal
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    e.preventDefault();
                    e.stopPropagation();
                }
            });

            // Hide the "Skip" button if daysSince exceeds maxDays
            if (daysSince > maxDays) {
                const btn = modalEl.querySelector('.btn-secondary');
                if (btn) btn.style.display = 'none';  // Hide the button
            }
        }
    }

