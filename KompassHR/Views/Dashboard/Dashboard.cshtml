    @if (Session["IsTrainingAccess"] != null && (bool)Session["IsTrainingAccess"])
    {
        <div class="row" id="divIsTrainingAccess">
            <div class="col-xl-12 col-md-12 col-sm-12">
                <div class="panel panel-inverse">
                    <div class="panel-heading ui-sortable-handle" style="background-color:#197fdd; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Training Calendar</h4>
                    </div>
                    <div class="panel-body">
                        <!-- Carousel Start -->
                        <div id="eventCarousel" class="carousel slide carousel-fade mb-4" data-bs-ride="carousel" data-bs-interval="3000">
                            <!-- Indicators -->
                            <div class="carousel-indicators">
                                @{
                                var banners = ViewBag.BannerImages as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                                int index = 0;
                                foreach (var img in banners)
                                {
                                    var isActive = index == 0 ? "active" : "";
                            <button type="button" data-bs-target="#eventCarousel" data-bs-slide-to="@index" class="@isActive" aria-label="Slide @(index + 1)"></button>;
                                    index++;
                                }
                                }
                            </div>

                            <!-- Carousel Inner -->
                            <div class="carousel-inner">
                                @{
                                bool first = true;
                                foreach (var img in banners)
                                {
                            <div class="carousel-item @(first ? "active" : "")">
                                <a href="@Url.Action("CalenderEventView", "ESS_Training_TrainingCalender", new { area = "ESS", TrainingCalenderId_Encrypted = img.TrainingCalenderId_Encrypted, BannerImage = img.FullPath })">
                                    <img src="@img.FullPath" class="d-block w-100" alt="Event @img.TrainingCalenderId" />
                                </a>
                            </div>;
                                    first = false;
                                }
                                }
                            </div>

                            <!-- Controls -->
                            <button class="carousel-control-prev" type="button" data-bs-target="#eventCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#eventCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>
                        <!-- Carousel End -->
                        <!-- Carousel CSS -->
                        <style>
                            .carousel-item img {
                                width: 100%;
                                max-height: 250px;
                                object-fit: cover;
                                border-radius: 10px;
                            }

                            .carousel-inner {
                                border-radius: 10px;
                            }

                            .carousel-indicators [data-bs-target] {
                                width: 10px;
                                height: 10px;
                                border-radius: 50%;
                                background-color: #0d6efd;
                            }

                            .carousel-control-prev-icon,
                            .carousel-control-next-icon {
                                background-color: rgba(0, 0, 0, 0.5);
                                border-radius: 50%;
                                padding: 10px;
                            }
                        </style>
                    </div>
                </div>
            </div>
        </div>
    }


