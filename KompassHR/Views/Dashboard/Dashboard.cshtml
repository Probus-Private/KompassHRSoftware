        var GetMachineName5 = @Html.Raw(Json.Encode(Session["GetMachineName5"]));
        console.log(GetMachineName1);
        console.log(GetMachineName2);
        console.log(GetMachineName3);
        console.log(GetMachineName4);
        console.log(GetMachineName5);*@

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            }).then(function() {
                window.location.href = '@Url.Action("Logout", "Login", new { Area = "" })';
            });
        }

        var Test1 = @Html.Raw(Json.Encode(TempData["Test1"]));
        var Test2 = @Html.Raw(Json.Encode(TempData["Test2"]));
        var Test3 = @Html.Raw(Json.Encode(TempData["Test3"]));
        var Test4 = @Html.Raw(Json.Encode(TempData["Test4"]));
        console.log(Test1);
        console.log(Test2);
        console.log(Test3);
        console.log(Test4);

        //var GetMenuList = @Html.Raw(Json.Encode(Session["GetTransactionMenulist"]));
        var LeaveCharts = document.getElementById('Leave-chart1');
        window.myDoughnut = new Chart(LeaveCharts, {
            type: 'doughnut',
            data: {
                labels: ['Taken', 'Pending', 'Balance'],
                datasets: [{
                    data: [2.5, 1, 3.5],
                    backgroundColor: ["#8ED1E6", "#E68100", "#4762A5"],

                    label: 'Leave'
                }]
            },
            options: {
                plugins:{
                    legend: {
                        display: true,
                        position: 'left',
                    }
                },

                scales: {
                    xAxes: {
                        gridLines: {
                            drawBorder: false,
                        },

                        title: {
                            display: true,
                            text: 'CL Leaves'
                        },

                        ticks: {
                            display: false,
                            // forces step size to be 50 units
                        }
                    },
                    y: {
                        display: false,
                        title: {
                            display: false,
                            text: 'Value'
                        },

                        ticks: {
                            display: false,
                        }
                    }
                }
            }
        });

    });
</script>

