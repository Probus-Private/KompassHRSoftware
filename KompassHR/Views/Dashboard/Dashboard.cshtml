<script>
    $(document).ready(function () {
        debugger;
        @*var GetMachineName1 = @Html.Raw(Json.Encode(Session["GetMachineName1"]));
        var GetMachineName2 = @Html.Raw(Json.Encode(Session["GetMachineName2"]));
        var GetMachineName3 = @Html.Raw(Json.Encode(Session["GetMachineName3"]));
