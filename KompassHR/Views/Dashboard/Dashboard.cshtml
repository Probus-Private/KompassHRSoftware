                    <div class="mb-4 text-center">
                        <h6 class="fw-medium text-gray-5 mb-1">Attendance</h6>
                        <h4 id="currentTime"></h4>
                    </div>

                    <div class="attendance-circle-progress attendance-progress mx-auto mb-3" id="progressCircle">
                        <span class="progress-left">
                            <span class="progress-bar border-success" id="leftBar"></span>
                        </span>
                        <span class="progress-right">
                            <span class="progress-bar border-success" id="rightBar"></span>
                        </span>
                        <div class="total-work-hours text-center w-100">
                            <span class="fs-13 d-block mb-1">Total Hours</span>
                            <h6 id="workHours">00:00:00</h6>
                        </div>
                    </div>

                    <div class="text-center">
                        <div class="badge badge-dark badge-md mb-3" id="productionTime">Production : 00:00 hrs</div>
                        <h6 class="fw-medium d-flex align-items-center justify-content-center mb-4">
                            <i class="ti ti-fingerprint text-primary me-1"></i>
                            Punch In at  <span id="punchInText"> --</span>
                        </h6>
                        <button class="btn btn-primary w-100" onclick="togglePunch()" id="punchBtn">Punch In</button>
                    </div>
                </div>
                <!-- clock Punch and animation Logic   -->

                <script>
                    let punchInTime = null;
                    let timerInterval = null;

                    function updateCurrentTime() {
                        const now = new Date();
                        document.getElementById("currentTime").innerText =
                            now.toLocaleTimeString() + ", " + now.toDateString();
                    }

                    setInterval(updateCurrentTime, 1000);
                    updateCurrentTime();

                    function formatTime(ms) {
                        let totalSeconds = Math.floor(ms / 1000);
                        let hrs = String(Math.floor(totalSeconds / 3600)).padStart(2, '0');
                        let mins = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, '0');
                        let secs = String(totalSeconds % 60).padStart(2, '0');
                        return `${hrs}:${mins}:${secs}`;
                    }

                    function updateWork() {
                        const now = new Date();
                        const diff = now - punchInTime;

                        document.getElementById("workHours").innerText = formatTime(diff);

                        // Assuming 1-hour work day
                        let percent = Math.min((diff / (1 * 60 * 60 * 1000)) * 100, 100);
                        updateCircle(percent);

                        document.getElementById("productionTime").innerText =
                            "Production : " + (diff / (60 * 60 * 1000)).toFixed(2) + " hrs";
                    }

                    function updateCircle(percent) {
                        let left = document.getElementById("leftBar");
                        let right = document.getElementById("rightBar");

                        if (percent <= 50) {
                            right.style.transform = `rotate(${percent * 3.6}deg)`;
                            left.style.transform = `rotate(0deg)`;
                        } else {
                            right.style.transform = `rotate(180deg)`;
                            left.style.transform = `rotate(${(percent - 50) * 3.6}deg)`;
                        }
                    }

                    function togglePunch() {
                        const btn = document.getElementById("punchBtn");

                        if (!punchInTime) {
                            punchInTime = new Date();
                            document.getElementById("punchInText").innerText =
                                punchInTime.toLocaleTimeString();

                            btn.innerText = "Punch Out";

                            timerInterval = setInterval(updateWork, 1000);
                        } else {
                            clearInterval(timerInterval);
                            punchInTime = null;

                            btn.innerText = "Punch In";
                            document.getElementById("workHours").innerText = "00:00:00";
                            updateCircle(0);
                        }
                    }
                </script>
            </div>
        </div>
