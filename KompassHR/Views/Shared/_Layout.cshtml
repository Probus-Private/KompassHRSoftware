                @*START NOTIFICATION SIDEBAR CODE*@

                <style>
                    /* Sidebar Base */
                    #notificationSidebar {
                        position: fixed;
                        top: 0;
                        right: -400px;
                        width: 400px;
                        height: 100%;
                        background: #fff;
                        box-shadow: -3px 0 10px rgba(0, 0, 0, 0.2);
                        padding: 10px;
                        transition: right 0.3s ease;
                        z-index: 9999;
                        display: flex;
                        flex-direction: column;
                        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                        overflow-y: auto;
                    }

                        #notificationSidebar.active {
                            right: 0;
                        }

                    .sidebar-header {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        padding-bottom: 15px;
                        border-bottom: 1px solid #eee;
                    }

                        .sidebar-header h4 {
                            margin: 0;
                            font-size: 18px;
                            color: #333;
                            font-weight: 600;
                        }

                    .close-btn {
                        font-size: 24px;
                        color: #999;
                        background: none;
                        border: none;
                        cursor: pointer;
                    }

                    /* Notification List */
                    .notifyUl {
                        list-style: none;
                        padding: 0;
                        margin: 0;
                    }

                    .notification-header {
                        background: #f9f9f9;
                        padding: 10px 15px;
                        font-weight: 600;
                        border-radius: 6px;
                        margin-bottom: 5px;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        cursor: pointer;
                        transition: background 0.3s;
                    }

                        .notification-header:hover {
                            background: #f1f1f1;
                        }

                        .notification-header i.chevron {
                            transition: transform 0.3s ease;
                        }

                        .notification-header.open i.chevron {
                            transform: rotate(180deg);
                        }

                    ul.nested {
                        list-style: none;
                        margin: 0;
                        padding-left: 15px;
                        overflow: hidden;
                        max-height: 0;
                        transition: max-height 0.5s ease;
                    }

                        ul.nested.show {
                            max-height: 500px;
                        }

                    .notification-item {
                        display: flex;
                        gap: 10px;
                        padding: 10px 0;
                        border-bottom: 1px solid #f0f0f0;
                        animation: fadeIn 0.4s forwards;
                    }

                    .notification-text {
                        flex: 1;
                        font-size: 14px;
                        color: #333;
                    }

                    .notification-time {
                        font-size: 12px;
                        color: #999;
                    }

                    ul.nested.show {
                        max-height: 350px; /* auto-adjust with scroll */
                        overflow-y: auto;
                    }

                    @@keyframes fadeIn {
                        from {
                            opacity: 0;
                            transform: translateY(-5px);
                        }

                        to {
                            opacity: 1;
                            transform: translateY(0);
                        }
                    }

                    /* Bell Icon */
                    .notification-bell {
                        position: relative;
                        display: inline-block;
                        cursor: pointer;
                        font-size: 20px;
                        margin: 8px;
                    }

                        .notification-bell .badge {
                            position: absolute;
                            top: -8px;
                            right: -8px;
                            font-size: 0.5rem;
                            padding: 3px 6px;
                            border-radius: 50%;
                            background-color: #dc3545;
                            color: #fff;
                            line-height: 1;
                        }

                    .highlight {
                        animation: pulse 1s infinite;
                    }

                    @@keyframes pulse {
                        0% {
                            transform: scale(1);
                            box-shadow: 0 0 0 0 rgba(220,53,69,0.7);
                        }

                        70% {
                            transform: scale(1.1);
                            box-shadow: 0 0 0 10px rgba(220,53,69,0);
                        }

                        100% {
                            transform: scale(1);
                            box-shadow: 0 0 0 0 rgba(220,53,69,0);
                        }
                    }

                    /* Responsive */
                    @@media (max-width: 576px) {
                        #notificationSidebar {
                            width: 100%;
                            right: -100%;
                        }

                            #notificationSidebar.active {
                                right: 0;
                            }
                    }
                </style>
