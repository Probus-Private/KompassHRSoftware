                <!-- ✅ Script -->
                <script>
                    // Open/Close Sidebar
                    document.getElementById('openBellSidebar').addEventListener('click', function () {
                        document.getElementById('notificationSidebar').classList.add('active');
                    });

                    document.getElementById('closeBellSidebar').addEventListener('click', function () {
                        document.getElementById('notificationSidebar').classList.remove('active');
                    });

                    // Close sidebar when clicking outside
                    document.addEventListener('click', function (event) {
                        const sidebar = document.getElementById('notificationSidebar');
                        const bellIcon = document.getElementById('openBellSidebar');
                        if (!sidebar.contains(event.target) && !bellIcon.contains(event.target)) {
                            sidebar.classList.remove('active');
                        }
                    });

                    // Expand/Collapse Dropdowns
                    function toggleCategory(id, event) {
                        event.stopPropagation();
                        const list = document.getElementById(id);
                        list.classList.toggle('show');
                        event.currentTarget.classList.toggle('open');
                    }

                    // Highlight Bell if new notifications exist
                    document.addEventListener('DOMContentLoaded', function () {
                        const badge = document.getElementById('notificationCount');
                        const count = parseInt(badge.innerText);
                        if (count > 0) {
                            badge.classList.add('highlight');
                        }
                    });
                </script>
