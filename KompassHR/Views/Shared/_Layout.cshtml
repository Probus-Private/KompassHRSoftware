        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('txtGlobalEmployeeSearch');

            const handleEvent = function(event) {
                if (event.key === "Enter" || event.type === "click") {
                    event.preventDefault();
                    btnEmployeeInfo();
                }
            };
            searchInput.addEventListener("keydown", handleEvent);
            searchInput.addEventListener("touchend", handleEvent);
        });

        function btnEmployeeInfo() {
            var SearchText = $("#txtGlobalEmployeeSearch").val();

            if (SearchText != "") {

                $(".Userloaderbg").css("display", "flex");

                $.ajax({
                    type: 'GET',
                    dataType: 'JSON',
                    url: '@Url.Action("EmployeeGlobalSearch", "Dashboard", new { area = "" })',
                    data: { SearchText: SearchText },
                    success: function (res) {

                        $(".Userloaderbg").css("display", "none");

                        if (!res || res.data.length === 0) {
                            Swal.fire({ icon: 'error', text: 'Record Not Found' });
                            return;
                        }

                        var data = res.data;

                        //Hide both tables initially
                        $("#tblEmployeeGlobalSearch").closest("table").hide();
                        $("#tblEmployeeGlobalSearch1").closest("table").hide();

                        //IF CONDITION DATA = SHOW FIRST TABLE
                        if (res.type === "IF") {

                            $("#tblEmployeeGlobalSearch").closest("table").show();

                            if ($.fn.DataTable.isDataTable('#tblEmployeeGlobalSearch')) {
                                $('#tblEmployeeGlobalSearch').DataTable().clear().rows.add(data).draw();
                            } else {
                                $('#tblEmployeeGlobalSearch').DataTable({
                                    data: data,
                                    destroy: true,
                                    columns: [
                                         {
                                             data: null,
                                             orderable: false,
                                             searchable: false,
                                             render: function (data, type, row) {
                                                 return `
                    <button class="btn btn-sm btn-outline-primary"
                title="View Employee"
                onclick="openEmployeeView('${row.EmployeeId}')">
                <i class="fa fa-eye"></i>
            </button>`;
                                             }
                                         },

                                        { data: 'EmployeeNo' },
                                        { data: 'EmployeeCardNo' },
                                        { data: 'EmployeeName' },
                                        { data: 'EmployeeLeft' },
                                        { data: 'CompanyName' },
                                        { data: 'BranchName' },
                                        { data: 'DepartmentName' },
                                        { data: 'SubDepartment' },
                                        { data: 'DesignationName' },
                                        { data: 'GradeName' },
                                        { data: 'Contractor' },
                                        { data: 'EmployeeGroup' },
                                        { data: 'EmployeeType' },
                                        { data: 'EmployeeLevel' },
                                        { data: 'WageCategory' },
                                        { data: 'CostCenter' },
                                        { data: 'Unit' },
                                        { data: 'CriticalStageApplicable' },
                                        { data: 'CriticalStage' },
                                        { data: 'LineName' },
                                        { data: 'JoiningDate' },
                                        { data: 'ConfirmationDate' },
                                        { data: 'LeavingDate' },
                                        { data: 'OT' },
                                        { data: 'CoffApplicable' },
                                        { data: 'WOFF1' },
                                        { data: 'WOFF2' },
                                        { data: 'AadharNo' },
                                        { data: 'PanNo' },
                                        { data: 'PrimaryMobileNo' },
                                        { data: 'Gender' },
                                        { data: 'MaritalStatus' }
                                    ]
                                });
                            }
                        }

                            //ELSE CONDITION DATA = SHOW SECOND TABLE
                        else if (res.type === "ELSE") {

                            $("#tblEmployeeGlobalSearch1").closest("table").show();

                            if ($.fn.DataTable.isDataTable('#tblEmployeeGlobalSearch1')) {
                                $('#tblEmployeeGlobalSearch1').DataTable().clear().rows.add(data).draw();
                            } else {
                                $('#tblEmployeeGlobalSearch1').DataTable({
                                    data: data,
                                    destroy: true,
                                    columns: [
                                        { data: 'EmployeeNo' },
                                        { data: 'EmployeeCardNo' },
                                        { data: 'EmployeeName' },
                                        { data: 'EmployeeLeft' },
                                        { data: 'CompanyName' },
                                        { data: 'BranchName' },
                                        { data: 'DepartmentName' },
                                        { data: 'SubDepartment' },
                                        { data: 'DesignationName' },
                                    ]
                                });
                            }
                        }

                        $('#myEmployeeInfoModal').modal('show');
                    }
                });
            }
        }

        var table = $('.TablePage').DataTable();
        table.search('').draw();

        function openEmployeeView(EmployeeId) {
            debugger
            window.location.href = '/Dashboard/EmployeeDetails?employeeId=' + EmployeeId;
        }
    </script>

