                            <span class="text-muted">Type: ${obj.Type}</span><br/>
                            <span class="text-muted">Date: ${obj.RequestDate}</span><br/>
                            <span class="text-muted">Reason: ${obj.Reason}</span>
                        </div>

                    </a>
                </li>`;
                });

                $("#leaveList").html(html);
            }
        });
    }
