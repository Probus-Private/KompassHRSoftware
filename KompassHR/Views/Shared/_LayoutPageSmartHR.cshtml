    <script>
        // Set initial countdown time (20 minutes)
        let timeLeft = 15 * 60; // 20 minutes in seconds
        function updateTimer() {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;

            // Format with leading zeros
            seconds = seconds < 10 ? '0' + seconds : seconds;

            // Update the UI
            document.getElementById('timer').innerText = `Session Time :  ${minutes}:${seconds}`;

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                Swal.fire({
                    title: "Session Expired!",
                    text: "Your session has expired. Please log in again.",
                    icon: "warning",
                    confirmButtonText: "OK",
                    allowOutsideClick: false
                }).then(() => {
                    window.location.href = @Html.Raw(Json.Encode(Url.Action("Logout", "Login", new { area = "" })));
                });
            }
            timeLeft--; // Decrease time by 1 second
        }

        // Start the countdown
        let timerInterval = setInterval(updateTimer, 1000);

        // Initial call to display immediately
        updateTimer();
    </script>


