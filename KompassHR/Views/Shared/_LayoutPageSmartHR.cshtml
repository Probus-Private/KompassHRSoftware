    <script>
        $("#btnGlobalSearch").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#tbodyBodyHeadEmployeeInfo tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    </script>


    <script>

        // THIS CODE IS USE FOR DISABLED ALL REGHT CLICK AND OPEN NEW TAB
        document.querySelectorAll('a').forEach(function (link) {
            link.addEventListener('click', function (e) {
                // Prevent Ctrl+Click, Cmd+Click (Mac), or Middle Click
                if (e.ctrlKey || e.metaKey || e.button === 1) {
                    e.preventDefault();
                }
            });

            // Prevent right-click menu on link
            link.addEventListener('contextmenu', function (e) {
                e.preventDefault();
            });
        });
    </script>

    <script>
        function loadLeaveNotifications() {debugger
            $.ajax({
                url: '/Dashboard/GetLeaveNotifications',
                type: 'GET',
                success: function (data) {

                    let html = "";
                    let count = data.length;

                    $("#leaveCount").text(count);

                    data.forEach(function (item) {

                        // convert Key/Value array to object
                        let obj = {};

                        item.forEach(function (kv) {
                            obj[kv.Key] = kv.Value;
                        });

                        html += `
                   <li class="notification-item">
                    <a href="/ESS/ESS_Leave_Approval/ESS_Leave_Approval?id=${obj.DocId_Encrypted}"
                       style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:8px;">

                        <i class="fa-solid fa-user text-info"></i>

                        <div class="notification-text">
                            <strong>${obj.EmployeeName}</strong><br/>
                            <span class="text-muted">Type: ${obj.Type}</span><br/>
                            <span class="text-muted">Date: ${obj.RequestDate}</span><br/>
                            <span class="text-muted">Reason: ${obj.Reason}</span>
                        </div>

                    </a>
                </li>`;
                    });

                    $("#leaveList").html(html);
                }
            });
        }
    </script>


