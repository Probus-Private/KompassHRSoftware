    <script>
        @{
            var imageUrl1 = Url.Content("~/assets/img/login/login-bg-1.jpg");
            var imageUrl2 = Url.Content("~/assets/img/login/login-bg-2.jpg");
            var imageUrl3 = Url.Content("~/assets/img/login/login-bg-3.jpg");
            var imageUrl4 = Url.Content("~/assets/img/login/login-bg-4.jpg");
            //var imageUrl5 = Url.Content("~/assets/img/login/Hrms.gif");
            //var imageUrl6 = Url.Content("~/assets/img/login/HRMS2.gif");
            var imageUrl5 = Url.Content("~/assets/img/login/login-bg-6.jpg");
            var imageUrl6 = Url.Content("~/assets/img/login/login-bg-8.jpg");
            var imageUrl7 = Url.Content("~/assets/img/login/login-bg-7.jpg");
        }
    const d = new Date();
    let day = d.getDay()
    var imageUrl = "";
    switch (day) {
        case 1:
            imageUrl = "@imageUrl1";
            break;
        case 2:
            imageUrl = "@imageUrl2";
            break;
        case 3:
            imageUrl = "@imageUrl3";
            break;
        case 4:
            imageUrl = "@imageUrl4";
            break;
        case 5:
            imageUrl = "@imageUrl5";
            break;
        case 6:
            imageUrl = "@imageUrl6";
            break;
        case 7:
            imageUrl = "@imageUrl7";
            break;
        default:
            imageUrl = "@imageUrl1";
    }

    // Set the src attribute of the imgLoginBackground element
    $('#imgLoginBackground').attr('src', imageUrl);
    </script>

    <script>
    $(document).ready(function () {
        var PasswordCheck = @Html.Raw(Json.Encode(ViewBag.SendPassword));
        if(PasswordCheck !=null)
        {
            Swal.fire({
                icon: 'success',
                text: 'Password send Successfully !',
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false;
                }
            });
        }

        $("#btnCancel").click(function(){
            $("#CustomerCode").val("");
            $("#EmployeeNo").val("");
            $("#txtGetAnswer").val("");
            // $("#txtEmailId").val("");
            $("#divQueAndEmail").hide();
            $("#btnForgotPassword").hide();
            $("#GetSequrityQueAns").show();
        })

        $("#ShowPassword").hover(
        function () {
            $(this).addClass("hover");
            const type = ESSPassword.getAttribute('type') === 'password' ? 'text' : 'password';
            ESSPassword.setAttribute('type', type);
            // toggle the eye slash icon
            this.classList.toggle('fa-solid-eye-slash');
        }, function () {
            $(this).removeClass("hover");
            const type = ESSPassword.getAttribute('type') === 'password' ? 'text' : 'password';
            ESSPassword.setAttribute('type', type);
            // toggle the eye slash icon
            this.classList.toggle('fa-solid-eye-slash');
        }
    );

