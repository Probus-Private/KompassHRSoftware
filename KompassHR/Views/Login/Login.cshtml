    <script>
    $(document).ready(function () {
        const inputs = $('.mfa-input');

        // Auto-focus to the next box after entering a digit
        $('.mfa-input').on('keyup', function (e) {
            var $input = $(this);
            // Move focus to next input when one character is entered
            if ($input.val().length === 1) {
                $input.next('.mfa-input').focus();
            }
            // Move focus to previous input on Backspace
            else if (e.key === "Backspace") {
                $input.prev('.mfa-input').focus();
            }
        });

        // Disable normal paste in the MFA input fields
        inputs.on('paste', function (e) {
            e.preventDefault();
        });

        inputs.on('input', function () {
            this.value = this.value.replace(/\D/g, '');
            if (this.value.length === 1) {
                $(this).next('.mfa-input').focus();
            }
        });

        $('#pasteButton').on('click', function () {
            navigator.clipboard.readText().then(function (text) {
                const code = text.trim();

                if (/^\d{6}$/.test(code)) {
                    $('.mfa-input').each(function (i) {
                        $(this).val(code[i]);
                    });
                    $('.mfa-input').last().focus();
                    $('#mfaError').text('');
                } else {
                    $('#mfaError').text("Clipboard doesn't contain a valid 6-digit code.");
                }
            }).catch(function (err) {
                $('#mfaError').text("Clipboard access denied or not supported.");
            });
        });


        $('#mfaForm').on('submit', function (e) {
            e.preventDefault();
            var code = '';
            $('.mfa-input').each(function () {
                code += $(this).val();
            });
            if (code.length !== 6 || isNaN(code)) {
                $('#mfaError').text("Please enter a valid 6-digit code.");
                return;
            }
            $.ajax({
                type: "POST",
                url: '@Url.Action("ValidateMFA", "Login")',
                data: { code: code },
                success: function (res) {
                    if (res.status === "success") {
                        window.location.href = '@Url.Action("Dashboard", "Dashboard")';
                    } else {
                        $('#mfaError').text("Invalid code. Please try again.");
                        $('.mfa-input').val(''); // Clear inputs
                        $('.mfa-input').first().focus();
                    }
                },
                error: function () {
                    $('#mfaError').text("Something went wrong. Please try again.");
                }
            });
        });
    });
    </script>

