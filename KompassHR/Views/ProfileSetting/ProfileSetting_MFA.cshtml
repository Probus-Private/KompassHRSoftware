@model KompassHR.Areas.Module.Models.Module_Employee.Mas_Employee_ESS

@{
    ViewBag.Title = "Authentication";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<script src="~/assets/js/CaptchaVerification.js"></script>

<style>
    label.error {
        color: red;
        font-size: 12px;
        height: auto;
    }

    .error {
        height: auto;
    }

    .qr-codes {
        margin-top: 10px;
        margin-bottom: 10px;
    }

    .qr-item {
        text-align: center;
        width: 100%;
        margin-bottom: 15px;
    }

        .qr-item img {
            max-width: 100%;
            height: auto;
        }

    .step-list li.qr-codes {
        padding-top: 10px;
        padding-bottom: 10px;
    }

    .step-guide {
        background: linear-gradient(to right, #f0f4ff, #e0ecff);
        border-radius: 16px;
        padding: 25px 20px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        font-family: 'Segoe UI', sans-serif;
        transition: all 0.3s ease-in-out;
        height: 100%;
    }

        .step-guide h5 {
            font-weight: 600;
            margin-bottom: 25px;
            color: #004085;
            font-size: 18px;
            text-align: center;
            border-bottom: 1px solid #cfe2ff;
            padding-bottom: 10px;
        }

    .step-list {
        counter-reset: step-counter;
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .step-list li {
            counter-increment: step-counter;
            position: relative;
            padding: 15px 15px 15px 55px;
            margin-bottom: 18px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            transition: transform 0.2s ease;
            font-size: 14px;
            color: #333;
        }

            .step-list li:hover {
                transform: translateY(-3px);
            }

            .step-list li::before {
                content: counter(step-counter);
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                width: 28px;
                height: 28px;
                background: #007bff;
                color: white;
                border-radius: 50%;
                text-align: center;
                line-height: 28px;
                font-size: 14px;
                font-weight: bold;
                box-shadow: 0 2px 6px rgba(0,0,0,0.2);
            }

    /* Responsive Grid for QR Codes */
    .qr-code-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: space-between;
    }
</style>

<style>
    @@media (max-width: 768px) {
        #QRCode img {
            width: 100% !important;
        }

        .qr-item img {
            width: 60px;
            height: 60px;
        }

        .step-guide {
            font-size: 14px;
        }
    }
</style>

<div id="content" class="app-content">

    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 class="fs-5" style="font-family: roboto;">2FA Authentication</h1>
            <ol class="breadcrumb mb-0">
                <li>
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <!-- Form Area -->
        <div class="col-md-7">
            <div class="panel panel-inverse">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">2FA Authentication - Add</h4>
                </div>
                <div class="panel-body">
                    <form id="2FAForm" action="@Url.Action("Verify2FA", "ProfileSetting")" method="post">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="row mb-3 align-items-center">
                                    <label class="col-md-3 col-form-label">2FA Enable <span class="important">*</span></label>
                                    <div class="col-md-4">
                                        @Html.DropDownListFor(model => model.MFAEnabled, new List<SelectListItem> {
                                            new SelectListItem { Text = "Yes", Value = "True"},
                                            new SelectListItem { Text = "No", Value = "False"},
                                        }, "--Select--", new { id = "ddlMFAEnabled", @class = "form-select", autocomplete = "off" })
                                    </div>
                                    <div class="col-md-4" id="GenerateButton" style="display:none;">
                                        @if (ViewBag.Action == "Reset")
                                        {
                                            <button type="button" class="btn btn-danger btn-sm" id="btnResetCode">Reset</button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-primary btn-sm" id="btnGenerateCode">Generate Code</button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row" id="QRCode" style="display: none;">
                            <div class="col-md-12">
                                <div class="text-center mb-3">
                                    <p>Scan this QR Code with Google Authenticator:</p>
                                    <img src="" class="img-fluid" />
                                    <p>Manual Entry Key: <strong></strong></p>
                                </div>
                                <div class="row align-items-center">
                                    <label class="col-md-3  col-form-label">Enter Code <span class="important">*</span></label>
                                    <div class="col-md-4">
                                        @Html.TextBoxFor(model => model.MFAToken, new
                                   {
                                       @class = "form-control",
                                       type = "text",
                                       id = "MFAToken",
                                       autocomplete = "off",
                                       maxlength = 6
                                   })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <hr />
                    <div class="col-md-12 text-end">
                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-floppy-disk"></i> Submit
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-md-5">
            <div class="step-guide">
                <h5>🔐 Setup 2FA in 6 Easy Steps</h5>
                <ol class="step-list">
                    <li><strong>Select "Yes"</strong> in the 2FA dropdown.</li>
                    <li><strong>Click "Generate Code"</strong> to get your QR.</li>

                    <li>
                        <div class="qr-codes">
                            <p>📲 <strong>Download the Google Authenticator app</strong> by scanning the QR below or searching it in your app store:</p>
                            <div class="d-flex justify-content-between">
                                <!-- QR Code for Android -->
                                <div class="qr-item text-center">
                                    <p><strong>For Android:</strong></p>
                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=80x80&data=https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2" alt="Google Authenticator for Android" />
                                </div>
                                <!-- QR Code for iOS -->
                                <div class="qr-item text-center">
                                    <p><strong>For iOS:</strong></p>
                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=80x80&data=https://apps.apple.com/us/app/google-authenticator/id388497605" alt="Google Authenticator for iOS" />
                                </div>
                            </div>
                        </div>
                    </li>

                    <li>🔍 <strong>Scan the QR code</strong> or enter the key manually inside the app.</li>
                    <li>⌨️ <strong>Type the 6-digit code</strong> shown in the app.</li>
                    <li>✅ <strong>Click Submit</strong> to enable 2FA Authentication</li>
                </ol>

            </div>
        </div>
    </div>

</div>

<!-- Script Logic -->
<script>
    $(document).ready(function () {
        let mfaEnabled = $("#ddlMFAEnabled").val();
        if (mfaEnabled === "True") {
            $("#GenerateButton").show();
        }

        $("#ddlMFAEnabled").trigger("change");

        $("#ddlMFAEnabled").change(function () {
            let value = $(this).val();
            if (value === "True") {
                $("#GenerateButton").show();
                $("#MFAToken").prop("disabled", false);
            } else {
                $("#GenerateButton").hide();
                $("#QRCode").hide();
                $("#MFAToken").val('').prop("disabled", true);
            }
        });

        $("#btnGenerateCode").click(function () {
            $.ajax({
                url: '@Url.Action("GenerateQRCode", "ProfileSetting")',
                type: 'POST',
                data: { forceReset: false },
                success: function (response) {
                    if (response.success) {
                        $("#QRCode").show();
                        $("#QRCode img").attr("src", response.barcodeImageUrl);
                        $("#QRCode strong").text(response.manualEntryKey);
                        $("#MFAToken").prop("disabled", false);
                    } else {
                        swal("Info", response.message, "info");
                    }
                },
                error: function () {
                    swal("Error", "Something went wrong while generating the QR code.", "error");
                }
            });
        });

        $("#btnResetCode").click(function () {
            $.ajax({
                url: '@Url.Action("GenerateQRCode", "ProfileSetting")',
                type: 'POST',
                data: { forceReset: true },
                success: function (response) {
                    if (response.success) {
                        $("#QRCode").show();
                        $("#QRCode img").attr("src", response.barcodeImageUrl);
                        $("#QRCode strong").text(response.manualEntryKey);
                        $("#MFAToken").prop("disabled", false);
                        $("#btnResetCode").hide();
                    } else {
                        swal("Error", response.message, "error");
                    }
                },
                error: function () {
                    swal("Error", "Something went wrong during reset.", "error");
                }
            });
        });
    });

    jQuery.validator.addMethod(
    "regex",
        function (value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        }, "erreur expression reguliere"
     );

    $('#2FAForm').validate({
        rules: {
            MFAEnabled: { required: true },
            MFAToken: {
                required: function () {
                    return $("#ddlMFAEnabled").val() === "True";
                },
                digits: true,
                minlength: 6,
                maxlength: 6
            }

        },
        messages: {
            MFAEnabled: { required: "Please select MFA option" },
            MFAToken: {
                required: "Enter 6-digit code",
                digits: "Only digits allowed",
                minlength: "Code must be 6 digits",
                maxlength: "Code must be 6 digits"
            }
        }
    });

    //var form = $("#MFAForm");
    //form.validate({
    //    rules: {
    //        MFAEnabled: { required: true },
    //        MFAToken: {
    //            required: function () {
    //                return $("#ddlMFAEnabled").val() === "True";
    //            },
    //            digits: true,
    //            minlength: 6,
    //            maxlength: 6
    //        }
    //    },
    //    messages: {
    //        MFAEnabled: { required: "Please select MFA option" },
    //        MFAToken: {
    //            required: "Enter 6-digit code",
    //            digits: "Only digits allowed",
    //            minlength: "Code must be 6 digits",
    //            maxlength: "Code must be 6 digits"
    //        }
    //    }
    //});

    var form = $("#2FAForm");
    form.validate();
    $("#btnSubmit").click(function () {
        form.valid();
        if (form.valid() == false)
        {
            return false;
        }

        $.ajax({
            url: '@Url.Action("Verify2FA", "ProfileSetting")',
            type: 'POST',
            data: form.serialize(),
            success: function (response) {
                debugger
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        text: response.message,
                        width: '400px',
                        allowOutsideClick: false,
                        showConfirmButton: true,
                        confirmButtonText: 'OK'
                    }).then(function () {
                        window.location.href = '@Url.Action("ProfileSetting_MFA", "ProfileSetting")';
                    });
                } else {
                    debugger
                    Swal.fire({
                        icon: 'error',
                        text: response.message,
                        width: '400px',
                        allowOutsideClick: false,
                        showConfirmButton: true,
                        confirmButtonText: 'OK'
                    });
                }
            },
            error: function () {
                debugger
                Swal.fire({
                    icon: 'error',
                    text: "An unexpected error occurred.",
                    width: '400px',
                    allowOutsideClick: false,
                    showConfirmButton: true,
                    confirmButtonText: 'OK'
                });
            }
        });
    });
</script>
