<style>

  .fixed-header-wrapper {
  max-height: 400px;
  overflow-y: auto;  
  overflow-x: hidden; 
}

.fixed-header-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  table-layout: fixed;
}

.fixed-header-wrapper th {
  position: sticky;
  top: 0;
  z-index: 2;
  background: #f1f1f1;
  box-shadow: inset 0 -1px 0 lightgray;
}


.table-scroll {
  table-layout: fixed;
  width: 100%;
}
.tbody-scroll .table-scroll {
    border-top: none; 
}
.table-scroll th,
.table-scroll td {
  width: 25%; 
  padding: 5px 10px;
  border: 1px solid lightgray;
  background: #fff;
  white-space: nowrap;
  vertical-align: middle;

}

.table-scroll th:nth-child(2),
.table-scroll td:nth-child(2),
.table-scroll th:nth-child(3),
.table-scroll td:nth-child(3) {
  text-align: center;
  white-space: nowrap;

}

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }
  .custom-group {
  display: flex;
  align-items: center;
}

.custom-group .file-input {
  flex: 0 1 200px; 
}

.custom-group .submit-btn {
  flex: 0 1 120px;
  white-space: nowrap;
}
.file-input {
  flex: 0 1 200px;
}

.submit-btn {
  flex: 0 1 120px;
}

</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Mas Employee Import And Export
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_UserAccessPolicy_Menu", "Setting_UserAccessPolicy_Menu", new {id = 32, ScreenId=121, area = "Setting"})">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Mas Employee Import Export - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        The Import and Export Employee feature enables quick bulk transfer of employee data to and from the system.

                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <!-- BEGIN table-responsive -->
                        @*<form id="exportForm" method="post" action="@Url.Action("DownloadExcelFile", "Setting_MasEmployee_Export")">*@

                        <form role="form" action='@Url.Action("Setting_MasEmployee_Export", "Setting_MasEmployee_Export", new { area = "Setting" })' id="exportForm" method="post">

                            <input type="hidden" name="selectedFieldsJson" id="selectedFields" />

                            <div class="table-scroll div1">
                                <div class="fixed-header-wrapper">
                                    <div class="table-wrap" style="height: 350px; overflow-y: auto;">

                                      @{
                                      string currentTable = null;
                                      Dictionary<string, string> tableNameMap = new Dictionary<string, string>
                                      {
                                      { "Mas_Employee", " Employee Information" },
                                      { "Mas_Employee_ESS", "Login Information" },
                                      { "Mas_Employee_Personal", "Personal Information" },
                                      { "Mas_Employee_Address", "Address Information" },
                                      { "Mas_Employee_Statutory", "Statutory Information" },
                                      {"Mas_Employee_Attendance","Attendance Information" },
                                      {"Mas_Employee_Bank","Bank Information" }
                                      };
                                      }

                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="EmployeeExportTable">
                                            <thead>
                                                <tr class="trheading text-center">
                                                    <th class="text-nowrap text-center">Field</th>
                                                 
                                                    <th class="text-nowrap text-center">
                                                        Select Fields For Export
                                                        <input type="checkbox" class="form-check-input" id="SelectAll" onchange="toggleColumn(this)" />
                                                        (All)
                                                    </th>
                                                    <th class="text-nowrap text-center">
                                                        Confirm Check
                                                        <input type="checkbox" class="form-check-input" id="SelectAllConfirm" onchange="toggleColumn(this)" />
                                                        (All)
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody class="table-scroll">
                                                @foreach (var d in ViewBag.GetEmployeeList)
                                        {
                                            if (currentTable != d.TableName)
                                            {
                                                currentTable = d.TableName;

                                                string displayName = tableNameMap.ContainsKey(currentTable) ? tableNameMap[currentTable] : currentTable;
                                        <tr>
                                            <td colspan="3" class="text-center fw-bold" style="background-color:#fff4b3">@displayName</td>
                                        </tr>
                                            }
                                        <tr>
                                            <td class="text-center-left">@d.COLUMN_NAME</td>
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input email-checkbox" value="@d.COLUMN_NAME" />
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input confirm-checkbox" value="@d.COLUMN_NAME" />
                                            </td>
                                        </tr>
                                        }
                                            </tbody>
                                        </table>


                                    </div>
                                </div>
                            </div>


                            <!-- END panel -->

                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-10">
                                        </div>
                                        <div class="col-md-2">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                        <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />

                            <div class="row">
                                <div class="col-md-8 offset-md-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="file" name="AttachFile" class="form-control form-control-sm file-input" id="AttachFile" onchange="ResetFile()" />

                                        <button type="button" onclick="GetEmployee('Excel')" class="btn btn-primary btn-sm submit-btn">
                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                        </button>
                                    </div>
                                    <span id="validationMessage" class="text-danger small"></span>
                                </div>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

 <script>
     function toggleColumn(master) {
         const thCell = master.closest('th');
         const colIndex = thCell.cellIndex;
         const table = thCell.closest('table');
         const rows = table.tBodies[0].rows;

         for (let row of rows) {
             const cell = row.cells[colIndex];
         // Skip this row if the cell is missing or has a colspan > 1
             if (!cell || cell.colSpan > 1) continue;

             const cb = cell.querySelector('input[type="checkbox"]');
             if (cb) cb.checked = master.checked;
         }
     }

 </script>

<script>
    function downloadExcelFile() {
     debugger
     const rows = Array.from(document.querySelectorAll('#EmployeeExportTable tbody tr'));
      const selected = rows
        .filter(tr => {
          const check = tr.querySelector('td:nth-child(2) input[type="checkbox"]');
          //const confirm = tr.querySelector('td:nth-child(3) input[type="checkbox"]');
            //return (check && check.checked) && (confirm && confirm.checked);
          return (check && check.checked)
        })
        .map(tr => {
          const td = tr.querySelector('td:first-child');
          return td ? td.innerText.trim() : '';
        })
        .filter(name => name !== '');

      //if (selected.length === 0) {
      //  alert('Please check  at least one field.');
      //  return;
        //  }

      if (selected.length === 0) {
          Swal.fire({ 
              icon: "info", 
              text: "Please check at least one field.",
              allowOutsideClick: false,
              allowEscapeKey: false
          });
          return; 
      }

      document.getElementById('selectedFields').value = JSON.stringify(selected);
      const form = document.getElementById('exportForm');
      form.action = '@Url.Action("DownloadExcelFile", "Setting_MasEmployee_Export", new { area = "Setting" })';
      form.submit();
    }

    </script>

<script>
  $(document).ready(function () {
    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

    if (Message) {
      Swal.fire({
        icon: Icon,
        text: Message,
        allowOutsideClick: () => {
          const popup = Swal.getPopup();
          popup.classList.remove('swal2-show');
          setTimeout(() => {
            popup.classList.add('animate__animated', 'animate__headShake');
          });
          setTimeout(() => {
            popup.classList.remove('animate__animated', 'animate__headShake');
          }, 500);
          return false;
        }
      });
    }
  });
  function GetEmployee(type) {
    const fileInput = $("#AttachFile");
    const validationMsg = $("#validationMessage");
    const file = fileInput[0].files[0];
    validationMsg.text("");
  
    if (!file) {
      validationMsg.text("Please select an Excel file.");
      return;
    }
    const ext = file.name.split('.').pop().toLowerCase();
    if (!['xls', 'xlsx'].includes(ext)) {
      validationMsg.text("Only Excel files (.xls, .xlsx) are allowed.");
      return;
    }
    $(".Userloaderbg").css("display", "flex");
    const formData = new FormData();
    formData.append("AttachFile", file);

    fetch('/Setting/Setting_MasEmployee_Export/UploadExcel', {
      method: 'POST',
      body: formData,
      credentials: 'same-origin'
    })
    .then(response => {
      if (!response.ok) {
        throw new Error("Server returned " + response.status);
      }
      return response.json();
    })
    .then(data => {
      Swal.fire({
        icon: data.Icon || "info",
        text: data.Message || "Excel File Should not be Empty."
      });
      fileInput.val("");
    })
    .catch(err => {
      console.error("Upload error:", err);
      Swal.fire({
        icon: "error",
        text: "File upload failed."
      });
    })
    .finally(() => {
        $(".Userloaderbg").css("display", "none");
    });
  }
</script>




