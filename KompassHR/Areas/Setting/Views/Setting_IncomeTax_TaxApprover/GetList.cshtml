<head>
    <meta name="viewport" content="width=device-width" />
    <title>Tax Approver List</title>
</head>
<body>
    <div id="content" class="app-content">
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
                <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                    Tax Approver
                </h1>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Setting_IncomeTax_Menu", "Setting_IncomeTax_Menu", new { id = 9, ScreenId =74, area = "Setting" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                        </a>
                    </li>
                </ol>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                     <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title"> Tax Approver - List</h4>
                       
                    </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            This is the list of Tax Approver created.
                        </p>
                    </div>
                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="@Url.Action("Setting_IncomeTax_TaxApprover", "Setting_IncomeTax_TaxApprover", new { area = "Setting" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                               style="width: 100%;">
                                            <thead>
                                                <tr>

                                                    <th class="fixed-side">Update</th>
                                                    <th class="fixed-side1">Delete</th>
                                                    <th class="text-nowrap">Business Unit </th>
                                                    <th class="text-nowrap">Employee Name </th>
                                                    <th class="text-nowrap">Mobile Number </th>
                                                    <th class="text-nowrap">Email ID </th>
                                                    <th class="text-nowrap">Created By</th>
                                                    <th class="text-nowrap">CreatedDate</th>
                                                    <th class="text-nowrap">Modifiy By</th>
                                                    <th class="text-nowrap">Modified Date</th>
                                                    <th class="text-nowrap">Machine Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetTaxApproverList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-Dark" onclick="Update('@d.TaxApproverId_Encrypted')" id="btnUpdate" style="cursor: pointer;"></i>
                                                        </td>
                                                        <td class="text-center">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg" onclick="Delete('@d.TaxApproverId_Encrypted')" id="btnDelete" style="cursor: pointer;"></i>
                                                        </td>
                                                        <td>@d.BranchName</td>
                                                        <td>@d.EmployeeName</td>
                                                        <td>@d.CompanyMobileNo</td>
                                                        <td>@d.CompanyEmailID</td>
                                                        <td>@d.CreatedBy</td>
                                                        <td>@d.CreatedDate</td>
                                                        <td>@d.ModifiedBy</td>
                                                        <td>@d.ModifiedDate</td>
                                                        <td>@d.MachineName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</body>
</html>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });

</script>

<script>
    function Update(TaxApproverID_Encrypted) {
        var url = '@Url.Action("Setting_IncomeTax_TaxApprover", "Setting_IncomeTax_TaxApprover")?TaxApproverID_Encrypted=' + TaxApproverID_Encrypted;
        window.location.href = url;
    }

    function Delete(TaxApproverID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_IncomeTax_TaxApprover")?TaxApproverID_Encrypted=' + TaxApproverID_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>
