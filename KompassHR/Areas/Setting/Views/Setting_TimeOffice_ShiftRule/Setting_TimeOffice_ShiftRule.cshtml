<script>
    $(document).ready(function () {
        $("#ddlCompanyName").select2();
        $("#ddlBusinessUnit").select2();
        $("#ddlOTCalculation").select2();

        if ($('input[name="IsMaxOT"]').is(':checked')) {
            $('#txtMaxOT').attr('readonly', false);
            var inputVal = document.getElementById("txtMaxOT");
            inputVal.style.background = "#ffffff";
        }
        if ($('input[name="IsMarkHalfDayForLate"]').is(':checked')) {
            $('#txtHalfDayLateByMins').attr('readonly', false);
            var inputVal = document.getElementById("txtHalfDayLateByMins");
            inputVal.style.background = "#ffffff";
        }
        if ($('input[name="IsMarkHalfdayForEarlyGoing"]').is(':checked')) {
            $('#txtHalfDayEarlyGoingMins').attr('readonly', false);
            var inputVal = document.getElementById("txtHalfDayEarlyGoingMins");
            inputVal.style.background = "#ffffff";
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $("#ddlCompanyName").on("change", function () {
            $("#ddlBusinessUnit").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_TimeOffice_ShiftRule")',
                //url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        $("#ddlBusinessUnit").append("<option value=0> --Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBusinessUnit").append();
                            $("#ddlBusinessUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        });


    });//ready function



    $('#txtMaxOT').keyup(function()  {
        debugger;
        var MinOT = Number($('#txtMinOT').val());
        var MaxOT = Number($('#txtMaxOT').val());
        if(MinOT > MaxOT)
        {
            $('#ErrortxtMaxOT').html("Max OT should be less than Min OT");
            return false;
        }
        else{
            $('#ErrortxtMaxOT').html("");
        }
    });
</script>

<script>





    $("#ChkIsMaxOT").change(function () {
        debugger;
        var inputVal = document.getElementById("txtMaxOT");
        if ($('#ChkIsMaxOT').is(":checked")) {
            $('#txtMaxOT').attr('readonly', false);
            inputVal.style.backgroundColor = "";
        }
        else
        {
            $('#txtMaxOT').attr('readonly', true);
            inputVal.style.backgroundColor = "#F5F5F5";
