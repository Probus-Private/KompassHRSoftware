        if ($('#ChkIsMarkHalfdayForEarlyGoing').is(":checked")) {
            $('#txtHalfDayEarlyGoingMins').attr('readonly', false);
            inputVal.style.backgroundColor = "";
        }
        else
        {
            $('#txtHalfDayEarlyGoingMins').attr('readonly', true);
            inputVal.style.backgroundColor = "#F5F5F5";
        }
    });
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
        "regex",
         function(value, element, regexp) {
             if (regexp.constructor != RegExp)
                 regexp = new RegExp(regexp);
             else if (regexp.global)
                 regexp.lastIndex = 0;
             return this.optional(element) || regexp.test(value);
         },"erreur expression reguliere"
      );
    $("#TimeOffice_ShiftRule").validate({
        rules: {
            CmpId:{
                required: true,
            },
            ShiftRuleBranchId:{
                required: true,
            },
            ShiftRuleName: {
                required: true,
            },
            ShiftRuleSName: {
                required: true,
            },
            OTFormula: {
                required: true,
            },
          
            //MinOT: {
            //    required: true,

            //},
            MaxOT: {
                required: true,
            },
            FullDayDuration: {
                required: true,
            },
            HalfDayDuration: {
                required: true,
            },
            HalfDayEarlyGoingMins: {
                required: true,
            },
            OTCalculation:{
                required: true,
            },
        },
        messages: {
            CmpId:{
                required: "Company name is required",
            },
            ShiftRuleBranchId:{
                required: "Business unit is required",
            },
            ShiftRuleName: {
                required: "Shift rule name is required",
            },
            ShiftRuleSName: {
                required: "Shift rule short name  is required",
            },
            OTFormula: {
                required: "OT formula is required",
            },
            //MinOT: {
            //    required: "Min OT is required",
            //},
            MaxOT: {
                required: "Max OT is required",
            },
            FullDayDuration: {
                required: "Full day duration is required",
            },
            HalfDayDuration: {
                required: "Half day duration is required",
            },
            HalfDayEarlyGoingMins: {
                required: "Half day erly going min is required",
            },
            OTCalculation:{
                required: "OT calculation is required",
            },
        }

    });

    var form = $("#TimeOffice_ShiftRule");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var ShiftRuleSName=$("#txtShiftRuleSName").val();
        var CmpId=$("#ddlCompanyName").val();
        var ShiftRuleBranchId=$("#ddlBusinessUnit").val();
        var ShiftRuleName=$("#txtShiftRuleName").val();
        var ShiftRuleId_Encrypted=$("#ShiftRuleId_Encrypted").val();
        var OTFormula=$("#ddlOTFormula").val();
        var MinOT=$("#txtMinOT").val();
        if(ShiftRuleBranchId==0)
        {
            $("#ErrorShiftRuleBranchId").html("Business unit is required"); return false;
        }
        else
        {
            $("#ErrorShiftRuleBranchId").html("");
        }
        if(OTFormula=="OT Not Applicable")
        {
            $("#ErrorMinOT").html("");

        }
        else
        {
            if(MinOT=="")
            {
                $("#ErrorMinOT").html("Min OT is required"); return false;
            }
            else{
                $("#ErrorMinOT").html("");
            }
        }

        $.ajax({
            url: '@Url.Action("IsShiftRuleExists", "Setting_TimeOffice_ShiftRule")',
            //url: "IsShiftRuleExists",
            method:"get",
            data :{ShiftRuleName:ShiftRuleName,ShiftRuleId_Encrypted:ShiftRuleId_Encrypted,ShiftRuleSName:ShiftRuleSName,ShiftRuleBranchId:ShiftRuleBranchId,CmpId:CmpId},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#TimeOffice_ShiftRule").submit();
                }
            }
        });

    });
</script>
