        if ($('#ChkIsMarkHalfDayForLate').is(":checked")) {
            $('#txtHalfDayLateByMins').attr('readonly', false);
            inputVal.style.backgroundColor = "";
        }
        else
        {
            $('#txtHalfDayLateByMins').attr('readonly', true);
            inputVal.style.backgroundColor = "#F5F5F5";
