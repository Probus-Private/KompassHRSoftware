                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.AccidentDetailSubUnitId, new SelectList(ViewBag.SubUnitList, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlAccidentDetailSubUnitId", type = "text", name = "AccidentDetailSubUnitId", autocomplete = "Off" })
