</div>

<script>
    $(document).ready(function () {
        var table = document.getElementById("tblrptActualLog");
        var rowCount = table.rows.length -1;
        $("#tblRowCount").html("No Of Rows : " + rowCount);
        var FD = document.getElementById("FromDate").value;
        var TD = document.getElementById("ToDate").value;
        $('title').html("Actual Log Report ("+FD+"To"+TD+")");

        var CheckEmptyDate = document.getElementById('FromDate').value;
        if (CheckEmptyDate == "") {
            document.getElementById('FromDate').value = SetTodaysDate;
            document.getElementById('ToDate').value = SetTodaysDate;
        }

      
        $("#ddlCmpId").select2();
        $("#ddlAccidentDetailBranchId").select2();
        $("#ddlAccidentDetailSubUnitId").select2();
        $("#ddlAccidentDetailShiftId").select2();
        $("#ddlLineId").select2();
        $("#ddlGradeId").select2();
        $("#ddlEmployeeID").select2();
        $("#ddlSubUnit").select2();
       
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlAccidentDetailBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_Safety_AccidentDetails")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        var Branch = data.Branch;
                        $("#ddlAccidentDetailBranchId").append("<option value=''>All </option>");
                        $.each(Branch, function (i, p) {
                            $("#ddlAccidentDetailBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#ddlAccidentDetailBranchId").on("change", function () {
            debugger;
            $("#ddlAccidentDetailSubUnitId").find("option").remove();
            $("#ddlAccidentDetailShiftId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var UnitBranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetUnit", "Setting_Safety_AccidentDetails")',
                data: { CmpId: CmpId, BranchId: BranchId },
                success: function (data) {
                    debugger;
                    if (data == false) {
                        $("#ddlAccidentDetailSubUnitId").find("option").remove();
                        $("#ddlAccidentDetailShiftId").find("option").remove();
                        $("#ddlAccidentDetailSubUnitId").append("<option value=''>All </option>");
                        $("#ddlAccidentDetailShiftId").append("<option value=''>All </option>");
                    }
                    else {
                        var ShiftNameGet = data.ShiftNameGet;
                        var List_SubUnit = data.List_SubUnit;
                      
                        if (List_SubUnit != null) {
                            $("#ddlAccidentDetailSubUnitId").append("<option value=''>All </option>");
                            $.each(List_SubUnit, function (i, p) {
                                $("#ddlAccidentDetailSubUnitId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                        debugger;
                        if (ShiftNameGet != null) {
                            $("#ddlAccidentDetailShiftId").append("<option value=''>All </option>");
                            $.each(ShiftNameGet, function (i, p) {
                                $("#ddlAccidentDetailShiftId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                    }
                }
            })
        });

    });//Ready Funcation
</script>




