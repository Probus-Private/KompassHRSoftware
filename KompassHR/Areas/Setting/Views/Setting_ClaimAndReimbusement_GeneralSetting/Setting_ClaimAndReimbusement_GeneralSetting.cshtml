<script>
    $(document).ready(function () {
        $("#txtCmpId").select2();
        $("#formReset").click(function () {
            $("#SaveEmergencyContact")[0].reset()
        })
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

    });
</script>




<script>
    $("#ddlToDay").change(function()
    {
        var FromDay = Number($('select#ddlFromDay option:selected').val());
        var ToDay =Number($('select#ddlToDay option:selected').val());
        if(ToDay<FromDay)
        {
            $("#ErrorToDay").html("ToDay should not be less than fromday");
            return false;
        }
        else{
            $("#ErrorToDay").html("");
        }
    });

    $("#ddlFromDay").change(function()
    {
        debugger;
        var FromDay = Number($('select#ddlFromDay option:selected').val());
        var ToDay =Number($('select#ddlToDay option:selected').val());
        if(ToDay<FromDay)
        {
            $("#ErrorToDay").html("ToDay should not be less than fromday");
            return false;
        }
        else{
            $("#ErrorToDay").html("");
        }
    });


    var form = $("#SaveGeneralSetting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var CompanyName=$("#txtCmpId").val();
        var ClaimIDEncrypted = $("#ClaimSettingIDEncrypted").val();
        $.ajax({
            url: '@Url.Action("isCliamGernalSettingAlreadyExists", "Setting_ClaimAndReimbusement_GeneralSetting")',
            method:"get",
            data:{CompanyName:CompanyName,ClaimIDEncrypted:ClaimIDEncrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveGeneralSetting").submit();
                }
            }
        });


        $("#formReset").click(function () {
            $("#SaveContractorCreaction")[0].reset();
        })

    });


    $("#txtCmpId").change(function(){
        debugger;
        var CompanyId =  $('#txtCmpId').find(":selected").val();
        //$("#ddlFromDay:selected").remove();
        //$("#ddlToDay:selected").remove();
        $.ajax({
            url: '@Url.Action("CompanyName", "Setting_ClaimAndReimbusement_GeneralSetting")',
            method:"get",
            data:{CompanyId:CompanyId},
            success:function(GetFormdaytoday){
                debugger;
                if(GetFormdaytoday !="")
                {
                    $("#ddlFromDay").find("option").remove();
                    $("#ddlToDay").find("option").remove();
                    for(var i=0; i<GetFormdaytoday.length; i++)
                    {
                        $("#ddlFromDay").append("<option value='" + GetFormdaytoday[0].ClaimSettingID +"'>" + GetFormdaytoday[0].FromDay +"</option>");
                        $("#ddlToDay").append("<option value='" + GetFormdaytoday[0].ClaimSettingID +"'>" + GetFormdaytoday[0].ToDay +"</option>");
                    }
                    //$.each(GetFormdaytoday, function(i, p) {
                    //    $("#ddlFromDay").append("<option value='" + GetFormdaytoday[0].ClaimSettingID +"'>" + GetFormdaytoday[0].FromDay +"</option>");
                    //    $("#ddlToDay").append("<option value='" + GetFormdaytoday[0].ClaimSettingID +"'>" + GetFormdaytoday[0].ToDay +"</option>");
                    //});
                }
                else
                {
                    $("#ddlFromDay").find("option").remove();
                    $("#ddlToDay").find("option").remove();
                    $("#ddlFromDay").append("<option value=0>--Select-- </option>");
                    $("#ddlToDay").append("<option value=0>--Select-- </option>");
                    for(var i=1; i<32; i++)
                    {
                        $("#ddlFromDay").append("<option value='" + i +"'>" + i +"</option>");
                        $("#ddlToDay").append("<option value='" + i +"'>" + i +"</option>");
                    }
                    //document.getElementById('ddlFromDay').options.length=0;
                    //$("#ddlFromDay option").prop("selected", function(e){
                    //    return this.preventDefault();
                    //});
                    //$("#ddlToDay option").prop("selected", function(){
                    //    return this.preventDefault();
                    //});
                    //$("#ddlFromDay").append("<option value=0>--Select--</option>");
                    //$("#ddlToDay").append("<option value=0>--Select--</option>");
                    return false;
                }
            }
        });

    });
</script>



