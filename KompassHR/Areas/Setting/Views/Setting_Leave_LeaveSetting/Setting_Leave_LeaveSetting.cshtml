    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var LeaveGroup = $("#txtLeaveSettingLeaveGroupId").val();
        var LeaveTypeName = $("#txtLeaveSettingLeaveTypeId").val();
        var LeaveSettingId_Encrypted = $("#LeaveSettingId_Encrypted").val();
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            url: "IsLeaveSettingExists",
            method: "get",
            data: { LeaveGroup: LeaveGroup, LeaveTypeName: LeaveTypeName, LeaveSettingId_Encrypted: LeaveSettingId_Encrypted },
            success: function (response) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else {
                    $(".Userloaderbg").css("display", "flex");
                    $("#SaveLeaveSetting").submit();
                }
            }
        });

    });





