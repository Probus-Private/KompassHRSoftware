<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Leave_Menu", "Setting_Leave_Menu", new { id = 4, ScreenId =44, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave Setting - Add </h4>
                   
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define leave setting here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_Leave_LeaveSetting", new { area = "Setting" })'  id="SaveLeaveSetting" method="post" data-parsley-validate="true">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyname, "Id", "Name"), "--Select--", new { id = "CmpId", @class = "form-select", autocomplete = "off", name = "CmpId " })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Leave Group
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveSettingLeaveGroupId, new SelectList(ViewBag.LeaveGroups, "Id", "Name"), "--Select--", new { @class = "form-control", id = "txtLeaveSettingLeaveGroupId", name = "LeaveSettingLeaveGroupId", type = "text", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Leave Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveSettingLeaveTypeId, new SelectList(ViewBag.LeaveType, "LeaveTypeId", "LeaveTypeName"), "--Select--", new { @class = "form-control", id = "txtLeaveSettingLeaveTypeId", name = "LeaveSettingLeaveTypeId", type = "text", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Per Year Leave
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.YearlyLeave, new { @class = "form-control", type = "text", id = "txtYearlyLeave", autocomplete = "Off", name = "YearlyLeave" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @*<div class="row">

                                    </div>*@
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Monthly Limit
                                            </label>
                                            <div class="col-md-4 d-flex align-items-center">
                                                @Html.CheckBoxFor(model => model.IsMonthlyLimit)
                                                &nbsp; &nbsp;<label class="form-check-label form-label">
                                                    Then Max
                                                    Leave
                                                    Per Month
                                                </label>
                                            </div>
                                            <div class="col-md-2">
                                                @Html.TextBoxFor(model => model.MonthlyMaxLeave, new
                                           {
                                               @class = "form-control",
                                               type = "number",
                                               id = "txtMonthlyMaxLeave",
                                               autocomplete = "Off",
                                               name = "MonthlyMaxLeave"@*, onkeypress = "return event.charCode >=48"*@ })
                                                @Html.ValidationMessageFor(model => model.MonthlyMaxLeave, "", new { @class = "help-block", id = "ErrorMonthlyMaxLeave", @style = "color:red" })
                                            </div>

                                            @*<div class="col-md-2">

                                                    &nbsp; <label class="form-check-label form-label">
                                                        Active
                                                    </label>
                                                </div>*@

                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Carry Forward
                                            </label>
                                            <div class="col-md-4 d-flex align-items-center">
                                                @Html.CheckBoxFor(model => model.IsCarryforward)
                                                &nbsp; &nbsp;
                                                @Html.DropDownListFor(model => model.CarryforwardBalanceOrMax, new List
                                                <SelectListItem>
                                                {
                                                   new SelectListItem { Text = "Balance Carry Forward",Value = "true"},
                                                   new SelectListItem { Text = "Max Carry Forward Leave",Value = "false"}
                                                   }, "--Select--",
                                                   new { @class = "form-select", @id = "txtCarryforwardBalanceOrMax", @name = "CarryforwardBalanceOrMax" })
                                            </div>
                                            <div class="col-md-2">
                                                @Html.TextBoxFor(model => model.CarryforwardMaxLeave, new { @class = "form-control", type = "number", id = "txtCarryforwardMaxLeave", autocomplete = "Off", name = "CarryforwardBalanceOrMax", onkeypress = "return event.charCode >=48" })
                                                @Html.ValidationMessageFor(model => model.CarryforwardMaxLeave, "", new { @class = "help-block", @id = "ErrorCarryforwardMaxLeave", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Encashment
                                            </label>
                                            <div class="col-md-4 d-flex align-items-center">
                                                @Html.CheckBoxFor(model => model.IsEncashment)
                                                &nbsp; &nbsp;
                                                @Html.DropDownListFor(model => model.EncashmentdBalanceOrMax, new List
                                                <SelectListItem>
                                                {
                                                   new SelectListItem { Text = "Balance Encashment",Value = "true"},
                                                   new SelectListItem { Text = "Max Encashment Leave",Value = "false"}
                                                   }, "--Select--",
                                                   new { @class = "form-select", @id = "EncashmentdBalanceOrMax", @name = "EncashmentdBalanceOrMax" })
                                            </div>
                                            <div class="col-md-2">
                                                @Html.TextBoxFor(model => model.EncashmentMaxLeave, new { @class = "form-control", type = "number", id = "txtEncashmentMaxLeave", autocomplete = "Off", name = "EncashmentdBalanceOrMax", onkeypress = "return event.charCode >=48" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="col-md-4"></label>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.IsSandwich)
                                                &nbsp; <label class="form-check-label form-label">
                                                    Sandwich Rule
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="col-md-4"></label>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.IsAfterConfirmation)
                                                &nbsp; <label class="form-check-label form-label">
                                                    Application
                                                    After Confirmation
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Color
                                            </label>
                                            <div class="col-md-2">
                                                <input type="color" name="color" class="form-control">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsDocRequired)
                                                &nbsp; <label class="form-check-label form-label">
                                                    Is Attachment
                                                    Required
                                                </label>
                                            </div>
                                            <div class="col-md-2">
                                                @Html.TextBoxFor(model => model.IsAfterDays, new { @class = "form-control", type = "number", id = "txtIsAfterDays", autocomplete = "Off", name = "EncashmentdBalanceOrMax", onkeypress = "return event.charCode >=48" })
                                            </div>
                                            <label class="form-label col-form-label col-md-4"> Days </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsAutoApproval)
                                                &nbsp; <label class="form-check-label form-label">
                                                    Is Auto
                                                    Approval
                                                    Required
                                                </label>
                                            </div>
                                            <div class="col-md-2">
                                                @Html.TextBoxFor(model => model.IsAutoApprovalAfterDays, new { @class = "form-control", type = "number", id = "txtIsAutoApprovalAfterDays", autocomplete = "Off", name = "EncashmentdBalanceOrMax", onkeypress = "return event.charCode >=48" })
                                            </div>
                                            <label class="form-label col-form-label col-md-4"> Days </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsHalfDayAllow)
                                                &nbsp;
                                                <label class="form-check-label form-label">
                                                    Is Half Day
                                                    Allow
                                                    Required
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsActivate)
                                                @Html.HiddenFor(model => model.LeaveSettingId_Encrypted)
                                                &nbsp;
                                                <label class="form-check-label form-label">
                                                    Is Active
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row IsMonthlyCreadit">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsMonthlyCreadit)
                                                &nbsp;
                                                <label class="form-check-label form-label">
                                                    Is Monthly Credit
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                @*<div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Auto Approval (in Days)
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.AutoApprovalDays, new { @class = "form-control", type = "text", id = "txtAutoApprovalDays", autocomplete = "Off", name = "AutoApprovalDays" })
                                            </div>
                                        </div>
                                    </div>
                                </div>*@
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Minimum Leave
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MinLeave, new { @class = "form-control", type = "text", Value = Model.MinLeave == null ? 0 : Model.MinLeave,  id = "txtMinLeave", autocomplete = "Off", name = "MinLeave" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Maximum Leave
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MaxLeave, new { @class = "form-control", type = "text", Value = Model.MinLeave == null ? 0 : Model.MaxLeave, id = "txtMaxLeave", autocomplete = "Off", name = "MaxLeave" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Back Date Days
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.BackDateDays, new { @class = "form-control", type = "text", id = "txtBackDateDays", autocomplete = "Off", name = "BackDateDays" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Future Date Days
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FutureDateDays, new { @class = "form-control", type = "text", id = "txtFutureDateDays", autocomplete = "Off", name = "FutureDateDays" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Leave_LeaveSetting", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnLeaveList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>





<script>
    $("#btnLeaveList").click(function () {
        var url = '@Url.Action("GetList", "Setting_Leave_LeaveSetting")';
        window.location.href = url;
    });


    $(document).ready(function () {
        $("#CmpId").select2();
        $("#txtLeaveSettingLeaveGroupId").select2();
        $("#txtLeaveSettingLeaveTypeId").select2();
        $('#txtCarryforwardBalanceOrMax').attr('disabled', true);
        $('#txtCarryforwardMaxLeave').attr('disabled', true);
        $('#EncashmentdBalanceOrMax').attr('disabled', true);
        $('#txtEncashmentMaxLeave').attr('disabled', true);
        $("#txtIsAfterDays").attr('disabled',true);
        $('#txtIsAutoApprovalAfterDays').attr('disabled', true);
        $('#txtMonthlyMaxLeave').attr('disabled', true);
        if( $("#IsEncashment").is(":checked"))
        {
            $('#txtCarryforwardBalanceOrMax').val();
        }
        else
        {
            $('#txtCarryforwardBalanceOrMax').val("");
        }

        if( $("#IsEncashment").is(":checked"))
        {
            $('#EncashmentdBalanceOrMax').val();
        }
        else
        {
            $('#EncashmentdBalanceOrMax').val("");
        }

        debugger;
        var CheckIsMonthlyCreadit = @Html.Raw(Json.Encode(TempData["CheckIsMonthlyCreadit"]));
        if (CheckIsMonthlyCreadit==true) {
            $('.IsMonthlyCreadit').show();  // show the div if true
        } else {
            $('.IsMonthlyCreadit').hide();  // hide the div if false/null
        }
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        $("#CmpId").on("change", function () {
            debugger;
            $("#txtLeaveSettingLeaveGroupId").find("option").remove();
            var CmpId = $("#CmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetLeaveGroup',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#txtLeaveSettingLeaveGroupId").append("<option value=0> --Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#txtLeaveSettingLeaveGroupId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });




        debugger;
        var LeaveSetting = @Html.Raw(Json.Encode(ViewBag.LeaveSetting));
        if(LeaveSetting!=null)
        {
            var MonthlyLimit=LeaveSetting.IsMonthlyLimit;
            var IsCarryforward=LeaveSetting.IsCarryforward;
            var CarryforwardBalanceOrMax=LeaveSetting.CarryforwardBalanceOrMax;
            var IsEncashment=LeaveSetting.IsEncashment;
            var EncashmentdBalanceOrMax=LeaveSetting.EncashmentdBalanceOrMax;
            var IsDocRequired=LeaveSetting.IsDocRequired;
            var IsAutoApproval=LeaveSetting.IsAutoApproval;

            if(MonthlyLimit==true)
            {
                $("#txtMonthlyMaxLeave").removeAttr("disabled");
            }
            else
            {
                $("#txtMonthlyMaxLeave").attr("disabled", "disabled");
            }
            if(IsCarryforward==true)
            {
                $("#txtCarryforwardBalanceOrMax").removeAttr("disabled");
            }
            else
            {
                $("#txtCarryforwardBalanceOrMax").attr("disabled", "disabled");
            }
            if(IsEncashment==true)
            {
                $("#EncashmentdBalanceOrMax").removeAttr("disabled");
            }
            else
            {
                $("#EncashmentdBalanceOrMax").attr("disabled", "disabled");
            }
            if(CarryforwardBalanceOrMax==false)
            {
                $("#txtCarryforwardMaxLeave").removeAttr("disabled");
            }
            else
            {
                $("#txtCarryforwardMaxLeave").attr("disabled", "disabled");
            }
            if(EncashmentdBalanceOrMax==false)
            {
                $("#txtEncashmentMaxLeave").removeAttr("disabled");
            }
            else
            {
                $("#txtEncashmentMaxLeave").attr("disabled", "disabled");
            }
            if(IsDocRequired==true)
            {
                $("#txtIsAfterDays").removeAttr("disabled");
            }
            else
