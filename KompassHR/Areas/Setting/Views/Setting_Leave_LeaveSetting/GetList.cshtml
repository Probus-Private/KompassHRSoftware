
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/additional-methods.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }
    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }


</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Leave_Menu", "Setting_Leave_Menu", new { id = 4, ScreenId =44, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave Setting - List</h4>
                  
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of leave setting created.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("Setting_Leave_LeaveSetting", "Setting_Leave_LeaveSetting", new { area = "Setting" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="text-center">
                                                <th class="text-nowrap">Update</th>
                                                <th class="text-nowrap">Delete</th>
                                                <th class="text-nowrap">Company </th>
                                                <th class="text-nowrap">Leave Group Name</th>
                                                <th class="text-nowrap">Short Name</th>
                                                <th class="text-nowrap">Yearly Leave</th>
                                                <th class="text-nowrap">Is Activate</th>
                                                <th class="text-nowrap">Is Monthly Limit</th>
                                                <th class="text-nowrap">Monthly Max Leave</th>
                                                <th class="text-nowrap">Is Carry forward</th>
                                                <th class="text-nowrap">Carry Forward Balance Or Max</th>
                                                <th class="text-nowrap">Carry Forward Max Leave</th>
                                                <th class="text-nowrap">Is Encashment</th>
                                                <th class="text-nowrap">Encashmentd Balance Or Max</th>
                                                <th class="text-nowrap">Encashment Max Leave</th>
                                                <th class="text-nowrap">Is Sandwich</th>
                                                <th class="text-nowrap">Is After Confirmation</th>
                                                <th class="text-nowrap">Is DocRequired</th>
                                                <th class="text-nowrap">Is After Days</th>
                                                <th class="text-nowrap">Is Auto Approval</th>
                                                <th class="text-nowrap">Is Auto Approval After Days</th>
                                                <th class="text-nowrap">Is Half DayAllow</th>    
                                                <th class="text-nowrap">Back Date Days</th>   
                                                <th class="text-nowrap">Future Date Days</th>                                               
                                                <th class="text-nowrap">Created By </th>
                                                <th class="text-nowrap">Created Date</th>
                                                <th class="text-nowrap">Modified By</th>
                                                <th class="text-nowrap">Modified Date</th>
                                                <th class="text-nowrap">Machine Name</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.LeaveSetting)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <a id="btnUpdate" onclick="UpdateLeaveSetting('@d.CmpId','@d.LeaveSettingId_Encrypted')"
                                                               style="cursor:pointer">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-center">
                                                        <a id="btnDelete" onclick="DeleteLeaveSetting('@d.LeaveSettingId_Encrypted')"
                                                             	 style="cursor:pointer">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>
                                                    <td>@d.CompanyName</td>
                                                    <td>@d.LeaveGroupName</td>
                                                    <td>@d.LeaveTypeShortName</td>
                                                    <td>@d.YearlyLeave</td>
                                                    <td>@d.IsActivate</td>
                                                    <td>@d.IsMonthlyLimit</td>
                                                    <td>@d.MonthlyMaxLeave</td>
                                                    <td>@d.IsCarryforward</td>
                                                    <td>@d.CarryforwardBalanceOrMax</td>
                                                    <td>@d.CarryforwardMaxLeave</td>
                                                    <td>@d.IsEncashment</td>
                                                    <td>@d.EncashmentdBalanceOrMax</td>
                                                    <td>@d.EncashmentMaxLeave</td>
                                                    <td>@d.IsSandwich</td>
                                                    <td>@d.IsAfterConfirmation</td>
                                                    <td>@d.IsDocRequired</td>
                                                    <td>@d.IsAfterDays</td>
                                                    <td>@d.IsAutoApproval</td>
                                                    <td>@d.IsAutoApprovalAfterDays</td>   
                                                    <td>@d.IsHalfDayAllow</td>   
                                                    <td>@d.BackDateDays</td>
                                                    <td>@d.FutureDateDays</td>                                                               
                                                    <td>@d.CreatedBy</td>
                                                    <td>@d.CreatedDate</td>
                                                    <td>@d.ModifiedBy</td>
                                                    <td>@d.ModifiedDate</td>
                                                    <td>@d.MachineName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }
    });
</script>


<script>

    function UpdateLeaveSetting(CmpId,LeaveSettingId_Encrypted) {
        var url = '@Url.Action("Setting_Leave_LeaveSetting", "Setting_Leave_LeaveSetting")?LeaveSettingId_Encrypted=' + LeaveSettingId_Encrypted+'&CmpId='+CmpId;
        window.location.href = url;
    }

    function DeleteLeaveSetting(LeaveSettingId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500000)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_Leave_LeaveSetting")?LeaveSettingId_Encrypted=' + LeaveSettingId_Encrypted;
            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


</script>



