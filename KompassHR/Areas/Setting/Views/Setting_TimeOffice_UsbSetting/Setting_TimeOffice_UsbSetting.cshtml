@model KompassHR.Areas.Setting.Models.Setting_TimeOffice.Atten_LogColumnSettings

@{
    ViewBag.Title = "Setting_TimeOffice_UsbSetting";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                USB Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TimeOffice_Menu", "Setting_TimeOffice_Menu", new { id = 5, ScreenId =51, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">  USB Setting</h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0"></p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("SaveUpdate", "Setting_TimeOffice_UsbSetting", new { area = "Setting" })' id="Save_LogColumnSetting" method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Log Setting Name
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.USBName, new { @class = "form-control", id = "txtUSBName", autocomplete = "Off", name = "USBName" })
                                        @Html.HiddenFor(model => model.USBId_Encrypted, new { @class = "form-control", id = "USBId_Encrypted" })


                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        User Id
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.UserId, new { @class = "form-control", id = "txtUserId", autocomplete = "Off", name = "UserId" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Log Date
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.LogDate, new { @class = "form-control", id = "txtLogDate", autocomplete = "Off", name = "LogDate" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Device Id
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.DeviceId, new { @class = "form-control", id = "txtDeviceId", autocomplete = "Off", name = "DeviceId" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Direction
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.Direction, new { @class = "form-control", id = "txtDirection", autocomplete = "Off", name = "Direction" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Direction IN
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.DirectionIn, new { @class = "form-control", id = "txtDirectionIn", autocomplete = "Off", name = "DirectionIn" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Direction OUT
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.DirectionOut, new { @class = "form-control", id = "txtDirectionOut", autocomplete = "Off", name = "DirectionOut" })
                                    </div>
                                </div>
                            </div>
                        </div>



                        <div class="LastShortLeaveBx">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                            </button>
                                            <button type="button" id="btnGetList"
                                                    class="btn btn-danger btn-sm">
                                                <i class="fa-solid fa-share-from-square"></i>
                                                List
                                            </button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {


        $("#btnGetList").click(function () {
            debugger;
            var url = '@Url.Action("GetList", "Setting_TimeOffice_UsbSetting")';
            window.location.href = url;
        });


        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    })


    $('#Save_LogColumnSetting').validate({
        rules: {
            USBName:{
                required: true,
            },
            UserId: {
                required: true,
            },
            LogDate:{
                required: true,
            },
            DeviceId:{
                required: true,
            },
            Direction:{
                required: true,
            },
            DirectionIn:{
                required:true,
            },
            DirectionOut:{
                required:true,
            },
        },
        messages: {
            USBName:{
                required: "USB name is required",
            },
            UserId: {
                required: "UserId is required",
            },
            LogDate: {
                required: "LogDate is required",
            },
            DeviceId:{
                required: "DeviceId is required",
            },
            Direction:{
                required: "Direction Name is required" ,
            },
            DirectionIn:{
                required:"Direction IN is required" ,
            },
            DirectionOut:{
                required:"Direction OUT is required" ,
            },
        },
    });


    var form = $("#Save_LogColumnSetting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger
        if (!form.valid()) {
            return false;
        }

        var USBName = $("#txtUSBName").val();
        var USBId_Encrypted = $("#USBId_Encrypted").val();
        $.ajax({
            url: '@Url.Action("Is_USBNameExists", "Setting_TimeOffice_UsbSetting")',
            method: "get",
            data: { USBName: USBName, USBId_Encrypted: USBId_Encrypted },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else {
                    $("#Save_LogColumnSetting").submit();
                }
            }
        });
    });
</script>
<script>
    const inputIds = ["txtUserId", "txtLogDate", "txtDeviceId", "txtDirection"];

    inputIds.forEach(id => {
        const input = document.getElementById(id);

        input.addEventListener('input', function () {
            // Remove non-digit characters first
            let cleaned = this.value.replace(/[^0-9]/g, '');

            // Limit to 10 digits max
            if (cleaned.length > 10) {
                cleaned = cleaned.substring(0, 10);
            }

            // Set the cleaned value back to the input
            this.value = cleaned;
        });
    });
</script>
