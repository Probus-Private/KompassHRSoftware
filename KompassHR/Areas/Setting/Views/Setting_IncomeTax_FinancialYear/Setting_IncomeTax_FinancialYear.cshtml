@model KompassHR.Areas.Setting.Models.Setting_IncomeTax.IncomeTax_Fyear

@{
    ViewBag.Title = "Setting_IncomeTax_FinancialYear";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Income Tax Year
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_IncomeTax_Menu", "Setting_IncomeTax_Menu", new { id = 9, ScreenId =74, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Income Tax Year <Span>- <b>@ViewBag.AddUpdateTitle</b></Span></h4>
                  
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define income tax year here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_IncomeTax_FinancialYear", new { area = "Setting" })' id="SaveIncomeTaxYear" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-9">                                        
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", name = "FromDate", type = "date", id = "dateFromDate", autocomplete = "Off" })
                                                @Html.HiddenFor(model => model.TaxFyear_Encrypted, new { id = "TaxFyear_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", name = "ToDate", type = "date", id = "dateToDate", autocomplete = "Off", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-7">
                                            <div class="row mb-15px">
                                                <label class="col-md-4"></label>
                                                <div class="col-md-8">
                                                    @Html.CheckBoxFor(model => model.IsActive, new { id = "chkIsActivate" })  &nbsp;  <label class="form-check-label form-label">Is Active</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-7">
                                            <div class="row mb-15px">
                                                <label class="col-md-4"></label>
                                                <div class="col-md-8">
                                                    @Html.CheckBoxFor(model => model.SetDefault, new { id = "chkIsDefault" })  &nbsp;  <label class="form-check-label form-label">Is Default</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_IncomeTax_FinancialYear", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetIncometaxYearList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>



<script>
    $(document).ready(function () {
       
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        var dt = @Html.Raw(Json.Encode(TempData["FromDate"]));
        var dt1 = @Html.Raw(Json.Encode(TempData["ToDate"]));
        debugger;
        if(dt == null || dt == "")
        {

        }
        else
        {
            var Fromdatedt =  convertDate(dt);
            var Todate =  convertDate(dt1);
            $("#dateFromDate").val(Fromdatedt);
            $("#dateToDate").val(Todate);
        }

    });//ready Function
    $("#btnGetIncometaxYearList").click(function () {
        var url = '@Url.Action("GetList", "Setting_IncomeTax_FinancialYear")';
        window.location.href = url;
    });
    $("#formReset").click(function () {
        $("#SaveIncomeTaxYear")[0].reset();
    })
</script>


<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveIncomeTaxYear").validate({
        rules: {            
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            }
        },
        messages: {           
            FromDate: {
                required: "Date is required",
            },
            ToDate: {
                required: "Date is required",
            }
        },

    });

    var form = $("#SaveIncomeTaxYear");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#dateFromDate").removeClass('error');
            $("#dateToDate").removeClass('error');
            return false;
        }
        var FromDate=$("#dateFromDate").val();
        var ToDate=$("#dateToDate").val();
       
        var TaxFyear_Encrypted=$("#TaxFyear_Encrypted").val();
        $.ajax({
            url:"IsIncomeTaxYearExists",
            method:"get",
            data:{FromDate:FromDate,ToDate:ToDate,TaxFyear_Encrypted:TaxFyear_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveIncomeTaxYear").submit();
                }
            }
        });

    });

   

    $(document).ready(function () {
        var Title=@Html.Raw(Json.Encode(ViewBag.AddUpdateTitle));
        
    
        
        function updateDates(selectedYear) {
            if (!selectedYear || isNaN(selectedYear) || selectedYear < 1900 || selectedYear > 2100) return;

            // Keep "From Date" as April 1st of selected year
            var fromDate = selectedYear + '-04-01';
            $('#dateFromDate').val(fromDate);

            // Keep "To Date" as March 31st of the next year
            var toDate = (parseInt(selectedYear) + 1) + '-03-31';
            $('#dateToDate').val(toDate);
        }
        if (Title=="Add") {
        // Set default values for current year
        var currentYear = new Date().getFullYear();
        updateDates(currentYear);
        }
        // When user types in the input
        $('#dateFromDate').on('input', function () {
            debugger
            let inputValue = $(this).val();

            // Extract the year (first 4 digits)
            let match = inputValue.match(/^(\d{4})/);
        
            if (match) {
                let selectedYear = parseInt(match[0]);
                updateDates(selectedYear);
            }
        });

        // Prevent users from modifying month/day
        $('#dateFromDate').on('focus', function () {
            debugger
            setTimeout(() => {
                this.setSelectionRange(0, 4); // Allow editing only the year
            }, 10);
        });

        // Restrict input to numbers (only allow typing years)
        $('#dateFromDate').on('keydown', function (event) {
            debugger
            let key = event.key;
            if (!/^\d$/.test(key) && key !== 'Backspace' && key !== 'ArrowLeft' && key !== 'ArrowRight') {
                event.preventDefault(); // Block non-numeric keys
            }
        });
    });


</script>
