</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );


    $('#SaveLocation').validate({
        rules: {
            CmpId: {
                required: true,

            },
            BranchName: {
                required: true,

            },
            BranchAddress: {
                required: true,
                //regex:/^[a-zA-Z0-9\s,\.\,\/\,(/)\&\_\-\ ]+$/
            },
            StateId: {
                required: true,

            },
            PhoneNo: {
                required: true,
                regex:/^[0-9]+$/,
                number:true,
                minlength: 10,
                maxlength:10
            },
            Email: {
                required: true,
                email:true,
            },

        },
        messages: {
            CmpId: {
                required: "Company name is required",

            },
            BranchName: {
                required: "Business unit is required",

            },
            BranchAddress: {
                required: "Address is required",
                //regex:"Please enter only alphabet"
            },
            StateId: {
                required: "State name is required",

            },
            PhoneNo: {
                required: "Phone number is required",
                regex:"Please enter valid Phoneno"
            },
            Email: {
                required: "Email Id is required",
                email:"Please enter valid email"
            },

        },
    });
    var form = $("#SaveLocation");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var CompanyName=$("#ddlCompanyName").val();
        var BranchName=$("#txtBranchName").val();
        var BranchIdEncrypted=$("#BranchId_Encrypted").val();
        $.ajax({
            method:"get",
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: '@Url.Action("IsLocationExists", "Setting_Prime_Location")',
            data:{CompanyName:CompanyName,BranchName:BranchName,BranchIdEncrypted:BranchIdEncrypted},
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveLocation").submit();
                }
            }
        })

    });
</script>

