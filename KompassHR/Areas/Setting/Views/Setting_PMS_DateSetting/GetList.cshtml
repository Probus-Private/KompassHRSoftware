<head>
    <meta name="viewport" content="width=device-width" />
    <title>Date Setting List</title>
</head>
<body>
    <div id="content" class="app-content">
        <!-- BEGIN breadcrumb -->
        <ol class="breadcrumb float-xl-end">
            <li class="breadcrumb-item"><a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId=121, area = "ESS" })">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Setting_PMS_Menu", "Setting_PMS_Menu", new { id = 11, ScreenId=516, area = "Setting" })">PMS Menu</a></li>
        </ol>
        <!-- END breadcrumb -->
        <!-- BEGIN page-header -->
        <h1 class="page-header"> Date Setting  </h1>
        <!-- END page-header -->
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                     <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title"> Date Setting  - List</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            This is the list of Date Setting created.
                        </p>
                    </div>
                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="@Url.Action("Setting_PMS_DateSetting", "Setting_PMS_DateSetting", new { area = "Setting" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                               style="width: 100%;">
                                            <thead>
                                                <tr>

                                                    <th class="fixed-side">Update</th>
                                                    <th class="fixed-side1">Delete</th>
                                                    <th class="text-nowrap">Quarter </th>
                                                    <th class="text-nowrap">From Month </th>
                                                    <th class="text-nowrap">To Month </th>
                                                    <th class="text-nowrap">Created By</th>
                                                    <th class="text-nowrap">CreatedDate</th>
                                                    <th class="text-nowrap">Modifiy By</th>
                                                    <th class="text-nowrap">Modified Date</th>
                                                    <th class="text-nowrap">Machine Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetDateSettingList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-Dark" onclick="Update('@d.DateSettingId_Encrypted','@d.FromMonth','@d.ToMonth')" id="btnUpdate"></i>
                                                        </td>
                                                        <td class="text-center">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg" onclick="Delete('@d.DateSettingId_Encrypted')" id="btnDelete"></i>
                                                        </td>
                                                        <td>@d.QuarterID</td>
                                                        <td>@d.FromMonth</td>
                                                        <td>@d.ToMonth</td>
                                                        <td>@d.CreatedBy</td>
                                                        <td>@d.CreatedDate</td>
                                                        <td>@d.ModifiedBy</td>
                                                        <td>@d.ModifiedDate</td>
                                                        <td>@d.MachineName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</body>
</html>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });

</script>

<script>
    function Update(DateSettingId_Encrypted,FromMonth,ToMonth) {
        @*var FromMonth = @Html.Raw(Json.Encode(TempData["FromMonth"]));
        var ToMonth =  @Html.Raw(Json.Encode(TempData["ToMonth"]));*@
        var url = '@Url.Action("Setting_PMS_DateSetting", "Setting_PMS_DateSetting")?DateSettingId_Encrypted=' + encodeURIComponent(DateSettingId_Encrypted) + '&FromMonth=' + encodeURIComponent(FromMonth) + '&ToMonth=' + encodeURIComponent(ToMonth);
        window.location.href = url;
    }

    function Delete(DateSettingId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_PMS_DateSetting")?DateSettingId_Encrypted=' + DateSettingId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


</script>
