@model KompassHR.Areas.Setting.Models.Setting_PMS.DateSetting
@{
    ViewBag.Title = "Setting_PMS_DateSetting";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId=121, area = "ESS" })">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Setting_PMS_Menu", "Setting_PMS_Menu", new { id = 11, ScreenId=516, area = "Setting" })">PMS Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Date Setting </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Date Setting - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add Date Setting for PMS here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_PMS_DateSetting", new { area = "Setting" })' id="SaveDateSetting" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Date Setting
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.QuarterID, new List<SelectListItem>{
                                                new SelectListItem { Text = "Q1", Value = "Q1" },
                                                new SelectListItem { Text = "Q2", Value = "Q2" },
                                                new SelectListItem { Text = "Q3", Value = "Q3" },
                                                new SelectListItem { Text = "Q4", Value = "Q4" },
                                              }, new { @class = "form-select", name = "QuarterID", @id = "ddlQuarterID" })
                                                @Html.HiddenFor(model => model.DateSettingId_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Month
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @*@Html.TextBoxFor(model => model.FromMonth, new { @class = "form-control", name = "FromMonth", type = "month", id = "FromMonth" })*@
                                                @Html.DropDownListFor(model => model.FromMonth,
                                                new List<SelectListItem>
                                                {
                                                    new SelectListItem { Text = "January", Value = "January" },
                                                    new SelectListItem { Text = "February", Value = "February" },
                                                    new SelectListItem { Text = "March", Value = "March" },
                                                    new SelectListItem { Text = "April", Value = "April" },
                                                    new SelectListItem { Text = "May", Value = "May" },
                                                    new SelectListItem { Text = "June", Value = "June" },
                                                    new SelectListItem { Text = "July", Value = "July" },
                                                    new SelectListItem { Text = "August", Value = "August" },
                                                    new SelectListItem { Text = "September", Value = "September" },
                                                    new SelectListItem { Text = "October", Value = "October" },
                                                    new SelectListItem { Text = "November", Value = "November" },
                                                    new SelectListItem { Text = "December", Value = "December" }
                                                },
                                                new { @class = "form-control", name = "FromMonth", id = "FromMonth", placeholder = "Select Month" })


                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Month
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @*@Html.TextBoxFor(model => model.ToMonth, new { @class = "form-control", name = "ToMonth", type = "month", id = "ToMonth" })*@
                                                @Html.DropDownListFor(model => model.ToMonth,
                                                new List<SelectListItem>
                                                {
                                                    new SelectListItem { Text = "January", Value = "January" },
                                                    new SelectListItem { Text = "February", Value = "February" },
                                                    new SelectListItem { Text = "March", Value = "March" },
                                                    new SelectListItem { Text = "April", Value = "April" },
                                                    new SelectListItem { Text = "May", Value = "May" },
                                                    new SelectListItem { Text = "June", Value = "June" },
                                                    new SelectListItem { Text = "July", Value = "July" },
                                                    new SelectListItem { Text = "August", Value = "August" },
                                                    new SelectListItem { Text = "September", Value = "September" },
                                                    new SelectListItem { Text = "October", Value = "October" },
                                                    new SelectListItem { Text = "November", Value = "November" },
                                                    new SelectListItem { Text = "December", Value = "December" }
                                                },
                                                new { @class = "form-control", name = "ToMonth", id = "ToMonth", placeholder = "Select Month" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_PMS_DateSetting", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetResignationReasonList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </form>
                            @*<button type="button" class="btn btn-danger btn-sm" id="btnGetFNFList">
                                    <i class="fa-solid fa-share-from-square"></i> List
                                </button>*@
                        </div>

                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#FromMonth").select2();
        $("#ToMonth").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;
        if (Message != null || Icon !=null ) {
            //swal("", AlreadyExist, "warning");
            if (Message != null) {
                Swal.fire({
                    //title: 'Saved',
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        //ask
    });
</script>

<script>
    $("#formReset").click(function () {
        $("#SaveDateSetting")[0].reset();
        
    })
</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveDateSetting").validate({
        rules: {
            ReasonName: {
                required: true,
            },
            FromMonth: {
                required: true,
            },
            ToMonth: {
                required: true,
            }
        },
        messages: {
            ReasonName: {
                required: "Quarter Selection is required",
            },
            FromMonth: {
                required: "From Date is required",
            },
            ToMonth: {
                required: "To Date is required",
            },
        }
    });
    var form = $("#SaveDateSetting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var QuarterID=$("#ddlQuarterID").val();
        var DateSettingId_Encrypted=$("#DateSettingId_Encrypted").val();

        $.ajax({
            url:"IsDateSettingExists",
            method:"get",
            data:{QuarterID:QuarterID,DateSettingId_Encrypted:DateSettingId_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveDateSetting").submit();

                }
            }
        });
    });
</script>
