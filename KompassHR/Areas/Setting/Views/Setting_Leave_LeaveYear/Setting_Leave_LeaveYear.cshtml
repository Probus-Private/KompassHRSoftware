                    <h4 class="panel-title"> Leave Year <Span>- <b>@ViewBag.AddUpdateTitle</b></Span></h4>
                 
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define leave year here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_Leave_LeaveYear", new { area = "Setting" })'  id="SaveLeaveYear" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.GetCompanyname, "Id", "Name"), "--Select--", new { id = "ddlCmpID", @class = "form-select", autocomplete = "off", name = "CmpID" })
                                               
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", name = "FromDate", type = "date", id = "dateFromDate", autocomplete = "Off" })
                                                @Html.HiddenFor(model => model.LeaveYearID_Encrypted,new { id= "LeaveYearID_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", name = "ToDate", type = "date", id = "dateToDate", autocomplete = "Off",@readonly= "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-7">
                                            <div class="row mb-15px">
                                                <label class="col-md-4"></label>
                                                <div class="col-md-8">
                                                    @Html.CheckBoxFor(model => model.IsActivate, new { id = "chkIsActivate" })  &nbsp;  <label class="form-check-label form-label">Is Active</label>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-7">
                                            <div class="row mb-15px">
                                                <label class="col-md-4"></label>
                                                <div class="col-md-8">
                                                    @Html.CheckBoxFor(model => model.IsDefault, new { id = "chkIsDefault" })  &nbsp;  <label class="form-check-label form-label">Is Default</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Leave_LeaveYear", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetLeaveYearList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

