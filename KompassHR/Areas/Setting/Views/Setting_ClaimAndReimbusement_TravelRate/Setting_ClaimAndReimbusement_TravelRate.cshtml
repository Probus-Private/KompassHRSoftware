@model KompassHR.Areas.Setting.Models.Setting_ClaimAndReimbusement.Claim_TravelRate
@{
    ViewBag.Title = "Setting_ClaimAndReimbusement_TravelRate";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>
<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
    <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
        <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
            Conveyance Rate
        </h1>
        <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
            <li style="margin-right: 10px;">
                <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                    <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                </a>
            </li>
            <li>
                <a href="@Url.Action("GetList", "Setting_ClaimAndReimbusement_TravelRate", new { id = 8, ScreenId =65, area = "Setting" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                </a>
            </li>
        </ol>
    </div>
</div>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Conveyance Rate - <b>@ViewBag.AddUpdateTitle</b></h4>
                 
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define travel conveyance here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "Setting_ClaimAndReimbusement_TravelRate" , new { area = "Setting" })" id="SaveTravelRate" method="post">

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { name = "CmpId", id = "ddlCompanyName", @class = "form-select", autocomplete = "off" })
                                                @Html.HiddenFor(model => model.TravelRateId_Encrypted, new { id = "TravelRateId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.TravelRateBranchId, new SelectList(ViewBag.Location, "Id", "Name"), "--Select--", new { name = "ShiftBranchId", id = "ddlBusinessUnit", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Vehical Type
                                                <span class="important">*</span>
                                            </label>

                                            <div class="col-md-10">
                                                @Html.Hidden("SelectedVehicleTypeText", "")
                                                @Html.DropDownListFor(model => model.VehicalType, new SelectList(ViewBag.VehicleType, "Name", "Name"), "--Select--", new { name = "VahicalType", id = "txtVahicalType", @class = "form-select", autocomplete = "off" })
                                                @*@Html.DropDownListFor(model => model.VehicalType, new List<SelectListItem> {
                                                new SelectListItem { Text = "Two Wheeler", Value = "Two Wheeler" },
                                                new SelectListItem { Text = "Four Wheeler", Value = "Four Wheeler" },
                                                new SelectListItem { Text = "Public Transport", Value = "Public Transport" },
                                               }, "--Select--", new { @class = "form-select", type = "text", name = "VehicalType", id = "txtVahicalType", autocomplete = "Off" })*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Travel Rate Amount
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.TravelRateAmount, new { @class = "form-control", type = "text", name = "TravelRateAmt", id = "txtTravelRateAmt", autocomplete = "Off" })
                                                @Html.HiddenFor(model => model.TravelRateId_Encrypted, new { @id = "TravelRateId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_ClaimAndReimbusement_TravelRate", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnTravelRateGetList">
                                                                <i class="fa-solid fa-share-from-square"></i>List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

    </div>
</div>
<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        $("#ddlCompanyName").select2();
        $("#ddlBusinessUnit").select2();
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
   $("#ddlCompanyName").on("change", function () {
        $("#ddlBusinessUnit").find("option").remove();
        var CmpId = $("#ddlCompanyName").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: '@Url.Action("GetBusinessUnit", "Setting_ClaimAndReimbusement_TravelRate")',
            data: { CmpId: CmpId },
            success: function (data) {
                debugger;
                if (data !=null) {
                    $("#ddlBusinessUnit").append("<option value=0> --Select-- </option>");
                    $.each(data, function(i, p) {
                        $("#ddlBusinessUnit").append();
                        $("#ddlBusinessUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                    });
                }
            }
        })
    });


        $("#formReset").click(function () {
            $("#SaveTravelRate")[0].reset();
        });



    });//Ready Funcation
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveTravelRate').validate({
        rules: {
            TravelRateAmount: {
                required: true,
                regex:/^\d*(\.\d+)?$/
            },
            CmpId: {
                required: true,

            },
            VehicalType: {
                required: true,
            },
            TravelRateBranchId: {
                required: true,
            },
        },
        messages: {
            TravelRateAmount: {
                required: "Travel rate amount is required",
                regex:"Please enter only digit"
            },
            CmpId: {
                required: "Company name is required",

            },
            VehicalType: {
                required: "Vehical type is required",
            },
            TravelRateBranchId: {
                required: "Business unit is required",
            },

        },
    });

    var form = $("#SaveTravelRate");
    form.validate();


    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var CmpId=$("#ddlCompanyName").val();
        var BranchId=$("#ddlBusinessUnit").val();
        var TravelRateAmt=$("#txtTravelRateAmt").val();
        var VahicalType = $("#txtVahicalType option:selected").text();
        var TravelRateId_Encrypted=$("#TravelRateId_Encrypted").val();

        $.ajax({
            url: '@Url.Action("IsTravelRateExists", "Setting_ClaimAndReimbusement_TravelRate")',
            method:"get",
            data:{TravelRateAmt:TravelRateAmt,VahicalType:VahicalType,TravelRateId_Encrypted:TravelRateId_Encrypted, CmpId:CmpId, BranchId:BranchId},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    debugger;
                    var selectedText = $('#txtVahicalType option:selected').text();
                    $('input[name="SelectedVehicleTypeText"]').val(selectedText);
                    $("#SaveTravelRate").submit();

                }
            }
        });
        @*$("#btnTravelRate").click(function () {
            var url = '@Url.Action("GetList", "Setting_ClaimAndReimbusement_TravelRate")';
            window.location.href = url;
        })*@

        $("#formReset").click(function () {
            $("#SaveTravelRate")[0].reset();
        })

    });


</script>



