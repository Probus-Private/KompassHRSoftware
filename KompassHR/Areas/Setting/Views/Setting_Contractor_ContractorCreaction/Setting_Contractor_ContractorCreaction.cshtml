                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <div class="col-md-6">
                                                <div class="row">
                                                    <label class="form-label col-form-label col-md-4">
                                                        Contact Person No.
                                                    </label>
                                                    <div class="col-md-8">
                                                        @Html.TextBoxFor(model => model.ContactPersonContactNo, new { @class = "form-control", type = "text", name = "ContactPersonContactNo", id = "txtContactPersonContactNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row">
                                                    <label class="form-label col-form-label col-md-4">
                                                        Contact Person Email ID

                                                    </label>
                                                    <div class="col-md-8">
                                                        @Html.TextBoxFor(model => model.ContactPersonEmailID, new { @class = "form-control", type = "text", name = "ContactPersonEmailID", id = "txtContactPersonEmailID", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                        <div class="row">
                                            <div class="LastShortLeaveBx">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="BtnBx">
