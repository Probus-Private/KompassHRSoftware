                                                                    <button type="button" class="btn btn-danger btn-sm" id="btnContractorCreactionGetList">
                                                                        <i class="fa-solid fa-share-from-square"></i>List
                                                                    </button>
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

    </div>
</div>


<script>

    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        $("#ddlCompanyName").select2();
        $("#txtContractorBranchID").select2();

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#txtContractorBranchID").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_Contractor_ContractorCreaction")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        //$("#txtContractorBranchID").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#txtContractorBranchID").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#formReset").click(function () {
            $("#SaveContractorCreaction")[0].reset();

        })
        @Html.Raw(Json.Encode(TempData["FromDate"]));

        var ToDate = @Html.Raw(Json.Encode(TempData["ToDate"]));
        var FromDate = @Html.Raw(Json.Encode(TempData["FromDate"]));
        debugger;
        if(ToDate=="" || FromDate=="")
        {

        }
        else
        {
            var ToDate =  convertDate(ToDate);
            var FromDate =  convertDate(FromDate);
            $("#txtToDate").val(ToDate);
            $("#txtFromDate").val(FromDate);
        }
    });//Ready Funcation
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveContractorCreaction').validate({
        rules: {
            ContractorName:{
                required:true,
            },
            //FromDate:{
            //    required:true,
            //},
            //ToDate:{
            //    required:true,
            //},
            //ContactNo:{
            //    required:true,
            //},
            ContactorEmailID:{
                email:true,
            },
            //FaxNo:{
            //    regex:/^\+?[0-9]{6,}$/,
            //},
            //ContactPersonContactNo:{
            //    regex:/^[0-9]+$/
            //},
            ContactPersonEmailID:{
                email:true,
            },
        },
        messages: {
            ContractorName:{
                required:"Please enter contractor name"
            },
            //FromDate:{
            //    required:"Please select formdate"
            //},
            //ToDate:{
            //    required:"Please select todate"
            //},
            //ContactNo:{
            //    required:"Please enter contact no."
            //},
            ContactorEmailID:{
                email:"Please enter valid email id"
            },
            //FaxNo:{
            //    regex:"Please enter valid fax no.",
            //},
            //ContactPersonContactNo:{
            //    regex:"Please enter only digit"
            //},
            ContactPersonEmailID:{
                email:"Please enter valid email id"
            },
        },
    });

    var form = $("#SaveContractorCreaction");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtFromDate").removeClass("error");
            $("#txtToDate").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        var ContractorName=$("#txtContractorName").val();
        var CmpId=$("#ddlCompanyName").val();
        var ContractorBranchID=$("#txtContractorBranchID").val();
        var ContractorId_Encrypted=$("#ContractorId_Encrypted").val();

        $.ajax({
            url:"IsContractorCreactionExists",
            method:"get",
            data:{ContractorName:ContractorName,ContractorId_Encrypted:ContractorId_Encrypted,CmpId:CmpId,ContractorBranchID:ContractorBranchID},
            success:function(response){
                debugger;
                $(".Userloaderbg").css("display","none");
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveContractorCreaction").submit();

                }
            }
        });


        $("#formReset").click(function () {
            $("#SaveContractorCreaction")[0].reset();
        })

    });

    $("#txtFromDate,#txtToDate").change(function () {
        debugger;
        var StartDate= document.getElementById('txtFromDate').value;
        var EndDate= document.getElementById('txtToDate').value;
        var eDate = new Date(EndDate);
        var sDate = new Date(StartDate);

        if(StartDate!= '' && EndDate!= '' && sDate > eDate)
        {
            $("#ErrortxtToDate").html("To date should not be less than from date.");
            $("#txtToDate").val('');
        }
        else{
            $("#ErrortxtToDate").html("");
        }
    });



</script>

