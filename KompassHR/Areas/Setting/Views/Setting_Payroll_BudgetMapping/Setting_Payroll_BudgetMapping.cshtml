
@model KompassHR.Areas.Setting.Models.Setting_Payroll.Payroll_BudgetMapping

@{
    ViewBag.Title = "Setting_Payroll_BudgetMapping";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
