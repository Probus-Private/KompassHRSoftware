                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.COFFGenerationDaysBranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "Select", new { id = "ddlBranchId", @class = "form-select", autocomplete = "off", name = "COFFGenerationDaysBranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            
