<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(() => {
                window.location.reload();
            });
        }

        var Action="@ViewBag.AddUpdateTitle";
        debugger
       
        $("#ddlCmpId").on("change", function () {
            debugger
            $("#ddlBranchId").empty();

            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetBusinessUnit", "Setting_TimeOffice_CoffGenerationDays")',
                data: { CmpId: CmpId },
                success: function (data) {

                    if (data && data.Branch) {
                        $("#ddlBranchId").append("<option value=''>Select</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                }
            });
        });


       $("#ddlBranchId").on("change", function () {
    var CmpId = $("#ddlCmpId").val();
    var BranchId = $("#ddlBranchId").val();
    if(CmpId && BranchId)
    {
        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetCoffDays", "Setting_TimeOffice_CoffGenerationDays")',
            data: { CmpId: CmpId, BranchId: BranchId },
            success: function (data) {
                debugger
                // Convert array-of-key-values → object
                var result = data.map(function (row) {
                    var obj = {};
                    row.forEach(function (item) {
                        obj[item.Key] = item.Value;
                    });
                    return obj; 
                });

                // Now result = [{COFFGenerationDay:0.25, IsExists:1}, ...]
    
                $('input[name="COFFGenerationDay"]').each(function () {

                    var dayVal = parseFloat($(this).val());

                    var match = result.find(function (r) {
                        return parseFloat(r.COFFGenerationDay) === dayVal;
                    });

                    if (match && match.IsExists == 1) {
                        $(this).prop('checked', true);
                    } else {
                        $(this).prop('checked', false);
                    }

                });
            }

         


        });
    }
});

    });
</script>

<script>

    $("#SaveCoffGenerationDays").validate({

        rules: {
            CmpId:
                {
                required: true,
                },
            COFFGenerationDaysBranchId:
                {
                required: true,
                },
          

        },
        messages: {

            CmpId: {
                required: "Select the Company Name",
            },
            COFFGenerationDaysBranchId: {
                required: "Select the Branch Name",
            },
          
        },
        errorPlacement: function (error, element) {
            if (element.hasClass("select2-hidden-accessible")) {
                // Insert error after Select2's container
                error.insertAfter(element.next('.select2'));
            } else {
                error.insertAfter(element);
            }
        },

    });


    var form = $("#SaveCoffGenerationDays");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if (form.valid() == false) {
            return false;
        }
         // Validate at least one checkbox is selected
    var checkedCount = $('input[name="COFFGenerationDay"]:checked').length;
    if (checkedCount === 0) {
        Swal.fire({
            icon: 'error',
            text: 'Select at least 1 Coff Generation Day',
            allowOutsideClick: false
        });
        return false;
    }

        var COFFGenerationDaysId_Encrypted = $("#txtCOFFGenerationDaysId_Encrypted").val();
        var CmpId = $("#ddlCmpId").val();
        var COFFGenerationDaysBranchId = $("#ddlBranchId").val();
       // var COFFGenerationDay=$("#COFFGenerationDay").val();
        var COFFGenerationDay = $('input[name="COFFGenerationDay"]:checked')
                           .map(function () { return this.value; })
                           .get();

        $.ajax({
            url: '@Url.Action("IsExists", "Setting_TimeOffice_CoffGenerationDays")',
            method: "get",
            traditional: true,
            data:
                {
                    COFFGenerationDaysId_Encrypted: COFFGenerationDaysId_Encrypted,
                    CmpId:CmpId,
                    COFFGenerationDaysBranchId:COFFGenerationDaysBranchId,
                    COFFGenerationDay:COFFGenerationDay
                },

            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: false
                        }).then(() => {
                            const p = Swal.getPopup();
                            p.classList.add('animate__headShake');
                            setTimeout(() => p.classList.remove('animate__headShake'), 500);
                        });
                    }
                }
                else
                {
                    debugger;
                    $("#SaveCoffGenerationDays").submit();
                }
            }
        });
    });
</script>
