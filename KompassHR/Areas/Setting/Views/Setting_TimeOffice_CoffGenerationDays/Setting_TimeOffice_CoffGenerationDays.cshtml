                                                        <tr>
                                                            <td class="text-center">
                                                                <input type="checkbox" name="COFFGenerationDay" value="0.5" />
                                                            </td>
                                                            <td class="text-center">0.5</td>
                                                        </tr>

                                                        <tr>
                                                            <td class="text-center">
                                                                <input type="checkbox" name="COFFGenerationDay" value="1" />
                                                            </td>
                                                            <td class="text-center">1</td>
                                                        </tr>

                                                        <tr>
                                                            <td class="text-center">
                                                                <input type="checkbox" name="COFFGenerationDay" value="1.5" />
                                                            </td>
