@model KompassHR.Areas.Setting.Models.Setting_Recruitment.Recruitment_Pool
@{
    ViewBag.Title = "Setting_Recruitment_PoolRecruiter";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    iv class="row" style="margin-bottom: 10px;">
    <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
        <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
            Recruitment Pool
        </h1>
        <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
            <li style="margin-right: 10px;">
                <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                    <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                </a>
            </li>
            <li>
                <a href="@Url.Action("Setting_Recruitment_Menu", "Setting_Recruitment_Menu", new { id =1 ,ScreenId =35, area = "Setting" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                </a>
            </li>
        </ol>
    </div>
</div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Recruitment Pool - <b>@ViewBag.AddUpdateTitle</b></h4>
                   
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define recruiter pool here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/Setting/Setting_Recruitment_PoolRecruiter/SaveUpdate" id="SavePoolRecruiter" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Campany Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.GetCompanyName,"Id","Name"), "--Select--", new { id = "ddlCmpID", @class = "form-select", autocomplete = "off", name = "CmpName" })
                                                @Html.HiddenFor(model => model.RecruitmentPoolID_Encrypted, new { id = "RecruitmentPoolID_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName,"Id","Name"), "--Select--", new { id = "ddlBranchId", @class = "form-select", name = "BranchId" })
                                                @Html.ValidationMessageFor(model => model.BranchId, "", new { @class = "help-block", @id = "ErrorBranchId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.RecruitmentAssignEmployeeID, new SelectList(ViewBag.GetAssignList, "Id","Name"), "--Select--", new { id = "ddlRecruitmentAssignEmployeeID", @class = "form-select", name = "RecruitmentAssignEmployeeID" })
                                                @Html.ValidationMessageFor(model => model.RecruitmentAssignEmployeeID, "", new { @class = "help-block", @id = "ErrorRecruitmentAssignEmployeeID", @style = "color:red" })
                                            </div>
                                        </div>
                                        
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Pool Recruiter
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.RecruitmentPoolEmployeeID, new SelectList(ViewBag.GetRecruiterList,"Id","Name"), "--Select--", new { id = "ddlRecruitmentPoolEmployeeID", @class = "form-select", name = "RecruitmentPoolEmployeeID" })
                                                @Html.ValidationMessageFor(model => model.RecruitmentPoolEmployeeID, "", new { @class = "help-block", @id = "ErrorRecruitmentPoolEmployeeID", @style = "color:red" })
                                            </div>
                                        </div>

                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-2">
                                    </label>
                                    <label class="form-label col-form-label col-md-2">
                                        @Html.CheckBoxFor(model => model.IsActive, new { id = "IsActive" })
                                        &nbsp;   Is Active
                                    </label>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="/Setting/Setting_Recruitment_PoolRecruiter/GetList">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetCostCenterList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        


        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        //$("#ddlCmpID").select2();
        //$("#ddlBranchId").select2();
        //$("#ddlRecruitmentAssignEmployeeID").select2();
        //$("#ddlRecruitmentPoolEmployeeID").select2();

    });
</script>

<script>
    //function numbervalidate(key) {
    //    var presskeys = (key.which) ? key.which : key.presskeys;
    //    if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
    //        return false;
    //    }
    //}

    $("#ddlCmpID").on("change", function () {
        debugger;
        $("#ddlBranchId").find("option").remove();
        var CmpId = $("#ddlCmpID").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: 'GetBusinessUnit',
            data: { CmpId: CmpId },
            success: function (data) {
                if (data !=null) {
                    $("#ddlBranchId").append("<option value=0>--Select-- </option>");
                    $.each(data, function(i, p) {
                        $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }
                else {
                    $('#ErrorESSPassword').html(" ");
                }
            }
        })
    })


    $("#ddlBranchId").on("change", function () {
        debugger
        $("#ddlRecruitmentAssignEmployeeID").find("option").remove();
        var BranchId = $("#ddlBranchId").val();
        var CmpID = $("#ddlCmpID").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: 'GetAssignName',
            data: { BranchId: BranchId,CmpID:CmpID },
            success: function (data) {
                if (data !=null) {
                    $("#ddlRecruitmentAssignEmployeeID").append("<option value=0>--Select-- </option>");
                    $.each(data, function(i, p) {
                        $("#ddlRecruitmentAssignEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }
                else {
                    $('#ddlRecruitmentAssignEmployeeID').html(" ");
                }
            }
        })
    });

    $("#ddlRecruitmentAssignEmployeeID").on("change", function () {
        debugger
        $("#ddlRecruitmentPoolEmployeeID").find("option").remove();
        var BranchId = $("#ddlBranchId").val();
        var CmpID = $("#ddlCmpID").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: 'GetPoolRecruiterName',
            data: { BranchId: BranchId,CmpID:CmpID },
            success: function (data) {
                if (data !=null) {
                    $("#ddlRecruitmentPoolEmployeeID").append("<option value=0>--Select-- </option>");
                    $.each(data, function(i, p) {
                        $("#ddlRecruitmentPoolEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }
                else {
                    $('#ddlRecruitmentPoolEmployeeID').html(" ");
                }
            }
        })
    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SavePoolRecruiter").validate({
        rules: {
            CmpID: {
                required: true,
            },
            CostCenterName: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            }
        },
        messages: {
            CmpID: {
                required: "Campany name is required",
            },
            CostCenterName: {
                required: "Cost center name is required",
                regex: "Enter only alphabate",
            }
        },
    });

    var form = $("#SavePoolRecruiter");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;      
        var BranchId = $("#ddlBranchId").val();
        var PoolEmployeeID=$("#ddlRecruitmentPoolEmployeeID").val(); 
        var employeeid=$("#ddlRecruitmentAssignEmployeeID").val();     
        
        if(BranchId=="0")
        {$('#ErrorBranchId').html("Business unit is required"); $("#ErrorBranchId").focus();  return false;}
        else{ $('#ErrorBranchId').html("");}

        if(employeeid=="0")
        {$('#ErrorRecruitmentAssignEmployeeID').html("Fine/Penalty/Month is required"); $("#ErrorRecruitmentAssignEmployeeID").focus();  return false;}
        else{ $('#ErrorRecruitmentAssignEmployeeID').html("");}       

        if(PoolEmployeeID=="0")
        {$('#ErrorRecruitmentPoolEmployeeID').html("Company name is required"); $("#ErrorRecruitmentPoolEmployeeID").focus();  return false;}
        else{ $('#ErrorRecruitmentPoolEmployeeID').html("");}      

        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var CmpID=$("#ddlCmpID").val();
        var BranchId = $("#ddlBranchId").val();
        var RecruitmentPoolID_Encrypted=$("#RecruitmentPoolID_Encrypted").val();
        var RecruitmentPoolEmployeeID=$("#ddlRecruitmentPoolEmployeeID").val();
        $.ajax({
            url:"IsPoolExists",
            method:"get",
            data:{CmpID:CmpID,BranchId:BranchId,RecruitmentPoolID_Encrypted:RecruitmentPoolID_Encrypted,RecruitmentPoolEmployeeID:RecruitmentPoolEmployeeID},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SavePoolRecruiter").submit();

                }
            }
        });

    });
</script>
