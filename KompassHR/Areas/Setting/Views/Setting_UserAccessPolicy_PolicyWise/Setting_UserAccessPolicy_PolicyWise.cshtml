</div>

<script>
    $(document).ready(function () {
        debugger
        //$('.TablePageAccess').DataTable({
        //    destroy: true,
        //    "searching": true,
        //    "paging": false,      // Disable paging
        //    "bInfo": true,
        //    "bFilter": true,
        //    "ordering": false,    // Disable sorting
        //});
        $('.TablePageAccess').DataTable({
            scrollY: 400,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
            stripeClasses: [] // Disable alternating row colors
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
    var UserAccessPolicyMaster = @Html.Raw(Json.Encode(ViewBag.UserAccessPolicyMaster));
    debugger;
    if(UserAccessPolicyMaster!=null)
    {
        var GroupName=UserAccessPolicyMaster[0][2].Value;
        $("#txtUserGroupName").val(GroupName);
        $('#tblLoadModule tr').not(function () { return !!$(this).has('th').length; }).remove();
        for(var i=0;i <= UserAccessPolicyMaster.length-1;i++)
        {
            var table = document.getElementById("tblLoadModule");
            var rowCount = table.rows.length;
            var row = table.insertRow(rowCount);
            var count = $('#tblLoadModule tr').length;

            row.insertCell(0).innerHTML= '<input ' + ( UserAccessPolicyMaster[i][10].Value ? 'checked' : ' ') + ' type="checkbox" />';
            row.insertCell(1).innerHTML = "" + UserAccessPolicyMaster[i][4].Value + "";
            row.insertCell(2).innerHTML = "" + UserAccessPolicyMaster[i][5].Value + "";
            row.insertCell(3).innerHTML = "" + UserAccessPolicyMaster[i][6].Value + "";
            row.insertCell(4).innerHTML = "" + UserAccessPolicyMaster[i][9].Value + "";
            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][3].Value +"";
        }
    }
</script>

<script>
    $("#btnSubmit").click(function () {
        debugger;
        var table =  $('.TablePageAccess').DataTable();
        table.search('').draw();
        $("#txtUserGroupName").val();
        var UserGroupName = $("#txtUserGroupName").val();
        var UserGroupIdEncrypted = $("#UserGroupId_Encrypted").val();

        var UserAccessRecoardList1 = new Array();
        $("#tblLoadModule").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");
            data.IsMenu = currentRow.find('input[type="checkbox"]').prop('checked');
            data.UserGroupDetails_ScreenID = currentRow.find("td:eq(5)").html();
            UserAccessRecoardList1.push(data);
        });

        if (UserAccessRecoardList1 == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }

        if(UserGroupName=="")
        {
            $("#ErrortxtUserGroupName").html("Access name is required");
            $("#txtUserGroupName").focus();
            return false;
        }
        else
        {
            $("#ErrortxtUserGroupName").html("");
        }
        $(".Userloaderbg").css("display", "flex");


        $.ajax({
            url: '@Url.Action("IsUserAssccesExists", "Setting_UserAccessPolicy_PolicyWise")',
            method: "get",
            data: { UserGroupName: UserGroupName, UserGroupIdEncrypted: UserGroupIdEncrypted },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else {
                    var UserAccessRecoardList = new Array();
                    $("#tblLoadModule").find(':checkbox:checked').each(function (i) {
                        var data = {};
                        var currentRow = $(this).closest("tr");
                        data.IsMenu = currentRow.find('input[type="checkbox"]').prop('checked');
                        data.UserGroupDetails_ScreenID = currentRow.find("td:eq(5)").html();
                        UserAccessRecoardList.push(data);
                    });

                    if (UserAccessRecoardList == null || UserAccessRecoardList =="") {
                        $(".Userloaderbg").css("display","none");
                        Swal.fire({
                            icon: 'warning',
                            title: 'Oops...',
                            text: 'Please select the checkbox before submitting the form.'
                        });
                    }

                    debugger;
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("SaveUpdate")",
                        contentType: "application/json",
                        dataType: "text",
                        data: JSON.stringify({ UserGroupName: UserGroupName, UserGroupIdEncrypted:UserGroupIdEncrypted, UserAccessRecoardList:UserAccessRecoardList }),
                        success: function (response) {
                            debugger;
                            var GetMsg  = JSON.parse(response);
                            var Message1 = GetMsg.Message;
                            var Icon1 = GetMsg.Icon;
                            if (Icon1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            // return false
                                        }
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("Setting_UserAccessPolicy_PolicyWise", "Setting_UserAccessPolicy_PolicyWise")';
                                        }
                                    });
                                }
                            }
                        }
                    });

                }
            }
        });

    });




    function checkAllCheckboxes(checkbox, checkboxType) {
        var checkboxes = document.querySelectorAll('[id^="' + checkboxType + 'CheckBox"]');
        checkboxes.forEach(function (cb) {
            cb.checked = checkbox.checked;
        });
        if (checkboxType === 'IsMenu' || checkboxType === 'IsSave' || checkboxType === 'IsUpdate' || checkboxType === 'IsDelete' || checkboxType === 'IsList') {

            var typeIndex = ['IsMenu', 'IsSave', 'IsUpdate', 'IsDelete', 'IsList'].indexOf(checkboxType);
            var dynamicCheckboxes = document.querySelectorAll('#tblLoadModule tr td:nth-child(' + (typeIndex + 1) + ') input[type="checkbox"]');
            dynamicCheckboxes.forEach(function (dynamicCheckbox) {
                dynamicCheckbox.checked = checkbox.checked;
            });
        }
    }
</script>

