<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                User Access Policy
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_UserAccessPolicy_Menu", "Setting_UserAccessPolicy_Menu", new { id = 32, ScreenId = 121, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">User Access Policy - @ViewBag.AddUpdateTitle </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        User access policy groups play a crucial role in managing access permissions within an HRMS, ensuring that employees have the appropriate level of access to perform their job duties while maintaining the security and integrity of sensitive HR data.
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Setting_UserAccessPolicy_PolicyWise", "Setting_UserAccessPolicy_PolicyWise", new { area = "Setting" })' id="SaveUserAccessPolicy" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Access Policy Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.UserGroupName, new { @class = "form-control", name = "UserGroupName", type = "text", id = "txtUserGroupName", autocomplete = "Off", Value = "" })
                                                @Html.ValidationMessageFor(model => model.UserGroupName, "", new { @class = "help-block", @id = "ErrorUserGroupName", @style = "color:red" })
                                                @*<span class="error" id="ErrortxtUserGroupName"></span>*@
                                                @Html.HiddenFor(model => model.UserGroupId_Encrypted, new { id = "UserGroupId_Encrypted" })
                                                @Html.HiddenFor(model => model.UserGroupId, new { id = "UserGroupId" })
                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <!-- BEGIN table-responsive -->
                                            <div class="table-scroll div1">
                                                <div class="table-wrap">
                                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TablePageAccess">
                                                        <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                            @*<tr class="trheading">
                                                                    <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsMenuCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsMenu')"> All</label></th>
                                                                    <th class="fixed-side"></th>
                                                                    <th class="fixed-side1"></th>
                                                                    <th class="fixed-side1"></th>
                                                                    <th class="fixed-side1"></th>
                                                                    <th hidden>ScreenId</th>
                                                                    <th hidden>ScreenModuleId</th>
                                                                </tr>*@
                                                            <tr class="trheading">
                                                                <th class="text-center text-nowrap"><label><input type="checkbox" name="checkbox" id="IsMenuCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsMenu')"> All Menu</label></th>
                                                                <th class="fixed-side text-nowrap">Module Name</th>
                                                                <th class="fixed-side1 text-nowrap">Type</th>
                                                                <th class="fixed-side text-nowrap">Form Name</th>
                                                                <th class="fixed-side1 text-nowrap">Description</th>
                                                                <th hidden>ScreenId</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="tblLoadModule">
                                                            @foreach (var d in ViewBag.GetUserAccessPolicyMaster)
                                                            {
                                                                if (@d.IsSideMenu == true)
                                                                {
                                                                    <tr>
                                                                        <td style="background-color: rgba(233, 236, 239, 1) !important;"><input type="checkbox" /></td>
                                                                        <td style="background-color: rgba(233, 236, 239, 1) !important;">@d.ModuleName</td>
                                                                        <td style="background-color: rgba(233, 236, 239, 1) !important;">@d.ScreenMenuType</td>
                                                                        <td style="background-color: rgba(233, 236, 239, 1) !important;">@d.ScreenDisplayMenuName</td>
                                                                        <td style="background-color: rgba(233, 236, 239, 1) !important;">@d.DescriptionForUser</td>
                                                                        <td hidden>@d.ScreenId</td>
                                                                    </tr>
                                                                }
                                                                else
                                                                {
                                                                    <tr>
                                                                        <td><input type="checkbox" /></td>
                                                                        <td>@d.ModuleName</td>
                                                                        <td>@d.ScreenMenuType</td>
                                                                        <td>@d.ScreenDisplayMenuName</td>
                                                                        <td>@d.DescriptionForUser</td>
                                                                        <td hidden>@d.ScreenId</td>
                                                                    </tr>
                                                                }
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="row">
                                        <div class="col-md-12">
