<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
    }


    .modal-body {
        max-height: 80vh;
        overflow-y: auto;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Late Mark Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TimeOffice_Menu", "Setting_TimeOffice_Menu", new { id = 5, ScreenId = 51, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">  Late Mark Setting - List</h4>

                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of  Late Mark Setting created.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="@Url.Action("Setting_TimeOffice_LateMarkSetting", "Setting_TimeOffice_LateMarkSetting", new { area = "Setting" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                        </div>
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine"
                                       style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th class="fixed-side">Update</th>
                                            <th class="fixed-side1">Delete</th>
                                            <th class="fixed-side1" hidden>View</th>
                                            <th class="text-nowrap">Company </th>
                                            <th class="text-nowrap text-center">Buisness Unit </th>
                                            <th class="text-nowrap text-center">Late Mark Name</th>
                                            <th class="text-nowrap text-center">Created By</th>
                                            <th class="text-nowrap text-center">Created Date</th>
                                            <th class="text-nowrap text-center">Modified By</th>
                                            <th class="text-nowrap text-center">Modified Date</th>
                                            <th class="text-nowrap text-center">Machine Name</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.GetLateMarkSettingList)
                                        {
                                            <tr>
                                                <td class="text-center" style="width: 80px;">
                                                    <a onclick="UpdateTemplate('@d.LateMarkSettingId_Encrypted')" id="btnUpdate" style="cursor:pointer;">
                                                        <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center" style="width: 80px;">
                                                    <a onclick="DeleteTemplate('@d.LateMarkSettingId_Encrypted')" id="btnDelete" style="cursor:pointer;">
                                                        <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center" style="width: 80px;" hidden>
                                                    <a onclick="View('@d.LateMarkSettingId')" id="btnView" style="cursor:pointer;">
                                                        <i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>
                                                    </a>
                                                </td>

                                                <th class="text-left">@d.CompanyName</th>
                                                <th class="text-left">@d.BranchName</th>
                                                <th class="text-left">@d.LateMarkSettingName</th>
                                                <td class="text-left">@d.CreatedBy</td>
                                                <td class="text-left">@d.CreatedDate</td>
                                                <td class="text-nowrap">@d.ModifiedBy</td>
                                                <td class="text-nowrap">@d.ModifiedDate</td>
                                                <td class="text-nowrap">@d.MachineName</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="LateMarkSettingDetails" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"></h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal fade" id="LateMarkSettingDetails" tabindex="-1" role="dialog" aria-labelledby="LateMarkSettingDetailsLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="LateMarkSettingDetailsLabel">Late Mark Setting Details</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <!-- BEGIN panel -->
                            <div class="modal-body-content">
                                <div class="row">
                                    <div class="col-md-3"></div>
                                    <div class="col-md-6">
                                        <div class="table-scroll div1">
                                            <div class="row">
                                                <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass tblAddData" style="width: 100%;" id="tblEmployeeHistoryHead">
                                                    <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                        <tr>
                                                            <th class="text-nowrap" style="text-align: center">From Day</th>
                                                            <th class="text-nowrap" style="text-align: center">To Day</th>
                                                            <th class="text-nowrap" style="text-align: center">Day</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblBodyLateMarkSettingDetails"></tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3"></div>
                                </div>
                            </div>
                            <!-- END panel -->
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>


<script>
    function UpdateTemplate(LateMarkSettingId_Encrypted,LateMarkSettingId) {
        debugger;
        var url = '@Url.Action("Setting_TimeOffice_LateMarkSetting", "Setting_TimeOffice_LateMarkSetting")?LateMarkSettingId_Encrypted=' + LateMarkSettingId_Encrypted ;
        window.location.href = url;
    }

    function DeleteTemplate(LateMarkSettingId_Encrypted) {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_TimeOffice_LateMarkSetting")?LateMarkSettingId_Encrypted=' + LateMarkSettingId_Encrypted;

            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    function View(LateMarkSettingId) {
        $.ajax({
            type: "GET",
            url: '@Url.Action("View", "Setting_TimeOffice_LateMarkSetting", new { area = "Setting" })',
            data: { LateMarkSettingId: LateMarkSettingId },
            contentType: "application/json; charset=utf-8",
            dataType: "json", // Changed to json for automatic parsing
            //success: function (response) {
            //    const modal = $('#LateMarkSettingDetails');
            //    const tableBody = $('#tblBodyLateMarkSettingDetails');

            //    tableBody.empty(); // Clear existing rows

            //    if (response && response.length > 0) {debugger;
            //        response.forEach(item => {
            //            const row = `<tr>
            //                <td>${item.FromDay}</td>
            //                <td>${item.ToDay}</td>
            //                <td>${item.Day}</td>
            //            </tr>`;
            //            tableBody.append(row);
            //        });
            //        modal.modal('show');
            //    } else {

            //    }
            //},
            success: function (response) {
                debugger;
                const data = JSON.parse(response);
                const modal = $('#LateMarkSettingDetails');
                const tableBody = $('#tblBodyLateMarkSettingDetails');

                modal.modal(data.length > 0 ? 'show' : 'hide');
                tableBody.empty(); // Clear existing rows

                if (data) {
                    data.forEach(item => {
                        const row = $('<tr>');

                        const FromLateMarkCount = item.find(e => e.Key === "FromLateMarkCount");
                        const ToLateMarkCount = item.find(e => e.Key === "ToLateMarkCount");
                        const DayCell = item.find(e => e.Key === "Day");

                        row.append(`<td>${FromLateMarkCount ? FromLateMarkCount.Value : ''}</td>`);
                        row.append(`<td>${ToLateMarkCount ? ToLateMarkCount.Value : ''}</td>`);
                        row.append(`<td>${DayCell ? DayCell.Value : ''}</td>`);

                        tableBody.append(row);
                    });
                }
            }

        });
    }
</script>
