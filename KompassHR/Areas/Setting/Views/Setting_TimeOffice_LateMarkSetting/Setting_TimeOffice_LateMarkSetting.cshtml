@model KompassHR.Areas.Setting.Models.Setting_TimeOffice.Atten_LateMarkSetting
@{
    ViewBag.Title = "Late Mark Setting";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 13px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Late Mark Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TimeOffice_Menu", "Setting_TimeOffice_Menu", new { id = 5, ScreenId = 51, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Late Mark Setting - <span>@ViewBag.AddUpdateTitle</span></h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define late mark setting manual here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_TimeOffice_LateMarkSetting", new { area = "Setting" })' id="SaveLateMarkSetting" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { id = "ddlCompanyName", @class = "form-select", autocomplete = "off", @required = "required" })
                                                @Html.HiddenFor(model => model.LateMarkSettingId_Encrypted, new { @id = "LateMarkSettingId_Encrypted" })
                                                @Html.HiddenFor(model => model.LateMarkSettingId, new { @id = "LateMarkSettingId" })


                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LateMarkSettingBranchId, new SelectList(ViewBag.BusinessUnit, "Id", "Name"), "--Select--", new { @class = "form-control", @id = "ddlLateMarkSettingBranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Late Mark Setting Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.LateMarkSettingName, new { @class = "form-control", id = "txtLateMarkSettingName", autocomplete = "Off", name = "LateMarkSettingName" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-6">
                                                From Late Mark Count
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.FromLateMarkCount, new { @class = "form-control", id = "txtFromLateMarkCount", autocomplete = "off", name = "FromLateMarkCount", type = "number", maxlength = "2" })
                                                @Html.ValidationMessageFor(model => model.FromLateMarkCount, "", new { @class = "help-block", @id = "ErrorFromLateMarkCount", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-6">
                                                To Late Mark Count
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.ToLateMarkCount, new { @class = "form-control", id = "txtToLateMarkCount", autocomplete = "off", name = "ToLateMarkCount", type = "number", maxlength = "2" })
                                                @Html.ValidationMessageFor(model => model.ToLateMarkCount, "", new { @class = "help-block", @id = "ErrorToLateMarkCount", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-6">
                                                Day
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.Day, new { @class = "form-control", type = "number", id = "txtDay", autocomplete = "Off", name = "Day", onkeypress = "return onlyNumbers(event);", maxlength = "3" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnAdd" class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-plus"></i> Add
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="col-md-4"></div>
                                    <div class="col-md-4">
                                        <div class="table-scroll div1">
                                            <div class="table-wrap">
                                                <table class="table table-bordered align-middle" id="data-table-combine" style="width: 100%;">
                                                    <thead>
                                                        <tr>
                                                            <th class="text-nowrap" style="width:50px">From Late Mark Count</th>
                                                            <th class="text-nowrap" style="width:50px">To Late Mark Count</th>
                                                            <th class="text-nowrap" style="width:50px">Day</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblLateMarkSettingDetails"></tbody>
                                                </table>

                                                <label class="form-label col-form-label col-md-2" id="lblErrorDuplicate" style="display: none; color: red;">Duplicate Entry</label>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-4">
                                                <button type="button" id="btnDeleteRow" style="margin-top: 3px;"
                                                        class="btn btn-danger btn-sm">
                                                    <i class="fa-solid fa-trash-alt"></i> Delete Row
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4"></div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_TimeOffice_LateMarkSetting", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnPunchMissingList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {debugger
        $("#ddlCompanyName").select2();
        $("#ddlLateMarkSettingBranchId").select2();
        $('title').html("Late Mark Setting");
        debugger

        var LateMarkSettingDetails =@Html.Raw(Json.Encode(ViewBag.GetLateMarkSettingDetails));
        debugger;

        if(LateMarkSettingDetails!=null)
        {
            for(var i=0;i <= LateMarkSettingDetails.length-1;i++)
            {
                var table = document.getElementById("tblLateMarkSettingDetails");
                var rowCount = table.rows.length;
                var row = table.insertRow(rowCount);
                var count = $('#tblLateMarkSettingDetails tr').length;

                row.insertCell(0).innerHTML = "" + LateMarkSettingDetails[i][0].Value + "";
                row.insertCell(1).innerHTML = "" + LateMarkSettingDetails[i][1].Value + "";
                row.insertCell(2).innerHTML = "" + LateMarkSettingDetails[i][2].Value + "";
            }
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null && Icon != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.remove('swal2-show');
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake');
                    });
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake');
                    }, 500);
                }
            }).then(function () {
                window.location.reload();
            });
        }

        $("#ddlCompanyName").on("change", function () {
            $("#ddlLateMarkSettingBranchId").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_TimeOffice_LateMarkSetting")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlLateMarkSettingBranchId").append("<option value=''>--Select--</option>");
                        $.each(data, function (i, p) {
                            $("#ddlLateMarkSettingBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            });
        });
    });

    jQuery.validator.addMethod(
        "regex",
        function (value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        },
        "Invalid input"
    );

    $("#SaveLateMarkSetting").validate({
        rules: {
            CmpId: { required: true },
            LateMarkSettingBranchId: { required: true },
            LateMarkSettingName: { required: true }

        },
        messages: {
            CmpId: { required: "Company name is required" },
            LateMarkSettingBranchId: { required: "Business unit is required" },
            LateMarkSettingName: { required: "Late mark setting name is required" }

        }
    });

    function validateLateMarkCount(input, errorLabelId) {
        const value = input.value.trim();
        const errorLabel = document.getElementById(errorLabelId);

        // Reset error state
        errorLabel.style.display = 'none';
        errorLabel.textContent = '';

        // Check if input is empty
        if (!value) {
            errorLabel.textContent = 'Please enter a count.';
            errorLabel.style.display = 'block';
            return false;
        }

        // Convert to number and validate range
        const count = parseInt(value, 10);
        if (isNaN(count) || count < 0 || count > 31) {
            errorLabel.textContent = 'Please enter a count between 1 and 31.';
            errorLabel.style.display = 'block';
            return false;
        }

        return true;
    }
    var srno = 0;

    //[ validation]
    $("#txtToLateMarkCount").keyup(function () {debugger
        var errorLabel = document.getElementById('ErrorToLateMarkCount');
        var toLateMarkCountVal = $(this).val().trim();
        var fromLateMarkCount = Number($('#txtFromLateMarkCount').val());
        var toLateMarkCount = Number(toLateMarkCountVal);

        // Reset error state
        errorLabel.style.display = 'none';
        errorLabel.textContent = '';

        // Check if input is empty
        if (toLateMarkCountVal === "") {
            errorLabel.textContent = "Enter To Late Mark Count.";
            errorLabel.style.display = 'block';
            return false;
        }

        // Validate range (1–31)
        if (isNaN(toLateMarkCount) || toLateMarkCount < 0 || toLateMarkCount > 31) {
            errorLabel.textContent = "Please enter To Late Mark Count between 1 and 31.";
            errorLabel.style.display = 'block';
            return false;
        }

        // Check if ToLateMarkCount > FromLateMarkCount (if FromLateMarkCount is non-empty)
        if (!isNaN(fromLateMarkCount) && $('#txtFromLateMarkCount').val().trim() !== '' && toLateMarkCount <= fromLateMarkCount) {
            errorLabel.textContent = "To Late Mark Count must be greater than From Late Mark Count.";
            errorLabel.style.display = 'block';
            return false;
        }

        return true;
    });

    $("#txtFromLateMarkCount").keyup(function () {
        var errorLabel = document.getElementById('ErrorFromLateMarkCount');
        var fromLateMarkCountVal = $(this).val().trim();
        var fromLateMarkCount = Number(fromLateMarkCountVal);

        // Reset error state
        errorLabel.style.display = 'none';
        errorLabel.textContent = '';

        // Check if input is empty
        if (fromLateMarkCountVal === "") {
            errorLabel.textContent = "Enter From Late Mark Count.";
            errorLabel.style.display = 'block';
            return false;
        }

        // Validate range (1–31)
        if (isNaN(fromLateMarkCount) || fromLateMarkCount < 0 || fromLateMarkCount > 31) {
            errorLabel.textContent = "Please enter From Late Mark Count between 1 and 31.";
            errorLabel.style.display = 'block';
            return false;
        }

        // Trigger ToLateMarkCount validation to ensure To > From
        if ($('#txtToLateMarkCount').val().trim() !== '') {
            $("#txtToLateMarkCount").trigger('keyup');
        }

        return true;
    });
    $("#btnAdd").click(function (e) {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }

        //for validation
        //var ddlGender = $('#ddlGender option:selected').val();
        var FromLateMarkCount = $("#txtFromLateMarkCount").val().trim();
        var ToLateMarkCount = $("#txtToLateMarkCount").val().trim();
        var Day = $("#txtDay").val().trim();

        if(FromLateMarkCount=="")
        {$('#ErrorFromLateMarkCount').html("From Late Mark Count is required");   return false;}
        else{ $('#ErrorFromLateMarkCount').html("");}

        if(ToLateMarkCount=="")
        {$('#ErrorToLateMarkCount').html("To Late Mark Count is required");   return false;}
        else{ $('#ErrorToLateMarkCount').html("");}

        //if(ToLateMarkCount <= FromLateMarkCount)
        //{ $('#ErrorToLateMarkCount').html("To Late Mark Count is Always Greater"); return false; }
        //else{ $('#ErrorToLateMarkCount').html("");}

        var sum= 0;
        var IncomeTotal=Number( $('#txtToLateMarkCount').val());
        var sum = IncomeTotal+1;

        var table = document.getElementById("tblLateMarkSettingDetails");
        var rowCount = table.rows.length;
        var row = table.insertRow(rowCount);
        var count = $('#tblLateMarkSettingDetails tr').length;

        row.insertCell(0).innerHTML = "" + FromLateMarkCount + "";
        row.insertCell(1).innerHTML = "" + ToLateMarkCount + "";
        row.insertCell(2).innerHTML = "" + Day + "";


        $('#txtFromLateMarkCount').val(''),
        $('#txtToLateMarkCount').val(''),
        $('#txtFromLateMarkCount').val(sum);

        //validation for dropdown
        var count = $('#tblLateMarkSettingDetails tr').length;

        if (count!="" ) {
            $("#ddlCompanyName").attr("disabled", "disabled");
            $('#ddlCompanyName').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
            $("#ddlLateMarkSettingBranchId").attr("disabled", "disabled");
            $('#ddlLateMarkSettingBranchId').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
            $("#txtFromLateMarkCount").attr("disabled", "disabled");
            $("#txtLateMarkSettingName").attr("disabled", "disabled");
        }
        else
        {
            $("#ddlCompanyName").removeAttr("disabled");
            $("#txtFromLateMarkCount").removeAttr("disabled");
            $("#txtLateMarkSettingName").removeAttr("disabled");
        }

    });
    $("#btnDeleteRow").click(function () {debugger
        var table = document.getElementById("tblLateMarkSettingDetails");
        var rowCount = table.rows.length;

        if (rowCount > 0) {
            table.deleteRow(rowCount - 1);
        }

        var lowerLast = $('#tblLateMarkSettingDetails').find('tr').last();

        if (lowerLast.length > 0) {
            var lowerLastCell = lowerLast[0].cells;
            var toLateMarkCount = lowerLastCell[1].innerHTML;
            var fromLateMarkCount = Number(toLateMarkCount) + 1;
            $("#txtFromLateMarkCount").val(fromLateMarkCount);
        } else {
            $("#ddlCompanyName").removeAttr("disabled");
            $("#txtFromLateMarkCount").removeAttr("disabled");
            $('#ddlCompanyName').next('.select2').find('.select2-selection').css('background-color', '');
            $("#txtFromLateMarkCount").val("");
            $("#txtLateMarkSettingName").removeAttr("disabled");
        }
    });
    var form = $("#SaveLateMarkSetting");
    form.validate();

    $("#btnSubmit").on("click", function () {debugger
        if (!form.valid()) {
            return false;
        }
        var CmpId = Number($("#ddlCompanyName").val());
        var LateMarkSettingBranchId = Number($("#ddlLateMarkSettingBranchId").val());
        var LateMarkSettingName = $("#txtLateMarkSettingName").val();
        var LateMarkSettingId_Encrypted = $("#LateMarkSettingId_Encrypted").val();
        var LateMarkSettingId = $("#LateMarkSettingId").val();

        var table = document.getElementById("tblLateMarkSettingDetails");
        var rowCount = table.rows.length;
        var Task = [];

        for (var i = 0; i < rowCount; i++) {
            var data = {
                FromLateMarkCount: parseInt(table.rows[i].cells[0].innerHTML),
                ToLateMarkCount: parseInt(table.rows[i].cells[1].innerHTML),
                Day: table.rows[i].cells[2].innerHTML
            };
            Task.push(data);
        }

        var error = $("#lbltblerror");
        if (rowCount <= 0) {
            error.text("Please add at least one late mark setting").show();
            return;
        } else {
            error.hide();
        }

        // Check if late mark setting exists
        $.ajax({
            url: '@Url.Action("IsLateMarkSettingExists", "Setting_TimeOffice_LateMarkSetting")',
            method: "GET",
            data: { CmpId: CmpId,
                LateMarkSettingBranchId: LateMarkSettingBranchId,
                LateMarkSettingName:LateMarkSettingName,
                LateMarkSettingId_Encrypted: LateMarkSettingId_Encrypted
            },
            success: function (response) {
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon === "error") {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup();
                            popup.classList.remove('swal2-show');
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake');
                            });
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake');
                            }, 500);
                            return false;
                        }
                    });
                } else {
                    // Proceed to save/update
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("SaveUpdate", "Setting_TimeOffice_LateMarkSetting")',
                        data: JSON.stringify({
                            Task: Task,
                            CmpId: CmpId,
                            LateMarkSettingBranchId: LateMarkSettingBranchId,
                            LateMarkSettingName: LateMarkSettingName,
                            LateMarkSettingId_Encrypted: LateMarkSettingId_Encrypted,
                            LateMarkSettingId:LateMarkSettingId,
                        }),
                        contentType: "application/json; charset=utf-8",
                        dataType: "json",
                        success: function (response) {
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup();
                                        popup.classList.remove('swal2-show');
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake');
                                        });
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake');
                                        }, 500);
                                        return false;
                                    }
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("GetList", "Setting_TimeOffice_LateMarkSetting", new { area = "Setting" })';
                                    }
                                });
                            }
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                text: 'An error occurred while saving the record.',
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup();
                                    popup.classList.remove('swal2-show');
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake');
                                    });
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake');
                                    }, 500);
                                    return false;
                                }
                            });
                        }
                    });
                }
            }
        });
    });
</script>