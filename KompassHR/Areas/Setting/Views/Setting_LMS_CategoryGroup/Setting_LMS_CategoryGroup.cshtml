<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                LMS Category Group
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_LMS_Menu", "Setting_LMS_Menu", new { id = 38, ScreenId =562, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Shift Group - <Span>@ViewBag.AddUpdateTitle</Span></h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define LMS category group here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "Setting_LMS_CategoryGroup", new { area = "Setting" })" id="SaveCategoryGroup" method="post" data-parsley-validate="true">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CategoryGroupCompanyId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { id = "txtCategoryGroupCompanyId", @class = "form-select",name= "CategoryGroupCompanyId", autocomplete = "off", @required = "required" })
                                                @Html.HiddenFor(model => model.CategoryGroupMasterId_Encrypted, new { id = "EncryptedId" })
                                                @Html.HiddenFor(model => model.CategoryGroupMasterId)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CategoryGroupBranchId, new SelectList(ViewBag.Location, "Id", "Name"), "--Select--", new { name = "ShiftGroupBranchId", @class = "form-control", @id = "ddlBusinessUnit" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                               Category Group Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LMSCategoryGroupName, new { @class = "form-control", type = "text", id = "txtCategoryGroupName", autocomplete = "Off", @required = "required" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr class="mt-0">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                            </label>
                                            <div class="col-md-5">
                                                <table class="table table-bordered align-middle tblAddData" id="tblShiftList" style="width: 100%;">
                                                    <thead style="text-align: center;">
                                                        <tr style="background-color: lightgray; border: 1px solid lightslategray;">
                                                            <th style="border: 1px solid lightslategray;" class="text-nowrap width-45">Select</th>
                                                            <th style="border: 1px solid lightslategray;" class="text-nowrap ">Category Name</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @if (ViewBag.CategoryName != null)
                                                        {
                                                            foreach (var item in ViewBag.CategoryName)
                                                            {
                                                                <tr>
                                                                    <td style="text-align: center;">
                                                                        <input type="checkbox" name="selectedCategories" value="@item.Id" @(item.IsActive == true ? "checked" : "") />
                                                                    </td>
                                                                    <td>@item.Name</td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_LMS_CategoryGroup", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnShiftGroupList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#txtCategoryGroupCompanyId").select2();
        $("#ddlBusinessUnit").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick:false
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#txtCategoryGroupCompanyId").on("change", function () {
            $("#ddlBusinessUnit").find("option").remove();
            var CmpId = $("#txtCategoryGroupCompanyId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_LMS_CategoryGroup")',
                //url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlBusinessUnit").append("<option value=''> --Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBusinessUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        });
    });//ready funcation
</script>

<script>

    var SelectedShiftList = @Html.Raw(Json.Encode(ViewBag.SelectedShiftList));
    if(SelectedShiftList!=null || SelectedShiftList!="")
    {
        var table = document.getElementById("tblShiftList");
        $.each(SelectedShiftList, function (data1, value) {
            debugger;
            //var rowCount = data.length;
            var rowCount = table.rows.length;
            var row = table.insertRow(rowCount);
            var count = SelectedShiftList.length;
            row.insertCell(0).innerHTML = ""+'<input id="chk" type="checkbox" name="checkBoxName" class="form-check-input" Value="'+value[0].Value+'" '+value[1].Value+'>'+""
            row.insertCell(1).innerHTML = "" + value[2].Value + "";
            row.insertCell(2).innerHTML = "" + value[3].Value + "";
            row.insertCell(3).innerHTML = "" + value[4].Value + "";
        });
    }
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );
    $('#SaveCategoryGroup').validate({
        rules: {
            CategoryGroupCompanyId: {
                required: true,
            },
            CategoryGroupBranchId: {
                required: true,
            },
            LMSCategoryGroupName: {
                required: true,
            }
        },
        messages: {
            CategoryGroupCompanyId: {
                required: "Company name  is required"
            },
            CategoryGroupBranchId: {
                required: "Business unit is required"
            },
            LMSCategoryGroupName: {
                required: "Category group name is required"
            }
        },
    });

    var form = $("#SaveCategoryGroup");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var CategoryGroupMasterId_Encrypted = $("#EncryptedId").val();
        var CompanyId = $("#txtCategoryGroupCompanyId").val();
        var BranchId = $("#ddlBusinessUnit").val();
        var CategoryName = $("#txtCategoryGroupName").val(); // Match parameter name

        var listCategoryGroup = [];
        $(':checkbox:checked').each(function (i) {
            var data1 = {};
            var currentRow = $(this).closest("tr");
            data1.CategoryId = $(this).val();
            data1.CategoryName = currentRow.find("td:eq(1)").text().trim();
            data1.IsActive = true;
            listCategoryGroup.push(data1);
        });

        if (listCategoryGroup.length == 0) {
            Swal.fire({
                icon: "error",
                text: "Please select at least one shift group",
                allowOutsideClick: () => false
            });
            return false;
        }

        $.ajax({
            async: true,
            type: "POST",
            url: '@Url.Action("IsExists", "Setting_LMS_CategoryGroup")',
            data: JSON.stringify({
                CategoryGroupMasterId_Encrypted: CategoryGroupMasterId_Encrypted,
                CompanyId: CompanyId,
                BranchId: BranchId,
                CategoryName: CategoryName,
                Task: listCategoryGroup
            }),
            contentType: "application/json; charset=utf-8",
            dataType: "json", // Use 'json' if your action returns JsonResult or similar
            success: function (response) {
                debugger;
                //var Getdata = JSON.parse(response);
                //var Message1 = response.Message;
                //var Icon1 = response.Icon;

                //if (response!="") {
                //    if (Message1 != null) {
                //        Swal.fire({
                //            icon: Icon1,
                //            text: Message1,
                //            allowOutsideClick: false
                //        });
                //    }
                //}
                if (response && typeof response === "object" && response.Message) {
                    var Message1 = response.Message;
                    var Icon1 = response.Icon || "info"; // fallback to "info" if Icon is undefined

                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: false
                    });
                }
                else{
                    $.ajax({
                        async: true,
                        type: "POST",
                        url: '@Url.Action("SaveUpdate", "Setting_LMS_CategoryGroup")',
                        data: JSON.stringify({
                            CategoryGroupMasterId_Encrypted: CategoryGroupMasterId_Encrypted,
                            CompanyId: CompanyId,
                            BranchId: BranchId,
                            CategoryName: CategoryName,
                            Task: listCategoryGroup
                        }),
                        contentType: "application/json; charset=utf-8",
                        dataType: "json", // Use 'json' if your action returns JsonResult or similar
                        success: function (response) {
                            debugger;
                            //var Getdata = JSON.parse(response);
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (Icon1!="") {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: false
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            location.reload();
                                        }
                                    });
                                }
                            }
                        }
                    });
                }
            }
        });
    });
</script>

