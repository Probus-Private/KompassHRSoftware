<script>
    $(document).ready(function () {
        var message = "@TempData["Message"]";
        var icon = "@TempData["Icon"]";

        if (message) {
            swal({
                title: message,
                icon: icon,
                button: "OK",
            });
        }
    });
</script>


<script>
$(document).ready(function () {
    $("#UploadSubmit").click(function (e) {
        e.preventDefault();
        $(".error-message").text("");
        var isValid = true;
        var usbName = $("#ddlUSBName").val();
        if (!usbName) {
            $("#ErrorUSBName").text("Please enter a USB name.");
            isValid = false;
        }

        var direction = $("#ddlDirection").val();
        if (!direction) {
            $("#ErrorDirection").text("Please enter a direction.");
            isValid = false;
        }

        var fileInput = $("#LogFile").val();
        var allowedExtensions = /(\.log|\.txt|\.csv|\.json|\.xml|\.dat)$/i;
        if (!fileInput) {
            $("#ErrorFile").text("Please upload a log file.");
            isValid = false;
        } else if (!allowedExtensions.exec(fileInput)) {
            $("#ErrorFile").text("Allowed file types: log, txt, csv, json, xml, dat.");
            isValid = false;
        }
        if (isValid) {
            $("#SaveLogFile").submit();
        }
    });
});
</script>