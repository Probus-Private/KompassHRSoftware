@model KompassHR.Areas.Setting.Models.Setting_Payroll.Mas_Employee_CTC_Template
@{
    ViewBag.Title = "Setting_Payroll_CTCTemplate";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
