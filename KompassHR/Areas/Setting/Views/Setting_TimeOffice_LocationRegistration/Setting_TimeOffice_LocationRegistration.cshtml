@model KompassHR.Areas.Setting.Models.Setting_TimeOffice.Mas_LocationRegistration
@{
    ViewBag.Title = "Setting_TimeOffice_LocationRegistration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }



    .box2 {
        width: 100px;
        height: 100px;
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
        margin-bottom: 10px;
    }

        .box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.03), 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        }

            .box2:hover .info i {
                color: #ff9c19;
            }


        .box2 .info i {
            font-size: 20px;
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
            font-size: 12px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .FS-12PX {
        font-size: 12px !important;
    }

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    .width-45 {
        width: 45px !important;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<style>
    #googleMap {
        width: 100%;
        height: 400px;
        border: none;
        transition: all 0.3s ease-in-out;
    }

        #googleMap.active {
            pointer-events: auto; /* becomes clickable */
        }



    /* Modal styles */
    .modal {
        display: none;
        position: fixed;
        z-index: 1;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0,0,0,0.4);
    }

    .modal-content {
        background-color: #fefefe;
        margin-right: 15% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 80%;
        height: 80%; /* Adjust height as needed */
    }

    /* Close button style */
    .close {
        color: #aaa;
        float: right;
        font-size: 28px;
        font-weight: bold;
    }

        .close:hover,
        .close:focus {
            color: black;
            text-decoration: none;
            cursor: pointer;
        }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Location Registration
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new { id = 5, ScreenId =150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" EmpList-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Location Registration - @ViewBag.AddUpdateTitle</h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("SaveUpdate", "Setting_TimeOffice_LocationRegistration", new { area = "Setting" })' id="SaveLocationRegistration" method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Latitude

                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.LocationLatitude, new
                                   {
                                       @class = "form-control",
                                       name = "LocationLatitude",
                                       id = "txtLatitude"
                                   })
                                        @Html.HiddenFor(model => model.LocationRegistrationId_Encrypted, new { id = "LocationRegistrationId_Encrypted" })
                                        @Html.ValidationMessageFor(model => model.LocationLatitude, "", new { @class = "help-block", @id = "ErrorLocationLatitude", @style = "color:red" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Longitude

                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.LocationLongitude, new
                                   {
                                       @class = "form-control",
                                       name = "LocationLongitude",
                                       id = "txtLongitude"
                                   })
                                        @Html.ValidationMessageFor(model => model.LocationLongitude, "", new { @class = "help-block", @id = "ErrorLocationLongitude", @style = "color:red" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Location Name
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.LocationName, new { @class = "form-control", name = "LocationName", id = "txtLocationName", @autocomplete = "Off" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Area Range (in meters)
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.LocationAreaRange, new { @class = "form-control", name = "LocationAreaRange", type = "text", id = "txtLocationAreaRange", @autocomplete = "Off", onkeypress = " return numbervalidate(event)" })
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Remark

                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.LocationRemark, new { @class = "form-control", name = "LocationRemark", id = "txtLocationRemark", @autocomplete = "Off" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="row mb-15px">
                                    <button type="button" class="btn btn-secondary btn-sm" onclick="openMap()">
                                        <i class="fa-solid fa-location-dot"></i>&nbsp; Open Map
                                    </button>
                                </div>
                            </div>
                        </div>


                        <div class="row">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                </button>
                                                <a href="@Url.Action("GetList", "Setting_TimeOffice_LocationRegistration", new { area = "Setting" })">
                                                    <button type="button" class="btn btn-danger btn-sm" id="btnLocationList">
                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- The Modal -->
                        <div id="myModal" class="modal">
                            <!-- Modal content -->
                            <div class="modal-content" style="margin-left: 263px; margin-top: 100px;">
                                <span class="close" onclick="closeModal()">&times;</span>
                                <!-- Google Maps iframe -->
                                <iframe id="googleMap"
                                        style="width: 100%; height: 400px;"
                                        frameborder="0"
                                        allowfullscreen></iframe>


                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    function openMap() {
        var latitude = Number($("#txtLatitude").val()) || 0;
        var longitude = Number($("#txtLongitude").val()) || 0;

        var modal = document.getElementById("myModal");
        var iframe = document.getElementById("googleMap");

        modal.style.display = "block";

        var googleMapsUrl = "https://maps.google.com/maps?q=" + latitude + "," + longitude + "&z=15&output=embed";
        iframe.src = googleMapsUrl;
    }



    function closeModal() {
        var modal = document.getElementById("myModal");
        var iframe = document.getElementById("googleMap");

        modal.style.display = "none";
        iframe.src = "";
        iframe.classList.remove("active");
    }

    // Close modal when clicking outside the map area
    window.onclick = function (event) {
        var modal = document.getElementById("myModal");
        if (event.target == modal) {
            closeModal();
        }
    }
</script>


<script>
    $(document).ready(function () {
        $("#txtCmpId").select2();
        $("#txtBranchId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var UpdateId = @Html.Raw(Json.Encode(TempData["UpdateId"]));
        var LocationLatitude = @Html.Raw(Json.Encode(TempData["LocationLatitude"]));
        var LocationLongitude = @Html.Raw(Json.Encode(TempData["LocationLongitude"]));
        if(UpdateId!="")
        {
            $("#txtLatitude").val(LocationLatitude);
            $("#txtLongitude").val(LocationLongitude);
        }
        else
        {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(successCallback, errorCallback);
            } else {
                console.log("Geolocation is not supported by your browser");
            }

            function successCallback(position) {
                const latitude = position.coords.latitude;
                const longitude = position.coords.longitude;
                $("#txtLatitude").val(latitude);
                $("#txtLongitude").val(longitude);
            }

            function errorCallback(error) {
                console.log("Error getting geolocation: " + error.message);
            }

        }



    });

</script>

<script>
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveLocationRegistration').validate({
        rules: {
            LocationName: {
                required: true,
            },
            LocationAreaRange: {
                required: true,
            },


        },
        messages: {

            LocationName: {
                required:"Location name is required",
            },
            LocationAreaRange: {
                required:"Area range is required",
            },

        },
    });


    var form = $("#SaveLocationRegistration");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        var Latitude=$("#txtLatitude").val();
        var Longitude=$("#txtLongitude").val();
        if(Latitude=="")
        {
            $('#ErrorLocationLatitude').html("Value is required");return false;
        }
        else{ $('#ErrorLocationLatitude').html("");}
        if(Longitude=="")
        {
            $('#ErrorLocationLongitude').html("Value is required");return false;
        }
        else{ $('#ErrorLocationLongitude').html("");}

        form.valid();
        if(form.valid()==false)
        {
            return false;
        }

        var LocationName=$("#txtLocationName").val();
        var LocationRegistrationId_Encrypted=$("#LocationRegistrationId_Encrypted").val();
        $.ajax({
            url:'@Url.Action("IsLocationRegistrationExists", "Setting_TimeOffice_LocationRegistration", new { area = "Setting" })',
            method:"get",
            data:{LocationName:LocationName,LocationRegistrationId_Encrypted:LocationRegistrationId_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveLocationRegistration").submit();

                }
            }
        });

    });

    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>
