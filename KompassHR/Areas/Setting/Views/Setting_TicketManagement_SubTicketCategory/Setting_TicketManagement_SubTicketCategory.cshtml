@model KompassHR.Areas.Setting.Models.Setting_TicketManagement.Ticket_SubCategory

@{
    ViewBag.Title = "Setting_TicketManagement_SubTicketCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Ticket Sub Category
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "Setting" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TicketManagement_Menu", "Setting_TicketManagement_Menu", new { id =13 ,ScreenId = 89, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Ticket Sub Category - <Span><b>@ViewBag.AddUpdateTitle</b></Span> </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add Ticktes Sub category here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/Setting/Setting_TicketManagement_SubTicketCategory/SaveUpdate" id="SaveTicketSubCategory" method="post" data-parsley-validate="true">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Ticket Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.TicketCategory_Id, new SelectList(ViewBag.CategoryList, "Id", "Name"), "--Select--", new { id = "ddlCategoryList", @class = "form-select", name = "TicketCategory_Id" })
                                                @Html.HiddenFor(model => model.TicketSubCategoryID_Encrypted,new { id= "TicketSubCategoryID_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Sub Category Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.TicketSubCategoryName, new { @class = "form-control", type = "text", id = "txtTicketSubCategoryName", autocomplete = "Off", name = "TicketSubCategoryName" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetTicketCategoryList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

    });

    $("#btnGetTicketCategoryList").click(function () {
        var url = '@Url.Action("GetList", "Setting_TicketManagement_SubTicketCategory")';
        window.location.href = url;
    });

    jQuery.validator.addMethod(
"regex",
 function(value, element, regexp) {
     if (regexp.constructor != RegExp)
         regexp = new RegExp(regexp);
     else if (regexp.global)
         regexp.lastIndex = 0;
     return this.optional(element) || regexp.test(value);
 },"erreur expression reguliere"
);
    
    $("#SaveTicketSubCategory").validate({
        rules: {
            TicketCategory_Id: {
                required: true,
            },
            TicketSubCategoryName: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
        },
        messages: {
            TicketCategory_Id: {
                required: "Please Select Category",
            },
            TicketCategoryName: {
                required: "Please enter sub category name",
                regex:"Please enter only alphabet",
            },


        }
    });

    var form = $("#SaveTicketSubCategory");
    form.validate();
    $("#btnSubmit").click(function () {
        if(form.valid()==false)
        {
            return false;
        }
        debugger;

        var TicketSubCategoryID_Encrypted=$("#TicketSubCategoryID_Encrypted").val();
        var TicketSubCategoryName=$("#txtTicketSubCategoryName").val();
        var TicketCategory_Id=$("#ddlCategoryList").val();


        $.ajax({
            url:"IsSubTicketCategoryExists",
            method:"get",
            data:{TicketSubCategoryID_Encrypted:TicketSubCategoryID_Encrypted,TicketSubCategoryName:TicketSubCategoryName,TicketCategory_Id:TicketCategory_Id},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveTicketSubCategory").submit();

                }
            }
        });

    });
</script>