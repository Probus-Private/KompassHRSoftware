@model KompassHR.Areas.Setting.Models.Setting_PMS.PMS_Competencies

@{
    ViewBag.Title = "Setting_Competencies";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Competency
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "Setting_Competencies", new { id = 11, ScreenId = 820, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Competency - @ViewBag.AddUpdateTitle</h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add Competency here!
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form"
                                  action='@Url.Action("SaveUpdate", "Setting_Competencies", new { area = "Setting" })'
                                  id="SaveCompetency"
                                  method="post"
                                  data-parsley-validate="true">

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Competency Type <span class="text-danger">*</span>
                                        </label>
                                        @Html.DropDownListFor(model => model.CompetencyFrameworkId,
                new SelectList(ViewBag.GetType, "Id", "Name", ViewBag.SelectedFrameworkId),
                "-- Select --",
                new
                {
                    @id = "txtCompetencyFrameworkId",
                    @class = "form-select",
                    autocomplete = "off",
                    required = "required"
                })
                                        @Html.HiddenFor(model => model.CompetencyId_Encrypted, new { id = "CompetencyId_Encrypted" })
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Competency Name <span class="text-danger">*</span>
                                        </label>
                                        @Html.TextBoxFor(model => model.CompetencyName, new
       {
           @class = "form-control",
           @placeholder = "Enter competency name",
           @id = "txtCompetencyName",
           autocomplete = "off"
       })
                                    </div>
                                </div>

                                <div class="row mb-3">

                                    @*<div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Weightage <span class="text-danger">*</span>
                                        </label>
                                        @Html.TextBoxFor(model => model.Weightage, new
                                   {
                                       @class = "form-control",
                                       @placeholder = "Enter Weightage",
                                       @id = "txtWeightage",
                                       autocomplete = "off"
                                   })
                                    </div>*@

                                    <div class="col-md-12">
                                        <label class="form-label text-dark fw-semibold">
                                            Description 
                                        </label>
                                        @Html.TextAreaFor(model => model.Description, new
       {
           @class = "form-control",
           @rows = "3",
           @placeholder = "Enter description",
           @id = "txtDescription",
           autocomplete = "off"
       })
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Competencies", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnDocumentCategory">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

    });//ready Funcation

    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $('#SaveCompetency').validate({
        rules: {
            CompetencyFrameworkId: {
                required: true,
            },
            CompetencyName: {
                required: true,
            },
        },
        messages: {
            CompetencyFrameworkId: {
                required: "Competency Framework is required",
            },
            CompetencyName: {
                required: "Competency Name is required",
            },
        },
    });


    var form = $("#SaveCompetency");
    form.validate();
    $("#btnSubmit").click(function () {
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var CompetencyFrameworkId=$("#txtCompetencyFrameworkId").val();
        var CompetencyName=$("#txtCompetencyName").val();
        var CompetencyId_Encrypted=$("#CompetencyId_Encrypted").val();

        $.ajax({
            url: '@Url.Action("IsValidation", "Setting_Competencies")',
            method:"get",
            data:{CompetencyFrameworkId:CompetencyFrameworkId,CompetencyName:CompetencyName,CompetencyId_Encrypted:CompetencyId_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveCompetency").submit();

                }
            }
        });

    });
</script>