
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 67px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 67px;
    }
</style>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Job Opening</title>
</head>
<body>
    <div id="content" class="app-content">
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
                <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                    Job Opening
                </h1>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Setting_Recruitment_Menu", "Setting_Recruitment_Menu", new { id =1 ,ScreenId =35, area = "Setting" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                        </a>
                    </li>
                </ol>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                     <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Job Opening - List</h4>
                       
                    </div> 
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            This is the list of job openings.
                        </p>
                    </div>
                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="/Setting/Setting_Recruitment_JobOpening/Setting_Recruitment_JobOpening">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle" id="fixed-header"
                                               style="width: 100%;">
                                            <thead>
                                                <tr>
                                                    <th class="fixed-side">Update</th>
                                                    <th class="fixed-side1">Delete</th>
                                                    <th class="text-nowrap">DocNo </th>
                                                    <th class="text-nowrap">Company Name </th>
                                                    <th class="text-nowrap">Business Unit</th>
                                                    <th class="text-nowrap">Department Name </th>
                                                    <th class="text-nowrap">Designation Name </th>
                                                    <th class="text-nowrap">Job Title </th>
                                                    <th class="text-nowrap">No Of Postions</th>
                                                    <th class="text-nowrap">Job Posting Date </th>
                                                    <th class="text-nowrap">Job Posting Closing Date</th>

                                                    <th class="text-nowrap">Job Location </th>
                                                    <th class="text-nowrap">Experience </th>
                                                    <th class="text-nowrap">Annual Salary </th>
                                                    <th class="text-nowrap">Currency Name </th>
                                                    <th class="text-nowrap">Job Type</th>
                                                    <th class="text-nowrap">Preferred Candidate</th>
                                                    <th class="text-nowrap">JobDescription</th>
                                                    <th class="text-nowrap">Skill </th>
                                                    <th class="text-nowrap">Age Between</th>
                                                    <th class="text-nowrap">Required With InDays </th>
                                                    <th class="text-nowrap">No Of Day Working InWeek</th>
                                                    <th class="text-nowrap">Night Shift Allowed </th>
                                                    <th class="text-nowrap">WFMAllowed</th>
                                                    <th class="text-nowrap">HybriAllowed </th>
                                                    <th class="text-nowrap">JobOpeningManpowerRequisitionId </th>
                                                    <th class="text-nowrap">Is Walk In</th>
                                                    <th class="text-nowrap">Walk In From Date </th>
                                                    <th class="text-nowrap">Walk In To Date </th>
                                                    <th class="text-nowrap">Walk In Time</th>
                                                    <th class="text-nowrap">Contact Person</th>
                                                    <th class="text-nowrap">Mobile No</th>
                                                    <th class="text-nowrap">Walk In Venue </th>
                                                    <th class="text-nowrap">Created By</th>
                                                    <th class="text-nowrap">Created Date</th>
                                                    <th class="text-nowrap">Modified By</th>
                                                    <th class="text-nowrap">Modified Date</th>
                                                    <th class="text-nowrap">Machine Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetJobOpeningList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <button type="button" onclick="UpdateJobOpening('@d.JobOpeningId_Encrypted')" id="btnUpdate"
                                                                    class="btn btn-success btnpress ListBtn">
                                                                <i class="fa-solid fa-pencil-alt"></i>
                                                            </button>
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" onclick="DeleteJobOpening('@d.JobOpeningId_Encrypted')" id="btnDelete"
                                                                    class="btn btn-danger ListBtn btnpress">
                                                                <i class="fa-solid fa-trash-alt"></i>
                                                            </button>
                                                        </td>
                                                        <td>@d.DocNo</td>
                                                        <td>@d.companyname</td>
                                                        <td>@d.branchname</td>
                                                        <td>@d.DepartmentName</td>
                                                        <td>@d.DesignationName</td>
                                                        <td>@d.JobTittle</td>
                                                        <td>@d.NoOfPostions</td>
                                                        <td>@d.JobPostingDate.ToString(string.Format("dd/MMM/yyyy"))</td>
                                                        <td>@d.JobPostingClosingDate.ToString(string.Format("dd/MMM/yyyy"))</td>
                                                        <td>@d.JobLocation</td>
                                                        <td>@d.Experience</td>
                                                        <td>@d.AnnualSalary</td>
                                                        <td>@d.CurrencyName</td>
                                                        <td>@d.JobType</td>
                                                        <td>@d.PreferredCandidate</td>
                                                        <td>@d.JobDescription</td>
                                                        <td>@d.Skill</td>
                                                        <td>@d.AgeBetween</td>
                                                        <td>@d.RequiredWithinDays</td>
                                                        <td>@d.NoOfDayWorkingInWeek</td>
                                                        <td>@d.NightShiftAllowed</td>
                                                        <td>@d.WFMAllowed</td>
                                                        <td>@d.HybriAllowed</td>
                                                        <td>@d.JobOpeningManpowerRequisitionId</td>
                                                        <td>@d.IsWalkIn</td>
                                                        <td>@d.WalkInFromDate</td>
                                                        <td>@d.WalkInToDate</td>
                                                        <td>@d.WalkInTime</td>
                                                        <td>@d.ContactPerson</td>
                                                        <td>@d.MobileNo</td>
                                                        <td>@d.WalkInVenue</td>
                                                        <td>@d.CreatedBy</td>
                                                        <td>@d.CreatedDate</td>
                                                        <td>@d.ModifiedBy</td>
                                                        <td>@d.ModifiedDate</td>
                                                        <td>@d.MachineName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>


</body>
</html>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>


<script>
    function UpdateJobOpening(JobOpeningId_Encrypted) {
        var url = '@Url.Action("Setting_Recruitment_JobOpening", "Setting_Recruitment_JobOpening")?JobOpeningId_Encrypted=' + JobOpeningId_Encrypted;
        window.location.href = url;
    }

    function DeleteJobOpening(JobOpeningId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_Recruitment_JobOpening")?JobOpeningId_Encrypted=' + JobOpeningId_Encrypted;
                //window.location.href = url;
              
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


</script>



