                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Annual Salary <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.AnnualSalary, new { @class = "form-control", type = "number", id = "txtAnnualSalary", autocomplete = "Off", name = "AnnualSalary" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Currency <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CurrencyID, new SelectList(ViewBag.GetCurrencyName, "CurrencyId", "CurrencyName"), "--Select--", new { id = "CurrencyID", @class = "form-select", autocomplete = "off", name = "CurrencyID" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Job Type <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">

                                                @Html.DropDownListFor(model => model.JobType, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Permannent", Value = "Permannent"},
                                                    new SelectListItem { Text = "Temparary", Value = "Temparary"},
                                                     new SelectListItem { Text = "Contract Base", Value = "Contract Base"},
                                                }, "--Select--", new { id = "ddlJobType", @class = "form-select", autocomplete = "off", name = "JobType" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Preferred Candidate <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PreferredCandidate, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Male", Value = "Male"},
                                                    new SelectListItem { Text = "Female", Value = "Female"},
                                                }, "--Select--", new { id = "ddlPreferredCandidate", @class = "form-select", autocomplete = "off", name = "PreferredCandidate" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Job Description <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.JobDescription, new { @class = "form-control", type = "text", id = "txtJobDescription", autocomplete = "Off", name = "JobDescription" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Skills <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.Skill, new { @class = "form-control", type = "text", id = "txtSkill", autocomplete = "Off", name = "Skill" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Age Limit <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.AgeBetween, new { @class = "form-control", type = "number", id = "txtAgeBetween", autocomplete = "Off", name = "AgeBetween" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Required Within <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.RequiredWithinDays, new { @class = "form-control", type = "number", id = "txtRequiredWithinDays", autocomplete = "Off", name = "RequiredWithinDays" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                No Of Day Working InWeek <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.NoOfDayWorkingInWeek, new { @class = "form-control", type = "number", id = "txtNoOfDayWorkingInWeek", autocomplete = "Off", name = "NoOfDayWorkingInWeek" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-4"></div>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.NightShiftAllowed, new { id = "chkNightShiftAllowed", name = "NightShiftAllowed" })
                                                <label class="form-label"> Night Shift Allowed </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-4"></div>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.WFMAllowed, new { id = "chkWFMAllowed", name = "WFMAllowed" })
                                                <label class="form-label"> WFH Allowed </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-4"></div>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.HybridAllowed, new { id = "chkHybriAllowed", name = "HybriAllowed" })
                                                <label class="form-label"> Hybrid Allowed </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr class="mt-0">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Walk In Drive <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.IsWalkIn, new List<SelectListItem>{
                                                new SelectListItem {Text ="Yes", Value="true"},
                                                 new SelectListItem {Text ="No", Value="false"}
                                              }, "--Select--", new { @class = "form-select", name = "IsWalkIn", id = "ddlIsWalkIn", @onchange = "check()" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Walk In From Date <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.WalkInFromDate, new { @class = "form-control", type = "date", id = "dateWalkInFromDate", autocomplete = "Off", name = "WalkInFromDate" })
                                                <span id="ErrorWalkInFromDate" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Walk In To Date  <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.WalkInToDate, new { @class = "form-control", type = "date", id = "dateWalkInToDate", autocomplete = "Off", name = "WalkInToDate" })
                                                <span id="ErrorWalkInToDate" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Walk In Time <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.WalkInTime, new { @class = "form-control", type = "text", id = "dateWalkInTime", autocomplete = "Off", name = "WalkInToDate" })
                                                <span id="ErrordateWalkInTime" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
