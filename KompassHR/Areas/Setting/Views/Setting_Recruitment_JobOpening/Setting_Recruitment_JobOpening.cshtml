                                                Contact Person <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ContactPerson, new { @class = "form-control", type = "text", id = "txtContactPerson", autocomplete = "Off", name = "ContactPerson" })
                                                <span id="ErrortxtContactPerson" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Mobile Number <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", type = "text", id = "txtMobileNo", autocomplete = "Off", name = "MobileNo" })
                                                <span id="ErrortxtMobileNo" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Venue <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.WalkInVenue, new { @class = "form-control", type = "text", id = "txtWalkInVenue", autocomplete = "Off", name = "WalkInVenue" })
                                                <span id="ErrortxtWalkInVenue" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="submit" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>

                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetJobOpeningList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $("#btnGetJobOpeningList").click(function () {
        var url = '@Url.Action("GetList", "Setting_Recruitment_JobOpening")';
        window.location.href = url;
    });

    $("#formReset").click(function () {
        $("#SaveJobOpening")[0].reset()
    });



   

</script>

<script>
    function check() {
        debugger;
        var ddlCheck=  $("#ddlIsWalkIn").val();
        if (ddlCheck== "false" || ddlCheck=="") {
            $("#dateWalkInFromDate").attr("disabled", "disabled");
            $("#dateWalkInToDate").attr("disabled", "disabled");
            $("#dateWalkInTime").attr("disabled", "disabled");
            $("#txtContactPerson").attr("disabled", "disabled");
            $("#txtMobileNo").attr("disabled", "disabled");
            $("#txtWalkInVenue").attr("disabled", "disabled");
        }
        else
        {
            $("#dateWalkInFromDate").removeAttr("disabled");
            $("#dateWalkInToDate").removeAttr("disabled");
            $("#dateWalkInTime").removeAttr("disabled");
            $("#txtContactPerson").removeAttr("disabled");
            $("#txtMobileNo").removeAttr("disabled");
            $("#txtWalkInVenue").removeAttr("disabled");
        }
    }

</script>

<script>

    $(document).ready(function () {
      
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        var IsWalkIn = @Html.Raw(Json.Encode(TempData["IsWalkIn"]));
        
        if (IsWalkIn == true) {
            $("#ddlIsWalkIn").val("true");
            $("#dateWalkInFromDate").removeAttr("disabled");
            $("#dateWalkInToDate").removeAttr("disabled");
            $("#dateWalkInTime").removeAttr("disabled");
            $("#txtContactPerson").removeAttr("disabled");
            $("#txtMobileNo").removeAttr("disabled");
            $("#txtWalkInVenue").removeAttr("disabled");
        }
        else if(IsWalkIn == false || IsWalkIn==null) {
            $("#ddlIsWalkIn").val("false");
            $("#dateWalkInFromDate").attr("disabled", "disabled");
            $("#dateWalkInToDate").attr("disabled", "disabled");
            $("#dateWalkInTime").attr("disabled", "disabled");
            $("#txtContactPerson").attr("disabled", "disabled");
            $("#txtMobileNo").attr("disabled", "disabled");
            $("#txtWalkInVenue").attr("disabled", "disabled");
        }

        var dt = @Html.Raw(Json.Encode(TempData["JobPostingDate"]));
        var dt1 = @Html.Raw(Json.Encode(TempData["JobPostingClosingDate"]));
        if(dt == null || dt == "")
        {

        }
        else
        {
            var JobPostingDatedt =  convertDate(dt);
