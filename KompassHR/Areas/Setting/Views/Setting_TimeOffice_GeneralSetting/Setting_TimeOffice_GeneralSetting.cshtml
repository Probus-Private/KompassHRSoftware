<script>
    //use for add regex function
    jQuery.validator.addMethod(
        "regex",
         function(value, element, regexp) {
             if (regexp.constructor != RegExp)
                 regexp = new RegExp(regexp);
             else if (regexp.global)
                 regexp.lastIndex = 0;
             return this.optional(element) || regexp.test(value);
         },"erreur expression reguliere"
      );
    $("#GeneralSettings").validate({
        rules: {
            CmpId:{
                required: true,
            },
            OutDoorCompanyBranchId:{
                required: true,
            },
            OutDoorCompanySettingName:{
                required: true,
            },
            OutDoorCompanyShortPeriod:{
                required: true,
            },
            OutDoorCompanyIstHalfDuration:{
                required: true,
            },
            OutDoorCompanyIIndHalfDuration:{
                required: true,
            },
            OutDoorCompanyFullDayDuration:{
                required: true,
            },
            BackDatedDays:{
                required: true,
            },
            FutureDatedDays:{
                required: true,
            },
            AutoApprovalDays:{
                required: true,
            },

        },
        messages: {
            CmpId:{
                required: "Company is required",
            },
            OutDoorCompanyBranchId:{
                required: "Business unit  is required",
            },
            OutDoorCompanySettingName :{
                required: "OutDoor company setting name is required",
            },
            OutDoorCompanyShortPeriod :{
                required: "OutDoor company short period is required",
            },
            OutDoorCompanyIstHalfDuration	:{
                required: "OutDoor company Ist-half duration is required",
            },
            OutDoorCompanyIIndHalfDuration	:{
                required: "OutDoor company IInd-half duration is required",
            },
            OutDoorCompanyFullDayDuration	:{
                required: "OutDoor company full day duration is required",
            },
            BackDatedDays	:{
                required: "Back date days is required",
            },
            FutureDatedDays	:{
                required: "Future date days is required",
            },
            AutoApprovalDays	:{
                required: "Auto approval days is required",
            },

        }
    });

    var form = $("#GeneralSettings");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        var OutDoorCompanyShortHrs=$("#txtOutDoorCompanyShortHrs").val();
        var OutDoorCompanyIstHalfDuration=$("#txtOutDoorCompanyIstHalfDuration").val();
        var OutDoorCompanyIIndHalfDuration=$("#txtOutDoorCompanyIIndHalfDuration").val();
        var OutDoorCompanyFullDayDuration=$("#txtOutDoorCompanyFullDayDuration").val();
        var BackDatedDays=	$("#txtBackDatedDays").val();
        var AllowTeamRequest=$("#txtAllowTeamRequest").val();
        var CmpId=$("#ddlCmpID").val();
        var OutDoorCompanyBranchId=$("#ddlOutDoorCompanyBranchId").val();
        var AttenGeneralId_Encrypted=$("#AttenGeneralId_Encrypted").val();
        var OutDoorCompanySettingName=$("#txtOutDoorCompanySettingName").val();
        var IsDefault=$("#chkIsDefault").is(":checked");
        $.ajax({
            url: '@Url.Action("IsGeneralSettingExists", "Setting_TimeOffice_GeneralSetting")',
            //url: "IsGeneralSettingExists",
            method:"get",
            data :{AttenGeneralId_Encrypted:AttenGeneralId_Encrypted,CmpId:CmpId,IsDefault:IsDefault,OutDoorCompanyBranchId:OutDoorCompanyBranchId,OutDoorCompanySettingName:OutDoorCompanySettingName},
            success:function(response){
                debugger;
                $(".Userloaderbg").css("display", "none");
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#GeneralSettings").submit();
                }
            }
        });

    });


</script>