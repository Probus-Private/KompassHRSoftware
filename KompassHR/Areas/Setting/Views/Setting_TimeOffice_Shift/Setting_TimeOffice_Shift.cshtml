            LunchTimePunchBegin: {
                required: "Punch begin before lunch is required",
            },

        }

    });

    var form = $("#TimeOffice_Shift");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            debugger;
            $("#txtBeginTime").removeClass("error");
            $("#txtEndTime").removeClass("error");
            $("#txtLunchTime").removeClass("error");
            return false;
        }

        // Set hidden field value for checkbox (if not using CheckBoxFor hidden input)
      //  var OT_CalculationAfterOutPunch = $("#chkOT_CalculationAfterOutPunch").is(":checked") ? 1 : 0;
     //   $("#OT_CalculationAfterOutPunch").val(OT_CalculationAfterOutPunch);

        var ShiftBranchId=$("#ddlBusinessUnit").val();
        var CmpId=$("#ddlCompanyName").val();
        var ShiftId_Encrypted=$("#ShiftId_Encrypted").val();
        var SName=$("#txtSName").val();
        var ShiftName=$("#txtShiftName").val();
        $.ajax({
            url: '@Url.Action("IsShiftExists", "Setting_TimeOffice_Shift")',
            //url: "IsShiftExists",
            method:"get",
            data :{ShiftBranchId:ShiftBranchId,ShiftId_Encrypted:ShiftId_Encrypted,SName:SName,CmpId:CmpId,ShiftName:ShiftName},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#TimeOffice_Shift").submit();
                }
            }
        });

        debugger;
        var PunchDuration = $("#txtPunchDuration").val();
        if(PunchDuration>120)
        {
            $("#ErrortxtPunchDuration").html("Please punch begin time less than 120");
            return false;
        }
        else
        {
            $("#ErrortxtPunchDuration").html("");
        }

        var GraceEarlyTime = $("#txtGraceEarlyTime").val();
        if(GraceEarlyTime>60)
        {
            $("#ErrortxtGraceEarlyTime").html("Please grace early time less than 60");
            return false;
        }
        else
        {
            $("#ErrortxtGraceEarlyTime").html("");
        }

        var GraceTimeForLateComming = $("#txtGraceTimeForLateComming").val();
        if(GraceTimeForLateComming>60)
        {
            $("#ErrortxtGraceTimeForLateComming").html("Please grace time for late comming less than 60");
            return false;
        }
        else
        {
            $("#ErrortxtGraceTimeForLateComming").html("");
        }

        var LunchTimeMin = $("#txtLunchTimeMin").val();
        if(LunchTimeMin>60)
        {
            $("#ErrortxtLunchTimeMin").html("Please lunch time less than 60");
            return false;
        }
        else
        {
            $("#ErrortxtLunchTimeMin").html("");
        }

        var LunchTimePunchBegin = $("#txtLunchTimePunchBegin").val();
        if(LunchTimePunchBegin>90)
        {
            $("#ErrortxtLunchTimePunchBegin").html("Please lunch time punch begin less than 90");
            return false;
        }
        else
        {
            $("#ErrortxtLunchTimePunchBegin").html("");
        }
    });

</script>

<script>
    $("#chkShiftFlag").change(function(){
        var BeginTime=$("#txtBeginTime").val();
        var EndTime= $("#txtEndTime").val();

        if ($('#chkShiftFlag').is(":checked")) {
            if(BeginTime>EndTime)
            {
                $("#ErrorEndTime").html("");
            }
            else{
                $('#ErrorEndTime').html("Shift start time should not less than shift end time"); $("#txtEndTime").focus();  return false;
            }
        }
        else{
            if(BeginTime>EndTime)
            {
                $('#ErrorEndTime').html("Shift start time should not greater than shift end time"); $("#txtEndTime").focus();  return false;

            }
            else{
                $("#ErrorEndTime").html("");
            }
        }

    })
    $("#txtBeginTime,#txtEndTime").change(function(){
        var BeginTime=$("#txtBeginTime").val();
        var EndTime= $("#txtEndTime").val();
        if ($('#chkShiftFlag').is(":checked")) {
            if(BeginTime>EndTime)
            {
                $("#ErrorEndTime").html("");
            }
            else{
                $('#ErrorEndTime').html("Shift start time should not less than shift end time"); $("#txtEndTime").focus();  return false;
            }
        }
        else{
            if(BeginTime>EndTime)
            {
                $('#ErrorEndTime').html("Shift start time should not greater than shift end time"); $("#txtEndTime").focus();  return false;

            }
            else{
                $("#ErrorEndTime").html("");
            }
        }

    })


    function onlyNumbers(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }
</script>
