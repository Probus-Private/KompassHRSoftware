                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Full_PH_To, new { @class = "form-control", type = "text", id = "txtCoff_Full_PH_To", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>

                                                </tr>
                                                <tr>
                                                    <td>
                                                        <label class="form-label col-form-label">
                                                            @Html.CheckBoxFor(model => model.Coff_Full_Half_PH_Applicable) &nbsp;      For 1.5 Day
                                                        </label>
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Full_Half_PH_From, new { @class = "form-control", type = "text", id = "txtCoff_Full_Half_PH_From", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Full_Half_PH_To, new { @class = "form-control", type = "text", id = "txtCoff_Full_Half_PH_To", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>

                                                </tr>
                                                <tr>
                                                    <td>
                                                        <label class="form-label col-form-label">
                                                            @Html.CheckBoxFor(model => model.Coff_Two_PH_Applicable) &nbsp;     For 2 Day
                                                        </label>
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Two_PH_From, new { @class = "form-control", type = "text", id = "txtCoff_Two_PH_From", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Two_PH_To, new { @class = "form-control", type = "text", id = "txtCoff_Two_PH_To", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>

                                                </tr>
                                                <tr>
                                                    <td>
                                                        <label class="form-label col-form-label">
                                                            @Html.CheckBoxFor(model => model.Coff_Two_Half_PH_Applicable) &nbsp;     For 2.5 Day
                                                        </label>
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Two_Half_PH_From, new { @class = "form-control", type = "text", id = "txtCoff_Two_Half_PH_From", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Two_Half_PH_To, new { @class = "form-control", type = "text", id = "txtCoff_Two_Half_PH_To", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>

                                                </tr>
                                                <tr>
                                                    <td>
                                                        <label class="form-label col-form-label">
                                                            @Html.CheckBoxFor(model => model.Coff_Three_PH_Applicable) &nbsp;     For 3 Day
                                                        </label>
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Three_PH_From, new { @class = "form-control", type = "text", id = "txtCoff_Three_PH_From", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>
                                                    <td class="text-center">
                                                        @Html.TextBoxFor(model => model.Coff_Three_PH_To, new { @class = "form-control", type = "text", id = "txtCoff_Three_PH_To", autocomplete = "Off", onKeypress = "return onlyNumbers(event);", MaxLength = 4 })
                                                    </td>

                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
