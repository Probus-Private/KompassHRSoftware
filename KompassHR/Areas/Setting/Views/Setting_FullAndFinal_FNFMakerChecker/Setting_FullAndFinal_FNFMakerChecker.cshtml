<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Maker Checker
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_FullAndFinal_Menu", "Setting_FullAndFinal_Menu", new { id = 7, ScreenId = 68, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">FNF Maker Checker</h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add FNF Maker and checker.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row justify-content-center">
                        <form role="form" action='@Url.Action("SaveUpdate", "Setting_FullAndFinal_FNFMakerChecker", new { area = "Setting" })' id="formMakerChecker" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-12">
                                            Company Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.MakerCheckerCmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CompanyBankCmpID", id = "ddlCmpId" })
                                            @Html.HiddenFor(model => model.MakerChecker_Encrypted, new { id = "MakerChecker_Encrypted" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-12">
                                            Business Unit
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.MakerCheckerBranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "CompanyBankBUId", id = "ddlBranchId" })
                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row mb-10px">
                                <div class="col-md-12">
                                    <div class="card-row-title">
                                        For FNF Assign Maker And Checker
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-10px">
                                        <div class="col-md-12 d-flex justify-content-between align-items-center">
                                            <label class="form-label col-form-label">
                                                FNF Maker
                                                <span class="important">*</span>
                                            </label>
                                            <div>
                                                <input type="checkbox" id="selectAllFNFMakerEmpIds" />
                                                <label for="selectAllFNFMakerEmpIds"><b>Select All</b></label>
                                            </div>
                                        </div>
                                            <div class="col-md-12">
                                                <select id="ddlFNFMakerEmpIdID" name="FNFMakerEmpId" class="form-control" multiple="multiple">
                                                    @{
                                                        var selectedFNFMakerEmpIds = ViewBag.SelectedFNFMakerEmpIds as List<string> ?? new List<string>();
                                                    }

                                                    @foreach (var emp in ViewBag.EmployeeName)
                                                    {
                                                        var selected = selectedFNFMakerEmpIds.Contains(emp.Id.ToString()) ? "selected" : "";
                                                        <option value="@emp.Id" @selected>@emp.Name</option>
                                                    }
                                                </select>

                                                <span class="help-block" id="ErrorFNFMakerEmpIdID" style="color:red"></span>
                                                <input type="hidden" id="SelectedFNFMakerEmpIds" name="SelectedFNFMakerEmpIds" />
                                                @*@Html.DropDownListFor(model => model.FNFMakerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlFNFMakerEmpId" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                FNF Checker
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.FNFCheckerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlFNFCheckerEmpId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            <br />
                            @*<div class="row mb-10px">
                                <div class="col-md-12">
                                    <div class="card-row-title">
                                        For Payroll Assign Maker And Checker
                                    </div>
                                </div>
                            </div>
                            <br />*@
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-12">
                                            Account
                                        </label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.AccountEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlAccountEmpId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-12">
                                            Other
                                        </label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.OtherEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlOtherEmpId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm"><i class="fa-solid fa-floppy-disk"></i> Submit</button>
                                                    <a href="@Url.Action("GetList", "Setting_FullAndFinal_FNFMakerChecker", new { area = "Setting" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetNoticePeriodList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlFNFCheckerEmpId").select2();
        $("#ddlAccountEmpId").select2();
        $("#ddlOtherEmpId").select2();

        
        //***********Multiselect FNFMakerEmpId******************//
        $('#ddlFNFMakerEmpIdID').select2({
            placeholder: "--Select--",
            width: '100%'
        });

        // Handle "Select All" checkbox
        $("#selectAllFNFMakerEmpIds").click(function () {
            if (this.checked) {
                $("#ddlFNFMakerEmpIdID > option").prop("selected", true).trigger("change");
            } else {
                $("#ddlFNFMakerEmpIdID > option").prop("selected", false).trigger("change");
            }
        });

        $("#ddlFNFMakerEmpIdID").on("change", function () {
            var total = $("#ddlFNFMakerEmpIdID option").length;
            var selected = $("#ddlFNFMakerEmpIdID").val().length || 0;
            $("#selectAllFNFMakerEmpIds").prop("checked", total === selected);
        });

        $("form").submit(function () {
            var selectedValues = $("#ddlFNFMakerEmpIdID").val();
            $("#SelectedFNFMakerEmpIds").val(selectedValues ? selectedValues.join(",") : "");
        });

        //***********Multiselect FNFMakerEmpId******************//
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(() => {
                window.location.reload();
            });
        }



        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            //$(".ddlEmployeeId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_FullAndFinal_FNFMakerChecker")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data.Branch != null) {
                        $("#ddlBranchId").append("<option value='0'>All</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#ddlBranchId").on("change", function () {
            debugger;
            $(".ddlEmployeeId").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "Setting_FullAndFinal_FNFMakerChecker")',
                data: { BranchId: BranchId,
                          CmpId: CmpId  },
                success: function (data) {
                    debugger;
                    if (data.EmployeeName != null) {
                        $(".ddlEmployeeId").append("<option value=''>--Select--</option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $(".ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
    });
</script>

<script>

    $("#formMakerChecker").validate({
        rules: {
            MakerCheckerCmpId: {
                required: true,
            },
            MakerCheckerBranchId: {
                required: true,
            },
            FNFMakerEmpId:
                {
                    required: true,
                },
            FNFCheckerEmpId:
                {
                    required: true,
                },
            //AccountEmpId:
            //    {
            //        required: true,
            //    },
            //OtherEmpId:
            //    {
            //        required: true,
            //    },
          
        },
        messages: {

            MakerCheckerCmpId: {
                required: "Select the Company Name",
            },
            MakerCheckerBranchId: {
                required: "Select the Branch Name",
            },
            FNFMakerEmpId: {
                required: "Select FNF Maker",
            },
           FNFCheckerEmpId: {
                required: "Select FNF Checker",
            },
            //AccountEmpId: {
            //    required: "Select Account",
            //},
            //OtherEmpId: {
            //    required: "Select Other",
            //},
          
          
        },
        errorPlacement: function (error, element) {
            if (element.hasClass("select2-hidden-accessible")) {
                // Insert error after Select2's container
                error.insertAfter(element.next('.select2'));
            } else {
                error.insertAfter(element);
            }
        },

    });


    var form = $("#formMakerChecker");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if (form.valid() == false) {
            return false;
        }

        var MakerChecker_Encrypted = $("#MakerChecker_Encrypted").val();
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();

        //var TopManagerId =$("#TopManagerId").val();
        //var IncrementMakerEmpId = $("#ddlIncrementMakerEmpId").val();
        //var IncrementCheckerEmpId = $("#ddlIncrementCheckerEmpId").val();

        var FNFMakerEmpId = $("#ddlFNfMakerEmpID").val();
        var FNFCheckerEmpId = $("#ddlFNFCheckerEmpId").val();
        var AccountEmpId = $("#ddlAccountEmpId").val();
        var OtherEmpId = $("#ddlOtherEmpId").val();

        //var IsTopManagerApprove =$("#IsTopManagerApprove").val();
        //var IsTopManager = $("#chkIsTopManagerApprove").is(":checked");
        //if(IsTopManager==true)
        //{
        //    if (IsTopManagerApprove=="")
        //    {
        //        $("#ErrorddlTopManagerId").html("Select Approver Name");
        //        return false;
        //    }
        //    else
        //    {
        //        $("#ErrorddlTopManagerId").html("");
        //    }
        //}


        $.ajax({
            url: '@Url.Action("IsExists", "Setting_FullAndFinal_FNFMakerChecker")',
            method: "get",
            data:
                { MakerChecker_Encrypted: MakerChecker_Encrypted,
                    CmpId:CmpId,
                    BranchId:BranchId,
                    //IsTopManagerApprove:IsTopManagerApprove,
                    //TopManagerId:TopManagerId,
                    FNFMakerEmpId:FNFMakerEmpId,
                    FNFCheckerEmpId:FNFCheckerEmpId,
                    AccountEmpId:AccountEmpId,
                    OtherEmpId:OtherEmpId,
                   // IncrementMakerEmpId:IncrementMakerEmpId,
                   // IncrementCheckerEmpId:IncrementCheckerEmpId
                },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: false
                        }).then(() => {
                            const p = Swal.getPopup();
                            p.classList.add('animate__headShake');
                            setTimeout(() => p.classList.remove('animate__headShake'), 500);
                        });
                    }
                }
                else
                {
                    debugger;
                    $("#formMakerChecker").submit();
                }
            }
        });
    });
</script>
