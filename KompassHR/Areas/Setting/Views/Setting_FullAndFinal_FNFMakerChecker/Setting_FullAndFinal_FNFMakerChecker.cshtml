@model KompassHR.Areas.Setting.Models.Setting_FullAndFinal.FNFMakerChecker

@{
    ViewBag.Title = "Setting_FullAndFinal_FNFMakerChecker";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
