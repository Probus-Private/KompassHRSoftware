@model KompassHR.Areas.Setting.Models.Setting_IncomeTax.IncomeTax_Rule
@{
    ViewBag.Title = "Setting_IncomeTax_TaxRule";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .formBx {
        border: 1px solid #ced4da;
        padding: 0.5rem 0.5rem;
        margin-bottom: 15px;
        padding-top: 15px;
    }

    h6 {
        margin-top: -20px;
        padding: 0 10px;
    }

    mark {
        background-color: #fff;
        font-size: 15px;
        padding: 0 5px;
    }


    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Tax Rule
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_IncomeTax_Menu", "Setting_IncomeTax_Menu", new { id = 9, ScreenId =74, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Tax Rule Setting - @ViewBag.AddUpdateTitle</h4>
                 
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define year wise Tax rule settings here!

                    </p>
                </div>
                <div class="panel-body" style="height: 100% !important;">
                    <form role="form" action='@Url.Action("SaveUpdate", "Setting_IncomeTax_TaxRule", new { area = "Setting" })' id="SaveTaxRule" method="post" data-parsley-validate="">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-2">
                                        Financial Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-10">
                                        @Html.DropDownListFor(model => model.IncomeTaxRule_FyearId,new SelectList(ViewBag.GetFinancialYear, "TaxFyearId", "TaxYear"),"--Select--", new { id = "ddlIncomeTaxRuleFyearId", @class = "form-control", autocomplete = "off", name = "IncomeTaxRule_FyearId" })
                                        @Html.HiddenFor(model => model.IncomeTaxRule_Encrypted,new { id= "IncomeTaxRule_Encrypted" })
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                        <hr class="mt-0">
                        <h4 class="text-red">
                            Exemptions U/s 10
                        </h4>
                        <div class="row">
                            <div class="col-md-12">
                                <h5 class="text-start bg-cyan text-white p-2 mb-0">HRA Setting</h5>
                                <div class="formBx">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark> Metro Setting </mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <div class="col-md-4">
                                                                @Html.TextBoxFor(model => model.HRA_Metro_Percentage, new { @name = "HRA_Metro_Percentage", @class = "form-control", id = "txtHRA_Metro_Percentage", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    placeholder="50">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-4">
                                                                % of Salary for HRA
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-4">
                                                                Rent Paid Minus
                                                            </label>
                                                            <div class="col-md-4">
                                                                @Html.TextBoxFor(model => model.HRA_Metro_Minus, new { @name = "HRA_Metro_Minus", @class = "form-control", id = "txtHRA_Metro_Minus", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    placeholder="10">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-4">
                                                                % of Salary for HRA
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>Non-Metro Setting</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <div class="col-md-4">
                                                                @Html.TextBoxFor(model => model.HRA_NoNMetro_Percentage, new { @name = "HRA_NoNMetro_Percentage", @class = "form-control", id = "txtHRA_NoNMetro_Percentage", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    placeholder="40">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-4">
                                                                % of Salary for HRA
                                                            </label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-4">
                                                                Rent Paid Minus
                                                            </label>
                                                            <div class="col-md-4">
                                                                @Html.TextBoxFor(model => model.HRA_NoNMetro_Minus, new { @name = "HRA_NoNMetro_Minus", @class = "form-control", type = "number", id = "txtHRA_NoNMetro_Minus", autocomplete = "Off", @style = "text-align:right" })
                                                                @*<input type="text" class="form-control"
                                                                    placeholder="10">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-4">
                                                                % of Salary for HRA
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>HRA Calculation (Monthly / Yearly)</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-15px">
                                                            <label class="form-label col-form-label col-md-4">
                                                                Calculation
                                                            </label>
                                                            <div class="col-md-4">
                                                                @Html.DropDownListFor(model => model.HRA_Calculation_Monthly_Yearly, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Monthly", Value = "true"},
                                                    new SelectListItem { Text = "Yearly", Value = "false"}
                                                }, "--Select--", new { id = "ddlHRA_Calculation_Monthly_Yearly", @class = "form-select", autocomplete = "off", name = "HRA_Calculation_Monthly_Yearly" })
                                                                @*<select class="form-select">
                                                                        <option class="form-control" selected>
                                                                            --Select--
                                                                        </option>
                                                                        <option class="form-control">
                                                                            Monthly
                                                                        </option>
                                                                        <option class="form-control">
                                                                            Yearly
                                                                        </option>
                                                                    </select>*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>HRA PAN Limit</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-15px">
                                                            <label class="form-label col-form-label col-md-4">
                                                                Maximum Amount Rs.
                                                            </label>
                                                            <div class="col-md-4">
                                                                @Html.TextBoxFor(model => model.HRA_PanLimit, new { @name = "HRA_PanLimit", @class = "form-control", id = "txtHRA_PanLimit", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control">*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <h5 class="text-start bg-cyan text-white p-2 mb-0">Child Education Setting</h5>
                                <div class="formBx">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>Child Education Allowance</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-15px">
                                                            <label class="form-label col-form-label col-md-1">
                                                                Rs.
                                                            </label>
                                                            <div class="col-md-2">
                                                                @Html.TextBoxFor(model => model.ChildEducation_Allowance, new { @name = "ChildEducation_Allowance", @class = "form-control", id = "txtChildEducation_Allowance", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="500">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-5">
                                                                Per Month for Maximum
                                                            </label>
                                                            <div class="col-md-2">
                                                                @Html.TextBoxFor(model => model.ChildEducation_NoOfChildren, new { @name = "ChildEducation_NoOfChildren", @class = "form-control", id = "txtChildEducation_NoOfChildren", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="2">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-1">
                                                                Children
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>Child Hostel Allowance</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-15px">
                                                            <label class="form-label col-form-label col-md-1">
                                                                Rs.
                                                            </label>
                                                            <div class="col-md-2">
                                                                @Html.TextBoxFor(model => model.ChildHostel_Allowance, new { @name = "ChildHostel_Allowance", @class = "form-control", id = "txtChildHostel_Allowance", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="500">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-5">
                                                                Per Month for Maximum
                                                            </label>
                                                            <div class="col-md-2">
                                                                @Html.TextBoxFor(model => model.ChildHostel_NoOfChildren, new { @name = "ChildHostel_NoOfChildren", @class = "form-control", id = "txtChildHostel_NoOfChildren", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="2">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-1">
                                                                Children
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <h5 class="text-start bg-cyan text-white p-2 mb-0">
                                    Handicap Employee Setting
                                </h5>
                                <div class="formBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="formBx">
                                                <h6><mark>Conveyance for Handicap Employee </mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-15px">
                                                            <label class="form-label col-form-label col-md-4">
                                                                Maximum Amount Rs.
                                                            </label>
                                                            <div class="col-md-4">
                                                                @Html.TextBoxFor(model => model.Conveyance_Handicap_Amount, new { @name = "Conveyance_Handicap_Amount", @class = "form-control", id = "txtConveyance_Handicap_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="3200">*@
                                                            </div>
                                                            <label class="form-label col-form-label col-md-4">
                                                                Per Month
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-start bg-cyan text-white p-2 mb-0">
                                    Leave Salary Setting
                                </h5>
                                <div class="formBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="formBx">
                                                <h6><mark>Leave Salary (Leave Encashment) </mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-15px">
                                                            <label class="form-label col-form-label col-md-4">
                                                                Maximum Amount Rs.
                                                            </label>
                                                            <div class="col-md-3">
                                                                @Html.TextBoxFor(model => model.LeaveSalary_Amount, new { @name = "LeaveSalary_Amount", @class = "form-control", id = "txtLeaveSalary_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="300000">*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <h5 class="text-start bg-cyan text-white p-2 mb-0">Gratuity Setting</h5>
                                <div class="formBx">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>Type A</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-9">
                                                                A. Covered Under Gratuity Act Maximum Amount Rs.
                                                            </label>
                                                            <div class="col-md-3">
                                                                @Html.TextBoxFor(model => model.Gratuity_Coverd_Amount, new { @name = "Gratuity_Coverd_Amount", @class = "form-control", id = "txtGratuity_Coverd_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="200000">*@
                                                            </div>
                                                        </div>
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-12 text-red">
                                                                Last Drawn Basic Salary x 15/26 x No. of Years
                                                                of Services <br>
                                                                (Simple Round For Years) <br>
                                                                5 Yrs 6 Months = 6 Years <br>
                                                                5 Yrs 5 Months = 5 Years <br>
                                                            </label>

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>Type B</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-9">
                                                                B.Not Covered Under Gratuity Act Maximum Amount
                                                                Rs.
                                                            </label>
                                                            <div class="col-md-3">
                                                                @Html.TextBoxFor(model => model.Gratuity_NotCoverd_Amount, new { @name = "Gratuity_Notcoverd_Amount", @class = "form-control", id = "txtGratuity_Notcoverd_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="200000">*@
                                                            </div>
                                                        </div>
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-12 text-red">
                                                                Last Drawn Basic Salary x 15/30 x No. of Years
                                                                of Services <br>
                                                                (Only Fully Completed Years) <br>
                                                                5 Yrs 6 Months = 5 Years <br>
                                                                5 Yrs 5 Months = 5 Years <br>
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="mt-0">

                        <h4 class="text-red">
                            Deducation U/s Chapter VI A
                        </h4>

                        <div class="row">
                            <div class="col-md-12">
                                <h5 class="text-start bg-cyan text-white p-2 mb-0">80C Setting</h5>
                                <div class="formBx">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark> 80DDB - Treatment of Specified Disease</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-7">
                                                                Normal Citizen
                                                            </label>

                                                            <div class="col-md-5">
                                                                @Html.TextBoxFor(model => model.TaxRule80DDB_NormalCitizen_Amount, new { @name = "TaxRule80DDB_NormalCitizen_Amount", @class = "form-control", id = "txtTaxRule80DDB_NormalCitizen_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="40000">*@
                                                            </div>
                                                        </div>
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-7">
                                                                Seninor Citizen
                                                            </label>
                                                            <div class="col-md-5">
                                                                @Html.TextBoxFor(model => model.TaxRule80DDB_SeniorCitizen_Amount, new { @name = "TaxRule80DDB_SeniorCitizen_Amount", @class = "form-control", id = "txtTaxRule80DDB_SeniorCitizen_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="100000">*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="formBx">
                                                <h6><mark>80U - Physical Handicap</mark></h6>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-7">
                                                                Severe
                                                            </label>
                                                            <div class="col-md-5">
                                                                @Html.TextBoxFor(model => model.TaxRule80U_Physical_Handicap_Severe_Amount, new { @name = "TaxRule80U_Physical_Handicap_Severe_Amount", @class = "form-control", id = "txtTaxRule80U_Physical_Handicap_Severe_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="125000">*@
                                                            </div>
                                                        </div>
                                                        <div class="row mb-10px">
                                                            <label class="form-label col-form-label col-md-7">
                                                                Non-Severe
                                                            </label>
                                                            <div class="col-md-5">
                                                                @Html.TextBoxFor(model => model.TaxRule80U_Physical_Handicap_Nonsevere_Amount, new { @name = "TaxRule80U_Physical_Handicap_Nonsevere_Amount", @class = "form-control", id = "txtTaxRule80U_Physical_Handicap_Nonsevere_Amount", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="125000">*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="formBx">
                                                <h6><mark> 80D - Medical Insurance</mark></h6>

                                                <table class="table table-bordered align-middle" id="TableMedical"
                                                       data-scrollbar="true" style="width: 100%;">
                                                    <thead>
                                                        <tr>
                                                            <th class="text-nowrap"></th>
                                                            <th class="text-nowrap">Self, Family, Children</th>
                                                            <th class="text-nowrap">Parents</th>
                                                            <th class="text-nowrap"> Deducation U/s 80D</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td class="text-nowrap">
                                                                <label class="form-label">
                                                                    Individual And Parents Below 60 Years
                                                                </label>
                                                            </td>
                                                            <td class="text-nowrap">
                                                                @Html.TextBoxFor(model => model.TaxRule80D_ParentsBelow60_Self_Family_Children, new { @name = "TaxRule80D_ParentsBelow60_Self_Family_Children", @class = "form-control", id = "txtTaxRule80D_ParentsBelow60_Self_Family_Children", autocomplete = "Off", @style = "text-align:right", type = "number" })
                                                                @*<input type="text" class="form-control"
                                                                    value="40000">*@
                                                            </td>
