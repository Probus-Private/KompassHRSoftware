<script>

    //Ready function
    $(document).ready(function () {
        var HRA_Calculation_Monthly_Yearly = @Html.Raw(Json.Encode(TempData["HRA_Calculation_Monthly_Yearly"]));
        if (HRA_Calculation_Monthly_Yearly == true) {
            $("#ddlHRA_Calculation_Monthly_Yearly").val("Yearly");
        }
        else if(HRA_Calculation_Monthly_Yearly == false) {
            $("#ddlHRA_Calculation_Monthly_Yearly").val("Monthly");
        }
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var GetToDate = @Html.Raw(Json.Encode(TempData["ToDate"]));
        var GetFromDate = @Html.Raw(Json.Encode(TempData["FromDate"]));
        if (GetFromDate==null)
        {
            const today = new Date();

            // Set the first day of the current month
            const firstDayOfCurrentMonth = new Date(today.getFullYear(), today.getMonth(), 1);

            // Format the date as 'YYYY-MM-DD'
            const formattedDate = formatToYYYYMMDD(firstDayOfCurrentMonth);

            // Set the #txtFromDate value
            $('#txtFromDate').val(formattedDate);
            $('#txtToDate').val("2999-12-31");
        }
        else{
            $('#txtFromDate').val(GetFromDate);
            $('#txtToDate').val(GetToDate);
            $('#txtFromDate').attr('readonly',true);
            $('#txtToDate').attr('readonly',true);
            $('#txtFromDate').css('background-color', '#e9ecef');
            $('#txtToDate').css('background-color', '#e9ecef');
        }

    });
    //Ready Function

    $('#txtFromDate').on('change', function () {
        // Get the selected date from the input
        const selectedDate = new Date($(this).val());

        // Adjust the date to the first day of the selected month
        const firstDayOfMonth = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);

        // Format the adjusted date as 'YYYY-MM-DD'
        const formattedDate = formatToYYYYMMDD(firstDayOfMonth);

        // Update the value of #txtFromDate
        $(this).val(formattedDate);
    });

    // Helper function to format a Date object as 'YYYY-MM-DD'
    function formatToYYYYMMDD(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0'); // 0-based index
        const day = String(date.getDate()).padStart(2, '0'); // Always '01' here
        return `${year}-${month}-${day}`;
    }
</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveTaxRule").validate({
        rules: {
            IncomeTaxRule_FyearId: {
                required: true,
            },

        },
        messages: {
            IncomeTaxRule_FyearId: {
                required: "Please select financial year",
            },

        },

    });
    //IsValidation Check
    var form = $("#SaveTaxRule");
    form.validate();
    $("#btnSubmit").click(function () {
       
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            //$("#dateToDate").removeClass('error');
            return false;
        }
        var IncomeTaxRuleFyearId=$("#ddlIncomeTaxRuleFyearId").val();
        var IncomeTaxRule_Encrypted=$("#IncomeTaxRule_Encrypted").val();
        $.ajax({
            url: "@Url.Action("IsTaxRuleExists", "Setting_IncomeTax_TaxRule")",
            method:"get",
            data:{IncomeTaxRuleFyearId:IncomeTaxRuleFyearId,IncomeTaxRule_Encrypted:IncomeTaxRule_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveTaxRule").submit();

                }
            }
        });

    });
</script>