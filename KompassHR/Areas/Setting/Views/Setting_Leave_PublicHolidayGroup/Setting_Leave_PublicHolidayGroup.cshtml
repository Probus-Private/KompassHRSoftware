    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SavePublicHolidayGroup").validate({
        rules: {
            HolidayGroup: {
                required: true,
            },

        },
        messages: {
            HolidayGroup: {
                required: "Holiday Group is required",
            },

        },

    });

    var form = $("#SavePublicHolidayGroup");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#dateToDate").removeClass('error');
            return false;
        }

        var PublicHolidayGroupID_Encrypted=$("#txtPublicHolidayGroupID_Encrypted").val();
        var HolidayGroup=$("#txtGroup").val();
        $.ajax({
            url:"IsPublicHolidayGroupExists",
            method:"get",
            data:{PublicHolidayGroupID_Encrypted:PublicHolidayGroupID_Encrypted,
                HolidayGroup:HolidayGroup
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SavePublicHolidayGroup").submit();
                }
            }
        });
    });
</script>

