<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }


    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Report Access Master
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 12, ScreenId = 85, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_SaleForce_Menu", "Setting_SaleForce_Menu", new { id =45 ,ScreenId =806, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Report Access Master - @ViewBag.AddUpdateTitle </h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add  Report Access Master for sale force.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "Setting_SaleForce_ReportAccess", new { area = "Setting" })" id="SaveReportAccessMaster" method="post">

                                <div class="form-group row">

                                    <div class="col-md-4 mb-3">
                                        <label class="mb-2"> User <span class="text-danger">*</span></label>
                                        @*@Html.DropDownListFor(model => model.USERS_Fid, new SelectList(ViewBag.UsersList, "Fid", "UserName"), "--Select--", new { @class = " form-control form-select", id = "User", required = "required" })*@
                                        @Html.DropDownListFor(model => model.USERS_Fid, new SelectList(ViewBag.ReportAccessList, "Fid", "UserName"), "--Select--", new { @class = " form-control form-select", id = "User", required = "required" })


                                    </div>

                                    <div class="col-md-4 mb-3">
                                        <label class="mb-2"> Module <span class="text-danger">*</span></label>
                                        @Html.DropDownList("Module", new SelectList(new List<object>() {
                                new { text = "CRM", value = "CRM" },
                                new { text = "Attendance", value = "Attendance" },
                                new { text = "Complaint", value = "Complaint" },
                                new { text = "Patrolling", value = "Patrolling" },
                                new { text = "Field Force", value = "FieldForce" },
                                new { text = "Sales Force", value = "Sales Force" },

                                }, "value", "text"), "--Select--", new { @class = "form-control form-select", @id = "Module" })
                                        @Html.ValidationMessage("Module", "", new { @class = "help-block", id = "ErrorModule", @style = "color:red" })
                                        @Html.HiddenFor(model => model.Encrypted_Id, new { id = "Encrypted_Id" })
                                        @Html.Hidden("access", (object)ViewBag.Access)
                                    </div>

                                    <div class="col-md-4 mb-3">
                                        <label for="MAS_REPORT_Fid" class="mb-2">Report Name<span class="text-danger">*</span></label>
                                        <select name="MAS_REPORT_Fid" class="form-control form-select" id="MAS_REPORT_Fid" required>
                                            <option>-- Select--</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" id="btnGetList"
                                                                class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>



<script>
    $("#btnGetList").click(function () {
        debugger;
        var url = '@Url.Action("GetList", "Setting_SaleForce_ReportAccess")';
        window.location.href = url;
    });


    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });
</script>

<script>
    jQuery.validator.addMethod(
       "regex",
        function(value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        },"erreur expression reguliere"
     );

    $('#SaveReportMaster').validate({
        rules: {
            MAS_REPORT_Fid:{
                required:true
            },
            MAS_REPORT_Fid:{
                required:true
            },
            Module:{
                required:true
            }
        },
        messages: {
            MAS_REPORT_Fid: {
                required: "User is required"
            },
            MAS_REPORT_Fid: {
                required: "Report Name is required"
            },
            Module: {
                required: "Module is required"
            }
        }
    });


