<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
               @Session["AssessmentCategoryName"] - @Session["AssessmentSubCategoryName"]
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "Setting_LMS_Library", new {  area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> LMS Assessment Qustion - List</h4>

                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of LMS assessment questionnaire created.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <!-- BEGIN table-responsive -->
                        <a href="#">
                            <button type="button" class="btn btn-primary btn-sm mb-10px" onclick="history.back();">
                                <i class="fa-solid fa-plus"></i> &nbsp; Add
                            </button>
                        </a>
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine"
                                       style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th class="fixed-side">Update</th>
                                            <th class="fixed-side1">Delete</th>
                                            <th class="fixed-side1">View</th>
                                            <th class="text-nowrap text-center">Question Type</th>
                                            <th class="text-nowrap text-center">Question </th>
                                            <th class="text-nowrap text-center">Created By</th>
                                            <th class="text-nowrap text-center">Created Date</th>
                                            <th class="text-nowrap text-center">Modified By</th>
                                            <th class="text-nowrap text-center">Modified Date</th>
                                            <th class="text-nowrap text-center">Machine Name</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.GetQuestionList)
                                        {
                                            <tr>
                                                <td class="text-center" style="width: 80px;">
                                                    <a onclick="UpdateTemplate('@d.LMSFeedbackID_Encrypted')" id="btnUpdate" style="cursor:pointer;">
                                                        <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center" style="width: 80px;">
                                                    <a onclick="DeleteTemplate('@d.LMSFeedbackID_Encrypted')" id="btnDelete" style="cursor:pointer;">
                                                        <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center" style="width: 80px;">
                                                    <a onclick="View('@d.LMSFeedbackID')" id="btnView" style="cursor:pointer;">
                                                        <i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>
                                                    </a>
                                                </td>
                                                <th class="text-nowrap ">@d.QuestionType</th>
                                                <td class="text-nowrap">@d.Question</td>
                                                <td class="text-nowrap">@d.CreatedBy</td>
                                                <td class="text-nowrap">@d.CreatedDate</td>
                                                <td class="text-nowrap">@d.ModifiedBy</td>
                                                <td class="text-nowrap">@d.ModifiedDate</td>
                                                <td class="text-nowrap">@d.MachineName</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="QuestionDetails" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"></h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="row">
                                    <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass tblAddData" style="width: 100%;" id="tblEmployeeHistoryHead">
                                        <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th class="text-nowrap" style="text-align: center">Options </th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblBodyQuestionDetails"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#btnUpdate").click(function() {
            // Disable the input field and dropdowns
            $("#txtQuestionType").prop("disabled", true);
            $("#ddlQuestionsDesignationID").prop("disabled", true);
            $("#ddlQuestionsDepartmentID").prop("disabled", true);
        });
    });
</script>

<script>
    function UpdateTemplate(LMSFeedbackID_Encrypted) {
        debugger;
        var url = '@Url.Action("LMSAssessment", "Setting_LMS_Library")?LMSFeedbackID_Encrypted=' + LMSFeedbackID_Encrypted ;
        window.location.href = url;
    }

    function DeleteTemplate(LMSFeedbackID_Encrypted) {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("DeleteAssessment", "Setting_LMS_Library")?LMSFeedbackID_Encrypted=' + LMSFeedbackID_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    function View(LMSFeedbackID){
        debugger;
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetOption", "Setting_LMS_Library")',
            data: { LMSFeedbackID},
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                const data = JSON.parse(response);
                const modal = $('#QuestionDetails');
                const tableBody = $('#tblBodyQuestionDetails');

                modal.modal(data.length > 0 ? 'show' : 'hide');
                tableBody.empty(); // Clear existing rows

                if (data) {
                    data.forEach(item => {
                        const row = $('<tr>');

                        const optionsCell = item.find(e => e.Key === "options");

                        row.append(`<td>${optionsCell ? optionsCell.Value : ''}</td>`);

                        tableBody.append(row);
                    });
                }
            }
        });
    }
</script>
