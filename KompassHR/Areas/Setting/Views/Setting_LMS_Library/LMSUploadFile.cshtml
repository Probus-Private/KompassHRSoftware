                                        </div>
                                    </div>
                                </div>

                                <style>
                                    .progress-container {
                                        position: relative;
                                        width: 30%;
                                        background: #ddd;
                                        border-radius: 0px;
                                        overflow: hidden;
                                        height: 18px;
                                        margin-top: -15px;
                                    }

                                    .progress-bar {
                                        height: 100%;
                                        width: 0;
                                        background: linear-gradient(to right, #00c6ff, #0072ff);
                                        transition: width 0.4s ease;
                                    }

                                    .progress-text {
                                        position: absolute;
                                        top: 0;
                                        left: 50%;
                                        transform: translateX(-50%);
