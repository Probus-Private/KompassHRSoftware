    function ResetFile(input)
    {
        debugger;
        const file = input.files[0];
        const maxSize = 3 * 1024 * 1024; // 3 MB in bytes
        const CheckFileTypeForImage = ['image/jpeg','image/jpg', 'image/png'];
        if (CheckFileTypeForImage.includes(file.type))
        {
            if (file && file.size > maxSize) {
                Swal.fire({
                    icon: "error",
                    text: "File size must be less than 3 MB.",
                })
                input.value = ''; // Clear the file
            }
        }

        const allowedTypes = [
      'application/pdf',
      'image/jpeg',
      'image/png',
      'video/mp4',
      'video/x-matroska',
      'video/webm',
      'video/quicktime',
      'video/avi'
        ];

        const errorSpan = document.getElementById("result");

        if (file) {
            if (!allowedTypes.includes(file.type)) {
                errorSpan.innerText = "❌ Invalid file type.";
                return false;
            } else {
                errorSpan.innerText = ''; // Clear error
            }
        }

       

        // Prepare form data
        const formData = new FormData();
        formData.append('file', file);

        // Show loader and reset progress
        document.getElementById('divProcessBar').style.display = "flex";

        const progressBar = document.getElementById('progressBar');
        const progressText = document.getElementById('progressText');
        progressBar.style.width = '0%';
        progressText.textContent = '0%';

        // Create XHR
        const xhr = new XMLHttpRequest();

        xhr.open('POST', '/Setting_LMS_Library/ScanAndUpload', true);

        debugger;
        // Progress event
        xhr.upload.addEventListener('progress', function (e) {
            if (e.lengthComputable) {
                const percentComplete = Math.round((e.loaded / e.total) * 100);
                progressBar.style.width = percentComplete + '%';
                progressText.textContent = percentComplete + '%';
            }
        });

        // Response event
        xhr.onload = function () {
            debugger;
           
            if (xhr.status === 200) {
                //Swal.fire({
                //    icon: "success",
                //    text: "File uploaded successfully!"
                //});
                document.getElementById('result').innerHTML = xhr.responseText;
            } else {
                //Swal.fire({
                //    icon: "error",
                //    text: "Error uploading file."
                //});
                document.getElementById('result').innerHTML = "❌ Error occurred while scanning.";
            }
        };

        xhr.onerror = function () {
           
            Swal.fire({
                icon: "error",
                text: "Error uploading file."
            });
        };

        xhr.send(formData);
    }

</script>

<script>
    function DeleteLMSLibrary(LMSLibraryDoc_Encrypted,DocumentPath,LMS_Library_LMSLibraryId) {
            const DeleteButtons = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            DeleteButtons.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("DeleteDocument", "Setting_LMS_Library")' +
                    '?LMSLibraryDoc_Encrypted=' + encodeURIComponent(LMSLibraryDoc_Encrypted) +
                    '&FileName=' + encodeURIComponent(DocumentPath) +
                    '&LMS_Library_LMSLibraryId=' + encodeURIComponent(LMS_Library_LMSLibraryId);

                } else if (
                    /* Read more about handling dismissals below */
                    result.dismiss === Swal.DismissReason.cancel
                ) {

                }
            })
        }


</script>


<script>
    function DownloadLMSLibrary(attachmentPath) {
        debugger;
        if (attachmentPath!="File Not Found")
        {
            var url = '@Url.Action("DownloadAttachment", "Setting_LMS_Library")';

            $.ajax({
                url: url,
                type: 'POST',
                data: { DownloadAttachment: attachmentPath },
                success: function (response) {
                    debugger;
                    if (response.Success) {
                        var fileName = response.FileName;
                        var fileData = atob(response.FileData);  // Decode the base64 string
                        var byteArray = new Uint8Array(fileData.length);
                        for (var i = 0; i < fileData.length; i++) {
                            byteArray[i] = fileData.charCodeAt(i);
                        }

                        var blob = new Blob([byteArray], { type: response.ContentType });
                        var downloadUrl = window.URL.createObjectURL(blob);
                        var a = document.createElement('a');
                        a.href = downloadUrl;
                        a.download = fileName;
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                        window.URL.revokeObjectURL(downloadUrl);
                    }
                    else {
                        Swal.fire({
                            icon: response.Icon || 'error',
                            text: response.Message || 'An error occurred.',
                            allowOutsideClick: false
                        });
                    }
                },
                error: function (xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        text: 'An unexpected error occurred.',
                        allowOutsideClick: false
                    });
                }
            });
        }
        else{
            var Message1 = "The file has not been uploaded.";
            var Icon1 = "error";
            if (Message1 != null) {
                if (Message1 != null) {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                }
            }
        }

    }
</script>
