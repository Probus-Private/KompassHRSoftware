<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Payroll Maker Checker
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Payroll_Menu", "Setting_Payroll_Menu", new { id = 6, ScreenId = 287, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Payroll Maker Checker</h4>
                   
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add Payroll Maker and checker.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row justify-content-center">
                        <form role="form" action='@Url.Action("SaveUpdate", "Setting_Payroll_MakerChecker", new { area = "Setting" })' id="formMakerChecker" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.MakerCheckerCmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CompanyBankCmpID", id = "ddlCmpId" })
                                            @Html.HiddenFor(model => model.MakerChecker_Encrypted, new { id = "MakerChecker_Encrypted" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Business Unit
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.MakerCheckerBranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "CompanyBankBUId", id = "ddlBranchId" })
                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row mb-10px">
                                <div class="col-md-12">
                                    <div class="card-row-title">
                                        For Increment Assign Maker And Checker
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Increment Maker
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.IncrementMakerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlIncrementMakerEmpId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Increment Checker
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.IncrementCheckerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlIncrementCheckerEmpId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <br />
                            <div class="row mb-10px">
                                <div class="col-md-12">
                                    <div class="card-row-title">
                                        For Payroll Assign Maker And Checker
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Payroll Process Maker
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.PayrollMakerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlPayrollMakerEmpId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Payroll Process Checker
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.PayrollCheckerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlPayrollCheckerEmpId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-10px">
                                <div class="col-md-12">
                                    <div class="card-row-title">
                                        For Account Assign Maker And Checker
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Payroll Account Checker <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.AccountCheckerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlAccountCheckerEmpId" })
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Payroll Disbursed <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.AccountMakerEmpId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "EmployeeId", id = "ddlAccountMakerEmpId" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                            <div class="row" hidden>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Maker Checker Type
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-1">
                                            @Html.CheckBoxFor(model => model.IsTopManagerApprove, new { @class = "form-check-input", id = "chkIsTopManagerApprove" })
                                        </div>
                                        <div class="col-md-7" id="topManagerDropdownContainer" style="display:none">
                                            @*@Html.TextBoxFor(model => model.MakerCheckerType, new { @class = "form-control", type = "text", id = "txtMakerCheckerType", name = "MakerCheckerType", autocomplete = "Off" })*@
                                            @Html.DropDownListFor(model => model.TopManagerId, new SelectList(ViewBag.EmployeeName ?? Enumerable.Empty<SelectListItem>(), "Id", "Name"), "--Select--", new { @class = "form-select ddlEmployeeId", name = "TopManagerId", id = "ddlTopManagerId" })
                                            <span id="ErrorddlTopManagerId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm"><i class="fa-solid fa-floppy-disk"></i> Submit</button>
                                                    <a href="@Url.Action("GetList", "Setting_Payroll_MakerChecker", new { area = "Setting" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetNoticePeriodList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlPayrollMakerEmpId").select2();
        $("#ddlPayrollCheckerEmpId").select2();
        $("#ddlAccountMakerEmpId").select2();
        $("#ddlAccountCheckerEmpId").select2();
        $("#ddlTopManagerId").select2();
        $("#ddlIncrementMakerEmpId").select2();
        $("#ddlIncrementCheckerEmpId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(() => {
                window.location.reload();
            });
        }

        $("#chkIsTopManagerApprove").change(function () {
            if ($("#chkIsTopManagerApprove").is(":checked")) {
                $("#topManagerDropdownContainer").show();
            } else {
                $("#topManagerDropdownContainer").hide();
                $("#ddlTopManagerId").val("");
            }
        });
        if ($("#chkIsTopManagerApprove").is(":checked")) {
            $("#topManagerDropdownContainer").show();
        } else {
            $("#topManagerDropdownContainer").hide();
            $("#ddlTopManagerId").val("");
        }



        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            //$(".ddlEmployeeId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_Payroll_MakerChecker")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data.Branch != null) {
                        $("#ddlBranchId").append("<option value=''>--Select--</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        @*$("#ddlBranchId").on("change", function () {
            debugger;
            $(".ddlEmployeeId").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "Setting_Payroll_MakerChecker")',
                data: { BranchId: BranchId },
                success: function (data) {
                    debugger;
                    if (data.EmployeeName != null) {
                        //$(".ddlEmployeeId").append("<option value=''>--Select--</option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $(".ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });*@
    });
</script>
<script>

    $("#formMakerChecker").validate({
        rules: {
            MakerCheckerCmpId: {
                required: true,
            },
            MakerCheckerBranchId: {
                required: true,
            },
            PayrollMakerEmpId:
                {
                    required: true,
                },
            PayrollCheckerEmpId:
                {
                    required: true,
                },
            AccountMakerEmpId:
                {
                    required: true,
                },
            AccountCheckerEmpId:
                {
                    required: true,
                },
            IncrementMakerEmpId:
              {
                  required: true,
              },
            IncrementCheckerEmpId:
                {
                    required: true,
                },
            //PayrollApprovalEmpId:
            //   {
            //       required: true,
            //   },
        },
        messages: {

            MakerCheckerCmpId: {
                required: "Select the Company Name",
            },
            MakerCheckerBranchId: {
                required: "Select the Branch Name",
            },
            PayrollMakerEmpId: {
                required: "Select Payroll Maker",
            },
            PayrollCheckerEmpId: {
                required: "Select Payroll Checker",
            },
            AccountMakerEmpId: {
                required: "Select Account Maker",
            },
            AccountCheckerEmpId: {
                required: "Select Account Checker",
            },
            IncrementMakerEmpId: {
                required: "Select Increment Maker",
            },
            IncrementCheckerEmpId: {
                required: "Select Increment Checker",
            },
            //PayrollApprovalEmpId: {
            //    required: "Select Payroll Approval",
            //},
        },
        errorPlacement: function (error, element) {
            if (element.hasClass("select2-hidden-accessible")) {
                // Insert error after Select2's container
                error.insertAfter(element.next('.select2'));
            } else {
                error.insertAfter(element);
            }
        },

    });


    var form = $("#formMakerChecker");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if (form.valid() == false) {
            return false;
        }

        var MakerChecker_Encrypted = $("#MakerChecker_Encrypted").val();
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        
        var TopManagerId =$("#TopManagerId").val();
        var IncrementMakerEmpId = $("#ddlIncrementMakerEmpId").val();
        var IncrementCheckerEmpId = $("#ddlIncrementCheckerEmpId").val();

        var PayrollMakerEmpId = $("#ddlPayrollMakerEmpId").val();
        var PayrollCheckerEmpId = $("#ddlPayrollCheckerEmpId").val();
        var AccountMakerEmpId = $("#ddlAccountMakerEmpId").val();
        var AccountCheckerEmpId = $("#ddlAccountCheckerEmpId").val();

        var IsTopManagerApprove =$("#IsTopManagerApprove").val();
        var IsTopManager = $("#chkIsTopManagerApprove").is(":checked");
        if(IsTopManager==true)
        {
            if (IsTopManagerApprove=="") 
            {
                $("#ErrorddlTopManagerId").html("Select Approver Name");
                return false;
            }
            else
            {
                $("#ErrorddlTopManagerId").html("");
            }
        }


        $.ajax({
            url: '@Url.Action("IsExists", "Setting_Payroll_MakerChecker")',
            method: "get",
            data:
                { MakerChecker_Encrypted: MakerChecker_Encrypted,
                    CmpId:CmpId,
                    BranchId:BranchId,
                    IsTopManagerApprove:IsTopManagerApprove,
                    TopManagerId:TopManagerId,
                    PayrollMakerEmpId:PayrollMakerEmpId,
                    PayrollCheckerEmpId:PayrollCheckerEmpId,
                    AccountMakerEmpId:AccountMakerEmpId,
                    AccountCheckerEmpId:AccountCheckerEmpId,
                    IncrementMakerEmpId:IncrementMakerEmpId,
                    IncrementCheckerEmpId:IncrementCheckerEmpId
                },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: false
                        }).then(() => {
                            const p = Swal.getPopup();
                            p.classList.add('animate__headShake');
                            setTimeout(() => p.classList.remove('animate__headShake'), 500);
                        });
                    }
                }
                else
                {
                    debugger;
                    $("#formMakerChecker").submit();
                }
            }
        });
    });
</script>
