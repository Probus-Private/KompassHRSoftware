@model KompassHR.Areas.Setting.Models.Setting_Payroll.Payroll_MakerChecker
@{
    ViewBag.Title = "Setting_Payroll_MakerChecker";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
