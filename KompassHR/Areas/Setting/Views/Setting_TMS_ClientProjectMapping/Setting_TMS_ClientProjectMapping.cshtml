@model KompassHR.Areas.Setting.Models.Setting_TMS.ClientProjectMapping

@{
    ViewBag.Title = "Setting_TMS_ClientProjectMapping";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Required library for validation -->
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<script src="~/assets/js/CaptchaVerification.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
        color: red;
    }

    .tblAddData td:nth-child(1) {
        text-align: center;
    }

    .tblAddData td:nth-child(6) {
        display: none;
    }

    .tblAddData td:nth-child(7) {
        display: none;
    }

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        /*overflow: auto;*/
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 10px !important;
        background-color: #F5F5F5;
    }
    /* Horizontal scrollbar */
    .dataTables_scrollBody::-webkit-scrollbar {
        height: 10px;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Client Project Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 12, ScreenId = 85, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TMS_Menu", "Setting_TMS_Menu", new { id =12 ,ScreenId =85, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Client Project Mapping - @ViewBag.AddUpdateTitle </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Client Project Mapping ensures client are assigned appropriate access and permissions based on project.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_UserAccessPolicy", new { area = "Setting" })' id="Saveclientprojectmapping" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Client Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ClientId, new SelectList(ViewBag.GetClient, "Id", "Name"), "--Select--", new { @class = "form-control", name = "EmpolyeeName", id = "ddlClientId" })
                                                <span id="ErrorddlClientId" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" id="btnshow" onclick="ShowProjectName()" class="btn btn-primary btn-sm">Show</button>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="table-responsive">
                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TablePageAccess">
                                                    <thead style="background-color: rgba(233, 236, 239, 1) !important; position: sticky; top: 0; z-index: 1;">
                                                        <tr class="trheading">
                                                            <th class="text-center" style="width:70px;"><label><input type="checkbox" class="allChecked" name="checkbox" id="AllCheckBox" value="value"><b>&nbsp; All</b></label></th>
                                                            <th class="text-nowrap" hidden> Project Id</th>
                                                            <th class="text-Left">Project Name</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblProjectName" style="max-height: 250px; overflow-y: auto;">
                                                        @if (ViewBag.GetProjectList != null)
                                                        {
                                                            foreach (var d in ViewBag.GetProjectList)
                                                            {
                                                                <tr>
                                                                    <td class="text-center">
                                                                        @{
                                                                            var check = d.IsActive ? "checked" : "";
                                                                        }
                                                                        <input type="checkbox" id="chkIsActive_@d.ProjectID" @check style="cursor:pointer" />
                                                                    </td>
                                                                    <td hidden>@d.ProjectID</td>
                                                                    <td>@d.ProjectName</td>
                                                                </tr>
                                                                                }
                                                                            }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        Submit
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        $("#ddlClientId").select2();

        $('.TablePageAccess').DataTable({
            destroy: true,        // Allows the table to be reinitialized
            searching: true,      // Enables the search box
            paging: false,        // Disables pagination
            info: true,          // Disables the table information display (e.g., "Showing 1 to 10 of 50 entries")
            ordering: false,      // Disables column sorting
            bFilter: true         // Enables the filtering functionality (search box)
        });
    });
</script>
<script>
    function ShowProjectName() {
        var ClientID = $("#ddlClientId").val();
        if (ClientID == "") {
            $("#ErrorddlClientId").html("Client name id required");
            return false;
        }
        else {
            $("#ErrorddlClientId").html("");
        }
        var ClientID = $("#ddlClientId").val();
        const url = '@Url.Action("Setting_TMS_ClientProjectMapping", "Setting_TMS_ClientProjectMapping", new { area = "Setting" })';
        window.location.href = url + '?ClientID=' + ClientID;
    }
</script>
<script>
    $("#AllCheckBox").on("click", function () {
        debugger;
        var isChecked = $(this).prop('checked');
        $("#tblProjectName tr").each(function () {
            $(this).find("input").prop('checked', isChecked);
        });
    });

    $("#btnSubmit").click(function () {
        debugger
        $(".Userloaderbg").css("display", "flex");
        var table = document.getElementById("tblProjectName");
        var ClientId = $("#ddlClientId").val();
        var rowCount = table.rows.length;
        var clientprojectmap = [];

        for (var i = 0; i < rowCount; i++) {
            debugger
            var data = {};
            var checkbox = table.rows[i].cells[0].children[0]; // Get the checkbox in the first cell
            //if (checkbox.checked) {  // Only collect data if the checkbox is checked
                data.ClientId = ClientId;
                data.IsActive = checkbox.checked;
                data.ProjectID = table.rows[i].cells[1].innerHTML;
                clientprojectmap.push(data);
            //}
        }

        console.log(clientprojectmap);
        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpadte", "Setting_TMS_ClientProjectMapping")',
            //url: "SaveUpadte",
            data: JSON.stringify({ clientprojectmap: clientprojectmap, ClientId: ClientId }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then(function () {
                            var url = '@Url.Action("Setting_TMS_ClientProjectMapping", "Setting_TMS_ClientProjectMapping")';
                            window.location.href = url;
                        })
                    }
                }
            }
        });
    });
</script>