<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Task Category Project-Module Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 12, ScreenId = 85, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TMS_Menu", "Setting_TMS_Menu", new { id =12 ,ScreenId =85, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Task Category Project-Module Mapping - @ViewBag.AddUpdateTitle </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define task category for project & module here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_TMS_TaskCategory_ProjectModuleMapping", new { area = "Setting" })' id="SaveTaskCateMapp" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Task Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TaskCategoryId, new SelectList(ViewBag.GetTaskCategory, "Id", "Name"), "--Select--", new { @class = "form-control", name = "TaskCategoryId", id = "ddlTaskCategory" })
                                                @Html.HiddenFor(model => model.TaskCate_ProjModuleMappingId_Encrypted)
                                                <span id="ErrorTaskCategory" class="text-danger"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" id="btnshow" onclick="ShowProjectName()" class="btn btn-primary btn-sm">Show</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-2"></div>
                                    <div class="col-md-8">
                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle TabledataBulkClass" style="width: 100%;">
                                            <thead style="background-color: rgba(233, 236, 239, 1) !important; position: sticky; top: 0; z-index: 1;">
                                                <tr>
                                                    <th class="text-center" style="width:70px;"><label><input type="checkbox" class="allChecked" name="checkbox" id="AllCheckBox" value="value"><b>&nbsp; All</b></label></th>
                                                    <th class="text-nowrap" hidden>ProjectId</th>
                                                    <th class="text-nowrap" hidden>ModuleId</th>
                                                    <th class="text-nowrap">Project</th>
                                                    <th class="text-nowrap">Module</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblProjectName" style="max-height: 250px; overflow-y: auto;">
                                                @foreach (var d in ViewBag.GetProjectModuleList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            @{
                                                                var check = d.IsActive ? "checked" : "";
                                                            }
                                                            <input type="checkbox" id="chkIsActive_@d.ProjectId" @check style="cursor:pointer" />
                                                        </td>
                                                        <td class="text-nowrap" hidden>@d.ProjectId</td>
                                                        <td class="text-nowrap" hidden>@d.ModuleId</td>
                                                        <td class="text-nowrap">@d.ProjectName</td>
                                                        <td class="text-nowrap">@d.ModuleName</td>
                                                    </tr>
                                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="col-md-2"></div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $("#btnGetList").click(function () {
        debugger;
        var url = '@Url.Action("GetList", "Setting_TMS_TaskCategory_ProjectModuleMapping")';
        window.location.href = url;
    });

    $(document).ready(function () {
        $("#ddlTaskCategory").select2();

        $('.TabledataBulkClass').DataTable({
            scrollY: 400,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
            stripeClasses: [] // Disable alternating row colors
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });


    $("#AllCheckBox").on("click", function () {
        debugger;
        var isChecked = $(this).prop('checked');
        $("#tblProjectName tr").each(function () {
            $(this).find("input").prop('checked', isChecked);
        });
    });


</script>
<script>
    function ShowProjectName() {
        var TaskCategoryId = $("#ddlTaskCategory").val();
        if (TaskCategoryId == "") {
            $("#ErrorTaskCategory").html("Task category id required");
            return false;
        }
        else {
            $("#ErrorTaskCategory").html("");
        }
        const url = '@Url.Action("Setting_TMS_TaskCategory_ProjectModuleMapping", "Setting_TMS_TaskCategory_ProjectModuleMapping", new { area = "Setting" })';
        window.location.href = url + '?TaskCategoryId=' + TaskCategoryId;
    }
</script>
<script>
    jQuery.validator.addMethod(
       "regex",
        function(value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        },"erreur expression reguliere"
     );

    $('#SaveTaskCateMapp').validate({
        rules: {
            TaskCategoryId: {
                required: true,
            },
        },
        messages: {
            TaskCategoryId: {
                required:"Task category name is required",
            },
        },
    });

    var form = $("#SaveTaskCateMapp");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
        }

        var TaskCate_ProjModuleMappingId_Encrypted = $("#TaskCate_ProjModuleMappingId_Encrypted").val();

        var table = document.getElementById("tblProjectName");
        var TaskCategoryId = $("#ddlTaskCategory").val();
        var rowCount = table.rows.length;
        var TaskCat_ProjectModuleMap = [];

        for (var i = 0; i < rowCount; i++) {
            debugger
            var data = {};
            var checkbox = table.rows[i].cells[0].children[0]; // Get the checkbox in the first cell
            //if (checkbox.checked) {  // Only collect data if the checkbox is checked
            data.TaskCategoryId = TaskCategoryId;
            data.IsActive = checkbox.checked;
            data.ProjectId = table.rows[i].cells[1].innerHTML;
            data.ModuleId = table.rows[i].cells[2].innerHTML;
            TaskCat_ProjectModuleMap.push(data);
            //}
        }

        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpadte", "Setting_TMS_TaskCategory_ProjectModuleMapping")',
            //url: "SaveUpadte",
            data: JSON.stringify({ TaskCat_ProjectModuleMap: TaskCat_ProjectModuleMap, TaskCategoryId: TaskCategoryId }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then(function () {
                            var url = '@Url.Action("Setting_TMS_TaskCategory_ProjectModuleMapping", "Setting_TMS_TaskCategory_ProjectModuleMapping")';
                            window.location.href = url;
                        })
                    }
                }
            }
        });
    });
</script>
