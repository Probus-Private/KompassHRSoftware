@model KompassHR.Areas.Setting.Models.Setting_TMS.TaskCategory_ProjectModuleMapping

@{
    ViewBag.Title = "Setting_TMS_TaskCategory_ProjectModuleMapping";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

