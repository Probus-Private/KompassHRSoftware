@model KompassHR.Areas.Setting.Models.Setting_UserAccessPolicy.Tool_UserAccessPolicyMaster
@{
    ViewBag.Title = "Setting_UserAccessPolicy_PolicyScreenMapping";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

