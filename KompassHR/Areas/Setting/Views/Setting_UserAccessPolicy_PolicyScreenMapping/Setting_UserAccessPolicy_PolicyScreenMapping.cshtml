<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Policy Screen Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_UserAccessPolicy_Menu", "Setting_UserAccessPolicy_Menu", new { id = 32, ScreenId = 121, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Policy Screen Mapping - @ViewBag.AddUpdateTitle </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This screen allows you to assign or update forms (screens/modules) for a selected policy.
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Setting_UserAccessPolicy_PolicyScreenMapping", "Setting_UserAccessPolicy_PolicyScreenMapping", new { area = "Setting" })' id="SaveUserAccessPolicy" method="post">
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="form-label">
                                                Policy Name<span class="important">*</span>
                                            </label>
                                            @Html.TextBoxFor(model => model.UserGroupName, new { @class = "form-control", name = "UserGroupName", type = "text", id = "txtUserGroupName", autocomplete = "Off", Value = "" })
                                            @Html.ValidationMessageFor(model => model.UserGroupName, "", new { @class = "help-block", @id = "ErrorUserGroupName", @style = "color:red" })
                                            @*<span class="error" id="ErrortxtUserGroupName"></span>*@
                                            @Html.HiddenFor(model => model.UserGroupId_Encrypted, new { id = "UserGroupId_Encrypted" })
                                            @Html.HiddenFor(model => model.UserGroupId, new { id = "UserGroupId" })
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="form-label">
                                                Module Name<span class="important">*</span>
                                            </label>
                                            @Html.DropDownList("UserGroupDetails_ModuleID", new SelectList(ViewBag.Kompass_Modules, "Id", "Name"), "--All--", new { id = "UserGroupDetails_ModuleID", @class = "form-control", autocomplete = "off", name = "UserGroupDetails_ModuleID" })
                                            @Html.ValidationMessage("UserGroupDetails_ModuleID", "", new { @class = "help-block", id = "ErrorUserGroupDetails_ModuleID", style = "color:red" })
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="form-label">
                                                Type<span class="important">*</span>
                                            </label>
                                            @Html.DropDownList("Type", new SelectList(ViewBag.TypeList, "Id", "Name"), "--All--", new { id = "ddlType", @class = "form-control", autocomplete = "off", name = "Type" })
                                            @Html.ValidationMessage("Type", "", new { @class = "help-block", id = "ErrorType", style = "color:red" })
                                        </div>
                                    </div>
                                </div>


                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <!-- BEGIN table-responsive -->
                                            <div class="table-scroll div1">
                                                <div class="table-wrap">
                                                    <table class="table table-bordered align-middle TablePageAccess" id="fixed-header"
                                                           style="width: 100%;">
                                                        <thead>
                                                            <tr class="trheading">
                                                                <th class="text-center text-nowrap">
                                                                    <label>
                                                                        <input type="checkbox" id="chkAllMenu">
                                                                        All Menu
                                                                    </label>
                                                                </th>
                                                                <th class="text-nowrap">Module Name</th>
                                                                <th class="text-nowrap">Form Name</th>
                                                                <th class="text-nowrap">Type</th>
                                                                <th class="text-nowrap">Description</th>

                                                            </tr>
                                                        </thead>
                                                        <tbody id="tblLoadModule"></tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "Setting_UserAccessPolicy_PolicyScreenMapping", new { area = "Setting" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetUserAccessPolicyList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr />

                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="table-scroll div1">
                                                <div class="table-wrap">
                                                    <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                                           style="width: 100%;">
                                                        <thead>
                                                            <tr class="trheading">
                                                               
                                                                <th class="text-nowrap">User Group Name</th>
                                                                <th class="text-nowrap">Module Name</th>
                                                                <th class="text-nowrap">Form Name</th>
                                                                <th class="text-nowrap">Type</th>
                                                                <th class="text-nowrap">Description</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var d in ViewBag.GetUserAccessPolicyMaster)
                                                            {
                                                                <tr>
                                                                   
                                                                    <td>@d.UserGroupName</td>
                                                                    <td>@d.ModuleName</td>
                                                                    <td>@d.ScreenDisplayMenuName</td>
                                                                    <td>@d.ScreenMenuType</td>
                                                                    <td>@d.DescriptionForUser</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                
            </div>
            <!-- END panel -->





        </div>
                </div>
            </div>

<script>
                $(document).ready(function () {

                    $('#chkAllMenu').prop('checked', false);
                    $("#UserGroupDetails_ModuleID").select2();
                    $("#ddlType").select2();



                    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
                    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
                    debugger;
                    if (Message != null) {
                        if (Icon != null) {
                            Swal.fire({
                                icon: Icon,
                                text: Message,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    // return false
                                }
                            }).then(function() {
                                window.location.reload();
                            });
                        }
                    }


                    $("#ddlType").on("change", function () {
                        debugger;
                        var UserGroupDetails_ModuleID = $("#UserGroupDetails_ModuleID").val();
                        var Type = $("#ddlType option:selected").text();
                        $.ajax({
                            type: 'GET',
                            dataType: 'JSON',
                            contentType: "application/json; charset=utf-8",
                            url: '@Url.Action("GetModuleWiseScreens", "Setting_UserAccessPolicy_PolicyScreenMapping")',
                            data: { ModuleId: UserGroupDetails_ModuleID,Type:Type },
                            success: function (data) {

                                var table = $('#fixed-header').DataTable();

                                table.clear(); // 🔥 clear old data

                                $.each(data, function (i, item) {

                                    table.row.add([
                                        `<input type="checkbox" class="chkMenu" value="${item.ScreenMasterId}">`,
                                        item.ModuleName,
                                        item.ScreenDisplayMenuName,
                                        item.ScreenMenuType,
                                        item.DescriptionForUser
                                    ]);
                                });

                                table.draw(); // 🔥 redraw table
                            },
                            error: function () {
                                alert("Error loading data");
                            }
                        });
                    });

                    var table = $('#fixed-header').DataTable({
                        scrollY: 400,
                        scrollCollapse: true,
                        paging: false,
                        scrollX: true,
                        searching: true,
                        destroy: true
                    });


                    var UserAccessPolicyMaster = @Html.Raw(Json.Encode(ViewBag.UserAccessPolicyMaster));
                    debugger;
                    if(UserAccessPolicyMaster!=null)
                    {
                        var GroupName=UserAccessPolicyMaster[0][2].Value;
                        $("#txtUserGroupName").val(GroupName);
                        $('#tblLoadModule tr').not(function () { return !!$(this).has('th').length; }).remove();
                        for(var i=0;i <= UserAccessPolicyMaster.length-1;i++)
                        {
                            debugger
                            var table = document.getElementById("tblLoadModule");
                            var rowCount = table.rows.length;
                            var row = table.insertRow(rowCount);
                            var count = $('#tblLoadModule tr').length;

                            row.insertCell(0).innerHTML= '<input ' + ( UserAccessPolicyMaster[i][10].Value ? 'checked' : ' ') + ' type="checkbox" />';
                            row.insertCell(1).innerHTML = "" + UserAccessPolicyMaster[i][1].Value + "";
                            row.insertCell(2).innerHTML = "" + UserAccessPolicyMaster[i][2].Value + "";
                            row.insertCell(3).innerHTML = "" + UserAccessPolicyMaster[i][3].Value + "";
                            row.insertCell(4).innerHTML = "" + UserAccessPolicyMaster[i][4].Value + "";
                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][5].Value +"";
                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][6].Value +"";
                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][7].Value +"";
                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][8].Value +"";
                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][9].Value +"";
                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][11].Value +"";

                            row.insertCell(5).innerHTML = ""+ UserAccessPolicyMaster[i][12].Value +"";
                        }
                    }


                });



</script>

<script>
                // Select / Unselect All
                $(document).on('change', '#chkAllMenu', function () {
                    $('.chkMenu').prop('checked', this.checked);
                });

                // Auto check/uncheck header
                $(document).on('change', '.chkMenu', function () {
                    let total = $('.chkMenu').length;
                    let checked = $('.chkMenu:checked').length;

                    $('#chkAllMenu').prop('checked', total === checked);
                });
</script>


