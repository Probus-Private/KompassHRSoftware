    $("#btnSubmit").click(function () {
        $(".Userloaderbg").css("display", "flex");
        var table = document.getElementById("tblUserRights");
        //var EmployeeId = $("#ddlEmployeeId").val();
        var EmployeeId = $('select#ddlEmployeeId option:selected').val();
        var GroupId = $("#txtGetUserPolicyName").val();
        var UserRightsIDEncrypted = $("#UserRightsIDEncrypted").val();

        var rowCount = table.rows.length;
        var UseRigths = [];
        debugger;
        for (i = 0; i <= rowCount - 1; i++) {
            debugger;
            var data = {};
            data.UserRightsScreenId = table.rows[i].cells[0].innerHTML;
            data.UserRightsModuleId = table.rows[i].cells[1].innerHTML;
            data.UserRightsGroupId = GroupId;
            //data.ScreenDisplayMenuName = table.rows[i].cells[2].innerHTML;
            //data.Description = table.rows[i].cells[3].innerHTML;
            //data.ScreenMenuType = table.rows[i].cells[4].innerHTML;
            data.ismenu = table.rows[i].cells[5].children[0].checked;
            data.EmployeeId = EmployeeId;
            //data.IsSave = table.rows[i].cells[6].children[0].checked;
            //data.IsUpdate = table.rows[i].cells[7].children[0].checked;
            //data.IsDelete = table.rows[i].cells[8].children[0].checked;
            //data.IsList = table.rows[i].cells[9].children[0].checked;
            UseRigths.push(data);
        }

        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpdate", "Setting_UserRights")',
