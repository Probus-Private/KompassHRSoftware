                                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                                <tr class="trheading">
                                                                    <th hidden>ScreenId</th>
                                                                    <th hidden>ScreenModuleId</th>
                                                                    <th class="text-center" colspan="3" style="border-left:1px solid lightgray;"></th>

                                                                    <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsMenuCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsMenu')"> All</label></th>
                                                                    @*<th class="text-center"><label><input type="checkbox" name="checkbox" id="IsSaveCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsSave')"> All</label></th>
                                                                        <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsUpdateCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsUpdate')"> All</label></th>
                                                                        <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsDeleteCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsDelete')"> All</label></th>
                                                                        <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsListCheckBox" value="value" onclick="checkAllCheckboxes(this, 'IsList')"> All</label></th>*@
                                                                </tr>
                                                                <tr>
                                                                    <th hidden>ScreenId</th>
                                                                    <th hidden>ScreenModuleId</th>
                                                                    <th class="text-center" style="border-left:1px solid lightgray;">Screen Name</th>
                                                                    <th class="text-center">Description</th>
                                                                    <th class="text-center">Screen Type</th>
                                                                    <th class="text-center">Menu</th>
                                                                    @*<th class="text-center">Add</th>
                                                                        <th class="text-center">Modify</th>
                                                                        <th class="text-center">Delete</th>
                                                                        <th class="text-center">List</th>*@
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblUserRights">
                                                                @if (ViewBag.GetMenus != null)
                                                                {
                                                                    foreach (var d in ViewBag.GetMenus)
                                                                    {
                                                                        <tr>
                                                                            @*<td class="fixed-side0 text-center" style="background-color:white !important; border-color:black !important;">
                                                                                    <input type="checkbox" id="txtDesignationId" class="chk chkDesignation" />
                                                                                </td>*@
                                                                            <td class="text-nowrap" hidden>@d.ScreenID</td>
                                                                            <td class="text-nowrap" hidden>@d.ScreenModuleId</td>
                                                                            <td class="text-nowrap" style="border-left:1px solid lightgray;">@d.ScreenDisplayMenuName</td>
                                                                            <td class="">@d.DescriptionForUser</td>
                                                                            <td class="text-nowrap">@d.ScreenMenuType</td>
                                                                            <td class="text-center">
                                                                                <input type="checkbox" @(d.IsMenu == true ? "checked" : "")>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                                <!-- END table-responsive -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
