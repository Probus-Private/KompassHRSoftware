                                                    </button>
                                                    @*<a href="/Setting/Setting_UserRights/GetList">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetUserAccessPolicyList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>*@
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlEmployeeId").select2();
        $("#txtGetUserPolicyName").select2();
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlEmployeeId").find("option").remove();
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            //var BranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_UserRights")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;

                    var BranchName = data.Branch;
                    if (BranchName != null) {
                        //var data1 = data.data;
                        //$("#ddlBranchId").append("<option value=''>All </option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });

                    }
                    else {
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                    }
                    var EmployeeName = data.EmployeeName;
                    if (EmployeeName != null) {
                        //$("#ddlEmployeeId").append("<option value=''>All </option>");
                        $.each(EmployeeName, function (i, p) {
                            $("#ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $("#ddlEmployeeId").append("<option value=''>--Select-- </option>");
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlEmployeeId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var UnitBranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetUnit',
                data: { CmpId: CmpId, UnitBranchId: UnitBranchId },
                success: function (data) {
                    debugger;
                    if (data == false) {
                        $("#ddlEmployeeId").find("option").remove();
                        $("#ddlEmployeeId").append("<option value=''>--Select-- </option>");
                    }
                    else {
                        debugger;
                        $("#ddlEmployeeId").find("option").remove();
                        if (data != null) {
                            //$("#txtEmployeeUnit").append("<option value=''>--Select-- </option>");
                            $.each(data, function (i, p) {
                                $("#ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                        else {
                            $("#ddlEmployeeId").append("<option value=''>--Select-- </option>");
                        }
                    }
                }
            })
        });

    });

    function checkAllCheckboxes(checkbox, checkboxType) {
        debugger;
        var checkboxes = document.querySelectorAll('[id^="' + checkboxType + 'CheckBox"]');
        checkboxes.forEach(function (cb) {
            cb.checked = checkbox.checked;
        });
        // if (checkboxType === 'IsMenu' || checkboxType === 'IsSave' || checkboxType === 'IsUpdate' || checkboxType === 'IsDelete' || checkboxType === 'IsList') {
        if (checkboxType === 'IsMenu') {

            var typeIndex = ['IsMenu'].indexOf(checkboxType);
            //var typeIndex = ['IsMenu', 'IsSave', 'IsUpdate', 'IsDelete', 'IsList'].indexOf(checkboxType);
            var dynamicCheckboxes = document.querySelectorAll('#tblUserRights tr td:nth-child(' + (typeIndex + 6) + ') input[type="checkbox"]');
            dynamicCheckboxes.forEach(function (dynamicCheckbox) {
                dynamicCheckbox.checked = checkbox.checked;
            });
        }
    }
</script>

