@model KompassHR.Areas.Setting.Models.Setting_UserAccessPolicy.UserBranchMapping
@{
    ViewBag.Title = "Setting_UserAccessPolicy_SiteWiseUser";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Required library for validation -->
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<script src="~/assets/js/CaptchaVerification.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
    .tblAddData td:nth-child(3) {
       text-align: center;
    }

    .tblAddData td:nth-child(1) {
        display: none;
    }

    .tblAddData td:nth-child(2) {
        display: none;
    }
     th:nth-child(3), td:nth-child(3) {
        width: 100px; /* Set the width for the first column */
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Business Unit Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_UserAccessPolicy_Menu", "Setting_UserAccessPolicy_Menu", new { id = 32, ScreenId = 121, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">User Business Unit Mapping - @ViewBag.AddUpdateTitle </h4>
                  
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        The user business unit mapping form is a critical tool in HRMS applications for organizing and managing employee data across different branches or locations within an organization, ensuring efficient HR operations and administration.
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form"  action='@Url.Action("SaveUpdate", "Setting_UserAccessPolicy", new { area = "Setting" })'   id="SaveSiteWiseUser" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.EmployeeID, new SelectList(ViewBag.GetEmpolyeeName, "Id", "Name"), "--Select--", new { @class = "form-control", name = "EmpolyeeName", id = "txtGetEmpolyeeName" })
                                                <span id="ErrortxtGetEmpolyeeName" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" id="btnshow" onclick="showallcompanyandbranchname()" class="btn btn-primary btn-sm">Show</button>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-12">

                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="panel-body">
                                                <!-- BEGIN table-responsive -->
                                                <div class="table-scroll div1">
                                                    <div class="table-wrap">
                                                        @*<div>
                                                            <label><b></b></label>
                                                        </div>*@
                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData">
                                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                                <tr class="trheading">
                                                                    <th class="text-nowrap" hidden>BusniessunieId</th>
                                                                    <th class="text-nowrap" hidden>CompanyId</th>
                                                                    @*<th class="text-nowrap" hidden>IsActive</th>*@
                                                                    <th class="text-center"> <input type="checkbox" class="allChecked" name="checkbox" id="AllCheckBox" value="value">&nbsp;All </th>
                                                                    <th class="text-center">Company Name</th>
                                                                    <th class="text-center">Business Unit</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblBusniessName"></tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                                <!-- END table-responsive -->
                                                
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        Submit
                                                    </button>
                                                    <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
        $(document).ready(function () {
        debugger;
        var UserSiteMapping = @Html.Raw(Json.Encode(ViewBag.UserSiteMapping));
        if(UserSiteMapping!=null)
        {
            for(var i=0;i <= UserSiteMapping.length-1;i++)
            {
                var table = document.getElementById("tblBusniessName");
                var rowCount = table.rows.length;
                var row = table.insertRow(rowCount);
                var count = $('#tblBusniessName tr').length;
                row.insertCell(0).innerHTML = "" + UserSiteMapping[i][3].Value + "";
                row.insertCell(1).innerHTML = "" + UserSiteMapping[i][1].Value + "";
                row.insertCell(2).innerHTML= '<input ' + ( UserSiteMapping[i][0].Value ? 'checked' : ' ') + ' type="checkbox" />';
                row.insertCell(3).innerHTML = "" + UserSiteMapping[i][2].Value + "";
                row.insertCell(4).innerHTML = "" + UserSiteMapping[i][4].Value + "";
            }
        }
        $("#txtGetEmpolyeeName").change(function () {
            $("#tblBusniessName").empty();
        });
        $("#txtGetEmpolyeeName").select2();
    });//ready fnction



    $("#btnGetList").click(function () {
        var url = '@Url.Action("GetList", "Setting_UserAccessPolicy_SiteWiseUser")';
        window.location.href = url;
    });


    function showallcompanyandbranchname() {
        debugger
        var EmployeeId = $("#txtGetEmpolyeeName").val();
        if(EmployeeId=="")
        {
            $("#ErrortxtGetEmpolyeeName").html("Employee name id required");
        }
        else{
            $("#ErrortxtGetEmpolyeeName").html("");
        }
        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetEmployee", "Setting_UserAccessPolicy_SiteWiseUser")',
            //url: 'GetEmployee',
            data: { EmployeeId: EmployeeId },
            success: function (data) {
                if(data == true)
                {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Employee Access Already Exists',
                        text: 'Please choose a different configuration.',
                    });
                }
                else
                {
                    debugger;
                    $.ajax({
                        type: 'GET',
                        data: { EmployeeId: EmployeeId },
                        url: '@Url.Action("GetBusinessUnit", "Setting_UserAccessPolicy_SiteWiseUser")',
                        success: function (data) {
                            debugger;
                            $('#tblBusniessName tr').not(function () { return !!$(this).has('th').length; }).remove();
                            for (var i = 0; i < data.length; i++) {
                                var table = document.getElementById("tblBusniessName");
                                var rowcount = table.rows.length;
                                var row = table.insertRow(rowcount);
                                row.insertCell(0).innerHTML = "" + data[i][3].Value + "";
                                row.insertCell(1).innerHTML = "" + data[i][1].Value + "";

                                row.insertCell(2).innerHTML = '<input ' + ( data[i][0].Value ? 'checked' : ' ') + ' type="checkbox" class="chk" />';

                                row.insertCell(3).innerHTML = "" + data[i][2].Value + "";
                                row.insertCell(4).innerHTML = "" + data[i][4].Value + "";
                            }
                        }
                    });
                }
            }

        });

    }


    $("#AllCheckBox").on("click", function () {
        debugger;
        var isChecked = $(this).prop('checked');
        $("#tblBusniessName tr").each(function () {
            $(this).find("input").prop('checked', isChecked);
        });
    });




    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
        function (value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        }, "erreur expression reguliere"
);

    $("#SaveSiteWiseUser").validate({
        rules: {
            EmployeeID: {
                required: true,
            },
        },
        messages: {
            EmployeeID: {
                required: "Empolyee Name is required"
            },
        }
    });



    var form = $("#SaveSiteWiseUser");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger
        form.valid();
        if (form.valid() == false) {
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        var table = document.getElementById("tblBusniessName");
        var empolyee = $("#txtGetEmpolyeeName").val();
        var rowCount = table.rows.length;
        var usersitemap = [];
        debugger;
        var data = {};
        for (i = 0; i <= rowCount - 1; i++) {
            debugger;
            var data={};
            data.EmployeeID = empolyee;
            data.IsActive = table.rows[i].cells[2].children[0].checked;
            data.BranchID = table.rows[i].cells[0].innerHTML;
           // data.EmployeeID = table.rows[i].cells[1].innerHTML;
            data.CmpID = table.rows[i].cells[1].innerHTML;
            usersitemap.push(data);
        }
        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpadte", "Setting_UserAccessPolicy_SiteWiseUser")',
            //url: "SaveUpadte",
            data: JSON.stringify({ usersitemap: usersitemap }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then(function () {
                            var url = '@Url.Action("Setting_UserAccessPolicy_SiteWiseUser", "Setting_UserAccessPolicy_SiteWiseUser")';
                            window.location.href = url;
                        })
                    }
                }
            }
        });
    });
</script>