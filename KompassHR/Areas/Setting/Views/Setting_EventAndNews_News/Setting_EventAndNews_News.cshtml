<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                News
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_EventAndNews_Menu", "Setting_EventAndNews_Menu",  new { id = 20,ScreenId=101, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> News - Add </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add new news here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_EventAndNews_News", new { area = "Setting" })' id="SaveNewsSetting" method="post" enctype="multipart/form-data">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", id = "DocNo", name = "DocNo", autocomplete = "Off", type = "text", style = "background-color:#eee;", Value = @ViewBag.DocNo.DocNo })
                                                @Html.HiddenFor(model => model.NewsID_Encrypted)

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", id = "txtDocDate", name = "DocDate", autocomplete = "Off", type = "date", @readonly = "readonly", style = "background-color:#eee;" })

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Title
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.NewsTitle, new { @class = "form-control", id = "txtNewsTitle", name = "NewsTitle", autocomplete = "Off", type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.NewsDescripation, new { @class = "form-control", id = "NewsDescripation", name = "NewsDescripation", autocomplete = "Off", type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.NewsFromDate, new { @class = "form-control", id = "txtNewsFromDate", name = "NewsFromDate", autocomplete = "Off", type = "date" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.NewsToDate, new { @class = "form-control", id = "txtNewsToDate", name = "NewsToDate", autocomplete = "Off", type = "date" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row ">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Attachment
                                            </label>
                                            <div class="col-md-8">
                                                <input class="form-control" onchange="ResetFile()" type="file" id="NewsFilePath" name="FilePath" />
                                                <label class="form-label col-form-label col-md-8" id="lblFileName">@TempData["FileName"]</label>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                            </label>
                                            <div class="col-md-8 ">
                                                @Html.CheckBoxFor(model => model.IsActive) &nbsp;
                                                <label class="form-label">
                                                    Is Active
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>

                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnGetNewsSettingList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveNewsSetting').validate({
        rules: {
            DocDate: {
                required: true,
            },
            NewsTitle: {
                required: true,
            },
            NewsDescripation: {
                required: true,
            },
            NewsFromDate: {
                required: true,
            },
            NewsToDate: {
                required: true,
            },
        },
        messages: {
            DocDate: {
                required: "Doc Date is required",
            },
            NewsTitle: {
                required: "News Title name is required",
            },
            NewsDescripation: {
                required: "News Descripation name is required",
            },
            NewsFromDate: {
                required: "FromDate name is required",
            },
            NewsToDate: {
                required: "ToDate name is required",
            },
        },
    });

    var form = $("#SaveNewsSetting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtDocDate").removeClass('error');
            $("#txtNewsFromDate").removeClass('error');
            $("#txtNewsToDate").removeClass('error');
            return false;
        }
        var NewsTitle=$("#txtNewsTitle").val();
        var NewsIDEncrypted=$("#NewsID_Encrypted").val();
        $.ajax({
            url: '@Url.Action("IsNewsExists", "Setting_EventAndNews_News")',
            method:"get",
            data:{NewsTitle:NewsTitle,NewsIDEncrypted:NewsIDEncrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveNewsSetting").submit();

                }
            }
        });
        return false;
    });
</script>

<script>
    $("#btnGetNewsSettingList").click(function () {
        var url = '@Url.Action("GetList", "Setting_EventAndNews_News")';
        window.location.href = url;
    });

    $(document).ready(function () {
        var DocDate = @Html.Raw(Json.Encode(TempData["DocDate"]));
        var FromDate = @Html.Raw(Json.Encode(TempData["FromDate"]));
        var ToDate = @Html.Raw(Json.Encode(TempData["ToDate"]));
        
        debugger;
        if(DocDate==""||FromDate==""||ToDate=="")
        {
           
        }
        else
        {
            var DocDate =  convertDate(DocDate);
            var FromDate =  convertDate(FromDate);
            var ToDate =  convertDate(ToDate);
            $("#txtDocDate").val(DocDate);
            $("#txtNewsFromDate").val(FromDate);
            $("#txtNewsToDate").val(FromDate);
        }

        $("#ddlDirecation").prop("disabled", true);
        $("#txtTotalMinutes").prop("disabled", true);
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        $("#NewsFilePath").change(function () {
            ResetFile();
        });
    });//Ready
</script>

<script>
function ResetFile() {
    let allowedExtension = ['image/jpeg', 'image/jpg', 'image/png', 'application/pdf'];
    let fileInput = document.getElementById('NewsFilePath');
    if (fileInput.files.length > 0) {
        let type = fileInput.files[0].type;
        if (allowedExtension.indexOf(type) > -1) {
            // valid
        } else {
            Swal.fire({
                text: 'File type should be allow only jpeg/jpg/png and pdf format.',
                icon: 'info',
                allowOutsideClick: false
            });
            fileInput.value = null;
        }
    }
    $("#lblFileName").text('');
}
</script>

<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>