@model KompassHR.Areas.Setting.Models.Setting_Preboarding.Preboarding_Document

@{
    ViewBag.Title = "Setting_Preboarding_Attachments";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    #content .table-responsive {
        max-height: none !important;
        height: auto !important;
        overflow: visible !important;
    }

    .error-message {
        display: none;
        font-size: 12px;
        margin-top: 4px;
    }

</style>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Preboarding Attachments
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Preboarding_Menu", "Setting_Preboarding_Menu", new { id = 2, ScreenId = 39, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <!-- Panel -->
    <div class="panel panel-inverse" data-sortable-id="index-1">
        <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
            <h4 class="panel-title">Preboarding Attachments</h4>
            <div class="panel-heading-btn">
                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
            </div>
        </div>

        <div class="panel-body">
            <form id="SaveDocuments" method="post" enctype="multipart/form-data"
                  action='@Url.Action("SaveUpdate", "Setting_Preboarding_Attachments", new { area = "Setting" })'>
                @Html.HiddenFor(model => model.PreboardingDocumentId_Encrypted)


                <!-- Upload Card -->
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label fw-semibold">File Name <span class="text-danger">*</span></label>
                                <input type="text" id="FileName" name="FileName" class="form-control" placeholder="Enter file name" />
                                <span id="errorFileName" class="text-danger error-message">Please enter a file name.</span>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-semibold">Upload PDF <span class="text-danger">*</span></label>
                                <input type="file" id="AttachmentFile" name="AttachmentFile" class="form-control" accept=".pdf" />
                                <span id="errorFileUpload" class="text-danger error-message">Please choose a valid PDF file (max 10MB).</span>
                            </div>
                            <div class="col-md-2 text-end">
                                <button type="button" id="btnAddAttachment" class="btn btn-primary w-100">
                                    <i class="fa fa-upload me-1"></i> Add
                                </button>
                            </div>
                        </div>
                        <small class="text-muted d-block mt-2">
                            Only PDF files allowed (Max size: 10MB)
                        </small>
                    </div>
                </div>

                <!-- File List Table -->
                <div class="table-responsive">
                    <table id="AttachmentTable" class="table table-hover table-bordered align-middle shadow-sm">
                        <thead class="table-light">
                            <tr>
                                <th style="width:5%">#</th>
                                <th>File Name</th>
                                <th>PDF Document</th>
                                <th style="width:20%">Upload Date</th>
                                <th style="width:10%">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Rows added dynamically -->
                        </tbody>
                    </table>
                </div>

                <!-- Submit Button -->
                <div class="text-end mt-3">
                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk"></i> Submit
                    </button>
                    <a href="@Url.Action("GetList", "Setting_Preboarding_Attachments", new {area = "Setting" })" class="btn btn-danger btn-sm">
                        <i class="fa-solid fa-share-from-square"></i> List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- jQuery Script -->


