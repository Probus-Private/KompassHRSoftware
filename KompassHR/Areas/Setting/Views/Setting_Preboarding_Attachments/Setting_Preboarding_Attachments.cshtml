<script>
$(document).ready(function () {
    var attachmentCount = 0;
    $('#btnAddAttachment').click(function () {
        var fileName = $('#FileName').val().trim();
        var fileInput = $('#AttachmentFile')[0];
        var file = fileInput.files[0];
        var isValid = true;

        $('.error-message').hide();

        if (!fileName) {
            $('#errorFileName').show();
            isValid = false;
        }

        if (!file) {
            $('#errorFileUpload').text('Please choose a file to upload.').show();
            isValid = false;
        } else {
            var fileExt = file.name.split('.').pop().toLowerCase();
            if (fileExt !== 'pdf') {
                $('#errorFileUpload').text('Only PDF files are allowed.').show();
                $('#AttachmentFile').val('');
                isValid = false;
            } else if (file.size > 10 * 1024 * 1024) {
                $('#errorFileUpload').text('File size exceeds 10MB limit.').show();
                $('#AttachmentFile').val('');
                isValid = false;
            }
        }

        if (!isValid) return;

        attachmentCount++;
        var uploadDate = new Date().toLocaleString();

        var newRow = $(`
        <tr>
            <td>${attachmentCount}</td>
            <td>${fileName}</td>
            <td><i class="fa-solid fa-file-pdf text-danger me-1"></i>${file.name}</td>
            <td>${uploadDate}</td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-danger btnRemove">
                    <i class="fa fa-trash"></i>
                </button>
            </td>
        </tr>`);

        // store file object
        newRow.data('file', file);
        $('#AttachmentTable tbody').append(newRow);

        $('#FileName').val('');
        $('#AttachmentFile').val('');
    });

    // ✅ Remove row
    $(document).on('click', '.btnRemove', function () {
        $(this).closest('tr').remove();

        // Reindex rows
        $('#AttachmentTable tbody tr').each(function (index) {
            $(this).find('td:first').text(index + 1);
        });
        attachmentCount = $('#AttachmentTable tbody tr').length;
    });

    // ✅ Submit button
    $('#btnSubmit').click(function (e) {
        e.preventDefault();

        if ($('#AttachmentTable tbody tr').length === 0) {
            $('#errorFileUpload').text('Please add at least one attachment before submitting.').show();
            return;
        }

        var formData = new FormData();
        var rows = $('#AttachmentTable tbody tr');
        var files = [];

        rows.each(function (index) {
            var fileName = $(this).find('td:eq(1)').text();
            var fileLabel = $(this).find('td:eq(2)').text();
            var file = $(this).data('file');
            var PreboardingDocumentId_Encrypted = $("#PreboardingDocumentId_Encrypted").val();// we'll store file object here later
            if (file) {
                formData.append('AttachmentFiles', file);
                formData.append('FileNames', fileName);
                formData.append('PreboardingDocumentId_Encrypted', PreboardingDocumentId_Encrypted);
            }
        });

        $.ajax({
            url: '@Url.Action("SaveUpdateMultiple", "Setting_Preboarding_Attachments", new { area = "Setting" })',
            type: 'POST',
            data: formData,
            contentType: false,
            processData: false,
            success: function (res) {
                Swal.fire({
                    icon: res.icon,
                    text: res.message
                }).then(() => {
                    window.location.reload();
                });
            },
            error: function (xhr) {
                Swal.fire("Error", "Something went wrong: " + xhr.responseText, "error");
            }
        });
    });
});
</script>
