                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => Model.DocNo, new { @class = "form-control", id = "DocNo", name = "DocNo", @readonly = "readonly", Value = @ViewBag.DocNo.DocNo })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new
                                           {
                                               name = "DocDate",
                                               @class = "form-control",
                                               id = "DocDate",
                                               type = "date"
                                           })



                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.WarningEmployeeID, new SelectList(ViewBag.GetEmployeeName, "EmployeeId", "EmployeeName"), "--Select--", new { id = "WarningEmployeeID", name = "WarningEmployeeID", @class = "form-select", autocomplete = "off" })

                                                @*<select class="form-select">
                                                        <option selected>Select</option>
                                                        <option>Emp1</option>
                                                        <option>Emp2</option>
                                                    </select>*@
                                            </div>
                                        </div>
                                    </div>


                                </div>


                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Total Warning
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">

                                                @*<input name="TotalWarning" id="TotalWarning" type="hidden" />*@
                                                @Html.TextBox("TotalWarning", "", new { @class = "form-control", id = "TotalWarning", name = "TotalWarning", @readonly = "readonly", disabled = "disabled", Value = 0 })
                                                @*@Html.TextBox("TotalWarning", "", new { @class = "form-control", id = "TotalWarning", name = "TotalWarning", @readonly = "readonly", disabled = "disabled", @Value = ViewBag.TotalWarning.DocNo })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                This Month
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBox("ThisMonthTotal", "", new { @class = "form-control", id = "ThisMonthTotal", name = "ThisMonthTotal", @readonly = "readonly", disabled = "disabled", Value = 0 })
                                                @*@Html.TextBox("ThisMonthTotal", "", new { @class = "form-control", id = "ThisMonthTotal", name = "ThisMonthTotal", @readonly = "readonly", disabled = "disabled", @Value = ViewBag.TotalWarning.DocNo })*@


                                                @*<input class="form-control" type="text" disabled />*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Warning Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.WarningID, new SelectList(ViewBag.GetWarningType, "WarningID", "WarningType"), "--Select--", new { id = "WarningID", name = "WarningID", @class = "form-select", autocomplete = "off" })

                                                @*<select class="form-select">
                                                        <option selected>Select</option>
                                                        <option>Type1</option>
                                                        <option>Type2</option>
                                                    </select>*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.Description, new { @class = "form-control", id = "Description", name = "Description" })


                                                @*<textarea class="form-control" rows="2"></textarea>*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="submit" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnEmployeeWarningGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- BEGIN scroll-top-btn -->
<a href="javascript:;" class="btn btn-icon btn-circle btn-success btn-scroll-to-top"
   data-toggle="scroll-to-top"><i class="fa fa-angle-up"></i></a>
<!-- END scroll-top-btn -->
<!-- END #app -->

<script>
    debugger;
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }



    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

</script>
<script>
    $(document).ready(function () {
            debugger;
            var dt = @Html.Raw(Json.Encode(TempData["DocDate"]));

            if(dt != null )
            {
                var VoucherDatedt =  convertDate(dt);
                $("#DocDate").val(VoucherDatedt);

            }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }

        $("#btnEmployeeWarningGetList").click(function () {
            window.location.href= '@Url.Action("GetList", "Setting_Warning_EmployeeWarning")';
        });

        });//Ready Funcation
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       debugger;
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#saveEmployeeWarning").validate({

        rules: {
            DocDate:{
                required:true,
            },
            WarningEmployeeID: {
                required: true,

            },
            WarningID: {
                required: true,

            },

            Description:{
                required:true,
            }


        },
        messages: {

            DocDate: {
                required: "This field is required",
            },
            WarningEmployeeID: {
                required: "This field is required",

            },
            WarningID: {
                required: "This field is required",
            },

            Description:{
                required: "This field is required",
            },


        }
    });

    //<-----------------------------Alreay exist---------------------------------->
    var form=$("#saveEmployeeWarning");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#DocDate").removeClass('error');
            //$('#txtCorporationDate').removeClass('error');
            return false;
        }
        debugger;
        var DocNo=$("#DocNo").val();
        var DocDate=$("#DocDate").val();
        var WarningEmployeeID=$("#WarningEmployeeID").val();
        var WarningEmpID_Encrypted=$("#WarningEmpID_Encrypted").val();
        var WarningID=$("#WarningID").val();
        var Description=$("#Description").val();




        $.ajax({
            url:"IsEmployeeWarningExists",
            method:"get",

            data:{DocNo:DocNo,
                DocDate:DocDate,
                EmployeerID:EmployeerID,
                WarningEmpID_Encrypted:WarningEmpID_Encrypted,
                WarningID:WarningID,
                Description:Description
            },
            success:function(response){
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    debugger;
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });
                    }
                }
                else{
                    //End BtnSubmit
                    $("#saveEmployeeWarning").submit();
                }
            }
        });
    });
</script>


<script>
    $(document).ready(function () {
        $("#WarningEmployeeID").change(function () {
            debugger;
            var WarningEmployeeID = $("#WarningEmployeeID").val();
            $.ajax({
                async: true,
                type: 'GET',
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                url: 'GetEmployeeWarningDetail',
                data: { WarningEmployeeID: WarningEmployeeID },
                success: function (data) {
                    debugger;
                    $('#TotalWarning').val(data.TotalWarning);
                    $('#ThisMonthTotal').val(data.MonthTotal)
                    //$('#TotalWarning').html(data.TotalWarning);


                },
            });
        });
    });

</script>