                        Add details of warning given to employee here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/Setting/Setting_Warning_EmployeeWarning/SaveUpdate" id="saveEmployeeWarning" method="post">
                                <div class="row mb-15px">
