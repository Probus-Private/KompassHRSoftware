            EDLICeilingLimit: {
                required: "EDLI ceiling limit is required",
            },
        }
    });

    var form = $( "#SaveStatutoryPFAdminCharges");
    form.validate();
    $("#btnSubmit").click(function () {
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var FromDate=$("#txtFromDate").val();
        var PFAdminChargesId_Encrypted=$("#PFAdminChargesId_Encrypted").val();
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            url: "@Url.Action("IsPFAdminExists", "Setting_Statutory_PFAdminCharges")",
            method:"get",
            data:{FromDate:FromDate,PFAdminChargesId_Encrypted:PFAdminChargesId_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $(".Userloaderbg").css("display", "flex");
                    $("#SaveStatutoryPFAdminCharges").submit();

                }
            }
        });

    });
</script>