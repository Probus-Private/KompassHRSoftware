@model KompassHR.Areas.Setting.Models.Setting_Payroll.Payroll_Company_Bank

@{
    ViewBag.Title = "Setting_Payroll_CompanyBank";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Company Bank
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Payroll_Menu", "Setting_Payroll_Menu", new { id = 6, ScreenId = 287, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Company Bank Setting</h4>
                  
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Company Bank
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row justify-content-center">
                        <form role="form" action='@Url.Action("SaveUpdate", "Setting_Payroll_CompanyBank", new { area = "Setting" })' id="formCompanyBank" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.CompanyBankCmpID, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CompanyBankCmpID", id = "ddlCmpId" })
                                            @Html.HiddenFor(model => model.CompanyBankId_Encrypted, new { id = "CompanyBankId_Encrypted" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Business Unit
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.CompanyBankBUId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "CompanyBankBUId", id = "ddlBranchId" })

                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Bank Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.BankName, new { @class = "form-control", type = "text", id = "txtBankName", name = "BankName", autocomplete = "Off" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Branch Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.BranchName, new { @class = "form-control", type = "text", id = "txtBranchName", name = "BranchName", autocomplete = "Off" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Account Number
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.AccountNo, new { @class = "form-control", type = "text", id = "txtAccountNo", name = "AccountNo", autocomplete = "Off", minlength = "10", maxlength = "15", oninput = "this.value = this.value.replace(/[^0-9]/g, '')" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            IFSC Code
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.IFSCCode, new { @class = "form-control", type = "text", id = "txtIFSCCode", name = "IFSCCode", autocomplete = "Off" ,oninput = "this.value = this.value.toUpperCase()" })
                                            <span id="ifscError" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                        </label>
                                        <label class="form-label col-form-label col-md-4">
                                            @Html.CheckBoxFor(model => model.IsDefault, new { id = "chkIsDefault" })
                                            Is Default
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit"
                                                            class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "Setting_Payroll_CompanyBank", new { area = "Setting" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetNoticePeriodList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        debugger;
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlEmployeeId").select2();
        $("#ddlNoDuesNameId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_Payroll_CompanyBank")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data.Branch != null) {
                        $("#ddlBranchId").append("<option value=''>--Select--</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
        //document.addEventListener("DOMContentLoaded", function () {
        //    let ifscInput = document.getElementById('txtIFSCCode');

        //    if (ifscInput) { // Ensure element exists
        //        ifscInput.addEventListener('input', function () {
        //            this.value = this.value.toUpperCase();
        //        });
        //    } else {
        //        console.error("IFSC Code input field not found!");
        //    }
        //});
        //$("#txtIFSCCode").on("input", function () {
        //    debugger;
        //    let value = $(this).val().toUpperCase();
        //    $(this).val(value); // Update input field with uppercase value
        //});

    });
</script>
<script>

    $("#formCompanyBank").validate({
        rules: {
            CompanyBankCmpID: {
                required: true,
            },
            CompanyBankBUId: {
                required: true,
            },
            BankName: {
                required: true,
            },
            BranchName:
                {
                    required: true,
                },
            AccountNo:
                {
                    required: true,
                },
            IFSCCode:
                {
                    required: true,
                },
        },
        messages: {

            CompanyBankCmpID: {
                required: "Select the Company Name",
            },
            CompanyBankBUId: {
                required: "Select the Branch Name",
            },
            BankName: {
                required: "Enter Bank Name",
            },
            BranchName: {
                required: "Enter Branch Name",
            },
            AccountNo: {
                required: "Enter Account Number Name",
                },
            IFSCCode: {
                required: "Enter IFSC Code Name",
            },
        },

    });


    var form = $("#formCompanyBank");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if (form.valid() == false) {
            return false;
        }
        var IFSC=$("#txtIFSCCode").val();
        if(IFSC!="") {
            debugger;
            let ifscPattern = /^[A-Z]{4}0[A-Z0-9]{6}$/; // IFSC Code Format
            //let value = this.value.toUpperCase();
            let errorSpan = document.getElementById('ifscError');

            if (IFSC.length < 11) {
                errorSpan.textContent = "IFSC code must be exactly 11 characters.";
                return false;
            } else if (!ifscPattern.test(IFSC)) {
                errorSpan.textContent = "Invalid IFSC code format.";
                return false;
            } else {
                errorSpan.textContent = "";
            }
        }
        var CompanyBankId_Encrypted = $("#CompanyBankId_Encrypted").val();
        var AccountNo = $("#txtAccountNo").val();
        var CmpID = $("#ddlCmpId").val();
        var BranchID = $("#ddlBranchId").val();
      
        $.ajax({
            url: '@Url.Action("IsAccountNoExists", "Setting_Payroll_CompanyBank")',
            method: "get",
            data: { CompanyBankId_Encrypted: CompanyBankId_Encrypted,AccountNo:AccountNo ,BranchID:BranchID,CmpID:CmpID},
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else {
                    debugger;

                    $("#formCompanyBank").submit();
                }

            }
        });
    });
</script>


