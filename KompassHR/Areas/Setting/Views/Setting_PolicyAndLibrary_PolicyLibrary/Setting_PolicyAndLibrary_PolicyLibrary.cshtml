                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Remark, new { @class = "form-control", type = "text", name = "DesignationName", id = "txtRemark", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.Remark, null, new { @class = "help-block", @id = "ErrorRemark", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2 mt-10px" style="display:none">
                                                <input class="form-check-input form-check-label form-check-inline"
