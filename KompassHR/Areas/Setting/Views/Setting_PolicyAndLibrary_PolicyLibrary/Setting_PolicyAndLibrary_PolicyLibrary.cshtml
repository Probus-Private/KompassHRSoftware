                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.FileType, new List<SelectListItem> {
                                                        new SelectListItem { Text = "URL", Value = "URL"},
                                                        new SelectListItem { Text = "Upload File", Value = "UploadFile"},
                                                    }, "--Select--", new { id = "ddlFileType", @class = "form-select", autocomplete = "off", name = "FileType" })
                                                    @Html.ValidationMessageFor(model => model.FileType, null, new { @class = "help-block", @id = "ErrorFileType", @style = "color:red" })
                                                </div>
                                                <div class="col-md-2 mt-10px" style="display:none">
                                                    <input class="form-check-input form-check-label form-check-inline"
