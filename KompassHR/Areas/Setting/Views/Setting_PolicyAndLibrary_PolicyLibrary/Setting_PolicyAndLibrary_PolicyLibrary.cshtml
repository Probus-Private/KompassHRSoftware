                                                    <label class="form-check-label form-label">
                                                        All
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>*@

                                @*<div class="row" id="divURL">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-2">
                                                    URL
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.DocumentPath, new { @class = "form-control", type = "text", name = "URL", id = "txtURL", autocomplete = "Off" })
                                                    @Html.ValidationMessageFor(model => model.DocumentPath, null, new { @class = "help-block", @id = "ErrorURL", @style = "color:red" })
                                                </div>
                                                <div class="col-md-2 mt-10px" style="display:none">
                                                    <input class="form-check-input form-check-label form-check-inline"
                                                           type="checkbox" />
                                                    <label class="form-check-label form-label">
                                                        All
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>*@


                                <div class="row mb-15px" id="divUploadFile">
                                    <label class="form-label col-form-label col-md-2">
                                        Upload File
                                    </label>
                                    <div class="col-md-8">
                                        <input type="file" name="Image" class="form-control" id="fileupload"
                                               accept="application/pdf" onchange="ResetFile()" />

                                        @Html.ValidationMessageFor(model => model.DocumentPath, null, new { @class = "help-block", @id = "ErrorDocumentPath", @style = "color:red" })

                                        <label class="form-label col-form-label col-md-8" id="lblFileName">
                                            @TempData["FileName"]
                                        </label>


                                    </div>
                                </div>



                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit"
                                                            class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="/Setting/Setting_PolicyAndLibrary_PolicyLibrary/GetList">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnPolicyList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        $("#divURL").hide();
        //$("#divUploadFile").hide();
        $("#ddlCompanyname").select2();
        $("#ddlBusinessUnit").select2();
        $("#ddlPolicyID").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        var FileType = @Html.Raw(Json.Encode(TempData["FileType"]));
        if(FileType!=null)
        {
            if(FileType=="URL")
            {
                $("#divURL").show();
            }
            else{
                $("#divUploadFile").show();
            }
        }
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        $("#ddlCompanyname").on("change", function () {
            debugger;
            $("#ddlBusinessUnit").find("option").remove();
            var CmpId = $("#ddlCompanyname").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlBusinessUnit").append("<option value=0> --Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBusinessUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });



    });
</script>

<script>
    $("#FormReset").click(function(){
        $("#FormPolocyLiabrary")[0].reset();
    })

    function ResetFile()
    {
        let allowedTypes = [
        'image/jpeg',
        'image/jpg',
        'image/png',
        'application/pdf',
        'application/msword', // .doc
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document' // .docx
        ];
        let type = document.getElementById('fileupload').files[0].type;

        if(allowedExtension.indexOf(type)>-1)
        {
        }else{
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf/docx/doc",
            })
            document.getElementById("fileupload").value = null;
        }

        $("#lblFileName").text('');
    }



</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    // Use for Add validation in form
    $("#FormPolocyLiabrary").validate({
        rules: {
            //CmpID: {
            //    required: true,
            //},
            //PolicyLibraryBranchId:{
            //    required: true,
            //},
            //PolicyLibraryPolicyId:{
            //    required: true,
            //},
            //Remark:{
            //    required: true,
            //},
            //FileType:{
            //    required: true,
            //},
        },
        messages: {
            //CmpID: {
            //    required: "Company name is required",
            //},
            //PolicyLibraryBranchId:{
            //    required: "Business unit is required",
            //},
            //PolicyLibraryPolicyId:{
            //    required: "Policy name is required",
            //},
            //Remark:{
            //    required: "Remark is required",
            //},
            //FileType:{
            //    required: "File type is required",
            //},
        }
    });

    var form = $("#FormPolocyLiabrary");
    form.validate();
    $("#btnSubmit").click(function () {
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var Companyname = $("#ddlCompanyname").val();
        if(Companyname!="")
        {
            $('#ErrorCmpID').html("");
        }
        else{
            $('#ErrorCmpID').html("Company name is required"); $("#ddlCompanyname").focus();  return false;
        }
        var BusinessUnit = $("#ddlBusinessUnit").val();
        if(BusinessUnit!="0")
        {
            $('#ErrorPolicyLibraryBranchId').html("");
        }
        else{
            $('#ErrorPolicyLibraryBranchId').html("Business unit is required"); $("#ddlBusinessUnit").focus();  return false;
        }
        var PolicyID = $("#ddlPolicyID").val();
        if(PolicyID!="")
        {
            $('#ErrorPolicyLibraryPolicyId').html("");
        }
        else{
            $('#ErrorPolicyLibraryPolicyId').html("Policy name is required"); $("#ddlPolicyID").focus();  return false;
        }

        var Remark = $("#txtRemark").val();
        if(Remark!="")
        {
            $('#ErrorRemark').html("");
        }
        else{
            $('#ErrorRemark').html("Remark is required"); $("#txtRemark").focus();  return false;
        }
        var FileType = $("#ddlFileType").val();
        if(FileType!="")
        {
            $('#ErrorFileType').html("");
        }
        else{
            $('#ErrorFileType').html("File type is required"); $("#ddlFileType").focus();  return false;
        }
        var DocumentFile=$("#fileupload").val();
        var URL=$("#txtURL").val();
        if(FileType=="URL")
        {
            if(URL!="")
            {
                $('#ErrorURL').html("");
            }
            else{
                $('#ErrorURL').html("URL is required"); $("#txtURL").focus();  return false;
            }
        }
        else{
            if(DocumentFile!="")
            {
                $('#ErrorDocumentPath').html("");
            }
            else{
                $('#ErrorDocumentPath').html("File is required"); $("#fileupload").focus();  return false;
            }
        }

        var CmpId=$("#ddlCompanyname").val();
        var BusinessUnit=$("#ddlBusinessUnit").val();
        var Remark=$("#txtRemark").val();
        var URL=$("#txtURL").val();
        var PolicyId=$("#ddlPolicyID").val();
        var PolicyLiabraryId_Encrypted=$("#PolicyLiabraryId_Encrypted").val();
        $.ajax({
            url:"IsExist",
            method:"GET",
            data:{CmpId:CmpId,BusinessUnit:BusinessUnit,BusinessUnit:BusinessUnit,Remark:Remark,URL:URL,PolicyId:PolicyId,PolicyLiabraryId_Encrypted:PolicyLiabraryId_Encrypted,FileType:FileType},
            success:function(response){

                debugger;
                var Message1 = response.Message;

                var Icon1 = response.Icon;
                if (response.Icon=="error") {

                    if (Message1 != null) {

                        if (Message1 != null) {

                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#FormPolocyLiabrary").submit();

                }
            }
        });
        return false;
    });



    $("#ddlFileType").change(function(){
        var Filetype=  $("#ddlFileType").val();
        if(Filetype=="UploadFile")
        {
            $("#divURL").hide();
            $("#divUploadFile").show();
        }
        else{
            $("#divURL").show();
            $("#divUploadFile").hide();
        }

    })

</script>
