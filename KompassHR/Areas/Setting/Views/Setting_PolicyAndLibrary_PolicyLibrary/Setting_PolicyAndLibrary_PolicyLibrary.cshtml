                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PolicyLibraryBranchId, new SelectList(ViewBag.Location, "BranchId", "BranchName"), "--Select--", new { id = "ddlBusinessUnit", @class = "form-select", name = "BranchID" })
