                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Policy Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PolicyLibraryPolicyId, new SelectList(ViewBag.maspolicyList, "PolicyID", "PolicyName"), "--Select--", new { id = "ddlPolicyID", @class = "form-select", autocomplete = "off" })
                                                @Html.ValidationMessageFor(model => model.PolicyLibraryPolicyId, null, new { @class = "help-block", @id = "ErrorPolicyLibraryPolicyId", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2 mt-10px" style="display:none">
                                                <input class="form-check-input form-check-label form-check-inline"
