<script>
    $(document).ready(function () {
        $("#ddlCompanyName").select2();
        $("#ddlBusinessUnit").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null || Icon !=null ) {
            //swal("", AlreadyExist, "warning");
            if (Message != null) {
                Swal.fire({
                    //title: 'Saved',
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }


        $("#ddlCompanyName").on("change", function () {
            $("#ddlBusinessUnit").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlBusinessUnit").append("<option value=0> --Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBusinessUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        });

    });//ready function

   
   
</script>

<script>
    //use for add regex function
      jQuery.validator.addMethod(
      "regex",
       function(value, element, regexp) {
           if (regexp.constructor != RegExp)
               regexp = new RegExp(regexp);
           else if (regexp.global)
               regexp.lastIndex = 0;
           return this.optional(element) || regexp.test(value);
       },"erreur expression reguliere"
    );

      $('#SaveAttendance').validate({
        rules: {
            CmpID: {
                required: true,
            },
            BranchID:{
                    required: true,
                },
            CoffTypeName: {
                required: true,
            },
        },
        messages: {
            CmpID: {
                required: "Company name is required",
            },
            BranchID:{
                required: "Business unit is required",
            },
            CoffTypeName: {
                required: "Setting Name is required",
            },
        },
      });

      var form = $("#SaveAttendance");
      form.validate();
      $("#btnSubmit").click(function () {
          debugger;
          form.valid();
          if(form.valid()==false)
          {
              return false;
          }
          var CoffTypeName=$("#txtName").val();
          var CoffIDEncrypted=$("#CoffID_Encrypted").val();
              $.ajax({
                  url:"IsAttenCoffExists",
                  method:"get",
                  data:{CoffTypeName:CoffTypeName,CoffIDEncrypted:CoffIDEncrypted},
                  success:function(response){
                      debugger;
                      var Message1 = response.Message;
                      var Icon1 = response.Icon;
                      if (response.Icon=="error") {
                          if (Message1 != null) {
                              if (Message1 != null) {
                                  Swal.fire({
                                      icon: Icon1,
                                      text: Message1,
                                      allowOutsideClick: () => {
                                          const popup = Swal.getPopup()
                                          popup.classList.remove('swal2-show')
                                          setTimeout(() => {
                                              popup.classList.add('animate__animated', 'animate__headShake')
                                          })
                                          setTimeout(() => {
                                              popup.classList.remove('animate__animated', 'animate__headShake')
                                          }, 500)
                                          return false
                                      }
                                  });
                              }
                          }
                      }
                      else{
                          $("#SaveAttendance").submit();

                      }
                  }
              });

          });
</script>