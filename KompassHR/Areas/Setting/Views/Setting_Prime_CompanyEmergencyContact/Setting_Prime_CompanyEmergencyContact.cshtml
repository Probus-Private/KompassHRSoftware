<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/ESS/ESS_AdminDashboard_Dashboard/ESS_AdminDashboard_Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Setting/Setting_Prime_Menu/Setting_Prime_Menu">PrimeSetting Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Emergency Contact </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Emergency Contact - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>    
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        
                        
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/Setting/Setting_Prime_CompanyEmergencyContact/SaveUpdate" id="SaveEmergencyContact" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                               @Html.DropDownListFor(model => model.ContactBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { id = "ddlContactBranchId", @class = "form-select", autocomplete = "off", name = "ContactBranchId" })
                                                @Html.HiddenFor(model => model.CompanyEmergencyContactId_Encrypted,new { id= "CompanyEmergencyContactId_Encrypted" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                               Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.Type, new { @class = "form-control", type = "text", id = "txtType", autocomplete = "Off", name = "Type" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.Name, new { @class = "form-control", type = "text", id = "Name", autocomplete = "Off", name = "Name" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                               Designation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">                                                
                                                @Html.TextBoxFor(model => model.Designation, new { @class = "form-control", type = "text", id = "txtDesignation", autocomplete = "Off", name = "Designation" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                               Mobile No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", type = "text", maxlength = "10", onkeypress = "return event.charCode >=48", inputmode = "numeric", id = "txtMobileNo", name = "MobileNo" , autocomplete = "Off" })
                                            </div>
                                        </div>                                         
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                            </label>
                                            <label class="form-label col-form-label col-md-2">
                                                @Html.CheckBoxFor(model => model.IsGlobal)
                                                &nbsp;  Is Global
                                            </label>

                                        </div>                                      
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="/Setting/Setting_Prime_CompanyEmergencyContact/GetList">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetIFSCCodeList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {

        $("#formReset").click(function () {
            $("#SaveEmergencyContact")[0].reset()
        })
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });
</script>


<script>

    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveEmergencyContact").validate({
        rules: {
            ContactBranchId: {
                required: true,            
            },
            Type: {
                required: true,
            },
            Name: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
            Designation: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
            MobileNo: {
                required: true,
                regex: /^[0-9]+$/,
            },          
        },
        messages: {
            ContactBranchId: {
                required: "Business unit is required",              
            },
            Type: {
                required: "Type name  is required",
            },
            Name: {
                required: "Name is required",
                regex:"Please enter only alphabet",
            },
            Designation: {
                required: "Designation is required",
                regex:"Please enter only alphabet",
            },
            MobileNo: {
                required: "Mobile no is required",
                regex:"Please enter only number",
            },           
        }

    });

    var form = $("#SaveEmergencyContact");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var MobileNo=$("#txtMobileNo").val();
        var CompanyEmergencyContactId_Encrypted=$("#CompanyEmergencyContactId_Encrypted").val();        

        $.ajax({
            url:"IsContactExists",
            method:"get",
            data:{MobileNo:MobileNo,CompanyEmergencyContactId_Encrypted:CompanyEmergencyContactId_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveEmergencyContact").submit();

                }
            }
        });

    });
</script>

