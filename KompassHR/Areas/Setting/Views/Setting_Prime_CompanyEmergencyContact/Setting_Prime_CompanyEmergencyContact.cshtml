            }

    .featureBx {
        padding: 10px;
        display: flex;
        justify-content: center;
    }

        .featureBx .feature-Item {
            background-color: #f5f5f5;
            width: 120px;
            margin: 10px;
            padding: 10px;
            border-radius: 10px;
            border: 1px solid #fff;
