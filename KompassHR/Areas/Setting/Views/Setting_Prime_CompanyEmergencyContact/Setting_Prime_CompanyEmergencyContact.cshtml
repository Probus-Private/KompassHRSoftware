    }

        .ApplyHistory .PostedTime {
            margin: 0 5px;
            font-size: 12px;
            color: #727272;
            font-weight: 600;
        }

        .ApplyHistory .ApplyCountBx {
            color: #1676CC;
            margin: 0 5px;
            font-size: 14px;
            font-weight: 800;
        }

    .BtnBx {
        display: flex;
        justify-content: end;
    }

        .BtnBx .btn {
            /* width: 80px; */
            margin: 5px 15px;
            font-size: 15px;
        }

            .BtnBx .btn i {
                margin-right: 5px;
            }

    .JobDescription {
        margin-bottom: 20px;
        padding: 10px;
    }

        .JobDescription .Title {
            margin: 10px 0;
        }

        .JobDescription .Text {
