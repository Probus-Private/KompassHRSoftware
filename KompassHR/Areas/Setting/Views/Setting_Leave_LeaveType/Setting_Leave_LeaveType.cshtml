@model KompassHR.Areas.Setting.Models.Setting_Leave.leave_type
@{
    ViewBag.Title = "Setting_Leave_LeaveType";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Type
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Leave_Menu", "Setting_Leave_Menu", new { id = 4, ScreenId =44, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave Type <Span> - <b>@ViewBag.AddUpdateTitle</b></Span></h4>
                  
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add leave type here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form"  action='@Url.Action("SaveUpdate", "Setting_Leave_LeaveType", new { area = "Setting" })' id="SaveLeaveType" method="post" data-parsley-validate="true">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Leave Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @{
                                                    var attributes1 = new Dictionary<string, object>
                                                    {
                                                        { "class", "form-control" },
                                                        { "type", "text" },
                                                        { "id", "txtLeaveTypeName" },
                                                        { "name", "LeaveTypeName" },
                                                        { "autocomplete", "Off" }
                                                    };

                                                    if(Model.ReadOnly)
                                                    {
                                                        attributes1.Add("readonly", "readonly");
                                                        attributes1.Add("style", "background-color: #eee;");
                                                    }
                                                }
                                                @Html.TextBoxFor(model => model.LeaveTypeName, attributes1)

                                               @* @Html.TextBoxFor(model => model.LeaveTypeName, new { @class = "form-control", type = "text", id = "txtLeaveTypeName", autocomplete = "Off", name = "LeaveTypeName" })*@
                                                @Html.HiddenFor(model => model.LeaveTypeId_Encrypted,new { id= "LeaveTypeID_Encrypted" })
                                                @Html.HiddenFor(model => model.LeaveTypeId, new { id = "LeaveTypeId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Short Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @{
                                                    var attributes = new Dictionary<string, object>
                                                    {
                                                        { "class", "form-control" },
                                                        { "type", "text" },
                                                        { "id", "txtLeaveTypeShortName" },
                                                        { "name", "LeaveTypeShortName" },
                                                        { "oninput", "this.value = this.value.toUpperCase()" },
                                                        { "autocomplete", "Off" }
                                                    };

                                                    if (Model.ReadOnly)
                                                    {
                                                        attributes.Add("readonly", "readonly");
                                                        attributes.Add("style", "background-color: #eee;");
                                                    }
                                                }
                                                @Html.TextBoxFor(model => model.LeaveTypeShortName, attributes)


                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-10">
                                                @Html.CheckBoxFor(model => model.IsActive, new { name = "IsActive", id = "chkIsActive" })

                                                &nbsp;
                                                <label class="form-check-label form-label">Is Active</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Leave_LeaveType", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetLeaveTypeList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });
</script>

<script>    

    $("#formReset").click(function () {
        $("#SaveLeaveType")[0].reset();
    })
</script>



<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveLeaveType").validate({
        rules: {
            LeaveTypeName: {
                required: true,
                //regex: /^[a-zA-Z ]+$/,
            },
            LeaveTypeShortName: {
                required: true,
                //regex: /^[a-zA-Z ]+$/,              
            },
        },
        messages: {
            LeaveTypeName: {
                required: "Leave name is required",               
            },
            LeaveTypeShortName: {
                required: " Short leave name is required",             
            },
        }
    });

    var form = $("#SaveLeaveType");
    form.validate();
    $("#btnSubmit").click(function () {
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var LeaveTypeShortName=$("#txtLeaveTypeShortName").val();
        var LeaveTypeName=$("#txtLeaveTypeName").val();     
        var LeaveTypeId_Encrypted=$("#LeaveTypeID_Encrypted").val();
        var LeaveTypeId=$("#LeaveTypeId").val();
        
        $.ajax({
            url:"IsLeaveTypeExists",
            method:"get",
            data:{LeaveTypeShortName:LeaveTypeShortName,LeaveTypeName:LeaveTypeName,LeaveTypeId:LeaveTypeId,LeaveTypeId_Encrypted:LeaveTypeId_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveLeaveType").submit();

                }
            }
        });

    });
</script>



