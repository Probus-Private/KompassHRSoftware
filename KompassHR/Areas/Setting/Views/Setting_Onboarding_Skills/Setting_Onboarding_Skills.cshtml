@model KompassHR.Areas.Setting.Models.Setting_Onboarding.Mas_Skill
@{
    ViewBag.Title = "Setting_Onboarding_Skills";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Skills
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Onboarding_Menu", "Setting_Onboarding_Menu", new { id = 3, ScreenId = 19, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Skills - @ViewBag.AddUpdateTitle</h4>
                
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add skill here!
                    </p>
                </div>
                <div class="panel-body" >
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_Onboarding_Skills", new { area = "Setting" })'  id="SaveSkills" method="post">
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Department Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.SkillDepartmentID, new SelectList(ViewBag.DepartmentName, "Id", "Name"), "--Select--", new { id = "ddlSkillDepartmentID", @class = "form-select", autocomplete = "off", name = "SkillDepartmentID" })
                                                @Html.ValidationMessageFor(model => model.SkillDepartmentID, "", new { @class = "help-block", id = "ErrorSkillDepartmentID", @style = "color:red" })
                                                @Html.HiddenFor(model => model.SkillID_Encrypted)

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                            </label>
                                            <label class="form-label col-form-label col-md-6">
                                                @Html.CheckBoxFor(model => model.checkboxAll, new { id = "checkboxAll", @class = "form-checkbox" })
                                                &nbsp;   All Department
                                            </label>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Skill Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.SkillName, new { @class = "form-control", name = "SkillName", @id = "Skills", type = "text", autocomplete = "off" })
                                                @Html.HiddenFor(model => model.SkillID_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="SubmitBtn"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Onboarding_Skills", new { area = "Setting" })">
                                                                <button type="button" class="btn btn-danger" id="btnSkill">
                                                                    <i class="fa-solid fa-share-from-square"></i> List
                                                                </button>
                                                            </a>

</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger;
        $("#ddlSkillDepartmentID").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        var DepartmentId = @Html.Raw(Json.Encode(ViewBag.SkillList));
        if(DepartmentId==0)
        {
            $("#checkboxAll").prop("checked",true);
        }
        else{
            $("#checkboxAll").prop("checked",false);
        }



        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#formReset").click(function () {
            $("#SaveSkills")[0].reset();
        })
    });//ready funcation
</script>


<script>
    //use for add regex function
      jQuery.validator.addMethod(
      "regex",
       function(value, element, regexp) {
           if (regexp.constructor != RegExp)
               regexp = new RegExp(regexp);
           else if (regexp.global)
               regexp.lastIndex = 0;
           return this.optional(element) || regexp.test(value);
       },"erreur expression reguliere"
    );

      $('#SaveSkills').validate({
        rules: {
            SkillName: {
                required: true,
                //regex:/^[a-zA-Z0-9\_\-\()/,/ ]+$/
            },
            //SkillDepartmentID: {
            //    required: true,
            //    regex:/^[a-zA-Z0-9\_\-\()/,/ ]+$/
            //},
        },
        messages: {
            SkillName: {
                required: "Skill name is required",
            },
            //SkillDepartmentID: {
            //    required: "Department name is required",
            //}
        },
      });
      var form = $("#SaveSkills");
      form.validate();
      $("#SubmitBtn").click(function () {
          debugger;
          form.valid();
          if(form.valid()==false)
          {
              return false;
          }
          var Skills=$("#Skills").val();
          var SkillDepartmentID= $("#ddlSkillDepartmentID").val();
          var SkillIDEncrypted=$("#SkillID_Encrypted").val();
          //$(':checkbox:checked').each(function (i) {
          //    debugger;
          //    if(Skills!="")
          //    {

          //    }
          //});

          if ($('#checkboxAll').is(":checked")) {

              if(SkillDepartmentID=="")
              {
                  $("#ErrorSkillDepartmentID").html("");
              }
              else{
                  $("#ErrorSkillDepartmentID").html("Department name is required"); return false;
              }

          }
          else if(SkillDepartmentID==""){
              $("#ErrorSkillDepartmentID").html("Department name is required"); return false;
          }
          else{
              $("#ErrorSkillDepartmentID").html("");
          }



          //if(SkillDepartmentID=="")
          //{
          //    $("#ErrorSkillDepartmentID").html("Department name is required"); return false;
          //}
          //else
          //{
          //    $("#ErrorSkillDepartmentID").html("");
          //}


          $.ajax({
              url: '@Url.Action("IsSkillExists", "Setting_Onboarding_Skills")',
              //url:"IsSkillExists",
              method:"get",
              data:{Skills:Skills,SkillIDEncrypted:SkillIDEncrypted},
              success:function(response){
                  debugger;
                  var Message1 = response.Message;
                  var Icon1 = response.Icon;
                  if (response.Icon=="error") {
                      if (Message1 != null) {
                          if (Message1 != null) {
                              Swal.fire({
                                  icon: Icon1,
                                  text: Message1,
                                  allowOutsideClick: () => {
                                      const popup = Swal.getPopup()
                                      popup.classList.remove('swal2-show')
                                      setTimeout(() => {
                                          popup.classList.add('animate__animated', 'animate__headShake')
                                      })
                                      setTimeout(() => {
                                          popup.classList.remove('animate__animated', 'animate__headShake')
                                      }, 500)
                                      return false
                                  }
                              });
                          }
                      }
                  }
                  else{
                      $("#SaveSkills").submit();

                  }
              }
          });

      });
      $("#checkboxAll").change(function(){
          debugger;
          if ($('#checkboxAll').is(":checked")) {
              $("#ddlSkillDepartmentID").val("").select2();
          }
          else{

          }
      })
</script>