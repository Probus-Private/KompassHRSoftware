@model KompassHR.Areas.Setting.Models.Setting_Prime.Mas_Country

@{
    ViewBag.Title = "Setting_Prime_Country";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row">
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
                <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                    Country
                </h1>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Setting_Prime_Menu", "Setting_Prime_Menu", new { id = 31, ScreenId = 1, area = "Setting" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                        </a>
                    </li>
                </ol>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Country - @ViewBag.AddUpdateTitle </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add Country here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_Prime_Country", new { area = "Setting" })' id="SaveCountry" method="post" data-parsley-validate="">
                                @Html.HiddenFor(model => model.CountryId_Encrypted, new { id = "txtCountryId_Encrypted" })

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                               Country Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CountryName, new { @class = "form-control", type = "text", id = "txtCountryName", autocomplete = "Off", name = "CountryName" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Nationality
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Nationality, new { @class = "form-control", type = "text", id = "txtNationality", autocomplete = "Off", name = "Nationality" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                ISO Code
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ISOCode, new { @class = "form-control", type = "text", id = "txtISOCode", autocomplete = "Off", name = "ISOCode" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                DialCode
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DialCode, new { @class = "form-control", type = "text", id = "txtDialCode", autocomplete = "Off", name = "DialCode" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="row">
                                        <label class="form-label col-form-label col-md-4">
                                            Is Default
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-8">
                                            @Html.CheckBoxFor(model => model.IsDefault, new { name = "IsDefault", id = "chkIsDefault" })
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Prime_Country", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetContactList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#formReset").click(function () {
            $("#SaveCountry")[0].reset();
        })

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

    });
</script>

<script>
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveCountry").validate({
        rules: {
            CountryName: {
                required: true,

            },
            Nationality: {
                required: true,

            },
            ISOCode: {
                required: true,
            },
            DialCode:{
                required: true,
            }
           
        },
        messages: {
            CountryName: {
                required: "Country is required"
            },
            Nationality: {
                required: "Nationality is required"
            },
            ISOCode: {
                required: "ISO Code is required"
            },
            DialCode: {
                required: "Dial Code is required"
            }
        }
    });


    var form = $("#SaveCountry");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtEstablishedDate").removeClass('error');
            return false;
        }
        var CountryName=$("#txtCountryName").val();
        var Nationality=$("#txtNationality").val();
        var ISOCode=$("#txtISOCode").val();
        var DialCode=$("#txtDialCode").val();
        var CountryId_Encrypted=$("#txtCountryId_Encrypted").val();

        $.ajax({
            url: '@Url.Action("IsCountryExists", "Setting_Prime_Country", new { area = "Setting" })',

         //   url:"IsCountryExists",
            method:"get",

            data:{CountryId_Encrypted:CountryId_Encrypted,
                CountryName:CountryName,
                Nationality:Nationality,
                ISOCode:ISOCode,
                DialCode:DialCode
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveCountry").submit();

                }
            }
        });

    });
</script>