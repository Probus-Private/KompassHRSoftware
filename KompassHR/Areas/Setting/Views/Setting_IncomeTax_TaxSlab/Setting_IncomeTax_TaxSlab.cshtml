        padding: 5px 8px !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .lbl {
        border: none;
        outline: none;
        text-align: center;
    }

    /*.table td:nth-child(1) {
        display: none;
    }

    .table td:nth-child(2) {
        display: none;
    }*/

