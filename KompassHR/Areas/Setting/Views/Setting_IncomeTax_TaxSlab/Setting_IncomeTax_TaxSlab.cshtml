@model KompassHR.Areas.Setting.Models.Setting_IncomeTax.IncomeTax_Slab
@{
    ViewBag.Title = "Setting_IncomeTax_TaxSlab";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
