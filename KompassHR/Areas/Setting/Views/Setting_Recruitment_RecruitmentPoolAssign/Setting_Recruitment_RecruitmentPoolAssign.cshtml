@model KompassHR.Areas.Setting.Models.Setting_Recruitment.RecruitmentPoolAssign

@{
    ViewBag.Title = "Setting_Recruitment_RecruitmentPoolAssign";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Recruitment Pool Assign
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "Setting_Recruitment_RecruitmentPoolAssign", new { id =1 ,ScreenId =861, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Recruitment Pool Assign - <b>@ViewBag.AddUpdateTitle</b></h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define recruiter Pool assign here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_Recruitment_RecruitmentPoolAssign", new { area = "Setting" })' id="SaveAssign" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlCmpId", @class = "form-select", autocomplete = "off", name = "CmpName" })
                                                @Html.HiddenFor(model => model.RecruitmentPoolAssignId_Encrypted, new { id = "RecruitmentPoolAssignId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { id = "ddlBranchId", @class = "form-select", name = "BranchId" })
                                                @Html.ValidationMessageFor(model => model.BranchId, "", new { @class = "help-block", @id = "ErrorBranchId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.RecruitmentAssignEmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "--Select--", new { id = "ddlRecruitmentAssignEmployeeId", @class = "form-select", name = "RecruitmentAssignEmployeeId" })
                                                @Html.ValidationMessageFor(model => model.RecruitmentAssignEmployeeId, "", new { @class = "help-block", @id = "ErrorRecruitmentAssignEmployeeId", @style = "color:red" })
                                            </div>
                                        </div>
                                      
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Recruitment_RecruitmentPoolAssign", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetCostCenterList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        $("#ddlCmpId").on("change", function () {
            debugger
            $("#ddlBranchId").empty();
  
            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetBusinessUnit", "Setting_Recruitment_RecruitmentPoolAssign")',
                data: { CmpId: CmpId },
                success: function (data) {

                    if (data && data.Branch) {
                        $("#ddlBranchId").append("<option value=''>--Select--</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                }
            });
        });


        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlRecruitmentAssignEmployeeId").select2();
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveAssign").validate({
        rules: {
            CmpId: {
                required: true,
            },

        },
        messages: {
            CmpId: {
                required: "Campany name is required",
            },
        },
    });

    var form = $("#SaveAssign");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        var BranchId = $("#ddlBranchId").val();
        var EmployeeId=$("#ddlRecruitmentAssignEmployeeId").val();

        if(BranchId=="0")
        {$('#ErrorBranchId').html("Business unit is required"); $("#ErrorBranchId").focus();  return false;}
        else{ $('#ErrorBranchId').html("");}

        if(EmployeeId=="0")
        {$('#ErrorRecruitmentAssignEmployeeId').html("Fine/Penalty/Month is required"); $("#ErrorRecruitmentAssignEmployeeId").focus();  return false;}
        else{ $('#ErrorRecruitmentAssignEmployeeId').html("");}

        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var CmpId=$("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var RecruitmentPoolAssignId_Encrypted=$("#RecruitmentPoolAssignId_Encrypted").val();
        var RecruitmentAssignEmployeeId=$("#ddlRecruitmentAssignEmployeeId").val();
        $.ajax({
            url: '@Url.Action("IsAssignExists", "Setting_Recruitment_RecruitmentPoolAssign")',
            method:"get",
            data:{CmpId:CmpId,BranchId:BranchId,RecruitmentPoolAssignId_Encrypted:RecruitmentPoolAssignId_Encrypted,RecruitmentAssignEmployeeId:RecruitmentAssignEmployeeId},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveAssign").submit();

                }
            }
        });

    });
</script>
