                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> ESIC Contribution  <Span>-  @ViewBag.AddUpdateTitle</Span></h4>
               
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define ESIC contribution here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_Statutory_ESICContribution", new { area = "Setting" })' id="SaveStatutoryESICContribution" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                            From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", name = "FromDate", type = "date", id = "txtFromDate", autocomplete = "Off" })
                                                @Html.HiddenFor(model => model.ESICContribution_Encrypted,new {id= "ESICContribution_Encrypted" })
                                             </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                               To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", name = "ToDate", type = "date", id = "txtToDate", autocomplete = "Off", Style = "background-color: #e9ecef;", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                ESIC (Employee) % 
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.ESICEmployee, new { @class = "form-control", name = "ESICEmployee", type = "number", id = "txtESICEmployee", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                ESIC (Employer) % 
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.ESICEmployer, new { @class = "form-control", name = "ESICEmployer", type = "number", id = "txtESICEmployer", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                ESIC Limit (Rs.)
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.ESICLimit, new { @class = "form-control", name = "ESICLimit", type = "number", id = "txtESICLimit", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label style="font-weight: 800;"> Physical Handicapped </label>
                                            <label class="form-label col-form-label col-md-3">
                                                ESIC Limit (Rs.)
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.ESICLimitForPhysicalHandicapped, new { @class = "form-control", name = "ESICLimitForPhysicalHandicapped", type = "number", id = "txtESICLimitForPhysicalHandicapped", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_Statutory_ESICContribution", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetStatutoryESICCodeList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- END panel -->
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
      

        var GetToDate = @Html.Raw(Json.Encode(TempData["ToDate"]));
        var GetFromDate = @Html.Raw(Json.Encode(TempData["FromDate"]));
        if (GetFromDate==null)
        {
            const today = new Date();

            // Set the first day of the current month
            const firstDayOfCurrentMonth = new Date(today.getFullYear(), today.getMonth(), 1);

            // Format the date as 'YYYY-MM-DD'
            const formattedDate = formatToYYYYMMDD(firstDayOfCurrentMonth);

            // Set the #txtFromDate value
            $('#txtFromDate').val(formattedDate);
            $('#txtToDate').val("2999-12-31");

        }
        else{
            $('#txtFromDate').val(GetFromDate);
            $('#txtToDate').val(GetToDate);

            $('#txtFromDate').attr('readonly',true);
            $('#txtToDate').attr('readonly',true);
            $('#txtFromDate').css('background-color', '#e9ecef');
            $('#txtToDate').css('background-color', '#e9ecef');

        }

       
    });//Ready Function End


    $('#txtFromDate').on('change', function () {
        // Get the selected date from the input
        const selectedDate = new Date($(this).val());

        // Adjust the date to the first day of the selected month
        const firstDayOfMonth = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);

        // Format the adjusted date as 'YYYY-MM-DD'
        const formattedDate = formatToYYYYMMDD(firstDayOfMonth);

        // Update the value of #txtFromDate
        $(this).val(formattedDate);
    });

    // Helper function to format a Date object as 'YYYY-MM-DD'
    function formatToYYYYMMDD(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0'); // 0-based index
        const day = String(date.getDate()).padStart(2, '0'); // Always '01' here
        return `${year}-${month}-${day}`;
    }
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveStatutoryESICContribution").validate({
        rules: {
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },
            ESICEmployee: {
                required: true,
            },
            ESICEmployer: {
                required: true,
            },
            ESICLimit: {
                required: true,
            },
            ESICLimitForPhysicalHandicapped: {
                required: true,
            },
        },
        messages: {
            FromDate: {
                required: "From date is required",
            },
            ToDate: {
                required: "To date is required",
            },
            ESICEmployee: {
                required: "ESIC % (Employee) is required",
            },
            ESICEmployer: {
                required: "ESIC % (Employer) is required",
            },
            ESICLimit: {
                required: "ESIC limit  is required",
            },
            ESICLimitForPhysicalHandicapped: {
                required: "ESIC limit for physical handicapped is required",
            },
        }
    });

    var form = $("#SaveStatutoryESICContribution" );
    form.validate();
    $("#btnSubmit").click(function () {
        form.valid();
        if(form.valid()==false)
        {
            $("#txtFromDate").removeClass('error');
            $("#txtToDate").removeClass('error');
            return false;
        }
        $(".Userloaderbg").css("display", "flex");

        var ESICContribution_Encrypted=$("#ESICContribution_Encrypted").val();
        var FromDate=$("#txtFromDate").val();
        $.ajax({
            url: '@Url.Action("IsESICContributionExists", "Setting_Statutory_ESICContribution")',
            method:"get",
            data:{ESICContribution_Encrypted:ESICContribution_Encrypted,FromDate:FromDate},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $(".Userloaderbg").css("display", "flex");
                    $("#SaveStatutoryESICContribution").submit();
                }
            }
        });
       
    });
</script>

