<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>


<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Organisation Chart Hierarchy
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_OrganisationChart_Menu", "Setting_OrganisationChart_Menu", new { id =37 ,ScreenId = 529, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Organisation Chart Hierarchy - List</h4>

                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Organisation Chart Hierarchy list created.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("Setting_OrganisationChart_Level", "Setting_OrganisationChart_Level", new { area = "Setting" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="fixed-header"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="text-center">
                                                <th class="text-nowrap fixed-side">Update</th>
                                                <th class="text-nowrap fixed-side1" hidden>Delete</th>
                                                <th class="text-nowrap">Organisation Type </th>
                                                <th class="text-nowrap">Level </th>
                                                <th class="text-nowrap">Title </th>
                                                <th class="text-nowrap">Remark </th>
                                                <th class="text-nowrap">Sub Level </th>
                                                <th class="text-nowrap">Created By</th>
                                                <th class="text-nowrap">Created Date</th>
                                                <th class="text-nowrap">Modified By</th>
                                                <th class="text-nowrap">Modified Date</th>
                                                <th class="text-nowrap">Machine Name</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetOrganisationList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <i class="fa-solid fa-pen-to-square fa-lg text-Dark" onclick="UpdateOrganisationlist('@d.OrganisationChartId_Encrypted')" id="UpdateBtn" style="cursor:pointer;"></i>
                                                    </td>
                                                    <td class="text-center" hidden>
                                                        <i class="fa-solid fa-trash-alt text-danger fa-lg" onclick="DeleteOrganistionlist('@d.OrganisationChartId_Encrypted')" id="DeleteBtn" style="cursor:pointer;"></i>
                                                    </td>
                                                    <td>@d.OrganisationTypeName</td>
                                                    <td>@d.Level</td>
                                                    <td>@d.OrganisationTitle</td>
                                                    <td>@d.OrganisationRemark</td>
                                                    <td>@d.SubLevel</td>
                                                    <td>@d.CreatedBy</td>
                                                    <td>@d.CreatedDate</td>
                                                    <td>@d.ModifiedBy</td>
                                                    <td>@d.ModifiedDate</td>
                                                    <td>@d.MachineName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>


<script>

    function UpdateOrganisationlist(OrganisationChartId_Encrypted) {
        debugger;
        window.location.href = '@Url.Action("Setting_OrganisationChart_Level", "Setting_OrganisationChart_Level")?OrganisationChartId_Encrypted=' + OrganisationChartId_Encrypted;
    }

    function DeleteOrganistionlist(OrganisationChartId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_OrganisationChart_Level")?OrganisationChartId_Encrypted=' + OrganisationChartId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>




