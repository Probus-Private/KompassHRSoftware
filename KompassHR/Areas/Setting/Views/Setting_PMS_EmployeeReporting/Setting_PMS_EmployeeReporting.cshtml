    <style>
        /* SAFE: applies ONLY inside this form */
        #SaveEmpReporting .section-heading {
            font-size: 18px;
            font-weight: 700;
            color: #2c3e50;
            border-left: 4px solid #007bff;
            padding-left: 10px;
            margin-bottom: 20px;
        }

        #SaveEmpReporting .form-box {
            background: #ffffff;
            border: 1px solid #e0e0e0;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.06);
            margin-bottom: 20px;
        }

        #SaveEmpReporting label {
            font-weight: 600;
            margin-bottom: 5px;
            color: #34495e;
        }

        #SaveEmpReporting .level-row {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 6px;
            border: 1px solid #ddd;
            margin-bottom: 12px;
        }

        #SaveEmpReporting .remove-level {
            float: right;
            cursor: pointer;
            color: #c0392b;
            font-weight: bold;
        }

        #SaveTicketMatrix .btn-add {
            margin-top: 10px;
        }
    </style>


<form action="/Setting/Setting_PMS_EmployeeReporting/SaveUpdate" id="SaveEmpReporting" method="post">
    <div id="content" class="app-content">

        <div class="row mb-2">
            <div class="col-md-12 d-flex justify-content-between align-items-center">
                <h1 style="font-size: 18px;">PMS Reporting Setup</h1>

                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("GetList", "Setting_PMS_EmployeeReporting", new { id = 11, ScreenId = 833, area = "Setting" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                        </a>
                    </li>
                </ol>
            </div>
        </div>

        <div class="panel panel-inverse">
            <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                <h4 class="panel-title">PMS Manager Reporting - <b>@ViewBag.AddUpdateTitle</b></h4>
            </div>

            <div class="panel-body">

                <div class="section-heading">Employee Info</div>

                <div class="form-box">
                    <div class="row">

                        <input type="hidden" name="EmployeeId" id="hdnEmployeeId" />
                        <input type="hidden" name="PmsEmployeeReportingId" id="hdnPmsEmployeeReportingId" />
                        <input type="hidden" name="PmsEmployeeReportingId_Encrypted" id="hdnPmsEmployeeReportingId_Encrypted" />

                        <div class="col-md-4">
                            <label>Employee</label>
                            <select class="form-control" id="ddlEmployee" name="EmployeeId">
                                <option value="">-- Select Employee --</option>
                                @foreach (var emp in ViewBag.getEmployeeID)
                                {
                                    <option value="@emp.Id">@emp.Name</option>
                                }
                            </select>

                            <span id="empError" class="text-danger" style="font-size:12px; display:none;">
                                Please select an Employee
                            </span>
                        </div>

                        <div class="col-md-4">
                            <label>Company Name</label>
                            <input type="text" id="CmpName" class="form-control" readonly />

                        </div>

                        <div class="col-md-4">
                            <label>Branch Name</label>
                            <input type="text" id="BranchName" class="form-control" readonly />
                           
                        </div>

                        <div class="col-md-4 mt-3">
                            <label>Employee No</label>
                            <input type="text" id="empNo" class="form-control" readonly />
                        </div>

                        <div class="col-md-4 mt-3">
                            <label>Department</label>
                            <input type="text" id="empDept" class="form-control" readonly />
                        </div>

                        <div class="col-md-4 mt-3">
                            <label>Designation</label>
                            <input type="text" id="empDesg" class="form-control" readonly />
                        </div>

                    </div>
                </div>


                <div class="section-heading">Reporting Levels</div>

                <div id="levelsContainer">
                    <!-- LEVEL 1 DEFAULT -->
                    <div class="level-row">
                        <span class="remove-level d-none">X</span>

                        <div class="row">
                            <div class="col-md-4">
                                <label>Level</label>
                                <input type="text" class="form-control" value="Level 1" readonly />
                            </div>

                            <div class="col-md-8">
                                <label>Select Manager</label>
                                <select class="form-control manager-select" name="ManagerLevels">
                                    <option value="">-- Select Manager --</option>
                                    @foreach (var mgr in ViewBag.getEmployeeID)
                                    {
                                        <option value="@mgr.Id">@mgr.Name</option>
                                    }
                                </select>

                                <!-- 🔴 Inline Validation for Level 1 -->
                                <span id="lvl1Error" class="text-danger" style="font-size:12px; display:none;">
                                    Please select Level 1 Manager
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hidden target fields -->
                <input type="hidden" name="ReportingManagerId1" id="R1" />
                <input type="hidden" name="ReportingManagerId2" id="R2" />
                <input type="hidden" name="ReportingManagerId3" id="R3" />
                <input type="hidden" name="ReportingManagerId4" id="R4" />

                <button type="button" class="btn btn-primary btn-sm mt-2" id="btnAddLevel">+ Add Level</button>

                <div class="text-end mt-4">
                    <button type="button" class="btn btn-primary btn-sm" id="btnSubmit">
                        <i class="fa-solid fa-floppy-disk"></i> Submit
                    </button>

                    <a href="@Url.Action("GetList", "Setting_PMS_EmployeeReporting", new { area = "Setting" })" class="btn btn-danger btn-sm">
                        <i class="fa-solid fa-share-from-square"></i> List
                    </a>
                </div>

            </div>
        </div>
    </div>
</form>


    <script>

        $(document).ready(function () {
            var Message = @Html.Raw(Json.Encode(TempData["Message"]));
            var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
            debugger;
            if (Message != null) {
                if (Icon != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            // return false
                        }
                    }).then(function() {
                        window.location.reload();
                    });
                }
            }

            $(".manager-select").select2();
            $("#ddlEmployee").select2();

            $("#ddlEmployee").change(function () {
                debugger
                let empId = $(this).val();

                if (empId === "") {
                    $("#empError").show();
                    return;
                } else {
                    $("#empError").hide();
                }

                $.ajax({
                    url: "/Setting/Setting_PMS_EmployeeReporting/GetEmployeeDetails",
                    type: "GET",
                    data: { EmpId: empId },
                    success: function (data) {
                        debugger
                        if (data) {
                            // 🔥 Convert Key-Value array → Normal object
                            let emp = convertKeyValueArray(data);

                            $("#hdnEmployeeId").val(emp.EmployeeId || "");
                            $("#CmpName").val(emp.CompanyName || "");
                            $("#BranchName").val(emp.BranchName || "");
                            $("#empNo").val(emp.EmployeeNo || "");
                            $("#empDept").val(emp.DepartmentName || "");
                            $("#empDesg").val(emp.DesignationName || "");
                        }
                    }
                });
            });

            debugger
            var editDataRaw = @Html.Raw(Json.Encode(ViewBag.GetApprover));
            var editData = editDataRaw ? convertKeyValueArray(editDataRaw) : null;
            if (editData) {

                $("#hdnPmsEmployeeReportingId").val(editData.PmsEmployeeReportingId || "");
                $("#hdnPmsEmployeeReportingId_Encrypted").val(editData.PmsEmployeeReportingId_Encrypted || "");
                $("#ddlEmployee").val(editData.EmployeeId).trigger("change");
                $("#ddlEmployee").prop("disabled", true);
        // 1️⃣ Set employee dropdown & lock
                $("#ddlEmployee").val(editData.EmployeeId).prop("disabled", true);
                $("#hdnEmployeeId").val(editData.EmployeeId); 

        // 2️⃣ Populate employee info
        $("#CmpName").val(editData.CompanyName || "");
        $("#BranchName").val(editData.BranchName || "");
        $("#empNo").val(editData.EmployeeNo || "");
        $("#empDept").val(editData.DepartmentName || "");
        $("#empDesg").val(editData.DesignationName || "");

        // 3️⃣ Clear default Level 1
        $("#levelsContainer").empty();

        // 4️⃣ Populate manager levels
        let mgrs = [
            editData.ReportingManagerId1,
            editData.ReportingManagerId2,
            editData.ReportingManagerId3,
            editData.ReportingManagerId4
        ].filter(x => x != null && x != 0);

        for (let i = 0; i < mgrs.length; i++) {
            let levelNum = i + 1;

            let html = `
            <div class="level-row">
                ${levelNum === 1 ? '<span class="remove-level d-none"></span>' : '<span class="remove-level" onclick="removeLevel(this)">X</span>'}
                <div class="row">
                    <div class="col-md-4">
                        <label>Level</label>
                        <input type="text" class="form-control" value="Level ${levelNum}" readonly />
                    </div>
                    <div class="col-md-8">
                        <label>Select Manager</label>
                        <select class="form-control manager-select" name="ManagerLevels">
                            <option value="">-- Select Manager --</option>
                            @foreach (var mgr in ViewBag.getEmployeeID)
                            {
                                <option value="@mgr.Id">@mgr.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            `;

            $("#levelsContainer").append(html);

            // Set selected manager
            $("#levelsContainer .level-row").eq(i).find("select").val(mgrs[i]).trigger("change");
        }

        $(".manager-select").select2();
    }


        });

        let lvl = 1;

$("#btnAddLevel").click(function () {

    if (lvl >= 4) {
        Swal.fire({
            icon: "warning",
            text: "Maximum 4 reporting levels allowed!"
        });
        return;
    }

    lvl++;

    let html = `
        <div class="level-row">
            <span class="remove-level" onclick="removeLevel(this)">X</span>

            <div class="row">
                <div class="col-md-4">
                    <label>Level</label>
                    <input type="text" class="form-control" value="Level ${lvl}" readonly />
                </div>

                <div class="col-md-8">
                    <label>Select Manager</label>
                    <select class="form-control manager-select" name="ManagerLevels">
                        <option value="">-- Select Manager --</option>
                        @foreach (var mgr in ViewBag.getEmployeeID)
                        {
                            <option value="@mgr.Id">@mgr.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>`;

    $("#levelsContainer").append(html);

    // ⭐ Re-apply Select2 for newly added dropdown
    $(".manager-select").last().select2();
});



        function removeLevel(e) {
            $(e).closest(".level-row").remove();

            // Recalculate level count
            lvl = $("#levelsContainer .level-row").length;

            // Renumber displayed labels
            $("#levelsContainer .level-row").each(function (i) {
                $(this).find("input[type='text']").val("Level " + (i + 1));
            });
        }


        $("#btnSubmit").click(function () {
            let managers = [];

            // Collect selected managers
            $("#levelsContainer .level-row").each(function () {
                let mgr = $(this).find("select").val();
                managers.push(mgr);
            });

            let empId = $("#ddlEmployee").val() || $("#hdnEmployeeId").val();
            $("#hdnEmployeeId").val(empId);
            var PmsEmployeeReportingId_Encrypted= $("#hdnPmsEmployeeReportingId_Encrypted").val();

            if (!empId) {
                $("#empError").show();
                return;
            } else {
                $("#empError").hide();
            }
           
            // Level 1 validation
            if (!managers[0] || managers[0] === "") {
                $("#lvl1Error").show();
                return;
            } else {
                $("#lvl1Error").hide();
            }

            // Get EmployeeId
            

            // Call server-side validation before submit
            $.ajax({
                url: '/Setting/Setting_PMS_EmployeeReporting/IsValidation',
                type: 'GET',
                data: { EmployeeId: empId,PmsEmployeeReportingId_Encrypted:PmsEmployeeReportingId_Encrypted },
                success: function (res) {
                    if (res === true) {
                        // Validation passed — map managers to hidden fields
                        $("#R1").val(managers[0] || "");
                        $("#R2").val(managers[1] || "");
                        $("#R3").val(managers[2] || "");
                        $("#R4").val(managers[3] || "");

                        // Submit the form
                        $("#SaveEmpReporting").submit();
                    } else {
                        // Show server validation message
                        Swal.fire({
                            icon: res.Icon || 'warning',
                            text: res.Message || 'Validation failed!'
                        });
                    }
                },
                error: function (err) {
                    Swal.fire({
                        icon: 'error',
                        text: 'Server error! Please try again.'
                    });
                }
            });
        });

        function convertKeyValueArray(arr) {
            let obj = {};
            arr.forEach(x => {
                obj[x.Key] = x.Value;
            });
            return obj;
        }
        $("#ddlEmployee").change(function () {
            let empId = $(this).val();
            $("#hdnEmployeeId").val(empId);
        });
    </script>