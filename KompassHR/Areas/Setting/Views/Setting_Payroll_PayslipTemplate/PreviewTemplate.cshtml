
@{
    ViewBag.Title = "PreviewTemplate";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />




<style>
    body {
        background-color: #f4f6f9;
    }

    .preview-wrapper {
        max-width: 1000px;   /* increased */
    margin: 40px auto;
    }

    .preview-card {
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        padding: 40px;
    }

    .preview-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .preview-title {
        font-weight: 600;
        font-size: 18px;
        color: #444;
    }

    .btn-close-preview {
        background-color: #dc3545;
        color: #fff;
        border: none;
        padding: 6px 14px;
        border-radius: 6px;
        font-size: 13px;
    }

        .btn-close-preview:hover {
            background-color: #bb2d3b;
        }

    /* Preview paper box only */
    .template-content {
        border: 1px dashed #ddd;
        padding: 20px;
        border-radius: 8px;
        background: #fff;
        max-width: 100%;
    }

    .template-content * {
    max-width: 100%;
    box-sizing: border-box;
}

    .template-content table {
    width: 100% !important;
}
</style>

<div id="content" class="app-content">

    <!-- Page Header -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">

            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Payslip Template
            </h1>

            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Payroll_PayslipTemplate", "Setting_Payroll_PayslipTemplate", new { id = 6, ScreenId = 911, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>

        </div>
    </div>

    <!-- Panel -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <!-- Panel Header -->
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Payslip Template</h4>
                </div>
                <!-- Panel Body -->
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="preview-wrapper">
                                <div class="preview-card">
                                    <!-- Preview Header -->
                                    <div class="preview-header">
                                        <div class="preview-title">
                                            Payslip Template Preview
                                        </div>
                                        @* Optional Close Button *@
                                        @*
                                            <button onclick="window.close()" class="btn-close-preview">
                                                Close
                                            </button>
                                        *@
                                    </div>
                                    <!-- Template Render Area -->
                                    <div class="template-content">
                                        @if (ViewBag.TemplateHtml != null)
                                        {
                                            @Html.Raw(ViewBag.TemplateHtml)
                                        }
                                        else
                                        {
                                            <div style="text-align:center; padding:40px; color:#999;">
                                                No Template Found
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>