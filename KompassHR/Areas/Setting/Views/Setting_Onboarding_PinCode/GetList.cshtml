@model KompassHR.Areas.Setting.Models.Setting_Onboarding.Mas_PinCode
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    th:nth-child(1), td:nth-child(1) {
        width: 40px; /* Set the width for the first column */
    }
    th:nth-child(2), td:nth-child(2) {
        width: 40px; /* Set the width for the first column */
    }
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Pincode
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_Onboarding_Menu", "Setting_Onboarding_Menu", new { id = 3, ScreenId = 19, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Pincode - List</h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of pincode created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("GetList", "Setting_Onboarding_PinCode", new { area = "Setting" })' id="SaveAddressInformation" method="post">
                        <div class="row">
                            <div class="col-md-1">
                                <a href="@Url.Action("Setting_Onboarding_PinCode", "Setting_Onboarding_PinCode", new { area = "Setting" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                            </div>
                            <div class="col-md-4">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        District/PIN
                                    </label>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(model => model.SearchType, new List<SelectListItem>{
                                                                new SelectListItem {Text ="District", Value="1"},
                                                                new SelectListItem {Text ="PIN", Value="2"},},
                                        new { @class = "form-select", id = "ddlDistPin", type = "text", name = "ddlDistPin", autocomplete = "Off" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Search
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.TextBoxFor(model => model.DistrictName, new { id = "txtDistrictName", @class = "form-control", autocomplete = "off", name = "DistrictName", Placeholder= "Enter District Name" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="button" id="btnShow" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-eye"></i> &nbsp; show
                                </button>
                            </div>
                        </div>
                    </form>

                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered align-middle TablePage TablePage" id="data-table-combine"
                                   style="width: 100%;">
                                <thead style="background-color:#eee">
                                    <tr class="text-center">
                                        <th class="text-nowrap width-45"> Update</th>
                                        <th class="text-nowrap width-45"> Delete</th>
                                        <th class="text-nowrap">PinCode</th>
                                        <th class="text-nowrap">State</th>
                                        <th class="text-nowrap">District</th>
                                        <th class="text-nowrap">Taluka</th>
                                        <th class="text-nowrap">Office</th>
                                    </tr>
                                </thead>
                                <tbody id="tblPincodeList">
                                    @foreach (var d in ViewBag.EmployeeType)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <a onclick="UpdatePinCode('@d.PinId_Encrypted')" id="btnUpdate"
                                                   style="cursor:pointer">
                                                    <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <a onclick="DeletePinCode('@d.PinId_Encrypted')" id="btnDelete"
                                                   style="cursor:pointer">
                                                    <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                </a>
                                            </td>
                                            <td>@d.PinCode</td>
                                            <td>@d.StateName</td>
                                            <td>@d.DistrictName</td>
                                            <td>@d.TalukaName</td>
                                            <td>@d.OfficeName</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <!-- BEGIN table-responsive -->
        </div>
    </div>
    <!-- END panel -->
</div>

<script>
    $(document).ready(function () {
        $('title').html("PinCode");
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>

<script>

    function UpdatePinCode(PinId_Encrypted) {
        window.location.href = '@Url.Action("Setting_Onboarding_PinCode", "Setting_Onboarding_PinCode")?PinId_Encrypted=' + PinId_Encrypted;

    }

    function DeletePinCode(PinId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_Onboarding_PinCode")?PinId_Encrypted=' + PinId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveAddressInformation').validate({
        rules: {
            DistrictName: {
                required: true,
            },

        },
        messages: {
            DistrictName: {
                required: "District name is required",
            },

        }
    });


    var form = $("#SaveAddressInformation");
    form.validate();
    $("#btnShow").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#SaveAddressInformation").submit();
    });
</script>

<script>
    $('#ddlDistPin').change(function () {
        let text = $(this).val() === "1" ? "Enter District Name" : "Enter PIN Code";
        $('#txtDistrictName').attr('placeholder', text);
    });
</script>
