        var array = $('.chk:checked').map(function(){
            return this.value;
        }).get();

        var LWFStateCode = $('#ddlLWFStateCode option:selected').text();
        var LowerLimit = $('#txtLowerLimit').val();
        var GetRemark = $('#txtRemark').val();
        var UpperLimit = $('#txtUpperLimit').val();
        var LWFEmployee = $('#txtLWFEmployee').val();
        var LWFEmployer = $('#txtLWFEmployer').val();

        if(LWFStateCode=="--Select--")
        {$('#ErrorLWFStateCode').html("State name is required");   return false;}
        else{ $('#ErrorLWFStateCode').html("");}

        if(LowerLimit=="")
        {$('#ErrorLowerLimit').html("Lower limit is required");   return false;}
        else{ $('#ErrorLowerLimit').html("");}

        if(GetRemark=="")
        {$('#ErrorRemark').html("Remark is required");   return false;}
        else{ $('#ErrorRemark').html("");}

        if(UpperLimit=="")
        {$('#ErrorUpperLimit').html("Upper limit is required");   return false;}
        else{ $('#ErrorUpperLimit').html("");}

        if(LWFEmployee=="")
        {$('#ErrorLWFEmployee').html("LWF employee is required");   return false;}
        else{ $('#ErrorPTAmount').html("");}

        if(LWFEmployer=="")
        {$('#ErrorLWFEmployer').html("LWF employer is required");   return false;}
        else{ $('#ErrorLWFEmployer').html("");}

        if ($('#chkLWFDeductionMonth1').is(":checked") ||$('#chkLWFDeductionMonth2').is(":checked") || $('#chkLWFDeductionMonth3').is(":checked") || $('#chkLWFDeductionMonth4').is(":checked") || $('#chkLWFDeductionMonth5').is(":checked") || $('#chkLWFDeductionMonth6').is(":checked") || $('#chkLWFDeductionMonth7').is(":checked") || $('#chkLWFDeductionMonth8').is(":checked") || $('#chkLWFDeductionMonth9').is(":checked") || $('#chkLWFDeductionMonth10').is(":checked") ||$('#chkLWFDeductionMonth11').is(":checked") || $('#chkLWFDeductionMonth12').is(":checked") )
        {
            $('#ErrorLWFDeductionMonth').html("");
        }
        else{
            $('#ErrorLWFDeductionMonth').html("Please select atleast one checkbox");   return false;}

        //for upper limit is always greater
        var sum= 0;
        var IncomeTotal=Number( $('#txtUpperLimit').val());
        var sum = IncomeTotal+1;

        //to add row into list
        e.preventDefault();
        var LWFtateCodeText = $('#ddlLWFStateCode option:selected').text();
        var LowerLimit = $('#txtLowerLimit').val();
        var UpperLimit = $('#txtUpperLimit').val();
        var LWFEmployee = $('#txtLWFEmployee').val();
        var LWFEmployer = $('#txtLWFEmployer').val();
        //var LWFDeductionMonth = $('#chkLWFDeductionMonth').val(b);

        var table = document.getElementById("tblLWFSlab");
        var rowCount = table.rows.length;
        var row = table.insertRow(rowCount);
        var count = $('#tblLWFSlab tr').length;

        row.insertCell(0).innerHTML = "" + LWFtateCodeText + "";
        row.insertCell(1).innerHTML = "" + LowerLimit + "";
        row.insertCell(2).innerHTML = "" + UpperLimit + "";
        row.insertCell(3).innerHTML = "" + LWFEmployee + "";
        row.insertCell(4).innerHTML = "" + LWFEmployer + "";

        $('#txtLowerLimit').val(''),
        $('#txtUpperLimit').val(''),
        $('#txtLWFEmployee').val(''),
        $('#txtLWFEmployer').val('');
        $('#chkLWFDeductionMonth').val('');
        $('#txtLowerLimit').val(sum);

        debugger;
        var count1 = $('#tblLWFSlab tr').length;
        if (count1!="" ) {
            $("#ddlLWFStateCode").attr("disabled", "disabled");
            $('#ddlLWFStateCode').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
            //document.querySelector('#ddlLWFStateCode').style.backgroundColor = '#e9ecef';
            $("#txtLowerLimit").attr("disabled", "disabled");
            $(".chk").attr("disabled", "disabled");
            $("#txtRemark").attr("disabled", "disabled");
        }
        else
        {
            $("#ddlLWFStateCode").removeAttr("disabled");
            $("#txtLowerLimit").removeAttr("disabled");
            $(".chk").removeAttr("disabled");
            $("#txtRemark").removeAttr("disabled");
        }
    });
    //<<-------------------------------------Add Row To Inner html-------------------------------------------------->>

    //<<--------------------------------------------Delete The Row Of Inner HTML------------------------------------------------>>

    $("#btnDeleteRow").click(function () {
        debugger;
        var table = document.getElementById("tblLWFSlab");
        var rowCount = table.rows.length;
        table.deleteRow(rowCount -1);
        $(".chk").removeAttr("disabled");
        var LowerLast= $('#tblLWFSlab').find('tr').last();
        if(LowerLast.length!=0){
            var LowerLastCell= LowerLast[0].cells;
            var LowerLastCellHTML= LowerLastCell[2].innerHTML;
            var LowerLimit = LowerLastCellHTML
            $("#txtLowerLimit").val(LowerLimit);

            var sum= 0;
            var LowerTotal=Number( $('#txtLowerLimit').val());
            var sum = (LowerTotal+1);
            $("#txtLowerLimit").val(sum);
        }

        var table = document.getElementById("tblLWFSlab");
        var rowCount = table.rows.length;
        if (rowCount==0)
        {
            $("#ddlLWFStateCode").removeAttr("disabled");
            $("#txtLowerLimit").removeAttr("disabled");
            $("#txtRemark").removeAttr("disabled");
            $('#ddlLWFStateCode').next('.select2').find('.select2-selection').css('background-color', '');

            $("#txtLowerLimit").val("");

        }


    });
    //<<--------------------------------------------Delete The Row Of Inner HTML------------------------------------------------>>
</script>

