<script>
    //<<-----------------------------------Ready function Start----------------------------------------->>
    $(document).ready(function () {
        $("#ddlLWFStateCode").select2();
        var payroll_lwfslabget =@Html.Raw(Json.Encode(ViewBag.LWFSlabLimit));
        debugger;
        if(payroll_lwfslabget!=null)
        {
            for(var i=0;i <= payroll_lwfslabget.length-1;i++)
            {
                var table = document.getElementById("tblLWFSlab");
                var rowCount = table.rows.length;
                var row = table.insertRow(rowCount);
                var count = $('#tblLWFSlab tr').length;

                row.insertCell(0).innerHTML = "" + payroll_lwfslabget[i][0].Value + "";
                row.insertCell(1).innerHTML = "" + payroll_lwfslabget[i][1].Value + "";
                row.insertCell(2).innerHTML = "" + payroll_lwfslabget[i][2].Value + "";
                row.insertCell(3).innerHTML = "" + payroll_lwfslabget[i][3].Value + "";
                row.insertCell(4).innerHTML = "" + payroll_lwfslabget[i][4].Value + "";
            }
        }
        debugger;
        var count1 = $('#tblLWFSlab tr').length;
        if (count1!="" ) {
            $("#ddlLWFStateCode").attr("disabled", "disabled");
            $('#ddlLWFStateCode').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
            $("#txtLowerLimit").attr("disabled", "disabled");
            //$(".chk").attr("disabled", "disabled");
            $("#txtRemark").attr("disabled", "disabled");
        }
        else
        {
            $("#ddlLWFStateCode").removeAttr("disabled");
            $("#txtLowerLimit").removeAttr("disabled");
            //$(".chk").removeAttr("disabled");
            $("#txtRemark").removeAttr("disabled");
        }

        debugger;
        var LowerLast= $('#tblLWFSlab').find('tr').last();
        if(LowerLast.length!=0){
            var LowerLastCell= LowerLast[0].cells;
            var LowerLastCellHTML= LowerLastCell[2].innerHTML;
            var LowerLimit = LowerLastCellHTML
            $("#txtLowerLimit").val(LowerLimit);

            var sum= 0;
            var LowerTotal=Number( $('#txtLowerLimit').val());
            var sum = (LowerTotal+1);
            $("#txtLowerLimit").val(sum);
        }

        var LWFSlabMonth = @Html.Raw(Json.Encode(ViewBag.LWFSlabMonth));

        // Iterate through the LWFSlabMonth array and set the checkboxes
        LWFSlabMonth.forEach(function (slab) {
            // Construct the checkbox ID dynamically
            var checkboxId = "#chkLWFDeductionMonth" + slab.LWFSlab_Month;

            // Check the checkbox if IsApplicable is true
            if (slab.IsApplicable) {
                $(checkboxId).prop("checked", true);
            } else {
                $(checkboxId).prop("checked", false);
            }
        });
    });


    //<<-------------------------------------Ready function end-------------------------------------------------->>



    $("#btnSubmit").click(function () {
        debugger;
        var LWFSlabMasterId_Encrypted= $("#LWFSlabMasterId_Encrypted").val();
        var StateCode=$("#ddlLWFStateCode").val();
        var Remark=$("#txtRemark").val();
        $(".Userloaderbg").css("display", "flex");

        $.ajax({
            url: '@Url.Action("IsLWFSlabExists", "Setting_Statutory_LWFSlab")',
            method:"get",
            data: { LWFSlabMasterId_Encrypted: LWFSlabMasterId_Encrypted,StateCode:StateCode,Remark:Remark },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }

                else{
                    var LWFSlabMasterId_Encrypted= $("#LWFSlabMasterId_Encrypted").val();
                    var StateCode=$("#ddlLWFStateCode").val();
                    var Remark=$("#txtRemark").val();
                    var LWFSlabMasterId=$("#LWFSlabMasterId").val();
                    var table = document.getElementById("tblLWFSlab");
                    var rowCount = table.rows.length;
                    var Task = new Array();
                    var data = {};
                    for (i = 0; i <= rowCount-1; i++) {
                        var data = {};
                        data.LowerLimit = table.rows[i].cells[1].innerHTML;
                        data.UpperLimit = table.rows[i].cells[2].innerHTML;
                        data.LWFEmployee = table.rows[i].cells[3].innerHTML;
                        data.LWFEmployer = table.rows[i].cells[4].innerHTML;
                        Task.push(data);
                    }

                    var table = document.getElementById("tblLWFMonth");
                    var Record = [];

                    // Loop through all rows in the table
                    $("#tblLWFMonth tbody tr").each(function () { // Target only tbody rows
                        var LWFMonth = {};
                        var currentRow = $(this);
                        var checkbox = currentRow.find(':checkbox');

                        if (checkbox.length > 0) { // Ensure there is a checkbox in the row
                            LWFMonth.LWFSlab_Month = checkbox.val(); // Get the value of the checkbox
                            LWFMonth.IsApplicable = checkbox.prop('checked') ? "true" : "false"; // Set IsApplicable based on checkbox state
                            Record.push(LWFMonth);
                        }
                    });
                    $(".Userloaderbg").css("display", "flex");
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("SaveUpdate", "Setting_Statutory_LWFSlab")',
                        data: JSON.stringify({Task: Task,StateCode: StateCode, Remark: Remark,LWFSlabMasterId_Encrypted:LWFSlabMasterId_Encrypted,Record:Record,LWFSlabMasterId:LWFSlabMasterId}),
                        contentType: "application/json; charset=utf-8",
                        dataType: "text",
                        success: function (response)
                        {
                            debugger;
                            var data =  JSON.parse(response);
                            var Message1 = data.Message;
                            var Icon1 = data.Icon;
                            if (data !=null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("Setting_Statutory_LWFSlab", "Setting_Statutory_LWFSlab")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })
                                }
                                // location.reload();
                            }
                        }
                    });
                }
            }

        });
    });


</script>

