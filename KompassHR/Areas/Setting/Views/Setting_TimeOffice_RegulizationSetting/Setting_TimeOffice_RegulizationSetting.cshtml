@model KompassHR.Areas.Setting.Models.Setting_TimeOffice.Atten_RegulizationSetting

@{
    ViewBag.Title = "Setting_TimeOffice_RegulizationSetting";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .select2.select2-container {
        width: 100% !important;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
               Regulization Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "Setting_TimeOffice_RegulizationSetting", new {id = 5, ScreenId=864, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <!-- END breadcrumb -->


    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Regulization Setting - <b>@ViewBag.AddUpdateTitle</b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Fill in below form for Attendance Regulization Setting here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_TimeOffice_RegulizationSetting", new { area = "Setting" })' id="FormRegulizationSetting" method="post" enctype="multipart/form-data">
                                
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                          For Regulization
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                               From Time
                                                <span class="important">*</span>
                                            </label>
                                           
                                            <div class="col-md-8">
                                                @Html.HiddenFor(model => model.RegulizationSettingId_Encrypted, new { @class = "form-control", id = "RegulizationSettingId_Encrypted" })

                                                @Html.TextBoxFor(model => model.FromTime,
                                                new
                                                {
                                                    @class = "form-control",
                                                    type = "time",
                                                    id = "txtFromTime",
                                                    name= "FromTime",
                                                    //value = Model.FromTime.HasValue ? Model.FromTime.Value.ToString(@"hh\:mm") : ""
                                                })
                                            </div>

                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                To Time
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToTime,
                                                new
                                                {
                                                    @class = "form-control",
                                                    type = "time",
                                                    id = "txtToTime",
                                                    name="ToTime",
                                                    //value = Model.ToTime.HasValue ? Model.ToTime.Value.ToString(@"hh\:mm") : ""
                                                })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Type 
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Type,
                                                  new List<SelectListItem>
                                                  {
                                                new SelectListItem { Text = "First Punch-Last Punch", Value = "FirstPunch-LastPunch" },
                                                new SelectListItem { Text = "First In-Last Out", Value = "FirstIn-LastOut" }

                                                 },
                                               "Select", new { @class = "form-control", name = "Type", id = "ddlType" })
                                            </div>
                                        </div>
                                    </div>
                                    </div>


                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                                            </button>

                                                            <a href="@Url.Action("GetList", "Setting_TimeOffice_RegulizationSetting", new { area = "Setting" })">
                                                                <button type="button" class="btn btn-danger btn-sm" id="btnTrainingAgency">
                                                                    <i class="fa-solid fa-share-from-square"></i> List
                                                                </button>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                             </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>




<script>
    $(document).ready(function () {
        debugger
       
        @*var Time = @Html.Raw(Json.Encode(TempData["Time"]));
        if (Time) {
            document.getElementById('txttime').value = Time;
        }*@

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false // Disable outside clicks
            }).then(() => {
                window.location.reload();
            });
        }

    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function (value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   }, "erreur expression reguliere"
);

    $("#FormRegulizationSetting").validate({
        rules: {
            FromTime: {
                required: true,
            },
            ToTime: {
                required: true,
            },
            Type: {
                required: true,
            },
           
        },
        messages: {
            FromTime: {
                required: "From Time is required",
            },
            ToTime: {
                required: "To Time is required",
            },
            Type: {
                required: "Type is required",
            },
          
        }
    });

    var form = $("#FormRegulizationSetting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
        }
       

        var FromTime = $("#txtFromTime").val();
        var RegulizationSettingId_Encrypted = $("#RegulizationSettingId_Encrypted").val();
        var ToTime = $("#txtToTime").val();
        var Type = $("#ddlType").val();
       
        $.ajax({
            url: '@Url.Action("IsRegulizationExists", "Setting_TimeOffice_RegulizationSetting")',
            method: "Get",
            data: {
                RegulizationSettingId_Encrypted:RegulizationSettingId_Encrypted,
                FromTime:FromTime,
                ToTime: ToTime,
                Type:Type,
             
            },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon === "error" && Message1)
                {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup();
                            popup.classList.remove('swal2-show');
                            setTimeout(() => popup.classList.add('animate__animated', 'animate__headShake'), 0);
                            setTimeout(() => popup.classList.remove('animate__animated', 'animate__headShake'), 500);
                            return false;
                        }
                    });
                }
                else {
                    $("#FormRegulizationSetting").submit();
                }
            }
        });
    });

    var form = $("#FormRegulizationSetting");
    form.validate();

    //$(document).on('input', '#txtBasic', function () {
    //    this.value = this.value.replace(/[^0-9.]/g, '');
    //    if (this.value === "0") {
    //        ("#errorBasic").text="Basic not allowed 0";
    //        this.value = "";
    //    }
    //});

    //$(document).on('input', '#txtDA', function () {
    //    this.value = this.value.replace(/[^0-9.]/g, '');
    //});
</script>