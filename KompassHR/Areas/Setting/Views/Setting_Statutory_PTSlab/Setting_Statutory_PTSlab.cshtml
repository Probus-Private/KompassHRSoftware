<script>
    //Ready Function Start
    $(document).ready(function () {
        $("#ddlPTStateCode").select2();
        $("#ddlPTSlabMonth").select2();
        $("#ddlPTDeductionType").select2();
        
        //BtnSubmit
        //To Get List In Inner HTML
        var payroll_ptslabget =@Html.Raw(Json.Encode(ViewBag.PTSlab_Master));
        debugger;

        if(payroll_ptslabget!=null)
        {
            var a=payroll_ptslabget[0][8].Value;
            $("#ddlPTSlabMonth").val(a).select2();
            //if (a=="0")
            //{
            //    $("#ddlPTSlabMonth").val(null).select2();
            //}
            //else{
            //
            //}

            for(var i=0;i <= payroll_ptslabget.length-1;i++)
            {
                var table = document.getElementById("tblPTSlabs");
                var rowCount = table.rows.length;
                var row = table.insertRow(rowCount);
                var count = $('#tblPTSlabs tr').length;

                row.insertCell(0).innerHTML = "" + payroll_ptslabget[i][0].Value + "";
                row.insertCell(1).innerHTML = "" + payroll_ptslabget[i][1].Value + "";
                row.insertCell(2).innerHTML = "" + payroll_ptslabget[i][2].Value + "";
                row.insertCell(3).innerHTML = "" + payroll_ptslabget[i][3].Value + "";
                row.insertCell(4).innerHTML = "" + payroll_ptslabget[i][4].Value + "";
                row.insertCell(5).innerHTML = "" + payroll_ptslabget[i][5].Value + "";
                row.insertCell(6).innerHTML = "" + payroll_ptslabget[i][7].Value + "";
                row.insertCell(7).innerHTML = "" + payroll_ptslabget[i][6].Value + "";
            }
        }

        //validation for dropdown
        var PTStateCode = $('#ddlPTStateCode option:selected').val();
        debugger;
        var count1 = $('#tblPTSlabs tr').length;
        if (count1!=0 ) {
            $("#ddlPTStateCode").attr("disabled", "disabled");
            $('#ddlPTStateCode').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
            $("#txtLowerLimit").attr("disabled", "disabled");
            $("#ddlPTDeductionType").attr("disabled", "disabled");
            $('#ddlPTDeductionType').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
            $("#txtRemark").attr("disabled", "disabled");
            $("#ddlPTSlabMonth").attr("disabled", "disabled");
            $('#ddlPTSlabMonth').next('.select2').find('.select2-selection').css('background-color', '#e9ecef');
        }
        else
        {
            $("#ddlPTStateCode").removeAttr("disabled");
            $("#txtLowerLimit").removeAttr("disabled");
            $("#ddlPTDeductionType").removeAttr("disabled");
            $("#txtRemark").removeAttr("disabled");
            $("#ddlPTSlabMonth").removeAttr("disabled");
        }

        var LowerLast= $('#tblPTSlabs').find('tr').last();
        if(LowerLast.length!=0){
            var LowerLastCell= LowerLast[0].cells;
            var c = LowerLastCell[4].innerHTML;
            var LowerLimit = c
            $("#txtLowerLimit").val(LowerLimit);
            var sum= 0;
            var LowerTotal=Number( $('#txtLowerLimit').val());
            var sum = (LowerTotal+1);
            $("#txtLowerLimit").val(sum);
        }

        //=========================================================================================>>
        var PTSlabMonth = @Html.Raw(Json.Encode(ViewBag.PTSlabMonth));

        // Iterate through the LWFSlabMonth array and set the checkboxes
        PTSlabMonth.forEach(function (slab) {
            // Construct the checkbox ID dynamically
            var checkboxId = "#chkLWFDeductionMonth" + slab.PTSlab_Month;

            // Check the checkbox if IsApplicable is true
            if (slab.IsApplicable) {
                $(checkboxId).prop("checked", true);
            } else {
                $(checkboxId).prop("checked", false);
            }
        });



    });//<<=======================================Ready Function End===============================>>

    $("#btnSubmit").click(function () {
        debugger;
        var PTSlabMasterId_Encrypted= $("#PTSlabMasterId_Encrypted").val();
        var StateCode=$("#ddlPTStateCode").val();
        var PTDeductionType=$("#ddlPTDeductionType").val();
        var Remark=$("#txtRemark").val();
        var PTSlabMonth=$("#ddlPTSlabMonth").val();
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            url: '@Url.Action("IsPTSlabExists", "Setting_Statutory_PTSlab")',
            method:"get",
            data: { PTSlabMasterId_Encrypted: PTSlabMasterId_Encrypted,StateCode:StateCode,PTDeductionType:PTDeductionType,Remark:Remark },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }

                else{
                    var StateCode=$("#ddlPTStateCode").val();
                    var PTDeductionType=$("#ddlPTDeductionType").val();
                    var Remark=$("#txtRemark").val();
                    var PTSlabMasterId_Encrypted= $("#PTSlabMasterId_Encrypted").val();
                    var PTSlabMasterId= $("#PTSlabMasterId").val();
                    //$("#SaveStatutoryPTSlab").submit();
                    var table = document.getElementById("tblPTSlabs");
                    var rowCount = table.rows.length;
                    var Task = new Array();
                    var data = {};
                    for (i = 0; i <= rowCount-1; i++) {
                        var data = {};
                        data.LowerLimit = table.rows[i].cells[3].innerHTML;
                        data.UpperLimit = table.rows[i].cells[4].innerHTML;
                        data.PTAmount = table.rows[i].cells[5].innerHTML;
                        data.FebPTAmount = table.rows[i].cells[7].innerHTML;
                        Task.push(data);
                    }



                    var table = document.getElementById("tblPTMonth");
                    var Record = [];

                    // Loop through all rows in the table
                    $("#tblPTMonth tbody tr").each(function () { // Target only tbody rows
                        var PTMonth = {};
                        var currentRow = $(this);
                        var checkbox = currentRow.find(':checkbox');

                        if (checkbox.length > 0) { // Ensure there is a checkbox in the row
                            PTMonth.PTSlab_Month = checkbox.val(); // Get the value of the checkbox
                            PTMonth.IsApplicable = checkbox.prop('checked') ? "true" : "false"; // Set IsApplicable based on checkbox state
                            Record.push(PTMonth);
                        }
