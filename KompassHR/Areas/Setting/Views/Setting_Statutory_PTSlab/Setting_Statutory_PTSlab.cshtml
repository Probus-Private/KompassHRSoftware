                                                    </td>
                                                    <td class="form-label">April</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="5" id="chkLWFDeductionMonth5" />
                                                    </td>
                                                    <td class="form-label">May</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk text-center" value="6" id="chkLWFDeductionMonth6" />
                                                    </td>
                                                    <td class="form-label">June</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="7" id="chkLWFDeductionMonth7" />
                                                    </td>
                                                    <td class="form-label">July</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="8" id="chkLWFDeductionMonth8" />
                                                    </td>
                                                    <td class="form-label">August</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="9" id="chkLWFDeductionMonth9" />
                                                    </td>
                                                    <td class="form-label">September</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="10" id="chkLWFDeductionMonth10" />
                                                    </td>
                                                    <td class="form-label">October</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="11" id="chkLWFDeductionMonth11" />
                                                    </td>
                                                    <td class="form-label">November</td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center">
                                                        <input type="checkbox" name="LWFDeductionMonth" class="form-check chk" value="12" id="chkLWFDeductionMonth12" />
                                                    </td>
                                                    <td class="form-label">December</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        @Html.ValidationMessageFor(model => model.FebPTAmount, "", new { @class = "help-block", @id = "ErrorLWFDeductionMonth", @style = "color:red" })

                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Additional Month <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PTSlabMonth, new List<SelectListItem> {
                                                                            new SelectListItem { Text = "01 - Jan", Value = "1" },
                                                                            new SelectListItem { Text = "02 - Feb", Value = "2" },
                                                                            new SelectListItem { Text = "03 - Mar", Value = "3" },
                                                                            new SelectListItem { Text = "04 - Apr", Value = "4" },
                                                                            new SelectListItem { Text = "05 - May", Value = "5" },
                                                                            new SelectListItem { Text = "06 - Jun", Value = "6" },
                                                                            new SelectListItem { Text = "07 - Jul", Value = "7" },
                                                                            new SelectListItem { Text = "08 - Aug", Value = "8" },
                                                                            new SelectListItem { Text = "09 - Sep", Value = "9" },
                                                                            new SelectListItem { Text = "10 - Oct", Value = "10" },
                                                                            new SelectListItem { Text = "11 - Nov", Value = "11" },
                                                                            new SelectListItem { Text = "12 - Dec", Value = "12" }
                                                                        }, "--Select--", new { id = "ddlPTSlabMonth", @class = "form-select", autocomplete = "off", name = "PTSlabMonth" })
                                                @Html.ValidationMessageFor(model => model.PTSlabMonth, "", new { @class = "help-block", @id = "ErrorPTSlabMonth", @style = "color:red" })

                                            </div>
