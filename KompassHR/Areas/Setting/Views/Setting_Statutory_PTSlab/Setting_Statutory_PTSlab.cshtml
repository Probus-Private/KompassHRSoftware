                                                    <th class="text-nowrap">Deduction Type  </th>
                                                    <th class="text-nowrap">Remark </th>
                                                    <th class="text-nowrap">Lower Limit</th>
                                                    <th class="text-nowrap">Upper Limit</th>
                                                    <th class="text-nowrap">PT Amount</th>
                                                    <th class="text-nowrap">Additional Month</th>
                                                    <th class="text-nowrap"> Additional Amount  </th>
                                                </tr>
