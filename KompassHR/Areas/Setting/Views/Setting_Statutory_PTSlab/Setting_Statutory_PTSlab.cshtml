                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Additional Amount <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FebPTAmount, new { @class = "form-control", name = "FebPTAmount", type = "number", id = "txtFebPTAmount", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.FebPTAmount, "", new { @class = "help-block", @id = "ErrorFebPTAmount", @style = "color:red" })
                                            </div>
