<script>
    document.getElementById("btnSubmit").addEventListener("click", function () {
        debugger;
        if (validateForm()) {
            $(".Userloaderbg").css("display", "flex");
            document.getElementById("FormHeadMapping").submit();
        }
    });

    function validateForm() {
        debugger;
        const ddlCompanyName = document.getElementById("ddlCompanyName");
        const errorSpan = document.getElementById("ErrorddlCompanyName");
        const selectedValue = ddlCompanyName.value;
        // Check if the dropdown has a valid selection
        if (selectedValue === "" || selectedValue === "--Select--") {
            // Update the error message
            errorSpan.innerHTML = "Select company name";
            errorSpan.style.display = "block";
            ddlCompanyName.focus();
            return false; // Validation failed
        } else {
            errorSpan.innerHTML = "";
            errorSpan.style.display = "none";
        }

        let values = [];
        let isDuplicate = false;

        // Loop through all textboxes in the table
        $("#tblPartA input[type='text'], #tblPartB input[type='text']").each(function () {
            let value = $(this).val().trim();
            if (value) {
                // Check for duplicate values
                if (values.includes(value)) {
                    isDuplicate = true;
                    return false; // Exit the loop on duplicate
                }
                values.push(value); // Add the value to the array
            }
        });

        if (isDuplicate) {
            // Prevent form submission and show an error
            const errorSpanChkSuq = document.getElementById("ErrorcheckboxSeq");
            errorSpanChkSuq.innerText = "Duplicate name not allowed.";
            errorSpanChkSuq.setAttribute("tabindex", "-1"); // Make the span focusable
            errorSpanChkSuq.focus();
            errorSpanChkSuq.style.display = "block";
            e.preventDefault();
            return false;
        }
        else
        {
            const errorSpanChkSuq = document.getElementById("ErrorcheckboxSeq");
            errorSpanChkSuq.style.display = "none";
        }
        return true; // Validation passed
    }
</script>

