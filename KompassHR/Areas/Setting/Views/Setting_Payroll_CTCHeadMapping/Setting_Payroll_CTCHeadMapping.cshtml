                            const errorSpanChkSuq = document.getElementById("ErrorcheckboxSeq");
                            errorSpanChkSuq.innerText = "You must check the previous checkbox first.";
                            errorSpanChkSuq.style.display = "block";
                            return;
                        }
                    }
                    // Clear error message if validation passes
                    document.getElementById("ErrorcheckboxSeq").innerText = "";
                    // Update the associated textbox based on checkbox state
                    const row = $(this).closest('tr');
                    const columnValue = row.find('td:eq(1)').text().trim();
                    const textbox = row.find('input[type="text"]');
                    textbox.val(this.checked ? columnValue : '');
                });
            });
        });
    });
</script>

