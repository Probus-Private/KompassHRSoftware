<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Claim Auditor
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_ClaimAndReimbusement_Menu", "Setting_ClaimAndReimbusement_Menu", new { id = 8, ScreenId =63, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">

                    <h4 class="panel-title">Claim Auditor - @ViewBag.AddUpdateTitle </h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define claim auditor here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "Setting_ClaimAndReimbusement_ClaimsVerifier" , new { area = "Setting" })" id="SaveClaimVerifier" method="post">
                               
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-control", name = "CmpId", @id = "ddlCmpId" })
                                                @Html.HiddenFor(model => model.ClaimVerifierId_Encrypted, new { id = "CliamVerifierId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VerifierBranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-control", name = "VerifierBranchId", @id = "VerifierBranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VerifierEmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "--Select--", new { id = "VerifierEmployeeId", @class = "form-control", autocomplete = "off", name = "VerifierEmployeeId" })
                                            </div>
                                        </div>
                                    </div>


                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VerifierType, new List<SelectListItem> {
                                                new SelectListItem { Text = "Account", Value = "Account" },
                                                new SelectListItem { Text = "Document Verification", Value = "Verification" },
                                               }, "--Select--", new { @class = "form-control", type = "text", name = "VerifierType", id = "VerifierType", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>                                    
                                </div>




                                <div class="row mb-20px">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Save
                                                        </button>
                                                      
                                                        <a href="@Url.Action("GetList", "Setting_ClaimAndReimbusement_ClaimsVerifier", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnList">
                                                                <i class="fa-solid fa-floppy-disk"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>

    $(document).ready(function () {
        $("#ddlCmpId").select2();
        $("#VerifierBranchId").select2();
        $("#VerifierEmployeeId").select2();
        $("#VerifierType").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }


        $("#ddlCmpId").on("change", function () {
            $("#VerifierBranchId").find("option").remove();
           
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Setting_ClaimAndReimbusement_ClaimsVerifier")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#VerifierBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#VerifierBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        })
    });
    
</script>



<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveClaimVerifier").validate({
        rules: {
            CmpId: {
                required: true,
            },
            VerifierBranchId: {
                required: true,
            },
            VerifierEmployeeId: {
                required: true,
            },
            VerifierType: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Please select Company",
            },
            VerifierBranchId: {
                required: "Please select Branch",
            },
            VerifierEmployeeId: {
                required: "Please select Employee ",
            },
            VerifierType: {
                required: "Please select type ",
            },
        },

    });
    //IsValidation Check
    var form = $("#SaveClaimVerifier");
    form.validate();
    $("#btnSubmit").click(function () {

        debugger;
        form.valid();
        if(form.valid()==false)
        {
            //$("#dateToDate").removeClass('error');
            return false;
        }
        var CliamVerifierId_Encrypted = $("#CliamVerifierId_Encrypted").val();
        var CmpId=$("#ddlCmpId").val();
        var VerifierBranchId=$("#VerifierBranchId").val();
        var VerifierEmployeeId=$("#VerifierEmployeeId").val();
        var VerifierType=$("#VerifierType").val();
        $.ajax({
            url: "@Url.Action("IsVerifierExist", "Setting_ClaimAndReimbusement_ClaimsVerifier")",
            method:"get",
            data: { ClaimVerifierId_Encrypted: CliamVerifierId_Encrypted, CmpId: CmpId, VerifierBranchId:VerifierBranchId,VerifierEmployeeId:VerifierEmployeeId,VerifierType:VerifierType},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveClaimVerifier").submit();
                }
            }
        });

    });
</script>