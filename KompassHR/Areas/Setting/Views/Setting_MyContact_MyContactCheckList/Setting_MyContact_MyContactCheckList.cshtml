@model KompassHR.Areas.Setting.Models.MyContact.Mas_MyContact
@{
    ViewBag.Title = "Setting_MyContact_MyContactCheckList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>


<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/ESS/ESS_AdminDashboard_Dashboard/ESS_AdminDashboard_Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="/Setting/Setting_WorkForce_Menu/Setting_WorkForce_Menu">My Contact CheckList Menu</a></li>

    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">My Contact CheckList </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> My Contact CheckList</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of contacts as per the category here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" id="SaveMyContactCheckList" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Contact Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.ContactCategoryID, new SelectList(ViewBag.GetContactCategoryName, "Id", "Name"), "--Select--", new { id = "ddlContactCategoryID", @class = "form-select", autocomplete = "off", name = "ContactCategoryID" })
                                                @Html.HiddenFor(model => model.MyContactId_Encrypted, new { id = "MyContactId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnShow"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Show
                                                        </button>
                                                        <a href="/Setting/Setting_MyContact_Menu/Setting_MyContact_Menu">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnBack">
                                                                <i class="fa-solid fa-share-from-square"></i> Back
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">My Contact CheckList</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        
                          
                    </div>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine">
                                <thead>
                                    <tr class="trheading">
                                        @*<th hidden class="fixed-side">Update</th>
                                            <th hidden class="fixed-side1">Delete</th>*@
                                        <th class="text-nowrap">Contact Category Name </th>
                                        <th class="text-nowrap">Person Name</th>
                                        <th class="text-nowrap">Company Name</th>
                                        <th class="text-nowrap">Designation</th>
                                        <th class="text-nowrap">Email ID </th>
                                        <th class="text-nowrap">Contact No</th>
                                        <th class="text-nowrap">WhatsApp No </th>
                                        <th class="text-nowrap">Address </th>
                                    </tr>
                                </thead>
                                <tbody id="tblMyContactCheckList"></tbody>
                            </table>
                        </div>
                    </div>
                    <!-- END table-responsive -->
                </div>
            </div>
        </div>

    </div>
</div>
<script>
    $(document).ready(function () {
        $("#btnBack").click(function () {
            var url = '@Url.Action("Setting_MyContact_Menu", "Setting_MyContact_Menu", new { area= "Setting" })';
            window.location.href = url;
        });

        //BtnShow
        $("#btnShow").click(function () {
            var ContactCategoryID = $("#ddlContactCategoryID").val();

            debugger;
            $.ajax({
                type: "get",
                url: "GetMyContactList",
                data: { ContactCategoryID: ContactCategoryID },
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (data) {
                    debugger;
                    var data1 = JSON.parse(data);
                    //var data =  JSON.parse(response);
                    if (data1 != null) {
                        $('#tblMyContactCheckList tr').not(function () { return !!$(this).has('th').length; }).remove();
                        for (var i = 0; i <= data1.length - 1; i++) {
                            var table = document.getElementById("tblMyContactCheckList");
                            var rowCount = table.rows.length;
                            var row = table.insertRow(rowCount);
                            var count = $('#tblMyContactCheckList tr').length;
                            //row.insertCell(0).innerHTML = '<center><button href="#Remove" onClick="SomeDeleteRowFunction(this)" title="Remove" class="btn btn-danger ListBtn btnpress"><i  class="fa-solid fa-trash-alt"></i></button></center>';
                            row.insertCell(0).innerHTML = "" + data1[i].ContactCategoryName + "";
                            row.insertCell(1).innerHTML = "" + data1[i].PersonName + "";
                            row.insertCell(2).innerHTML = "" + data1[i].CompanyName + "";
                            //row.insertCell(3).innerHTML = "" + data1[i].CompanyName + "";
                            row.insertCell(3).innerHTML = "" + data1[i].Designation + "";
                            row.insertCell(4).innerHTML = "" + data1[i].EmailID + "";
                            row.insertCell(5).innerHTML = "" + data1[i].ContactNo + "";
                            row.insertCell(6).innerHTML = "" + data1[i].WhatsAppNo + "";
                            row.insertCell(7).innerHTML = "" + data1[i].Address + "";
                        }
                    }
                }
            })

        });
        //End BtnSubmit

        $("#formReset").click(function () {
            $("#SaveMyContactCheckList")[0].reset()
        });
    });
</script>

