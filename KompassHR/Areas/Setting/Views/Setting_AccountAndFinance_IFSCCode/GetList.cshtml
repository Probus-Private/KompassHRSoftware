</style>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>IFSC Code</title>
</head>
<body>
    <div id="content" class="app-content">
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
                <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                    IFSC Code
                </h1>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Setting_AccountAndFinance_Menu", "Setting_AccountAndFinance_Menu", new { id = 0, ScreenId =0, area = "Setting" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                        </a>
                    </li>
                </ol>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                     <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">IFSC Code - List</h4>
                       
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            This is the list of IFSC codes created.
                        </p>
                    </div>
                    <div class="panel-body">

                        <div class="row">
                            <div class="col-md-12">
                               
                                <form role="form" action="/Setting/Setting_AccountAndFinance_IFSCCode/GetList" id="SaveGetList" method="post">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <a href="/Setting/Setting_AccountAndFinance_IFSCCode/Setting_AccountAndFinance_IFSCCode">
                                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                                </button>
                                            </a>
                                        </div>

                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-2">
                                                    Bank Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-10">
                                                    @Html.DropDownListFor(model => model.BankId, new SelectList(ViewBag.GetBankName, "BankId", "BankName"), "--Select--", new { id = "IFSCCodeBankID", @class = "form-select", autocomplete = "off", name = "IFSCCodeBankID" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <button type="button" id="btnShow" onclick="GetIFSCCode();" class="btn btn-primary btnpress  mb-10px">
                                                 &nbsp; Show
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                       style="width: 100%;">
                                    <thead class="text-center">
                                        <tr>
                                            <th class="fixed-side">Update</th>
                                            <th class="fixed-side1">Delete</th>
                                            <th class="text-nowrap text-center">IFSC Code </th>
                                            <th class="text-nowrap text-center">Bank Name </th>
                                            <th class="text-nowrap text-center">Bank Location </th>
                                            <th class="text-nowrap text-center">Address </th>
                                            <th class="text-nowrap text-center">City </th>
                                            <th class="text-nowrap text-center">District </th>
                                            <th class="text-nowrap text-center">State</th>
                                            <th class="text-nowrap text-center">Created By</th>
                                            <th class="text-nowrap text-center">Created Date</th>
                                            <th class="text-nowrap text-center">Modified By</th>
                                            <th class="text-nowrap text-center">Modified Date</th>
                                            <th class="text-nowrap text-center">Machine Name</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblIFSCCode">
                                        @foreach (var d in ViewBag.GetIFSCCodeList)
                                        {
                                            <tr>

                                                <td class="text-center">
                                                    <a  onclick="UpdateCostCenter('@d.IFSCID_Encrypted')" id="UpdateBtn" style="cursor:pointer">
                                                        <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center">
                                                    <a  onclick="DeleteCostCenter('@d.IFSCID_Encrypted')" id="DeleteBtn" style="cursor:pointer">
                                                        <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                    </a>
                                                </td>

                                                <td class="text-nowrap">@d.IFSCode</td>
                                                <td class="text-nowrap">@d.BankName</td>
                                                <td class="text-nowrap">@d.BranchName</td>
                                                <td class="text-nowrap">@d.Address</td>
                                                <td class="text-nowrap">@d.City</td>
                                                <td class="text-nowrap">@d.District</td>
                                                <td class="text-nowrap">@d.StateName</td>
                                                <td class="text-nowrap">@d.CreatedBy</td>
                                                <td class="text-nowrap">@d.CreatedDate</td>
                                                <td class="text-nowrap">@d.ModifiedBy</td>
                                                <td class="text-nowrap">@d.ModifiedDate</td>
                                                <td class="text-nowrap">@d.MachineName</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- END panel -->



</body>
</html>

<script>
    $(document).ready(function () {
        $("#IFSCCodeBankID").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>
    $('#fixed-header').DataTable({
        scrollY: 300,
        scrollX: true,
        scrollCollapse: true,
        searching: true,
        paging: true,
        fixedColumns: true,
        info: true,
        responsive: false
    });
</script>
<script>
    function UpdateCostCenter(IFSCID_Encrypted) {
        var url = '@Url.Action("Setting_AccountAndFinance_IFSCCode", "Setting_AccountAndFinance_IFSCCode")?IFSCID_Encrypted=' + IFSCID_Encrypted;
        window.location.href = url;
    }

    function DeleteCostCenter(IFSCID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Setting_AccountAndFinance_IFSCCode")?IFSCID_Encrypted=' + IFSCID_Encrypted;
                //window.location.href = url;
                DeleteButtons.fire(
                    'Deleted!',
                    'Your file has been deleted.',
                    'success'
                )
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }



