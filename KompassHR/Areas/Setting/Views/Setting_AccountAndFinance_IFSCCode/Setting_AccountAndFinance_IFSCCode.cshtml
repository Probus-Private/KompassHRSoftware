@model KompassHR.Areas.Setting.Models.Setting_AccountAndFinance.Mas_IFSCCode
@{
    ViewBag.Title = "IFSCCode";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                IFSC Code
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_AccountAndFinance_Menu", "Setting_AccountAndFinance_Menu", new { id = 0, ScreenId =0, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                 <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> IFSC Code - @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add IFSC codes here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/Setting/Setting_AccountAndFinance_IFSCCode/SaveUpdateIFSCCode" id="SaveIFSCCode" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                IFSC Code
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.IFSCode, new { @class = "form-control", name = "IFSCode", type = "text", id = "txtIFSCode", oninput = "this.value = this.value.toUpperCase()" })
                                                @Html.HiddenFor(model => model.IFSCID_Encrypted)
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Bank Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.IFSCCodeBankID, new SelectList(ViewBag.GetBankName, "BankId", "BankName"), "--Select--", new { id = "IFSCCodeBankID", @class = "form-select", autocomplete = "off", name = "IFSCCodeBankID" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Bank Location
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.BranchName, new { @class = "form-control", type = "text", id = "txtBranchName", autocomplete = "Off", name = "BranchName" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Address
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @*<textarea class="form-control" rows="3"></textarea>*@
                                                @Html.TextAreaFor(model => model.Address, new { @class = "form-control", type = "text", id = "txtAddress", autocomplete = "Off", name = "Address" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                City
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.City, new { @class = "form-control", type = "text", id = "txtCity", name = "City" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                District
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.District, new { @class = "form-control", type = "text", id = "txtDistrict", autocomplete = "Off", name = "District" })
                                            </div>
                                        </div>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                State
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.StateName, new { @class = "form-control", type = "text", id = "txtStateName", autocomplete = "Off", name = "StateName" })
                                            </div>
                                        </div>
                                    </div>
                                </div>



                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="/Setting/Setting_AccountAndFinance_IFSCCode/GetList">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetIFSCCodeList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#IFSCCodeBankID").select2();
        $("#formReset").click(function () {
            $("#SaveIFSCCode")[0].reset()
        })
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });
</script>


<script>

    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveIFSCCode").validate({
        rules: {
            IFSCode: {
                required: true,
                regex:/^[A-Za-z]{4}[a-zA-Z0-9]{7}$/,
                minlength: 11,

            },
            IFSCCodeBankID: {
                required: true,

            },
            BranchName: {
                required: true,
                
            },
            Address: {
                required: true,              
            },
            City: {
                required: true,
              
            },
            District: {
                required: true,
                regex: /^[a-zA-Z]+$/,
            },
            StateName: {
                required: true,
                regex: /^[a-zA-Z]+$/,
            }
        },
        messages: {
            IFSCode: {
                required: "IFSC code is required",
                regex:"Please enter valid IFSC code",
                minlength: "Please enter 11 IFSC code",
            },
            IFSCCodeBankID: {
                required: "Bank name  is required",
            },
            BranchName: {
                required: "Branch name is required",
               
            },
            Address: {
                required: "Address is required",
               
            },
            City: {
                required: "City is required",
                
            },
            District: {
                required: "District is required",
                
            },
            StateName: {
                required: "State name is required",
              
            },
        }

    });

    var form = $("#SaveIFSCCode");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        debugger;
        var IFSCode=$("#txtIFSCode").val();
        var IFSCCodeBankID=$("#IFSCCodeBankID").val();
        var BranchName=$("#txtBranchName").val();
        var Address=$("#txtAddress").val();
        var City=$("#txtCity").val();
        var District=$("#txtDistrict").val();
        var StateName=$("#txtStateName").val();
        var IFSCID_Encrypted=$("#IFSCID_Encrypted").val();

        $.ajax({
            url:"IsIFSCodeExists",
            method:"get",
            data:{IFSCode:IFSCode,IFSCCodeBankID:IFSCCodeBankID,BranchName:BranchName,Address:Address,City:City,District:District,StateName:StateName,IFSCID_Encrypted:IFSCID_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveIFSCCode").submit();

                }
            }
        });

    });
</script>

