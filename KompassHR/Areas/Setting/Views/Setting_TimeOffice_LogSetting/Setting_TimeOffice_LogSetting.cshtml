@model KompassHR.Areas.Setting.Models.Setting_TimeOffice.Atten_LogDownloadSetting
@{
    ViewBag.Title = "Setting_TimeOffice_LogSetting";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 13px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Log Download Setting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Setting_TimeOffice_Menu", "Setting_TimeOffice_Menu", new { id = 5, ScreenId =51, area = "Setting" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">  Log Download Setting - <Span>@ViewBag.AddUpdateTitle</Span></h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Setting_TimeOffice_LogSetting", new { area = "Setting" })' id="Save_LogSetting" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Log Setting Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LogSettingName, new { @class = "form-control", type = "text", id = "txtLogSettingName", autocomplete = "Off", name = "LogSettingName" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Server Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ServerName, new { @class = "form-control", id = "txtServerName", autocomplete = "Off", name = "ServerName" })
                                                @Html.ValidationMessageFor(model => model.ServerName, "", new { @class = "help-block", id = "ErrorServerName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                UserName
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.UserName, new { @class = "form-control", type = "text", id = "txtUserName", autocomplete = "Off", name = "UserName" })
                                                @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "help-block", id = "ErrorUserName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Password
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Password, new { @class = "form-control", type = "text", id = "txtPassword", autocomplete = "Off", name = "Password" })
                                                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "help-block", id = "ErrorPassword", @style = "color:red" })
                                                @Html.HiddenFor(model => model.AttenLogSettingId_Encrypted, new { id = "AttenLogSettingId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Database Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DatabaseName, new { @class = "form-control", id = "txtDatabaseName", autocomplete = "Off", name = "DatabaseName" })
                                                @Html.ValidationMessageFor(model => model.DatabaseName, "", new { @class = "help-block", id = "ErrorDatabaseName", @style = "color:red" })
                                                @Html.ValidationMessageFor(model => model.DatabaseName, "", new { @class = "help-block", id = "ErrorDatabaseNameGreen", @style = "color:green" })
                                            </div>
                                            @*<div class="col-md-2">
                                                    <button type="button" id="btnCheck" class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Check
                                                    </button>
                                                </div>*@
                                        </div>
                                    </div>

                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Table Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TableName, new { @class = "form-control", id = "txtTableName", autocomplete = "Off", name = "TableName" })

                                                <div class="form-check mt-2">
                                                    @Html.CheckBoxFor(model => model.IsMonthWise, new { @class = "form-check-input", id = "chkMonthwise" })
                                                    <label class="form-check-label" for="chkMonthwise">Is Table Monthwise</label>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                DeviceId
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DeviceId, new { @class = "form-control", id = "txtDeviceId", autocomplete = "Off", name = "DeviceId" })
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                UserId
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.UserId, new { @class = "form-control", id = "txtUserId", autocomplete = "Off", name = "UserId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Log Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LogDate, new { @class = "form-control", id = "txtLogDate", autocomplete = "Off", name = "LogDate" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Direction
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Direction, new { @class = "form-control", id = "txtDirection", autocomplete = "Off", name = "Direction" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Setting_TimeOffice_LogSetting", new { area = "Setting" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGatePassList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    })

    $("#btnCheck").click(function () {
        debugger
        $("#ErrorDatabaseName").html("");
        var ServerName = $('#txtServerName').val();
        var UserName = $('#txtUserName').val();
        var Password = $('#txtPassword').val();
        var DatabaseName = $('#txtDatabaseName').val();
        if (ServerName == "")
        { $("#ErrorServerName").html("Server Name is required"); return false; }
        else { $("#ErrorServerName").html(""); }

        if (UserName == "")
        { $("#ErrorUserName").html("User Name is required"); return false; }
        else { $("#ErrorUserName").html(""); }

        if (Password == "")
        { $("#ErrorPassword").html("Password is required"); return false; }
        else { $("#ErrorPassword").html(""); }

        if (DatabaseName == "")
        { $("#ErrorDatabaseName").html("Database Name is required"); return false; }
        else { $("#ErrorDatabaseName").html(""); }
        $.ajax({
            url: '@Url.Action("TestConnection", "Setting_TimeOffice_LogSetting")',
            method: "Post",
            data: { ServerName: ServerName, UserName: UserName, Password: Password, DatabaseName: DatabaseName },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    return false;
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                    return false;
            }
        });
    });

    jQuery.validator.addMethod(
"regex",
    function(value, element, regexp) {
        if (regexp.constructor != RegExp)
            regexp = new RegExp(regexp);
        else if (regexp.global)
            regexp.lastIndex = 0;
        return this.optional(element) || regexp.test(value);
    },"erreur expression reguliere"
 );

    $('#Save_LogSetting').validate({
        rules: {
            LogSettingName:{
                required: true,
            },
            ServerName: {
                required: true,
            },
            UserName:{
                required: true,
            },
            Password:{
                required: true,
            },
            DatabaseName:{
                required: true,
            },
            TableName:{
                required: true,
            },
            DeviceId:{
                required: true,
            },
            UserId:{
                required: true,
            },
            DownloadDate:{
                required: true,
            },
            LogDate:{
                required: true,
            },
            Direction:{
                required: true,
            },
            AttDirection:{
                required: true,
            },
            C6:{
                required: true,
            },

        },
        messages: {
            LogSettingName:{
                required: "Setting name is required",
            },
            ServerName: {
                required: "Server Name is required",
            },
            UserName: {
                required: "UserName is required",
            },
            Password:{
                required: "Password is required",
            },
            DatabaseName:{
                required: "Database Name is required" ,
            },
            TableName:{
                required: "Table Name is required",
            },
            DeviceId:{
                required: "Device Id is required",
            },
            UserId:{
                required: "UserId is required",
            },
            DownloadDate:{
                required: "Download Date is required",
            },
            LogDate:{
                required: "Log Date is required",
            },
            Direction:{
                required: "Direction is required",
            },
            AttDirection:{
                required: "Att Direction is required",
            },
            C6:{
                required: "C6 is required",
            },

        },
    });



    var form = $("#Save_LogSetting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger
        if (!form.valid()) {
            return false;
        }

        var ServerName = $('#txtServerName').val();
        var UserName = $('#txtUserName').val();
        var Password = $('#txtPassword').val();
        var DatabaseName = $('#txtDatabaseName').val();
        var LogSettingName = $('#txtLogSettingName').val();
        var AttenLogSettingId_Encrypted = $('#AttenLogSettingId_Encrypted').val();

        $.ajax({
            url: '@Url.Action("TestConnection", "Setting_TimeOffice_LogSetting")',
            method: "POST",
            data: {
                ServerName: ServerName,
                UserName: UserName,
                Password: Password,
                DatabaseName: DatabaseName
            },
            success: function (response) {
                if (response.Icon === "success") {
                    // If connection successful, check if setting already exists
                    $.ajax({
                        url: '@Url.Action("Is_LogSettingExists", "Setting_TimeOffice_LogSetting")',
                        method: "GET",
                        data: {
                            ServerName: ServerName,
                            UserName: UserName,
                            Password: Password,
                            DatabaseName: DatabaseName,
                            LogSettingName: LogSettingName,
                            AttenLogSettingId_Encrypted: AttenLogSettingId_Encrypted
                        },
                        success: function (response) {
                            if (response.Icon === "error") {
                                Swal.fire({
                                    icon: response.Icon,
                                    text: response.Message
                                });
                            } else {
                                $("#Save_LogSetting").submit();
                            }
                        }
                    });
                } else {
                    // Connection failed, show error
                    Swal.fire({
                        icon: response.Icon,
                        text: response.Message
                    });
                }
            }
        });
        return false;
    });
</script>