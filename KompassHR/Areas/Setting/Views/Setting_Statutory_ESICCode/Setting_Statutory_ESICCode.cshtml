                        });
                    }
                    else {
                        $('#ddlESICCodeBranchId').html(" ");
                    }
                }
            })
        });*@
    });//Ready Function End
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveStatutoryESICCode").validate({
        rules: {
            ESICCode: {
                required: true,
                //regex: /^[0-9]{2}(\p{Pd})[0-9]{2}\1[0-9]{6}\1[0-9]{3}\1[0-9]{4}$/,
            },
            //ESICCodeBranchId: {
            //    required: true,
            //},
            ESICAddress: {
                required: true,
            },
            ESICRemark: {
                required: true,
            },
        },
        messages: {
            ESICCode: {
                required: "ESIC code is required",
            },
            //ESICCodeBranchId: {
            //    required: "Business unit is required",
            //},
            ESICAddress: {
                required: "ESIC address is required",
            },
            ESICRemark: {
                required: "Remark is required",
            },
        }
    });

    var form = $( "#SaveStatutoryESICCode" );
    form.validate();
    $("#btnSubmit").click(function () {
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        debugger;
        var ESICCode=$("#txtESICCode").val();
        //var ESICCodeBranchId=$("#ddlESICCodeBranchId").val();
        var ESICCodeId_Encrypted=$("#ESICCodeId_Encrypted").val();
        var ESICRemark=$("#txtESICRemark").val();
        $.ajax({
            url: '@Url.Action("IsESICExists", "Setting_Statutory_ESICCode")',
            method:"get",
            data:{ESICCode:ESICCode,ESICCodeId_Encrypted:ESICCodeId_Encrypted,ESICRemark:ESICRemark}, //ESICCodeBranchId:ESICCodeBranchId,
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveStatutoryESICCode").submit();

                }
            }
        });

    });
</script>

