        }

        if (!CheckDuplicateLevels()) {
            return false;  // stop submit
        }

        if (!ValidateSeverityOrder()) {
            return false;
        }

        var TicketMatrixID_Encrypted = $("#TicketMatrixID_Encrypted").val();
        var ddlTicketCategoryID = $("#txtTicketMatrixKPICategoryId").val();
        var TicketSubCategoryId = $("#txtTicketSubCategoryId").val(); // ✅ FIX

