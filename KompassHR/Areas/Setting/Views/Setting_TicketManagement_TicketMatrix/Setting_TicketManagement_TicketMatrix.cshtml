                    });
                } else {
                    $("#SaveTicketMatrix").submit();
                }
            }
        });
    });

    function ValidateLevelEmployee() {
        debugger
        let isValid = true; // track overall validity

        for (let i = 1; i <= 4; i++) {
            let employeeVal = $(`#ddlLevel${i}Employee`).val();
          //  let tatVal = $(`#Level${i}TAT`).val();

            // Validate Employee
            if (employeeVal === '') {
                $(`#ErrorLevel${i}Employee`).text(`Level ${i} Employee is required`);
                isValid = false;
            } else {
                $(`#ErrorLevel${i}Employee`).text('');
            }

            // Validate TAT
            //if (tatVal === '') {
            //    $(`#ErrorLevel${i}TAT`).text(`Level ${i} TAT is required`);
            //    isValid = false;
            //} else {
            //    $(`#ErrorLevel${i}TAT`).text('');
            //}
        }

        return isValid; // false if any level failed, true if all passed
    }



