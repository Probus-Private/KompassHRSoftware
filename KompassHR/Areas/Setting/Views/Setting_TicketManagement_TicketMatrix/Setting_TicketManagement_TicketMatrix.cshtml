    function CheckDuplicateLevels() {
        debugger
        var L1 = $("#ddlLevel1Employee").val();
        var L2 = $("#ddlLevel2Employee").val();
        var L3 = $("#ddlLevel3Employee").val();
        var L4 = $("#ddlLevel4Employee").val();

        var arr = [L1, L2, L3, L4].filter(x => x !== "" && x !== null);

        var duplicate = arr.some((value, index) => arr.indexOf(value) !== index);

        if (duplicate) {
            Swal.fire({
                icon: "error",
                text: "Assigned employees cannot be duplicate."
            });
            return false;
        }

        return true;
    }

    function ValidateSeverityOrder() {
        debugger
        var crit = Number($("#txtCritical_ResolutionTime").val());
        var high = Number($("#txtHigh_ResolutionTime").val());
        var medium = Number($("input[name='Medium_ResolutionTime']").val());
        var low = Number($("input[name='Low_ResolutionTime']").val());

        // Validate Critical < High
        if (high <= crit) {
            Swal.fire({
                icon: "error",
                text: "High Resolution Time must be greater than Critical Resolution Time."
            });
            return false;
        }

        // Validate High < Medium
        if (medium <= high) {
            Swal.fire({
                icon: "error",
                text: "Medium Resolution Time must be greater than High Resolution Time."
            });
            return false;
        }

        // Validate Medium < Low
        if (low <= medium) {
            Swal.fire({
                icon: "error",
                text: "Low Resolution Time must be greater than Medium Resolution Time."
            });
            return false;
        }

        return true;
    }


    var form = $("#SaveTicketMatrix");
