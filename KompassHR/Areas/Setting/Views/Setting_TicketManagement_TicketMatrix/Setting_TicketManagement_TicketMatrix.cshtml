<script>
    $(document).ready(function () {
        $("#ddlLevel1Employee, #ddlLevel2Employee, #ddlLevel3Employee, #ddlLevel4Employee, #ddlDepartmentID").select2();
        $("#txtTicketMatrixKPICategoryId").select2();
        $("#txtTicketSubCategoryId").select2();

        $("#txtTicketMatrixKPICategoryId").on("change", function () {
            debugger;
            var CategoryId = $(this).val();
            $("#txtTicketSubCategoryId").empty();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                url: '@Url.Action("GetSubCategory", "Setting_TicketManagement_TicketMatrix")',
                data: { CategoryId: CategoryId },
                success: function (data) { debugger;
                    var data = data.data || [];
                    if (data.length > 0) {debugger
                        $("#txtTicketSubCategoryId").append("<option value=''>--Select--</option>");
                        $.each(data, function (i, t) {
                            $("#txtTicketSubCategoryId").append("<option value='" + t.Id + "'>" + t.Name + "</option>");
                        });
                    }

                }
            });
        });

        $("#ddlDepartmentID").on("change", function () { debugger;
            var DepartmentID = $(this).val();
            $("[id^=ddlLevel]").each(function () {
                var ddl = $(this);
                var level = ddl.attr("id").replace("ddlLevel", "").replace("Employee", "");
                var chk = $("#chkAllLevel" + level);
                ddl.empty();
                if (chk.is(":checked")) {
                    loadAllEmployees(ddl);
                } else {
                    loadDeptEmployees(ddl, DepartmentID);
                }
            });
        });

        $(".chkAllLevel").change(function () {
            var level = $(this).data("level");
            var ddl = $("#ddlLevel" + level + "Employee");
            ddl.empty();

            if (this.checked) {
                loadAllEmployees(ddl);
            } else {
                var DepartmentID = $("#ddlDepartmentID").val();
                if (DepartmentID) {
                    loadDeptEmployees(ddl, DepartmentID);
                }
            }
        });

        function loadAllEmployees(ddl) { debugger;
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                url: '/Setting/Setting_TicketManagement_TicketMatrix/GetAllEmployees',
                success: function (data) {
                    ddl.append("<option value=''> --Select-- </option>");
                    $.each(data.result, function (i, p) {
                        ddl.append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }
            });
        }

        function loadDeptEmployees(ddl, DepartmentID) { debugger;
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                url: '/Setting/Setting_TicketManagement_TicketMatrix/GetEmployee',
                data: { DepartmentID: DepartmentID },
                success: function (data) {
                    ddl.append("<option value=''> --Select-- </option>");
                    $.each(data.result, function (i, p) {
                        ddl.append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }
            });
        }
    });




