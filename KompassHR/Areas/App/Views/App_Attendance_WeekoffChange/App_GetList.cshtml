<div class="col-md-2">
    <a href="@Url.Action("App_Attendance_WeekoffChange", "App_Attendance_WeekoffChange", new { area = "App", ScreenId = 146 })" class="mobile-fixed-add-btn">
        <button type="button" class="btn btn-primary shadow">
            <i class="fa-solid fa-plus fa-lg"></i>
        </button>
    </a>
</div>

<div class="container mx-auto px-2 py-2">
    <!-- Search Input -->
    <div class="flex justify-center mb-2">
        <div class="w-full max-w-md">
            <input type="text" id="searchDate" class="form-control w-full px-4 py-2 border rounded-md"
                   placeholder="Search by Date (e.g., 20/Aug/2024)">
        </div>
    </div>

    <div class="flex flex-wrap gap-2 justify-center">
       
        @foreach (var d in ViewBag.GetAttenWOList)
        {
            var WOID = d?.WOID ?? 0;
            string topBorderColor = "green-500";
            string bgClass = $"bg-{topBorderColor}";
            string borderClass = $"border-t-4 border-{topBorderColor}";

            <div class="bg-white rounded-xl shadow-md p-3 w-full max-w-full sm:max-w-md lg:max-w-sm mx-auto @borderClass WOCard">
                <!-- Top Section -->
                <div class="flex justify-between items-start mb-1">
                    <div>
                        <div class="text-base font-semibold text-gray-800">
                            @(d != null ? $"{"Week Off"} ({"Full Day"})" : "")
                        </div>
                        <div class="text-sm text-gray-500">@d.PendingDay</div>
                    </div>
                </div>

                <!-- Table-style Layout -->
                <table class="w-full text-sm text-gray-700">
                    <tbody>
                        <tr>
                            <td class="py-2 w-1/4"><i class="fas fa-calendar-alt text-blue-600"></i></td>
                            <td class="font-medium w-1/3">Week Off Date</td>
                            <td class="px-2">:</td>
                            <td class="truncate WO_Date">@d.WO_Date</td>
                        </tr>

                        <tr class="border-b">
                            <td class="py-2"><i class="fas fa-lightbulb text-yellow-500"></i></td>
                            <td class="font-medium">Reason</td>
                            <td class="px-2">:</td>
                            <td class="truncate">@d.Remark</td>
                        </tr>
                    </tbody>
                </table>

                <!-- Footer Buttons -->
                <div class="flex flex-wrap justify-start items-center gap-3 mt-2">


                    <button onclick="DeleteAttenWO('@d.WOID')"
                            class="text-red-600 border border-red-500 px-1 py-2 rounded-md hover:bg-red-50">
                        <i class="fa fa-trash"></i> Delete
                    </button>

                    @*<a href="@Url.Action("App_LeaveDetails", "App_Leave_Leave", new { LeaveMasterId = d.LeaveMasterId })"
                       class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                        <i class="fa-solid fa-bars"></i> View More
                    </a>*@
                </div>

            </div>
        }
    </div>
</div>




@*=====New Code START================================================================================================================*@
<script>
    document.getElementById('searchDate').addEventListener('input', function () {
        const searchValue = this.value.trim().toLowerCase();
        const cards = document.querySelectorAll('.WOCard');

        cards.forEach(card => {
            const nameElement = card.querySelector('.WO_Date');
            let dateText = '';

            if (nameElement && nameElement.innerText) {
                dateText = nameElement.innerText.toLowerCase();
            }

            if (dateText.includes(searchValue)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>
@*=====New Code END================================================================================================================*@

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });

</script>

<script>
    function DeleteAttenWO(WOID) {
        debugger
            const DeleteButtons = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            DeleteButtons.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("App_Delete", "App_Attendance_WeekoffChange")?WOID=' + WOID;
                } else if (
                    /* Read more about handling dismissals below */
                    result.dismiss === Swal.DismissReason.cancel
                ) {

                }
            })
        }


</script>