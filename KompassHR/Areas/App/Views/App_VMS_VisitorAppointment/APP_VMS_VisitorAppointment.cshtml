<script>
    function VisitorAppointmentList(){
        var url = '@Url.Action("App_GetList", "App_VMS_VisitorAppointment")';
        window.location.href = url;
    }



    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }


    //Ajax Call For GetLocation
    $(document).ready(function () {

        $("#txtVisitorAppointmentEmployeeID").select2();
        var GetAddUpdateTitle = @Html.Raw(Json.Encode(ViewBag.AddUpdateTitle));
        if(GetAddUpdateTitle=="Add")
        {
            var GetBranchId = @Html.Raw(Json.Encode(Session["BranchId"]));
            var GetEmployeeId = @Html.Raw(Json.Encode(Session["EmployeeId"]));
            var BranchAddress = @Html.Raw(Json.Encode(ViewBag.BranchAddress));
            var GetBranchAddress= BranchAddress[0][0].Value;
            $("#txtVisitorBranchID").val(GetBranchId).select2();
            $("#txtVisitorAppointmentEmployeeID").val(GetEmployeeId).select2();
            $("#txtMeetingLocation").val(GetBranchAddress);
            $("#txtVisitingBranchID").val(GetBranchId).select2();
        }



        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#txtAppointmentDate").val(dateString);
        $("#txtCmpId").select2();
        $("#txtVisitorBranchID").select2();
        $("#txtVisitorType").select2();
        $("#txtVisitingBranchID").select2();

        $("#btnGetLocation").click(function () {
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                url: '@Url.Action("GetLocation", "App_VMS_VisitorAppointment")',
                success: function (data) {

                    $("#txtVisitorBranchID").val(data);
                },
                error: function() {
                    alert("There is some problem to get the date");
                }
            });
        });
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        $("#formReset").click(function () {
            $("#SaveVisitorAppointment")[0].reset()
        });

        var IsSpecial = @Html.Raw(Json.Encode(TempData["IsSpecial"]));
        debugger
        if (IsSpecial == true) {
            $("#ddlIsSpecial").val("1");
        }
        else if(IsSpecial == false) {
            $("#ddlIsSpecial").val("0");
        }
        debugger;
        var AppointmentDate = @Html.Raw(Json.Encode(TempData["AppointmentDate"]));
        if(AppointmentDate == null || AppointmentDate == "")
        {

        }
        else
        {
            var AppointmentDate =  convertDate(AppointmentDate);
            $("#txtAppointmentDate").val(AppointmentDate);

        }



        $("#txtVisitorBranchID").change(function () {
            debugger;
            var CompanyId = $("#txtCmpId").val();

            var BranchId = $("#txtVisitorBranchID").val();
            $("#txtVisitorAppointmentEmployeeID").find("option").remove();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployee", "App_VMS_VisitorAppointment")',
                data: { BranchId: BranchId },
                success: function (data) {
                    debugger;
                    var EmployeeName=data.EmployeeName;
                    var AddressBranch=data.AddressBranch;
                    if (data != null) {
                        $.each(EmployeeName, function (i, p) {
                            $("#txtVisitorAppointmentEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });


                        var BranchAdress = AddressBranch[0][0].Value;
                        $("#txtMeetingLocation").val(BranchAdress);
                    }
                }
            });
        });

    });//Ready function

    function DeleteVisitorAppointment(VisitorAppointmentID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("PendingDelete", "App_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted;
                //window.location.href = url;
            //    DeleteButtons.fire(
            //        'Deleted!',
            //        'Your file has been deleted.',
            //        'success'
            //    )
            //} else if (
            //    /* Read more about handling dismissals below */
            //    result.dismiss === Swal.DismissReason.cancel
            //) {

            }
        })
    }


    function GetAllData(){
        debugger
        var Moblieno = $("#txtVisitorMobileNo").val();
        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetAllInformation", "App_VMS_VisitorAppointment")',
            data: { Moblieno: Moblieno },
            success: function (GetData) {
                debugger;
                console.log(GetData)
                if(GetData=="")
                {
                    var Message ="Record not found";
                    var Icon = "error";
                    if (Message != null) {
                        if (Message != null) {
                            Swal.fire({
                                icon: Icon,
                                text: Message,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    debugger;
                   // $("#LastVisitDate").show();
                   // $("#HideLastVisitDate").show();
                    var visitorName = GetData[0][0].Value;
