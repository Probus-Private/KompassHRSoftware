<script>

    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }


    jQuery.validator.addMethod(
       "regex",
        function(value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        },"erreur expression reguliere"
     );

    $('#SaveVisitorAppointment').validate({
        rules: {
            CmpId:{
                required: true,
            },
            AppointmentDate: {
                required: true,
            },
            AppointmentTime: {
                required: true,
            },
            VisitorName: {
                required: true,
            },
            EmailID:{
                email: true
            },
            VisitorPuposeId:{
                required: true,
            },
            VisitorAppointmentBranchID:{
                required: true,
            },
            MobileNo:{
                required: true,
            },
            Company:{
                required: true,
            },
            VisitorTypeId:{
                required: true,
            },
            VisitorAppointmentEmployeeID:{
                required: true,
            },

        },
        messages: {
            CmpId:{
                required: "Company Name is required"
            },
            AppointmentDate: {
                required:"Appointment date is required",
            },
            AppointmentTime: {
                required:"Appointment time is required",
            },
            VisitorName: {
                required: "Visitor name is required",
            },
            EmailID: {
                email: "Please enter a valid email address"
            },
            VisitorPuposeId: {
                required: "Pupose is required",
            },
            VisitorAppointmentBranchID:{
                required: "Business Unit is required",
            },
            MobileNo:{
                required: "Mobile No is required"
            },
            Company:{
                required: "Visitor company name is required"
            },
            VisitorTypeId:{
                required: "Visitor type is required"
            },
            VisitorAppointmentEmployeeID:{
                required: "Host name is required"
            }
        },
    });


    var form = $("#SaveVisitorAppointment");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtAppointmentDate").removeClass('error');
            $("#txtAppointmentTime").removeClass('error');
            return false;
        }
        var BranchId=$("#txtVisitorBranchID").val();
        if(BranchId==0)
        {
            $("#ErrorVisitorAppointmentBranchID").html("Business unit is required"); return false;
        }
        else
        {
            $("#ErrorVisitorAppointmentBranchID").html("");
        }

        var AppointmentTime = $("#txtAppointmentTime").val();
        var AppointmentDate = $("#txtAppointmentDate").val();
        var currentDateTime = new Date(); // for now

        // Splitting the appointment time into hours and minutes
        var appointmentTimeParts = AppointmentTime.split(':');
        var appointmentHours = parseInt(appointmentTimeParts[0]);
        var appointmentMinutes = parseInt(appointmentTimeParts[1]);

        // Splitting the appointment date into year, month, and day
        var appointmentDateParts = AppointmentDate.split('-');
        var appointmentYear = parseInt(appointmentDateParts[0]);
        var appointmentMonth = parseInt(appointmentDateParts[1]) - 1; // Months are zero-indexed
        var appointmentDay = parseInt(appointmentDateParts[2]);

        // Constructing appointment date and time
        var appointmentDateTime = new Date(appointmentYear, appointmentMonth, appointmentDay, appointmentHours, appointmentMinutes, 0);

        if (appointmentDateTime < currentDateTime) {
            $("#ErrorAppointmentTime").html("Time should not be less than current Time");
            return false;
            //alert('Time should not be less than current Time');
        } else {
            $("#ErrorAppointmentTime").html("");
        }
        $(".Userloaderbg").css("display", "flex");
    });
</script>

