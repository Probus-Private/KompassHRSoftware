
@{
    ViewBag.Title = "APP_VMS_VisitorAppointment";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

@model KompassHR.Areas.ESS.Models.ESS_VMS.Visitor_Appointment


<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />

<style>
    .app-header-fixed {
        padding-top: 0px;
        padding-bottom: 0px;
    }

    .app-content {
        padding: 0px 0px;
    }

    .panel .panel-body {
        padding: 8px;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }


    @@media (max-width: 767px) {
        .form-label {
            margin-bottom: 0.25rem;
            display: inline-block;
        }
    }

    #btnSubmit {
        transition: background-color 0.3s ease;
    }

    #btnGetList {
        transition: background-color 0.3s ease;
    }
</style>

<style>
    /*.form-label-container {
                                        display: flex;
                                        align-items: center;
                                        justify-content: flex-end;
                                    }*/

    .form-label-text {
        display: inline-flex;
        align-items: center;
        min-width: 120px; /* Adjust this value to fit your longest label */
    }

        .form-label-text i {
            margin-right: 0.5rem; /* Space between icon and label text */
        }
</style>

<style>
    @@media (max-width: 767px) {
        .row.mb-3.align-items-center {
            display: flex;
            flex-wrap: nowrap;
            align-items: center;
        }

            .row.mb-3.align-items-center .col-md-4,
            .row.mb-3.align-items-center .col-md-8 {
                flex: 1;
                max-width: none;
                padding-right: 10px;
                padding-left: 10px;
            }

            .row.mb-3.align-items-center .col-md-4 {
                flex: 0 0 auto;
                width: 40%;
            }

            .row.mb-3.align-items-center .col-md-8 {
                flex: 1;
                width: 60%;
            }

        .form-label {
            margin-bottom: 0;
            white-space: nowrap;
        }

        .form-control,
        .form-select {
            width: 100%;
        }
    }
</style>

<div id="content" class="app-content">
    <div class="panel panel-inverse" data-sortable-id="index-1">
        <div class="panel-body" data-scrollbar="false">
            <div class="row">
                <div class="col-md-12">
                    <div class="panel panel-inverse" data-sortable-id="index-1">
                        <div class="panel-body">
                            <form role="form" action='@Url.Action("App_SaveUpdate", "App_VMS_VisitorAppointment", new { area = "App" })' id="SaveVisitorAppointment" method="post">
                                @Html.HiddenFor(model => model.VisitorAppointmentID_Encrypted, new { id = "VisitorAppointmentID_Encrypted" })
                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-hashtag text-purple-600"></i> Doc No.
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", @readonly = "readonly", style = "background-color: #eee;", Value = @ViewBag.DocNo.DocNo })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-calendar-days text-purple-600"></i> Appointment
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.AppointmentDate, new { @class = "form-control", name = "AppointmentDate", type = "date", id = "txtAppointmentDate", autocomplete = "Off" })
                                    </div>
                                </div>


                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-cash-register text-green-500"></i> Company Name
                                                    <span class="important">*</span>
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyName, "Id", "Name"), new { @class = "form-control", name = "CmpId", type = "date", id = "txtCmpId", onChange = "ChangeConpany()" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label">
                                            <span class="form-label-text">
                                                <i class="fa-solid fa-sitemap text-orange-500"></i>Business Unit <span class="important">*</span>
                                            </span>:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.VisitorAppointmentBranchID, new SelectList(ViewBag.BranchName, "Id", "Name"), new { @class = "form-control", id = "txtVisitorBranchID", name = "VisitorAppointmentBranchID", onChange = "BranchName()" })
                                        @Html.ValidationMessageFor(model => model.VisitorAppointmentBranchID, "", new { @class = "help-block", id = "ErrorVisitorAppointmentBranchID", @style = "color:red" })
                                    </div>
                                </div>



                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label">
                                            <span class="form-label-text">
                                                <i class="fa-solid fa-user-tie text-blue-600"></i>Host Name <span class="important">*</span>
                                            </span>:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.VisitorAppointmentEmployeeID, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { @class = "form-control", name = "VisitorAppointmentEmployeeID", id = "txtVisitorAppointmentEmployeeID" })
                                    </div>
                                </div>



                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label">
                                            <span class="form-label-text">
                                                <i class="fa-solid fa-sitemap text-orange-500"></i>Visiting Business Unit<span class="important">*</span>
                                            </span>:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.VisitingBranchID, new SelectList(ViewBag.VisitingBranchName, "Id", "Name"), new { @class = "form-control", id = "txtVisitingBranchID", name = "VisitingBranchID" })
                                        @Html.ValidationMessageFor(model => model.VisitorAppointmentBranchID, "", new { @class = "help-block", id = "ErrorVisitingBranchID", @style = "color:red" })
                                    </div>
                                </div>


                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fas fa-clock text-amber-600"></i> Appointment Time <span class="important">*</span></span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.AppointmentTime, new { @name = "AppointmentTime", @class = "form-control", @id = "txtAppointmentTime", @type = "time" })
                                        @Html.ValidationMessageFor(model => model.AppointmentTime, "", new { @class = "help-block", id = "ErrorAppointmentTime", @style = "color:red" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-user-check text-green-500"></i> Visitor Type</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.VisitorTypeId, new SelectList(ViewBag.VisitorType, "Id", "Name"), "--Select--", new { @class = "form-control", name = "VisitorType", type = "date", id = "txtVisitorType" })
                                    </div>
                                </div>



                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fas fa-mobile-screen text-green-500"></i> Mobile No <span class="important">*</span></span>:</label>
                                    </div>
                                    <div class="col-md-4">
                                        @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", name = "MobileNo", type = "text", id = "txtVisitorMobileNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                    </div>
                                    <div class="col-md-1 col-3">
                                        <button type="button" id="btnGetMoblie" onclick="GetAllData()" class="btn btnpress btn-primary">
                                            Search
                                        </button>
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-hourglass text-blue-500"></i> Last Visit</span>:</label>
                                    </div>
                                    <div class="col-md-4">
                                        <input type="text" id="lblCountOfVisitor" class="form-control" />
                                    </div>
                                    <div class="col-md-1 col-2">
                                        <button type="button" class="btn btnpress btn-primary" id="btnGetInformatiom">
                                            <span><i class="fa-solid fa-eye"></i></span>
                                        </button>
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-user text-blue-600"></i>Visitor Name</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.VisitorName, new { @class = "form-control", name = "VisitorName", type = "text", id = "txtVisitorName", autocomplete = "Off", oninput = "this.value = this.value.toUpperCase()" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-id-badge text-indigo-500"></i>Designation</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.Designation, new { @class = "form-control", name = "VisitorDesignation", type = "text", id = "txtVisitorDesignation", autocomplete = "Off" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-user-plus text-pink-600"></i>Addition Person</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.AdditionPerson, new { @class = "form-control", name = "AdditionPerson", type = "text", id = "txtAdditionPerson", autocomplete = "Off", onkeypress = " return numbervalidate(event)", Maxlength = 10 })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-envelope text-green-600"></i>Email Id</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.EmailID, new { @class = "form-control", name = "EmailId", type = "text", id = "txtVisitorEmailID", autocomplete = "Off" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-building-user text-blue-600"></i>Visitor Company Name</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.Company, new { @class = "form-control", name = "VisitorCompany", type = "text", id = "txtVisitorCompany", autocomplete = "Off" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-star text-yellow-600"></i>VIP</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.IsSpecial, new List<SelectListItem> {
                                                  new SelectListItem { Text = "No", Value = "0"},
                                                    new SelectListItem { Text = "Yes", Value = "1"}
                                                }, new { id = "ddlIsSpecial", @class = "form-select", autocomplete = "off", name = "IsSpecial" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-bullseye text-blue-600"></i>Purpose</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.VisitorPuposeId, new SelectList(ViewBag.PurposeName, "Id", "Name"), "--Select--", new { id = "ddlVisitorPupose", @class = "form-control", name = "VisitorPuposeId" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-comment-dots text-gray-600"></i>Remark</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextAreaFor(model => model.VisitorRemark, new { @class = "form-control", name = "VisitorRemark", type = "text", id = "txtVisitorRemark", autocomplete = "Off" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4 form-label-container">
                                        <label class="form-label"><span class="form-label-text"><i class="fa-solid fa-map-marker-alt text-red-500"></i>Appointment Location</span>:</label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.MeetingLocation, new { @class = "form-control", name = "MeetingLocation", type = "text", id = "txtMeetingLocation", autocomplete = "Off" })
                                    </div>
                                </div>


                                <div class="col-md-12 LastShortLeaveBx">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="submit" id="btnSubmit" class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                            </button>
                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetList" onclick="VisitorAppointmentList();">
                                                <i class="fa-solid fa-share-from-square"></i> List
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>






        </div>
    </div>
</div>


