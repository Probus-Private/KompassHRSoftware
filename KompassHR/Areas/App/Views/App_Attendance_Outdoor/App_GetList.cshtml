
@{
    ViewBag.Title = "App_GetList";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    .profile-card {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .profile-card .header {
            padding: 15px;
            position: relative;
            color: white;
        }

    .org-level {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.4);
        padding: 4px 8px;
        border-radius: 10px;
        font-size: 12px;
    }

    .profile-card .content {
        padding: 15px;
    }

    .profile-card .name {
        font-size: 16px;
        font-weight: 600;
    }

    .profile-card .subtitle {
        font-size: 14px;
        color: #555;
        margin-bottom: 5px;
    }

    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }
</style>

<style>
    /* Fixed circular "+" button for all screen sizes */
    .mobile-fixed-add-btn {
        position: fixed;
        bottom: 15px;
        right: 15px;
        z-index: 1050;
        width: 50px;
        height: 50px;
    }

        .mobile-fixed-add-btn .btn {
            width: 100%;
            height: 100%;
            padding: 0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

    .app {
        background-color: white;
    }
</style>

<style>
    .timeline {
        max-width: 400px;
        background-color: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

        .timeline:before {
            left: 32px;
        }

    .timeline-item {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

    .iconGreen {
        width: 24px;
        height: 24px;
        background-color: green;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .iconRed {
        width: 24px;
        height: 24px;
        background-color: #ff5b57;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .text {
        flex-grow: 1;
    }

        .text p {
            margin: 0;
            font-size: 14px;
        }

        .text small {
            color: gray;
            font-size: 12px;
        }

    .button {
        text-align: center;
        margin-top: 20px;
    }

        .button button {
            background-color: #a8d935;
            border: none;
            padding: 10px 20px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            border-radius: 5px;
        }

            .button button:hover {
                background-color: #8cc62f;
            }

   body {
        background-color: white !important;
    }
</style>

<div class="col-md-2">
    <a href="@Url.Action("App_Attendance_Outdoor", "App_Attendance_Outdoor", new { area = "App", ScreenId = 146 })" class="mobile-fixed-add-btn">
        <button type="button" class="btn btn-primary shadow">
            <i class="fa-solid fa-plus fa-lg"></i>
        </button>
    </a>
</div>

<div class="container mx-auto px-2 py-2">
    <!-- Search Input -->
    <!-- Fixed Search Bar -->
    <div class="fixed top-0 left-0 w-full bg-white z-50 shadow">
        <div class="flex justify-center py-2">
            <div class="w-full max-w-md">
                <input type="text" id="searchDate" class="form-control w-full px-4 py-2 border rounded-md"
                       placeholder="Search by Date (e.g., 20/Aug/2024)">
            </div>
        </div>
    </div>
    <div class="pt-10">
        <!-- Card Grid -->
        <div class="flex flex-wrap justify-center gap-2">

            @foreach (var d in ViewBag.OutDoorCompanyAll)
            {
                var leaveMasterId = d?.LeaveMasterId ?? 0;
                var cancelStatus = d?.CancelStatus;
                var status = d?.Status ?? "";
                string topBorderColor = d.Status != null && d.Status.Contains("Approved") ? "green-500"
                        : d.Status != null && d.Status.Contains("Rejected") ? "red-500"
                        : d.Status != null && d.Status.Contains("Pending") ? "orange"
                        : "";
                string bgClass = $"bg-{topBorderColor}";
                string borderClass = $"border-t-4 border-{topBorderColor}";
            <div class="bg-white rounded-xl shadow-md p-3 w-full sm:max-w-md md:max-w-sm border-t-4 @borderClass outdoor-card">
                <!-- Top Section -->
                <div class="flex justify-between items-start mb-1">
                    <div>
                        <div class="text-sm-0"><i class="fa-solid fa-hashtag text-purple-600"></i> Doc No. : @d.DocNo</div>
                        <div class="text-base font-semibold text-gray-800">
                            @(d != null ? $"{"OutDoor"} ({d.OutDoorCompanyType})" : "")
                        </div>

                    </div>
                    <div class="flex items-center justify-end space-x-2">
                        <div>
                            <div class="text-white text-center px-4 py-1 rounded-full text-sm font-semibold @bgClass">
                                @d.Status
                            </div>
                            <div class="text-xs text-gray-500 mt-1 text-right">
                                @d.ApprovedDay
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Table-style Layout -->
                <table class="w-full text-sm text-gray-700 table-auto">
                    <tbody>
                        <tr class="align-top">
                            <td class="py-2 w-6 text-center align-middle">
                                <i class="fas fa-calendar-alt text-blue-600"></i>
                            </td>
                            <td class="font-medium whitespace-nowrap pr-1">For Date</td>
                            <td class="px-1">:</td>
                            <td class="break-words text-wrap max-w-xs sm:max-w-md ForDate">@d.ForDate</td>
                        </tr>

                        <tr class="align-top">
                            <td class="py-2 w-6 text-center align-middle">
                                <i class="fas fa-briefcase text-purple-600"></i>
                            </td>
                            <td class="font-medium whitespace-nowrap pr-1">Shift</td>
                            <td class="px-1">:</td>
                            <td class="break-words text-wrap max-w-xs sm:max-w-md">@d.OutDoorCompanyShiftName</td>
                        </tr>
                        <tr class="align-top">
                            <td class="py-2 w-6 text-center align-middle">
                                <i class="fas fa-lightbulb text-yellow-500"></i>
                            </td>
                            <td class="font-medium whitespace-nowrap pr-1">Reason</td>
                            <td class="px-1">:</td>
                            <td class="break-words text-wrap max-w-xs sm:max-w-md">@d.Reason</td>
                        </tr>

                        <tr class="align-top border-b">
                            <td class="py-2 w-6 text-center align-middle">
                                <i class="fas fa-user-tie text-indigo-600"></i>
                            </td>
                            <td class="font-medium whitespace-nowrap pr-1">Approver</td>
                            <td class="px-1">:</td>
                            <td class="break-words text-wrap max-w-xs sm:max-w-md">@d.ApprovedBy</td>
                        </tr>


                    </tbody>
                </table>


                <!-- Footer Buttons -->
                <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                    <i class="fa-solid fa-sitemap fa-2xl cursor-pointer" onclick="ApproveStatus(@d.OutDoorCompanyId)"></i>
                    <a href="@Url.Action("App_OutdoorDetails", "App_Attendance_Outdoor", new { OutDoorCompanyId_Encrypted = d.OutDoorCompanyId_Encrypted })"
                       class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                        <i class="fa-solid fa-bars"></i> View Details
                    </a>
                    @if (d.Status.Contains("Pending"))
                           {
                            <button onclick="DeleteOutDoor('@d.OutDoorCompanyId_Encrypted','@d.OutDoorCompanyId','@d.Status')" class="text-red-600 border border-red-500 px-3 py-1 rounded-md hover:bg-red-50">
                                <i class="fa fa-trash"></i> Delete
                            </button>
                           }
                           else
                           {
                            if (cancelStatus == "Requested" || cancelStatus == "Canceled")
                            {
                            <button class="btn btn-outline-secondary btn-sm px-2 py-1 rounded-md" disabled>@cancelStatus</button>
                            }
                            else
                            {
                            <a href="#modal-dialogForHoldReject1"
                               onclick="CancelRequestFun(@d.OutDoorCompanyId,'@d.Status')"
                               class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                <i class="fa fa-xmark"></i> Cancel
                            </a>
                            }
                           }

                </div>
            </div>
                    }
        </div>
    </div>
</div>

