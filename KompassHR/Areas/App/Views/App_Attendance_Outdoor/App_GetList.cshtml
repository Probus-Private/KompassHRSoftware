<script>
    document.getElementById('searchDate').addEventListener('input', function () {
        const searchValue = this.value.trim().toLowerCase();
        const cards = document.querySelectorAll('.outdoor-card');

        cards.forEach(card => {
            const dateElement = card.querySelector('.ForDate');
            const dateText = dateElement ? dateElement.innerText.trim().toLowerCase() : '';

            if (dateText.includes(searchValue)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>