<script>
    const getFromDate = document.getElementById('txtFromDate');
    const getToDate = document.getElementById('txtToDate');
    const getFromTime = document.getElementById('txtFromTime');
    const getToTime = document.getElementById('txtToTime');
    const changeTotalMinute = parseInt(document.getElementById('txtTotalMinutes').value, 10);

    // Call this function on chnage fromdate todate fromtime & totime
    function calculateTimeDifference() {
        debugger;
        const fromDateTime = new Date(`${getFromDate.value}T${getFromTime.value}`);
        const toDateTime = new Date(`${getToDate.value}T${getToTime.value}`);
        // Calculate difference in milliseconds
        const diffInMs = toDateTime - fromDateTime;
        const fromDateOnly = new Date(fromDateTime);
        const toDateOnly = new Date(toDateTime);
        const totalDays = Math.floor((toDateOnly - fromDateOnly) / (1000 * 60 * 60 * 24));
        let days = Math.floor(diffInMs / (1000 * 60 * 60 * 24));
        const totalHours = diffInMs / (1000 * 60 * 60);
        const remainingHours = totalHours % 24;
        days += 1;
        //if (remainingHours >= 16) {

        //}
        //Calculate the remaining hours, minutes, and seconds
        const hours = Math.floor((diffInMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diffInMs % (1000 * 60 * 60)) / (1000 * 60));
        const Totalmin = hours*60+minutes;
        $("#txtTotalDuration").val(Totalmin);
        $("#txtTotalDays").val(days);
    }
    // Onchnage 4 tab for real-time calculations
    [getFromDate, getToDate, getFromTime, getToTime].forEach(input => {
        input.addEventListener('change', calculateTimeDifference);
    });
</script>

