                            }).then(function() {
                                $(".Userloaderbg").css("display", "none");
                            });
                        }
                    }
                    return false;
                }
                else{
                    $("#SaveOutDoor").submit();
                }
            }
        });

    });

    //CapthaVerification code added in CapthaVerification.js file.
    $(".Close").click(function () {
        $("#mainCaptcha").val("");
        $("#txtInput").val("");
        $("#success").html("");
        $("#error").html("");
    });

</script>

