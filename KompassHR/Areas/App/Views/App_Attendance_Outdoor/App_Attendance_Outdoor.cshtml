<div id="content" class="app-content">
    <div class="panel panel-inverse" data-sortable-id="index-1">
        <div class="panel-body" data-scrollbar="false">
            <div class="row">
                <div class="col-md-12">
                    <!-- BEGIN panel -->
                    <div class="panel panel-inverse" data-sortable-id="index-1">
                        <div class="panel-body">

                            <div class="row">
                                <div class="col-md-12">
                                    <form role="form" action='@Url.Action("App_SaveUpdate", "App_Attendance_Outdoor", new { area = "App" })' id="SaveOutDoor" method="post" data-parsley-validate="true">
                                        @Html.HiddenFor(model => Model.OutDoorCompanyID)
                                        <div class="row mb-3 align-items-center">
                                            <div class="col-md-4">
                                                <div class="form-label-container">
                                                    <label class="form-label">
                                                        <span class="form-label-text">
