<script>
    function btnGetLists()
    {
        var url = '@Url.Action("App_GetList", "App_Attendance_Outdoor")';
        window.location.href = url;
    }

    $(document).ready(function () {
        //Validation for back day days Min Days
        debugger;
        var OutdoorBranchID = @Html.Raw(Json.Encode(Session["BranchID"]));
        $("#txtVisitingBranchID").select2();
        $("#txtVisitingBranchID").val(OutdoorBranchID).select2();

        var BackDatedDays = @Html.Raw(Json.Encode(ViewBag.BackDatedDays));
        var FutureDatedDays = @Html.Raw(Json.Encode(ViewBag.FutureDatedDays));
        var fromDateInputMin = document.getElementById("txtFromDate");
        var toDateInputMin = document.getElementById("txtToDate");
        var currentDateMin = new Date();
        var minDate = new Date();
        minDate.setDate(currentDateMin.getDate() - BackDatedDays);
        var minDateString = minDate.toISOString().split('T')[0];
        fromDateInputMin.setAttribute("min", minDateString);
        toDateInputMin.setAttribute("min", minDateString);

        //Validation for back day days Max Days
        var fromDateInputMax = document.getElementById("txtFromDate");
        var toDateInputMax = document.getElementById("txtToDate");
        var currentDateMax = new Date();
        var MaxDate = new Date();
        MaxDate.setDate(currentDateMax.getDate() + FutureDatedDays);
        var maxDateString = MaxDate.toISOString().split('T')[0];
        fromDateInputMax.setAttribute("max", maxDateString);
        toDateInputMax.setAttribute("max", maxDateString);

        //End Validation for back day days
        document.querySelector('#txtDocNo').style.backgroundColor = '#e9ecef';
        document.querySelector('#txtTotalDuration').style.backgroundColor = '#e9ecef';
        document.querySelector('#txtTotalDays').style.backgroundColor = '#e9ecef';
        $("#txtTotalMinutes").prop("readonly", true);
        document.querySelector('#txtTotalMinutes').style.backgroundColor = '#eee';
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];

        $('#OutDoorCompanyType').change(function () {
            debugger;
            document.getElementById("divMaxAllow").style.display = "block";
            var SelectedDay = $('#OutDoorCompanyType').val();
            var FromTime = $("#txtFromTime").val();
            var ToTime = $("#txtToTime").val();

            //Ask Time Diff Code Start
            $.ajax({
                type: "Get",
                url: '@Url.Action("App_GetTotalDuration", "App_Attendance_Outdoor", new { area = "App" })',
                data: { FromTime:FromTime , ToTime:ToTime},
                dataType: "text",
                success: function (data) {
                    debugger;
                    var a = JSON.parse(data);
                    var GetnewTime = a.data.Hours*60 + a.data.Minutes;
                    $('#txtTotalDuration').val(GetnewTime);
                    var TotalTime = $('#txtTotalMinutes').val();
                    var GetTotalTime=TotalTime.replaceAll("Min", "");
                    var SetTotalTime =Number(GetTotalTime);
                    if(GetnewTime>SetTotalTime)
                    {
                        $("#ErrortxtTotalDuration").html("Total duration not greater than : " + TotalTime );
                        return false;
                    }
                    else{
                        $("#ErrortxtTotalDuration").html("");
                    }
                }
            });

            var SelectedDay = $('#OutDoorCompanyType').val();
            var Duration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyShortHrs));
            var IstHalfDuration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyIstHalfDuration));
            var IIndHalfDuration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyIIndHalfDuration));
            var FullDayDuration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyFullDayDuration));
            if(SelectedDay == "Full Day" )
            {
                debugger;
                var ShiftId = $("#ddlShift").val();
                //$("#txtToDate").prop("disabled", false);
                $("#txtToDate").prop("readonly", false);
                document.querySelector('#txtToDate').style.backgroundColor = '';
                $.ajax({
                    async: true,
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: 'application/json; charset=utf-8',
                    url: '@Url.Action("App_OutDoorType", "App_Attendance_Outdoor", new { area = "App" })',
                    data: { DayType:"Full Day",ShiftId: ShiftId },
                    success: function (data){
                        debugger;
                        var SetData = Object.values(data[0]);

                        $('#txtFromTime').val(SetData[0].Value);
                        $('#txtToTime').val(SetData[1].Value);
                        $('#txtTotalDuration').val(SetData[2].Value);

                        //Ashafak Added
                        var TotalTime = $('#txtTotalMinutes').val();
                        var GetTotalTime=TotalTime.replaceAll("Min", "");
                        var SetTotalTime =Number(GetTotalTime);
                        var TotalDuration = $('#txtTotalDuration').val();
                        if(TotalDuration>SetTotalTime)
                        {
                            $("#ErrortxtTotalDuration").html("Total duration not greater than : " + TotalTime );
                            return false;
                        }
                        else{
                            $("#ErrortxtTotalDuration").html("");
                        }
                        // $('#txtTotalDuration').val(b);
                    },
                });
                $("#txtTotalDays").val('1')
                $("#txtFromDate").val(dateString);
                $("#txtToDate").val(dateString);
                $("#txtTotalMinutes").val(FullDayDuration);
                document.querySelector('#txtToDate').style.backgroundColor = '';
                //$("#ddlDirecation").prop("disabled", true);
                $("#txtTotalMinutes").prop("readonly", true);
                $("#txtToDate").attr('readOnly', false);
            }
            if(SelectedDay ==  "1st Half" )
            {
                var ShiftId = $("#ddlShift").val();
                $.ajax({
                    async: true,
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: 'application/json; charset=utf-8',
                    url: '@Url.Action("App_OutDoorType", "App_Attendance_Outdoor", new { area = "App" })',
                    data: { DayType:"1st Half",ShiftId: ShiftId },
                    success: function (data){
                        debugger;
