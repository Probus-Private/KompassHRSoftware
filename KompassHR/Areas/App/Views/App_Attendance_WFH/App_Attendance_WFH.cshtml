            $("#FromTime").removeClass('error');
            $("#txtToDate").removeClass('error');
            $("#ToTime").removeClass('error');
            return false;
        }
        var FromTime = $("#FromTime").val();
        var ToTime = $("#ToTime").val();
        if (FromTime >= ToTime) {
            $('#ErrorToTime').html("To time should be greater than from time");
            return false;
        }else if(FromTime < ToTime){
            $('#ErrorToTime ,#ErrorFromTime').html("");
        }
        else {
            $('#ErrorToTime').html("");
        }
        var StartDate= document.getElementById('txtFromDate').value;
        var EndDate= document.getElementById('txtToDate').value;
        if(StartDate > EndDate){
            $('#ErrortxtToDate').html("To Date should be greater than from date");
            return false;
        }
        else
        {
            $('#ErrortxtToDate').html("");
        }


        var EmployeeId = $("#WFHIdEmployeeId").val();
        var WHFType=$("#ddlWfhCompanyShift").val();
        var FromDate=$("#txtFromDate").val();
        var Todate = $("#txtToDate").val();
        var FromTime=$("#FromTime").val();
        var ToTime = $("#ToTime").val();
        var ErrorFromDate=$("#ErrortxtFromDate").text();
        var ErrorToDate = $("#ErrortxtToDate").text();
        //if(ErrorFromDate == 'From Date should be less than to date' || ErrorToDate == 'To Date should be greater than from date' || ErrorFromTime =='From Time should be less than To time' || ErrorToTime == 'To time should be greater than from time')
        if( FromTime > ToTime || ToTime < FromTime || FromDate > Todate )
        {
            return false;
        }

        else{
            $(".Userloaderbg").css("display","flex");
            $.ajax({
                url:"IsWHFExists",
                method:"get",
                data:{EmployeeId:EmployeeId,WHFType:WHFType,FromDate:FromDate,Todate:Todate,FromTime:FromTime,ToTime:ToTime}, //AdditionalNotifyPerson:AdditionalNotifyPerson,
                success:function(response){
                    debugger;
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon=="error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        return false;
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                })
                                $(".Userloaderbg").css("display","none");
                            }
                        }
                        return false;
                    }
                    else{
                        $("#SaveWorkFromHome").submit();
                    }
                }
            });
        }

    });

