    $("#txtFromDate").change(function(){
        debugger;
        var SelectedDay = $('#ddlWfhCompanyShift').val();
        if(SelectedDay ==  "1st Half" )
        {
            $("#txtToDate").val("");
            var GetfromDate=$("#txtFromDate").val().toString("yyyy-MM-dd");
            $("#txtToDate").val(GetfromDate);
        }
        if(SelectedDay ==  "2nd Half" )
        {
            $("#txtToDate").val("");
            var GetfromDate=$("#txtFromDate").val().toString("yyyy-MM-dd");
            $("#txtToDate").val(GetfromDate);
        }
        var StartDate= document.getElementById('txtFromDate').value;
        var EndDate= document.getElementById('txtToDate').value;
        var sDate = new Date(StartDate);
        var eDate = new Date(EndDate);
        var Time = Math.abs(eDate - sDate);
        var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;
        $("#txtTotalDay").val(days);
        if(EndDate == "" && EndDate ==null){
            $("#ErrortxtFromDate").html("");
        }else if(StartDate > EndDate){
            $('#ErrortxtFromDate').html("From Date should be less than to date");
            return false;
        }else if(StartDate=>EndDate){
            $('#ErrortxtToDate ,#ErrortxtFromDate').html("");
            return false;
        }
        else{
            $('#ErrortxtFromDate').html("");
            return false;
        }



    })

