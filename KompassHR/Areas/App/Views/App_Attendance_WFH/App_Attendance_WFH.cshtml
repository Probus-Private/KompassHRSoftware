<script type="text/javascript">
    $(document).ready(function () {
        debugger;
        var GetMinMaxDate = @Html.Raw(Json.Encode(TempData["GetMinMaxDate"]));
        var MinDate = GetMinMaxDate[0].Value;
        var MaxDate = GetMinMaxDate[1].Value;
        var currentDate = new Date();
        //For MinDate Set
        currentDate.setDate(currentDate.getDate() - MinDate); //2 Meanse Currect daye plus 2 days enabled only
        var SetMinDays = currentDate.toISOString().split('T')[0];
        document.getElementById("txtFromDate").setAttribute("min", SetMinDays);
        document.getElementById("txtToDate").setAttribute("min", SetMinDays);
        //For Max Date Set
        var currentDate1 = new Date();
        currentDate1.setDate(currentDate1.getDate() + MaxDate);
        var SetMaxDays = currentDate1.toISOString().split('T')[0];
        document.getElementById("txtFromDate").setAttribute("max", SetMaxDays);
        document.getElementById("txtToDate").setAttribute("max", SetMaxDays);


        $("#WFHIdEmployeeId").select2();



        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];

        $('#ddlWfhCompanyShift').change(function () {
            debugger;
            var SelectedDay = $('#ddlWfhCompanyShift').val();
            $("#txtToDate").removeAttr('readonly', true);
            document.querySelector('#txtToDate').style.backgroundColor = '';
            if(SelectedDay == "Full Day" )
            {
                var ShiftId = $("#ddlShift").val();
                $.ajax({
                    async: true,
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: 'application/json; charset=utf-8',
                    url: 'WorkFromHomeType',
                    data: { DayType:"Full Day",ShiftId: ShiftId },
                    success: function (data){
                        debugger;
                        var SetData = Object.values(data[0]);
                        var a = Object.values(SetData[0]);
                        var b = Object.values(SetData[1]);
                        var duration = Object.values(SetData[2]);
                        document.getElementById("FromTime").value = a[1];
                        document.getElementById("ToTime").value = b[1];
                    },

                });
                $("#txtFromDate").val(dateString);
                $("#txtToDate").val(dateString);
            }
            if(SelectedDay ==  "1st Half" )
            {
                $("#txtFromDate").val(dateString);
                $("#txtToDate").val(dateString);
                $("#txtToDate").attr('readonly', true);
                document.querySelector('#txtToDate').style.backgroundColor = '#e9ecef';

                var ShiftId = $("#ddlShift").val();
                $.ajax({
                    async: true,
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: 'application/json; charset=utf-8',
                    url: 'WorkFromHomeType',
                    data: { DayType:"1st Half",ShiftId: ShiftId },
                    success: function (data){
                        debugger;
                        var SetData = Object.values(data[0]);
                        var a = Object.values(SetData[0]);
                        var b = Object.values(SetData[1]);
                        var duration = Object.values(SetData[2]);
                        document.getElementById("FromTime").value = a[1];
                        document.getElementById("ToTime").value = b[1];
                    },

                });
                //$("#txtFromDate").val(dateString);
                // $("#txtToDate").val(dateString);

            }
            if(SelectedDay ==  "2nd Half")
            {
                $("#txtFromDate").val(dateString);
                $("#txtToDate").val(dateString);
                $("#txtToDate").attr('readonly', true);
                document.querySelector('#txtToDate').style.backgroundColor = '#e9ecef';
                var GetfromDate=$("#txtFromDate").val().toString("yyyy-MM-dd");
                $("#txtToDate").val(GetfromDate);
                var ShiftId = $("#ddlShift").val();
                $.ajax({
                    async: true,
                    type: 'GET',
                    dataType: 'JSON',
                    url: 'WorkFromHomeType',
                    data: { DayType:"2nd Half",ShiftId: ShiftId },
                    success: function (data){
                        debugger;
                        var SetData = Object.values(data[0]);
                        var a = Object.values(SetData[0]);
                        var b = Object.values(SetData[1]);
                        var duration = Object.values(SetData[2]);
                        document.getElementById("FromTime").value = a[1];
                        document.getElementById("ToTime").value = b[1];
                    },

                });
                // $("#txtFromDate").val(dateString);
                //$("#txtToDate").val(dateString);
            }

        });

        $("#formReset").click(function () {
            $("#SaveWorkFromHome")[0].reset();
        });

    });//ready Funcation
</script>

<script>

    function btnGetLists(){
        var url = '@Url.Action("App_Attendance_WFH_ApprovalandrejectList", "App_Attendance_WFH")';
        window.location.href = url;
    }
    function DeleteOutDoor(WFHId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "App_Attendance_WFH")?WFHId_Encrypted=' + WFHId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


    jQuery.validator.addMethod(
     "regex",
      function(value, element, regexp) {
          if (regexp.constructor != RegExp)
              regexp = new RegExp(regexp);
          else if (regexp.global)
              regexp.lastIndex = 0;
          return this.optional(element) || regexp.test(value);
      },"erreur expression reguliere"
  );

    $('#SaveWorkFromHome').validate({
        rules: {
            WFHShiftId:{
                required: true,
            },
            WFHIdEmployeeId: {
                required: true,
            },
            ddlWfhCompanyShift:{
                required: true,
            },
            FromDate:{
                required: true,
            },
            ToDate:{
                required: true,
            },
            FromTime:{
                required: true,
            },
            ToTime:{
                required: true,
            },
            Reason:{
                required: true,
            }

        },
        messages: {
            WFHShiftId:{
                required: "Please select shift",
            },
            WFHIdEmployeeId: {
                required: "Please select the Employee Name",
            },
            ddlWfhCompanyShift: {
                required: "Wfh type is required",
            },
