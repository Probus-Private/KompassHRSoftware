<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    .profile-card {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .profile-card .header {
            padding: 15px;
            position: relative;
            color: white;
        }

    .org-level {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.4);
