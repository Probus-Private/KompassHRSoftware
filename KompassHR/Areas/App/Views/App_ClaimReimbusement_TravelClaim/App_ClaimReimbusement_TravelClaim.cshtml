                    } else if (data.error) {
                        alert(data.error); // e.g. SessionExpired or AccessDenied
                    }
                },
                error: function (xhr) {
                    console.log(xhr.responseText);
                }
            });

        })



        $("#txtTotalKMAmount,#txtTotalKM,#txtTransportTicketAmount,#txtFoodAmount,#txtHotelLodgingAmount,#txtConveyance,#txtOtherA,#txtOtherB").keyup(function (e) {
            debugger;

            $("#ErrortxtTotalKMAmount").html("");
            // var TotalAmount = $("#txtTotalAmount").val(AllTotal);
            var PerKMRate = Number($("#txtPerKMRate").val());
            var TotalKMAmount = Number($("#txtTotalKMAmount").val());
            var TotakKMRate = PerKMRate * TotalKMAmount;
            $("#txtTotalKM").val(TotakKMRate);

            var TotalKM = Number($("#txtTotalKM").val());
            var TransportTicketAmount = Number($("#txtTransportTicketAmount").val());
            var FoodAmount = Number($("#txtFoodAmount").val());
            var HotelLodgingAmount = Number($("#txtHotelLodgingAmount").val());
            var LocalConveyanceAmount = Number($("#txtConveyance").val());
            var Other1Amount = Number($("#txtOtherA").val());
            var Other2Amount = Number($("#txtOtherB").val());

            var AllTotal = TotalKM + TransportTicketAmount + FoodAmount + HotelLodgingAmount + LocalConveyanceAmount + Other1Amount + Other2Amount;
            var AllTotalRoundUp = Math.round(AllTotal);
            $("#txtTotalAmount").val(AllTotalRoundUp);
        });

        $("#formReset").click(function () {
            $("#FormTravelClaim")[0].reset()
        });
    });

    var date = new Date();
    var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
