<script>
    function ResetFile(Origin) {
        debugger
        var a = Origin; // Correct concatenation

        let allowedExtension = [
            'image/jpeg',
            'image/jpg',
            'image/png',
            'application/pdf',
            'application/msword', // .doc
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document', // .docx
            'application/zip', // .zip
            'application/x-zip-compressed', // Some browsers use this for ZIP
            'multipart/x-zip' // Additional MIME type for ZIP
        ];

        let maxSize = 3 * 1024 * 1024; // 3 MB in bytes

        let fileInput = document.getElementById(a);

        if (!fileInput || !fileInput.files.length) {
            Swal.fire({
                icon: "error",
                text: "No file selected.",
            });
            return;
        }

        let file = fileInput.files[0];
        let type = file.type;
        let size = file.size;

        // Check file type
        if (allowedExtension.indexOf(type) === -1) {
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf/docx/doc/zip",
            });
            fileInput.value = null;
            return;
        }

        // Check file size
        if (size > maxSize) {
            Swal.fire({
                icon: "error",
                text: "File size should not exceed 3 MB.",
            });
            fileInput.value = null;
            return;
        }
    }
</script>

<script>
    document.querySelectorAll(".file-validation").forEach(function (input) {
        input.addEventListener("change", function () {
            const allowedTypes = [
                "image/jpeg",
                "image/jpg",
                "image/png",
                "application/pdf"
            ];
            const file = this.files[0];
            if (file && !allowedTypes.includes(file.type)) {
                Swal.fire({    
                    text: 'Only Images and PDF files are allowed!',
                    icon: 'error',
                    allowOutsideClick: false
                });
                this.value = ""; // reset file input
            }
        });
    });

</script>



