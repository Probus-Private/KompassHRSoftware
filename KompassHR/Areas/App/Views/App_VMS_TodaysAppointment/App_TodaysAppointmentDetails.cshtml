
@{
    ViewBag.Title = "App_TodaysAppointmentDetails";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}



<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }

    .pace-running {
        background-color: #fff;
    }
</style>

<style>
    /* Fixed circular "+" button for all screen sizes */
    .mobile-fixed-add-btn {
        position: fixed;
        bottom: 15px;
        right: 15px;
        z-index: 1050;
        width: 50px;
        height: 50px;
    }

        .mobile-fixed-add-btn .btn {
            width: 100%;
            height: 100%;
            padding: 0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }
</style>

<div class="flex flex-wrap gap-2 justify-center max-w-6xl mx-auto px-2">
    @{
        var Visitor_appointment = ViewBag.Visitor_appointment as IEnumerable<dynamic>;
        var d = Visitor_appointment?.FirstOrDefault();
    }

    @{
        var VisitorAppointmentID = d?.VisitorAppointmentID ?? 0;

        string topBorderColor = "green-500";
        string bgClass = $"bg-{topBorderColor}";
        string borderClass = $"border-t-4 border-{topBorderColor}";
    }

    <div class="bg-white rounded-xl shadow-md p-3 w-full sm:w-1/2 lg:w-1/3 @borderClass">
        @*<div class="bg-white rounded-xl shadow-md p-4 w-full sm:w-1/2 lg:w-1/3">*@
        <!-- Top Section -->
        <div class="flex justify-between items-start mb-3">
            <div>
                <div class="text-base font-semibold text-gray-800">
                    @(d != null ? $"VMS" : "")
                </div>
                @*<div class="text-sm text-gray-500">@d.PendingDay</div>*@
            </div>
            <div class="text-right">
                <div class="text-xs text-gray-500 mt-1">@d.ApprovedDay</div>
            </div>
        </div>

        <!-- Table-style Layout -->
        <table class="w-full text-sm text-gray-700">
            <tbody>
                <tr>
                    <td class="py-2 w-5"><i class="fa-solid fa-hashtag text-purple-600"></i></td>
                    <td class="font-medium">Doc No.</td>
                    <td class="px-2">:</td>
                    <td class="truncate">@d.DocNo</td>
                </tr>

                <tr>
                    <td class="py-2 w-5"><i class="fa-solid fa-calendar-days text-purple-600"></i></td>
                    <td class="font-medium">Applied On</td>
                    <td class="px-2">:</td>
                    <td class="truncate">@d.CreatedDate</td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-id-card text-purple-600"></i></td>
                    <td class="font-medium">Host Name</td>
                    <td class="px-2">:</td>
                    <td>@d.HostName</td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-building text-orange-600"></i></td>
                    <td class="font-medium">Business Unit</td>
                    <td class="px-2">:</td>
                    <td>@d.VisitingBusinessUnit</td>
                </tr>
                <tr>
                    <td class="py-2 w-5"><i class="fa-solid fa-user-tie text-blue-600"></i></td>
                    <td class="font-medium">Visitor Name</td>
                    <td class="px-2">:</td>
                    <td class="truncate">@d.VisitorName</td>
                </tr>


                <tr>
                    <td class="py-2"><i class="fa-solid fa-calendar-days text-amber-600"></i></td>
                    <td class="font-medium">For Date</td>
                    <td class="px-2">:</td>
                    <td class="truncate">
                        @(d.AppointmentDate?.ToString("dd-MM-yyyy"))

                    </td>
                </tr>

                <tr>
                    <td class="py-2"><i class="fa-solid fa-clock text-amber-600"></i></td>
                    <td class="font-medium">For Time</td>
                    <td class="px-2">:</td>
                    <td>@d.AppointmentTime</td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-cash-register text-green-500"></i></td>
                    <td class="font-medium">Visitor Type</td>
                    <td class="px-2">:</td>
                    <td class="truncate">
                        @d.VisitorType
                    </td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-bullseye text-blue-500"></i></td>
                    <td class="font-medium">Purpose</td>
                    <td class="px-2">:</td>
                    <td class="truncate">
                        @d.Purpose
                    </td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-user-tag text-amber-600"></i></td>
                    <td class="font-medium">Designation</td>
                    <td class="px-2">:</td>
                    <td>@d.Designation</td>
                </tr>

                <tr>
                    <td class="py-2"><i class="fa-solid fa-mobile-screen text-green-500"></i></td>
                    <td class="font-medium">Mobile</td>
                    <td class="px-2">:</td>
                    <td class="truncate">
                        @d.MobileNo
                    </td>
                </tr>

                <tr>
                    <td class="py-2"><i class="fa-solid fa-envelope text-green-500"></i></td>
                    <td class="font-medium">EmailID</td>
                    <td class="px-2">:</td>
                    <td class="truncate">
                        @d.EmailID
                    </td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-users text-pink-600"></i></td>
                    <td class="font-medium">Addition Person</td>
                    <td class="px-2">:</td>
                    <td>@d.AdditionPerson</td>
                </tr>

                <tr>
                    <td class="py-2"><i class="fa-solid fa-map-marker-alt text-pink-600"></i></td>
                    <td class="font-medium">Meeting Location</td>
                    <td class="px-2">:</td>
                    <td>@d.MeetingLocation</td>
                </tr>

                <tr class="border-b">
                    <td class="py-2"><i class="fa-solid fa-lightbulb text-yellow-600"></i></td>
                    <td class="font-medium">Reason</td>
                    <td class="px-2">:</td>
                    <td>@d.VisitorRemark</td>
                </tr>
            </tbody>
        </table>

        <!-- Footer Buttons -->
        <div class="flex justify-end gap-3 mt-2">
            <button type="button" class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50" id="btnGetList" onclick="btnGetLists();">
                <i class="fa-solid fa-share-from-square"></i> List
            </button>
        </div>
    </div>
</div>


<script>
    function btnGetLists() {
        var url = '@Url.Action("App_VMS_TodaysAppointment", "App_VMS_TodaysAppointment")';
        window.location.href = url;
    }
</script>
