<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>

<script>
    function DeleteRequest(VisitorAppointmentID_Encrypted,Status) {
        debugger;
        if(Status!="Pending")
        {
            Swal.fire({
                icon: "error",
                text: "Approved/Rejected request can't delete",
                allowOutsideClick: false
            });
            return false;
        }
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: false

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("App_Delete", "APP_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>


<script>
    function UpdateVisitorAppointment(VisitorAppointmentID_Encrypted ,CmpId) {
        var url = '@Url.Action("APP_VMS_VisitorAppointment", "APP_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted + '&CmpId='+ CmpId;;
        window.location.href = url;    }
</script>






