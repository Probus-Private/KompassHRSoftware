
@{
    ViewBag.Title = "App_GetList";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}








<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    .profile-card {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .profile-card .header {
            padding: 15px;
            position: relative;
            color: white;
        }

    .org-level {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.4);
        padding: 4px 8px;
        border-radius: 10px;
        font-size: 12px;
    }

    .profile-card .content {
        padding: 15px;
    }

    .profile-card .name {
        font-size: 16px;
        font-weight: 600;
    }

    .profile-card .subtitle {
        font-size: 14px;
        color: #555;
        margin-bottom: 5px;
    }



    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }
</style>

<style>
    /* Fixed circular "+" button for all screen sizes */
    .mobile-fixed-add-btn {
        position: fixed;
        bottom: 15px;
        right: 15px;
        z-index: 1050;
        width: 50px;
        height: 50px;
    }

        .mobile-fixed-add-btn .btn {
            width: 100%;
            height: 100%;
            padding: 0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }
</style>

<div class="col-md-2">
    <a href="@Url.Action("APP_VMS_VisitorAppointment", "APP_VMS_VisitorAppointment", new { area = "App", ScreenId = 146 })" class="mobile-fixed-add-btn">
        <button type="button" class="btn btn-primary shadow">
            <i class="fa-solid fa-plus fa-lg"></i>
        </button>
    </a>
</div>
<div class="container mx-auto px-2 py-2">
    <!-- Search Input -->
    <div class="flex justify-center mb-2">
        <div class="w-full max-w-md">
            <input type="text" id="searchDate" class="form-control w-full px-4 py-2 border rounded-md"
                   placeholder="Search by Date (e.g., 20/Aug/2024)">
        </div>
    </div>

    <!-- Card Grid -->
    <div class="flex flex-wrap gap-2 justify-center">
        @{
            var VisitorAppointment = ViewBag.VisitorAppointment as List<dynamic>;
        }
        @foreach (var d in VisitorAppointment)
        {
            var VisitorAppointmentID = d?.VisitorAppointmentID ?? 0;
            //var cancelStatus = d?.CancelStatus;
            var status = d?.Status ?? "";
            string topBorderColor = d.Status != null && d.Status.Contains("Approved") ? "green-500"
                    : d.Status != null && d.Status.Contains("Rejected") ? "red-500"
                    : d.Status != null && d.Status.Contains("Pending") ? "orange"
                    : "";
            string bgClass = $"bg-{topBorderColor}";
            string borderClass = $"border-t-4 border-{topBorderColor}";

            <div class="bg-white rounded-xl shadow-md p-3 w-full max-w-full sm:max-w-md lg:max-w-sm mx-auto @borderClass leave-card">
                <!-- Top Section -->
                <div class="flex justify-between items-start mb-1">
                    <div>
                        <div class="text-base font-semibold text-gray-800">
                            @(d != null ? $"VMS" : "")
                        </div>
                        <div class="text-sm text-gray-500">@d.PendingDay</div>
                    </div>
                    <div class="flex items-center justify-end space-x-2">
                        <div>
                            <div class="text-white px-4 py-1 rounded-full text-sm font-semibold @bgClass">
                                @d.Status
                            </div>
                            <div class="text-xs text-gray-500 mt-1 text-right">
                                @d.ApprovedDay
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Table-style Layout -->
                <table class="w-full text-sm text-gray-700">
                    <tbody>
                        <tr>
                            <td class="py-2 w-1/4"><i class="fas fa-calendar-alt text-blue-600"></i></td>
                            <td class="font-medium w-1/3">Appointment Date/Time</td>
                            <td class="px-2">:</td>
                            <td class="truncate leave-date">@d.AppointmentDate (@d.AppointmentTime)</td>
                        </tr>

                        <tr>
                            <td class="py-2"><i class="fas fa-briefcase text-purple-600"></i></td>
                            <td class="font-medium">Visitor Name</td>
                            <td class="px-2">:</td>
                            <td>@d.VisitorName</td>
                        </tr>
                        <tr>
                            <td class="py-2"><i class="fas fa-user-tie text-indigo-600"></i></td>
                            <td class="font-medium">Approver</td>
                            <td class="px-2">:</td>
                            <td>@d.ApproverName</td>
                        </tr>
                        <tr class="border-b">
                            <td class="py-2"><i class="fas fa-lightbulb text-yellow-500"></i></td>
                            <td class="font-medium">Reason</td>
                            <td class="px-2">:</td>
                            <td class="truncate">@d.VisitorRemark</td>
                        </tr>
                    </tbody>
                </table>

                <!-- Footer Buttons -->
                <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                    <i class="fa-solid fa-sitemap fa-2xl cursor-pointer" onclick="ApproveStatus(@d.VisitorAppointmentID)"></i>


                    @*<button onclick="DeleteRequest('@d.VisitorAppointmentID_Encrypted','@d.Status')"
                            class="text-red-600 border border-red-500 px-1 py-2 rounded-md hover:bg-red-50">
                        <i class="fa fa-trash"></i> Delete
                    </button>*@



                    @*<a href="#modal-dialogForHoldReject1"
                       onclick="UpdateVisitorAppointment('@d.VisitorAppointmentID_Encrypted','@d.CmpId')"
                       class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                        <i class="fa fa-edit"></i> Update
                    </a>*@

                    <a href="@Url.Action("App_VMSDetails", "APP_VMS_VisitorAppointment", new { VisitorAppointmentID_Encrypted = d.VisitorAppointmentID_Encrypted })"
                       class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                        <i class="fa-solid fa-bars"></i> View More
                    </a>
                </div>

            </div>
        }
    </div>
</div>



<div class="modal fade" id="RequestInfoModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body p-3" style="position: relative;">
                <!-- Close Button -->
                <div class="position-absolute top-0 end-0 m-2" data-bs-dismiss="modal">
                    <button type="button" class="btn btn-sm btn-danger rounded-circle" id="CloseModel" aria-label="Close">
                        <i class="fa fa-xmark"></i>
                    </button>
                </div>
                <!-- Content -->
                <div id="timelineMainDiv" class="mt-4">
                    <!-- Dynamic timeline content here -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function ApproveStatus(DocId) {
        debugger
        $.ajax({
            url: '@Url.Action("RequestStatus", "APP_VMS_VisitorAppointment")',
            method: "GET",
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            data: { DocId: DocId },
            success: function (response) {
                debugger
                $('#RequestInfoModal').modal('show');
                var data = JSON.parse(response);
                var timelineHtml = '';
                for (var i = 0; i < data.length; i++) {
                    var icon = '';
                    var iconColor='';
                    var textColor = '';
                    if (data[i][5].Value === 'success') {
                        icon = '✔';
                        iconColor ="iconGreen";
                        textColor = 'Green';
                    } else if (data[i][5].Value === 'error') {
                        icon = '✘';
                        iconColor ="iconRed";
                        textColor = 'Red';
                    } else {
                        icon = '⏳';
                        iconColor ="iconRed";
                        textColor = 'Black';
                    }
                    timelineHtml += '<div class="timeline-item">' +
                                '<div class="' + iconColor + '"><span class="timelineIcon">' + icon + '</span></div>' +
                                '<div class="text">' +
                                '<b><p class="timelineRemark" style="color:' + textColor + ';">' + data[i][2].Value + '</p></b>' +
                                '<small class="timelineEmployeeName" style="color:Black;">' + data[i][3].Value + '</small><br />' +
                                 '<small class="timelineDate" style="color:Black;">' + data[i][1].Value + '</small>' +
                                '</div>' +
                                '</div>';
                }
                $('#timelineMainDiv').html(timelineHtml);
            }
        });
    }

</script>




<style>
    .timeline {
        max-width: 400px;
        background-color: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
