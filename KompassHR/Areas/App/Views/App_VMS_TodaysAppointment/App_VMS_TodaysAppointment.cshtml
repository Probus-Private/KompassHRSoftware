
@{
    ViewBag.Title = "App_VMS_TodaysAppointment";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    .profile-card {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .profile-card .header {
            padding: 15px;
            position: relative;
            color: white;
        }

    .org-level {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.4);
        padding: 4px 8px;
        border-radius: 10px;
        font-size: 12px;
    }

    .profile-card .content {
        padding: 15px;
    }

    .profile-card .name {
        font-size: 16px;
        font-weight: 600;
    }

    .profile-card .subtitle {
        font-size: 14px;
        color: #555;
        margin-bottom: 5px;
    }



    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }
</style>

<style>
    /* Fixed circular "+" button for all screen sizes */
    .mobile-fixed-add-btn {
        position: fixed;
        bottom: 15px;
        right: 15px;
        z-index: 1050;
        width: 50px;
        height: 50px;
    }

        .mobile-fixed-add-btn .btn {
            width: 100%;
            height: 100%;
            padding: 0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

    .app {
        background-color: white;
    }
</style>

<style>
    .timeline {
        max-width: 400px;
        background-color: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

        .timeline:before {
            left: 32px;
        }

    .timeline-item {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

    .iconGreen {
        width: 24px;
        height: 24px;
        background-color: green;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .iconRed {
        width: 24px;
        height: 24px;
        background-color: #ff5b57;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .text {
        flex-grow: 1;
    }

        .text p {
            margin: 0;
            font-size: 14px;
        }

        .text small {
            color: gray;
            font-size: 12px;
        }

    .button {
        text-align: center;
        margin-top: 20px;
    }

        .button button {
            background-color: #a8d935;
            border: none;
            padding: 10px 20px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            border-radius: 5px;
        }

            .button button:hover {
                background-color: #8cc62f;
            }
</style>


<div class="container mx-auto px-2 py-2 bg-white">
    <!-- Search Input -->
    <!-- Fixed Search Bar -->
    <div class="fixed top-0 left-0 w-full bg-white z-50 shadow">
        <div class="flex justify-center py-2">
            <div class="w-full max-w-md">
                <input type="text" id="searchDate" class="form-control w-full px-4 py-2 border rounded-md"
                       placeholder="Search by Date (e.g., 20/Aug/2024)">
            </div>
        </div>
    </div>

    <div class="pt-10">
        <div class="flex flex-wrap justify-center gap-2">
            @{
                var VisitorAppointment = ViewBag.VisitorAppointment as List<dynamic>;
            }
            @foreach (var d in VisitorAppointment)
            {
                var VisitorAppointmentID = d?.VisitorAppointmentID ?? 0;
                string topBorderColor = "green-500";
                string bgClass = $"bg-{topBorderColor}";
                string borderClass = $"border-t-4 border-{topBorderColor}";
                <div class="bg-white rounded-xl shadow-md p-3 w-full sm:max-w-md md:max-w-sm border-t-4 @borderClass leave-card">
                    <!-- Top Section -->
                    <div class="flex justify-between items-start mb-1">
                        <div>
                            <div class="text-sm-0"><i class="fa-solid fa-hashtag text-purple-600"></i> Doc No. : @d.DocNo</div>
                            <div class="text-base font-semibold text-gray-800">
                                @(d != null ? $"VMS" : "")
                            </div>

                        </div>
                        <div class="flex items-center justify-end space-x-2">
                            <div>
                                
                                <div class="text-xs text-gray-500 mt-1 text-right">
                                    @d.ApprovedDay
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Table-style Layout -->
                    <table class="w-full text-sm text-gray-700 table-auto">
                        <tbody>
                            <tr class="align-top">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-calendar-alt text-blue-600"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">Appointment Date/Time</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md truncate Fordate">
                                    @d.AppointmentDate (@d.AppointmentTime)
                                </td>
                            </tr>

                            <tr class="align-top">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-briefcase text-purple-600"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">Visitor Name</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md">@d.VisitorName</td>
                            </tr>

                            <tr class="border-b align-top">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-lightbulb text-yellow-500"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">Purpose</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md truncate">@d.Purpose</td>
                            </tr>
                        </tbody>
                    </table>


                    <!-- Footer Buttons -->
                    <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                       
                        <a href="@Url.Action("App_TodaysAppointmentDetails", "App_VMS_TodaysAppointment", new { VisitorAppointmentID_Encrypted = d.VisitorAppointmentID_Encrypted })"
                           class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                            <i class="fa-solid fa-bars"></i> View More
                        </a>
                    </div>

                </div>
            }
        </div>
    </div>

</div>

<div class="modal fade" id="RequestInfoModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body p-3" style="position: relative;">
                <!-- Close Button -->
                <div class="position-absolute top-0 end-0 m-2" data-bs-dismiss="modal">
                    <button type="button" class="btn btn-sm btn-danger rounded-circle" id="CloseModel" aria-label="Close">
                        <i class="fa fa-xmark"></i>
                    </button>
                </div>
                <!-- Content -->
                <div id="timelineMainDiv" class="mt-4">
                    <!-- Dynamic timeline content here -->
                </div>
            </div>
        </div>
    </div>
</div>

@*=====New Code START=================*@
<script>
    document.getElementById('searchDate').addEventListener('input', function () {
        const searchValue = this.value.trim().toLowerCase();
        const cards = document.querySelectorAll('.leave-card');

        cards.forEach(card => {
            const dateElement = card.querySelector('.Fordate');
            const dateText = dateElement ? dateElement.innerText.trim().toLowerCase() : '';

            if (dateText.includes(searchValue)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>
@*=====New Code END===================*@

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>

<script>
    function DeleteRequest(VisitorAppointmentID_Encrypted,Status) {
        debugger;
        if(Status!="Pending")
        {
            Swal.fire({
                icon: "error",
                text: "Approved/Rejected request can't delete",
                allowOutsideClick: false
            });
            return false;
        }
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: false

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("App_Delete", "APP_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>

<script>
    function UpdateVisitorAppointment(VisitorAppointmentID_Encrypted ,CmpId) {
        var url = '@Url.Action("APP_VMS_VisitorAppointment", "APP_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted + '&CmpId='+ CmpId;;
        window.location.href = url;    }
</script>

<script>
    function ApproveStatus(DocId) {
        debugger
        $.ajax({
            url: '@Url.Action("RequestStatus", "APP_VMS_VisitorAppointment")',
            method: "GET",
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            data: { DocId: DocId },
            success: function (response) {
                debugger
                $('#RequestInfoModal').modal('show');
                var data = JSON.parse(response);
                var timelineHtml = '';
                for (var i = 0; i < data.length; i++) {
                    var icon = '';
                    var iconColor='';
                    var textColor = '';
                    if (data[i][5].Value === 'success') {
                        icon = '✔';
                        iconColor ="iconGreen";
                        textColor = 'Green';
                    } else if (data[i][5].Value === 'error') {
                        icon = '✘';
                        iconColor ="iconRed";
                        textColor = 'Red';
                    } else {
                        icon = '⏳';
                        iconColor ="iconRed";
                        textColor = 'Black';
                    }
                    timelineHtml += '<div class="timeline-item">' +
                                '<div class="' + iconColor + '"><span class="timelineIcon">' + icon + '</span></div>' +
                                '<div class="text">' +
                                '<b><p class="timelineRemark" style="color:' + textColor + ';">' + data[i][2].Value + '</p></b>' +
                                '<small class="timelineEmployeeName" style="color:Black;">' + data[i][3].Value + '</small><br />' +
                                 '<small class="timelineDate" style="color:Black;">' + data[i][1].Value + '</small>' +
                                '</div>' +
                                '</div>';
                }
                $('#timelineMainDiv').html(timelineHtml);
            }
        });
    }

</script>






