
@{
    ViewBag.Title = "App_Profile";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }

    .pace-running {
        background-color: #fff;
    }
</style>

<style>
    /* Fixed circular "+" button for all screen sizes */
    .mobile-fixed-add-btn {
        position: fixed;
        bottom: 15px;
        right: 15px;
        z-index: 1050;
        width: 50px;
        height: 50px;
    }

        .mobile-fixed-add-btn .btn {
            width: 100%;
            height: 100%;
            padding: 0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

    .app {
        background-color: white;
    }
</style>




@*<div class="flex flex-wrap gap-2 justify-center max-w-6xl mx-auto px-2">*@
<div class="bg-white min-h-screen flex justify-center">
    <div class="p-4 w-full max-w-2xl mx-auto space-y-3 text-sm text-gray-800">
        <!-- Profile Row -->
        <div class="flex flex-col items-center border-b pb-4">
            @if (!string.IsNullOrEmpty(ViewBag.ProfilePhotoBase64))
            {
                @*<div class="mb-2 flex justify-center">
                        <img src="data:image/jpeg;base64,@ViewBag.ProfilePhotoBase64"
                             alt="Profile Picture"
                             class="block h-28 w-28 rounded-full border border-gray-300 shadow-md" />
                    </div>*@

                <div class="mb-2 flex justify-center">
                    <img src="data:image/jpeg;base64,@ViewBag.ProfilePhotoBase64"
                         alt="Profile Picture"
                         class="block h-28 w-28 rounded-full object-contain border border-gray-300 shadow-md bg-white" />
                </div>
            }
            else
            {
                <div class="mb-2 h-28 w-28 rounded-full bg-indigo-500 text-white flex items-center justify-center text-3xl font-semibold shadow-md">
                    @ViewBag.Profile.Initial
                </div>
            }

            <!-- Name & Employee No -->
            <div class="text-center">
                <div class="text-lg font-semibold text-gray-900">@ViewBag.Profile.EmployeeName</div>
                <div class="text-sm text-gray-600">Employee No :<span class="font-medium">@ViewBag.Profile.EmployeeNo</span></div>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-building text-orange-600 w-5"></i>
            <div class="font-medium w-1/3">Company</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.CompanyName</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-building text-blue-600 w-5"></i>
            <div class="font-medium w-1/3">Business Unit</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.BranchName</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-sitemap text-green-600 w-5"></i>
            <div class="font-medium w-1/3">Department</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.DepartmentName</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-user-tag text-cyan-600 w-5"></i>
            <div class="font-medium w-1/3">Designation</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.DesignationName</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-user-tie text-amber-600 w-5"></i>
            <div class="font-medium w-1/3">Grade</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.GradeName</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-calendar-check text-teal-600 w-5"></i>
            <div class="font-medium w-1/3">Date of Joining</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.JoiningDate</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-briefcase text-indigo-600 w-5"></i>
            <div class="font-medium w-1/3">Experience</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.TotalExperience</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-cake-candles text-pink-600 w-5"></i>
            <div class="font-medium w-1/3">Date of Birth</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.BirthdayDate</div>
        </div>

        @if (@ViewBag.Profile.CountryId == 1)
        {
            <div class="flex items-center gap-3">
            <i class="fa-solid fa-id-card text-slate-700 w-5"></i>
            <div class="font-medium w-1/3">PAN</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.PAN</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-id-badge text-slate-700 w-5"></i>
            <div class="font-medium w-1/3">Aadhaar No</div>
            <div class="w-2/3 whitespace-normal break-words">: @((ViewBag.Profile.AadhaarNo) ?? "-")</div>
        </div>
        }
        

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-phone text-green-700 w-5"></i>
            <div class="font-medium w-1/3">Mobile No</div>
            <div class="w-2/3 whitespace-normal break-words">: @((ViewBag.Profile.PrimaryMobile) ?? "-")</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-envelope text-blue-700 w-5"></i>
            <div class="font-medium w-1/3">Personal Email</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.PersonalEmailId</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-envelope text-orange-700 w-5"></i>
            <div class="font-medium w-1/3">Company Email</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.CompanyMailID</div>
        </div>

        <div class="flex items-center gap-3">
            <i class="fa-solid fa-globe text-green-700 w-5"></i>
            <div class="font-medium w-1/3">Nationality</div>
            <div class="w-2/3 whitespace-normal break-words">: @ViewBag.Profile.Nationality</div>
        </div>
    </div>
</div>
@*</div>*@