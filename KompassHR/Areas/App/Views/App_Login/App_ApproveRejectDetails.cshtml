                var SetUrl = "";
                var SetData = {};

                if (Origin === "GeneralClaim" || Origin === "TravelClaim") {
                    SetUrl = '@Url.Action("ApproveClaimRequest", "App_Login")';
                    SetData = {DocId: DocId, Encrypted: Encrypted,Status: Status,Remark: Remark, ApproveAmount: ApproveAmount, Origin: Origin };
