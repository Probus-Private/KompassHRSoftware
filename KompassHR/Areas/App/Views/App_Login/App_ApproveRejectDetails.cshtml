<script>
    function showTab(tab) {
        const leave = document.getElementById("LeaveType");
        const history = document.getElementById("History");
        const btnLeave = document.getElementById("btnLeaveType");
        const btnHistory = document.getElementById("btnHistory");

        if (tab === "LeaveType") {
            leave.classList.remove("hidden");
            history.classList.add("hidden");

            btnLeave.classList.add("bg-blue-600", "text-white");
            btnLeave.classList.remove("bg-gray-100", "text-gray-700");

            btnHistory.classList.remove("bg-blue-600", "text-white");
            btnHistory.classList.add("bg-gray-100", "text-gray-700");
        } else {
            leave.classList.add("hidden");
            history.classList.remove("hidden");

            btnHistory.classList.add("bg-blue-600", "text-white");
            btnHistory.classList.remove("bg-gray-100", "text-gray-700");

            btnLeave.classList.remove("bg-blue-600", "text-white");
            btnLeave.classList.add("bg-gray-100", "text-gray-700");
        }
    }
</script>

