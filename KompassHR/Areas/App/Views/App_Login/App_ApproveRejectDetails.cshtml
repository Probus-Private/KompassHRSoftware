
@{
    ViewBag.Title = "App_ApproveRejectDetails";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }

    .pace-running {
        background-color: #fff;
    }
</style>

<style>
    /* Fixed circular "+" button for all screen sizes */
    .mobile-fixed-add-btn {
        position: fixed;
        bottom: 15px;
        right: 15px;
        z-index: 1050;
        width: 50px;
        height: 50px;
    }

        .mobile-fixed-add-btn .btn {
            width: 100%;
            height: 100%;
            padding: 0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }
         label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

</style>


<style>
    .icon-hover {
    display: inline-block;
    transition: all 0.2s ease;
    padding: 8px; /* Gives clickable area without visible border */
    border-radius: 50%; /* Makes the hover area circular */
}

.icon-hover:hover {
    background-color: rgba(0, 123, 255, 0.1); /* Light blue tint for download */
    transform: scale(1.15);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

a.text-success.icon-hover:hover {
    background-color: rgba(25, 135, 84, 0.1); /* Light green tint for view */
}
</style>

<div class="max-w-3xl mx-auto bg-white min-h-screen">
    <!-- Sticky Header with Tabs -->
    <div class="fixed top-0 left-0 w-full bg-white z-50 shadow">
        <div class="flex justify-center py-1">
            <!-- Centering buttons using flex -->
            <div class="flex gap-3 justify-center w-full max-w-md">
                <button onclick="showTab('LeaveType')" id="btnLeaveType"
                        class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap bg-blue-600 text-white transition">
                    @TempData["Origin"] Details
                </button>
                <button onclick="showTab('History')" id="btnHistory"
                        class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap bg-gray-100 text-gray-700 hover:bg-gray-200 transition">
                    History
                </button>
            </div>
        </div>
    </div>

<div class="pt-10">
        <!-- Leave Type Content -->
        <div id="LeaveType" class="flex flex-wrap justify-center gap-2 p-2 bg-white">
            @{
                string Origin = TempData["Origin"] as string;
                IEnumerable<dynamic> GetList = null;
                dynamic d = null;

                // Check which list is not null or empty
                var leaveList = ViewBag.GetLeaveDetails as IEnumerable<dynamic>;
                var outdoorList = ViewBag.GetOutDoorDetails as IEnumerable<dynamic>;
                var punchmissList = ViewBag.GetPunchMissingDetails as IEnumerable<dynamic>;
                var shiftchangeList = ViewBag.GetShiftChangeDetails as IEnumerable<dynamic>;
                var workfromhomeList = ViewBag.GetWorkFromHomeDetails as IEnumerable<dynamic>;
                var coffList = ViewBag.GetCoffDetails as IEnumerable<dynamic>;
                var personalgatepassList = ViewBag.GetPersonalGatepassDetails as IEnumerable<dynamic>;
                var GetTravelClaimList = ViewBag.GetTravelClaimDetails as IEnumerable<dynamic>;
                var GetGeneralClaimList = ViewBag.GetGeneralClaimDetails as IEnumerable<dynamic>;
                if (leaveList != null && leaveList.Any())
                {
                    GetList = leaveList;
                }
                else if (outdoorList != null && outdoorList.Any())
                {
                    GetList = outdoorList;
                }
                else if (punchmissList != null && punchmissList.Any())
                {
                    GetList = punchmissList;
                }
                else if (shiftchangeList != null && shiftchangeList.Any())
                {
                    GetList = shiftchangeList;
                }
                else if (workfromhomeList != null && workfromhomeList.Any())
                {
                    GetList = workfromhomeList;
                }
                else if (personalgatepassList != null && personalgatepassList.Any())
                {
                    GetList = personalgatepassList;
                }
                else if (coffList != null && coffList.Any())
                {
                    GetList = coffList;
                }
                else if (GetTravelClaimList != null && GetTravelClaimList.Any())
                {
                    GetList = GetTravelClaimList;
                }
                else if (GetGeneralClaimList != null && GetGeneralClaimList.Any())
                {
                    GetList = GetGeneralClaimList;
                }
                d = GetList?.FirstOrDefault();
                var GetColors = new List<string> { "red-400", "green-400", "blue-400", "purple-400", "yellow-400", "pink-400", "teal", "indigo", "orange" };
                var rnd = new Random(Guid.NewGuid().GetHashCode());
                var randomColor = GetColors[rnd.Next(GetColors.Count)];
                string color = $"bg-{randomColor}";
                string borderClass = $"border-t-4 border-{randomColor}";
            }
            @switch (Origin)
            {
                case "Leave":
                    if (d != null)
                    {
                    <!-- ====================== LEAVE DETAILS START ==============================-->
                        <div class="bg-white rounded-xl shadow-md w-full max-w-md @borderClass p-3 search-card">
                            <!-- Header -->
                            <input type="hidden" class="hdnEncryptedId" value="@d.LeaveMasterId_Encrypted" />
                            <input type="hidden" class="hdnDocId" value="@d.LeaveMasterId" />
                            <input type="hidden" class="hdnOrigin" value="@d.Origin" />
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 @color text-white rounded-full flex items-center justify-center font-semibold text-lg">
                                        @(d.EmployeeName != null ? d.EmployeeName.Substring(0, 1) : "?")
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-800">@d.EmployeeName</div>
                                        <div class="text-xs text-gray-500">@d.EmployeeNo</div>
                                    </div>
                                </div>
                                <div class="text-right text-xs text-gray-500">
                                    <div>Applyed On</div>
                                    <div>@(d.CreatedDate != null ? d.CreatedDate.ToString("dd/MM/yyyy") : "-")</div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-gray-700">
                                    <tbody>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-file-lines text-blue-500 mr-1"></i> Doc No
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.DocNo</td>
                                        </tr>

                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-id-badge text-green-500 mr-1"></i> Employee ID
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.EmployeeId</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-calendar-day text-purple-500 mr-1"></i> From Date
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.FromDate</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-calendar-check text-emerald-500 mr-1"></i> To Date
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.ToDate</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-clock text-indigo-500 mr-1"></i> Leave Day Type
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.LeaveMasterDayType</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-leaf text-teal-500 mr-1"></i> Leave Type
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.LeaveMasterId</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-briefcase text-pink-500 mr-1"></i> Shift Name
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.LeaveMasterShiftName</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-hourglass-half text-yellow-500 mr-1"></i> Total Days
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.TotalDays</td>
                                        </tr>
                                        <tr>
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-comment-dots text-red-500 mr-1"></i> Reason
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.Reason</td>
                                        </tr>
                                        <tr class="border-b">
                                            <td class="py-1 font-medium text-gray-700">
                                                <i class="fa-solid fa-info-circle text-gray-600 mr-1"></i> Status
                                            </td>
                                            <td class="px-1">:</td>
                                            <td>@d.Status</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Footer Buttons -->
                            <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                                <a href="#modal-dialogForApproval1" id="btnmodal-dialog" onclick="Approved(this, 'Approved')"
                                   class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                    <i class="fa-solid fa-check-double"></i> Approve
                                </a>

                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule(this)" id="btnmodal-dialog1"
                                        class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50">
                                    <i class="fa fa-trash"></i> Reject
                                </button>
                            </div>
                        </div>
                    <!-- ====================== LEAVE DETAILS END ==============================-->
                    }
                    else
                    {
                        <div class="text-red-600 text-sm font-medium">No data found for Leave request.</div>
                    }
                    break;


                case "Outdoor":
                    if (d != null)
                    {
                    <!-- ====================== OUTDOOR DETAILS START ==============================-->
                        <div class="bg-white rounded-xl shadow-md w-full max-w-md @borderClass p-3 search-card">
                            <!-- Header -->
                            <input type="hidden" class="hdnEncryptedId" value="@d.OutDoorCompanyId_Encrypted" />
                            <input type="hidden" class="hdnDocId" value="@d.OutDoorCompanyId" />
                            <input type="hidden" class="hdnOrigin" value="@d.Origin" />
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 @color text-white rounded-full flex items-center justify-center font-semibold text-lg">
                                        @d.EmployeeName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-800">@d.EmployeeName</div>
                                        <div class="text-xs text-gray-500">@d.EmployeeNo</div>
                                    </div>
                                </div>
                                <div class="text-right text-xs text-gray-500">
                                    <div>Applied On</div>
                                    <div>@d.CreatedDate.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                            <!-- Body -->
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-gray-700">
                                    <tbody>
                                        <tr><td class="py-1"><i class="fas fa-solid fa-hashtag text-purple-600"></i></td><td class="font-medium">Doc No.</td><td class="px-1">:</td><td>@d.DocNo</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-user-tie text-blue-600"></i></td><td class="font-medium">Type</td><td class="px-1">:</td><td>@d.OutDoorCompanyType</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-briefcase text-purple-600"></i></td><td class="font-medium">Shift Name</td><td class="px-1">:</td><td>@d.OutDoorCompanyShiftName</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-alt text-orange-600"></i></td><td class="font-medium">From Date</td><td class="px-1">:</td><td>@d.FromDate</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-alt text-yellow-600"></i></td><td class="font-medium">To Date</td><td class="px-1">:</td><td>@d.ToDate</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-clock text-green-600"></i></td><td class="font-medium">Total Days/Hrs.</td><td class="px-1">:</td><td>@d.TotalDays</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-comment text-indigo-600"></i></td><td class="font-medium">Reason</td><td class="px-1">:</td><td>@d.Reason</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-moon text-pink-600"></i></td><td class="font-medium">Night Shift</td><td class="px-1">:</td><td>@d.IsNightShift</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-info-circle text-teal-600"></i></td><td class="font-medium">Status</td><td class="px-1">:</td><td>@d.Status</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-user-check text-cyan-600"></i></td><td class="font-medium">Approve By</td><td class="px-1">:</td><td>@d.ApproveRejectBy</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-check text-blue-600"></i></td><td class="font-medium">Approved Date</td><td class="px-1">:</td><td>@d.ApproveRejectDate</td></tr>
                                        <tr class="border-b"><td class="py-1"><i class="fas fa-comment-dots text-pink-600"></i></td><td class="font-medium">Remark</td><td class="px-1">:</td><td>@d.ApproveRejectRemark</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            <!-- Footer Buttons -->
                            <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                                <a href="#modal-dialogForApproval1" id="btnmodal-dialog" onclick="Approved(this, 'Approved')"
                                   class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                    <i class="fa-solid fa-check-double"></i> Approve
                                </a>

                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule(this)" id="btnmodal-dialog1"
                                        class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50">
                                    <i class="fa fa-trash"></i> Reject
                                </button>
                            </div>
                        </div>
                    <!-- ====================== OUTDOOR DETAILS END ================================-->
                    }
                    else
                    {
                        <div class="text-black-600 text-sm font-medium">No data found for Outdoor request.</div>
                    }
                    break;

                case "PunchMissing":
                    if (d != null)
                    {
                    <!-- ====================== PUNCH MISSING DETAILS START ==============================-->
                        <div class="bg-white rounded-xl shadow-md w-full max-w-md @borderClass p-3 search-card">
                            <!-- Header -->
                            <input type="hidden" class="hdnEncryptedId" value="@d.PunchMissingId_Encrypted" />
                            <input type="hidden" class="hdnDocId" value="@d.PunchMissingId" />
                            <input type="hidden" class="hdnOrigin" value="@d.Origin" />
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 @color text-white rounded-full flex items-center justify-center font-semibold text-lg">
                                        @d.EmployeeName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-800">@d.EmployeeName</div>
                                        <div class="text-xs text-gray-500">@d.EmployeeNo</div>
                                    </div>
                                </div>
                                <div class="text-right text-xs text-gray-500">
                                    <div>Created On</div>
                                    <div>@d.CreatedDate.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-gray-700">
                                    <tbody>
                                        <tr><td class="py-1"><i class="fas fa-hashtag text-blue-600"></i></td><td class="font-medium">Doc No</td><td class="px-1">:</td><td>@d.DocNo</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-sign-in-alt text-orange-600"></i></td><td class="font-medium">In/Out Type</td><td class="px-1">:</td><td>@d.PunchMissingInOut</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-moon text-indigo-600"></i></td><td class="font-medium">Shift Name</td><td class="px-1">:</td><td>@d.PunchMissingShiftName</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-day text-yellow-600"></i></td><td class="font-medium">For Date</td><td class="px-1">:</td><td>@d.PunchMissingLogDate</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-clock text-green-600"></i></td><td class="font-medium">For Time</td><td class="px-1">:</td><td>@d.PunchMissingLogTime</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-solid fa-comment text-blue-600"></i></td><td class="font-medium">Reason</td><td class="px-1">:</td><td>@d.Reason</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-info-circle text-teal"></i></td><td class="font-medium">Status</td><td class="px-1">:</td><td>@d.Status</td></tr>
                                        <tr><td class="py-1"><i class="fa-solid fa-user-tie text-orange-600"></i></td><td class="font-medium">Approve By</td><td class="px-1">:</td><td>@d.ApprovedBy</td></tr>
                                        <tr><td class="py-1"><i class="fa-solid fa-calendar-days text-blue-600"></i></td><td class="font-medium">Approve Date</td><td class="px-1">:</td><td>@d.ApproveRejectDate</td></tr>
                                        <tr class="border-b"><td class="py-1"><i class="fa-solid fa-comment-dots text-red-600"></i></td><td class="font-medium">Remark</td><td class="px-1">:</td><td>@d.ApproveRejectRemark</td></tr>

                                    </tbody>
                                </table>
                            </div>

                            <!-- Footer Buttons -->
                            <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                                <a href="#modal-dialogForApproval1" id="btnmodal-dialog" onclick="Approved(this, 'Approved')"
                                   class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                    <i class="fa-solid fa-check-double"></i> Approve
                                </a>

                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule(this)" id="btnmodal-dialog1"
                                        class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50">
                                    <i class="fa fa-trash"></i> Reject
                                </button>
                            </div>
                        </div>
                    <!-- ====================== PUNCH MISSING DETAILS END ================================-->
                    }
                    else
                    {
                        <div class="text-black-600 text-sm font-medium">No data found for Punch Missing request.</div>
                    }
                    break;

                    case "WorkFromHome":
                    if (d != null)
                    {
                    <!-- ====================== WORK FROM HOME DETAILS START ==============================-->
                        <div class="bg-white rounded-xl shadow-md w-full max-w-md @borderClass p-3 search-card">
                            <!-- Header -->
                            <input type="hidden" class="hdnEncryptedId" value="@d.WFHId_Encrypted" />
                            <input type="hidden" class="hdnDocId" value="@d.WFHId" />
                            <input type="hidden" class="hdnOrigin" value="@d.Origin" />
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 @color text-white rounded-full flex items-center justify-center font-semibold text-lg">
                                        @(d.EmployeeName != null ? d.EmployeeName.Substring(0, 1) : "?")
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-800">@d.EmployeeName</div>
                                        <div class="text-xs text-gray-500">@d.EmployeeNo</div>
                                    </div>
                                </div>
                                <div class="text-right text-xs text-gray-500">
                                    <div>Created On</div>
                                    <div>@d.CreatedDate.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-gray-700">
                                    <tbody>
                                        <tr><td class="py-1"><i class="fas fa-flag text-blue-600 mr-1"></i></td><td class="font-medium">Shift Name</td><td class="px-1">:</td><td>@d.WFHShiftName</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-briefcase text-purple-600 mr-1"></i></td><td class="font-medium">From Date</td><td class="px-1">:</td><td>@d.FromDate</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-id-card-alt text-indigo-600 mr-1"></i></td><td class="font-medium">To Date</td><td class="px-1">:</td><td>@d.ToDate</td></tr>

                                        <tr><td class="py-1"><i class="fas fa-user text-green-600 mr-1"></i></td><td class="font-medium">Total Days</td><td class="px-1">:</td><td>@d.TotalDays</td></tr>
                                        <tr class="border-b"><td class="py-1"><i class="fas fa-hashtag text-gray-600 mr-1"></i></td><td class="font-medium">Reason</td><td class="px-1">:</td><td>@d.Reason</td></tr>
                                        
                                    </tbody>
                                </table>
                            </div>

                            <!-- Footer Buttons -->
                            <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                                <a href="#modal-dialogForApproval1" id="btnmodal-dialog" onclick="Approved(this, 'Approved')"
                                   class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                    <i class="fa-solid fa-check-double"></i> Approve
                                </a>

                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule(this)" id="btnmodal-dialog1"
                                        class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50">
                                    <i class="fa fa-trash"></i> Reject
                                </button>
                            </div>
                        </div>
                     <!-- ====================== WORK FROM HOME DETAILS END ===============================-->
                    }
                    else
                    {
                        <div class="text-black-600 text-sm font-medium">No data found for Work From Home request.</div>
                    }
                    break;

                case "ShiftChange":
                    if (d != null)
                    {
                     <!-- ====================== SHIFT CHANGE DETAILS START ==============================-->
                        <div class="bg-white rounded-xl shadow-md w-full max-w-md @borderClass p-3 search-card">
                            <!-- Header -->
                            <input type="hidden" class="hdnEncryptedId" value="@d.ShiftChangeId_Encrypted" />
                            <input type="hidden" class="hdnDocId" value="@d.ShiftChangeId" />
                            <input type="hidden" class="hdnOrigin" value="@d.Origin" />
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 @color text-white rounded-full flex items-center justify-center font-semibold text-lg">
                                        @(d.EmployeeName != null ? d.EmployeeName.Substring(0, 1) : "?")
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-800">@d.EmployeeName</div>
                                        <div class="text-xs text-gray-500">@d.EmployeeNo</div>
                                    </div>
                                </div>
                                <div class="text-right text-xs text-gray-500">
                                    <div>Applied On</div>
                                    <div>@(d.CreatedDate.ToString("dd-MM-yyyy") != null ? d.CreatedDate.ToString("dd-MM-yyyy") : "-")</div>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-gray-700">
                                    <tbody>
