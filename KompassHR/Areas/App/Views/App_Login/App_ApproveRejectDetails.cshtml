                        $("#ErrortxtTCApproveAmount").html("Please enter claim approve amount");
                        return false;
                    }
                    else {
                        $("#ErrortxtTCApproveAmount").html("");
                    }
                    var TotalAmount = Number($("#txtTCTotalAmount").html());
                    debugger
                    if (TotalAmount < TCamount) {
                        $("#ErrortxtTCApproveAmount").html("Approve amount should not greter than total amount");
                        return false;
                    }
                    else {
                        $("#ErrortxtTCApproveAmount").html("");
