                                        <tr><td class="py-1"><i class="fas fa-clock text-indigo-600"></i></td><td class="font-medium">Description</td><td class="px-1">:</td><td>@d.GeneralClaimDescription</td></tr>

                                        <tr><td class="py-1"><i class="fas fa-comment text-gray-600"></i></td><td class="font-medium">Reason</td><td class="px-1">:</td><td>@d.Reason</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-info-circle text-teal-600"></i></td><td class="font-medium">Status</td><td class="px-1">:</td><td>@d.Status</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-user-check text-cyan-600"></i></td><td class="font-medium">Approved By</td><td class="px-1">:</td><td>@d.ApproveRejectBy</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-check text-orange-600"></i></td><td class="font-medium">Approve Date</td><td class="px-1">:</td><td>@d.ApproveRejectDate</td></tr>
                                        <tr class="py-1"><td class="py-1"><i class="fas fa-comment-dots text-red-500"></i></td><td class="font-medium">Remark</td><td class="px-1">:</td><td>@d.ApproveRejectRemark</td></tr>

                                        <tr>
                                            <td class="py-1"><i class="fas fa-comment text-gray-600"></i></td>
                                            <td class="font-medium">Attachment</td>
                                            <td class="px-1">:</td>
                                            <td>
                                                @if (@d.AttachmentPath != "")
                                                {
                                                    <a href="#"><i class="fa fa-download fa-xl" onclick="DownloadFile('@d.AttachmentPath.Replace("\\", "/")')"></i></a>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-xmark fa-xl" style="color: red;"></i>
                                                }
                                            </td>
                                        </tr>
                                        <tr class="border-b">
                                            <td><i class="fas fa-hourglass-half text-pink-600"></i></td>
                                            <td class="font-medium">Approve Amount</td>
                                            <td class="px-1">:</td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" id="txtGCApproveAmount" name="ApproveAmount" placeholder="Enter amount" style="max-width: 120px;" />
                                                <span id="ErrortxtGCApproveAmount" class="Error"></span>
                                            </td>
                                        </tr>

                                    </tbody>
                                </table>
                            </div>

                            <!-- Footer Buttons -->
                            <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                                <a href="#modal-dialogForApproval1" id="btnmodal-dialog" onclick="Approved(this, 'Approved')"
                                   class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                    <i class="fa-solid fa-check-double"></i> Approve
                                </a>

                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule(this)" id="btnmodal-dialog1"
                                        class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50">
                                    <i class="fa fa-trash"></i> Reject
                                </button>
                            </div>
                        </div>
                    <!-- ====================== GENERAL CLAIM DETAILS END ==============================-->
                    }
                    else
                    {
                        <div class="text-red-600 text-sm font-medium">No data found for general claim request.</div>
                    }
                    break;
            }

        </div>
    </div>

    <!-- History Section -->
    <div id="History" class="hidden p-0">
        <div class="bg-white p-3 rounded-lg shadow">
            @{
                var leavehistory = ViewBag.GetLeaveHistory as List<dynamic>;
                int index = 0;
            }
            @if (leavehistory != null && leavehistory.Any())
            {
            <div class="space-y-3">
                @foreach (var item in leavehistory)
                    {
                        string color1 = "";
                        string borderClass1 = "";

                        switch (index % 10)
                        {
                            case 0:
                                color1 = "bg-red-400";
                                borderClass1 = "border-l-4 border-red-400";
                                break;
                            case 1:
                                color1 = "bg-blue-400";
                                borderClass1 = "border-l-4 border-blue-400";
                                break;
                            case 2:
                                color1 = "bg-green-400";
                                borderClass1 = "border-l-4 border-green-400";
                                break;
                            case 3:
                                color1 = "bg-yellow-400";
                                borderClass1 = "border-l-4 border-yellow-400";
                                break;
                            case 4:
                                color1 = "bg-purple-400";
                                borderClass1 = "border-l-4 border-purple-400";
                                break;
                            case 5:
                                color1 = "bg-pink-400";
                                borderClass1 = "border-l-4 border-pink-400";
                                break;
                            case 6:
                                color1 = "bg-indigo-400";
                                borderClass1 = "border-l-4 border-indigo-400";
                                break;
                            case 7:
                                color1 = "bg-teal";
                                borderClass1 = "border-l-4 border-teal";
                                break;
                            case 8:
                                color1 = "bg-orange";
                                borderClass1 = "border-l-4 border-orange";
                                break;
                            case 9:
                                color1 = "bg-cyan";
                                borderClass1 = "border-l-4 border-cyan";
                                break;
                        }

                        index++; // Increment after assigning
                    <div class="@borderClass1 pl-4 bg-white rounded-md shadow-sm p-3">
                        <div class="text-sm text-gray-700 font-semibold">
                            <i class="fa-solid fa-hashtag text-blue-500"></i> Doc No: @item.DocNo
                        </div>
                        <div class="text-sm text-gray-600 mt-1">
                            <i class="fa-solid fa-comment text-purple-500"></i> Remark: @item.Remark
                        </div>
                    </div>
                    }
            </div>
            }
            else
            {
            <div class="text-center text-gray-500">No history data available yet.</div>
            }
        </div>
    </div>
</div>

<!-- JavaScript for Toggle -->
<script>
    function showTab(tab) {
        const leave = document.getElementById("LeaveType");
        const history = document.getElementById("History");
        const btnLeave = document.getElementById("btnLeaveType");
        const btnHistory = document.getElementById("btnHistory");

        if (tab === "LeaveType") {
            leave.classList.remove("hidden");
            history.classList.add("hidden");

            btnLeave.classList.add("bg-blue-600", "text-white");
            btnLeave.classList.remove("bg-gray-100", "text-gray-700");

            btnHistory.classList.remove("bg-blue-600", "text-white");
            btnHistory.classList.add("bg-gray-100", "text-gray-700");
        } else {
            leave.classList.add("hidden");
            history.classList.remove("hidden");

            btnHistory.classList.add("bg-blue-600", "text-white");
            btnHistory.classList.remove("bg-gray-100", "text-gray-700");

            btnLeave.classList.remove("bg-blue-600", "text-white");
            btnLeave.classList.add("bg-gray-100", "text-gray-700");
        }
    }
</script>

<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Reject</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <input type="hidden" id="modalDocId" />
                                            <input type="hidden" id="modalEncryptedId" />
                                            <input type="hidden" id="modalOrigin" />
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Approved(this,'Rejected')" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress CloseModel" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->

<script>
    function OpenModule(btn) {
        debugger;
        var container = $(btn).closest('.search-card');
        var docId = container.find('.hdnDocId').val();
        var encryptedId = container.find('.hdnEncryptedId').val();
        var origin = container.find('.hdnOrigin').val();

        // Set values into modal hidden fields
        $('#modalDocId').val(docId);
        $('#modalEncryptedId').val(encryptedId);
        $('#modalOrigin').val(origin);
        $("#myModalFinal").modal('show');
    }

    function Approved(elem,Approver) {
        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes Submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                $(".Userloaderbg").css("display", "flex");
                var DocId = $("#modalDocId").val();
                var Encrypted = $("#modalEncryptedId").val();
                var Origin = $("#modalOrigin").val();
                var Status = "";
                var Remark = "";




                if (Approver == "Rejected") {
                    DocId = $('#modalDocId').val();
                    Encrypted = $('#modalEncryptedId').val();
                    Origin = $('#modalOrigin').val();
                    Remark = $("#txtApproveRejectRemark").val();
                    Status = "Rejected";
                }
                else {
                    var container = $(elem).closest('.search-card');
                    DocId = container.find('.hdnDocId').val();
                    Encrypted = container.find('.hdnEncryptedId').val();
                    Origin = container.find('.hdnOrigin').val();
                    Status = "Approved";
                }
                //if (Approver == "Rejected") {
                //    Remark = $("#txtApproveRejectRemark").val();
                //    Status = "Rejected";
                //}
                //else {
                //    Status = "Approved";
                //}
                $("#myModalFinal").modal('hide');
                
                $.ajax({
                    url: "@Url.Action("RequestForCancelApprove", "App_Login")",
                    method: "get",
                    data: { DocId: DocId, Encrypted: Encrypted, Status: Status, Remark: Remark, Origin: Origin },
                    success: function (response) {
                        debugger;
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon == "error") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: false
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            $(".Userloaderbg").css("display", "none");
                                            $("#txtApproveRejectRemark").val("")
                                            @*window.location.href = '@Url.Action("ESS_TimeOffice_Approval", "ESS_TimeOffice_Approval")';*@
                                        } else if (
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })
                                }
                            }
                        }
                        else {
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (response.Icon == "success") {
                                if (Message1 != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: false
                                        })
                                        .then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("App_ApproveRejectList", "App_Login")';
                                            } else if (
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {
                                            }
                                        })
                                        $("#myModalFinal").modal('hide');
                                        $("#txtApproveRejectRemark").val("");
                                    }
                                }
                            }
                        }
                    }
                });

            } else if (
                            result.dismiss === Swal.DismissReason.cancel
                       ) {
            }
        })
    }
</script>
