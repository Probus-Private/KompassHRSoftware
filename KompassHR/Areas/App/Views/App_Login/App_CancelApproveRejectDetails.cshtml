                                        <tr><td class="py-1"><i class="fas fa-user-tie text-blue-600"></i></td><td class="font-medium">Origin</td><td class="px-1">:</td><td>@d.Origin</td></tr>
                                        @*<tr><td class="py-1"><i class="fas fa-user-tie text-blue-600"></i></td><td class="font-medium">Type</td><td class="px-1">:</td><td>@d.OutDoorCompanyType</td></tr>*@
