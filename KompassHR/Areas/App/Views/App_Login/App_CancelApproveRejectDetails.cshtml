                                        <tr><td class="py-1"><i class="fas fa-calendar-alt text-orange-600"></i></td><td class="font-medium">From Date</td><td class="px-1">:</td><td>@d.FromDate - @d.FromTime</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-alt text-yellow-600"></i></td><td class="font-medium">To Date</td><td class="px-1">:</td><td>@d.TODATE - @d.ToTime</td></tr>
