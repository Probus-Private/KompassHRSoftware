                                        @*<tr><td class="py-1"><i class="fas fa-moon text-pink-600"></i></td><td class="font-medium">Night Shift</td><td class="px-1">:</td><td>@d.IsNightShift</td></tr>*@
                                        <tr class="border-b"><td class="py-1"><i class="fas fa-info-circle text-teal-600"></i></td><td class="font-medium">Status</td><td class="px-1">:</td><td>@d.Status</td></tr>
                                        @*<tr><td class="py-1"><i class="fas fa-user-check text-cyan-600"></i></td><td class="font-medium">Approve By</td><td class="px-1">:</td><td>@d.ApproveRejectBy</td></tr>
                                        <tr><td class="py-1"><i class="fas fa-calendar-check text-blue-600"></i></td><td class="font-medium">Approved Date</td><td class="px-1">:</td><td>@d.ApproveRejectDate</td></tr>
                                        <tr class="border-b"><td class="py-1"><i class="fas fa-comment-dots text-pink-600"></i></td><td class="font-medium">Remark</td><td class="px-1">:</td><td>@d.ApproveRejectRemark</td></tr>*@
                                    </tbody>
                                </table>
                            </div>
                            <!-- Footer Buttons -->
