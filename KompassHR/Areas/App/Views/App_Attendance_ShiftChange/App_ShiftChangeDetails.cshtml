
@{
    ViewBag.Title = "App_ShiftChangeDetails";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }

    .pace-running {
        background-color: #fff;
