<div class="flex flex-wrap gap-2 justify-center max-w-6xl mx-auto px-2">
    @{
        var ShiftChangeList = ViewBag.GetShiftChangeList as IEnumerable<dynamic>;
        var d = ShiftChangeList?.FirstOrDefault();
    }

    @{
        var ShiftChangeId = d?.ShiftChangeId ?? 0;
        var cancelStatus = d?.CancelStatus;
        var status = d?.Status ?? "";


        string topBorderColor = d.Status != null && d.Status.Contains("Approved") ? "green-500"
                    : d.Status != null && d.Status.Contains("Rejected") ? "red-500"
                    : d.Status != null && d.Status.Contains("Pending") ? "orange"
                    : "";

        string bgClass = $"bg-{topBorderColor}";
        string borderClass = $"border-t-4 border-{topBorderColor}";
    }

    <div class="bg-white rounded-xl shadow-md p-3 w-full sm:w-1/2 lg:w-1/3 @borderClass">
        @*<div class="bg-white rounded-xl shadow-md p-4 w-full sm:w-1/2 lg:w-1/3">*@
        <!-- Top Section -->
        <div class="flex justify-between items-start mb-0">
            <div>
                <div class="text-base font-semibold text-gray-800">
                    @(d != null ? $"{"Shift Change"}" : "")
                </div>
                @*<div class="text-sm text-gray-500">@d.PendingDay</div>*@
            </div>
            <div class="text-right">
                <div class="text-white px-4 py-1 rounded-full text-sm font-semibold @bgClass">
                    @d.Status
                </div>
                <div class="text-xs text-gray-500 mt-1">@d.ApprovedDay</div>
            </div>
        </div>

        <!-- Table-style Layout -->
        <table class="w-full text-sm text-gray-700">
            <tbody>
                <tr>
                    <td class="py-2 w-5"><i class="fa-solid fa-hashtag text-purple-600"></i></td>
                    <td class="font-medium">Doc No.</td>
                    <td class="px-2">:</td>
                    <td class="truncate">@d.DocNo</td>
                </tr>

               
                <tr>
                    <td class="py-2"><i class="fas fa-briefcase text-purple-600"></i></td>
                    <td class="font-medium">Shift</td>
                    <td class="px-2">:</td>
                    <td>@d.ShiftName</td>
                </tr>
                @*<tr>
                    <td class="py-2 w-5"><i class="fa-solid fa-user-tie text-blue-600"></i></td>
                    <td class="font-medium">Name</td>
                    <td class="px-2">:</td>
                    <td class="truncate">@d.EmployeeName</td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-id-card text-purple-600"></i></td>
                    <td class="font-medium">Emp. No.</td>
                    <td class="px-2">:</td>
                    <td>@d.EmployeeNo</td>
                </tr>*@
                <tr>
                    <td class="py-2"><i class="fa-solid fa-building text-orange-600"></i></td>
                    <td class="font-medium">Business Unit</td>
                    <td class="px-2">:</td>
                    <td>@d.BranchName</td>
                </tr>

                <tr>
                    <td class="py-2"><i class="fa-solid fa-calendar-days text-amber-600"></i></td>
                    <td class="font-medium">For Date</td>
                    <td class="px-2">:</td>
                    <td>@d.ForDate</td>
                </tr>
               
                @*<tr>
                        <td class="py-2"><i class="fas fa-thumbs-up text-indigo-600"></i></td>
                        <td class="font-medium">Status</td>
                        <td class="px-2">:</td>
                        <td>
                            <span class="badge @(status != null && status.Contains("Approved") ? "bg-success" : status != null && status.Contains("Rejected") ? "bg-danger" : "bg-secondary")">
                                @status
                            </span>
                        </td>
                    </tr>*@
                <tr>
                    <td class="py-2"><i class="fas fa-lightbulb text-yellow-500"></i></td>
                    <td class="font-medium">Reason</td>
                    <td class="px-2">:</td>
                    <td>@d.ShiftChangeReason</td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-user-tie text-orange-600"></i></td>
                    <td class="font-medium">Approver</td>
                    <td class="px-2">:</td>
                    <td>@d.ApprovedBy</td>
                </tr>
                <tr>
                    <td class="py-2"><i class="fa-solid fa-calendar-days text-blue-600"></i></td>
                    <td class="font-medium">Approve On</td>
                    <td class="px-2">:</td>
                    <td>@(d != null ? $"{d.ApproveRejectDate} {d.ApprovedAutoManually}" : "")</td>
                </tr>

                <tr class="border-b">
                    <td class="py-2"><i class="fa-solid fa-comment-dots text-red-600"></i></td>
                    <td class="font-medium">Remark</td>
                    <td class="px-2">:</td>
                    <td>@(d != null ? $"{d?.ApproveRejectRemark} " : "")</td>
                </tr>

            </tbody>
        </table>

        <!-- Footer Buttons -->
        <div class="flex justify-end gap-3 mt-2">
            <button type="button" class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50" id="btnGetList" onclick="btnGetLists();">
                <i class="fa-solid fa-share-from-square"></i> List
            </button>
            @*@if (cancelStatus == "Requested" || cancelStatus == "Canceled")
                {
                    <button class="btn btn-outline-secondary btn-sm" disabled>@cancelStatus</button>
                }
                else
                {
                    <a href="#modal-dialogForHoldReject1" onclick="CancelRequestFun(@d.LeaveMasterId,'@d.Status')"
                       class="text-blue-600 border border-blue-500 px-3 py-1 rounded-md hover:bg-blue-50">
                        <i class="fa fa-xmark"></i> Cancel
                    </a>
                }*@

            @*<button onclick="DeleteLeave('@d.LeaveMasterId_Encrypted','@d.Status')" class="text-red-600 border border-red-500 px-3 py-1 rounded-md hover:bg-red-50">
                    <i class="fa fa-trash"></i> Delete
                </button>*@
        </div>
    </div>
    </di>




    <!-- #Start Cancel Request dialog -->
    <div class="modal fade" id="CancelModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header bg-black text-white">
                    <h4 class="modal-title"> Remark For Cancel</h4>
                </div>
                <div class="modal-body">
                    <div class="modal-body-content">
                        <div class="row">
                            <div class="col-md-12">
                                <form>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                @* @Html.DropDownListFor(model => model.PunchMissingEmployeeID, new SelectList(ViewBag.GetAdditionalList, "Id", "Name"), new { id = "LeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-select", autocomplete = "off" })*@
                                                <h6> Select Approver Name</h6>

                                                @Html.DropDownList("Id", new SelectList(ViewBag.GetManagerEmployee, "Id", "Name"), "--Select--", new { @class = "form-control", Id = "ddlManagerName" })
                                                <h1></h1>
                                                <span id="ErrorMessage" class="Error" style="color:red"></span>
                                                <h6> Enter Remark </h6>
                                                <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>

                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" onclick="SendCancelRequest()" id="btnReject" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk"> </i> Submit
                    </button>
                    <button type="button" id="btnCancel" class="btn btn-danger btnpress btn-sm CloseModel" data-bs-dismiss="modal">
                        <i class="fa-solid fa-share-from-square"></i> Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>


    <script>

    function btnGetLists() {
        var url = '@Url.Action("App_GetList", "App_Attendance_ShiftChange")';
        window.location.href = url;
    }
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        $('title').html("ShiftChange ");
        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
    </script>

    <script>
    function DeleteShiftChange(ShiftChangeId_Encrypted,ShiftChangeId) {
        debugger
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                $(".Userloaderbg").css("display", "flex");
                window.location.href = '@Url.Action("App_Delete", "App_Attendance_ShiftChange")?ShiftChangeId_Encrypted='
                                + encodeURIComponent(ShiftChangeId_Encrypted)
                                 + '&ShiftChangeId='
                                  + encodeURIComponent(ShiftChangeId);
                @*window.location.href = '@Url.Action("Delete", "ESS_TimeOffice_ShiftChange")?ShiftChangeId_Encrypted=' + ShiftChangeId_Encrypted+'&ShiftChangeId='+ShiftChangeId;*@

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    </script>

    <script>
    function CancelRequestFun(ShiftChangeId,Status) {
        debugger;
        if(Status=="Pending")
        {
            var  Message="Pending request can't be cancel";
            var Icon="error";
            if (Message != null) {
                if (Icon != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                }
            }
        }
        else if (Status=="L1- Approved" || Status=="L2- Approved" || Status=="L3- Approved"){
            localStorage.setItem('ShiftChangeId', ShiftChangeId);
            $("#CancelModal").modal('show');
        }
        else if (Status=="Canceled"){
            var  Message="This request already canceled";
            var Icon="error";
            if (Message != null) {
                if (Icon != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                }
            }
        }

    }

    function SendCancelRequest()
    {
        debugger
        debugger;
        //$("#CancelModal").modal('show');
        var ddlManagerName = $('select#ddlManagerName option:selected').val();
        var txtApproveRejectRemark = $('#txtApproveRejectRemark').val();
        if(ddlManagerName=="")
        {
            $("#ErrorMessage").html("Please select approver name");
            $("#ddlManagerName").focus();
            return false;
        }
        else
        {
            $("#ErrorMessage").html("");
        }
        if(txtApproveRejectRemark=="")
        {
            $("#AreaErrorMessage").html("Please enter remark");
            $("#txtApproveRejectRemark").focus();
            return false;
        }
        else
        {
            $("#AreaErrorMessage").html("");
        }
        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes Submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;

                var GetShiftChangeId = localStorage.getItem('ShiftChangeId');

                var ddlManagerId = $("#ddlManagerName").val();
                var Origin="ShiftChange";
                Remark = $("#txtApproveRejectRemark").val();
                $("#CancelModal").modal('hide');
                $(".Userloaderbg").css("display", "flex");
                $.ajax({
                    url: "@Url.Action("App_CancelRequest", "App_Attendance_ShiftChange")",
                    method:"get",
                    data: { GetShiftChangeId: GetShiftChangeId, ddlManagerId: ddlManagerId, Remark: Remark, Origin: Origin },
                    success:function(response){
                        debugger;
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon=="error") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    })
                                    .then((result) => {
                                        $(".Userloaderbg").css("display","none");
                                        if (result.isConfirmed) {
                                            $("#CancelModal").modal('hide');
                                            $("#txtApproveRejectRemark").val("")
                                            window.location.href = '@Url.Action("App_GetList", "App_Attendance_ShiftChange")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })
                                }
                            }
                        }
                        else{
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (response.Icon=="success") {
                                if (Message1 != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        })
                                        .then((result) => {
                                            $(".Userloaderbg").css("display","none");
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("App_GetList", "App_Attendance_ShiftChange")';
                                            } else if (
                                                /* Read more about handling dismissals below */
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {

                                            }
                                        })

                                        $("#CancelModal").modal('hide');
                                        $("#txtApproveRejectRemark").val("");
                                    }
                                }
                            }
                        }
                    }
                });

            } else if (
                /* Read more about handling dismissals below */
                            result.dismiss === Swal.DismissReason.cancel
                        ) {
                $("#CancelModal").modal('hide');
                $("#ddlManagerName").val(null);
                $("#txtApproveRejectRemark").val("");
            }
        })
    }

    document.getElementById('CloseModel').addEventListener('click', function() {
        // Clearing the dropdown and textarea
        document.getElementById('ddlManagerName').selectedIndex = 0;
        document.getElementById('txtApproveRejectRemark').value = '';
        // Clearing error messages if needed
        document.getElementById('ErrorMessage').innerText = '';
        document.getElementById('AreaErrorMessage').innerText = '';
    });
    </script>
