
@{
    ViewBag.Title = "App_ShowMap";
    //Layout = "~/Views/Shared/_MobileLayout.cshtml";
    Layout = null;

    string CheckInOutLatitude = TempData["Latitude"]?.ToString();
    string CheckInOutLongitude = TempData["Longitude"]?.ToString();
    string LogDate = TempData["LogDate"]?.ToString();
    string LogTime = TempData["LogTime"]?.ToString();
    string Direction = TempData["Direction"]?.ToString();
    string Remarks = TempData["Remarks"]?.ToString();
    string Origin = TempData["Origin"]?.ToString();
    string LocationName = TempData["LocationName"]?.ToString();
    string SelfiePath = TempData["SelfiePath"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Show Location</title>
    <style>

        #map {
            width: 100%;
            height: 400px;
            margin-top: 20px;
            border-radius: 10px;
            border: 1px solid #ccc;
        }

        @@media (max-width: 600px) {
            #map {
                height: 300px;
            }

            button {
                width: 100%;
                font-size: 18px;
            }
        }
    </style>
</head>
<body>
    <div class="max-w-3xl mx-auto p-3 mx-auto bg-gray-100">
        <div class="space-y-2">
            <div class="bg-white rounded-2xl shadow-lg p-4 flex flex-col relative mb-1">
                @{
                    bool isPunchIn = Direction == "IN";
                    string cardColor = isPunchIn ? "text-green-600" : "text-red-600";
                    string iconClass = isPunchIn ? "fa-sign-in-alt" : "fa-sign-out-alt";
                }
                <div class="flex items-center @cardColor mb-3">
                    <i class="fas @iconClass text-xl mr-2"></i>
                    <span class="text-sm font-bold">PUNCH @Direction</span>
                </div>
                <div class="text-gray-700 space-y-2 text-sm break-words">
                    <p class="flex flex-wrap items-center">
                        <i class="fas fa-calendar-alt text-blue-500 mr-2 w-5"></i>
                        <span>@LogDate</span>
                        <i class="fas fa-clock text-green-500 ml-4 mr-2 w-5"></i>
                        <span>@LogTime</span>
                    </p>
                    <p class="flex items-start">
                        <i class="fas fa-map-marker-alt text-purple-500 mr-2 w-5"></i>
                        <span>Location:</span> <span class="ml-1">@LocationName</span>
                    </p>
                    <p class="flex items-start">
                        <i class="fas fa-comment-dots text-amber-500 mr-2 w-5 mt-0.5"></i>
                        <span>Remark:</span>
                        <span class="ml-1 break-words">@Remarks</span>
                    </p>
                    <p class="flex items-start">
                        <i class="fas fa-globe text-teal-500 mr-2 w-5"></i>
                        <span>Origin:</span> <span class="ml-1">@Origin</span>
                    </p>
                    <div class="w-full h-72 sm:h-96 rounded-xl overflow-hidden shadow-md">
                        <iframe id="map" src="" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

<script>
    const lat = @CheckInOutLatitude;
    const lng = @CheckInOutLongitude;
    const url = `https://maps.google.com/maps?q=${lat},${lng}&z=15&output=embed`;
    document.getElementById('map').src = url;
</script>
