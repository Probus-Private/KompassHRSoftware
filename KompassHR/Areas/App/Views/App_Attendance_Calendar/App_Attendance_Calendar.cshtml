
@{
    ViewBag.Title = "App_Attendance_Calendar";
    //Layout = "~/Views/Shared/_MobileLayout.cshtml";
    Layout = null;
    var currentDate = DateTime.Now.ToString("yyyy-MM-dd");

}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance UI</title>
    <script src="~/scripts/jquery-1.10.2.js"></script>
    <script src="~/scripts/jquery-1.10.2.min.js"></script>
    <script src="~/scripts/jquery.validate.js"></script>
    <script src="~/scripts/jquery.validate.min.js"></script>
    <link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
    @*<script src="https://cdn.tailwindcss.com"></script>*@
</head>

<body class="bg-gray-100">
    <div class="max-w-3xl mx-auto p-0 bg-gray-100">
        @using (Html.BeginForm("App_Attendance_Calendar", "App_Attendance_Calendar", new { area = "App" }, FormMethod.Get, null))
        {
    <!-- Fixed Header -->
            <div class="fixed top-0 left-1/2 transform -translate-x-1/2 z-20 bg-white w-full max-w-3xl shadow-md px-2 py-2 sm:px-3 overflow-x-auto">
                <div class="flex flex-nowrap items-center gap-2 min-w-[600px]">
                    <!-- From Date -->
                    <div class="min-w-[140px]">
                        <input type="month" id="fromDate" name="Date" value="@ViewBag.GetDate"
                               class="w-full px-2 py-1 border rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-400 text-sm" />
                    </div>

                    <!-- Show Button -->
                    <div class="min-w-[90px]">
                        <button type="submit"
                                class="w-full bg-blue-600 text-white px-3 py-1 text-sm rounded-md font-medium hover:bg-blue-700 transition">
                            Show
                        </button>
                    </div>

                    <!-- Toggle Buttons -->
                    <div class="flex gap-1 bg-gray-100 p-1 rounded-full min-w-[200px]">
                        <button onclick="showTab('dayWise')" id="btnDayWise"
                                type="button"
                                class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap bg-blue-600 text-white">
                            Day wise
                        </button>
                        <button onclick="showTab('summary')" id="btnSummary"
                                type="button"
                                class="px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap bg-gray-100 text-gray-700 hover:bg-gray-200">
                            Summary
                        </button>
                    </div>
                </div>
            </div>
        }


        <!-- Spacer -->
        <div class="h-12"></div>




        <!-- Day Wise Section -->
        <!-- Font Awesome CDN -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-..." crossorigin="anonymous" referrerpolicy="no-referrer" />

        <!-- Font Awesome not needed now since we’re showing status name, not icon -->

        <div id="dayWise" class="space-y-3 px-2">
            @if (ViewBag.EmployeeWiseReport != null)
            {
                foreach (var item in ViewBag.EmployeeWiseReport)
                {
                    DateTime date = Convert.ToDateTime(item.Date);
                    string day = date.ToString("dddd");
                    string dayNumber = date.Day.ToString();
                    string dateText = date.ToString("yyyy-MM-dd");

                    string statusColor = item.InOutStatus == "AB" ? "bg-red-500"
                                          : item.InOutStatus == "WO" || item.InOutStatus == "PH" ? "bg-yellow-500"
                                          : "bg-green-500";

                    string emoji = "🙂"; // Default happy
                    if (item.LateBy != "00:00")
                    {
                        emoji = "😢"; // Late
                    }
                    else if (item.EarlyBy != "00:00")
                    {
                        emoji = "😮"; // Early
                    }


                    string topBorderColor = item.InOutStatus == "P" ? "border-t-4 border-green-500"
                       : item.InOutStatus == "AB" ? "border-t-4 border-red-500"
                       : (item.InOutStatus == "PH" || item.InOutStatus == "PH(P)") ? "border-t-4 border-blue-500"
                       : (item.InOutStatus == "WO" || item.InOutStatus == "WO(P)") ? "border-t-4 border-yellow-500"
                       : item.InOutStatus == "CO" ? "border-t-4 border-black"
                       : "border-t-4 border-green-500";

                    <div class="bg-white rounded-xl shadow-md p-3 md:flex md:items-start justify-between relative mt-3 @topBorderColor">

                        <!-- Header Row -->
                        <div class="flex justify-between items-center">
                            <div class="flex items-center gap-3">
                                @{
                                    int dayNum = int.Parse(dayNumber);
                                    string suffix = "th";

                                    if ((dayNum % 100 < 11) || (dayNum % 100 > 13))
                                    {
                                        switch (dayNum % 10)
                                        {
                                            case 1: suffix = "st"; break;
                                            case 2: suffix = "nd"; break;
                                            case 3: suffix = "rd"; break;
                                        }
                                    }
                                }
                                <div class="text-3xl font-bold text-blue-700 leading-none">
                                    @dayNum<sup class="text-xs align-top ml-0.5">@suffix</sup>
                                </div>

                                <div>
                                    <div class="text-sm font-semibold text-gray-700">@day</div>
                                    <div class="text-xs text-gray-500">@dateText</div>
                                </div>
                            </div>

                            <!-- ✅ Combine loader gif + status into one flex container -->
                            <div class="flex items-center gap-1">
                                @if (item.LateBy != "00:00" || item.EarlyBy != "00:00")
                                {
                                    <img src="~/assets/OtherImages/RedLoader.gif" width="20" height="20" />
                                }
                                else
                                {
                                    <img src="~/assets/OtherImages/GreenLoader.gif" width="20" height="20" />
                                }
                                <div class="@statusColor text-white px-1 py-1 rounded-full text-sm font-semibold text-center" style="width:60px;">
                                    @item.InOutStatus
                                </div>
                            </div>
                        </div>





                        <!-- Attendance Details -->
                        <table class="table-auto text-sm w-full">
                            <tbody>
                                <tr>
                                    <td class="p-1 pr-2"><i class="fas fa-sign-in-alt text-blue-500"></i></td>
                                    <td class="p-1 text-gray-700 font-medium">In Time</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.Intime</td>

                                    <td class="p-1 pr-2">
                                        @if (item.LateBy != "00:00")
                                        {
                                            <span>😢</span>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-circle-check text-green-600"></i>
                                        }
                                    </td>
                                    <td class="p-1 text-gray-700 font-medium">Late By</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.LateBy</td>
                                </tr>
                                <tr>
                                    <td class="p-1 pr-2"><i class="fas fa-sign-out-alt text-red-500"></i></td>
                                    <td class="p-1 text-gray-700 font-medium">Out Time</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.OutTime</td>

                                    <td class="p-1 pr-2">
                                        @if (item.EarlyBy != "00:00")
                                        {
                                            <span>😢</span>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-circle-check text-green-600"></i>
                                        }
                                    </td>
                                    <td class="p-1 text-gray-700 font-medium">Early By</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.EarlyBy</td>
                                </tr>
                                <tr>
                                    <td class="p-1 pr-2"><i class="fa-regular fa-clock text-indigo-500"></i></td>
                                    <td class="p-1 text-gray-700 font-medium">Duration</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.Duration</td>

                                    <td class="p-1 pr-2"><i class="fa-solid fa-circle-check text-green-600"></i></td>
                                    <td class="p-1 text-gray-700 font-medium">Comp Off</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">
                                        @if (item.CO?.ToString() == "0")
                                        {
                                            @:00:00
                                        }
                                        else
                                        {
                                            @item.CO
                                        }


                                    </td>
                                </tr>
                                <tr>
                                    <td class="p-1 pr-2"><i class="fa-solid fa-business-time text-purple-600"></i></td>
                                    <td class="p-1 text-gray-700 font-medium">Shift</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.Shift</td>

                                    <td class="p-1 pr-2"><i class="fa-solid fa-circle-check text-green-600"></i></td>
                                    <td class="p-1 text-gray-700 font-medium">Over Time</td>
                                    <td class="p-1">:</td>
                                    <td class="p-1">@item.ApprovedOT</td>
                                </tr>
                            </tbody>
                        </table>


                    </div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-gray-500 text-center">No calendar data available.</p>
                                    }
        </div>


        <!-- Summary Section -->
        @{
            var summaryData = ViewBag.EmployeeWiseSummeryReport as List<dynamic>;

            // Single list with both icon and color
            var iconStyles = new List<string>
            {
                "fa-user-check text-green-600",
                "fa-calendar-xmark text-yellow-600",
                "fa-umbrella-beach text-teal-500",
                "fa-user-xmark text-red-500",
                "fa-clock text-purple-500",
                "fa-retweet text-pink-500",
                "fa-plane-departure text-green-500",
                "fa-head-side-mask text-rose-500",
                "fa-calendar-plus text-emerald-600",
                "fa-baby text-blue-400",
                "fa-hospital-user text-indigo-500",
                "fa-user-slash text-red-400",
                "fa-briefcase-clock text-pink-500",
                "fa-hand-holding-medical text-fuchsia-600",
                "fa-ban text-lime-600",
                "fa-wallet text-blue-600",
                "fa-calendar-days text-slate-500"
            };

            int i = 0;
        }

        <div id="summary" class="hidden space-y-3 px-2">
            <div class="bg-white p-4 rounded-lg shadow">
                @*<h3 class="text-lg font-semibold text-gray-700 mb-4">Attendance Summary</h3>*@

                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
                    @if (summaryData != null)
            {
                foreach (var item in summaryData)
                {
                    var iconStyle = i < iconStyles.Count ? iconStyles[i] : "fa-circle-info text-blue-500";
                    i++;

                            <div class="bg-gradient-to-br from-white to-gray-100 border border-gray-200 shadow-md rounded-xl p-2 text-center transition transform hover:scale-105">
                                <div class="flex justify-center mb-1">
                                    <i class="fa-solid @iconStyle text-2xl"></i>
                                </div>
                                <p class="text-base sm:text-lg font-semibold text-gray-700 leading-tight">@item.Lable</p>
                                <p class="text-xl font-bold text-indigo-700 mt-1">@item.Counts</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-red-500">No summary data found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</body>

</html>
<!-- Toggle Script -->
<script>
    function showTab(tab) {
        const dayWise = document.getElementById("dayWise");
        const summary = document.getElementById("summary");
        const btnDayWise = document.getElementById("btnDayWise");
        const btnSummary = document.getElementById("btnSummary");

        if (tab === "dayWise") {
            dayWise.classList.remove("hidden");
            summary.classList.add("hidden");

            btnDayWise.classList.add("bg-blue-600", "text-white");
            btnDayWise.classList.remove("bg-gray-100", "text-gray-700");

            btnSummary.classList.remove("bg-blue-600", "text-white");
            btnSummary.classList.add("bg-gray-100", "text-gray-700");
        } else {
            summary.classList.remove("hidden");
            dayWise.classList.add("hidden");

            btnSummary.classList.add("bg-blue-600", "text-white");
            btnSummary.classList.remove("bg-gray-100", "text-gray-700");

            btnDayWise.classList.remove("bg-blue-600", "text-white");
            btnDayWise.classList.add("bg-gray-100", "text-gray-700");
        }
    }
</script>

