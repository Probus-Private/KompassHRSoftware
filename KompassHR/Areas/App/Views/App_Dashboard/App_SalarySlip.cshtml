<script src="~/assets/MyJS/main.js"></script>
<script>
    function generatePDF() {
        debugger;
        //$(".Userloaderbg").css("display", "flex");

        const jsPDF = window.jspdf.jsPDF;

        // Initialize jsPDF with A4 size
        const pdf = new jsPDF({
            orientation: 'portrait',
            unit: 'pt', // points
            format: 'a4'
        });

        // Target the DOM element instead of innerHTML
        const contentElement = document.getElementById('payslip');

        // Optional: Inline styling for fonts (applies to rendered HTML)
        const style = document.createElement('style');
        style.innerHTML = `
        body {
            font-family: 'helvetica', Tahoma, Geneva, Verdana, sans-serif !important;
            font-size: 13px !important;
        }
        #PayslipMDL .modal-body,
        #PayslipMDL form,
        #PayslipMDL table {
            font-family: 'helvetica', Tahoma, Geneva, Verdana, sans-serif !important;
            font-size: 13px !important;
        }
    `;
        document.head.appendChild(style);

        // Use jsPDF.html() with DOM element (auto-handles layout + styles)
        pdf.html(contentElement, {
            callback: function (doc) {
                doc.save('Payslip.pdf');
                $(".Userloaderbg").css("display", "none"); // hide loader after save
            },
            x: 10,
            y: 20,
            width: 575,
            windowWidth: 900
        });

        // Remove added style to avoid affecting other elements
        //document.head.removeChild(style);
    }

</script>

<script>
    function generateAndSendPDF(EmpNo) {

        Swal.fire({
            title: 'Are you sure?',
            text: "Do you want to send the payslip by email?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, send it!',
            allowOutsideClick: false
        }).then((result) => {

            if (!result.isConfirmed) return;

            $(".Userloaderbg").css("display", "flex");

            // 1️⃣ Get logo & convert to Base64
            const logo = document.getElementById("CompanyLogo").src;

            convertImgToBase64(logo, function (base64Logo) {

                if (base64Logo) {
                    $("#CompanyLogo").attr("src", base64Logo);
                }

                // 2️⃣ Add required print styles
                const printStyles = `
                <style>
                    body, table, form {
                        font-family: helvetica, Tahoma, Verdana, sans-serif !important;
                        font-size: 13px !important;
                    }
                </style>
            `;

                // 3️⃣ Get final HTML to send to server
                const payslipHtml = printStyles + document.getElementById("payslip").innerHTML;

                // 4️⃣ Send to server (Server generates PDF & mails it)
                $.ajax({
                    url: '@Url.Action("GenerateAndSendEmail", "App_Dashboard")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ htmlContent: payslipHtml, EmpNo: EmpNo }),

                    success: function (response) {
                        $(".Userloaderbg").css("display", "none");

                        if (response.success) {
                            Swal.fire({
                                icon: "success",
                                text: `Email sent to ${response.email}!`,
                                allowOutsideClick: false
                            });
                        } else {
                            Swal.fire({
                                icon: "error",
                                text: `Failed to send email: ${response.error}`,
                                allowOutsideClick: false
                            });
                        }
                    },

                    error: function () {
                        $(".Userloaderbg").css("display", "none");
                        Swal.fire({
                            icon: "error",
                            text: "An error occurred while sending the email.",
                            allowOutsideClick: false
                        });
                    }
                });

            });
        });
    }
    function convertImgToBase64(url, callback) {
        if (!url) return callback(null);

        var img = new Image();
        img.crossOrigin = "Anonymous";

        img.onload = function () {
            var canvas = document.createElement("canvas");
            canvas.width = this.width;
            canvas.height = this.height;

            var ctx = canvas.getContext("2d");
            ctx.drawImage(this, 0, 0);

            var dataURL = canvas.toDataURL("image/png");
            callback(dataURL);
        };

        img.onerror = function () {
            console.warn("Logo could not be converted to Base64.");
            callback(null);
        };

        img.src = url;
    }

</script>