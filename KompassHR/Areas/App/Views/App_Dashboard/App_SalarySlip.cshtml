
@{
    ViewBag.Title = "App_SalarySlip";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Payslips</title>

    <!-- Tailwind CSS -->
    <link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
    <!-- Font Awesome (for icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <!-- Include dompurify -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/2.4.0/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        .app-header-fixed {
            padding-top: 5px;
            padding-bottom: 5px;
        }

        .app-content {
            padding: 5px 5px;
        }

        .pace-running {
            background-color: #fff;
        }

        #app {
            background-color: #fff;
        }
    </style>
</head>

<body class="bg-white">
    <div id="content" class="app-content p-2 min-h-screen bg-white">
        <!-- Panel Container -->
        <div class="bg-white shadow-lg rounded-xl border border-gray-200 p-0">
            <div class="max-w-3xl mx-auto bg-white min-h-screen">
                <div class="bg-white p-1 rounded-lg shadow">
                    @{
                        int index = 0;
                    }
                    <div class="space-y-3">
                        @foreach (var item in ViewBag.GetPaySlipList)
                        {
                            string borderClass1 = "";
                            string bgColor = "";
                            string textColor = "";

                            switch (index % 10)
                            {
                                case 0:
                                    borderClass1 = "border-l-4 border-red-400";
                                    bgColor = "bg-red-50";
                                    textColor = "text-red-500";
                                    break;
                                case 1:
                                    borderClass1 = "border-l-4 border-blue-400";
                                    bgColor = "bg-blue-50";
                                    textColor = "text-blue-500";
                                    break;
                                case 2:
                                    borderClass1 = "border-l-4 border-green-400";
                                    bgColor = "bg-green-50";
                                    textColor = "text-green-500";
                                    break;
                                case 3:
                                    borderClass1 = "border-l-4 border-yellow-400";
                                    bgColor = "bg-yellow-50";
                                    textColor = "text-yellow-500";
                                    break;
                                case 4:
                                    borderClass1 = "border-l-4 border-purple-400";
                                    bgColor = "bg-purple-50";
                                    textColor = "text-purple-500";
                                    break;
                                case 5:
                                    borderClass1 = "border-l-4 border-pink-400";
                                    bgColor = "bg-pink-50";
                                    textColor = "text-pink-500";
                                    break;
                                case 6:
                                    borderClass1 = "border-l-4 border-indigo-400";
                                    bgColor = "bg-indigo-50";
                                    textColor = "text-indigo-500";
                                    break;
                                case 7:
                                    borderClass1 = "border-l-4 border-teal-400";
                                    bgColor = "bg-teal-50";
                                    textColor = "text-teal-500";
                                    break;
                                case 8:
                                    borderClass1 = "border-l-4 border-orange-400";
                                    bgColor = "bg-orange-50";
                                    textColor = "text-orange-500";
                                    break;
                                case 9:
                                    borderClass1 = "border-l-4 border-cyan-400";
                                    bgColor = "bg-cyan-50";
                                    textColor = "text-cyan-500";
                                    break;
                            }

                            index++;
                            <div class="@borderClass1 pl-4 rounded-md shadow-sm p-2">
                                <!-- Top row: Month name (left) and View button (right) -->
                                <div class="flex justify-between items-center">
                                    <!-- Left: Month Name -->
                                    <div class="text-base text-gray-800 font-semibold">
                                        <i class="fa-solid fa-calendar-days mr-1 @textColor"></i> @item.GetMonthName
                                    </div>

                                    <!-- Right: View Button -->
                                    <div>
                                        <button onclick="ViewPaySlip(@item.SalaryID)"
                                                class="text-orange border border-blue-500 text-xs px-1.5 py-0.5 rounded hover:bg-blue-50">
                                            <i class="fas fa-eye text-xs"></i> <span class="text-xs">View</span>
                                        </button>
                                    </div>
                                </div>

                                <!-- Bottom row: Email (left) and Send Mail button (right) -->
                                <div class="flex justify-between items-center mt-2">
                                    <!-- Left: Email -->
                                    <div class="flex items-center space-x-2 text-sm text-gray-700">
                                        <i class="fa-solid fa-envelope"></i>
                                        <span>@(TempData["GetEmployeeEmailId"] ?? "")</span>
                                    </div>

                                    <!-- Right: Send Mail Button -->
                                    <div>
                                        <button onclick="ViewPaySlip(@item.SalaryID, 'Mail')"
                                                class="text-blue-600 border border-blue-500 text-xs px-1.5 py-0.5 rounded hover:bg-blue-50">
                                            <i class="fa-solid fa-paper-plane text-xs"></i>
                                            <span class="text-xs">Send</span>
                                        </button>
                                    </div>

                                </div>
                            </div>


                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>

</html>

