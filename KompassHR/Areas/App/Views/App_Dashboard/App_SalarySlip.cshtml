<script>
    function handleClose(event) {
        event.preventDefault(); // Prevent default button behavior
    }
    function ViewPaySlip(SalaryID, format) {
        debugger
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            url: '@Url.Action("GetPaySlipDetails", "App_Dashboard")',
            data: { SalaryID: SalaryID },
            success: function (response) {
                debugger;
                const json = response.GetPersonal[0];
                const transformed = {
                    GetPersonal: Object.fromEntries(
                        json.map(item =>[item.Key, item.Value])
                    )
                };
                $(".Userloaderbg").css("display", "none");
                var GetData = transformed.GetPersonal;

                bindPayslipFields("Previewpayslip", GetData);
                bindPayslipFields("payslip", GetData);

                function bindPayslipFields(parentId, GetData) {
                    const parent = $("#" + parentId);

                    parent.find("#EmpName").html(GetData.EmployeeName);
                    parent.find("#EmpNo").html(GetData.EmployeeNo);
                    parent.find("#EmpDepartment").html(GetData.Department);
                    parent.find("#EmpDesignation").html(GetData.Designation);
                    parent.find("#EmpGrade").html(GetData.Grade);
                    parent.find("#EmpDOJ").html(GetData.JoiningDate);
                    parent.find("#EmpBankName").html(GetData.BankName);
                    parent.find("#EmpBankAccountNo").html(GetData.AccountNo);
                    parent.find("#EmpIFSCCode").html(GetData.IFSCCode);
                    parent.find("#EmpPFNo").html(GetData.PFNo);
                    parent.find("#EmpUANNo").html(GetData.UAN);
                    parent.find("#EmpESICNo").html(GetData.ESIC);
                    parent.find("#EmpLINNo").html(GetData.LIN);
                    parent.find("#EmpAadhaarNo").html(GetData.AadhaarNo);
                    parent.find("#EmpPANNo").html(GetData.PAN);

                    parent.find("#spnCompanyName").html(GetData.CompanyName);
