                                    <td><strong><span id="spnStandardAmt"></span></strong></td>
                                    <td><strong><span id="spnEarningAmt"></span></strong></td>
                                    <td hidden><strong><span id="ArrearsAmt"></span></strong></td>
                                    <td><strong>Total Deduction</strong></td>
                                    <td><strong><span id="spnDeductionAmt"></span></strong></td>
                                </tr>
                                <tr>
                                    @*<td colspan="3" class="border-0"></td>*@
                                    <td class="hideBorder" colspan="3"><span id="spnNetPayInWord"></span></td>
                                    <td><strong>Net Pay</strong></td>
                                    <td colspan="2"><strong><span id="spnNetPay"></span></strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </form>

                <!-- Footer Note -->
                <div class="text-center mt-2 small">
                    This is a computer generated report and does not require signature.
