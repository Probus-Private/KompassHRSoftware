
@{
    ViewBag.Title = "App_Holiday";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link href="~/assets/MyCSS/Tailwindcss.css" rel="stylesheet" />
<style>
    .app-header-fixed {
        padding-top: 5px;
        padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }

    .pace-running {
        background-color: #fff;
    }
    #app {
            background-color: #fff;
        }
</style>
@{
    var holidays = ViewBag.GetPublicHolidaysList as IEnumerable<dynamic>;
    // Group holidays by month
    var groupedByMonth = holidays?
        .GroupBy(h => Convert.ToDateTime(h.PublicHolidayDate).ToString("MMMM"))
        .OrderBy(g => DateTime.ParseExact(g.Key, "MMMM", System.Globalization.CultureInfo.InvariantCulture));
}


<div id="content" class="app-content p-2 min-h-screen bg-white">
    <!-- Panel Container -->
    <div class="bg-white shadow-lg rounded-xl border border-gray-200 p-0">
        <div class="max-w-3xl mx-auto bg-white min-h-screen">
            <div class="bg-white p-3 rounded-lg shadow">
                @{
                    int index = 0;
                }
                <h2></h2>
                <div class="space-y-3">
                    @if (groupedByMonth != null)
                    {
                        foreach (var monthGroup in groupedByMonth)
                        {
                            var monthYearShown = false;
                            foreach (var holiday in monthGroup)
                            {
                                var holidayDate = Convert.ToDateTime(holiday.PublicHolidayDate);
                                var day = holidayDate.ToString("dd");
                                var monthShort = holidayDate.ToString("MMM");
                                var year = holidayDate.ToString("yyyy");
                                var dayOfWeek = holidayDate.ToString("dddd");
                                var description = holiday.Description ?? "Public Holiday";
                                var daysRemaining = holiday.DaysRemaining;
                                var Type = holiday.Type;
                                string borderClass = "";
                                string bgColor = "";
                                string textColor = "";

                                switch (index % 10)
                                {
                                    case 0: borderClass = "border-l-4 border-red-400"; bgColor = "bg-red-50"; textColor = "text-red-500"; break;
                                    case 1: borderClass = "border-l-4 border-blue-400"; bgColor = "bg-blue-50"; textColor = "text-blue-500"; break;
                                    case 2: borderClass = "border-l-4 border-green-400"; bgColor = "bg-green-50"; textColor = "text-green-500"; break;
                                    case 3: borderClass = "border-l-4 border-yellow-400"; bgColor = "bg-yellow-50"; textColor = "text-yellow-500"; break;
                                    case 4: borderClass = "border-l-4 border-cyan"; bgColor = "bg-cyan"; textColor = "text-cyan"; break;
                                    case 5: borderClass = "border-l-4 border-pink-400"; bgColor = "bg-pink-50"; textColor = "text-pink-500"; break;
                                    case 6: borderClass = "border-l-4 border-indigo"; bgColor = "bg-indigo"; textColor = "text-indigo"; break;
                                    case 7: borderClass = "border-l-4 border-teal"; bgColor = "bg-teal"; textColor = "text-teal"; break;
                                    case 8: borderClass = "border-l-4 border-orange"; bgColor = "bg-orange"; textColor = "text-orange"; break;
                                    case 9: borderClass = "border-l-4 border-purple"; bgColor = "bg-purple"; textColor = "text-purple"; break;
                                }

                                index++;
                                @*if (!monthYearShown)
                                {
                                    <h2 class="text-xl font-bold @textColor mt-4 mb-2">@monthGroup.Key - @year</h2>;
                                    monthYearShown = true;
                                }*@
                                <div class="@borderClass pl-4 rounded-md shadow-sm p-1">
                                    <!-- Wrap as vertical flex column -->
                                    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center space-y-1 sm:space-y-0">
                                        <!-- Left: Date + Description -->
                                        <div class="text-sm text-gray-600 font-bold flex justify-between items-center">
                                            <div class="@textColor flex items-center">
                                                <i class="fa-solid fa-calendar-days mr-1"></i>
                                                @day @monthShort @year
                                            </div>
                                            <div class="text-gray-800 text-sm font-medium">
                                                @Type
                                            </div>
                                        </div>

                                        <div class="text-base text-gray-800 ml-5 font-normal leading-snug">
                                            @description
                                        </div>



                                        <!-- Right: Day & Days Remaining (stacked below on mobile) -->
                                        <div class="text-base text-gray-800">
                                            <!-- Move day of week and days remaining here aligned right -->
                                            <div class="flex flex-col items-end gap-1 text-sm text-gray-500 mt-1">
                                                
                                                @if (daysRemaining != null && daysRemaining.ToString().Contains("Expired"))
                                                {
                                                    <div class="flex items-center gap-1">
                                                      <span>@dayOfWeek</span>  <span>@daysRemaining</span>
                                                        <img src="~/assets/OtherImages/RedLoader.gif" width="16" height="16" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="flex items-center gap-1">
                                                        <span>@dayOfWeek</span>  <span>@daysRemaining</span>
                                                        <img src="~/assets/OtherImages/GreenLoader.gif" width="16" height="16" />
                                                    </div>
                                                }
                                            </div>
                                        </div>



                                    </div>
                                </div>

                            }
                        }
                    }
                    else
                    {
                        <div class="text-center text-gray-600">No public holidays available.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>













