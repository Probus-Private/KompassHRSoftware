
@{
    ViewBag.Title = "App_Dashboard";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

<style>
    body {
        font-family: roboto;
        /*        background-color: #f7f7f7;*/
        background-color: #ffffff;
    }

    .app-header-fixed {
        padding-top: 0;
    }

    .app-content {
        padding: 10px 20px;
        /*        background-color: #f7f7f7 !important;*/
    }

    .leave-container, .attendance-container, .vms-container {
        padding: 5px;
        /*        background: #fff;*/
        /*        border-radius: 10px;*/
        /*        box-shadow: 0 1px 2px rgba(0,0,0,0.1);*/
    }

        .leave-container h3, .attendance-container h3, .vms-container h3 {
            /*            margin-bottom: 0px;*/
            color: #333;
            font-size: 0.7rem;
            /*            text-align: center;*/
        }

    .leave-box, .attendance-box, .vms-box {
        flex: 1;
        display: flex;
        flex-direction: row;
       
        align-items: center;
        padding: 15px 5px;
        text-align: left;
        transition: transform 0.3s ease;
        border-radius: 7px;
        background-color: #fff;
        /*        box-shadow: 0 1px 2px rgba(0,0,0,0.1);*/
        border: 1px solid #D9D9D9;
    }

        .leave-box:hover, .attendance-box:hover, .vms-box:hover {
            transform: translateY(-5px);
        }

        .leave-box h3, .attendance-box h3, .vms-box h3 {
            font-size: 0.9rem;
            color: #555;
            font-weight: 500;
        }

    .leave-boxes a, .attendance-boxes a, .vms-boxes a {
        padding: 5px;
    }

    .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    @@media screen and (max-width: 500px) {

        .leave-boxes, .attendance-boxes, .vms-boxes {
            /*            justify-content: space-evenly;*/
        }

        .leave-box h3, .attendance-box h3, .vms-box h3 {
            font-size: 0.8rem;
            font-weight: 700;
        }

        .leave-box, .attendance-box, .vms-box {
            padding: 10px;
        }

            .leave-box img, .attendance-box img, .vms-box img {
                width: 30%;
                /*            margin-top: 5px;*/
            }
    }

</style>

<div id="content" class="app-content bg-white">
    <div class="row">
        <div class="col-lg-12 col-md-12 ui-sortable">
            <!-- BEGIN panel -->
            <div class="leave-container">
                <div class="gradientLine-Div">
                    <div class="gradientLine1"></div>
                    <div class="menu-text"><strong>What do you want to do today?</strong></div>
                    <div class="gradientLine2"></div>
                </div>

                <div class="leave-boxes row">
                    <a href="@Url.Action("App_GetList", "App_Leave_Leave", new { id = 4, ScreenId=293, area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/1.png" alt="Leave" width="30%" /> &nbsp;
                            <h3>Leave</h3>
                        </div>
                    </a>
                    
                    <a href="@Url.Action("App_GetList", "App_Leave_Coff", new {area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/5.png" alt="Coff" width="30%" /> &nbsp;
                            <h3>Coff</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_GetList", "App_Attendance_Outdoor", new {area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/3.png" alt="Outdoor" width="30%" /> &nbsp;
                            <h3>Outdoor</h3>
                        </div>
                    </a>
                    <a href="@Url.Action("App_Attendance_PunchMissingApprovalpendingList", "App_Attendance_PunchMissing", new {area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/4.png" alt="Punch Missing" width="30%" /> &nbsp;
                            <h3>Punch Missing</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_Attendance_GetApproveRejectPersonalGatepassList", "App_Attendance_PersonalGatePass", new {area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/Gatepass.png" alt="Personal Gatepass" width="30%" /> &nbsp;
                            <h3>Personal Gatepass</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_Attendance_WFH_ApprovalandrejectList", "App_Attendance_WFH", new {area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/WFHS.png" alt="COFF" width="30%" /> &nbsp;
                            <h3>Work From Home</h3>
                        </div>
                    </a>
                   
                    <a href="@Url.Action("App_Attendance_calendar", "App_Attendance_calendar", new { id = 4, ScreenId=293, area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/CalendarTime.png" alt="Holidays" width="30%" /> &nbsp;
                            <h3>Calendar</h3>
                        </div>
                    </a>
                    <a href="@Url.Action("App_Holiday", "App_Dashboard", new { area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/Holiday.png" alt="Holidays" width="30%" /> &nbsp;
                            <h3>Public Holiday</h3>
                        </div>
                    </a>

                    @*<a href="@Url.Action("App_PunchLog", "App_PunchLog", new { area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/PunchMissing.png" width="30%"  />
                            <h3>Punch Log</h3>
                        </div>
                    </a>*@
                    
                    <a href="@Url.Action("App_SalarySlip", "App_Dashboard", new { area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/6.png" alt="Salary Slips" width="30%" /> &nbsp;
                            <h3>Salary Slip</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_ShowMoreDashboard", "App_Dashboard", new { area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/8.png" alt="See More" width="30%" />
                            <h3>Show More</h3>
                        </div>
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

@*THIS BELOW CODE IS FOR SWIPER*@
<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<!-- Initialize Swiper -->
<script>
    var swiper = new Swiper(".mySwiper", {
        spaceBetween: 30,
        centeredSlides: true,
        autoplay: {
            delay: 2500,
            disableOnInteraction: false,
        },
        pagination: {
            el: ".swiper-pagination",
            clickable: true,
        },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
    });
</script>

<script>
    $(document).ready(function () {
        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(function() {
                window.location.href = '@Url.Action("App_ErrorPage", "App_Login", new { Area = "App" })';
            });
        }
    });
</script>