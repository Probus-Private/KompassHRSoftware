
@{
    ViewBag.Title = "App_Attendance_AttendanceSubMenu";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

<style>
    body {
        font-family: roboto;
        /*        background-color: #f7f7f7;*/
        background-color: #ffffff;
    }

    .app-header-fixed {
        padding-top: 0;
    }

    .app-content {
        padding: 10px 20px;
        /*        background-color: #f7f7f7 !important;*/
    }

    .leave-container, .attendance-container, .vms-container {
        padding: 5px;
        /*        background: #fff;*/
        /*        border-radius: 10px;*/
        /*        box-shadow: 0 1px 2px rgba(0,0,0,0.1);*/
    }

        .leave-container h3, .attendance-container h3, .vms-container h3 {
            /*            margin-bottom: 0px;*/
            color: #333;
            font-size: 0.7rem;
            /*            text-align: center;*/
        }

    .leave-box, .attendance-box, .vms-box {
        flex: 1;
        display: flex;
        flex-direction: row;
        align-items: center;
        padding: 15px 5px;
        text-align: left;
        transition: transform 0.3s ease;
        border-radius: 7px;
        background-color: #fff;
        /*        box-shadow: 0 1px 2px rgba(0,0,0,0.1);*/
        border: 1px solid #D9D9D9;
    }

        .leave-box:hover, .attendance-box:hover, .vms-box:hover {
            transform: translateY(-5px);
        }

        .leave-box h3, .attendance-box h3, .vms-box h3 {
            font-size: 0.9rem;
            color: #555;
            font-weight: 500;
        }

    .leave-boxes a, .attendance-boxes a, .vms-boxes a {
        padding: 5px;
    }

    .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    @@media screen and (max-width: 500px) {

        .leave-boxes, .attendance-boxes, .vms-boxes {
            /*            justify-content: space-evenly;*/
        }

        .leave-box h3, .attendance-box h3, .vms-box h3 {
            font-size: 0.8rem;
            font-weight: 700;
        }

        .leave-box, .attendance-box, .vms-box {
            padding: 10px;
        }

            .leave-box img, .attendance-box img, .vms-box img {
                width: 30%;
                /*            margin-top: 5px;*/
            }
    }
</style>

<div id="content" class="app-content bg-white">
    <div class="row">
        <div class="col-lg-12 col-md-12 ui-sortable">
            <!-- BEGIN panel -->
            <div class="leave-container">
                <div class="gradientLine-Div">
                    <div class="gradientLine1"></div>
                    <div class="menu-text"><strong>Main Menu</strong></div>
                    <div class="gradientLine2"></div>
                </div>

                <div class="leave-boxes row">
                    @*@foreach (var item in ViewBag.GetUserMenuList)
                        {
                            <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" class="col-md-2 col-6" style="text-decoration:none !important;">
                                <div class="leave-box">
                                    <img src="~/assets/MenuImages/@item.Icon" />
                                    <h3>@item.ScreenDisplayMenuName</h3>
                                </div>
                            </a>

                        }*@

                    <a href="@Url.Action("App_GetList", "App_Attendance_ShiftChange", new { id = 4, ScreenId=293, area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/ShiftChange.png" alt="Leave" />
                            <h3>Shift Change</h3>
                        </div>
                    </a>
                    <a href="@Url.Action("App_GetList", "App_Attendance_WeekoffChange", new { id = 4, ScreenId=293, area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/MenuImages/DefaultIcon.png" alt="COFF" />
                            <h3>Week Off Change</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_Attendance_PunchMissingApprovalpendingList", "App_Attendance_PunchMissing", new { id = 4, ScreenId=155, area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/4.png" alt="Punch Missing" />
                            <h3>Punch Missing</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_Attendance_WFH_ApprovalandrejectList", "App_Attendance_WFH", new { id = 4, ScreenId=155, area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/5.png" alt="Work From Home" />
                            <h3>Work From Home</h3>
                        </div>
                    </a>

                    <a href="@Url.Action("App_Attendance_GetApproveRejectPersonalGatepassList", "App_Attendance_PersonalGatePass", new { area = "App" })" class="col-md-2 col-6" style="text-decoration:none !important;">
                        <div class="leave-box">
                            <img src="~/assets/img/Icons/14.png" alt="Personal Gatepass" />
                            <h3>Personal Gatepass</h3>
                        </div>
                    </a>

                </div>
            </div>

        </div>
    </div>
</div>
