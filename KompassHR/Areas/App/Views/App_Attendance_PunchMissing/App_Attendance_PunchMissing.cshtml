<script>
    $(document).ready(function () {
        debugger;

        //Start Validation for back day days
        var BackDatedDays = @Html.Raw(Json.Encode(ViewBag.GetBackDatedDays));
        var fromDateInput = document.getElementById("PunchMissingAttendanceDate");
        var toDateInput = document.getElementById("PunchMissingLogDate");
        //For min Days (Back DAys -------------------------------------------------)
        var currentDate = new Date();
        var minDate = new Date();
        var LogminDate = new Date();
        minDate.setDate(currentDate.getDate() - BackDatedDays);
        var minDateString = minDate.toISOString().split('T')[0];
        fromDateInput.setAttribute("min", minDateString);
        toDateInput.setAttribute("min", minDateString);

        //For MAx Days  -------------------------------------------------)
        LogminDate.setDate(currentDate.getDate()+0);
        minDate.setDate(currentDate.getDate());
        var minDateString = minDate.toISOString().split('T')[0];
        var LogminDateString = LogminDate.toISOString().split('T')[0];
        fromDateInput.setAttribute("max", LogminDateString);
        toDateInput.setAttribute("max", LogminDateString);
        //  toDateInput.setAttribute("min", minDateString);

        //--------------------------------------------------------------------------------
        //End Validation for back day days

        $("#btnGetList").click(function () {
            var url = '@Url.Action("App_Attendance_PunchMissingApprovalpendingList", "App_Attendance_PunchMissing")';
            window.location.href = url;
        })


                                             


        var BAckDate = @Html.Raw(Json.Encode(ViewBag.BAckDate));
        $("#BAckDate").val(BAckDate);

        var Branch = @Html.Raw(Json.Encode(ViewBag.Branch));
        $("#txtBranch").val(Branch);

        var Emp = @Html.Raw(Json.Encode(ViewBag.Emp));
        $("#ddlEmployeeName").val(Emp);

        var CMPID = @Html.Raw(Json.Encode(ViewBag.CMPID));
        $("#txtCMPID").val(CMPID);

        var AllowInReq = @Html.Raw(Json.Encode(ViewBag.AllowInReq));
        $("#AllowInReq").val(AllowInReq);

        var TotalTakenIn = @Html.Raw(Json.Encode(ViewBag.TotalTakenIn));
        $("#TotalTakenIn").val(TotalTakenIn);

        var AllowOutReq = @Html.Raw(Json.Encode(ViewBag.AllowOutReq));
        $("#AllowOutReq").val(AllowOutReq);
        var TotalTakenOut = @Html.Raw(Json.Encode(ViewBag.TotalTakenOut));
        $("#TotalTakenOut").val(TotalTakenOut);

        var AllowBeforeStartShift = @Html.Raw(Json.Encode(ViewBag.AllowBeforeStartShift));
        $("#AllowBeforeStartShift").val(AllowBeforeStartShift);
        var AllowAfterEndShift = @Html.Raw(Json.Encode(ViewBag.AllowAfterEndShift));
        $("#AllowAfterEndShift").val(AllowAfterEndShift);

        var AtdDate = @Html.Raw(Json.Encode(ViewBag.AtdDate));
        var AtdDateLog = @Html.Raw(Json.Encode(ViewBag.AtdDateLog));
        if(AtdDate !=null){
            var Today = new Date(AtdDate);
            var d =("0" + Today.getDate()).slice(-2)
            var m = ("0" + (Today.getMonth() + 1)).slice(-2);
            var y = Today.getFullYear();
            var ddmmyy = y+"-"+m+"-"+d;
            $("#PunchMissingAttendanceDate").val(ddmmyy);
        }
        if(AtdDateLog !=null){
            var Today = new Date(AtdDateLog);
            var d =("0" + Today.getDate()).slice(-2)
            var m = ("0" + (Today.getMonth() + 1)).slice(-2);
            var y = Today.getFullYear();
            var ddmmyy1 = y+"-"+m+"-"+d;
            $("#PunchMissingLogDate").val(ddmmyy1);
        }


        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#PunchMissingAttendanceDate").change(function() {
            var AttendanceDate = $("#PunchMissingAttendanceDate").val();
            $("#PunchMissingLogDate").val(AttendanceDate);

            // Convert AttendanceDate to Date object
