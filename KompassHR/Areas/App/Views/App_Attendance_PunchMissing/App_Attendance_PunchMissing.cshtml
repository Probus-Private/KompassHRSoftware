            var formattedMinDate = formatDate(minDate);
            var formattedMaxDate = formatDate(maxDate);

            // Set min and max attributes for #PunchMissingLogDate
            $("#PunchMissingLogDate").attr("min", formattedMinDate).attr("max", formattedMaxDate);
