<div class="col-md-2">
    <a href="@Url.Action("App_Attendance_PunchMissing", "App_Attendance_PunchMissing", new { area = "App", ScreenId = 146 })" class="mobile-fixed-add-btn">
        <button type="button" class="btn btn-primary shadow">
            <i class="fa-solid fa-plus fa-lg"></i>
        </button>
    </a>
</div>

<div class="container mx-auto px-2 py-2">
    <!-- Search Input -->
    <!-- Fixed Search Bar -->
    <div class="fixed top-0 left-0 w-full bg-white z-50 shadow">
        <div class="flex justify-center py-2">
            <div class="w-full max-w-md">
                <input type="text" id="searchDate" class="form-control w-full px-4 py-2 border rounded-md"
                       placeholder="Search by Date (e.g., 20/Aug/2024)">
            </div>
        </div>
    </div>

    <div class="pt-10">
        <div class="flex flex-wrap justify-center gap-2">
            @foreach (var d in ViewBag.PendingList)
            {
                var PunchMissingId = d?.PunchMissingId ?? 0;
                var cancelStatus = d?.CancelStatus;
                //var status = d?.Status ?? "";
                string topBorderColor = d.Status != null && d.Status.Contains("Approved") ? "green-500"
                        : d.Status != null && d.Status.Contains("Rejected") ? "red-500"
                        : d.Status != null && d.Status.Contains("Pending") ? "orange"
                        : "";
                string bgClass = $"bg-{topBorderColor}";
                string borderClass = $"border-t-4 border-{topBorderColor}";
                <div class="bg-white rounded-xl shadow-md p-3 w-full sm:max-w-md md:max-w-sm border-t-4 @borderClass leave-card">
                    <!-- Top Section -->
                    <div class="flex justify-between items-start mb-1">
                        <div>
                            <div class="text-sm-0"><i class="fa-solid fa-hashtag text-purple-600"></i> Doc No. : @d.DocNo</div>
                            <div class="text-base font-semibold text-gray-800">
                                @(d != null ? $"{d.PunchMissingInOut} -{"Punch Missing"}" : "")
                            </div>
                        </div>
                        <div class="flex items-center justify-end space-x-2">
                            <div>
                                <div class="text-white text-center px-4 py-1 rounded-full text-sm font-semibold @bgClass">
                                    @d.Status
                                </div>
                                <div class="text-xs text-gray-500 mt-1 text-right">
                                    @d.ApprovedDay
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Table-style Layout -->
                    <table class="w-full text-sm text-gray-700 table-auto">
                        <tbody>
                            <tr class="align-top">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-calendar-alt text-blue-600"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">For Date/Time</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md">
                                    @d.AttendanceDate (@d.ForLogTime)
                                </td>
                            </tr>

                            <tr class="align-top">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-briefcase text-purple-600"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">Shift</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md">
                                    @d.PunchMissingShiftName
                                </td>
                            </tr>
                            <tr class="align-top">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-lightbulb text-yellow-500"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">Reason</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md truncate">
                                    @d.Reason
                                </td>
                            </tr>

                            <tr class="align-top border-b ">
                                <td class="py-2 w-6 text-center align-middle">
                                    <i class="fas fa-user-tie text-indigo-600"></i>
                                </td>
                                <td class="font-medium whitespace-nowrap pr-1">Approver</td>
                                <td class="px-1">:</td>
                                <td class="break-words text-wrap max-w-xs sm:max-w-md">
                                    @d.ApprovedBy
                                </td>
                            </tr>

                            
                        </tbody>
                    </table>


                    <!-- Footer Buttons -->
                    <div class="flex flex-wrap justify-start items-center gap-3 mt-2">
                        <i class="fa-solid fa-sitemap fa-2xl cursor-pointer" onclick="ApproveStatus(@d.PunchMissingId)"></i>
                        <a href="@Url.Action("App_PunchMissingDetails", "App_Attendance_PunchMissing", new { PunchMissingId = d.PunchMissingId })"
                           class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                            <i class="fa-solid fa-bars"></i> View Details
                        </a>

                        @if (d.Status.Contains("Pending"))
                        {
                            <button onclick="DeletePunchMissing('@d.PunchMissingId_Encrypted','@d.Status')"
                                    class="text-red-600 border border-red-500 px-2 py-1 rounded-md hover:bg-red-50">
                                <i class="fa fa-trash"></i> Delete
                            </button>
                        }
                        else
                        {
                           if (cancelStatus == "Requested" || cancelStatus == "Canceled")
                           {
                            <button class="btn btn-outline-secondary btn-sm px-2 py-1 rounded-md" disabled>@cancelStatus</button>
                           }
                           else
                           {
                            <a href="#modal-dialogForHoldReject1" onclick="CancelRequestFun(@d.PunchMissingId,'@d.Status')"
                               class="text-blue-600 border border-blue-500 px-2 py-1 rounded-md hover:bg-blue-50">
                                <i class="fa fa-xmark"></i> Cancel
                            </a>
                           }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="RequestInfoModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body p-3" style="position: relative;">
                <!-- Close Button -->
                <div class="position-absolute top-0 end-0 m-2" data-bs-dismiss="modal">
                    <button type="button" class="btn btn-sm btn-danger rounded-circle" id="CloseModel" aria-label="Close">
                        <i class="fa fa-xmark"></i>
                    </button>
                </div>
                <!-- Content -->
                <div id="timelineMainDiv" class="mt-4">
                    <!-- Dynamic timeline content here -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function ApproveStatus(DocId) {
        $.ajax({
            url: '@Url.Action("RequestStatus", "App_Attendance_PunchMissing")',
            method: "GET",
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            data: { DocId: DocId },
            success: function (response) {
                debugger
                $('#RequestInfoModal').modal('show');
                var data = JSON.parse(response);
                var timelineHtml = '';
                for (var i = 0; i < data.length; i++) {
                    var icon = '';
                    var iconColor='';
                    var textColor = '';
                    if (data[i][5].Value === 'success') {
                        icon = '✔';
                        iconColor ="iconGreen";
                        textColor = 'Green';
                    } else if (data[i][5].Value === 'error') {
                        icon = '✘';
                        iconColor ="iconRed";
                        textColor = 'Red';
                    } else {
                        icon = '⏳';
                        iconColor ="iconRed";
                        textColor = 'Black';
                    }
                    timelineHtml += '<div class="timeline-item">' +
                                '<div class="' + iconColor + '"><span class="timelineIcon">' + icon + '</span></div>' +
                                '<div class="text">' +
                                '<b><p class="timelineRemark" style="color:' + textColor + ';">' + data[i][2].Value + '</p></b>' +
                                '<small class="timelineEmployeeName" style="color:Black;">' + data[i][3].Value + '</small><br />' +
                                 '<small class="timelineDate" style="color:Black;">' + data[i][1].Value + '</small>' +
                                '</div>' +
                                '</div>';
                }
                $('#timelineMainDiv').html(timelineHtml);
            }
        });
    }

</script>

<!-- #Start Cancel Request dialog -->
<div class="modal fade" id="CancelModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Cancel</h4>
            </div>
            <div class="modal-body">
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            @* @Html.DropDownListFor(model => model.PunchMissingEmployeeID, new SelectList(ViewBag.GetAdditionalList, "Id", "Name"), new { id = "LeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-select", autocomplete = "off" })*@
                                            <h6> Select Approver Name</h6>

                                            @Html.DropDownList("Id", new SelectList(ViewBag.GetManagerEmployee, "Id", "Name"), "--Select--", new { @class = "form-control", Id = "ddlManagerName" })
