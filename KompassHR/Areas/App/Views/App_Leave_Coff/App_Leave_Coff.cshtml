<div id="content" class="app-content">
    <div class="panel panel-inverse" data-sortable-id="index-1">
        <div class="panel-body" data-scrollbar="false">

            <div class="w-full overflow-x-auto rounded-lg border border-gray-200">
                <table class="w-full text-sm text-center text-gray-700 min-w-[500px]" id="tblCoffRequest">
                    <thead class="bg-blue-500 text-xs text-white-100 sticky top-0">
                        <tr>
                            <th>Select </th>
                            <th hidden>COFF Generation ID</th>
                            <th>Generation Date</th>
                            <th>Available Coff</th>
                            <th> Valid Till</th>

                        </tr>
                    </thead>
                    <tbody id="tblCOFFRequestBody">
                        @foreach (var d in ViewBag.GetGeneratedDays)
                        {
                            DateTime coffExpiredDate;
                            bool isDateParsed = DateTime.TryParse(d.CoffExpriredDate?.ToString(), out coffExpiredDate);

                            <tr class="coff-row">
                                <td class="text-center">
                                    @if (isDateParsed && coffExpiredDate > DateTime.Today)
                                    {
                                        <input type="checkbox" name="name" id="txtCoffGenerationID" value="@d.CoffGenerationID" />
                                    }
                                    else
                                    {
                                        <span class="Error" style="color:red">Expired</span>
                                    }
                                </td>
                                <td hidden class="text-nowrap">@d.CoffGenerationID</td>
                                <td class="text-nowrap">@d.CoffGenerationDate</td>
                                <td class="text-nowrap">@d.Approvenoofcoff</td>
                                <td class="text-nowrap">@d.CoffExpriredDate</td>
                            </tr>
                        }


                    </tbody>
                </table>

            </div>







            <br />


            <div class="row">
                <div class="col-md-12">
                    <div class="panel panel-inverse" data-sortable-id="index-1">
                        <div class="panel-body">
                            <form role="form" action='@Url.Action("App_SaveUpdate", "App_Leave_Coff", new { area = "App" })' id="SaveCOFFRequest" method="post">
                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-hashtag text-purple-600"></i> Doc No.
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.DocNo, new { @id = "txtDocNo", name = "DocNo", @class = "form-control", autocomplete = "off", Value = @ViewBag.DocNo, Style = "background-color: lightgray;", @readonly = "readonly" })
                                        @Html.HiddenFor(model => model.CoffRequestID_Encrypted)
                                    </div>
                                </div>



                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-calendar-days text-orange-600"></i> Doc Date
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.DocDate, new { @id = "txtDocDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date", Style = "background-color: lightgray;", @readonly = "readonly" })
                                    </div>
                                </div>


                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fas fa-briefcase text-purple-600"></i> Shift
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.CoffShiftId, new SelectList(ViewBag.GetShiftList, "ShiftId", "ShiftName"), "--Select--", new { id = "ddlCoffShiftId", name = "CoffShiftId", @class = "form-select", autocomplete = "off" })
                                    </div>
                                </div>


                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-cash-register text-green-500"></i> Day Type
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.CoffRequestDayType, new List<SelectListItem>{
                                                                                 new SelectListItem {Text ="Full Day", Value="Full Day"},
                                                                                 new SelectListItem {Text ="1st Half", Value="1st Half"},
                                                                                 new SelectListItem {Text ="2nd Half", Value="2nd Half"}
                                                                                }, "--Select--", new { @class = "form-select", name = "CoffRequestDayType", @id = "ddlCoffRequestDayType" })
                                    </div>
                                </div>


                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-calendar-day text-blue-500"></i>  From Date
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.FromDate, new { @id = "txtFromDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date" })


                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-calendar-check text-blue-600"></i>  To Date
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.ToDate, new { @id = "txtToDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date" })
                                        @Html.ValidationMessageFor(model => model.ToDate, "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })
                                    </div>
                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-hourglass text-blue-500"></i> Total Days
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.TotalDays, new { @id = "txtTotalDays", name = "TotalDays", @class = "form-control", autocomplete = "off", Style = "background-color: lightgray;", @readonly = "readonly" })
                                    </div>
                                </div>


                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fas fa-lightbulb text-yellow-500"></i> Reason
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextAreaFor(model => model.Reason, new { @id = "txtReason", name = "Reason", @class = "form-control", autocomplete = "off" })
                                    </div>
                                </div>



                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("App_GetList", "App_Leave_Coff", new { area = "App" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>






















<script>
    $(document).ready(function () {
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
        $("#txtDocDate").val(dateString);

        $("#ddlCoffShiftId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $("#txtFromDate,#txtToDate").change(function () {
            debugger;
            var StartDate= document.getElementById('txtFromDate').value;
            var CoffRequestDayType= $("#ddlCoffRequestDayType").val();
            var EndDate= document.getElementById('txtToDate').value;
            if(StartDate==""){
                $('#ErrortxtToDate').html("To date should not be less than from date"); return false;
                $("#txtToDate").val("");
            }
            else{
                $('#ErrortxtToDate').html("");
            }
            var sDate = new Date(StartDate);
            var eDate = new Date(EndDate);
            var Time = Math.abs(eDate - sDate);
            var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;


            if(CoffRequestDayType=="Full Day")
            {
                $("#txtTotalDays").val(days);
                // $("#txtTotalDays").val(1);
            }
            else if(CoffRequestDayType=="1st Half")
            {
                var StartDate= document.getElementById('txtFromDate').value;
                $("#txtToDate").val(StartDate);
                $("#txtTotalDay").val("0.5");
            }
            else if(CoffRequestDayType=="2nd Half")
            {
                var StartDate= document.getElementById('txtFromDate').value;
                $("#txtToDate").val(StartDate);
                $("#txtTotalDay").val("0.5");
            }
            let toDateValue = $("#txtToDate").val();
            //if (!toDateValue) return; // Exit if no toDate is selected

            // Create a date object for 'toDate' and reset the time to 00:00:00
            let toDate = new Date(toDateValue);
            toDate.setHours(0, 0, 0, 0); // Reset time

            // Loop through each row inside the #tblCOFFRequestBody table
            $("#tblCOFFRequestBody .coff-row").each(function () {
                let row = $(this);

                // Get the expired date from the 4th <td> (index 3) and reset its time
                let expiredDateText = row.find("td").eq(4).text().trim();
                let expiredDate = new Date(expiredDateText);
                expiredDate.setHours(0, 0, 0, 0); // Reset time

                // Target the .text-center <td> where the checkbox or "Expired" text goes
                let textCenterCell = row.find(".text-center");

                if (expiredDate < toDate) {
                    // If expired, remove checkbox and show "Expired" text
                    textCenterCell.find(".coff-checkbox").remove();
                    if (!textCenterCell.find(".Error").length) {
                        textCenterCell.html('<span class="Error" style="color:red">Expired</span>');
                    }
                } else {
                    // If not expired, show checkbox and remove "Expired" text
                    if (!textCenterCell.find(".coff-checkbox").length) {
                        let coffID = row.find(".coff-id").text(); // Get the ID
                        textCenterCell.html(`<input type="checkbox" class="coff-checkbox" name="name" value="${coffID}" />`);
                    }
                    textCenterCell.find(".Error").remove();
                }
            });

            var StartDate=$("#txtFromDate").val();
            var EndDate=$("#txtToDate").val();

            var sDate = new Date(StartDate);
            var eDate = new Date(EndDate);
            var Time = Math.abs(eDate - sDate);
            var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;
            if(StartDate!= '' && EndDate!= '' && sDate > eDate)
            {
                $("#ErrortxtToDate").html("To date should not be less than from date.");
                $("#txtToDate").val('');
                return false;
            }
            else{
                $("#ErrortxtToDate").html("");
            }



        });

        $("#ddlCoffRequestDayType").change(function () {
            debugger;
            var StartDate= document.getElementById('txtFromDate').value;
            var EndDate= document.getElementById('txtToDate').value;
            var CoffRequestDayType= $("#ddlCoffRequestDayType").val();
            if(CoffRequestDayType=="Full Day")
            {
                //var sDate = new Date(StartDate);
                //var eDate = new Date(EndDate);
                //var Time = Math.abs(eDate - sDate);
                //var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;
                $("#txtToDate").removeAttr('readOnly', true);
                $("#txtTotalDays").val(1);
            }
            else if(CoffRequestDayType=="1st Half")
            {
                $("#txtToDate").val("");
                $("#txtFromDate").val("");
                $("#txtTotalDays").val(0.5);
                $("#txtToDate").attr('readOnly', true);
            }
            else if(CoffRequestDayType=="2nd Half")
            {
                $("#txtToDate").val("");
                $("#txtFromDate").val("");
                $("#txtTotalDays").val(0.5);
                $("#txtToDate").attr('readOnly', true);
            }

        });

    })//ready Function


    //$("#txtToTime").change(function(){
    //    debugger;
    //    var FromTime = $("#txtFromTime").val();
    //    var ToTime = $("#txtToTime").val();

    //    if (FromTime >= ToTime) {
    //        $('#ErrortxtToTime').html("To time should be greater than from time");
    //        return false;
    //    }else if(FromTime < ToTime){
    //        $('#ErrortxtFromTime ,#ErrortxtToTime').html("");
    //    }
    //    else {
    //        $('#ErrortxtToTime').html("");
    //    }
    //    var difference = (strToMins(ToTime) - strToMins(FromTime));
    //    $('#txtTotalDuration').val(difference);
    //});





    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveCOFFRequest').validate({
        rules: {
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },
            CoffRequestDayType: {
                required:true,
            },
            Reason: {
                required:true,
            },
            CoffShiftId: {
                required:true,
            },
        },
        messages: {
            FromDate: {
                required:"From date is required",
            },
            ToDate: {
                required:"To date is required",
            },
            CoffRequestDayType: {
                required:"Day type is required",
            },
            Reason: {
                required:"Reason is required"
            },
            CoffShiftId: {
                required:"Shift is required"
            },
        },
    });

    var form = $("#SaveCOFFRequest");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtFromDate").removeClass("error");
            $("#txtToDate").removeClass("error");
            return false;
        }
        var StartDate= document.getElementById('txtFromDate').value;
        var EndDate= document.getElementById('txtToDate').value;
        if(StartDate>EndDate){
            $('#ErrortxtToDate').html("To date should not be less than from date"); return false;
        }
        else{
            $('#ErrortxtToDate').html("");
        }
        var table = document.getElementById("tblCOFFRequestBody");
        var rowCount = table.rows.length;
        if(rowCount==0)
        {
            debugger;
            Swal.fire({
                icon: "error",
                text: "You don't have COFF balance.",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        var GetTotalDays=Number($("#txtTotalDays").val());
        var Sum=0;
        var CoffRequestIDRecord=[];
        var zxy="";
        $('input:checkbox:checked').each(function (i) {
            debugger;

            var data1 = {};
            var $row = $(this).closest('tr');
           // data1.CoffGeneratedID = $(this).val();
            data1.CoffGeneratedID = $row.find('td:eq(1)').text();
            data1.Days = $row.find('td:eq(3)').text(); // Get the 'Days' value from the 4th cell (index 3)
            Sum += parseFloat(data1.Days); // Convert to integer and add to Sum
            if (i > 0) {
                if (GetTotalDays > Sum) {
                    zxy="Pending";
                }
            }
            CoffRequestIDRecord.push(data1);
        });
        //if(zxy=="Pending")
        //{
        //    Swal.fire({
        //        icon: "error",
