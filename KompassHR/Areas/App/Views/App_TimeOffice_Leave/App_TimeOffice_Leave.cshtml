    function formatDate(dateString) {
        // Extract the timestamp
        let timestamp = Number(dateString.match(/\/Date\((\d+)\)\//)[1]);
        // Create a Date object
        let date = new Date(timestamp);

        // Extract day, month, year, hours, and minutes
        let day = String(date.getDate()).padStart(2, '0'); // Pad single digits with a leading zero
        let month = String(date.getMonth() + 1).padStart(2, '0'); // Months are 0-indexed, so add 1
        let year = date.getFullYear();
        let hours = String(date.getHours()).padStart(2, '0'); // Pad single digits with a leading zero
        let minutes = String(date.getMinutes()).padStart(2, '0'); // Pad single digits with a leading zero

        // Return the formatted date string
        return `${day}/${month}/${year}, ${hours}:${minutes}`;
    }

