<script>
    function btnGetLists()
    {
        var url = '@Url.Action("App_GetList", "App_TimeOffice_Leave")';
        window.location.href = url;
    }

    $(document).ready(function () {
        $("#LeaveMasterEmployeeId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;

        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false // Disable outside clicks
            }).then(() => {
                window.location.reload();
            });
        }


        @*var data = @Html.Raw(Json.Encode(ViewBag.GetShiftList));
        debugger;
        $("#ddlShift").find("option").remove();
        $("#ddlShift").append("<option value='0'>-- Select--</option>");
        for(var i=0; i<data.length; i++)
        {

            $("#ddlShift").append("<option value='" + data[i].ShiftId +"'>" + data[i].ShiftName +"</option>");
            $("#ShiftName").val(data[i].ShiftName);
        }*@

        $('#ToDate,#FormDate').change(function () {
            debugger

            var CheckValidation = $("#LeaveMasterDayType").val();
            if(CheckValidation=="1st Half")
            {
                var StartDate= document.getElementById('FormDate').value;
                $("#ToDate").val(StartDate);
                $("#txtTotalDay").val("0.5");
            }
            if(CheckValidation=="2nd Half")
            {
                var StartDate= document.getElementById('FormDate').value;
                $("#ToDate").val(StartDate);
                $("#txtTotalDay").val("0.5");
            }

            var StartDate= document.getElementById('FormDate').value;
            var EndDate= document.getElementById('ToDate').value;
            if(StartDate=="")
            {
                $("#ErrortxtToDate").html("Please select form date first.");
                $("#ToDate").val('');
                return false;
            }
            else{
                $("#ErrortxtToDate").html("");
            }

            var sDate = new Date(StartDate);
            var eDate = new Date(EndDate);
            var Time = Math.abs(eDate - sDate);
            var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;

            if(CheckValidation=="Full Day")
            {
                var StartDate= document.getElementById('FormDate').value;
                //$("#ToDate").val(StartDate);
                $("#txtTotalDay").val(days);
            }
            if(StartDate!= '' && EndDate!= '' && sDate > eDate)
            {
                $("#ErrortxtToDate").html("To date should not be less than from date.");
                $("#ToDate").val('');
            }
            else{
                $("#ErrortxtToDate").html("");
            }

            $.ajax({
                url: '@Url.Action("GetData", "ESS_TimeOffice_Leave")',
                type: 'GET',
                data: { fromDate: StartDate, toDate: EndDate },
                success: function (response) {
                    debugger;
                    $('#tblConflictEmp tbody').empty();

                    response.forEach(item => {
                        $('#tblConflictEmp tbody').append(`
                                    <tr>
                                    <td class="text-nowrap">${item[0].Value}</td>
                                    <td class="text-nowrap">${item[1].Value}</td>
                                    <td class="text-nowrap">${item[2].Value}</td>
                                    <td class="text-nowrap">${item[3].Value}</td>
                                    </tr>
                                `);
                    });
                },
                error: function (err) {
                    console.error('Error fetching data:', err);
                }
            });
        });

        $('#LeaveMasterLeaveYearId').change(function () {
            debugger;
            var FYearId=$("#LeaveMasterLeaveYearId").val();
            $.ajax({
                url: '@Url.Action("GetLeaveBalance", "ESS_TimeOffice_Leave")',
                type: 'GET',
                data: { FYearId: FYearId },
                success: function (response) {
                    debugger;
                    $('#tblLeaveBalance tbody').empty();

                    $('#tblLeaveBalance tbody').empty();
                    var GetData = response.data[0];
                    const jsonData = GetData.reduce((acc, item) => {
                        acc[item.Key] = item.Value;
                        return acc;
                    }, {});

                    $('#tblLeaveBalance tbody').append(`
                            <tr>
                                <td class="text-nowrap">${jsonData.LeaveTypeShortName}</td>
                                <td class="text-nowrap">${jsonData.OpeningBalance}</td>
                                <td class="text-nowrap">${jsonData.TakenLeave}</td>
                                <td class="text-nowrap">${jsonData.PendingLeave}</td>
                                <td class="text-nowrap">${jsonData.ClosingBalance}</td>
                            </tr>
                        `);
                },
                error: function (err) {
                    console.error('Error fetching data:', err);
                }
            });
        });

        var TotalCount = $("#ShortLeaveTotalCount").text();
        var AvailesCount = $("#ShortLeaveAvailedCount").text();
        var Balance = TotalCount - AvailesCount;
        $("#ShortLeaveBalanceCount").text(Balance);

        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];

        $("#LeaveMasterDayType").change(function(){
            var SelectedDay =   $("#LeaveMasterDayType").val();
            if(SelectedDay== "Full Day")
            {
                //$("#FormDate").val(dateString);
                //$("#ToDate").val(dateString);
                $("#FormDate").val("");
                $("#ToDate").val("");
                $("#ToDate").attr('readOnly', false);
                $("#txtTotalDay").val("1");
            }
            if(SelectedDay== "1st Half")
            {
                $("#FormDate").val("");
                $("#ToDate").val("");
                $("#ToDate").attr('readOnly', true);
                $("#txtTotalDay").val("0.5");
            }
            if(SelectedDay== "2nd Half")
            {
                $("#FormDate").val("");
                $("#ToDate").val("");
                $("#ToDate").attr('readOnly', true);
                $("#txtTotalDay").val("0.5");
            }

        });

        function ResetFile()
        {
            let allowedExtension = ['image/jpeg', 'image/jpg', 'image/png'];
            let type = document.getElementById('LeaveFilePath').files[0].type;

            if(allowedExtension.indexOf(type)>-1)
            {
            }else{
                alert('File type should be jpeg/jpg/png')
                document.getElementById("LeaveFilePath").value = null;
            }
            $("#lblFileName").text('');
        }



        $("#LeaveType").change(function(){
            debugger;
            var GetLeaveTypeId = $("#LeaveType").val();
            $.ajax({
                url: '@Url.Action("GetFutureAndBackDays", "ESS_TimeOffice_Leave")',
                Type:"Get",
                contentType:"application/json; charset=utf-8",
                dataType:"text",
                data:{GetLeaveTypeId:GetLeaveTypeId},
                success:function(data){
                    debugger;
                    var data1= JSON.parse(data);
                    var GetBackDays=data1[0][0].Value;
                    var GetFutureDays=data1[0][1].Value;
                    var IsDocRequired=data1[0][2].Value;
                    var IsAfterDays=data1[0][3].Value;

                    localStorage.setItem("IsDocRequired", IsDocRequired);
                    localStorage.setItem("IsAfterDays", IsAfterDays);
                    //alert(IsDocRequired);
                    if(GetBackDays!=null && GetFutureDays!=null)
                    {
                        var fromDateInputMin = document.getElementById("FormDate");
                        var toDateInputMin = document.getElementById("ToDate");
                        var currentDateMin = new Date();
                        var minDate = new Date();
                        minDate.setDate(currentDateMin.getDate() - GetBackDays);
                        var minDateString = minDate.toISOString().split('T')[0];
                        fromDateInputMin.setAttribute("min", minDateString);
                        toDateInputMin.setAttribute("min", minDateString);

                        //Validation for back day days Max Days
                        var currentDateMax = new Date();
                        var MaxDate = new Date();
                        MaxDate.setDate(currentDateMax.getDate() + GetFutureDays);
                        var maxDateString = MaxDate.toISOString().split('T')[0];
                        fromDateInputMin.setAttribute("max", maxDateString);
                        toDateInputMin.setAttribute("max", maxDateString);
                    }
                }
            });

        });




    });//ready funcation
    function LoadEmployeeLog() {
        debugger;
        var LogFromDate = $("#FormDate").val();
        var LogToDate = $("#ToDate").val();
        if (LogFromDate=="")
        {
            $("#ErrortxtFromDate").html("From date and To date required");return false;
        }else{$("#ErrortxtFromDate").html("");}
        if (LogToDate=="")
        {
            $("#ErrortxtFromDate").html("From date and To date required");return false;
        }else{$("#ErrortxtFromDate").html("");}

        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: '@Url.Action("GetEmployeeLogAndShift", "ESS_TimeOffice_Leave")',
            data: { LogFromDate: LogFromDate, LogToDate: LogToDate },
            success: function (data) {
                debugger;
                $("#tblEmployeeLog  tbody tr").detach();
                //$("#tblShift  tbody tr").detach();
                var Logdata = data;
                //var Shiftdata = data.Shiftdata;
                var tableLogContent = '';
                //var tableShiftContent = '';

                for (var i = 0; i < Logdata.length; i++) {
                    tableLogContent += '<tr id="LogSelectRow_NotUse">';
                    tableLogContent += '<td class="text-nowrap">' + convertDateTime12Hr(Logdata[i][0].Value) + '</td>';
                    if (Logdata[i][1].Value=="IN")
                    {
                        tableLogContent += '<td class="text-nowrap text-center"><i class="fa-solid fa-circle-down fa-lg" style="color: #5cce40; padding: 0px;"></i></td>';
                    }
                    else{
                        tableLogContent += '<td class="text-nowrap text-center"><i class="fa-solid fa-circle-up fa-lg" style="color:#fe6966; padding: 0px;"></i></td>';
                    }
                    tableLogContent += '<td class="text-nowrap text-center">' + Logdata[i][1].Value + '</td>';
                    //tableLogContent += '<td hidden>' + convertDateTime(Logdata[i][0].Value) + '</td>';
                    //tableLogContent += '<td  class="text-nowrap text-center"><i class="fa-solid fa-square-check fa-lg" style="color:#5cce40;padding:0px;cursor:pointer;" onclick="funLogInOutTime(\'IN\', \'' + convertDateTime(Logdata[i][0].Value) + '\')"></i></td>';
                    //tableLogContent += '<td  class="text-nowrap text-center"><i class="fa-solid fa-square-check fa-lg" style="color:#fe6966;padding:0px;cursor:pointer;" onclick="funLogInOutTime(\'OUT\', \'' + convertDateTime(Logdata[i][0].Value) + '\')"></i></td>';
                }
                $('#tblEmployeeLog tbody').append(tableLogContent);
            }
        });
    }

    //This Function use for bind in input type
    function convertDateTime12Hr(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date1 = millisecToDateTime12Hour(getdate);
        return date1;
    }
    function millisecToDateTime12Hour(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = ("0" + date.getMinutes()).slice(-2);

        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = ("0" + hours).slice(-2);

        var yyyyMMdd = [date.getFullYear(), mnth, day].join("-");
        var hhmm = [hours, minutes].join(":");
        return yyyyMMdd + " " + hhmm + " " + ampm;
    }
