
@{
    ViewBag.Title = "App_GetList";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}



<style>
   .gradientLine-Div {
        display: flex;
        align-items: center;
        margin: 10px 0;
    }

    .gradientLine1,
    .gradientLine2 {
        flex: 1; /* Better than fixed width to adapt responsively */
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        background: linear-gradient(to right, #000000, #66666600);
    }

    .gradientLine-Div div strong {
        white-space: nowrap;
    }


    .profile-card {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

        .profile-card .header {
            padding: 15px;
            position: relative;
            color: white;
        }

    .org-level {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.4);
        padding: 4px 8px;
        border-radius: 10px;
        font-size: 12px;
    }

    .profile-card .content {
        padding: 15px;
    }

    .profile-card .name {
        font-size: 16px;
        font-weight: 600;
    }

    .profile-card .subtitle {
        font-size: 14px;
        color: #555;
        margin-bottom: 5px;
    }



    .app-header-fixed {
        padding-top: 5px;
         padding-bottom: 5px;
    }

    .app-content {
        padding: 5px 5px;
    }
</style>

<div id="content" class="app-content">
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="@Url.Action("App_TimeOffice_Leave", "App_TimeOffice_Leave", new { area = "App" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                        </div>

                        <div class="gradientLine-Div">
                            <div class="gradientLine1"></div>
                            <div class="menu-text"><strong>Leave List</strong></div>
                            <div class="gradientLine2"></div>
                        </div>

                        <div class="container mt-3">
                            <div class="row">
                                @{
                                    var leaveList = ViewBag.LeaveAll as List<dynamic>; // Change to your actual model
                                }

                                <div class="container mt-3">
                                    <!-- Search Box -->
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <input type="text" id="searchDate" class="form-control" placeholder="Search by Date (e.g., 20/Aug/2024 )">
                                        </div>
                                    </div>

                                    <div class="row" id="cardContainer">
                                        @foreach (var d in leaveList)
                                        {
                                            <div class="col-md-4 col-sm-6 mb-4 leave-card" data-date="@d.ForDate">
                                                <div class="profile-card">
                                                    <div class="header d-flex justify-content-between align-items-center px-3 py-2" style="background-color: #007bff; border-bottom: 3px solid #0056b3;">
                                                        <h5 class="text-white m-0">Leave Status</h5>
                                                        <a href="@Url.Action("App_LeaveDetails", "App_TimeOffice_Leave", new { LeaveMasterId = d.LeaveMasterId })" title="View">
                                                            <i class="fa-solid fa-circle-chevron-right fa-xl text-white"></i>
                                                        </a>
                                                    </div>


                                                    <div class="content">
                                                        <p class="subtitle name"><strong>For Date:</strong> @d.ForDate</p>
                                                        <p class="subtitle"><strong>Reason:</strong> @d.Reason</p>
                                                        <p class="subtitle"><strong>Status:</strong> @d.Status</p>
                                                    </div>

                                                    <!-- Footer with Icons -->
                                                    <div class="card-footer d-flex justify-content-end gap-3 p-2 bg-white border-top">

                                                        <!-- View Icon -->
                                                        @*<a href="@Url.Action("App_LeaveDetails", "App_TimeOffice_Leave", new { LeaveMasterId = d.LeaveMasterId })" title="View">
                                                            <i class="fa fa-eye fa-lg text-primary"></i>
                                                        </a>*@

                                                        <!-- Cancel Icon (conditionally shown) -->
                                                        @if (d.CancelStatus == "Requested" || d.CancelStatus == "Canceled")
                                                        {
                                                            @*<i class="fa fa-ban fa-lg text-secondary" title="@d.CancelStatus"></i>*@
                                                            @*<i class="fas fa-times-circle fa-lg" title="@d.CancelStatus"></i>*@
                                                            <span>@d.CancelStatus</span>
                                                        }
                                                        else
                                                        {
                                                            <a href="#modal-dialogForHoldReject1" onclick="CancelRequestFun(@d.LeaveMasterId,'@d.Status')" title="Cancel">
                                                                @*<i class="fa fa-xmark fa-lg text-warning"></i>*@
                                                                <i class="fas fa-window-close fa-xl" style="color: blue;"></i>
                                                            </a>
                                                        }
                                                        <!-- Delete Icon -->
                                                        <a href="javascript:void(0);" onclick="DeleteLeave('@d.LeaveMasterId_Encrypted','@d.Status')" title="Delete">
                                                            <i class="fa fa-trash fa-xl" style="color: orangered;"></i>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>



                        <!-- Optional Offcanvas Example -->
                        <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasExample" aria-labelledby="offcanvasLabel">
                            <div class="offcanvas-header" style="background-color: #007bff;">
                                <h5 id="offcanvasLabel">Leave Details</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
                            </div>
                            <div class="offcanvas-body" id="offcanvasBody">
                                <p>Loading...</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<!-- #Start Cancel Request dialog -->
<div class="modal fade" id="CancelModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Cancel</h4>
            </div>
            <div class="modal-body">
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            @* @Html.DropDownListFor(model => model.PunchMissingEmployeeID, new SelectList(ViewBag.GetAdditionalList, "Id", "Name"), new { id = "LeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-select", autocomplete = "off" })*@
                                            <h6> Select Approver Name</h6>

                                            @Html.DropDownList("Id", new SelectList(ViewBag.GetManagerEmployee, "Id", "Name"), "--Select--", new { @class = "form-control", Id = "ddlManagerName" })
                                            <h1></h1>
                                            <span id="ErrorMessage" class="Error" style="color:red"></span>
                                            <h6> Enter Remark </h6>
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>

                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="SendCancelRequest()" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress btn-sm CloseModel" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End Cancel Request dialog -->


<style>
    .timeline {
        max-width: 400px;
        background-color: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

        .timeline:before {
            left: 32px;
        }

    .timeline-item {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

    .iconGreen {
        width: 24px;
        height: 24px;
        background-color: green;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .iconRed {
        width: 24px;
        height: 24px;
        background-color: #ff5b57;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .text {
        flex-grow: 1;
    }

        .text p {
            margin: 0;
            font-size: 14px;
        }

        .text small {
            color: gray;
            font-size: 12px;
        }

    .button {
        text-align: center;
        margin-top: 20px;
    }

        .button button {
            background-color: #a8d935;
            border: none;
            padding: 10px 20px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            border-radius: 5px;
        }

            .button button:hover {
                background-color: #8cc62f;
            }
</style>

<div class="modal fade" id="RequestInfoModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body-content" style="position: relative;">
                <div class="timeline">
                    <div class="panel-heading-btn" style="margin-top: -13px; position: absolute; right: 8px;" data-bs-dismiss="modal">
                        <a href="javascript:;" class="btn btn-icon btn-danger btnClear" aria-hidden="true" id="CloseModel">
                            <i class="fa fa-xmark"></i>
                        </a>

                    </div>
                    <div id="timelineMainDiv">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@*=====New Code START================================================================================================================*@
<script>
    document.getElementById('searchDate').addEventListener('input', function () {
        const searchValue = this.value.trim().toLowerCase();
        const cards = document.querySelectorAll('.leave-card');

        cards.forEach(card => {
            const nameElement = card.querySelector('.name');
            let dateText = '';

            if (nameElement && nameElement.innerText) {
                dateText = nameElement.innerText.toLowerCase();
            }

            if (dateText.includes(searchValue)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>
@*=====New Code END================================================================================================================*@


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>

<script>
    function DeleteLeave(LeaveMasterId_Encrypted,Status) {
        debugger;
        if(Status!="Pending")
        {
            Swal.fire({
                icon: "error",
                text: "Approved/Rejected request can't delete",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("LeaveDelete", "ESS_TimeOffice_Leave")?LeaveMasterId_Encrypted=' + LeaveMasterId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }



</script>

<script>
    function CancelRequestFun(LeaveMasterId,Status) {
        debugger;
        if(Status=="Pending" || Status=="Cancel")
        {
            if(Status=="Pending")
            {
                var Message="Pending request can't cancel";
                var Icon="error";
            }
            else{
                var Message="Request already cancel";
                var Icon="error";
            }

            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        localStorage.setItem('LeaveMasterId', LeaveMasterId);
        $("#CancelModal").modal('show');
    }

    function SendCancelRequest()
    {
        //$("#CancelModal").modal('show');
        var ddlManagerName = $('select#ddlManagerName option:selected').val();
        if(ddlManagerName=="")
        {
            $("#ErrorMessage").html("Please select approver name");
            $("#ddlManagerName").focus();
            return false;
        }
        else
        {
            $("#ErrorMessage").html("");
        }

        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes Submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                $("#CancelModal").modal('hide');
                $(".Userloaderbg").css("display","flex");
                var GetLeaveId = localStorage.getItem('LeaveMasterId');

                var ddlManagerId = $("#ddlManagerName").val();
                var Origin="Leave";
                Remark = $("#txtApproveRejectRemark").val();
                $("#CancelModal").modal('hide');
                $(".Userloaderbg").css("display", "flex");
                $.ajax({
                    url: "@Url.Action("CancelRequest", "ESS_TimeOffice_Leave")",
                    method:"get",
                    data: { LeaveMasterId: GetLeaveId, ddlManagerId: ddlManagerId, Remark: Remark, Origin: Origin },
                    success:function(response){
                        debugger;
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon=="error") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    })
                                    .then((result) => {
                                        if (result.isConfirmed) {
                                            $("#CancelModal").modal('hide');
                                            $("#txtApproveRejectRemark").val("")
                                            window.location.href = '@Url.Action("GetList", "ESS_TimeOffice_Leave")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })
                                }
                            }
                        }
                        else{
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (response.Icon=="success") {
                                if (Message1 != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        })
                                        .then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("GetList", "ESS_TimeOffice_Leave")';
                                            } else if (
                                                /* Read more about handling dismissals below */
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {

                                            }
                                        })

                                        $("#CancelModal").modal('hide');
                                        $("#txtApproveRejectRemark").val("");
                                    }
                                }
                            }
                        }
                    }
                });

            } else if (
                /* Read more about handling dismissals below */
                            result.dismiss === Swal.DismissReason.cancel
                        ) {
                $("#CancelModal").modal('hide');
                $("#ddlManagerName").val(null);
                $("#txtApproveRejectRemark").val("");
            }
        })
    }
</script>

<script>
    function ApproveStatus(DocId) {
        $.ajax({
            url: '@Url.Action("RequestStatus", "ESS_TimeOffice_Leave")',
            method: "GET",
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            data: { DocId: DocId },
            success: function (response) {
                debugger
                $('#RequestInfoModal').modal('show');
                var data = JSON.parse(response);
                var timelineHtml = '';
                for (var i = 0; i < data.length; i++) {
                    var icon = '';
                    var iconColor='';
                    var textColor = '';
                    if (data[i][5].Value === 'success') {
                        icon = '✔';
                        iconColor ="iconGreen";
                        textColor = 'Green';
                    } else if (data[i][5].Value === 'error') {
                        icon = '✘';
                        iconColor ="iconRed";
                        textColor = 'Red';
                    } else {
                        icon = '⏳';
                        iconColor ="iconRed";
                        textColor = 'Black';
                    }

                    timelineHtml += '<div class="timeline-item">' +
                                '<div class="' + iconColor + '"><span class="timelineIcon">' + icon + '</span></div>' +
                                '<div class="text">' +
                                '<b><p class="timelineRemark" style="color:' + textColor + ';">' + data[i][2].Value + '</p></b>' +
                                '<small class="timelineEmployeeName" style="color:Black;">' + data[i][3].Value + '</small><br />' +
                                 '<small class="timelineDate" style="color:Black;">' + data[i][1].Value + '</small>' +
                                '</div>' +
                                '</div>';
                }
                $('#timelineMainDiv').html(timelineHtml);
            }
        });
    }

</script>


