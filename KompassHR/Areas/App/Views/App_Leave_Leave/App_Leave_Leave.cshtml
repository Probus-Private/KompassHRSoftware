                $(".Userloaderbg").css("display", "none");
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (data.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick:false
                            });
                        }
                    }
                    return false;
                }
                else{
                    $(".Userloaderbg").css("display", "flex");
                    $("#SaveLeave").submit();
                }
            }
        });
    });


