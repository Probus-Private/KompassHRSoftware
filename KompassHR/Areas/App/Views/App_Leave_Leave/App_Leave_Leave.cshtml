                                </div>

                                <div class="row mb-3 align-items-center">
                                    <div class="col-md-4">
                                        <div class="form-label-container">
                                            <label class="form-label">
                                                <span class="form-label-text">
                                                    <i class="fa-solid fa-calendar-days text-purple-600"></i> Leave Year
                                                </span>:
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
