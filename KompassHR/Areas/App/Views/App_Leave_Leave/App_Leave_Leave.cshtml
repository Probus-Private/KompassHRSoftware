        function ResetFile()
        {
            let allowedExtension = ['image/jpeg', 'image/jpg', 'image/png'];
            let type = document.getElementById('LeaveFilePath').files[0].type;

            if(allowedExtension.indexOf(type)>-1)
            {
            }else{
                alert('File type should be jpeg/jpg/png')
                document.getElementById("LeaveFilePath").value = null;
            }
            $("#lblFileName").text('');
        }



        $("#LeaveType").change(function(){
            debugger;
            var GetLeaveTypeId = $("#LeaveType").val();
            $("#FormDate").val("");
            $("#ToDate").val("");
            $.ajax({
                url: '@Url.Action("GetFutureAndBackDays", "App_Leave_Leave")',
                Type:"Get",
                contentType:"application/json; charset=utf-8",
                dataType:"text",
                data:{GetLeaveTypeId:GetLeaveTypeId},
                success:function(data){
                    debugger;
                    var data1= JSON.parse(data);
                    var GetBackDays=data1[0][0].Value;
                    var GetFutureDays=data1[0][1].Value;
                    var IsDocRequired=data1[0][2].Value;
                    var IsAfterDays=data1[0][3].Value;

                    localStorage.setItem("IsDocRequired", IsDocRequired);
                    localStorage.setItem("IsAfterDays", IsAfterDays);
                    //alert(IsDocRequired);
                    if(GetBackDays!=null && GetFutureDays!=null)
                    {
                        var fromDateInputMin = document.getElementById("FormDate");
                        var toDateInputMin = document.getElementById("ToDate");
                        var currentDateMin = new Date();
                        var minDate = new Date();
                        minDate.setDate(currentDateMin.getDate() - GetBackDays);
                        var minDateString = minDate.toISOString().split('T')[0];
                        fromDateInputMin.setAttribute("min", minDateString);
                        toDateInputMin.setAttribute("min", minDateString);

                        //Validation for back day days Max Days
                        var currentDateMax = new Date();
                        var MaxDate = new Date();
                        MaxDate.setDate(currentDateMax.getDate() + GetFutureDays);
                        var maxDateString = MaxDate.toISOString().split('T')[0];
                        fromDateInputMin.setAttribute("max", maxDateString);
                        toDateInputMin.setAttribute("max", maxDateString);
                    }
                }
            });

        });




    });//ready funcation


    //This Function use for bind in input type
    function convertDateTime12Hr(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date1 = millisecToDateTime12Hour(getdate);
        return date1;
    }
    function millisecToDateTime12Hour(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = ("0" + date.getMinutes()).slice(-2);

        var ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        hours = ("0" + hours).slice(-2);

        var yyyyMMdd = [date.getFullYear(), mnth, day].join("-");
        var hhmm = [hours, minutes].join(":");
        return yyyyMMdd + " " + hhmm + " " + ampm;
    }
</script>

