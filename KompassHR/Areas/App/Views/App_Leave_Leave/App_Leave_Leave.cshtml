<div id="content" class="app-content">
    <div class="panel panel-inverse" data-sortable-id="index-1">
        <div class="panel-body" data-scrollbar="false">

            <div class="w-full overflow-x-auto rounded-lg border border-gray-200">
                <table class="w-full text-sm text-center text-gray-700 min-w-[500px]" id="tblLeaveBalance">
                    <thead class="bg-blue-500 text-xs text-white-100 sticky top-0">
                        <tr>
                            <th scope="col" class="px-1 py-1">Type</th>
                            <th scope="col" class="px-1 py-1">O/B.</th>
                            <th scope="col" class="px-1 py-1">Taken</th>
                            <th scope="col" class="px-1 py-1">Pending</th>
                            <th scope="col" class="px-1 py-1">Bal.</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var d in ViewBag.GetLeaveBalance)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-1 py-1 whitespace-nowrap">@d.LeaveTypeShortName</td>
                                <td class="px-1 py-1 whitespace-nowrap">@d.OpeningBalance</td>
                                <td class="px-1 py-1 whitespace-nowrap">@d.TakenLeave</td>
                                <td class="px-1 py-1 whitespace-nowrap">@d.PendingLeave</td>
                                <td class="px-1 py-1 whitespace-nowrap">@d.ClosingBalance</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <br />
            <div class="row">
                <div class="col-md-12">
                    <div class="panel panel-inverse" data-sortable-id="index-1">
                        <div class="panel-body">
