
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }
    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row mb-2">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 style="font-size:18px; margin:0;">Final PMS Evaluation</h1>
            <ol style="list-style:none; display:flex; gap:10px; margin:0;">
                <li>
                    <a href="@Url.Action("Dashboard", "Dashboard")">
                        <img src="~/assets/MenuImages/Home.png" />
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_PMS_Menu", "ESS_PMS_Menu", new { id = 11, ScreenId = 594, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" />
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="panel panel-inverse">
        <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
            <h4 class="panel-title">Final Review Employees - List</h4>
        </div>

        <div class="alert alert-yellow mb-0">
            This list shows employees whose <b>KRA or Competency</b> is completed.
        </div>

        <div class="panel-body">
            <div class="table-scroll">
                <div class="table-wrap">
                    <table class="table table-bordered table-hover table-striped mb-0 TablePage">
                        <thead>
                            <tr>
                                <th>View</th>
                                <th>Employee Name</th>
                                <th>Department</th>
                                <th>Designation</th>
                                <th>KRA Status</th>
                                <th>Competency Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.GetList != null)
                            {
                                foreach (var d in ViewBag.GetList)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <i class="fa-solid fa-eye text-danger fa-lg"
                                               style="cursor:pointer"
                                               onclick="ViewForApprover('@d.EmployeeId')"></i>
                                        </td>

                                        <td>@d.EmployeeName</td>
                                        <td>@d.DepartmentName</td>
                                        <td>@d.DesignationName</td>

                                        <!-- KRA STATUS -->
                                        <td class="text-center">
                                            @if (d.KRA_Completed == 1)
                                            {
                                                <span class="badge bg-success status-badge">Completed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary status-badge">Pending</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (d.Competency_Completed == 1)
                                            {
                                                <span class="badge bg-success status-badge">Completed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary status-badge">Pending</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function ViewForApprover(empId) {
        window.location.href = '@Url.Action("ESS_PMS_FinalEvaluation", "ESS_PMS_FinalEvaluation", new { area = "ESS" })'
            + '?EmployeeId=' + empId;
    }

    $(document).ready(function () {

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>