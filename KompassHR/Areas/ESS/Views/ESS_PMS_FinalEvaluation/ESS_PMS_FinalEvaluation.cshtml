@model KompassHR.Areas.ESS.Models.ESS_PMS.PMS_FinalEvaluation
@{
    ViewBag.Title = "Final Evaluation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int totalCols = ViewBag.IsStandardRequired ? 11 : 9;
}

<style>
 

    .final-score {
    margin-top: 20px;
    padding: 16px;
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    text-align: center;
    font-weight: 700;
    font-size: 18px;
    color: #047857;
}

.muted {
    font-size: 12px;
    color: #6b7280;
    font-weight: normal;
}

    body {
        background: #f4f6fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .review-wrapper {
        max-width: 1400px;
        margin: 20px auto;
        padding: 22px;
        background: #ffffff;
        border-radius: 10px;
        border: 1px solid #d1d5db;
    }

    .section-title {
        font-size: 15px;
        font-weight: 700;
        color: #1e3a8a;
        margin: 20px 0 12px;
        padding: 8px 12px;
        background: #eef2ff;
        border-left: 4px solid #1e3a8a;
    }

    .employee-card {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }

   .emp-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 40px;
}

.emp-item {
    display: flex;
    align-items: center;
    gap: 10px;
}

.emp-label {
    min-width: 120px;
    font-size: 12px;
    font-weight: 600;
    color: #6b7280;
}

.emp-value {
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
}

.emp-badge {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    background: #dcfce7;
    color: #047857;
}


    .calc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .calc-table th {
            background: #e5e7eb;
            padding: 10px;
            border: 1px solid #c7cdd4;
            text-align: center;
            font-weight: 600;
        }

        .calc-table td {
            padding: 8px;
            border: 1px solid #d1d5db;
            text-align: center;
            background: #f8fafc;
        }

            .calc-table td.left {
                text-align: left;
                background: #ffffff;
            }

            .calc-table td.weightage {
                background: #fef3c7;
                font-weight: 700;
            }

            .calc-table td.total,
            .calc-table td.score {
                background: #dcfce7;
                font-weight: 700;
                color: #065f46;
            }
</style>


<div id="content" class="app-content">
    <div class="review-wrapper">
@using (Html.BeginForm("FinalSubmit", "ESS_PMS_FinalEvaluation",FormMethod.Post, new { area = "ESS", id = "finalEvalForm" }))
{
    @Html.HiddenFor(m => m.YearId, new { id = "YearId",Value= @ViewBag.YearId })
    @Html.HiddenFor(m => m.EmployeeId, new { id = "EmployeeId", Value = @ViewBag.EmployeeId })
    @Html.HiddenFor(m => m.ReviewerId, new { id = "ReviewerId", Value = ViewBag.reviewerId })
    @Html.HiddenFor(m => m.OutOfRating, new { id = "OutOfRating", Value = ViewBag.OutOfRating })
    @Html.HiddenFor(m => m.KRAFinalRating, new { id = "KRAFinalRating" })
    @Html.HiddenFor(m => m.CompetencyFinalRating, new { id = "CompetencyFinalRating" })
    @Html.HiddenFor(m => m.TotalFinalRating, new { id = "TotalFinalRating" })



        <!-- PAGE HEADER -->
        <div class="row mb-3">
            <div class="col-md-12 d-flex justify-content-between align-items-center">
                <h1 class="page-title mb-0">Final Evaluation</h1>

                <div class="page-actions">
                    <a href="@Url.Action("Dashboard", "Dashboard")">
                        <img src="~/assets/MenuImages/Home.png" />
                    </a>
                    <a href="@Url.Action("GetList", "ESS_PMS_FinalEvaluation",
    new { id = 11, ScreenId = 877, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" />
                    </a>
                </div>
            </div>
        </div>
        <div class="section-title">Employee Information</div>

        <div class="employee-card">
            @foreach (var e in ViewBag.EmpInfo)
            {
                <div class="emp-grid">
                    <div class="emp-item">
                        <span class="emp-label">Company Name</span>
                        <span class="emp-value">@e.CompanyName</span>
                    </div>
                    <div class="emp-item">
                        <span class="emp-label">Branch Name</span>
                        <span class="emp-value">@e.BranchName</span>
                    </div>
                    <div class="emp-item">
                        <span class="emp-label">Employee Name</span>
                        <span class="emp-value">@e.EmployeeName</span>
                    </div>

                    <div class="emp-item">
                        <span class="emp-label">Department</span>
                        <span class="emp-value">@e.DepartmentName</span>
                    </div>

                    <div class="emp-item">
                        <span class="emp-label">Designation</span>
                        <span class="emp-value">@e.DesignationName</span>
                    </div>

                    @*<div class="emp-item">
                        <span class="emp-label">Status</span>
                        <span class="emp-badge">@e.Status</span>
                    </div>*@
                </div>
            }
        </div>
        <div class="section-title">Objective / KRA Evaluation</div>

        <table class="calc-table">
            <thead>
                <tr>
                    <th>Objective</th>
                    <th>KRA</th>
                    <th>UOM</th>
                    <th>Target Type</th>
@if (ViewBag.IsStandardRequired)
{
                    <th>Standard</th>
}
                    <th>Target</th>
                    <th>Actual</th>
@if (ViewBag.IsStandardRequired)
{
                    <th>50% Between</th>
}
                    <th>Rating</th>
                    <th>Weightage</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in ViewBag.KraList)
                {
                    <tr class="kra-row">
                        <td class="left">@d.Objective</td>
                        <td class="left">@d.KRA</td>
                        <td>@d.UOM</td>
                        <td>@d.TargetType</td>
@if (ViewBag.IsStandardRequired)
{
                        <td class="standard" data-standard="@d.StandardValue">
                            @d.StandardValue
                        </td>   
}
                          <td class="target" data-target="@d.EffectiveTarget">@d.EffectiveTarget</td>
                        <td class="actual" data-actual="@d.ActualValue">@d.ActualValue</td>
@if (ViewBag.IsStandardRequired)
{
                        <td class="mid">@d.MidValue</td>
}
                        <td class="rating">@d.Rating</td>
                        <td class="weightage" data-weightage="@d.Weightage">@d.Weightage</td>
                        <td class="total">@d.Score</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="@(totalCols - 2)" class="label">Total</td>
                    <td id="totalWeightage" class="weightage">0</td>
                    <td id="totalScore" class="total">0</td>
                </tr>
                <tr>
                    <td colspan="@(totalCols - 1)" class="label">Average Rating</td>
                    <td id="avgRating" class="final">0</td>
                </tr>
            </tfoot>
        </table>

        <div class="final-score">
            Final Appraisal(KRA) Rating : <b><span id="FinalRatingScore"></span></b>
            <div class="muted">Calculated as per yearly appraisal policy</div>
        </div>
        <div class="section-title">Competency Evaluation</div>

        <table class="calc-table">
            <thead>
                <tr>
                    <th>Framework</th>
                    <th>Competency</th>
                    <th>Self Rating</th>
                    <th>Appraiser Rating</th>
                    <th>Weightage</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in ViewBag.CompetencyInfo)
                {
                    <tr class="comp-row">
                        <td class="left">@c.Framework</td>
                        <td class="left">@c.Competency</td>
                        <td>@c.AppraiseeRating</td>
                        <td class="rating" data-rating="@c.AppraiserRating">@c.AppraiserRating</td>
                        <td class="weightage" data-weightage="@c.Weightage">@c.Weightage</td>
                        <td class="score">0</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4"><b>Total</b></td>
                    <td id="totalWeightage1" class="weightage">0</td>
                    <td id="totalScore1" class="score">0</td>
                </tr>
                <tr>
                    <td colspan="5"><b>Final Competency Score</b></td>
                    <td id="finalCompetencyScore" class="score">0</td>
                </tr>
            </tfoot>
        </table>
        <div class="final-score">
            Final Appraisal (Competency) Rating :
            <b><span id="finalScoreText"></span></b>
        </div>

        <div class="final-score" style="background:#eef2ff; border-color:#c7d2fe;">
            <div style="display:flex; justify-content:space-around; flex-wrap:wrap; gap:20px;">

                <div>
                    <div class="muted">KFOs (KRA)</div>
                    <div style="font-size:22px;">
                        <b><span id="kfoTotal">0.00</span></b>
                    </div>
                </div>

                <div>
                    <div class="muted">Competencies</div>
                    <div style="font-size:22px;">
                        <b><span id="competencyTotal">0.00</span></b>
                    </div>
                </div>

                <div>
                    <div class="muted">Final Rating</div>
                    <div style="font-size:26px; color:#1e40af;">
                        <b><span id="overallFinalScore">0.00</span></b>
                    </div>
                </div>

            </div>
        </div>
        <div class="text-center mt-4">
            <button type="button" id="btnFinalSubmit"
                    class="btn btn-success btn-lg px-5">
                <i class="fa fa-check-circle"></i> Submit Final Evaluation
            </button>
        </div>
}
        </div>

    </div>

 <script>
     function calculateCompetencyScore() {

         let totalWeightage1 = 0;
         let totalScore1 = 0;

         document.querySelectorAll(".comp-row").forEach(row => {

             let rating = parseFloat(row.querySelector(".rating").dataset.rating) || 0;
             let weightage = parseFloat(row.querySelector(".weightage").dataset.weightage) || 0;

             let score = rating * weightage;

             row.querySelector(".score").innerText = score.toFixed(2);

             totalWeightage1 += weightage;
             totalScore1 += score;
         });

         document.getElementById("totalWeightage1").innerText = totalWeightage1.toFixed(2);
         document.getElementById("totalScore1").innerText = totalScore1.toFixed(2);

         let finalScore =
             totalWeightage1 > 0
                 ? (totalScore1 / totalWeightage1).toFixed(2)
                 : "0.00";

         document.getElementById("finalCompetencyScore").innerText = finalScore;
         document.getElementById("finalScoreText").innerText = finalScore;
     }
     document.addEventListener("DOMContentLoaded", calculateCompetencyScore);

