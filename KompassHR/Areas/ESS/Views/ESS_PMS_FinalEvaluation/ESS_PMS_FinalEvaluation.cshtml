     function calculateAll() {

         let totalWeightage = 0;
         let totalScore = 0;

         document.querySelectorAll(".kra-row").forEach(function (row) {

             let rating = parseFloat(row.querySelector(".rating").innerText) || 0;
             let weightage = parseFloat(row.querySelector(".weightage").dataset.weightage) || 0;

             let score = rating * weightage;

             // ✅ Only update score (rating comes from DB)
             row.querySelector(".total").innerText = score.toFixed(2);

             totalWeightage += weightage;
             totalScore += score;
         });

         document.getElementById("totalWeightage").innerText = totalWeightage.toFixed(2);
         document.getElementById("totalScore").innerText = totalScore.toFixed(2);

         let avg = totalWeightage > 0
             ? (totalScore / totalWeightage).toFixed(2)
             : "0.00";

         document.getElementById("avgRating").innerText = avg;
         document.getElementById("FinalRatingScore").innerText = avg;
     }
     document.addEventListener("DOMContentLoaded", function () {
         calculateAll();
     });

     document.addEventListener("input", function (e) {
         if (e.target.classList.contains("standard")) {
             calculateAll();
         }
     });

     document.addEventListener("DOMContentLoaded", function () {
         calculateOverallScore();
     });

     document.addEventListener("input", function (e) {
         if (e.target.classList.contains("standard")) {
             calculateOverallScore();
         }
     });


     $('#btnFinalSubmit').click(function () {
         debugger
         calculateAll();
         calculateCompetencyScore();
         calculateOverallScore();
         let kra = parseFloat($("#FinalRatingScore").text()) || 0;
         let comp = parseFloat($("#finalCompetencyScore").text()) || 0;
         let finalScore = parseFloat($("#overallFinalScore").text()) || 0;

         if (finalScore === 0) {
             alert("Final score cannot be zero.");
             return;
         }

         if (!confirm("Are you sure you want to submit the final evaluation?")) {
             return;
         }

         $("#KRAFinalRating").val(kra);
         $("#CompetencyFinalRating").val(comp);
         $("#TotalFinalRating").val(finalScore);

         $("#YearId").val('@ViewBag.YearId');
         $("#EmployeeId").val('@ViewBag.EmployeeId');
         $("#ReviewerId").val('@ViewBag.Reviewerid');
         $("#OutOfRating").val('@ViewBag.OutOfRating');
         var YearId = $("#YearId").val();
         var Employeeid = $("#EmployeeId").val();
         var Reviewerid = $("#Reviewerid").val();
         var OutOfRating = $("#OutOfRating").val();

         $.ajax({
             url: '/ESS_PMS_FinalEvaluation/IsValidation',
             method: "get",
             data: { YearId: YearId, Employeeid: Employeeid, Reviewerid: Reviewerid, OutOfRating: OutOfRating },
             success: function (response) {
                 debugger;
                 var Message1 = response.Message;
                 var Icon1 = response.Icon;
                 if (response.Icon == "error") {
                     if (Message1 != null) {
                         if (Message1 != null) {
                             Swal.fire({
                                 icon: Icon1,
                                 text: Message1,
                                 allowOutsideClick: () => {
                                     const popup = Swal.getPopup()
                                     popup.classList.remove('swal2-show')
                                     setTimeout(() => {
                                         popup.classList.add('animate__animated', 'animate__headShake')
                                     })
                                     setTimeout(() => {
                                         popup.classList.remove('animate__animated', 'animate__headShake')
                                     }, 500)
                                     return false
                                 }
                             });
                         }
                     }
                 }
                 else {
                     $("#finalEvalForm").submit();

                 }
             }
         });
     });


