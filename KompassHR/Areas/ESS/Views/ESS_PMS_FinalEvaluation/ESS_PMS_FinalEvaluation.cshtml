<script>
function calculateOverallScore() {

    let kfo = parseFloat(document.getElementById("FinalRatingScore").innerText) || 0;
    let competency = parseFloat(document.getElementById("finalCompetencyScore").innerText) || 0;

    // Excel logic → simple average
    let finalRating = (kfo + competency) / 2;

    // Show section values
    document.getElementById("kfoTotal").innerText = kfo.toFixed(2);
    document.getElementById("competencyTotal").innerText = competency.toFixed(2);
    document.getElementById("overallFinalScore").innerText = finalRating.toFixed(2);
}

/* Run on load */
document.addEventListener("DOMContentLoaded", function () {
    calculateOverallScore();
});

/* Recalculate when KRA standards change */
document.addEventListener("input", function (e) {
    if (e.target.classList.contains("standard")) {
        calculateOverallScore();
    }
});
</script>


       


