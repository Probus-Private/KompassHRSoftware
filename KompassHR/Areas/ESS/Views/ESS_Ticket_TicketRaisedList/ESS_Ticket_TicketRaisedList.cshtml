<style>
    #detached-tickets-wrapper .card {
        border: none;
        border-radius: 10px;
        background-color: #fff;
        margin-bottom: 1.5rem;
    }

    #detached-tickets-wrapper .card-header {
        border-color: #ededed;
        position: relative;
        background: transparent;
        padding: 1rem 1.25rem 1rem;
        border-bottom: 1px solid #ededed;
    }

    #detached-tickets-wrapper .card-title {
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        color: #111827;
        margin-bottom: 0;
    }

    #detached-tickets-wrapper .card-body {
        padding: 1.25rem;
    }

    #detached-tickets-wrapper .badge {
        font-size: 12px;
        padding: 5px 10px;
        border-radius: 6px;
        margin-left: 6px;
    }

    #detached-tickets-wrapper .list-group-item {
        border-color: #f3f4f6;
        background-color: #fff;
    }

    .ticket-iconbx {
        width: 28px;
        height: 28px;
        border-radius: 10px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        margin-right: 15px;
        margin-top: 15px;
        transform: rotate(45deg);
        flex-shrink: 0;
    }

        .ticket-iconbx i {
            transform: rotate(-45deg);
        }

    .ticket-content {
        padding: 15px;
    }

    .ticket-title {
        font-size: 16px;
        font-weight: 500;
        color: #202C4B;
    }

    .ticket-count {
        font-size: 30px;
        font-weight: 800;
        color: #202C4B;
    }


    .ticket-iconbx.bg-primary {
        background-color: #0d6efd !important;
        color: #fff !important;
    }

    .ticket-iconbx.bg-info {
        background-color: #0dcaf0 !important;
        color: #fff !important;
    }

    .ticket-iconbx.bg-warning {
        background-color: #ff9800 !important;
        color: #fff !important;
    }

    .ticket-iconbx.bg-danger {
        background-color: #dc3545 !important;
        color: #fff !important;
    }

    .ticket-iconbx.bg-success {
        background-color: #198754 !important;
        color: #fff !important;
    }
</style>

<style>
    .detached-ticket-body {
        padding: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .detached-ticket-table {
        width: 100%;
        margin-bottom: 0;
        font-size: 14px;
        color: #4B5563;
        border-collapse: collapse;
        white-space: nowrap;
        text-align: left;
    }

        .detached-ticket-table thead th {
            font-weight: 600;
            color: #6B7280;
            padding: 12px 24px;
            border-bottom: 1px solid #ededed;
            background-color: #F8F9FA;
        }

        .detached-ticket-table tbody td {
            padding: 12px 24px !important;
            vertical-align: middle;
            border-bottom: 1px solid #f3f4f6;
        }

        .detached-ticket-table tbody tr {
            transition: background-color 0.2s ease;
        }

            .detached-ticket-table tbody tr:hover {
                background-color: #f8f9fa;
            }

            .detached-ticket-table tbody tr:last-child td {
                border-bottom: none;
            }
</style>

