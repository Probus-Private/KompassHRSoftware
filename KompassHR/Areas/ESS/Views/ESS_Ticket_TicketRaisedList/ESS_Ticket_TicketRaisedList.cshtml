        color: #1D2A3A;
    }



    .no-border-bottom {
        border-bottom: none !important;
    }

    .align-middle-right {
        text-align: right;
        vertical-align: middle;
    }

    /* ── Progress & Status Upgrades ──────────────── */
    .progress-bar-custom {
        height: 8px;
        border-radius: 10px;
        background-color: rgba(241, 245, 249, 0.8);
        width: 100px;
        margin-right: 12px;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

        .progress-bar-custom .progress-bar {
            border-radius: 10px;
            box-shadow: inset 0 -1px 2px rgba(0, 0, 0, 0.1);
        }

    .text-progress-pct {
        font-weight: 700;
        font-size: 13px;
    }

    /* Upgrade Avatar Initials */
    .avatar-initials {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 12px;
        margin-right: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.5);
        flex-shrink: 0;
    }

    /* Avatar color variants with subtle gradients */
    .avatar-primary {
        background: linear-gradient(135deg, #ebf5ff, #dbeafe);
        color: #2563eb;
        border-color: rgba(59, 130, 246, 0.2);
    }

    .avatar-success {
        background: linear-gradient(135deg, #e8f5e9, #dcfce7);
        color: #16a34a;
        border-color: rgba(34, 197, 94, 0.2);
    }

    .avatar-warning {
        background: linear-gradient(135deg, #fff4e5, #fef3c7);
        color: #d97706;
        border-color: rgba(245, 158, 11, 0.2);
    }

    .avatar-purple {
        background: linear-gradient(135deg, #f0ebf8, #f3e8ff);
        color: #7e22ce;
        border-color: rgba(168, 85, 247, 0.2);
    }

    /* Upgrade action buttons in panels */
    .btn-premium-action {
        border-radius: 20px;
        padding: 4px 14px;
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.2s ease;
    }

        .btn-premium-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.2);
            background-color: #0d6efd;
            color: #ffffff;
        }
</style>


