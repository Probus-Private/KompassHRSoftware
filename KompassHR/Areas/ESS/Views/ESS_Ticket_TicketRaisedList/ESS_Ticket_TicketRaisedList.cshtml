                            }
                        }
                    }
                };

                // Initialize Status Ticket Chart

                var pending = @TempData["GetOpenTickets"];
                var inProgress = @TempData["GetInProcessTickets"];
                var escalated = @TempData["GetEscalatedTicket"];
                var closed = @TempData["GetResolvedTickets"];

                var sChartCtx = document.getElementById('statusTicketChart');
                if (sChartCtx) {
                    new Chart(sChartCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Pending', 'In Progress', 'Escalated','Closed'],
                            datasets: [{
                                data:  [pending, inProgress, escalated, closed],
                                // backgroundColor: ['#ffc107', '#0dcaf0', '#0d6efd', '#fd7e14', '#198754', '#6c757d'],
                                backgroundColor: ['#ffc107', '#0d6efd', '#fd7e14', '#6c757d'],
                                borderWidth: 0,
                                hoverOffset: 4
                            }]
                        },
                        options: donutOptions
                    });
                }

                // Initialize Priority Ticket Chart

                var Critical = @TempData["GetCriticalTicket"];
                var High = @TempData["GetHighTicket"];
                var Medium = @TempData["GetMediumTicket"];
                var Low = @TempData["GetLowTicket"];


                var pChartCtx = document.getElementById('priorityTicketChart');
                if (pChartCtx) {
                    new Chart(pChartCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Critical','High', 'Medium', 'Low'],
                            datasets: [{
                                data: [Critical,High,Medium,Low],
                                backgroundColor: ['#dc3545', '#ff9800', '#0dcaf0','#198754'],
                                borderWidth: 0,
                                hoverOffset: 4
                            }]
                        },
                        options: donutOptions
                    });
                }

                // Initialize Category Donut Chart
                var cChartCtx = document.getElementById('categoryDonutChart');
                if (cChartCtx) {
                    new Chart(cChartCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['IT Support', 'Payroll', 'Leave', 'HR Queries', 'Hardware', 'Software'],
                            datasets: [{
                                data: [32, 15, 10, 14, 8, 12],
                                backgroundColor: ['#0d6efd', '#6f42c1', '#e83e8c', '#17a2b8', '#20c997', '#fd7e14'],
                                borderWidth: 0,
                                hoverOffset: 4
                            }]
                        },
                        options: donutOptions
                    });
                }



                var ticketTrendData = @Html.Raw(JsonConvert.SerializeObject(ViewBag.Last8DayResponse));
                var ticketTrendCreateData=@Html.Raw(JsonConvert.SerializeObject(ViewBag.Last8DayCreated));

                var labels = [];
                var resolvedData = [];
                var CreatedData=[];

                if (ticketTrendData != null) {

                    ticketTrendData.forEach(function (item) {
                        labels.push(item.DayName);
                        resolvedData.push(item.ResolvedTickets);
                    });
                }


                if (ticketTrendCreateData != null) {

                    ticketTrendCreateData.forEach(function (item) {
                        //labels.push(item.DayName);
                        CreatedData.push(item.CreatedTickets);
                    });
                }


                // Initialize Ticket Trend Line Chart
                var trendCtx = document.getElementById('ticketTrendChart');


                if (trendCtx) {
                    new Chart(trendCtx, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [
                                {
                                    label: 'Created Tickets',
                                    data:CreatedData,
                                    borderColor: '#dc3545',
                                    backgroundColor: 'rgba(220, 53, 69, 0.05)',
                                    borderWidth: 2,
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#dc3545'
                                },
                                {
                                    label: 'Resolved Tickets',
                                    data:  resolvedData,
                                    borderColor: '#198754',
                                    backgroundColor: 'rgba(25, 135, 84, 0.05)',
                                    borderWidth: 2,
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#198754'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'top',
                                    labels: { usePointStyle: true, boxWidth: 8 }
                                }
                            },
                            scales: {
                                y: { beginAtZero: true, grid: { color: '#f3f4f6', drawBorder: false } },
                                x: { grid: { display: false, drawBorder: false } }
                            }
                        }
                    });
                }
            });
</script>
