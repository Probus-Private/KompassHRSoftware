<script>
function FilterPriority() {
    debugger
    var selectedPriority = document.getElementById("ddlPriority").value.toLowerCase();
    var table = document.querySelector(".detached-ticket-table");
    var rows = table.getElementsByTagName("tbody")[0].getElementsByTagName("tr");

    for (var i = 0; i < rows.length; i++) {

        var priorityCell = rows[i].getElementsByTagName("td")[7]; // Priority column index

        if (priorityCell) {
            var priorityText = priorityCell.textContent || priorityCell.innerText;
            priorityText = priorityText.toLowerCase();

            if (selectedPriority == "" || priorityText == selectedPriority) {
                rows[i].style.display = "";
            } else {
                rows[i].style.display = "none";
            }
        }
    }
}
</script>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>

