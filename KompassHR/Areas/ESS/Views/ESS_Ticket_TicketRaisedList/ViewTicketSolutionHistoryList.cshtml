
@{
    ViewBag.Title = "ViewTicketSolutionHistoryList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }



    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /* Increase width of Solution column */
.table-scroll td.solution-col,
.table-scroll th.solution-col {
    width: 350px !important;   /* Increase as needed */
    white-space: normal !important; /* Allow wrapping */
}

/* Minimize Download Attachment column */
.table-scroll td.download-col,
.table-scroll th.download-col {
    width: 80px !important;
    text-align: center;
}

</style>

<style>
    .info-box {
        background: #fff;
        border: 1px solid #ddd;
        padding: 20px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-family: roboto, sans-serif;
    }

    .info-row {
        display: flex;
        flex-wrap: wrap;
        margin-bottom: 6px;
    }

    .info-item {
        width: 50%;
        display: flex;
        margin-bottom: 4px;
    }

    .info-label {
        min-width: 140px;
        font-weight: 600;
        color: #333;
    }

    .info-value {
        color: #000;
    }
        .card-row-title {
        /*color: #e63c3c;*/
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #ccc 2px solid;
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Ticket Solution
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Ticket_TicketRaisedList", "ESS_Ticket_TicketRaisedList",  new { id = 13,ScreenId= 201, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Ticket  Solution - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            @*<a href="/ESS/ESS_Ticket_TicketRaise/ESS_Ticket_TicketRaise">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>*@



                            @if (ViewBag.GetTicketSolutionHistory == null ||
                              ((IEnumerable<dynamic>)ViewBag.GetTicketSolutionHistory).Count() == 0)
                            {
                                <script>
                                      Swal.fire({
                                           icon: 'info',
                                            title: 'No Records Found',
                                            text: 'No Solution History is available for this ticket.',
                                            confirmButtonText: 'OK'
                                            }).then(() => {
                                                window.location.href = '/ESS/ESS_Ticket_TicketRaisedList/ESS_Ticket_TicketRaisedList';
                                            });
                                </script>

                                return; 
                            }



                            @{
                                var list = ((IEnumerable<dynamic>)ViewBag.GetTicketSolutionHistory).ToList();
                                var first = list.First();
                            }



                            <div class="row mb-20px">
                                <div class="col-md-12">
                                    <div class="card-row-title">
                                        Ticket Information
                                    </div>
                                </div>
                            </div>

                        
                             
                        

                               
                             <div class="info-box">


                                 <div class="info-row">
                                     <div class="info-item">
                                         <div class="info-label">Ticket Raise Date:</div>
                                         <div class="info-value">@first.TicketRaiseDate</div>
                                     </div>
                                 </div>

                                     <div class="info-row">
                                         <div class="info-item">
                                             <div class="info-label">Ticket Raise By:</div>
                                             <div class="info-value">@first.TicketRaiseBy</div>
                                         </div>

                                         <div class="info-item">
                                             <div class="info-label">Designation:</div>
                                             <div class="info-value">@first.DesignationName</div>
                                         </div>

                                         @*<div class="info-item">
                    <div class="info-label">Ticket Raise Date:</div>
                    <div class="info-value">@first.TicketRaiseDate</div>
                </div>*@
                                     </div>


                                     <div class="info-row">
                                         <div class="info-item">
                                             <div class="info-label"> Category Name:</div>
                                             <div class="info-value">@first.TicketCategoryName</div>
                                         </div>

                                         <div class="info-item">
                                             <div class="info-label"> SubCategory Name:</div>
                                             <div class="info-value">@first.TicketSubCategoryName</div>
                                         </div>
                                     </div>


                                     <div class="info-row">
                                         <div class="info-item">
                                             <div class="info-label">Ticket Title:</div>
                                             <div class="info-value">@first.TicketTitle</div>
                                         </div>

                                         <div class="info-item">
                                             <div class="info-label">Description:</div>
                                             <div class="info-value">@first.Description</div>
                                         </div>
                                     </div>



                                 </div>


                                <!-- BEGIN table-responsive -->

                                <div class="row mb-20px  mt-30px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Ticket Solution
                                        </div>
                                    </div>
                                </div>

                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                               style="width: 100%;">
                                            <thead>
                                                <tr>

                                                    <th class="text-nowrap text-center">Doc No</th>
                                                    <th class="text-nowrap text-center">Doc Date </th>
                                                    @*<th class="text-nowrap"> Category Name</th>
                                <th class="text-nowrap"> SubCategory Name</th>
                                <th class="text-nowrap"> Ticket Title</th>
                                <th class="text-nowrap"> Description</th>*@
                                                    <th class="text-nowrap text-center solution-col">Solution</th>
                                                    @*<th class="text-nowrap">Ticket Raise By</th>*@
                                                    <th class="text-nowrap text-center download-col">Download Attachment</th>
                                                    <th class="text-nowrap text-center"> Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetTicketSolutionHistory)
                                                {
                                                    <tr>

                                                        <td class="text-center">@d.DocNo</td>
                                                        <td class="text-center">@d.DocDate</td>
                                                        @*<td>@d.TicketCategoryName</td>
                                    <td>@d.TicketSubCategoryName</td>
                                    <td>@d.TicketTitle</td>
                                    <td>@d.Description</td>*@
                                                        <td class="text-left solution-col">@d.Solution</td>
                                                        @*<td>@d.TicketRaiseBy</td>*@
                                                        @if (d.AttachFile != "No")
                                                        {
                                                            <td class="text-center download-col">
                                                                <a onclick="DownloadSolutionHistory('@d.TicketRaiseSLAActionId_Encrypted')" id="Download" class="btn btn-success ListBtn btnpress">
                                                                    <span class="fa-solid fa-download"></span>
                                                                </a>
                                                            </td>
                                                        }


                                                        @*@if (d.AttachFile != "No")
                                    {
                                      <td class="text-center">
                                          <a href="@Url.Action("DownloadSolutionHistory", "ESS_Ticket_TicketRaisedList",
                                          new { FilePath = d.AttachFile })" class="text-primary"
                                             title="Download File">
                                              <i class="fa-solid fa-download fa-lg"></i>
                                          </a>
                                          </td>
                                          }*@
                                                        else
                                                        {
                                                            <td class="download-col">
                                                                <div style="display:flex; justify-content:center; align-items:center;">
                                                                    <i class="fa fa-times" style="color:red;"></i>
                                                                </div>
                                                            </td>
                                                        }


                                                        <td class="text-center">@d.Status</td>
                                                        @*<td>@d.CreatedBy</td>
                                    <td>@d.CreatedDate</td>
                                    <td>@d.ModifiedBy</td>
                                    <td>@d.ModifiedDate</td>
                                    <td>@d.MachineName</td>*@
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                            </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    function DownloadSolutionHistory(TicketRaiseSLAActionId_Encrypted) {
        debugger
        var url = '@Url.Action("DownloadSolutionHistory", "ESS_Ticket_TicketRaisedList")?TicketRaiseSLAActionId_Encrypted=' + TicketRaiseSLAActionId_Encrypted;
        window.location.href = url;
    }
</script>