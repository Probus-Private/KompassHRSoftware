<script>
    $(document).ready(function () {
        var selectedValue = $('#txtIsEnrollmentRequired').val();
        if (selectedValue === "Yes") {
            $('.enrollmentDateSection').css('display', 'flex');
        } else {
            $('.enrollmentDateSection').css('display', 'none');
            //$('#dateEnrollmentLastDate').val('');
        }

        var selectedValue = $('#ddlTrainingFeesPaidType').val();
        if (selectedValue === "QRScan") {
            $('#divQRAttachment').css('display', 'flex');
        } else {
            $('#divQRAttachment').css('display', 'none');
        }

        var selectedValue1 = $('#ddlTrainingFeesType').val();
        if (selectedValue1 === "Paid") {
            $('.divTrainingFeesAmount').css('display', 'flex');
        } else {
            $('.divTrainingFeesAmount').css('display', 'none');
            //$('#dateEnrollmentLastDate').val('');
        }

        $("#ddlCategoryID").select2();
        $("#ddlTrainerID").select2();
        $("#ddlTrainingTypeID").select2();
        $('#ddlEmployeeID').select2();
        $("#ddlTrainingfrequencyID").select2();
        $("#ddlTrainingAgencyID").select2();
        $("#ddlTrainingfrequencyID").select2();
        $("#ddlAssesmentTypeID").select2();
        var MonthYear = @Html.Raw(Json.Encode(TempData["MonthYear"]));
        $("#txtMonthYear").val(MonthYear);
        
        OnTrainingCategoryChanged();
        // OnTrainingProviderSourceChanged();
        OnAssesmentRequiredChanged();

        //***********Multiselect Training Subcategory******************//
        $('#ddlTrainingSubcategoryID').select2({
            placeholder: "Select Training Subcategory",

            width: '100%'
        });

        // Handle "Select All" checkbox
        $("#selectAllSubcategory").click(function () {
            if (this.checked) {
                $("#ddlTrainingSubcategoryID > option").prop("selected", true).trigger("change");
            } else {
                $("#ddlTrainingSubcategoryID > option").prop("selected", false).trigger("change");
            }
        });

        $("#ddlTrainingSubcategoryID").on("change", function () {
            var total = $("#ddlTrainingSubcategoryID option").length;
            var selected = $("#ddlTrainingSubcategoryID").val().length || 0;
            $("#selectAllSubcategory").prop("checked", total === selected);
        });

        $("form").submit(function () {debugger;
            var selectedValues = $("#ddlTrainingSubcategoryID").val();
            $("#SelectedTrainingSubcategories").val(selectedValues ? selectedValues.join(",") : "");
        });


        //***********Multiselect department******************//
        $('#ddlDepartmentID').select2({
            placeholder: "Select Departments",
            width: '100%'
        });

        // Handle "Select All" checkbox
        $("#selectAllDepartments").click(function () {
            if (this.checked) {
                $("#ddlDepartmentID > option").prop("selected", true).trigger("change");
            } else {
                $("#ddlDepartmentID > option").prop("selected", false).trigger("change");
            }
        });

        $("#ddlDepartmentID").on("change", function () {
            var total = $("#ddlDepartmentID option").length;
            var selected = $("#ddlDepartmentID").val().length || 0;
            $("#selectAllDepartments").prop("checked", total === selected);
        });

        $("form").submit(function () {
            var selectedValues = $("#ddlDepartmentID").val();
            $("#SelectedDepartments").val(selectedValues ? selectedValues.join(",") : "");

            var selectedsubcategoryValues = $("#ddlTrainingSubcategoryID").val();
            $("#SelectedTrainingSubcategories").val(selectedsubcategoryValues ? selectedsubcategoryValues.join(",") : "");
        });

        //***********Multiselect department******************//

        $("#ddlEmployeeID").change(function () {
            var selectedText = $("#ddlEmployeeID option:selected").text();
            $("#TrainingProvidedBy").val(selectedText);
        });

        $("#ddlTrainingAgencyID").change(function () {
            var selectedText = $("#ddlTrainingAgencyID option:selected").text();
            $("#TrainingProvidedBy").val(selectedText);
        });

        $("#ddlTrainerID").change(function () {
            var selectedText = $("#ddlTrainerID option:selected").text();
            $("#TrainingProvidedBy").val(selectedText);
        });
    });

    //[Min participant validation]
    function OnValidateMinParticipants() {
        var maxParticipants = parseInt(document.getElementById("txtMaxParticipants").value, 10);
        var minParticipants = parseInt(document.getElementById("txtMinParticipants").value, 10);
        // If MinParticipants is greater than MaxParticipants, show the error message
        if (minParticipants > maxParticipants) {
            document.getElementById("ValidatorMinParticipants").innerText = "Minimum Participants must be less than or equal to Maximum Participants."; // Set the error text
            document.getElementById("ValidatorMinParticipants").style.display = "inline";  // Display the error message
        } else {
            document.getElementById("ValidatorMinParticipants").style.display = "none";
        }
    }
</script>


