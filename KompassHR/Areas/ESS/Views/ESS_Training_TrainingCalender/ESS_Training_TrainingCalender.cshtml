    function OnTrainingProviderSourceChanged() {debugger;
       
        var selectedValue = document.getElementById("txtTrainingProviderSource").value;
        var categoryID = document.getElementById("ddlCategoryID").value;
        // Hide all dropdowns & clear errors
        document.getElementById("ddltraineremployee").style.display = "none";
        document.getElementById("ddlagency").style.display = "none";
        document.getElementById("ddltrainer").style.display = "none";

        document.getElementById("errorInternal").innerText = "";
        document.getElementById("errorAgency").innerText = "";
        document.getElementById("errorTrainer").innerText = "";

        // Show the relevant dropdown based on selection
        if (selectedValue === "Internal") {
            document.getElementById("ddltraineremployee").style.display = "block";

            var selectedTrainerId = '@Model.TrainingProviderId';

            $("#ddlEmployeeID").find("option").remove();
            $.ajax({
                url: '@Url.Action("GetInternalTrainer", "ESS_Training_TrainingCalender")',
                method: "GET",
                data: { categoryID: categoryID },
                success: function (data) {
                    debugger;
                    if (data != null) {
                      
                        $("#ddlEmployeeID").append("<option value=''>--Select--</option>");
                        $.each(data.InternalEmployees, function (i, p) {
                            var isSelected = (p.Id == selectedTrainerId) ? "selected" : "";
                            $('#ddlEmployeeID').append("<option value='" + p.Id + "' " + isSelected + ">" + p.Name + "</option>");
                        });
                    }
                },
                error: function (xhr, status, error) {
                    console.log("AJAX Error:", xhr.responseText);
                }
            });

        } else if (selectedValue === "Agency") {
            document.getElementById("ddlagency").style.display = "block";
        } else if (selectedValue === "External") {
            document.getElementById("ddltrainer").style.display = "block";
        }
    }

    function validateTrainingProvider() {
        var selectedValue = document.getElementById("txtTrainingProviderSource").value;
        var isValid = true;

        // Reset error messages
        document.getElementById("errorInternal").innerText = "";
        document.getElementById("errorAgency").innerText = "";
        document.getElementById("errorTrainer").innerText = "";

        if (selectedValue === "Internal") {
            var internalTrainer = document.getElementById("ddlEmployeeID").value;
            if (!internalTrainer) {
                document.getElementById("errorInternal").innerText = "Please select an Internal Trainer.";
                isValid = false;
            }
        } else if (selectedValue === "Agency") {
            var agencyTrainer = document.getElementById("ddlTrainingAgencyID").value;
            if (!agencyTrainer) {
                document.getElementById("errorAgency").innerText = "Please select a Training Agency.";
                isValid = false;
            }
        } else if (selectedValue === "External") {
            var externalTrainer = document.getElementById("ddlTrainerID").value;
            if (!externalTrainer) {
                document.getElementById("errorTrainer").innerText = "Please select an External Trainer.";
                isValid = false;
            }
        }

        return isValid;
    }

    // Ensure the correct dropdown is shown when the page loads (if a value is pre-selected)
    //document.addEventListener("DOMContentLoaded", function () {debugger;
    //    OnTrainingProviderSourceChanged();
    //});

    function OnAssesmentRequiredChanged() {debugger;
        var requiredValue = $('#txtAssesmentRequired').val();
        if (requiredValue === "Yes") {
            $('#ddlAssesmentTypeID').prop('disabled', false);
        } else {
            $('#ddlAssesmentTypeID').prop('disabled', true);
        }
    }

</script>

