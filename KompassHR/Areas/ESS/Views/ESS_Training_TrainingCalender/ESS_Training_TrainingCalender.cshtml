<script>
    $.validator.addMethod("fileExtension", function (value, element, param) {
        if (element.files.length === 0) return true; // skip if no file
        var extension = value.split('.').pop().toLowerCase();
        return param.split(',').includes(extension);
    }, "Invalid file type.");

    // Add regex validation method
    $.validator.addMethod("regex", function (value, element, regexp) {
        if (regexp.constructor != RegExp)
            regexp = new RegExp(regexp);
        else if (regexp.global)
            regexp.lastIndex = 0;
        return this.optional(element) || regexp.test(value);
    }, "Invalid format.");

    $('#SaveTrainingCalender').validate({
        rules: {
            TrainingCalenderName: { required: true },
            SelectedTrainingSubcategories: { required: true },
            TrainingTypeId: { required: true },
            TrainingfrequencyId: { required: true },
            ModeOfTraining: { required: true },
            TraningCategoryId: { required: true }, // Keep if your form uses this name
            TrainingInstitute: { required: true },
            TrainingDescription: { required: true },
            TrainerId: { required: true },
            MaxParticipants: { required: true },
            MinParticipants: { required: true },
            TrainingProviderSource: { required: true },
            AssesmentRequired: { required: true },
            TrainingFeesType: { required: true },

            BannerFile: {
                required: {
                    depends: function () {
                        var existing = $('#divBannerFile span.form-label').text().trim();
                        return existing === '';
                    }
                },
                fileExtension: "jpg,jpeg,png,pdf,mp4,avi,mov,wmv,mkv"
            },

            EnrollmentLastDate: {
                required: {
                    depends: function () {
                        return $('#txtIsEnrollmentRequired').val() === 'Yes';
                    }
                }
            },

            TrainingFeesAmount: {
                required: {
                    depends: function () {
                        return $('#ddlTrainingFeesType').val() === 'Paid';
                    }
                },
                number: true
            },

            EnrollmentAttachment: {
                required: {
                    depends: function () {
                        var isQR = $('#ddlTrainingFeesPaidType').val() === 'QRScan';
                        var existing = $('#divQRAttachment span.form-label').text().trim();
                        return isQR && existing === '';
                    }
                },
                fileExtension: "jpg,jpeg,png,pdf,mp4,avi,mov,wmv,mkv"
            }
        },

        messages: {
            TrainingCalenderName: { required: "Training Calender Name is required." },
            SelectedTrainingSubcategories: { required: "Please select a training sub-category." },
            TrainingTypeId: { required: "Please select a training type." },
            TrainingfrequencyId: { required: "Please select a training frequency." },
            ModeOfTraining: { required: "Mode of training is required." },
            TraningCategoryId: { required: "Please select training category." },
            TrainingInstitute: { required: "Please select training institute." },
            TrainingDescription: { required: "Training description is required." },
            TrainerId: { required: "Please select trainer." },
            MaxParticipants: { required: "Maximum participants is required." },
            MinParticipants: { required: "Minimum participants is required." },
            TrainingProviderSource: { required: "Please select training provider." },
            AssesmentRequired: { required: "Please select assessment required." },
            TrainingFeesType: { required: "Training fees type is required." },
            BannerFile: {
                required: "Banner file is required.",
                fileExtension: "Only jpg, jpeg, png, pdf, mp4, avi, mov, wmv, mkv files are allowed."
            },
            EnrollmentLastDate: { required: "Enrollment last date is required." },
            TrainingFeesAmount: {
                required: "Fees amount is required.",
                number: "Please enter a valid number."
            },
            EnrollmentAttachment: {
                required: "QR code attachment is required when you choose QRScan.",
                fileExtension: "Only jpg, jpeg, png, pdf, mp4, avi, mov, wmv, mkv files are allowed."
            }
        }
    });

    //$("#ddlTrainingSubcategoryID").rules("add", {
    //    required: true,
    //    messages: {
    //        required: "Please select at least one training sub-category."
    //    }
    //});

    var form = $("#SaveTrainingCalender");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        var selectedSubcategories = $("#ddlTrainingSubcategoryID").val();
        var isValid = true;

        if (!selectedSubcategories || selectedSubcategories.length === 0) {
            $("#ddlTrainingSubcategoryID-error").text("Please select at least one training sub-category.").show();
            $("#ddlTrainingSubcategoryID").addClass("error");
            isValid = false;
        } else {
            $("#ddlTrainingSubcategoryID-error").text("").hide();
            $("#ddlTrainingSubcategoryID").removeClass("error");
        }
        if (!form.valid()) {
            $("#txtEstablishedDate").removeClass("error");
            return false;
        }

        if (!isValid) {
            return false;
        }

        $("#SaveTrainingCalender").submit();
    });
</script>
