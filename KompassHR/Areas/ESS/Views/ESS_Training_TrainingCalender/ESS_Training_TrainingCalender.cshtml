@model KompassHR.Areas.ESS.Models.ESS_Training.Training_TrainingCalender

@{
    ViewBag.Title = "ESS_Training_TrainingCalender";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>

<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }



    .box2 {
        width: 100px;
        height: 100px;
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
        margin-bottom: 10px;
    }

        .box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.03), 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        }

            .box2:hover .info i {
                color: #ff9c19;
            }


        .box2 .info i {
            font-size: 20px;
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
            font-size: 12px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .FS-12PX {
        font-size: 12px !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }


    .fixed-side {
        position: sticky;
        left: 0px;
    }

    /*.fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #1d76c6;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .empbx h4 {
        margin-bottom: 5px;
    }

    .empbx h6 i {
        font-size: 1rem;
        margin-right: 5px;
    }

    .empbx {
        margin-bottom: 20px;
    }

    .note-editable{
        border:groove;
        font-size:16px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Training Calendar
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_LMS_Training_Training", "ESS_LMS_Training_Training",  new { id = 38,ScreenId=589, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Training Calendar</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Information related to the training calender.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" method="post" action='@Url.Action("SaveUpdate", "ESS_Training_TrainingCalender", new { area = "ESS" })' enctype="multipart/form-data" id="SaveTrainingCalender">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Training Details
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Training Course
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.TraningCategoryId, new SelectList(ViewBag.CategoryName, "Id", "Name"), "--Select--", new { id = "ddlCategoryID", name = "CategoryID", @class = "form-select", autocomplete = "off", onchange = "OnTrainingCategoryChanged();OnTrainingCategoryIdChanged()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <div class="col-md-12 d-flex justify-content-between align-items-center">
                                                <label class="form-label col-form-label mb-0">
                                                    Training Category <span class="important">*</span>
                                                </label>
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input" id="selectAllSubcategory" />
                                                    <label class="form-check-label" for="selectAllSubcategory"><b>Select All</b></label>
                                                </div>
                                            </div>
                                            <div class="col-md-12 mt-1">
                                                <select id="ddlTrainingSubcategoryID" class="form-control" multiple="multiple"></select>
                                                <span id="ddlTrainingSubcategoryID-error" style="display:none; font-size:12px;color:red;"></span>
                                                <input type="hidden" id="SelectedTrainingSubcategories" name="SelectedTrainingSubcategories" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Training Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.TrainingTypeId, new SelectList(ViewBag.GetTrainingType, "Id", "Name"), "--Select--", new { id = "ddlTrainingTypeID", name = "TrainingTypeID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Training Calender Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.TrainingCalenderName, new { @class = "form-control", name = "TrainingCalenderName", @id = "txtTrainingCalenderName", autocomplete = "Off", @maxlength = 100 })
                                                @Html.HiddenFor(model => model.TrainingCalenderId_Encrypted, new { @class = "form-control", id = "TrainingCalenderId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Training Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextAreaFor(model => model.TrainingDescription, new { @class = "summernote", style = "border: 1px solid #000;", id = "txtTrainingDescription", @placeholder = "Description....", autocomplete = "Off", contenteditable = "true" })
                                                @*@Html.TextAreaFor(model => model.TrainingDescription, new { @class = "form-control", name = "TrainingDescription", @id = "txtTrainingDescription", autocomplete = "off", @maxlength = 500, rows = 1 })*@
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Department <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                <div>
                                                    <input type="checkbox" id="selectAllDepartments" />
                                                    <label for="selectAllDepartments"><b>Select All</b></label>
                                                </div>

                                                <select id="ddlDepartmentID" name="Department" class="form-control" multiple="multiple">
                                                    @{
                                                        var selectedDepartments = ViewBag.SelectedDepartmentIds as List<string> ?? new List<string>();
                                                    }

                                                    @foreach (var dept in ViewBag.DepatmentList)
                                                    {
                                                        var selected = selectedDepartments.Contains(dept.Id.ToString()) ? "selected" : "";
                                                        <option value="@dept.Id" @selected>@dept.Name</option>
                                                    }
                                                </select>

                                                <span class="help-block" id="ErrorDepartmentID" style="color:red"></span>
                                                <input type="hidden" id="SelectedDepartments" name="SelectedDepartments" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Scheduling Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Month Year
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", name = "MonthYear", type = "datetime-local", id = "txtMonthYear", required = "required" })
                                                @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Mode of Training
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ModeOfTraining,
                                                new SelectList(new List<SelectListItem>
                                                {
                                                new SelectListItem { Value = "", Text = "--Select--", Selected = true },
                                                new SelectListItem { Value = "Offline", Text = "Offline" },
                                                new SelectListItem { Value = "Online", Text = "Online" }
                                                }, "Value", "Text"),
                                                new { id = "txtModeOfTraining", name = "ModeOfTraining", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Venue/Location/Link
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.Location, new { @class = "form-control", name = "Location", @id = "txtLocation", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                               GPS Latitude
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.GPSLattitude, new { @class = "form-control", name = "MonthYear", id = "txtGPSLattitude", required = "required" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                               GPS Longitude
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.GPSLongitude, new { @class = "form-control", name = "MonthYear",  id = "txtGPSLongitude", required = "required" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Enrollment & Capacity Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Who will provide the training <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.TrainingProviderSource,
                                                new SelectList(new List<SelectListItem>
                                                {
                                                new SelectListItem { Value = "", Text = "--Select--", Disabled = true, Selected = true },
                                                new SelectListItem { Value = "Internal", Text = "Internal" },
                                                new SelectListItem { Value = "External", Text = "External" },
                                                new SelectListItem { Value = "Agency", Text = "Agency" }
                                                }, "Value", "Text"),
                                                new { id = "txtTrainingProviderSource", name = "TrainingProviderSource", @class = "form-select", autocomplete = "off", onchange = "OnTrainingProviderSourceChanged()" })
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Internal Trainer Dropdown -->
                                    <div class="col-md-6" id="ddltraineremployee" style="display: none;">
                                        <label class="form-label col-form-label col-md-12">Internal Trainer <span class="important">*</span></label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.TrainingProviderId, new SelectList(ViewBag.GetIntenalTraineeEmployee, "Id", "Name"), "--Select--", new { id = "ddlEmployeeID", name = "EmployeeID", @class = "form-select", autocomplete = "off" })
                                            <span class="text-danger" id="errorInternal"></span>
                                            @Html.HiddenFor(model => model.TrainingProvidedBy, new { id = "TrainingProvidedBy" })
                                        </div>
                                    </div>

                                    <!-- Agency Dropdown -->
                                    <div class="col-md-6" id="ddlagency" style="display: none;">
                                        <label class="form-label col-form-label col-md-12">Training Agency <span class="important">*</span></label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.TrainingAgencyId, new SelectList(ViewBag.GetAgency, "Id", "Name"), "--Select--", new { id = "ddlTrainingAgencyID", name = "TrainingAgencyID", @class = "form-select", autocomplete = "off" })
                                            <span class="text-danger" id="errorAgency"></span>
                                            @Html.HiddenFor(model => model.TrainingProvidedBy, new { id = "TrainingProvidedBy" })
                                        </div>
                                    </div>

                                    <!-- External Trainer Dropdown -->
                                    <div class="col-md-6" id="ddltrainer" style="display: none;">
                                        <label class="form-label col-form-label col-md-12">External Trainer <span class="important">*</span></label>
                                        <div class="col-md-12">
                                            @Html.DropDownListFor(model => model.TrainerId, new SelectList(ViewBag.GetTrainer, "Id", "Name"), "--Select--", new { id = "ddlTrainerID", name = "TrainerID", @class = "form-select", autocomplete = "off" })
                                            <span class="text-danger" id="errorTrainer"></span>
                                            @Html.HiddenFor(model => model.TrainingProvidedBy, new { id = "TrainingProvidedBy" })
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Training Frequency
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.TrainingfrequencyId, new SelectList(ViewBag.GetTrainingFrequency, "Id", "Name"), "--Select--", new { id = "ddlTrainingfrequencyID", name = "TrainingfrequencyID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Enrolled Participiant
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.EnrolledCount, new { @class = "form-control", name = "EnrolledCount", @id = "txtEnrolledCount", autocomplete = "Off", disabled = "disabled" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3" hidden>
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Maximum Participants
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.MaxParticipants, new { @class = "form-control", name = "MaxParticipants", @id = "txtMaxParticipants", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3" hidden>
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Minimum Participants
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.MinParticipants, new { @class = "form-control", name = "MinParticipants", @id = "txtMinParticipants", autocomplete = "Off", onInput = "OnValidateMinParticipants()" })
                                                <span id="ValidatorMinParticipants" style="display:none;color:red"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3" hidden>
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                WaitList Allowed
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.WaitList,
                                                new SelectList(new List<SelectListItem>
                                                {
                                                new SelectListItem { Value = "", Text = "--Select--", Disabled = true, Selected = true },
                                                new SelectListItem { Value = "Yes", Text = "Yes" },
                                                new SelectListItem { Value = "No", Text = "No" }

                                                }, "Value", "Text"),
                                                new { id = "txtWaitList", name = "WaitList", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Assessment
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Assessment Required
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.AssesmentRequired,
                                                new SelectList(new List<SelectListItem>
                                                {
                                                new SelectListItem { Value = "", Text = "--Select--", Disabled = true, Selected = true },
                                                new SelectListItem { Value = "Yes", Text = "Yes" },
                                                new SelectListItem { Value = "No", Text = "No" }
                                                }, "Value", "Text"),
                                                new { id = "txtAssesmentRequired", name = "AssesmentRequired", @class = "form-select", autocomplete = "off", onchange = "OnAssesmentRequiredChanged()" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Assessment Type
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.AssesmentTypeId, new SelectList(ViewBag.GetAssesmentType, "Id", "Name"), "--Select--", new { id = "ddlAssesmentTypeID", name = "AssesmentTypeID", @class = "form-select", autocomplete = "off", disabled = "disabled" })
                                            </div>
