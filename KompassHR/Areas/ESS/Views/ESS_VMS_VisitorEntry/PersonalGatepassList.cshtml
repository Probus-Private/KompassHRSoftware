        //var url = '@Url.Action("UpdateCheckOutVisitor", "ESS_VMS_VisitorEntry")?PersonalGatepassId_Encrypted=' + PersonalGatepassId_Encrypted;
        var url = '@Url.Action("UpdateCheckOutVisitor", "ESS_VMS_VisitorEntry")'
         + '?PersonalGatepassId=' + encodeURIComponent(PersonalGatepassId)
         + '&InOut=' + encodeURIComponent(InOut)
        window.location.href = url;
    }
