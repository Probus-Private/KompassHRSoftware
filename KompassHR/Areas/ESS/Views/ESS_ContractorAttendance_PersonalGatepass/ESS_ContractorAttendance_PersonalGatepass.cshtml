                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Time
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToTime, new { @class = "form-control", id = "ToTime", type = "datetime-local", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.ToTime, "", new { @class = "help-block", id = "ErrorToTime", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                TotalTime Allow
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalDurations, new { @class = "form-control", id = "Totalallowtime", type = "text", autocomplete = "Off", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Duration
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalDurations, new { @class = "form-control", id = "TotalDurations", type = "text", autocomplete = "Off", @readonly = "readonly", Style = "background-color: #eee;" })
                                                @Html.ValidationMessageFor(model => model.TotalDurations, "", new { @class = "help-block", id = "ErrortxtTotalDuration", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3"
                                                   style="width: 16.5%;">
                                                Reason
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9" style="min-width: 83.5%; max-width: 100%;">
                                                @Html.TextAreaFor(model => model.Reason, new { @class = "form-control", id = "Reason", name = "Reason", type = "text", autocomplete = "Off", @required = "required" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">

                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm" value="Submit">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("ESS_ContractorAttendance_GetList", "ESS_ContractorAttendance_PersonalGatepass", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $("#ddlEmployeeID").select2();
        $("#ddlShift").select2();
        //Validation for back day days
        var BackDatedDays = @Html.Raw(Json.Encode(ViewBag.GetBackDatedDays));

        $("#ddlEmployeeID").on("change",function(){
            debugger;
            $("#ddlShift").find("option").remove();
            var EmployeeId=$("#ddlEmployeeID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetShift", "ESS_ContractorAttendance_PersonalGatepass")',
                data: { EmployeeId: EmployeeId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlShift").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlShift").append("<option value='" + p.ShiftId + "'>" + p.ShiftName + "</option>");
                        });
                    }
                }
            })
        });

        var Duration =@Html.Raw(Json.Encode(ViewBag.Duration));
        $("#Totalallowtime").val(Duration + ' Min')
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#PersoanlDate").val(dateString);

        $("#ddlShift").change(function () {
            debugger;
            var ShiftId = $("#ddlShift").val();

            $.ajax({
                type: "Get",
                url: "@Url.Action("GetShiftFlag", "ESS_TimeOffice_PersonalGatePass")",
                data: { ShiftId:ShiftId},
            dataType: "text",
            success: function (data) {
                debugger;
                var GetShiftFlag = JSON.parse(data)
                var Flag=GetShiftFlag[0].Value;
                if(Flag==false)
                {
                    var fromDateInput = document.getElementById("FromTime");
                    var ToDateInput = document.getElementById("ToTime");

                    var now = new Date();

                    // Min Date: BackDatedDays ago at 00:00
                    var minDate = new Date();
                    minDate.setDate(now.getDate() - BackDatedDays);
                    minDate.setHours(0, 0, 0, 0);

                    // Max Date: today at 23:59
                    var maxDate = new Date();
                    maxDate.setDate(now.getDate() + 0);
                    maxDate.setHours(23, 59, 59, 999);

                    // Format to yyyy-MM-ddTHH:mm
                    function formatDateToLocalInput(date) {
                        const offset = date.getTimezoneOffset();
                        const localDate = new Date(date.getTime() - (offset * 60 * 1000));
                        return localDate.toISOString().slice(0, 16); // "yyyy-MM-ddTHH:mm"
                    }

                    fromDateInput.min = formatDateToLocalInput(minDate);
                    fromDateInput.max = formatDateToLocalInput(maxDate);

                    ToDateInput.min = formatDateToLocalInput(minDate);
                    ToDateInput.max = formatDateToLocalInput(maxDate);


                    var PersoanlDateInput = document.getElementById("PersoanlDate");

                    var now = new Date();
                    var minDate = new Date();
                    minDate.setDate(now.getDate() - BackDatedDays);

                    var maxDate = new Date(); // today

                    function formatDate(date) {
                        return date.toISOString().split('T')[0]; // yyyy-MM-dd
                    }

                    PersoanlDateInput.min = formatDate(minDate);
                    PersoanlDateInput.max = formatDate(maxDate);
                }
                else{
                    var fromDateInput = document.getElementById("FromTime");
                    var ToDateInput = document.getElementById("ToTime");

                    var now = new Date();
                    // Min Date: BackDatedDays ago at 00:00
                    var minDate = new Date();
                    minDate.setDate(now.getDate() - BackDatedDays);
                    minDate.setHours(0, 0, 0, 0);

                    // Max Date: today at 23:59
                    var maxDate = new Date();
                    maxDate.setDate(now.getDate() + 1);
                    maxDate.setHours(23, 59, 59, 999);

                    // Format to yyyy-MM-ddTHH:mm
                    function formatDateToLocalInput(date) {
                        const offset = date.getTimezoneOffset();
                        const localDate = new Date(date.getTime() - (offset * 60 * 1000));
                        return localDate.toISOString().slice(0, 16); // "yyyy-MM-ddTHH:mm"
                    }

                    fromDateInput.min = formatDateToLocalInput(minDate);
                    fromDateInput.max = formatDateToLocalInput(maxDate);

                    ToDateInput.min = formatDateToLocalInput(minDate);
                    ToDateInput.max = formatDateToLocalInput(maxDate);


                    var PersoanlDateInput = document.getElementById("PersoanlDate");

                    var now = new Date();
                    var minDate = new Date();
                    minDate.setDate(now.getDate() - BackDatedDays);

                    var maxDate = new Date(); // today

                    function formatDate(date) {
                        return date.toISOString().split('T')[0]; // yyyy-MM-dd
                    }

                    PersoanlDateInput.min = formatDate(minDate);
                    PersoanlDateInput.max = formatDate(maxDate);

                }
            }
        })
    });


    });//Reday Funcation


    $("#FromTime, #ToTime").change(function () {
        debugger;
        var FromTime = $("#FromTime").val();
        var ToTime = $("#ToTime").val();

        if (!ToTime) {
            $('#ErrorToTime').html("To time is required");
            return;
        }

        if (FromTime >= ToTime) {
            $('#ErrorFromTime').html("From Time should be less than To Time");
            return false;
        } else {
            $('#ErrorToTime, #ErrorFromTime').html("");
        }

        // Parse datetime-local strings into Date objects
        var fromDate = new Date(FromTime);
        var toDate = new Date(ToTime);

        // Calculate time difference in minutes
        var diffMs = toDate - fromDate; // in milliseconds
        var diffMins = Math.floor(diffMs / 60000); // convert to minutes

        $('#TotalDurations').val(diffMins + " Min");

        var TotalTime = $('#Totalallowtime').val(); // e.g., "60Min"
        var allowedMinutes = parseInt(TotalTime.replace("Min", "").trim());

        if (diffMins > allowedMinutes) {
            $("#ErrortxtTotalDuration").html("Total duration cannot exceed: " + allowedMinutes + " Min");
            return false;
        } else {
            $("#ErrortxtTotalDuration").html("");
        }
    });


    function DeletePersonalGetPass(PersonalGatepassId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("PersonalGetPassDelete", "ESS_ContractorAttendance_PersonalGatepass")?PersonalGatepassId_Encrypted=' + PersonalGatepassId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>

<script>
    jQuery.validator.addMethod(
    "regex",
        function(value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        },"erreur expression reguliere"
    );

    $('#SavePersonalGetpass').validate({
        rules: {
            EmployeeID: {
                required: true,
            },
            PersonalGatepassShiftId:{
                required: true,
            },

            PersonalGatepassDate:{
                required: true,
            },
            FromTime:{
                required: true,
            },
            ToTime:{
                required: true,
            },
            Direction:{
                required: true,
            },
            Reason:{
                required: true,
            },

        },
        messages: {
            EmployeeID: {
                required: "Please select the Employee Name",
            },
            PersonalGatepassShiftId:{
                required: "Please select shift",
            },

            PersonalGatepassDate: {
                required: "Date is required",
            },
            FromTime:{
                required: "From Time is required",
            },
            ToTime:{
                required: "To Time is required",
            },
            Direction:{
                required: "Direction is required",
            },
            Reason:{
                required: "Reason is required",
            }
        },
    });

    var form = $("#SavePersonalGetpass");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if(form.valid()==false)
        {
            $("#PersoanlDate").removeClass('error');
            $("#FromTime").removeClass('error');
            $("#ToTime").removeClass('error');
            return false;
        }

        var EmployeeID=$("#ddlEmployeeID").val();
        var PersoanlDate = $("#PersoanlDate").val();
        var FromTime = $("#FromTime").val();
        var ToTime = $("#ToTime").val();
        var ErrorFromTime = $("#ErrorFromTime").text();
        var ErrorToTime = $("#ErrorToTime").text();
        var ShiftId = $("#ddlShift").val();

        var Duration =@Html.Raw(Json.Encode(ViewBag.Duration));
        var TotalAllowRequest=$("#Totalallowtime").val();
        var GetTotalAllowRequest=Number(TotalAllowRequest.replaceAll("Min", ""));
        var TotalDurations = $("#TotalDurations").val();
        var ErrortxtTotalDuration = $("#ErrortxtTotalDuration").text();

        if(TotalDurations==0)
        {
            $("#ErrortxtTotalDuration").html("Total duration should not be 0");return false;
        }
        else{
            $("#ErrortxtTotalDuration").html("");
        }

        var PersoanlDate = $("#PersoanlDate").val();
        var FromTime = $("#FromTime").val();
        var ToTime = $("#ToTime").val();

        if (PersoanlDate && FromTime) {
            var personalDateOnly = new Date(PersoanlDate);
            var fromDateTime = new Date(FromTime);

            // Compare if FromTime is before PersonalDate
            if (fromDateTime < personalDateOnly) {
                $('#ErrorFromTime').html("From date/time must be equal to or greater than the Personal date.");
            } else {
                $('#ErrorFromTime').html(""); // Clear error if valid
            }
        }

        if (!ToTime) {
            $('#ErrorToTime').html("To time is required");
            return;
        }

        if (FromTime >= ToTime) {
            $('#ErrorFromTime').html("From Time should be less than To Time");
            return false;
        } else {
            $('#ErrorToTime, #ErrorFromTime').html("");
        }

        // Parse datetime-local strings into Date objects
        var fromDate = new Date(FromTime);
        var toDate = new Date(ToTime);

        // Calculate time difference in minutes
        var diffMs = toDate - fromDate; // in milliseconds
        var diffMins = Math.floor(diffMs / 60000); // convert to minutes

        $('#TotalDurations').val(diffMins + " Min");

        var TotalTime = $('#Totalallowtime').val(); // e.g., "60Min"
        var allowedMinutes = parseInt(TotalTime.replace("Min", "").trim());

        if (diffMins > allowedMinutes) {
            $("#ErrortxtTotalDuration").html("Total duration cannot exceed: " + allowedMinutes + " Min");
            return false;
        } else {
            $("#ErrortxtTotalDuration").html("");
        }


        if(Duration < TotalDurations ||FromTime > ToTime || ToTime < FromTime|| TotalDurations==0 )
        {
            return false;
        }
        else
        {
            $(".Userloaderbg").css("display","flex");
            $.ajax({
                url: '@Url.Action("IsPersoanlGetPassExists", "ESS_ContractorAttendance_PersonalGatepass")',
               // url:"IsPersoanlGetPassExists",
                method:"get",
                data:{EmployeeID:EmployeeID,PersoanlDate:PersoanlDate,FromTime:FromTime,ToTime:ToTime,ShiftId:ShiftId}, //,AdditionalNotifyPerson:AdditionalNotifyPerson
                success:function(response){
                    debugger;

                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon=="error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        return false;
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                })
                                $(".Userloaderbg").css("display","none");
                            }
                        }
                        return false;
                    }
                    else{
                        $("#SavePersonalGetpass").submit();
                    }
                }
            });
        }

    });

</script>
