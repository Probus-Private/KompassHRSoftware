            </h6>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body" style="padding:0px;">
            <div class="row text-center mt-2">
                <div class="d-flex justify-content-center">
                    <img src="" id="ImgEmp" class="rounded-circle" alt="Flowchart Icon" width="80" height="80">
                </div>
            </div>
            <div class="row">
                <div class="table-responsive">
                    <table id="orgChartTable" class="table table-hover">
                        @*<thead class="table-light">
                                <tr>
                                    <th>Question</th>
                                    <th>Answer</th>
                                </tr>
                            </thead>*@
                        <tbody>
                            <!-- Dynamic rows will be inserted here -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- END panel -->


<script>
    var employeeData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GetOrganisationChart));
    var CompanyLogo = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Session["EmployeeProfile"]));
    debugger;
    var data = [];
    employeeData.forEach(item => {
        var parentId = item.Parent ? item.Parent.toString() : '';
        var nodeId = item.Key.toString();
        data.push({
            id: nodeId,
            parent: parentId,
            name: item.Name,
            color: item.Highlight === 1 ? "#90ca4bbf" : "lightblue",
            Title: item.Title,
            OrgLevel: item.OrgLevel,
            EmployeeName: item.EmployeeName,
            Designation: item.Designation,
            Remark: item.Remark,
            JoiningDate: item.JoiningDate,
            Experience: item.Experience,
            Employeeid: item.Employeeid,
            Gender: item.Gender
        });
    });
    //console.log(data);

    new d3.OrgChart()
      .nodeId((dataItem) => dataItem.id)
      .parentNodeId((dataItem) => dataItem.parent)
      .nodeWidth((d) => 280)
      .initialZoom(0.7)
      .nodeHeight((node) => {
        // Dynamically set height based on content or node type
        return node.data.height || 175; // Default height = 175px
    })
      .childrenMargin((d) => 50)
      .compactMarginBetween((d) => 45)
      .compactMarginPair((d) => 80)
        .linkUpdate(function (d) {
            d3.select(this)
              .attr("stroke", "black")  // Set line color to black
              .attr("stroke-width", 1); // Make the line thicker
        })
      .nodeContent((node) => {
          let imageUrl;
          debugger;
          if (node.data.Gender == "Male") {
              imageUrl = node.data.image || "/assets/img/Allimages/MaleIcon.png";
          }
          if (node.data.Gender == "Female"){
              imageUrl = node.data.image || "/assets/img/Allimages/FeMaleIcon.png";
          }
          if (node.data.Gender == "-")
          {
              imageUrl = node.data.image || "/assets/img/Allimages/Kings.png";
          }
          return `
        <div class="profile-card">
    <div class="header" style="background: ${node.data.color}; position: relative;">
        <h2>${node.data.Title}</h2>
               <span class="org-level" style="position: absolute; right: 5px; top: 5px; font-size: 14px; color: white; background: rgba(0, 0, 0, 0.4); padding: 3px 5px; border-radius: 7px;" data-bs-toggle="offcanvas" href="#offcanvasExample" onclick="showOrgLevel('${node.data.Employeeid}', '${node.data.Gender}')">
                ${node.data.OrgLevel}
            </span>
        <img src="${imageUrl}" alt="Profile Picture" onerror="this.onerror=null;this.src='/assets/img/Allimages/default.png';">
    </div>
    <div class="content">
        <div class="info">
        </div>
        <p class="name">${node.data.EmployeeName}</p>
        <p class="subtitle">${node.data.Designation}</p>
              <p class="subtitle">${node.data.Remark}</p>
    </div>
    <div class="footer">
        <span><i class="fa-regular fa-calendar"></i> ${node.data.JoiningDate}</span>
        <span><i class="fa-regular fa-calendar"></i> ${node.data.Experience}</span>

    </div>
</div>`;
      })
      .container('.chart-container')
      .data(data)
      .render()
    .expandAll(); // Expands all nodes by default


</script>

<script>
    function showOrgLevel(EmpId,Gender) {
        debugger
        let GetGender=Gender;
        $.ajax({
            url: '@Url.Action("GetOrgChartDetails", "ESS_OrganisationChart_Menu")', // Generates the correct URL
            type: 'GET',
            data: { EmployeeId: EmpId }, // Pass Employee ID
            dataType: 'json',
            success: function (response)
            {
                debugger;
                var MaleimageUrl = '@Url.Content("~/assets/img/Allimages/MaleIcon.png")';
                var FemaleimageUrl = '@Url.Content("~/assets/img/Allimages/FeMaleIcon.png")';
                var DefaultImgUrl = '@Url.Content("~/assets/img/Allimages/Kings.png")';

                var SetImgUrl=response.EmployeePhoto;
                if (SetImgUrl!=null)
                {
                    $("#ImgEmp").attr("src", SetImgUrl);
                }
                else
                {
                    $("#ImgEmp").attr("src", "").hide();

                    if (GetGender=='Male')
                    {
                        $("#ImgEmp").attr("src", MaleimageUrl);
                        $("#ImgEmp").show();
                    }
                    if (GetGender=='Female')
                    {
                        $("#ImgEmp").attr("src", FemaleimageUrl);
                        $("#ImgEmp").show();
                    }
                }

                var formattedData = response.Data.map(itemArray => {
                    let obj = {};
                    itemArray.forEach(item => {
                        obj[item.Key] = item.Value;
                    });
                    return obj;
                });




                // Clear the table body before adding new data
                $("#orgChartTable tbody").empty();

                // Append rows dynamically
                formattedData.forEach(item => {
                    if (item.Question!='Employee Photo')
                    {
                        var row = `<tr>
                        <td><strong>${item.Question || ''}</strong></td>
                        <td><strong>:</strong></td>
                        <td>${item.Answer || ''}</td>
                        </tr>`;
                    }



                    $("#orgChartTable tbody").append(row);
                });
            },
            error: function (xhr, status, error) {
                console.error("Error fetching organisation chart details:", error);
            }
        });
    }

</script>

<script>
    function printDiv() {
        window.print(); // Triggers the print dialog
    }
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mermaid/10.2.4/mermaid.min.js"></script>

<script>
    function exportToPDF1() {
            const {jsPDF } = window.jspdf;
            const doc = new jsPDF('l', 'mm', 'a4'); // Landscape mode

            const scale = window.devicePixelRatio; // Improve image quality
            const flowchartDiv = document.querySelector("#flowchartDiv");

            html2canvas(flowchartDiv, {
                scale: scale,
                useCORS: true, // Handle cross-origin issues
            }).then(canvas => {
                const imgData = canvas.toDataURL("image/png");
                const imgWidth = 280; // Adjust for landscape A4
                const imgHeight = (canvas.height * imgWidth) / canvas.width;

                doc.addImage(imgData, 'PNG', 10, 10, imgWidth, imgHeight);
                doc.save("flowchart.pdf");
            });
        }
</script>


