
@{
    ViewBag.Title = "ShowOrganisationChart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    #flowchartDiv {
        width: 100%;
        height: 600px;
        border: 1px solid black;
        background-color: white;
        overflow: auto;
    }
</style>

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
    }
    .profile-card {
        max-width: 350px;
        background: white;
        border-radius: 10px;
        box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2);
        text-align: center;
        overflow: hidden;
        margin: 20px auto;
         border: 1px solid #003366; /* Added Border */
    }
    .header {
        background: #b3e0ff;
        padding: 7px;
        position: relative;
    }
    .header img {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        border: 1px solid white;
        position: absolute;
        top: 75%;
        left: 50%;
        transform: translate(-50%, -50%);
            margin-left: -112px;
    }
    .header h2 {
        margin: 0;
        font-size: 14px;
        color: #003366;
        font-weight: bold;
        margin-left: 20px;
    }
    .content {
        padding: 5px 5px 2px;
    }
    .info {

        font-size: 14px;
        color: #555;
        margin-bottom: 11px;
        text-align: right;
    }
    .info p {
        margin-bottom: 0rem !important;
    }
    .info i {
        margin-right: 5px;
    }
    .name {
        font-size: 14px;
        font-weight: bold;
        color: #003366;
    }
    .subtitle {
        font-size: 14px;
        color: #444;
        font-weight: bold;
    }
    .footer {
        display: flex;
        justify-content: space-between;
        padding: 5px 8px;
        border-top: 1px solid #ddd;
        font-size: 14px;
    }
    .footer i {
        margin-right: 5px;
    }

    @@media (max-width: 400px) {
        .profile-card {
            width: 90%;
        }
    }
</style>

<style>
    .breadcrumb {
        position: fixed;
        right: 20px;
        top: 60px;
        background: none;
        padding: 10px;
    }

    .chart-container {
    width: 100%;
    height: 100vh; /* Adjust based on your needs */
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: auto; /* Allows scrolling if needed */
    position: relative;
}

</style>



<style>
    @@media print {

        body * {
            visibility: hidden;
        }

        #printSection, #printSection * {
            visibility: visible !important;
        }

        #printSection {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            max-width: 100%;
            overflow: hidden !important; /* Prevents overflow */
            page-break-inside: avoid;
        }

        #flowchartDiv {
            overflow: hidden !important; /* Prevents overflow */
            /*border: none !important;*/
        }

        .printDiv {
            display: none;
        }
    }
</style>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3-org-chart@3.0.1"></script>
<script src="https://cdn.jsdelivr.net/npm/d3-flextree@2.1.2/build/d3-flextree.js"></script>



<script src="https://d3js.org/d3.v7.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3-org-chart@2"></script>
<script src="https://cdn.jsdelivr.net/npm/d3-flextree@2.1.2/build/d3-flextree.js"></script>


<div id="content" class="app-content">
        <section class="content">
        <div class="row">
            <div class="col-md-12">
                <div class="box box-info">
                    <div class="box-header with-border">
                        <div class="row" id="printSection">
                            <div class="col-md-12">
                                <div class="form-group d-flex align-items-center mb-2">
                                    <button onclick="printDiv()" id="printDiv" class="btn btn-sm btn-success me-3 printDiv">
                                        <i class="fa fa-print"></i> Print
                                    </button>
                                    <h2 class="flex-grow-1 text-center m-0">@Session["OrgTypeName"] Flowchart</h2>
                                    <ol style="list-style: none; padding: 0; margin: 0; display: flex; margin-left: auto;">
                                        <li style="margin-right: 10px;">
                                            <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                                                <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                                            </a>
                                        </li>
                                        <li>
                                            <a href="@Url.Action("ESS_OrganisationChart_Menu", "ESS_OrganisationChart_Menu",  new { id = 37,ScreenId=535, area = "ESS" })">
                                                <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                                            </a>
                                        </li>
                                    </ol>
                                </div>
                                <span class="printDiv" style="color:orangered">Before printing, scroll the chart to fit within the white panel, then click the print button.</span>
                                <div class="chart-container" id="flowchartDiv"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Include FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">


</div>
@*<div class="chart-container" style="height: 1200px; background-color: #f6f6f6"></div>*@

<!-- Start panel -->
<div class="row">
    <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false" data-bs-scroll="true" style="max-width: 350px; width: 100%;">
        <div class="offcanvas-header" style="border-bottom: 1px solid #d3d3d38a;">
            <h6 class="offcanvas-title text-center" id="EmpName1" style="width: 100%;">
