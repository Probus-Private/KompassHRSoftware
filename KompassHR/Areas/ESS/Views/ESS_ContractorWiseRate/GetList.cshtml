
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Contractor Wise Rate
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_AttenInvoiceMenu", "Module_Employee_AttenInvoiceMenu",  new {id = 27,ScreenId=925, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">Contractor Wise Rate - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Contractor Wise Rate created.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row align-items-center mb-3">


                                <div class="row">
                                    <div class="col-md-3">
                                        <a href="@Url.Action("ESS_ContractorWiseRate", "ESS_ContractorWiseRate", new { area = "ESS" })">
                                            <button type="button" class="btn btn-primary btn-sm mb-10px">
                                                <i class="fa-solid fa-plus"></i> &nbsp; Add
                                            </button>
                                        </a>
                                    </div>
                             
                                </div>

                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                               style="width: 100%;">
                                            <thead>
                                                <tr>
                                                    <th class="fixed-side">Update</th>
                                                    <th class="fixed-side1">Delete</th>
                                                    <th class="fixed-side1">View</th>
                                                    <th class="text-nowrap">Company Name</th>
                                                    <th class="text-nowrap">Buisness Unit</th>
                                                    <th class="text-nowrap">Contractor Name</th>
                                                    <th class="text-nowrap">From Month</th>
                                                    <th class="text-nowrap">To Month</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetRateList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <a onclick="UpdateRate('@d.CmpId','@d.BranchId','@d.ContractorId','@d.ContractorWiseRateMasterId_Encrypted','@d.FromMonth','@d.ToMonth')" id="btnUpdate" style="cursor:pointer;">
                                                                <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                            </a>
                                                        </td>

                                                        <td class="text-center">
                                                            <a onclick="DeleteRate('@d.ContractorWiseRateMasterId')" id="btnDelete" style="cursor:pointer;">
                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                            </a>
                                                        </td>
                                                        <td class="text-center" style="width: 80px;">
                                                            <a onclick="View('@d.ContractorId','@d.CmpId','@d.BranchId','@d.FromMonth','@d.ToMonth')" id="btnView" style="cursor:pointer;">
                                                                <i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>
                                                            </a>
                                                        </td>
                                                        <td>@d.CompanyName</td>
                                                        <td>@d.BranchName</td>
                                                        <td>@d.ContractorName</td>
                                                        <td>@d.FromMonth</td>
                                                        <td>@d.ToMonth</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>

    <!-- #Start modal-dialog -->
    <div class="modal fade" id="ManpowerCategoryListModel" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-black text-white">
                    <h4 class="modal-title" id="EmployeeListTitle">@*Employee List*@</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true" id="CloseModelHistory">
                            <i class="fa fa-xmark"></i>
                        </a>
                    </div>
                </div>
                <div class="modal-body" style="height: 500px; overflow-y: auto;">
                    <!-- BEGIN panel -->
                    <div class="modal-body-content">
                        <div class="row">
                            <div class="col-md-12">
                                <form>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <div class="table-scroll">
                                                    <div class="table-wrap">
                                                        <table class="table table-bordered table-hover mb-0 table-wrap align-middle" id="tblEmployeeLog">
                                                            <thead>
                                                                <tr class="trheading">
                                                                    <th class="fixed-side1">Delete</th>
                                                                    <th>Designation</th>
                                                                    <th style="text-align:center">Per Day Rate</th>
                                                                    <th style="text-align:center">Canteen Rate</th>
                                                                    <th style="text-align:center">Attendance Bonus Rate</th>
                                                                    <th style="text-align:center">Transport Allowance Rate</th>
                                                                    <th style="text-align:center">Other1</th>
                                                                    <th style="text-align:center">Other2</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tbodyLineManpowerCategoryHeadCountList"></tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>


    <script>
    $(document).ready(function () {
        debugger

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
    </script>

    <script>
        function UpdateRate(CmpId, BranchId, ContractorId,ContractorWiseRateMasterId_Encrypted,FromMonth,ToMonth) {
            debugger;
            var url = '@Url.Action("ESS_ContractorWiseRate", "ESS_ContractorWiseRate")'
                + '?ContractorWiseRateMasterId_Encrypted=' + encodeURIComponent(ContractorWiseRateMasterId_Encrypted)
                + '&ContractorId=' + encodeURIComponent(ContractorId)
                + '&CmpId=' + encodeURIComponent(CmpId)
                + '&BranchId=' + encodeURIComponent(BranchId)
                + '&FromMonth=' + encodeURIComponent(FromMonth)
                + '&ToMonth=' + encodeURIComponent(ToMonth);

            window.location.href = url;
        }


        function DeleteRate(ContractorWiseRateMasterId) {debugger;
                const DeleteButtons = Swal.mixin({
                    customClass: {
                        cancelButton: ' btnpress',
                        confirmButton: ' btnpress'
                    },
                    buttonsStyling: true
                })
                DeleteButtons.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'No, cancel!',
                    reverseButtons: false,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }

                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("Delete", "ESS_ContractorWiseRate")?ContractorWiseRateMasterId=' + ContractorWiseRateMasterId;

                    } else if (
                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                    }
                })
            }

        function View(ContractorId, CmpId, BranchId,FromMonth,ToMonth) {
            debugger;
            var url = '@Url.Action("ShowDesignationList", "ESS_ContractorWiseRate")';
            $.getJSON(url, {
                CmpId: CmpId,
                BranchId: BranchId,
                ContractorId:ContractorId,
                FromMonth:FromMonth,
                ToMonth:ToMonth
            }, function (data) {
                debugger;
                const jsonData = JSON.parse(data);
                $('#ManpowerCategoryListModel').modal('show');
                $('#EmployeeListTitle').text('Contractor Category List'); // Set the modal title
                $("#tbodyLineManpowerCategoryHeadCountList").empty();
                $.each(jsonData, function (index, item) {debugger;
                    var row = `<tr>
                         <td class="text-center">
                                        <a onclick="Delete(${item.ContractorWiseRateDetailsId})" id="btnDelete" style="cursor:pointer;">
                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                        </a>
                                    </td>
                                <td style="text-left">${item.DesignationName}</td>
                                <td style="text-align:right">${item.PerDayRate}</td>
                                <td style="text-align:right">${item.CanteenRate}</td>
                                <td style="text-align:right">${item.AttendanceBonusRate}</td>
                                <td style="text-align:right">${item.TransportAllowanceRate}</td>
                                <td style="text-align:right">${item.Other1}</td>
                                 <td style="text-align:right">${item.Other2}</td>
                           </tr>`;
                    $("#tbodyLineManpowerCategoryHeadCountList").append(row);
                });
            });
        }


        function Delete(ContractorWiseRateDetailsId) {debugger;
            const DeleteButtons = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            DeleteButtons.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("DeleteContractorWiseRateDetails", "ESS_ContractorWiseRate")?ContractorWiseRateDetailsId=' + ContractorWiseRateDetailsId;

                } else if (
                    result.dismiss === Swal.DismissReason.cancel
                ) {

                }
            })
        }
    </script>


