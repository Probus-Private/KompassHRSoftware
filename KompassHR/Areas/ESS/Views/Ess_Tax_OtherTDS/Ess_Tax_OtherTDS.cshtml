@model KompassHR.Areas.ESS.Models.ESS_Tax.IncomeTax_OtherTDS
@{
    ViewBag.Title = "Ess_Tax_OtherTDS";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>

<style>
     .select2.select2-container {
        width: 100% !important;
    }
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .formBx {
        border: 1px solid #ced4da;
        padding: 0.5rem 0.5rem;
        margin-bottom: 15px;
        padding-top: 15px;
    }

    h6 {
        margin-top: -20px;
        padding: 0 10px;
    }

    mark {
        background-color: #fff;
        font-size: 15px;
        padding: 0 5px;
    }


    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Other TDS
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Tax_Menu", "ESS_Tax_Menu", new {id = 9, ScreenId=183, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Other TDS  - @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define Other TDS here!

                    </p>
                </div>
                <div class="panel-body" style="height: 100% !important;">
                    <form role="form" action='@Url.Action("SaveUpdate", "Ess_Tax_OtherTDS", new { area = "ESS" })' id="SaveOtherTDS" method="post" data-parsley-validate="">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Financial Year <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.OtherTDSFyearId, new SelectList(ViewBag.GetTaxFyear, "Id", "Name"), "--Select--", new { id = "ddlOtherTDSFyearId", @class = "form-control", autocomplete = "off", name = "OtherTDSFyearId" })
                                        @Html.HiddenFor(model => model.OtherTDSId_Encrypted, new { id = "OtherTDSId_Encrypted" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Employee Name <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.OtherTDSEmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "--Select--", new { id = "ddlOtherTDSEmployeeId", @class = "form-control", autocomplete = "off", name = "OtherTDSEmployeeId" })

                                    </div>
                                </div>
                            </div>
                        </div>

                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Type <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.OtherTypeId, new SelectList(ViewBag.GetOtherTypeList, "Id", "Name"), "--Select--", new { id = "ddlOtherTypeId", @class = "form-control", autocomplete = "off", name = "OtherTypeId" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Month/Year <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.MonthYear, new { id = "MonthYear", @class = "form-control", autocomplete = "off", type = "month", name = "MonthYear" })
                                    </div>
                                </div>
                            </div>
                            
                        </div>


                        <div class="row">

                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Total Amount <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.TotalAmount, new { id = "txtTotalAmount", @class = "form-control", autocomplete = "off", name = "TotalAmount" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        TDS Amount <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.TDSAmount, new { id = "txtTDSAmount", @class = "form-control", autocomplete = "off", name = "TDSAmount" })
                                    </div>
                                </div>
                            </div>

                            
                        </div>

                       
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Remark <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextAreaFor(model => model.Remark, new { id = "txtRemark", @class = "form-control", autocomplete = "off", name = "Remark" })
                                    </div>
                                </div>
                            </div>                            
                        </div>                                           
                        <div class="row">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="btnSubmit"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                </button>
                                                <a href="@Url.Action("GetList", "Ess_Tax_OtherTDS", new { area = "ESS" })">
                                                    <button type="button" id="btnOtherTDSList" class="btn btn-danger btn-sm">
                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!-- END panel -->
    </div>
</div>


<script>

    $(document).ready(function(){
        debugger

    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
    if (Message != null) {
        if (Icon != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    // return false
                }
            }).then(function() {
                window.location.reload();
            });
        }
    }


    $("#ddlOtherTDSEmployeeId").select2();
  //  $("#ddlOtherTypeId").select2();

    var MonthYear = @Html.Raw(Json.Encode(TempData["MonthYear"]));

        if (MonthYear && MonthYear !== "null" && MonthYear !== "undefined" && MonthYear.trim() !== "") {
            var dateParts = MonthYear.split('-');
            var yyyy = parseInt(dateParts[0], 10);
            var mm = parseInt(dateParts[1], 10) - 1;
            var selectedDate = new Date(yyyy, mm, 1);
            var formattedMonth = selectedDate.getFullYear() + '-' + String(selectedDate.getMonth() + 1).padStart(2, '0');
            var CheckEmptyDate = document.getElementById('MonthYear').value;
            if (CheckEmptyDate === "") {
                document.getElementById('MonthYear').value = formattedMonth;
            }
        } else {
            console.error("TempData['MonthYear'] is invalid or empty.");
        }

        updateFinancialYearRange();

        // Also apply when dropdown changes
        $('#ddlOtherTDSFyearId').change(function () {
            updateFinancialYearRange();
        });

        function updateFinancialYearRange() {
            var selectedFYear = $('#ddlOtherTDSFyearId').find(":selected").text(); // Get selected financial year text

            if (selectedFYear && selectedFYear.includes("-")) {
                var years = selectedFYear.split("-"); // Assuming format "2023-2024"
                var startYear = years[0].trim();
                var endYear = years[1].trim();

                // Define financial year range
                minDate = startYear + "-04"; // Financial year starts in April
                maxDate = endYear + "-03";   // Financial year ends in March

                $('#MonthYear').attr('min', minDate);
                $('#MonthYear').attr('max', maxDate);
            } else {
                $('#MonthYear').removeAttr('min max');
            }
        }


    });
</script>


<script>
    // Helper function to format a Date object as 'YYYY-MM-DD'
    function formatToYYYYMMDD(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0'); // 0-based index
        const day = String(date.getDate()).padStart(2, '0'); // Always '01' here
        return `${year}-${month}-${day}`;
    }
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveOtherTDS").validate({
        rules: {
            OtherTDSFyearId: {
                required: true,
            },
            OtherTDSEmployeeId: {
                required: true,
            },
            OtherTypeId: {
                required: true,
            },
            TotalAmount: {
                required: true,
                min: 1,
            },
            TDSAmount: {
                required: true,
            },
            MonthYear: {
                required: true,
            },
            Remark: {
                required: true,
            },
        },
        messages: {
            OtherTDSFyearId: {
                required: "Please select financial year",
            },
            OtherTDSEmployeeId: {
                required: "Please select Employee",
            },
            OtherTypeId: {
                required: "Please select Perquisite ",
            },
            TotalAmount: {
                required: "Please enter Total Amount",
                min: "Total Amount must be greater than 0",
            },
            TDSAmount: {
                required: "Please enter Taxable Amount",
            },
            MonthYear: {
                required: "Please select Month Year ",
            },
            Remark: {
                required: "Please select Month Year ",
            },
        },
    });

    //IsValidation Check
    var form = $("#SaveOtherTDS");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {            
            return false;
        }
        else{
            $("#SaveOtherTDS").submit();
        }       
    });
</script>