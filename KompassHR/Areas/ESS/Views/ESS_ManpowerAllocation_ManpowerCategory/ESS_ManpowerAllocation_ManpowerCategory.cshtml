            else{$('#ErrorKPISubCategoryFName').html("");valid =true}

            var KPISubCategoryId_Encrypted=$("#KPISubCategoryId_Encrypted").val();
            var CompanyName=$("#txtCmpId").val();
            var KPICategoryBranchId=$("#txtKPICategoryBranchId").val();
            var KPISubCategoryFName = $("#txtKPICategoryFName").val();

            var lstKPICategory=[];
            $(':checkbox:checked').each(function (i) {
                debugger;
                var data1 = {};
                data1.KPIDepartmentId = $(this).val();
                lstKPICategory.push(data1);
            });
            debugger;
            if (lstKPICategory == "") {
                debugger;
                Swal.fire({
                    icon: "error",
                    text: "Select atleast one designation",
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        return false;
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
