                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        window.location.reload();
                        return false
                    }
                });
                return false;
            }

            $.ajax({
                async: true,
                type:"POST",
                url: '@Url.Action("IsManpowerAllocationExists", "ESS_ManpowerAllocation_ManpowerCategory")',
                data:JSON.stringify({KPISubCategoryId_Encrypted:KPISubCategoryId_Encrypted,CompanyName:CompanyName,KPICategoryBranchId:KPICategoryBranchId,KPISubCategoryFName:KPISubCategoryFName, lstKPICategory:lstKPICategory}),
                contentType: "application/json; charset=utf-8",
                dataType:"text",
                success:function(response){
                    debugger;
                    var Getdata = JSON.parse(response);
                    var Message1 = Getdata.Message;
                    var Icon1 = Getdata.Icon;
                    if (Icon1=="error") {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                    else{
                        actionUrl = '@Url.Action("SaveUpdate", "ESS_ManpowerAllocation_ManpowerCategory")';
                        form.action = actionUrl;
                        form.submit();
                    }
                }
            });
        }

    }



