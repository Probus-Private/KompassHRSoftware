<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Line and Manpower Category HC/MD Mapping by HR
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ManpowerAllocation_Menu", "ESS_ManpowerAllocation_Menu",  new { id = 35,ScreenId=278, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Line and Manpower Category HC/MD Mapping by HR- @ViewBag.AddUpdateTitle </h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the form of Line and Manpower Category HC/MD Mapping by HR .
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_HC_MDMappingByHR", "ESS_HC_MDMappingByHR", new { area = "ESS" })' id="formheadcountmapping" method="post" enctype="multipart/form-data">
                                <div class="row">
                                    <!-- Company Name -->
                                    <div class="col-md-6">
                                        <div class="mb-3 row">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlCmpId", name = "CmpId", autocomplete = "off" })
                                                @Html.HiddenFor(model => model.HC_MDMappingMasterID_Encrypted)
                                                @Html.HiddenFor(model => model.HC_MDMappingMasterID)
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Business Unit -->
                                    <div class="col-md-6">
                                        <div class="mb-3 row">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlBranchId", name = "BranchId", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <!-- Month/Year -->
                                    <div class="col-md-6">
                                        <div class="mb-3 row">
                                            <label class="form-label col-form-label col-md-4">
                                                Date <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.Date, new { @class = "form-control", name = "Date", type = "date", id = "txtDate" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" id="btnshow" onclick="GetHeadCount('Normal')" class="btn btn-primary btn-sm">Show</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Import File
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                <input type="file" name="AttachFile" class="form-control" id="txtAttachFile" />
                                                <span id="ErrorFile" class="error" style="color:red;"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-sm btn-danger" id="btnfileupload">Import</button> &nbsp; &nbsp;
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <div class="col-md-8">
                                                <button type="button" class="btn btn-sm btn-primary" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                    <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-2"></div>
                                    <div class="col-md-8">
                                        <div class="table-scroll div1">
                                            <div class="table-wrap" style="max-height:300px; overflow-y:auto;">
                                                <table class="table table-bordered align-middle tblAddData tdTable" id="tblApproval" style="width: 100%;">
                                                    <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                        <tr class="trheading">
                                                            <th>Line</th>
                                                            <th>Manpower Category</th>
                                                            <th style="text-align:center">HC</th>
                                                            <th style="text-align:center">MD</th>
                                                            <th hidden>LineId</th>
                                                            <th hidden>KPISubCategoryId</th>
                                                            <th hidden>HC_MDMappingDetailsID</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblHC_MDMapping">
                                                        @if (ViewBag.GetLineandManpowerCategoryList != null)
                                                        {
                                                            foreach (var item in ViewBag.GetLineandManpowerCategoryList)
                                                            {
                                                        <tr>
                                                            <td style="text-align:left;width:200px">@item.LineName</td>
                                                            <td style="text-align:left;width:200px">@item.KPISubCategoryFName</td>
                                                            <td style="text-align:right;width:50px">
                                                                <input type="number" name="HC[@($"{item.LineId}_{item.KPISubCategoryFName}")]"
                                                                       class="form-control" min="0" step="1" style="height:26px;text-align:right" value="@item.HeadCount" oninput="validateInteger(this);" />
                                                            </td>
                                                            <td style="text-align:right;width:50px">
                                                                <input type="number" name="MD[@($"{item.LineId}_{item.KPISubCategoryFName}")]"
                                                                       class="form-control" min="0" step="1" style="height:26px;text-align:right" value="@item.MonthDays" />
                                                            </td>
                                                            <td hidden>@item.LineId</td>
                                                            <td hidden>@item.KPISubCategoryId</td>
                                                            <td hidden>@item.HC_MDMappingDetailsID</td>
                                                        </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2"></div>
                                </div>
                                <hr />

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                    Submit
                                                </button>
                                                <a href="@Url.Action("GetList", "ESS_HC_MDMappingByHR", new { area = "ESS" })">
                                                    <button type="button" class="btn btn-danger btn-sm" id="btnPunchMissingList">
                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        debugger

        var addUpdateTitle = '@ViewBag.AddUpdateTitle';
        if (addUpdateTitle === "Update") {
            var Date = @Html.Raw(Json.Encode(TempData["Date"]));
            $("#txtDate").val(Date);
        }
        else{
            var Date = @Html.Raw(Json.Encode(TempData["Date"]));
            $("#txtDate").val(Date);
        }

        $('title').html("Line and Manpower Category HC/MD Mapping");

        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_HC_MDMappingByHR")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formheadcountmapping').validate({
        rules: {
            CmpId: {
                required: true,
            },
            Date: {
                required: true,
            },
            BranchId: {
                required: true,
            }
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            Date: {
                required: "Date is required",
            },
            BranchId: {
                required: "Buisness Unit is required",
            },
        },
    });

    var form = $("#formheadcountmapping");
    form.validate();


    function GetHeadCount(Process) {
        debugger;
        if(Process=="Excel")
        {
            var fileInput = document.getElementById('AttachFile');
            var files = fileInput.files;

            // Check if a file is selected
            if (files.length > 0) {
                var fileName = files[0].name;
                $("#validationMessage_").html("");
            } else {
                $("#validationMessage_").html("Choose a file");
                return false;
            }
        }
        else{
            form.valid();
            if (form.valid() == false) {
                $("#FromDate").removeClass("error");
                return false;
            }
            $(".Userloaderbg").css("display", "flex");
        }

        $('#tblHC_MDMapping tr').not(function(){ return !!$(this).has('th').length; }).remove();
        $(".Userloaderbg").css("display", "flex");
        $("#formheadcountmapping").submit();
    }

    $("#btnSubmit").click(function () {
        debugger;
        var rowCount = $('#tblHC_MDMapping tr').length;
        if (rowCount === 0) {
            Swal.fire({
                icon: 'warning',
                text: 'Please add at least one manpower category to the list!',
                allowOutsideClick: false
            });
            return false;
        }

        if (!form.valid()) {
            $("#FromDate").removeClass("error");
            return false;
        }

        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var Date = $("#txtDate").val();
        var HC_MDMappingMasterID_Encrypted = $("#HC_MDMappingMasterID_Encrypted").val();
        // var HeadCountMappingMasterID = $("#HeadCountMappingMasterID").val();

        $(".Userloaderbg").css("display", "flex");

        $.ajax({
            type: "POST",
            url: '@Url.Action("IsHC_MDMappingExists", "ESS_HC_MDMappingByHR")',
            data: JSON.stringify({
                CmpId: CmpId,
                BranchId: BranchId,
                Date: Date,
                HC_MDMappingMasterID_Encrypted: HC_MDMappingMasterID_Encrypted
            }),
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;

                if (Icon1 === "error") {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup();
                            popup.classList.remove('swal2-show');
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake');
                            });
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake');
                            }, 500);
                            return false;
                        }
                    });
                    $(".Userloaderbg").hide();
                    return false;
                }

                var rows = document.getElementById("tblHC_MDMapping").rows;
                var HC_MDMapping = [];

                for (var i = 0; i < rows.length; i++) {
                    var row = rows[i];

                    // skip rows without inputs
                    if (!row.cells[2] || !row.cells[2].querySelector("input")) {
                        continue;
                    }

                    var HeadCount = row.cells[2].querySelector("input").value.trim() || 0;
                    var MonthDays = row.cells[3].querySelector("input").value.trim() || 0;
                    var LineId = row.cells[4].textContent.trim() || 0;
                    var KPISubCategoryId = row.cells[5].textContent.trim() || 0;
                    var HC_MDMappingDetailsID = row.cells[6].textContent.trim() || 0;

                    if (KPISubCategoryId !== "0") {
                        HC_MDMapping.push({
                            LineId: LineId,
                            KPISubCategoryId: KPISubCategoryId,
                            HeadCount: HeadCount,
                            MonthDays: MonthDays,
                            HC_MDMappingDetailsID: HC_MDMappingDetailsID
                        });
                    }
                }

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("SaveUpadte", "ESS_HC_MDMappingByHR")',
                    data: JSON.stringify({
                        HC_MDMapping: HC_MDMapping,
                        CmpId: CmpId,
                        BranchId: BranchId,
                        Date: Date,
                        HC_MDMappingMasterID_Encrypted: HC_MDMappingMasterID_Encrypted
                        //  HeadCountMappingMasterID: HeadCountMappingMasterID
                    }),
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (data) {
                        debugger;
                        var Message1 = data.Message;
                        var Icon1 = data.Icon;

                        if (Icon1 && Message1) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: false
                            }).then(function () {
                                var url = '@Url.Action("ESS_HC_MDMappingByHR", "ESS_HC_MDMappingByHR")';
                                window.location.href = url;
                            });
                        }
                    }
                });
            }
        });
    });


    function downloadExcelFile() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var Date = $("#txtDate").val();
        // var LeaveTypeId = encodeURIComponent($("#ddlLeaveTypeId").val());
        var url = `@Url.Action("DownloadExcelFile", "ESS_HC_MDMappingByHR")?CmpId=${CmpId}&BranchId=${BranchId}&Date=${Date}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }

                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'Line_ManpowerCategoryHC_MDMapping.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }

    function ResetFile()  {
        debugger;
        let allowedExtension = ['application/vnd.ms-excel'];
        let fileInput = document.getElementById('txtAttachFile');

        if (fileInput.files.length > 0) {
            let type = fileInput.files[0].type;

            if (allowedExtension.indexOf(type) === -1) {
                $("#ErrorFile").text('File type should be Excel (.xlsx)');
                fileInput.value = null;
                return false;
            }
        }

        $("#ErrorFile").text('');
    }

    var form = $("#formheadcountmapping");
    form.validate();

    $("#btnfileupload").click(function(){
        debugger;

        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }

        var fileInput = document.getElementById('txtAttachFile');
        if (fileInput.files.length === 0) {
            Swal.fire({
                icon:  "error",
                text: "Please import excel file",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        $('#tblHC_MDMapping').not(function(){return!!$(this).has('th').length;}).remove();
        $("#formheadcountmapping").submit();
    })

    function validateInteger(input) {
        input.value = input.value.replace(/[^0-9]/g, ""); // allow only digits
    }


</script>
