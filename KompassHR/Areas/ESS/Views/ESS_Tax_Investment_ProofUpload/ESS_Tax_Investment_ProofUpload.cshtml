<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


    });//radayFuncation
</script>

<script>
    function FileUpload(Origin) {
        debugger;
        if (Origin=="HRA")
        {
            var fileInput = document.getElementById("txtHRA");

            if (fileInput.files.length === 0) {
                $("#errorHRA").html("select a file to upload.");
                $("#errorHRA").css("display","flex");
                return false;
            }
            else{
                $("#errorHRA").html("");
                $("#errorHRA").css("display","none");
            }

            var AttachFile = fileInput.files[0]; // Get the file object
            var formData = new FormData(); // Create FormData object
            formData.append("AttachFile", AttachFile); // Append the file
            formData.append("Origin", Origin); // Append other data
        }
        else if (Origin=="Mediclaim80D")
        {
            var fileInput = document.getElementById("txtMediclaim80D");

            if (fileInput.files.length === 0) {
                $("#errorMediclaim80D").html("select a file to upload.");
                $("#errorMediclaim80D").css("display","flex");
                return false;
            }
            else{
                $("#errorMediclaim80D").html("");
                $("#errorMediclaim80D").css("display","none");
            }

            var AttachFile = fileInput.files[0]; // Get the file object
            var formData = new FormData(); // Create FormData object
            formData.append("AttachFile", AttachFile); // Append the file
            formData.append("Origin", Origin); // Append other data
        }
