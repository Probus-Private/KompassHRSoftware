<script>

    function DownloadProofUpload(attachmentPath) {
        debugger;
        if (attachmentPath!="File Not Found")
        {
            var url = '@Url.Action("DownloadAttachment", "ESS_Tax_Investment_ProofUpload")';

            $.ajax({
                url: url,
                type: 'POST',
                data: { DownloadAttachment: attachmentPath },
                success: function (response) {
                    debugger;
                    if (response.Success) {
                        var fileName = response.FileName;
                        var fileData = atob(response.FileData);  // Decode the base64 string
                        var byteArray = new Uint8Array(fileData.length);
                        for (var i = 0; i < fileData.length; i++) {
                            byteArray[i] = fileData.charCodeAt(i);
                        }

                        var blob = new Blob([byteArray], { type: response.ContentType });
                        var downloadUrl = window.URL.createObjectURL(blob);
                        var a = document.createElement('a');
                        a.href = downloadUrl;
                        a.download = fileName;
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                        window.URL.revokeObjectURL(downloadUrl);
                    }
                    else {
                        Swal.fire({
                            icon: response.Icon || 'error',
                            text: response.Message || 'An error occurred.',
                            allowOutsideClick: false
                        });
                    }
                },
                error: function (xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        text: 'An unexpected error occurred.',
                        allowOutsideClick: false
                    });
                }
            });
        }
        else{
            var Message1 = "The file has not been uploaded.";
            var Icon1 = "error";
            if (Message1 != null) {
                if (Message1 != null) {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                }
            }
        }

    }
</script>

<script>
    function ResetFile(Origin) {
        var a = "txt" + Origin; // Correct concatenation

        let allowedExtension = [
            'image/jpeg',
            'image/jpg',
            'image/png',
            'application/pdf',
            'application/msword', // .doc
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document', // .docx
            'application/zip', // .zip
            'application/x-zip-compressed', // Some browsers use this for ZIP
            'multipart/x-zip' // Additional MIME type for ZIP
        ];

        let maxSize = 1 * 1024 * 1024; // 1 MB in bytes

        let fileInput = document.getElementById(a);

        if (!fileInput || !fileInput.files.length) {
            Swal.fire({
                icon: "error",
                text: "No file selected.",
            });
            return;
        }

        let file = fileInput.files[0];
        let type = file.type;
        let size = file.size;

        // Check file type
        if (allowedExtension.indexOf(type) === -1) {
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf/docx/doc/zip",
            });
            fileInput.value = null;
            return;
        }

        // Check file size
        if (size > maxSize) {
            Swal.fire({
                icon: "error",
                text: "File size should not exceed 1 MB.",
            });
            fileInput.value = null;
            return;
        }
    }
</script>