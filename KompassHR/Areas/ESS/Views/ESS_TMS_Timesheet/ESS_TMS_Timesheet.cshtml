<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Timesheet
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_Menu", "ESS_TMS_Menu",  new { id = 12,ScreenId=194, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Timesheet - Add </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "ESS_TMS_Timesheet", new { area = "ESS" })" id="SaveTimeSheet" method="post" enctype="multipart/form-data">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNo", type = "text", id = "txtDocNo", autocomplete = "Off", @readonly = "readonly", Value = ViewBag.DocNo != null ? ViewBag.DocNo : "", Style = "background-color: lightgray;" })
                                                @Html.HiddenFor(model => model.TimeSheetID_Encrypted, new { id = "TimeSheetID_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                            </label>
                                            <div class="col-md-8">
                                                @{
                                                    var minDateOffset = TempData["DocMinDate"] != null ? Convert.ToInt32(TempData["DocMinDate"]) : 0;
                                                    var maxDateOffset = TempData["DocMaxDate"] != null ? Convert.ToInt32(TempData["DocMaxDate"]) : 0;

                                                    var minDate = DateTime.Now.AddDays(-minDateOffset).ToString("yyyy-MM-dd");
                                                    var maxDate = DateTime.Now.AddDays(maxDateOffset).ToString("yyyy-MM-dd");
                                                }
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", type = "date", id = "txtDocDate", autocomplete = "Off", Name = "DocDate", min = minDate, max = maxDate })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Client Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ClientID, new SelectList(ViewBag.GetClientName, "Id", "Name"), "--Select--", new { id = "ddlClientID", @class = "form-select", autocomplete = "off", name = "ClientID", onchange = "onClientChange ()"})

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Manager Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ResponsiblePerson, new SelectList(ViewBag.GetResponsiblePersonName, "Id", "Name"), "--Select--", new { id = "ddlResponsiblePerson", @class = "form-select", autocomplete = "off", name = "ResponsiblePerson"})

                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Project Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ProjectID, new SelectList(ViewBag.GetProjectName, "Id", "Name"), "--Select--", new { id = "ddlProjectID", @class = "form-select", autocomplete = "off", name = "ProjectID", onchange = "onProjectChange()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Module Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ModuleId, new SelectList(ViewBag.GetModuleName, "Id", "Name"), "--Select--", new { id = "txtModuleID", name = "ModuleID", @class = "form-select", onchange = "onModuleChange()" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Task Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TaskCategoryId, new SelectList(ViewBag.TaskCategory, "Id", "Name"), "--Select--", new { id = "txtTaskCategoryId", name = "TaskCategoryId", @class = "form-select", onchange = "onTaskCategoryChange()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Task SubCategory
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TaskSubCategoryId, new SelectList(ViewBag.TaskSubCategory, "Id", "Name"), "--Select--", new { id = "txtTaskSubCategoryId", name = "TaskSubCategoryId", @class = "form-select" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Task Title
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.TaskTitle, new { @class = "form-control", type = "text", id = "txtTaskTitle", autocomplete = "Off", Name = "TaskTitle" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px" hidden>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                From Time
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FormTime, new { @class = "form-control", type = "time", id = "timeFormTime", autocomplete = "Off", Name = "FormTime", Value = TempData["FromTime"] != null ? ((DateTime)TempData["FromTime"]).ToString("HH:mm") : null })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                To Time
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToTime, new { @class = "form-control", type = "time", id = "timeToTime", autocomplete = "Off", Name = "ToTime", Value = TempData["ToTime"] != null ? ((DateTime)TempData["ToTime"]).ToString("HH:mm") : null })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row  mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Time <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Time, new { id = "txtTime", @class = "form-control", @placeholder = "HH:mm", maxlength = "5" })
                                                @Html.ValidationMessageFor(model => model.Time, "", new { @class = "help-block", id = "ErrorToTime", style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                   
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Task Status
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TaskStatus, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Complete", Value = "Complete"},
                                                    new SelectListItem { Text = "In Process", Value = "In Process"},
                                                }, "--Select--", new { id = "ddlTaskStatus", @class = "form-select", autocomplete = "off", name = "TaskStatus" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Complete Percentage (%)
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CompletePercentage, new { @class = "form-control", type = "number", id = "txtCompletePercentage", autocomplete = "Off", Name = "CompletePercentage" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Task Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.TaskDescription, new { @class = "summernote", style = "border: 1px solid #000;", id = "txtTaskDescription", @placeholder = "Description....", autocomplete = "Off", contenteditable = "true" })
                                                @*@Html.TextAreaFor(model => model.TaskDescription, new { @class = "form-control", type = "text", id = "txtTaskDescription", autocomplete = "Off", Name = "TaskDescription" })*@
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Attachment
                                            </label>
                                            <div class="col-md-8">
                                                <input class="form-control" type="file" name="AssignFilePath" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="submit" id="btnSubmits" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnTimeSheetGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>


