                        );
                    });
                } else {
                    $moduleDropdown.append("<option>--Select--</option>");
                }

                //Task Category Dropdown
                var $TaskCategoryIdDropdown = $("#txtTaskCategoryId");
                $TaskCategoryIdDropdown.empty().append("<option value=''>--Select--</option>");

                if (data.taskCategory && data.taskCategory.length > 0) {
                    $.each(data.taskCategory, function (i, taskCategory) {debugger
                        $TaskCategoryIdDropdown.append(
                            $("<option>").val(taskCategory.Id).text(taskCategory.Name)
                        );
                    });
                }
            },
            error: function () {
                console.error("Failed to fetch modules.");
                $("#txtModuleID").empty().append("<option>Error loading modules</option>");
            }
        });
    }

