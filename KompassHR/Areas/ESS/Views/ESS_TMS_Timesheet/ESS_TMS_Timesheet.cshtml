<script>
    function DeleteTimeSheet(TimeSheetID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: false

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_TMS_Timesheet")?TimeSheetID_Encrypted=' + TimeSheetID_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>

<script>
    function onProjectChange() {debugger
        var projectId = document.getElementById("ddlProjectID").value;

        $("#txtModuleID").find("option").remove();
        $("#txtTaskCategoryId").find("option").remove();
        $.ajax({
            type: 'GET',
