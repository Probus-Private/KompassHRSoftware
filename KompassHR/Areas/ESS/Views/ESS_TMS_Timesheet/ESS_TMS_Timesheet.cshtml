            data: { ProjectId: projectId },
            success: function (data) {
                var $moduleDropdown = $("#txtModuleID");
                $moduleDropdown.empty();

                // Module Dropdown
                if (data.module && data.module.length > 0 > 0) {
                    $moduleDropdown.append("<option value=''>--Select--</option>");
                    $.each(data.module, function (i, module) {
                        $moduleDropdown.append(
