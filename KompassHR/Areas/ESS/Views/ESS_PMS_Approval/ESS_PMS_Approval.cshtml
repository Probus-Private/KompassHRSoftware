    color: #6B7280;
}

.employee-grid .value {
    font-weight: 600;
    color: #111827;
}

</style>

<script>
    $(document).ready(function () {
        // Initialize tabs
        $('#kraTabs button').on('click', function (e) {
            e.preventDefault();
            $(this).tab('show');
        });

        // Notification handling
        var message = @Html.Raw(Json.Encode(TempData["Message"]));
        var icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (message) {
            showNotification(icon, message);
        }
    });

function Approved(Approver) {
    debugger;
    var DocId = $("#OwnObjectiveCreationId").val();
    var Encrypted = $("#OwnObjectiveCreationId_Encrypted").val();
    var Status = "";
    var Remark = $("#approvalComments").val();

    if (Approver == "Rejected") {
        Remark = $("#approvalComments").val();
        Status = "Rejected";
    }
    else if (Approver == 'Approved') {
        Status = "Approved";
    }
    else {
        Status = "Draft";
    }

    // ✅ ONLY ADD THIS BLOCK
    Swal.fire({
        title: "Are you sure?",
        text: "Do you want to " + Status + " this record?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Yes",
        cancelButtonText: "No"
    }).then((result) => {

        if (result.isConfirmed) {

            // 🔽 YOUR EXISTING AJAX (UNCHANGED)
            $.ajax({
                url: "@Url.Action("ForApprovalCandidate", "ESS_PMS_Approval")",
                method: "get",
                data: { DocId: DocId, Encrypted: Encrypted, Status: Status, Remark: Remark },
                success: function (response) {
                    debugger;
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon == "error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });

                                $("#txtApproveRejectRemark").val("")
                                    .then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("GetList", "ESS_PMS_Approval")';
                                        }
                                    })
                            }
                        }
                    }
                    else {
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon == "success") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    })
                                        .then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("GetList", "ESS_PMS_Approval")';
                                            }
                                        })

                                    $("#myModalFinal").modal('hide');
                                    $("#txtApproveRejectRemark").val("");
                                }
                            }
                        }
                    }
                }
            });

        }
    });
}

