    }

    .metric-body {
        padding: 1.5rem;
    }

    /* Description Container */
    .description-container {
        padding: 1.5rem;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

