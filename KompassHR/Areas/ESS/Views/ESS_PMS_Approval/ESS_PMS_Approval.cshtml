    .approval-section {
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 8px;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
    }

    .approval-notes textarea {
        min-height: 100px;
    }

    .approval-actions {
        display: flex;
        flex-wrap: wrap;
