@model KompassHR.Areas.ESS.Models.ESS_PMS.PMS_OwnObjectiveCreation


@{
    ViewBag.Title = "ESS_PMS_TeamGoalView";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                KRA Approval Dashboard
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "ESS_PMS_Approval", new { id = 11, ScreenId=626, area = "ESS" })" aria-label="Go Back" title="Back">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    @foreach (var d in ViewBag.OwnObjectiveInfo)
    {
        <div class="kra-approval-container">
            <!-- Status Ribbon -->
            <div class="status-ribbon">
                <span class="badge bg-light text-dark">
                    <i class="fas fa-clock me-1"></i> Pending Approval
                </span>
            </div>

            <!-- Main Card -->
            <div class="card kra-card">
                <div class="card-body">
                    <form method="post" action="@Url.Action("SaveApproval", "ESS_PMS_OwnGoalCreation", new { area = "ESS" })" id="OwnObjectiveApproval">
                        <!-- Employee & KRA Summary -->
                        <div class="summary-section">
                            <div class="employee-card">
                                <div class="employee-header">
                                    <div class="avatar">
                                        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" />
                                    </div>
                                    <div>
                                        <h4 class="emp-name">@d.EmployeeName</h4>
                                        <div class="emp-sub">@d.DesignationName</div>
                                        @Html.Hidden("OwnObjectiveCreationId","", new { id = "OwnObjectiveCreationId", Value=@d.OwnObjectiveCreationId })
                                        @Html.Hidden("OwnObjectiveCreationId_Encrypted", "", new { id = "OwnObjectiveCreationId_Encrypted", Value = @d.OwnObjectiveCreationId_Encrypted })


                                        @Html.HiddenFor(model => model.OwnObjectiveCreationId_Encrypted, new { id = "txtTeamObjectiveCreationId_Encrypted", @class = "form-control", placeholder = "Enter Key Result Area" })


                                    </div>
                                </div>

                                <div class="employee-grid">
                                    <div>
                                        <span class="label">Department</span>
                                        <span class="value">@d.DepartmentName</span>
                                    </div>
                                    <div>
                                        <span class="label">Grade</span>
                                        <span class="value">@d.GradeName</span>
                                    </div>
                                    <div>
                                        <span class="label">PMS Year</span>
                                        <span class="value">@d.PMS_Year</span>
                                    </div>
                                </div>
                            </div>

                            <div class="kra-overview">
                                <div class="kra-metric">
                                    <div class="metric-label">Objective</div>
                                    <div class="metric-value">@d.OwnObjectiveTitle</div>
                                </div>
                                <div class="kra-metric">
                                    <div class="metric-label">Weightage</div>
                                    <div class="metric-value">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-primary" role="progressbar" style="width: @d.Weightage%;" aria-valuenow="@d.Weightage" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <small>@d.Weightage% of total</small>
                                    </div>
                                </div>
                                <div class="kra-metric">
                                    <div class="metric-label">Timeline</div>
                                    <div class="metric-value">
                                        <i class="fas fa-calendar-day me-1"></i> @d.Timeline
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- KRA Details Tabs -->
                        <div class="kra-details-tabs">
                            <ul class="nav nav-tabs" id="kraTabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab">
                                        <i class="fas fa-info-circle me-1"></i> Key Details
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="alignment-tab" data-bs-toggle="tab" data-bs-target="#alignment" type="button" role="tab">
                                        <i class="fas fa-project-diagram me-1"></i> Alignment
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="metrics-tab" data-bs-toggle="tab" data-bs-target="#metrics" type="button" role="tab">
                                        <i class="fas fa-chart-line me-1"></i> Performance Metrics
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button" role="tab">
                                        <i class="fas fa-file-alt me-1"></i> Full Description
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content" id="kraTabContent">
                                <!-- Key Details Tab -->
                                <div class="tab-pane fade show active" id="details" role="tabpanel">
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <div class="detail-icon">
                                                <i class="fas fa-bullseye"></i>
                                            </div>
                                            <div>
                                                <div class="detail-label">KRA Title</div>
                                                <div class="detail-value">@d.OwnKRA</div>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="detail-icon">
                                                <i class="fas fa-ruler"></i>
                                            </div>
                                            <div>
                                                <div class="detail-label">UOM</div>
                                                <div class="detail-value">@d.UOM</div>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="detail-icon">
                                                <i class="fas fa-flag-checkered"></i>
                                            </div>
                                            <div>
                                                <div class="detail-label">Target Type</div>
                                                <div class="detail-value">@d.TargetType</div>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="detail-icon">
                                                <i class="fas fa-flag-checkered"></i>
                                            </div>
                                            <div>
                                                <div class="detail-label">Target</div>
                                                <div class="detail-value">@d.Target</div>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="detail-icon">
                                                <i class="fas fa-eye"></i>
                                            </div>
                                            <div>
                                                <div class="detail-label">Visibility</div>
                                                <div class="detail-value">@d.Visibility</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Alignment Tab -->
                                <div class="tab-pane fade" id="alignment" role="tabpanel">
                                    @{
                                        var isAlign = d.IsAlign as bool?;
                                    }
                                    <div class="alignment-card @(isAlign == true ? "aligned" : "not-aligned")">
                                        <div class="alignment-icon">
                                            <i class="fas @(isAlign == true ? "fa-link text-success" : "fa-unlink text-warning")"></i>
                                        </div>
                                        <div class="alignment-details">
                                            <h5>@(isAlign == true ? "Aligned With Organizational Goals" : "Independent Objective")</h5>
                                            @if (isAlign == true)
                                            {
                                                <p>This KRA is aligned with: <strong>@d.AlignWithType</strong></p>
                                                <div class="alignment-benefits">
                                                    <span><i class="fas fa-check-circle text-success me-1"></i>Objective :- @d.AlignObjectiveTitle</span>
                                                    <span><i class="fas fa-check-circle text-success me-1"></i>KRA :- @d.AlignKRA</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <p>This is an independent objective not directly aligned with organizational goals.</p>
                                                <div class="alignment-notes">
                                                    <i class="fas fa-info-circle text-info me-1"></i>
                                                    <small>Consider discussing alignment opportunities during review</small>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Performance Metrics Tab -->
                                <div class="tab-pane fade" id="metrics" role="tabpanel">
                                    <div class="metrics-container">
                                        <div class="metric-card">
                                            <div class="metric-header">
                                                <i class="fas fa-chart-bar"></i>
                                                <h6>KPI Measurement</h6>
                                            </div>
                                            <div class="metric-body">
                                                @d.KPICategory - @d.KPIName
                                            </div>
                                        </div>
                                        <div class="metric-card">
                                            <div class="metric-header">
                                                <i class="fas fa-check-double"></i>
                                                <h6>Smart Criteria</h6>
                                            </div>
                                            <div class="metric-body">
                                                @d.SmartPrinciple
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Description Tab -->
                                <div class="tab-pane fade" id="description" role="tabpanel">
                                    <div class="description-container">
                                        @Html.Raw(d.Description ?? "<div class='text-muted'>No detailed description provided</div>")
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Approval Section -->
                        <div class="approval-section">
                            <h5 class="section-title">
                                <i class="fas fa-clipboard-check me-2"></i>Approval Decision
                            </h5>

                            <div class="approval-notes">
                                <label for="approvalComments" class="form-label">Your Evaluation Notes</label>
                                <textarea class="form-control" id="approvalComments" rows="3" placeholder="Provide constructive feedback or approval notes..."></textarea>
                                <div class="form-text">These notes will be shared with the employee</div>
                            </div>

                            <div class="approval-actions justify-content-end ">
                                @if (Session["IsManager"]?.ToString() == "True")
                                {
                                    <span class="float-end hidden-print">
                                        <a href="#modal-dialogForApproval1" onclick="Approved('Approved')" type="button" class="btn btn-success btn-sm" id="btnmodal-dialog" value="Approved"><i class="fa-solid fa-check-double"></i>Approve</a>
                                        <button href="#modal-dialogForHoldReject1" onclick="Approved('Rejected')" type="button" class="btn btn-danger btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>
                                    </span>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
                                        }
    <!-- Rejection Modal -->
    <div class="modal fade" id="rejectionModal" tabindex="-1" aria-labelledby="rejectionModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title" id="rejectionModalLabel">
                        <i class="fas fa-exclamation-triangle text-danger me-2"></i>Request Changes
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label">Reason for requesting changes</label>
                        <textarea class="form-control" id="rejectionReason" rows="4" placeholder="Be specific about what needs to be modified..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="suggestedChanges" class="form-label">Suggested improvements</label>
                        <textarea class="form-control" id="suggestedChanges" rows="3" placeholder="Provide constructive suggestions (optional)..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="submitRejection()">
                        <i class="fas fa-paper-plane me-1"></i> Submit Feedback
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    /* ==== Soft Modern Color Enhancements (Add Only) ==== */

/* Header Title */
#content h1 {
    color: #3B82F6;
    font-weight: 700;
}

/* Status Ribbon */
.status-ribbon .badge {
    background: linear-gradient(90deg, #3B82F6, #6366F1) !important;
    color: #fff !important;
    box-shadow: 0 3px 8px rgba(59, 130, 246, 0.25);
}

/* Metric Cards */
.kra-metric {
    border-left: 4px solid #3B82F6 !important;
}

/* Progress Bar */
.progress-bar {
    background: linear-gradient(90deg, #3B82F6, #6366F1) !important;
}

/* Tabs active */
.nav-tabs .nav-link.active {
    color: #3B82F6 !important;
    border-bottom: 2px solid #3B82F6 !important;
    font-weight: 600;
}

/* Detail icons soft color */
.detail-icon {
    background: #DBEAFE !important;
    color: #3B82F6 !important;
}

/* Alignment section colors */
.alignment-card.aligned {
    border-left: 5px solid #10B981 !important;
    background: #ECFDF5 !important;
}

.alignment-card.not-aligned {
    border-left: 5px solid #F59E0B !important;
    background: #FFF7ED !important;
}

/* KPIs */
.metric-header {
    background: #F1F5FF !important;
    color: #3B82F6 !important;
}

/* Approval title */
.section-title {
    color: #3B82F6 !important;
}

/* Buttons */
.btn-success {
    background: #10B981 !important;
    border-color: #10B981 !important;
}

.btn-danger {
    background: #EF4444 !important;
    border-color: #EF4444 !important;
}

/* Hover effects (very soft) */
.kra-metric:hover,
.detail-item:hover,
.metric-card:hover {
    background: #F9FAFF !important;
    transition: .2s;
}

    body {
        background-color: #f5f7fb;
        color: #495057;
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    }

    .page-header {
        padding: 1rem 0;
        border-bottom: 1px solid #e9ecef;
    }

    .page-title {
        font-weight: 600;
        color: var(--dark-color);
        margin-bottom: 0.5rem;
    }

    .text-gradient {
        background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .breadcrumb {
        background: transparent;
        padding: 0;
        font-size: 0.875rem;
    }

    /* KRA Card Styles */
    .kra-approval-container {
        position: relative;
        margin-bottom: 2rem;
    }

    .status-ribbon {
        position: absolute;
        top: -10px;
        right: 20px;
        z-index: 1;
    }

    .kra-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    /* Summary Section */
    .summary-section {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        margin-bottom: 2rem;
