        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .metric-header {
        padding: 1rem;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        border-bottom: 1px solid #e9ecef;
    }

    .metric-header h6 {
        margin-bottom: 0;
        margin-left: 0.75rem;
