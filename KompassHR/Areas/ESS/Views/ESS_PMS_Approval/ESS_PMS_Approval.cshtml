            width: 100%;
        }
    }

    /* ================= EMPLOYEE INFO CARD ================= */

.employee-card {
    background: #ffffff;
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    border-left: 5px solid #3B82F6;
    max-width: 420px;
}

.employee-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
}

.employee-header .avatar {
