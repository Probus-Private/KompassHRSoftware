
@{
    ViewBag.Title = "CandidateDataGetByResourceId";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>



<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>



<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Candidate Data
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">  Candidate Data - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of candidates approved by the user. From here, the candidates move to the interview phase.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="/ESS/ESS_Recruitment_RequestPool/ESS_Recruitment_RequestPool">
                                <button type="button" class="btn btn-danger btn-sm  mb-10px">
                                    <i class="fa-solid fa-share fa-flip-horizontal"></i> &nbsp; Back
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage2" id="tbl"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="trheading">
                                                <th class="text-nowrap">Update </th>
                                                <th class="text-nowrap">Delete</th>
                                                <th class="text-nowrap text-center">Salutation</th>
                                                <th class="text-nowrap text-center">Candidate Name </th>
                                                <th class="text-nowrap text-center">Mobile No </th>
                                                <th class="text-nowrap text-center">Alternate Mobile No</th>
                                                <th class="text-nowrap text-center">EmailId </th>
                                                <th class="text-nowrap text-center">DOB </th>
                                                <th class="text-nowrap text-center">Age</th>
                                                <th class="text-nowrap text-center">Gender</th>
                                                <th class="text-nowrap text-center">Current City </th>
                                                <th class="text-nowrap text-center"> Marital Status</th>
                                                <th class="text-nowrap text-center">Qualification Remark</th>
                                                <th class="text-nowrap text-center">Nationality</th>
                                                <th class="text-nowrap text-center"> Currently Working</th>
                                                <th class="text-nowrap text-center">Last Company Name </th>
                                                <th class="text-nowrap text-center">Total Experience</th>
                                                <th class="text-nowrap text-center">Relevant Experience</th>
                                                <th class="text-nowrap text-center">Last Designation</th>
                                                <th class="text-nowrap text-center">Sutable For Designation</th>
                                                <th class="text-nowrap text-center"> Serving Notice Period</th>
                                                <th class="text-nowrap text-center">Notice Period Days </th>
                                                <th class="text-nowrap text-center">Technical Details</th>
                                                <th class="text-nowrap text-center">Relevant Skill</th>
                                                <th class="text-nowrap text-center">Communication Skill</th>
                                                <th class="text-nowrap text-center">CTC</th>
                                                <th class="text-nowrap text-center"> Expected CTC</th>
                                                <th class="text-nowrap text-center">Holding Any Offer </th>
                                                <th class="text-nowrap text-center">Offer Remark</th>
                                                <th class="text-nowrap text-center">Expat Local</th>
                                                <th class="text-nowrap text-center">Ready To Traval</th>
                                                <th class="text-nowrap text-center">Leag lBoand</th>
                                                <th class="text-nowrap text-center"> Bond Month</th>
                                                <th class="text-nowrap text-center">Job Description</th>
                                                <th class="text-nowrap text-center">Resume Path </th>
                                                <th class="text-nowrap text-center">Origin</th>
                                                <th class="text-nowrap text-center">ResumeStatus</th>
                                                <th class="text-nowrap text-center">ResumeSource</th>
                                                <th class="text-nowrap text-center">Hr Selection</th>
                                                <th class="text-nowrap text-center">Hr Ranking</th>
                                                <th class="text-nowrap text-center">HRComment</th>
                                                <th class="text-nowrap text-center">Candidate Comment</th>

                                            </tr>
                                        </thead>
                                        <tbody id="tblShortListCandidate">
                                            @foreach (var d in ViewBag.ResourcIdWise)
                                            {
                                                <tr>

                                                    <td class="text-center">
                                                        <a id="btnDelete" onclick="UpdateCandidate('@d.Resume_ResourceId','@d.ResumeId_Encrypted')" style="cursor:pointer;">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-center">
                                                        <a id="btnDelete" onclick="DeleteCandidate('@d.ResumeId_Encrypted')" style="cursor:pointer;">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-nowrap">@d.Salutation</td>
                                                    <td class="text-nowrap">@d.CandidateName</td>
                                                    <td class="text-nowrap">@d.MobileNo</td>
                                                    <td class="text-nowrap">@d.AlternateMobileNo</td>
                                                    <td class="text-nowrap">@d.EmailId</td>
                                                    <td class="text-nowrap">@d.DOB</td>
                                                    <td class="text-nowrap">@d.Age</td>
                                                    <td class="text-nowrap">@d.Gender</td>
                                                    <td class="text-nowrap">@d.CurrentCity</td>
                                                    <td class="text-nowrap">@d.MaritalStatus</td>
                                                    <td class="text-nowrap">@d.QualificationRemark</td>
                                                    <td class="text-nowrap">@d.Nationality</td>
                                                    <td class="text-nowrap">@d.CurrentlyWorking</td>
                                                    <td class="text-nowrap">@d.LastCompanyName</td>
                                                    <td class="text-nowrap">@d.TotalExperience</td>
                                                    <td class="text-nowrap">@d.RelevantExperience</td>
                                                    <td class="text-nowrap">@d.LastDesignation</td>
                                                    <td class="text-nowrap">@d.SutableForDesignation</td>
                                                    <td class="text-nowrap">@d.ServingNoticePeriod</td>
                                                    <td class="text-nowrap">@d.NoticePeriodDays</td>
                                                    <td class="text-nowrap">@d.TechnicalDetails</td>
                                                    <td class="text-nowrap">@d.RelevantSkill</td>
                                                    <td class="text-nowrap">@d.CommunicationSkill</td>
                                                    <td class="text-nowrap">@d.CTC</td>
                                                    <td class="text-nowrap">@d.ExpectedCTC</td>
                                                    <td class="text-nowrap">@d.HoldingAnyOffer</td>
                                                    <td class="text-nowrap">@d.OfferRemark</td>
                                                    <td class="text-nowrap">@d.ExpatLocal</td>
                                                    <td class="text-nowrap">@d.ReadyToTraval</td>
                                                    <td class="text-nowrap">@d.LeaglBoand</td>
                                                    <td class="text-nowrap">@d.BondMonth</td>
                                                    <td class="text-nowrap">@d.JobDescription</td>

                                                    <td class="text-nowrap">
                                                        @if (d.ResumePath == "File Not Found")
                                                        {
                                                            <span>@d.ResumePath</span>
                                                        }
                                                        else
                                                        {
                                                            <a type="button" class="btn btn-success ListBtn btnpress" href="~/ESS/ESS_Recruitment_RequestPool/DownloadFile?ResourceRequest=@d.ResumePath" download>
                                                                <i class="fa-solid fa-download"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap">@d.Origin</td>
                                                    <td class="text-nowrap">@d.ResumeStatus</td>
                                                    <td class="text-nowrap">@d.ResumeSource</td>
                                                    <td class="text-nowrap">@d.HrSelection</td>
                                                    <td class="text-nowrap">@d.HrRanking</td>
                                                    <td class="text-nowrap">@d.HRComment</td>
                                                    <td class="text-nowrap">@d.CandidateComment</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }



    });

</script>
<script>


    function UpdateCandidate(Resume_ResourceId,ResumeId_Encrypted) {
        var url = '@Url.Action("ESS_Recruitment_CandidateData", "ESS_Recruitment_CandidateData")?ResumeId_Encrypted=' + ResumeId_Encrypted+'&Resume_ResourceId='+Resume_ResourceId;
        window.location.href = url;
    }

    function DeleteCandidate(ResumeId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Recruitment_CandidateData")?ResumeId_Encrypted=' + ResumeId_Encrypted;
                //window.location.href = url;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


</script>


