                                                            <a type="button" class="btn btn-success ListBtn btnpress" href="~/ESS/ESS_Recruitment_CandidateData/DownloadFile?FilePath=@d.FilePath" download>
                                                                <i class="fa-solid fa-download"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap">@d.ResumeStatus</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <br>
                        <div class="row">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
