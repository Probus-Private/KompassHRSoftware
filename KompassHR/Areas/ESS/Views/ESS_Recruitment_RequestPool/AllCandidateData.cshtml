<script>

    function UpdateFuncation(ResumeId_Encrypted, Resume_ResourceId) {
    debugger;
    var url = '@Url.Action("ESS_Recruitment_CandidateData", "ESS_Recruitment_CandidateData")'
            + '?ResumeId_Encrypted=' + encodeURIComponent(ResumeId_Encrypted)
            + '&Resume_ResourceId=' + encodeURIComponent(Resume_ResourceId);

    window.location.href = url;
}


    function DeleteFunction(ResumeId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Recruitment_CandidateData")?ResumeId_Encrypted=' + ResumeId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


</script>
