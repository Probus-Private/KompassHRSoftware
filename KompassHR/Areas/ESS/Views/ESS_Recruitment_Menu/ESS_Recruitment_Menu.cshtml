
@{
    ViewBag.Title = "ESS_Recruitment_Menu";
    Layout = "~/Views/Shared/_LayoutPageSmartHR.cshtml";
}

<style>
    .card {
        background-color: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        text-align: center;
        transition: transform 0.2s;
        cursor: pointer;
        text-decoration: none !important;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }

        .card h3 {
            margin: 0;
            padding: 12px;
            font-weight: 500;
            color: #333;
            font-size: 14px;
        }

    .alert-yellow {
        background-color: #feffdb !important;
        border: 1px solid #feffdb !important;
        color: #000;
    }
</style>

<script>
    $(document).ready(function () {

        $('.nav-link').removeClass('active');
        $('.tab-pane').removeClass('show active');

        $('#Menu-tab').addClass('active');
        $('#Menu-tab-pane').addClass('show active');

        $('#RecruitmentMenulink').addClass('active');
    });
</script>

<div class="content">

    <!-- Breadcrumb -->
    <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb ">
        <div class="my-auto mb-2">
            <h2 class="mb-1">Recruitment</h2>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })"><i class="ti ti-smart-home"></i></a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("ESS_Dashboard", "ESS_Dashboard", new { area = "Dashboard" })" class="fs-14"> All Dashboard </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Recruitment</li>
                </ol>
            </nav>
        </div>
    </div>
    <!-- /Breadcrumb -->

    <div class="alert alert-yellow rounded-0 d-flex align-items-center mb-3 text-black">
        <p> <b>Recruitment</b>  model allows authorized users to request resources, reserve candidate lists, schedule interviews with managers, and seek closer. From resource requests to closing positions, the recruitment module provides end-to-end functionality.</p>
    </div>

    <div class="row">

        @foreach (var item in ViewBag.GetUserMenuList)
            {<div class="col-xl-3 col-lg-4 col-md-4">
            <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" class="card">
                <img src="~/assets/MenuImages/@item.Icon" alt="@item.ScreenDisplayMenuName" />
                <h3 class="text-center">@item.ScreenDisplayMenuName</h3>
            </a>
        </div>
        }
    </div>
</div>