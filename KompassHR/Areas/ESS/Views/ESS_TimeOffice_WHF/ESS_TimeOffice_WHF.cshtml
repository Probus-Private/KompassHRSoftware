<script type="text/javascript">
    document.getElementById("txtFromDate").addEventListener("blur", function () {
        var dateValue = this.value;
        if (dateValue.includes("-")) {
            var parts = dateValue.split("-"); 
            dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
        }
        var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
        if (!regex.test(dateValue)) {
            $("#ErrortxtFromDate").html("Please enter valid date in DD-MM-YYYY format");
            this.value = "";
            this.focus();
            return;
        } else {
            $("#ErrortxtFromDate").html("");
        }
    });

    document.getElementById("txtToDate").addEventListener("blur", function () {
        var dateValue = this.value;
        if (dateValue.includes("-")) {
            var parts = dateValue.split("-"); 
            dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
        }
        var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
        if (!regex.test(dateValue)) {
            $("#ErrortxtToDate").html("Please enter valid date in DD-MM-YYYY format");
            this.value = "";
            this.focus();
            return;
        } else {
            $("#ErrortxtToDate").html("");
        }
    });

    $(document).ready(function () {
        debugger;
        var GetMinMaxDate = @Html.Raw(Json.Encode(TempData["GetMinMaxDate"]));
        var MinDate = GetMinMaxDate[0].Value;
        var MaxDate = GetMinMaxDate[1].Value;
        var currentDate = new Date();
        //For MinDate Set
        currentDate.setDate(currentDate.getDate() - MinDate); //2 Meanse Currect daye plus 2 days enabled only
        var SetMinDays = currentDate.toISOString().split('T')[0];
        document.getElementById("txtFromDate").setAttribute("min", SetMinDays);
        document.getElementById("txtToDate").setAttribute("min", SetMinDays);
        //For Max Date Set
        var currentDate1 = new Date();
        currentDate1.setDate(currentDate1.getDate() + MaxDate);
        var SetMaxDays = currentDate1.toISOString().split('T')[0];
        document.getElementById("txtFromDate").setAttribute("max", SetMaxDays);
        document.getElementById("txtToDate").setAttribute("max", SetMaxDays);


        $("#WFHIdEmployeeId").select2();
        $("#btnGetList").click(function () {
            var url = '@Url.Action("ESS_TimeOffice_WHF_ApprovalandrejectList", "ESS_TimeOffice_WHF")';
            window.location.href = url;
        })

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
