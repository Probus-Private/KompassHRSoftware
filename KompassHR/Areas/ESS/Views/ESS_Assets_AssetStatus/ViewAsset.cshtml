@model KompassHR.Areas.Module.Models.Module_Employee.Mas_Employee_Asset

@{
    ViewBag.Title = "ViewAsset";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>


@*<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-bs4.min.js"></script>*@

<style>
    .note-toolbar {
        display: none;
    }

    .note-editable {
        height: 100% !important;
        [contenteditable="false"];
    }

    .table, tr, td, th, .invoice, .smallFrom {
        border: none;
        font-size: 13px;
        font-family: Arial;
    }

    p {
        font-size: 15px;
    }
</style>

<style>
    .noborder {
    border: none !important;
}
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Asset status
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Assets_AssetStatus", "ESS_Assets_AssetStatus", new {id = 47, ScreenId=839, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="alert alert-warning alert-dismissible rounded-0 mb-0 fade show">
        Asset Status
        @*Recruitment for the "@ViewBag.AssetList1.DesignationName" has been initiated by your team member and currently pending approval from you.*@
    </div>

    <div class="invoice">
        <!-- BEGIN invoice-company -->
        <div class="invoice-company">
            @*@Html.HiddenFor(model => model.ResourceId_Encrypted, new { id = "txtResourceId_Encrypted" })*@
            @Html.HiddenFor(model => model.EmployeeId, new { id = "txtEmployeeId" })
            @*<span class="float-end hidden-print">
                <button type="button" class="btn  btn-primary btn-sm" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>
                <a href="#modal-dialogForApproval1" onclick="OpenModule('Approved')" type="button" class="btn btn-success btn-sm" id="btnmodal-dialog" value="Approved"><i class="fa-solid fa-check-double"></i>Approve</a>
                <button href="#modal-dialogForHoldReject1" onclick="OpenModule('Rejected')" type="button" class="btn btn-danger btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>
            </span>*@
            @*Take Action -*@
        </div>
        <!-- END invoice-company -->

        @*<form class="form">*@
        <form role="form" action='@Url.Action("SaveUpdate", "ESS_Assets_AssetStatus", new { area = "ESS" })' id="AssetStatusSaveUpdate" method="post">

            <div class="card">
                <div id="card">
                    <div class="invoice-header">

                        <div class="invoice-from">
                            @*<b><small class="smallFrom">From,</small></b>*@
                            <address class="mt-5px mb-5px">
                                <i class="fa-solid fa-user"> </i>&nbsp;&nbsp;   <strong class="text-dark"><b>@ViewBag.AssetList1.EmployeeName</b></strong><br />
                                <i class="fa-solid fa-building"> </i>&nbsp;&nbsp;&nbsp;&nbsp;<b>Department&nbsp;:</b>&nbsp;@ViewBag.AssetList1.DepartmentName <br />
                                <i class="fa-regular fa-handshake"> </i>&nbsp;&nbsp;<b>Designation&nbsp;:</b>&nbsp;@ViewBag.AssetList1.DesignationName <b></b><br />
                                <i class="fa-solid fa-phone-volume"> </i>&nbsp;&nbsp; <b>Phone&nbsp;:</b>&nbsp;+91-@ViewBag.AssetList1.companymobileno  <b></b><br />
                                <i class="fa-solid fa-envelope"> </i>&nbsp;&nbsp; <b>Email &nbsp;:</b>   @ViewBag.AssetList1.CompanyMailID
                            </address>
                        </div>

                        <div class="invoice-date">
                            <small> </small><br />
                            <div class="date text-dark mt-5px"></div><br />
                            <div class="date text-dark mt-5px"></div>
                            <div class="invoice-detail">
                                @*<i class="fa-solid fa-calendar-days"></i> <b>Opening Date&nbsp;: </b>&nbsp; @ViewBag.ResourceApprovalList.DocDate<br />*@
                                @*<i class="fa-solid fa-calendar-days"></i>  <b> Closing Date&nbsp;:</b> &nbsp; @ViewBag.ResourceApprovalList.ClosingDate*@
                            </div>
                        </div>

                    </div>

                    <!-- END invoice-header -->
                    <!-- BEGIN invoice-content -->
                    <div class="invoice-content">
                        <!-- BEGIN table-responsive -->

                        <div class="table-responsive row">

                            <div class="col-md-6">
                                <table class="table">
                                    <tbody>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Company Name</span><br />
                                            </th>
                                            <td>
                                                <input type="text" class="form-control noborder"  value="@ViewBag.AssetList1.CompanyName" readonly="readonly" />
                                                @*<input type="hidden" class="form-control noborder" value="@ViewBag.AssetList1.AssetId"/>
                                                <input type="hidden" class="form-control noborder" value="@ViewBag.AssetList1.AssetEmployeeId" />
                                                <input type="hidden" class="form-control noborder" value="@ViewBag.AssetList1.RequiredAlert" />
                                                <input type="hidden" class="form-control noborder" value="@ViewBag.AssetList1.AssetEmployeeId" />*@

                                                <input type="hidden" name="AssetId" value="@ViewBag.AssetList1.AssetId" />
                                                <input type="hidden" name="AssetEmployeeId" value="@ViewBag.AssetList1.AssetEmployeeId" />
                                                <input type="hidden" name="RequiredAlert" value="@ViewBag.AssetList1.RequiredAlert" />
                                                <input type="hidden" name="AssetId_Encrypted" id="AssetId_Encrypted" />
                                                <input type="hidden" name="AssetEmployeeId" value="@ViewBag.AssetList1.AssetEmployeeId" />


                                            </td>
                                            @*<td>@ViewBag.AssetList1.CompanyName</td>*@
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Department</span><br />
                                            </th>
                                            <td>
                                                <input type="text" class="form-control noborder"  value="@ViewBag.AssetList1.DepartmentName" readonly="readonly" />
                                            </td>
                                            @*<td>@ViewBag.AssetList1.DepartmentName</td>*@
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Asset Name</span><br />
                                            </th>
                                            @*<td>@ViewBag.AssetList1.AssetName</td>*@
                                            <td>
                                                <input type="text" class="form-control noborder"  value="@ViewBag.AssetList1.AssetName1" readonly="readonly" />

                                                <input type="hidden"  class="form-control noborder"  name="AssetName" value="@ViewBag.AssetList1.AssetName" readonly="readonly"/>
                                            </td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Asset Remark</span><br />
                                            </th>
                                            @*<td>@ViewBag.AssetList1.AssetRemark</td>*@
                                            <td>
                                                <input type="text" class="form-control noborder" name="Remark" value="@ViewBag.AssetList1.Remark" readonly="readonly" />
                                            </td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Alert Remark</span><br />
                                            </th>
                                            <td>
                                                <input type="text" class="form-control noborder"  name="AssetRemark" value="@ViewBag.AssetList1.AssetRemark" readonly="readonly"/>
                                            </td>
                                            @*<input type="text"  name="AssetAlertRemark" value="@ViewBag.AssetList1.AssetAlertRemark" readonly="readonly"/>*@
                                            @*<td>@ViewBag.AssetList1.AssetAlertRemark</td>*@
                                        </tr>

                                      
                                        <tr>
                                            <th>
                                                <span class="text-dark">Return Asset</span><br />
                                            </th>
                                            <td>
                                                @*<input type="hidden" id="hdnReturnStatus" name="ReturnStatus" />
                                                   <input type="checkbox" id="txtReturnAsset" class="form-check-input" name="ReturnStatus"/>*@
                                                <input type="hidden" id="hdnReturnStatus" name="ReturnStatus" />
                                                <input type="checkbox" id="txtReturnAsset" class="form-check-input" name="ReturnStatus" onclick="toggleReturnFields()"
                                                       @(ViewBag.ReturnStatus ? "checked" : "") />
                                             </td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Return Remark</span><br />
                                            </th>
                                            <td>
                                                <input type="text" id="txtReturnRemark" class="form-control" name="ReturnRemark" value="@ViewBag.AssetList1.ReturnRemark"/>
                                                <input type="hidden" id="AssetId_Encrypted" name="AssetId_Encrypted" />
                                            </td>
                                        </tr>
                                        @*<tr id="return-remark-row" style="display:none;">
                                            <th><span class="text-dark">Return Remark</span><br /></th>
                                            <td>
                                                <input type="text" id="txtReturnRemark" class="form-control" name="ReturnRemark" />
                                            </td>
                                        </tr>*@
                                    </tbody>
                                </table>
                            </div>

                            <div class="col-md-6">
                                <table class="table ">
                                    <thead>
                                    </thead>

                                    <tbody>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Business Unit</span><br />
                                            </th>
                                            <td>
                                                <input type="text" class="form-control noborder" value="@ViewBag.AssetList1.BranchName" readonly="readonly" />
                                            </td>
                                            @*<td>@ViewBag.AssetList1.BranchName</td>*@
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Designation Name</span><br />
                                            </th>
                                            <td>
                                                <input type="text" class="form-control noborder"  value="@ViewBag.AssetList1.DesignationName" readonly="readonly" />
                                            </td>
                                            @*<td>@ViewBag.AssetList1.DesignationName</td>*@
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Assign Date </span><br />
                                            </th>
                                            <td>
                                                <input type="text" class="form-control noborder" name="Date" value="@ViewBag.AssetList1.Date" readonly="readonly"/>
                                            </td>
                                            @*<td>@ViewBag.AssetList1.AssetAllocationDate</td>*@
                                            @*<input type="text" class="form-control" name="AssetAllocationDate" value="@ViewBag.AssetList1.AssetAllocationDate" readonly="readonly"/>*@

                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Alert</span><br />
                                            </th>
                                            @*<td>@ViewBag.AssetList1.RequiredAlertText</td>*@
                                            <td>
                                                <input type="text" class="form-control noborder"  name="RequiredAlertText" value="@ViewBag.AssetList1.RequiredAlertText" readonly="readonly" />
                                            </td>
                                        </tr>


                                        <tr>
                                            <th>
                                                <span class="text-dark">Required Alert Date </span><br />
                                            </th>
                                            @*<td>@ViewBag.AssetList1.RequiredAlertDate</td>*@
                                            <td>
                                                <input type="text" class="form-control noborder" name="RequiredAlertDate" value="@ViewBag.AssetList1.RequiredAlertDate" readonly="readonly" />
                                            </td>
                                            </tr>


                                        <tr>
                                            <th>
                                                <span class="text-dark">Return Date</span><br />
                                            </th>
                                            <td>
                                                <input type="date" id="txtReturnDate" class="form-control" name="ReturnDate" value="@ViewBag.AssetList1.ReturnDate"/>
                                            </td>
                                        </tr>
                                        @*<tr id="return-date-row" style="display:none;">
                                            <th><span class="text-dark">Return Date</span><br /></th>
                                            <td>
                                                <input type="date" id="txtReturnDate" class="form-control" name="ReturnDate" />
                                            </td>
                                            </tr>*@
                                           </tbody>

                                </table>
                            </div>

                        </div>

                        <!-- END table-responsive -->

                        <div class="row mb-20px">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                @*<button class="btn btn-primary btn-sm" type="button" id="btnSubmit">
                                                    <a onclick="SaveStatus(d.AssetId)" id="btnUpdate" style="cursor:pointer;">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                              </button>*@
                                                <button class="btn btn-primary btn-sm" type="button"
                                                        onclick="SubmitForm('@ViewBag.AssetList1.AssetId_Encrypted')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>
            </div>
        </form>
    </div>
</div>



<script>
    $(document).ready(function () {
        debugger
        var ReturnDate = @Html.Raw(Json.Encode(TempData["ReturnDate"]));
        $("#txtReturnDate").val(ReturnDate);
    });
</script>

<script>
        function toggleReturnFields() {
            var isChecked = document.getElementById("txtReturnAsset").checked;
            if (isChecked) {
                document.getElementById("return-remark-row").style.display = "table-row";
                document.getElementById("return-date-row").style.display = "table-row";
            } else {
                document.getElementById("return-remark-row").style.display = "table-row";
                document.getElementById("return-date-row").style.display = "table-row";
                document.getElementById("txtReturnRemark").value = ""; // Clear the remark if hidden
                document.getElementById("txtReturnDate").value = ""; // Clear the date if hidden
            }
        }

        $(document).ready(function() {

            toggleReturnFields();
        });
    </script>

<script>
    function SubmitForm(AssetId_Encrypted) {
        debugger;

        document.getElementById("AssetId_Encrypted").value = AssetId_Encrypted;

        var isChecked = document.getElementById("txtReturnAsset").checked;
        document.getElementById("hdnReturnStatus").value = isChecked ? "true" : "false";

        var returnRemark = document.getElementById("txtReturnRemark").value;
        document.getElementById("txtReturnRemark").value = returnRemark;
        var returnDate = document.getElementById("txtReturnDate").value;
        document.getElementById("txtReturnDate").value = returnDate;
        document.getElementById("AssetStatusSaveUpdate").submit();
    }
            </script>


