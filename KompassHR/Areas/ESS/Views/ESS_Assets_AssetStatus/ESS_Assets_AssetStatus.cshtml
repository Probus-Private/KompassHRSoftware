</script>

<script>
    $(document).ready(function () {
        debugger

        $("#ddlBranchId").select2({
          
        });

        $("#ddlAssetEmployeeId").select2({
         
        });
        $("#ddlCompanyId").select2({
         
        });

        //$("#ddlAssetId").select2({
        //    allowClear: true,
        //    width: "100%"
        //});

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: false
                }).then(function () {
                   // window.location.reload();
                });
            }
        }

        $("#ddlCompanyId").on("change", function () {
            debugger
            $("#ddlBranchId").empty();
            $("#ddlAssetEmployeeId").empty();

            var CompanyId = $("#ddlCompanyId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetBusinessUnit", "ESS_Assets_AssetStatus")',
                data: { CompanyId: CompanyId },
                success: function (data) {

                    if (data && data.Branch) {
                        $("#ddlBranchId").append("<option value=''>All</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    if (data && data.EmployeeName) {
                        $("#ddlAssetEmployeeId").append("<option value=''>All</option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $("#ddlAssetEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            });
        });



        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlAssetEmployeeId").find("option").remove();
            var BranchId = $("#ddlBranchId").val() || null;
            var CompanyId = $("#ddlCompanyId").val();
            // var GetYear = $("#txtFromDate").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployee", "ESS_Assets_AssetStatus")',
                data: { CompanyId: CompanyId, BranchId: BranchId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlAssetEmployeeId").append("<option value=''>All</option>");
                        $.each(data, function (i, p) {
                            $("#ddlAssetEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


    });
</script>


