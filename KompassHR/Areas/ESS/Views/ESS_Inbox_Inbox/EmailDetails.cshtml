<script>
     function ApproveReject(Status) {
         debugger;
         
         var DivTravelClaimDisplayNone= document.getElementById("DivTravelClaim").style.display;
         var DivGeneralClaimDisplayNone= document.getElementById("DivGeneralClaim").style.display;

         if(DivTravelClaimDisplayNone=="")
         {
             var ApproveAmount =null;
             var TravelClaimTotalAmount = Number($("#TravelClaimTotalAmount").html());
             var TravelClaimApproveAmount = Number($("#TravelClaimApproveAmount").val());
             if(TravelClaimApproveAmount =="")
             {
                 $("#ErrorTravelClaimApproveAmount").html("Please enter approve amount");
                 $("#TravelClaimApproveAmount").focus();
                 return false;
             }
             else
             {
                 $("#ErrorTravelClaimApproveAmount").html("");
             }
             //TravelClaim Approve Amount Check
             if(TravelClaimApproveAmount>TravelClaimTotalAmount || TravelClaimApproveAmount==0)
             {
                 $("#ErrorTravelClaimApproveAmount").html("Approve amount should be less than total amount");
                 return false;
             }
             else{
                 $("#ErrorTravelClaimApproveAmount").html("");
             }
         }

         if(DivGeneralClaimDisplayNone=="")
         {
             var GeneralClaimTotalAmount = $("#GeneralClaimTotalAmount").html();
             var GeneralClaimApproveAmount = $("#GeneralClaimApproveAmount").val();
             if(GeneralClaimApproveAmount =="")
             {
                 $("#ErrorGeneralClaimApproveAmount").html("Please enter approve amount");
                 $("#GeneralClaimApproveAmount").focus();
                 return false;
             }
             else
             {
                 $("#ErrorGeneralClaimApproveAmount").html("");
             }
             //GeneralClaim Approve Amount Check
             if(GeneralClaimApproveAmount>GeneralClaimTotalAmount || GeneralClaimApproveAmount==0)
             {
                 $("#ErrorGeneralClaimApproveAmount").html("Approve amount should be greter than total amount");
                 return false;
             }
             else{
                 $("#ErrorGeneralClaimApproveAmount").html("");
             }
         }


         if(TravelClaimApproveAmount !=null || TravelClaimApproveAmount=="")
         {
             ApproveAmount = TravelClaimApproveAmount;
         }
         if(GeneralClaimApproveAmount !=null || GeneralClaimApproveAmount=="")
         {
             ApproveAmount = GeneralClaimApproveAmount;
         }

        
        var Remark="";
        if (Status == "Rejected") {

            Remark = $("#txtApproveRejectRemark").val();
        }
        $.ajax({
            type: "POST",
            //url = '@Url.Action("ApproveLeaveRequest", "Inbox")',
            url: "ApproveLeaveRequest/Inbox",
            data: { Status: Status, Remark: Remark , ApproveAmount:ApproveAmount},
           // contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response)
            {
                debugger;
                var data =  JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (data !=null) {
                    if (Message1 != null) {

                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }

                            }).then(function() {
                                var url = '@Url.Action("ESS_Inbox_Inbox", "ESS_Inbox_Inbox", new { Area = "ESS" })';
                                window.location.href = url;
                            })
                        }
                        // location.reload();
                }
            }

        });
    }
</script>


