                        <li><a href="/ESS/ESS_Inbox_Inbox/GetInboxList?GetFilter=PM"> Punch Missing<div class="ms-auto icon2" id="DivTeamPunchMissingCount"><i class="fa fa-bell"></i><span class="badge2" id="TeamPunchMissingCount">@ViewBag.RquisitionCount[0].TeamPunchMissingCount</span></div></a></li>
                        <li><a href="/ESS/ESS_Inbox_Inbox/GetInboxList?GetFilter=SL">Short Leave<div class="ms-auto icon2" id="DivTeamShortLeaveCount"><i class="fa fa-bell"></i><span class="badge2" id="TeamShortLeaveCount">@ViewBag.RquisitionCount[0].TeamShortLeaveCount</span></div></a></li>
                        <li><a href="/ESS/ESS_Inbox_Inbox/GetInboxList?GetFilter=WFH"> Work Form Home<div class="ms-auto icon2" id="DivTeamWorkFromHomeCount"><i class="fa fa-bell"></i><span class="badge2" id="TeamWorkFromHomeCount">@ViewBag.RquisitionCount[0].TeamWorkFromHomeCount</span></div></a></li>
