<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Remark For Reject</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal" aria-hidden="true">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                @*<input type="button" onclick="ApproveReject('Reject')" class="Ok btn btn-success" data-bs-dismiss="modal" id="btnReject" value="Submit" />*@
                <button type="button" onclick="ApproveReject('Rejected')" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress btnClear" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
                @*<input type="button" class="Ok btn btn-close" data-bs-dismiss="modal" id="btnCancel" value="Cancel" />*@
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->
<script>
    $(document).ready(function () {
        var LeaveCount = $("#LeaveCount").html();
        var TeamLeaveCount = $("#TeamLeaveCount").html();
        var OutDoorCompanyCount = $("#TeamOutDoorCompanyCount").html();
        var PunchMissingCount = $("#TeamPunchMissingCount").html();
        var ShortLeaveCount = $("#TeamShortLeaveCount").html();
        var WorkFromHomeCount = $("#TeamWorkFromHomeCount").html();
        var CoffCount = $("#TeamCoffCount").html();
        var PersonalGatepassCount = $("#TeamPersonalGatepassCount").html();

        if (LeaveCount == 0) {
            $("#DivLeaveCount").hide()
        } else {
            $("#DivLeaveCount").show()
        }
        if (TeamLeaveCount == 0) {
            $("#DivTeamLeaveCount").hide()
        }
        else {
            $("#DivTeamLeaveCount").show()
        }
        if (OutDoorCompanyCount == 0) {
            $("#DivTeamOutDoorCompanyCount").hide()
        }
        else {
            $("#DivTeamOutDoorCompanyCount").show()
        }
        if (PunchMissingCount == 0) {
            $("#DivTeamPunchMissingCount").hide()
        }
        else {
            $("#DivTeamPunchMissingCount").show()
        }
        if (ShortLeaveCount == 0) {
            $("#DivTeamShortLeaveCount").hide()
        }
        else {
            $("#DivTeamShortLeaveCount").show()
        }
        if (WorkFromHomeCount == 0) {
            $("#DivTeamWorkFromHomeCount").hide()
        }
        else {
            $("#DivTeamWorkFromHomeCount").show()
        }
        if (PersonalGatepassCount == 0) {
            $("#DivTeamPersonalGatepassCount").hide()
        }
        else {
            $("#DivTeamPersonalGatepassCount").show()
        }

        debugger;
        @*var Filter = 'All';
        location.href = '@Url.Action("Inbox", "Inbox")?GetFilter=' + Filter;*@


        //$("#tblInbox").load();
        //setInterval(function () {
        //    debugger;
        //    $('#tblInbox').load();
        //}, 2000);

        //RecordFilter('All');


    });

    //Select All Checkboxes
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
    //Clear Remark in Reject Reson
    $(".btnClear").click(function () {
        $("#txtApproveRejectRemark").val("");
    });
    //$(document).on('click', '#tblInbox tr td', function () {
    function GetDetails(tblRow) {
        debugger;
        var currentRow = $(tblRow).closest("tr");
        var DocID_Encrypted = currentRow.find("td:eq(0)").html();
        var Origin = currentRow.find("td:eq(1)").html();
        var EmployeeName = currentRow.find("td:eq(4)").html();

        $.ajax({
            type: "Get",
            url :'@Url.Action("GetEmailDetails", "ESS_Inbox_Inbox")',
            data: { DocID: DocID_Encrypted, Origin: Origin, },
            dataType: "text",
            success: function (data) {
                debugger;
                var url = '@Url.Action("EmailDetails", "ESS_Inbox_Inbox")';
                window.location.href = url;
            }
        });
    }

    function OpenModel() {
        debugger;
        var RecordList = new Array();
        $(':checkbox:checked').each(function (i) {
            debugger;
            var data = {};
            data.DocID = $(this).val();
            var currentRow = $(this).closest("tr");
            data.Origin = currentRow.find("td:eq(1)").html();
            RecordList.push(data);
        });
        debugger;
        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $("#myModal").modal('show');
    }
    //Approve Leave Request
    //$("#btnApprove").on('click', function () {
    function ApproveReject(Status) {
        debugger;
        var Remark;
        if (Status == "Rejected") {

            Remark = $("#txtApproveRejectRemark").val();
        }
        var RecordList = new Array();
        $(':checkbox:checked').each(function (i) {
            debugger;
            var data = {};
            data.DocID = $(this).val();
            var currentRow = $(this).closest("tr");
            data.Origin = currentRow.find("td:eq(1)").html();
            data.Status = Status;
            data.ApproveRejectRemark = Remark;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $.ajax({
            type: "POST",
            url: "MultipleApproveLeaveRequest",
            data: JSON.stringify(RecordList),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("ESS_Inbox_Inbox", "ESS_Inbox_Inbox")';
                        window.location.href = url;
                    });
                }

                @*var url = '@Url.Action("Inbox", "Inbox")';
                window.location.href = url;*@
            }
        });
    }

    function RefreshTable() {
        window.location.reload();
    }
</script>


