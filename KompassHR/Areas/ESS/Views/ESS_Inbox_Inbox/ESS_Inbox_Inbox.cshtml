                        <li><a href="/ESS/ESS_Inbox_Inbox/GetInboxList?GetFilter=PG"> Personal Getpass <div class="ms-auto icon2" id="DivTeamPersonalGatepassCount"><i class="fa fa-bell"></i><span class="badge2" id="TeamPersonalGatepassCount">@ViewBag.RquisitionCount[0].TeamPersonalGatepassCount</span></div></a></li>
                        <li><a href="/ESS/ESS_Inbox_Inbox/GetInboxList?GetFilter=PG"> New Added-Pending @*<div class="ms-auto icon2"><i class="fa fa-bell"></i><span class="badge2" id="Team1">@ViewBag.RquisitionCount[0].TeamPersonalGatepassCount</span></div>*@</a></li>
                        <li><a href="/ESS/ESS_Inbox_Inbox/GetInboxList?GetFilter=PG"> New Added-Pending @*<div class="ms-auto icon2"><i class="fa fa-bell"></i><span class="badge2" id="Team2">@ViewBag.RquisitionCount[0].TeamPersonalGatepassCount</span></div>*@</a></li>
                    </ul>
                </div>
                <!-- END scrollbar -->
            </div>
        </div>
        <!-- END mailbox-sidebar -->
        <!-- BEGIN mailbox-content -->
        <div class="mailbox-content">
            <div class="mailbox-content-header">
                <!-- BEGIN btn-toolbar -->
                <div class="btn-toolbar align-items-center">
                    <div class="form-check me-2">
                        <input type="checkbox" class="form-check-input" data-checked="email-checkbox" id="emailSelectAll" onchange="checkAll(this)" value="" data-change="email-select-all" />
                        <label class="form-check-label" for="emailSelectAll"></label>
                    </div>
                    <div class="dropdown me-2">
                        <button id="btnApprove" onclick="ApproveReject('Approved')" type="button" class="btn btn-success btn-sm"><i class="fa-solid fa-floppy-disk"> </i> <span class="d-none d-lg-inline">Approve</span></button> &nbsp; &nbsp;
                        <button id="btnReject" onclick="OpenModel()" data-toggle="modal" data-target="#myModal" type="button" class="btn btn-danger btn-sm"><i class="fa-solid fa-share-from-square"></i> <span class="d-none d-lg-inline">Reject</span></button>
                    </div>
                    <button onclick="RefreshTable()" class="btn btn-sm btn-white me-2" id="tblReload"><i class="fa fa-redo"></i></button>
                    <a class="btn btn-white btn-sm" href='/ESS/ESS_Requisition_Menu/ESS_Requisition_Menu'> <i class="fa fa-fw fa-reply"></i> <span class="d-none d-lg-inline">Back</span></a>
                    @*<button class="btn btn-sm btn-white" id="tblReload">
                        <i class="fa fa-arrow-left"><a href="/ESS/ESS_Requisition_Menu/ESS_Requisition_Menu"> Back</a></i>
                    </button>*@
                    <div class="w-100 d-sm-none d-block mb-2 hide" data-email-action="divider"></div>
                    <!-- BEGIN btn-group -->
                    <div class="btn-group">
                        <button class="btn btn-sm btn-white hide" data-email-action="delete"><i class="fa fa-times me-1"></i> <span class="hidden-xs">Delete</span></button>
                        <button class="btn btn-sm btn-white hide" data-email-action="archive"><i class="fa fa-folder me-1"></i> <span class="hidden-xs">Archive</span></button>
                        <button class="btn btn-sm btn-white hide" data-email-action="archive"><i class="fa fa-trash me-1"></i> <span class="hidden-xs">Junk</span></button>
                    </div>
                    <!-- END btn-group -->
                    <!-- BEGIN btn-group -->
                    @*New and Preveius Button*@
                    @*<div class="btn-group ms-auto">
                        <button class="btn btn-white btn-sm">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button class="btn btn-white btn-sm">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </div>*@
                    <!-- END btn-group -->
                </div>
                <!-- END btn-toolbar -->
            </div>
            <div class="mailbox-content-body" id="tblDiv">
                <div data-scrollbar="false" data-height="100%" data-skip-mobile="false">
                    <!-- BEGIN list-email -->
                    @* Table Code*@
                    <table class="table table-bordered align-middle" id="tblInbox" style="width: 100%;">
                        <thead>
                            <tr>
                                @*<th class="text-nowrap"></th>
                                    <th class="text-nowrap"></th>
                                    <th class="text-nowrap"> </th>
                                    <th class="text-nowrap"></th>
                                    <th class="text-nowrap"></th>
                                    <th class="text-nowrap"></th>*@
                            </tr>
                        </thead>
                        <tbody class="scrollable-tbody">
                            @if (@ViewBag.GetPending_ForApproval != null)
                            {
                                foreach (var d in ViewBag.GetPending_ForApproval)
                                {
                                    <tr>
                                        <td hidden>@d.DocID_Encrypted</td>
                                        <td hidden>@d.Origin</td>
                                        <td style="width:10px"><input type="checkbox" class="form-check-input" data-checked="email-checkbox" value="@d.DocID_Encrypted" id="tblCheckbox"></td>
                                        <td style="width:20px">
                                            <span class="email-userBx">
                                                <a class="email-user bg-indigo">
                                                    <span class="text-white">@d.FirstEmployeeName</span>
                                                </a>
                                            </span>
                                        </td>
                                        <td onclick="GetDetails(this)"><span class="email-sender">@d.EmployeeName</span></td>
                                        <td onclick="GetDetails(this)"> <span class="email-title">@d.Reason</span></td>
                                        <td onclick="GetDetails(this)"><span class="email-title sub">@d.TotalDuration</span></td>
                                        <td onclick="GetDetails(this)"  style="text-align: left; padding-left: 10px;"><span class="email-time">@d.PendingScience</span></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    @*Table Code End*@
                </div>
            </div>
            <div class="mailbox-content-footer d-flex align-items-center">
                <div class="text-dark fw-bold">@TempData["LeaveCount"] &nbsp; messages</div>
                <div class="btn-group ms-auto">
                    <button id="btnApprove" onclick="ApproveReject('Approved')" type="button" class="btn btn-success btn-sm"><i class="fa-solid fa-floppy-disk"> </i> <span class="d-none d-lg-inline">Approve</span></button> &nbsp; &nbsp;
                    <button id="btnReject" onclick="OpenModel()" data-toggle="modal" data-target="#myModal" type="button" class="btn btn-danger btn-sm"><i class="fa-solid fa-share-from-square"></i> <span class="d-none d-lg-inline">Reject</span></button>&nbsp; &nbsp;
