<style type="text/css">
    /*.table {
        background: -moz-linear-gradient(-90deg, #003471, #448CCB);
        background: -webkit-gradient(linear, left top, left bottom, from(#003471), to(#448CCB));
    }*/

    table, th, td {
        border-left: none;
        border-right: none;
        padding: 15PX 8PX !important;
        cursor: pointer !important;
    }

    .email-user {
        display: inline-flex;
        justify-content: center;
        width: 30px;
        height: 30px;
        min-width: 30px;
        overflow: hidden;
        font-size: 18px;
        line-height: 30px;
        text-align: center;
        color: #fff;
        background: #adb5bd;
        margin: -5px 0;
        border-radius: 30px;
        text-decoration: none;
    }

    .email-time {
        display: block;
        font-size: 11px;
        font-weight: 600;
        color: rgba(var(--app-component-color-rgb),.65);
        width: 100px;
        right: 0;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        text-align: right;
    }



    @@media (min-width: 768px) {
        .email-desc {
            padding-left: 20px;
        }
    }

    .email-desc {
        display: block;
        position: relative;
        color: rgba(var(--app-component-color-rgb),.5);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
    }

    .email-sender {
        display: block;
        width: 300px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 600;
    }

    @@media (min-width: 1200px) {
        .email-title {
            padding-left: 15px;
        }
    }

    .email-title {
        display: block;
        line-height: 20px;
        width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 600;
    }

    .sub {
        display: block;
        line-height: 20px;
        width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 600;
        color: rgba(var(--app-component-color-rgb),.5);
    }

    .table-bordered > :not(caption) > * > * {
        border-width: 3px 1px;
    }

    .mailbox-sidebar {
        height: 600px;
    }

    .mailbox .nav-inbox > li > a:hover {
        color: var(--app-component-color);
    }

    .icon2 {
        position: relative;
    }

        .icon2 i {
            font-size: 16px;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .badge2 {
        position: absolute;
        top: -8px;
        display: block;
        background: var(--app-theme);
        line-height: 12px;
        font-weight: 600;
        color: var(--app-theme-color);
        padding: 3px 6px;
        font-size: 8px;
        border-radius: 30px;
        right: -5px;
        z-index: 99;
    }
</style>

<style> 
    /*THIS DATALIST FORM TBODY ADDED SCROLL*/
    .scrollable-tbody {
        display: block;
        height: 462px; /* Set the desired height */
