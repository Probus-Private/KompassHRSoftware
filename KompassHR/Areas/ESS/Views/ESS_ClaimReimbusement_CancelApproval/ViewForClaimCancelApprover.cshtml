            </span>
            <input type="hidden" id="hdnEncryptedId" value="@(Item.RequestCancelID_Encrypted ?? string.Empty)" />
            <input type="hidden" id="hdnDocIdId" value="@(Item.RequestCancelID ?? string.Empty)" />
            <input type="hidden" id="hdnOrigin" value="@(Item.Type ?? string.Empty)" />
            <span class="hidden-print d-flex gap-2">
                <button type="button" class="btn btn-primary" onclick="printDiv();" id="search">
                    <i class="ace-icon fa fa-print align-top bigger-125"></i> Print
                </button>
                <a href="#modal-dialogForApproval1" onclick="Approved('Approved')" class="btn btn-success" id="btnmodal-dialog">
                    <i class="fa-solid fa-check-double"></i> Approve
                </a>
                <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" class="btn btn-danger" id="btnmodal-dialog1">
                    Reject
                </button>
            </span>
        </div>

