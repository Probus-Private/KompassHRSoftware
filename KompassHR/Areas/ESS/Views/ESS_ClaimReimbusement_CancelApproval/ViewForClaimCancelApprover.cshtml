        <!-- #Start Appprove Reject Modal -dialog -->
        <div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
            <div class="modal-dialog modal-md">
                <div class="modal-content">
                    <div class="modal-header bg-black text-white">
                        <h4 class="modal-title"> Remark For Reject</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                               aria-hidden="true" id="CloseModel">
                                <i class="fa fa-xmark"></i>
                            </a>
                        </div>
                    </div>
                    <div class="modal-body">
                        <!-- BEGIN panel -->
                        <div class="modal-body-content">
                            <div class="row">
                                <div class="col-md-12">
                                    <form>
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="row mb-15px">
                                                    <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <!-- END panel -->
                    </div>
                    <div class="modal-footer">
                        <button type="button" onclick="Approved('Rejected')" id="btnReject" class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-floppy-disk"> </i> Submit
                        </button>
                        <button type="button" id="btnCancel" class="btn btn-danger btnpress CloseModel" data-bs-dismiss="modal">
                            <i class="fa-solid fa-share-from-square"></i> Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <!-- #End modal-dialog -->

        <script>
            $(document).ready(function () {
                var Message = @Html.Raw(Json.Encode(TempData["Message"]));
                var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: false
                    });

                }
                var List = @Html.Raw(Json.Encode(ViewBag.ResourceApprovalList));
                debugger;
                var Encrypted=List[1].Value;
                var id=List[0].Value;
                $("#txtResourceId_Encrypted").val(Encrypted);
                $("#txtResourceId").val(id);
            });
        </script>

        <script>
            function printDiv() {
                var divElements = document.getElementById('card').innerHTML;
                var oldPage = document.body.innerHTML;
                document.body.innerHTML =
                  "<html><head></head><body>    " +
                divElements + "    </body>";
                window.print();
                document.body.innerHTML = oldPage;
            }
            function OpenModule()
            {
                debugger;
                $("#myModalFinal").modal('show');
            }

            function Approved(Approver)
            {
                const DeleteButtons = Swal.mixin({
                    customClass: {
                        cancelButton: ' btnpress',
                        confirmButton: ' btnpress'
                    },
                    buttonsStyling: true
                })
                DeleteButtons.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    showCancelButton: true,
                    confirmButtonText: 'Yes,submit!',
                    cancelButtonText: 'No, cancel!',
                    reverseButtons: false,
                    allowOutsideClick: false

                }).then((result) => {
                    if (result.isConfirmed) {
                        debugger;
                        if(Approver=="Approved")
                        {
                            var ApproveAmount=Number($("#txtClaimApproveAmount").val());
                            if(ApproveAmount=="")
                            {
                                $("#ErrortxtClaimApproveAmount").html("Please enter claim approve amount");
                                return false;
                            }
                            else{
                                $("#ErrortxtClaimApproveAmount").html("");
                            }
                            var TotalAmount = Number($("#txtTotalAmount").html());
                            debugger
                            if(TotalAmount < ApproveAmount)
                            {
                                $("#ErrortxtClaimApproveAmount").html("Approve amount should be less than total amount");
                                return false;
                            }
                            else{
                                $("#ErrortxtClaimApproveAmount").html("");
                            }
                        }

                        var DocId=$("#hdnDocIdId").val();
                        var Encrypted=$("#hdnEncryptedId").val();
                        var Origin=$("#hdnClaimType").val();

                        var Status="";
                        var Remark="";
                        if(Approver=="Rejected")
                        {
                            Remark = $("#txtApproveRejectRemark").val();
                            Status="Rejected";
                        }
                        else{
                            Status="Approved";
                        }
                        $(".Userloaderbg").css("display", "flex");
                        $.ajax({
                            url: "@Url.Action("RequestForCancelApprove", "ESS_ClaimReimbusement_CancelApproval")",
                            method:"get",
                            data:{DocId:DocId,Encrypted:Encrypted,Status:Status,Remark:Remark,ApproveAmount:ApproveAmount,Origin:Origin},
                            success:function(response){
                                debugger;
                                $(".Userloaderbg").css("display", "none");
                                var Message1 = response.Message;
                                var Icon1 = response.Icon;
                                if (response.Icon=="error") {
                                    if (Message1 != null) {
                                        if (Message1 != null) {
                                            Swal.fire({
                                                icon: Icon1,
                                                text: Message1,
                                                allowOutsideClick: false
                                            });

                                            $("#myModalFinal").modal('hide');
                                            $("#txtApproveRejectRemark").val("")
                                            .then((result) => {
                                                if (result.isConfirmed) {
                                                    window.location.href = '@Url.Action("ESS_ClaimReimbusement_CancelApproval", "ESS_ClaimReimbusement_CancelApproval")';
                                                } else if (
                                                    /* Read more about handling dismissals below */
                                                    result.dismiss === Swal.DismissReason.cancel
                                                ) {

                                                }
                                            })
                                        }
                                    }
                                }
                                else{
                                    var Message1 = response.Message;
                                    var Icon1 = response.Icon;
                                    if (response.Icon=="success") {
                                        if (Message1 != null) {
                                            if (Message1 != null) {
                                                Swal.fire({
                                                    icon: Icon1,
                                                    text: Message1,
                                                    allowOutsideClick: false
                                                })
                                                .then((result) => {
                                                    if (result.isConfirmed) {
                                                        window.location.href = '@Url.Action("ESS_ClaimReimbusement_CancelApproval", "ESS_ClaimReimbusement_CancelApproval")';
                                                    } else if (
                                                        /* Read more about handling dismissals below */
                                                        result.dismiss === Swal.DismissReason.cancel
                                                    ) {

                                                    }
                                                })

                                                $("#myModalFinal").modal('hide');
                                                $("#txtApproveRejectRemark").val("");
                                            }
                                        }
                                    }
                                }
                            }
                        });
                    } else if (
                        /* Read more about handling dismissals below */
                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                    }
                })
            }

        </script>