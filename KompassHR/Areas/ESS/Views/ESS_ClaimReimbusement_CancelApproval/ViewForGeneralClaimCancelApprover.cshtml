<style>
    .note-toolbar {
        display: none;
    }

    .note-editable {
        height: 100% !important;
        [contenteditable="false"];
    }

    .table, tr, td, th, .invoice, .smallFrom {
        border: none;
        font-size: 13px;
        font-family: Arial;
    }

    .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<style>
    @@media (max-width: 768px) {
    .app-content, .invoice { padding: 10px; }
    .breadcrumb { flex-wrap: wrap; font-size: 14px; }
    .invoice-company, .invoice-from, .invoice-to { font-size: 14px; display: flex; flex-direction: column; gap: 10px; }
    .invoice-from address, .invoice-to address { word-break: break-word; }
    
    .table { width: 100%; display: block; overflow-x: auto; white-space: nowrap; }
    .table th, .table td { font-size: 14px; padding: 8px; }
    
    .float-end { float: none !important; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 10px; }
    .float-end .btn { width: 100%; font-size: 14px; }

    .fa-solid, .fa-regular, address { font-size: 14px; }
    
    .hidden-print { display: block; }
    @@media print { .hidden-print { display: none !important; } }
}

</style>

