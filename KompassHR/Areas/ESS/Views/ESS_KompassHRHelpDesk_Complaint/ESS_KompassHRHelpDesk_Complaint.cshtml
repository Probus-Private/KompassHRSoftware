
@{
    ViewBag.Title = "ESS_KompassHRHelpDesk_Complaint";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!-- ================== Icon Css ================== -->
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<link href="~/assets/MyCSS/MenuImages.css" rel="stylesheet" />
<link href="~/Content/Site.css" rel="stylesheet" />
<!-- ================== End SWEEand css ================== -->


    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <style>
        :root {
            --primary: #4361ee;
            --secondary: #3f37c9;
            --success: #4cc9f0;
            --warning: #f72585;
            --danger: #e63946;
            --light: #f8f9fa;
            --dark: #212529;
            --gray: #6c757d;
            --light-gray: #e9ecef;
        }

         .required-star {
                    color: #dc3545;
                    font-weight: 700;
                }

        body {
            background-color: #f5f7fb;
            color: var(--dark);
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 250px;
            background: linear-gradient(to bottom, var(--primary), var(--secondary));
            color: white;
            padding: 20px 0;
            transition: all 0.3s;
        }

        .logo {
            padding: 0 20px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 20px;
        }

        .logo h2 {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo i {
            font-size: 24px;
        }

        .nav-links {
            list-style: none;
        }

        .nav-links li {
            padding: 12px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .nav-links li:hover, .nav-links li.active {
            background-color: rgba(255,255,255,0.1);
            border-left: 4px solid var(--success);
        }

        /* Main Content Styles */
        .main-content {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--light-gray);
        }

        .search-bar {
            display: flex;
            align-items: center;
            background: white;
            border-radius: 30px;
            padding: 8px 15px;
            width: 300px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .search-bar input {
            border: none;
            outline: none;
            background: transparent;
            width: 100%;
            margin-left: 10px;
        }

        .user-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .notification {
            position: relative;
            cursor: pointer;
        }

        .notification span {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--danger);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }

        /* Metrics Cards */
        .metrics-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: transform 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .metric-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .metric-info h3 {
            font-size: 14px;
            color: var(--gray);
            margin-bottom: 5px;
        }

        .metric-info .value {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .metric-info .trend {
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .trend.up {
            color: var(--success);
        }

        .trend.down {
            color: var(--danger);
        }

        .metric-icon {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .total-complaints .metric-icon {
            background: rgba(67, 97, 238, 0.2);
            color: var(--primary);
        }

        .open-complaints .metric-icon {
            background: rgba(247, 37, 133, 0.2);
            color: var(--warning);
        }

        .in-progress .metric-icon {
            background: rgba(76, 201, 240, 0.2);
            color: var(--success);
        }

        .resolved .metric-icon {
            background: rgba(56, 193, 114, 0.2);
            color: #38c172;
        }

        /* Charts Section */
        .charts-section {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-container {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .chart-title {
            font-size: 18px;
            font-weight: 600;
        }

        .chart-actions {
            display: flex;
            gap: 10px;
        }

        .chart-actions select {
            padding: 5px 10px;
            border-radius: 5px;
            border: 1px solid var(--light-gray);
            outline: none;
        }

        /* Recent Complaints */
        .recent-complaints {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
        }

        .section-actions button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: background 0.3s;
        }

        .section-actions button:hover {
            background: var(--secondary);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: var(--light);
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--light-gray);
        }

        .status {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .status.open {
            background: rgba(247, 37, 133, 0.1);
            color: var(--warning);
        }

        .status.progress {
            background: rgba(76, 201, 240, 0.1);
            color: var(--success);
        }

        .status.resolved {
            background: rgba(56, 193, 114, 0.1);
            color: #38c172;
        }

        .priority {
            display: flex;
            align-items: center;
            gap: 5px;
        }

     .priority.high::before {
    content: "";
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ff9999; /* light red for high priority */
}


        .priority.medium::before {
            content: "";
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ffc107;
        }

        .priority.low::before {
            content: "";
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--success);
        }

        .priority.critical::before {
            content: "";
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #dc3545;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
        }

        .action-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--gray);
            transition: color 0.3s;
            padding: 5px;
            border-radius: 4px;
        }

        .action-btn:hover {
            color: var(--primary);
            background: rgba(67, 97, 238, 0.1);
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: white;
            border-radius: 10px;
            width: 90%;
            max-width: 1000px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .modal-header {
            padding: 20px;
            border-bottom: 1px solid var(--light-gray);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border-radius: 10px 10px 0 0;
        }

        .modal-title {
            font-size: 20px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .close-modal {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: white;
            padding: 5px;
            border-radius: 4px;
        }

        .close-modal:hover {
            background: rgba(255,255,255,0.1);
        }

        .modal-body {
            padding: 20px;
        }

        .details-section {
            margin-bottom: 25px;
            padding: 20px;
            background: var(--light);
            border-radius: 8px;
            border-left: 4px solid var(--primary);
        }

        .details-section h3 {
            margin-bottom: 15px;
            color: var(--primary);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 15px;
        }

        .detail-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .details-full {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .detail-row {
            display: flex;
            align-items: flex-start;
            margin-bottom: 8px;
        }

        .detail-label {
            width: 140px;
            font-weight: 600;
            color: var(--gray);
            flex-shrink: 0;
            font-size: 14px;
        }

        .detail-value {
            flex: 1;
            word-break: break-word;
            font-size: 14px;
            color: var(--dark);
        }

        .detail-value.full-width {
            background: white;
            padding: 10px;
            border-radius: 5px;
            border: 1px solid var(--light-gray);
            min-height: 40px;
        }

        /* File Attachments */
        .file-attachments {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .file-attachment {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: white;
            border: 1px solid var(--light-gray);
            border-radius: 5px;
            transition: all 0.3s;
        }

        .file-attachment:hover {
            background: var(--light);
            border-color: var(--primary);
        }

        .file-icon {
            width: 32px;
            height: 32px;
            background: var(--primary);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 14px;
        }

        .file-info {
            flex: 1;
        }

        .file-name {
            font-weight: 500;
            font-size: 14px;
            color: var(--dark);
        }

        .file-size {
            font-size: 12px;
            color: var(--gray);
        }

        .file-download {
            background: none;
            border: none;
            color: var(--primary);
            cursor: pointer;
            padding: 5px;
            border-radius: 3px;
        }

        .file-download:hover {
            background: rgba(67, 97, 238, 0.1);
        }

        .no-attachments, .no-history {
            text-align: center;
            padding: 20px;
            color: var(--gray);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .no-attachments i, .no-history i {
            font-size: 32px;
            color: var(--light-gray);
        }

        /* Status Update Form */
        .status-update-form {
            margin-top: 20px;
            padding: 20px;
            background: var(--light);
            border-radius: 8px;
            border-left: 4px solid var(--success);
        }

        .status-update-form h3 {
            margin-bottom: 15px;
            color: var(--success);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group label {
            font-weight: 500;
            color: var(--gray);
            font-size: 14px;
        }

        .form-group select,
        .form-group input,
        .form-group textarea {
            padding: 10px;
            border: 1px solid var(--light-gray);
            border-radius: 5px;
            font-size: 14px;
            background: white;
        }

     
        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }

        .form-group select:focus,
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(67, 97, 238, 0.1);
        }

        /* Status History */
        .status-history {
            margin-top: 20px;
            padding: 20px;
            background: var(--light);
            border-radius: 8px;
            border-left: 4px solid var(--warning);
        }

        .status-history h3 {
            margin-bottom: 15px;
            color: var(--warning);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .history-item {
            padding: 15px;
            background: white;
            border-radius: 6px;
            margin-bottom: 10px;
            border-left: 3px solid var(--primary);
        }

        .history-status {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .history-status-type {
            font-weight: 600;
            color: var(--dark);
        }

        .history-timestamp {
            font-size: 12px;
            color: var(--gray);
        }

        .history-notes {
            color: var(--gray);
            font-size: 14px;
            margin-bottom: 5px;
        }

        .history-meta {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--gray);
        }

        /* Status Badges */
        .status {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
        }

        .status.open { background: rgba(247, 37, 133, 0.1); color: var(--warning); }
        .status.in-progress { background: rgba(76, 201, 240, 0.1); color: var(--success); }
        .status.resolved { background: rgba(56, 193, 114, 0.1); color: #38c172; }
        .status.closed { background: rgba(108, 117, 125, 0.1); color: var(--gray); }

        /* Priority Badges */
        .priority-badge {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
        }

        .priority-critical { background: rgba(220, 53, 69, 0.1); color: #dc3545; }
        .priority-high { background: rgba(247, 37, 133, 0.1); color: var(--warning); }
        .priority-medium { background: rgba(255, 193, 7, 0.1); color: #ffc107; }
        .priority-low { background: rgba(76, 201, 240, 0.1); color: var(--success); }

        /* Modal Footer */
        .modal-footer {
            padding: 15px 20px;
            border-top: 1px solid var(--light-gray);
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--secondary);
        }

        .btn-secondary {
            background: var(--light-gray);
            color: var(--dark);
        }

        .btn-secondary:hover {
            background: #d1d5db;
        }

        .pageHeader {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--light-gray);
        }

        .page-header {
            font-size: 24px;
            font-weight: 600;
        }

        @@media (max-width: 992px) {
            .charts-section {
                grid-template-columns: 1fr;
            }

            .sidebar {
                width: 70px;
            }

            .sidebar .logo h2 span, .sidebar .nav-links li span {
                display: none;
            }

            .sidebar .logo {
                text-align: center;
                padding: 10px;
            }

            .nav-links li {
                justify-content: center;
                padding: 15px 0;
            }
        }

        @@media (max-width: 768px) {
            .metrics-cards {
                grid-template-columns: 1fr 1fr;
            }

            .header {
                flex-direction: column;
                gap: 15px;
                align-items: flex-start;
            }

            .search-bar {
                width: 100%;
            }
        }

        @@media (max-width: 576px) {
            .metrics-cards {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }
        }
    </style>
<body>


    <style>
        .customer-details {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .detail-row.single {
            display: flex;
            flex-direction: row;
            gap: 10px;
            align-items: center;
        }

        .detail-row.double {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 10px;
        }

        .detail-item {
            flex: 1;
            min-width: 200px;
        }

        .detail-label {
            font-weight: 600;
            color: #444;
        }

        .detail-value {
            margin-left: 5px;
            color: #222;
        }

        .details-section h3 {
            font-size: 1.1rem;
            margin-bottom: 10px;
            color: #333;
            border-bottom: 2px solid #ddd;
            padding-bottom: 5px;
        }

         .detail-item {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
    }

    .detail-label {
        font-weight: 600;
        color: #444;
        margin-right: 5px; /* small space between label and value */
        white-space: nowrap;
    }

    .detail-value {
        color: #222;
        flex: 1;
        word-break: break-word;
    }

    /* Optional: make sure items share space evenly in two columns */
    .detail-row.double .detail-item {
        flex: 1;
        min-width: 250px;
    }
    </style>

   @* for ticket information*@
    <style>
        .details-section {
            padding: 15px;
        }

            .details-section h3 {
                margin-bottom: 15px;
                font-size: 18px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

        /* Create two columns */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px; /* space between columns */
        }

        /* Inside each group, align label and value horizontally */
        .detail-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .detail-label {
            font-weight: 600;
            color: #333;
            flex: 0 0 45%;
        }

        .detail-value {
            flex: 1;
            color: #555;
            text-align: left;
            word-break: break-word;
        }

        .status.open {
            color: #008000;
            font-weight: 600;
        }
    </style>



    <div id="content" class="app-content">

        <div class="dashboard-container">
            <!-- Sidebar -->
            <!-- Main Content -->
            <div class="main-content">
                <!-- Header -->
                <div class="pageHeader d-flex align-items-center justify-content-between" style="flex-wrap:nowrap;">
                    <h5 class="page-header text-center text-md-start">Help Desk Complaints</h5>
                    <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                        <li style="margin-right: 10px;">
                            <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                                <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("ESS_KompassHRHelpDesk_Menu", "ESS_KompassHRHelpDesk_Menu",  new { id = 44,ScreenId=793, area = "ESS" })">
                                <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                            </a>
                        </li>
                    </ol>
                </div>

                <!-- Metrics Cards -->
                <div class="metrics-cards">
                    <div class="card total-complaints">
                        <div class="metric-card">
                            <div class="metric-info">
                                <h3>Total Complaints</h3>
                                <div class="value">@ViewBag.DashboardCount.TotalCount</div>
                                <div class="trend up">
                                    <i class="fas fa-arrow-up"></i> 12% from last week
                                </div>
                            </div>
                            <div class="metric-icon">
                                <i class="fas fa-ticket-alt"></i>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card open-complaints">
                        <div class="metric-card">
                            <div class="metric-info">
                                <h3>Open Complaints</h3>
                                <div class="value">@ViewBag.DashboardCount.OpenCount</div>
                                <div class="trend down">
                                    <i class="fas fa-arrow-down"></i> 5% from yesterday
                                </div>
                            </div>
