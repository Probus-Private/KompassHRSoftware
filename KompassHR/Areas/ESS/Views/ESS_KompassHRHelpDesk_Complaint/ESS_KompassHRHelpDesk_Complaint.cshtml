    <script>

    function OpenModal(button) {
    var HelpDeskId_Encrypted = button.getAttribute("data-encryptedId");
    var baseUrl = '@Url.Action("UpdateStatus", "ESS_KompassHRHelpDesk_Complaint")';
    var url = baseUrl + '?HelpDeskId_Encrypted=' + encodeURIComponent(HelpDeskId_Encrypted);

    fetch(url, {
        method: "GET"
    })
    .then(response => response.text())
    .then(data => {
        console.log("Status updated successfully"); // optional log
        // You can update modal or message if backend returns something
    })
    .catch(error => console.error("Error updating status:", error));

    debugger;

    // ==========================
    // 🧩 Fill modal data section
        // ==========================
    var currentComplaintId = button.getAttribute("data-helpdeskid");
    var customerCode = button.getAttribute("data-customercode");
    var companyname = button.getAttribute("data-companyname");
    var branchname = button.getAttribute("data-branchname");
    var mobileno = button.getAttribute("data-mobileno");
    var emailid = button.getAttribute("data-emailid");
    var department = button.getAttribute("data-department");
    var designation = button.getAttribute("data-designation");

    var ticketNo = button.getAttribute("data-ticketno");
    var created = button.getAttribute("data-created");
    var requestBy = button.getAttribute("data-requestby");
    var priority = button.getAttribute("data-priority");
    var requesttype = button.getAttribute("data-requesttype");
    var modulename = button.getAttribute("data-modulename");
    var title = button.getAttribute("data-title");

    var description = button.getAttribute("data-description");
    var expectedresult = button.getAttribute("data-expectedresult");
    var actualresult = button.getAttribute("data-actualresult");
    var attachfile = button.getAttribute("data-attachfile");

    document.getElementById("modal-helpDeskEncrypted").value = HelpDeskId_Encrypted;
    document.getElementById("modal-currentComplaintId").value = currentComplaintId ;
    document.getElementById("modal-customercode").textContent = customerCode || "-";
    document.getElementById("modal-company").textContent = companyname || "-";
    document.getElementById("modal-branch").textContent = branchname || "-";
    document.getElementById("modal-mobileno").textContent = mobileno || "-";
    document.getElementById("modal-emailid").textContent = emailid || "-";
    document.getElementById("modal-department").textContent = department || "-";
    document.getElementById("modal-designation").textContent = designation || "-";

    document.getElementById("modal-ticketno").textContent = ticketNo || "-";
    document.getElementById("modal-createddate").textContent = created || "-";
    document.getElementById("modal-requestby").textContent = requestBy || "-";
    document.getElementById("modal-priority").textContent = priority || "-";
    document.getElementById("modal-type").textContent = requesttype || "-";
    document.getElementById("modal-modulename").textContent = modulename || "-";
    document.getElementById("modal-title").textContent = title || "-";

    document.getElementById("modal-description").textContent = description || "-";
    document.getElementById("modal-expectedresult").textContent = expectedresult || "-";
    document.getElementById("modal-actualresult").textContent = actualresult || "-";

    // ✅ Status dropdown
    var status = button.getAttribute("data-status");
        debugger
    document.getElementById("modal-current-status").innerHTML =
        `<span class="status ${status.toLowerCase()}">${status}</span>`;

    const statusSelect = document.getElementById("status-select");
    if (statusSelect) {
        let statusValue = (status || "").trim().toLowerCase();
        for (let opt of statusSelect.options) {
            if (opt.value.toLowerCase() === statusValue) {
                opt.selected = true;
                break;
            }
        }
    }

    // ✅ File attachments
    const container = document.getElementById("modal-fileattachments");
    container.innerHTML = "";

    if (attachfile && attachfile.trim() !== "") {
        let files = attachfile.split(",");
        files.forEach(f => {
            let filePath = f.trim();
            if (filePath === "") return;

            let fileName = filePath.split("\\").pop();
            let ext = fileName.split(".").pop().toLowerCase();
            let fileUrl = "/ESS_KompassHRHelpDesk_Complaint/OpenAttachment?filePath=" + encodeURIComponent(filePath);

            let div = document.createElement("div");
            div.className = "file-item";

            if (["jpg", "jpeg", "png", "gif", "bmp", "webp"].includes(ext)) {
                div.innerHTML = `
                    <img src="${fileUrl}" alt="${fileName}" class="attachment-image" onclick="window.open('${fileUrl}', '_blank')" />
                    <a href="${fileUrl}" target="_blank" class="download-link">Open Image</a>`;
            } else {
                div.innerHTML = `
                    <a href="${fileUrl}" target="_blank" class="attachment-file">
                        <i class="fas fa-file"></i> ${fileName}
                    </a>`;
            }
            container.appendChild(div);
        });
    } else {
        container.innerHTML = `
            <div class="no-attachments">
                <i class="fas fa-file"></i>
                <span>No attachments available</span>
            </div>`;
    }

    // ✅ Finally show the modal
    const modal = document.getElementById("statusModal");
    modal.style.display = "block";
    document.body.style.overflow = "hidden";
}


// Close modal when clicking on close buttons
document.querySelectorAll(".close-modal").forEach(btn => {
    btn.addEventListener("click", function () {
        document.getElementById("statusModal").style.display = "none";
        document.body.style.overflow = "auto";
    });
});

// Close modal when clicking outside content
window.addEventListener("click", function (e) {
    const modal = document.getElementById("statusModal");
    if (e.target === modal) {
        modal.style.display = "none";
        document.body.style.overflow = "auto";
    }
});

    </script>



        <script>
            // Initialize charts


            const complaintsCtx = document.getElementById('complaintsChart').getContext('2d');
            const complaintsChart = new Chart(complaintsCtx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [
                        {
                            label: 'New Complaints',
                            data: [12, 19, 15, 22, 18, 14, 20],
                            borderColor: '#4361ee',
                            backgroundColor: 'rgba(67, 97, 238, 0.1)',
                            tension: 0.4,
                            fill: true
                        },
                        {
                            label: 'Resolved Complaints',
                            data: [8, 12, 10, 15, 14, 10, 16],
                            borderColor: '#4cc9f0',
                            backgroundColor: 'rgba(76, 201, 240, 0.1)',
                            tension: 0.4,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'top',
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });





            var statusChartData=@Html.Raw(Json.Encode(ViewBag.DashboardCount));
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            const statusChart = new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Open', 'In Process', 'Resolved'],
                    datasets: [{
                        data: [
                        statusChartData.OpenCount,
                        statusChartData.InProcessCount,
                        statusChartData.ResolvedCount
                        ],
                        backgroundColor: [
                            '#f72585',
                            '#4cc9f0',
                            '#38c172'
                        ],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });


           // Modal functionality
            //const modal = document.getElementById('statusModal');
            //const closeModalButtons = document.querySelectorAll('.close-modal');
            const saveStatusButton = document.getElementById('Submit-status-btn');


            // Save status changes
            saveStatusButton.addEventListener('click', function () {
                debugger
                const helpDeskEncrypted = document.getElementById('modal-helpDeskEncrypted').value;
                const currentComplaintId = document.getElementById('modal-currentComplaintId').value;
                const newStatus = document.getElementById('status-select').value;
                const notes = document.getElementById('status-notes').value;
                const actualResultUpdate = document.getElementById('actual-result-update').value;

                if (!newStatus || !notes) {
                    alert('Please fill in all required fields (Status and Notes)');
                    return;
                }

                // Update the complaint status
                updateComplaintStatus(currentComplaintId,helpDeskEncrypted, newStatus, notes, actualResultUpdate);

                //setTimeout(() => {
                //    location.reload();
                //}, 1000);
            });

            function updateComplaintStatus(complaintId,helpDeskEncrypted, newStatus, notes, actualResultUpdate) {
                debugger
                $.ajax({
                    url: '@Url.Action("TicketResponse", "ESS_KompassHRHelpDesk_Complaint")',
                    method: "GET",
                    contentType: "application/json; charset=utf-8",
                    dataType: "text",
                    data: { complaintId: complaintId, HelpDeskId_Encrypted: helpDeskEncrypted, newStatus: newStatus, notes: notes, actualResultUpdate: actualResultUpdate },
                    success: function (response) {
                        debugger
                        $('#statusModal').modal('hide');
                        var data = JSON.parse(response);
                        var Message = data.Message;
                        var Icon = data.Icon;
                        debugger;
                        if (Message != null) {
                            if (Message != null) {
                                Swal.fire({
                                    icon: Icon,
                                    text: Message,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)

                                        return false
                                    }
                                }).then(function() {
                                    window.location.reload();
                                });
                            }
                        }
                    }
                });
            }

        </script>
</body>



