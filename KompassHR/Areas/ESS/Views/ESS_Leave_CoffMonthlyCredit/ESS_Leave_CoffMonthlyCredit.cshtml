<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Coff Monthly Creadit
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Coff Monthly Creadit </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Coff Monthly Creadit.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_Leave_CoffMonthlyCredit", "ESS_Leave_CoffMonthlyCredit", new { area = "ESS" })' id="SaveForm" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyName, "Id", "Name"), "--Select--", new { id = "txtCmpId", name = "CmpID", @class = "form-select", autocomplete = "off", onChange = "ChangeConpany()" })
                                                <span id="ErrortxtCmpID" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { id = "txtBranchId", name = "BranchId", @class = "form-select", autocomplete = "off" })
                                                <span id="ErrortxtBranchname" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Leave Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "month", autocomplete = "off", id = "txtMonthYear" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-9">
                                                <a href="@Url.Action("ESS_Leave_CoffMonthlyCredit", "ESS_Leave_CoffMonthlyCredit", new { area = "ESS" })">
                                                    <button type="submit" class="btn btn-success btn-sm" id="btnGetList">
                                                        <i class="fa-solid fa-magnifying-glass"></i> Show
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                            <div class="row">
                                <div class="col-md-12">
                                    <div class="panel panel-inverse" data-sortable-id="index-1">
                                        <div class="panel-body">
                                            <!-- Scrollable div -->
                                            <div class="table-scroll div1">
                                                <div class="table-wrap" style="max-height: 400px; overflow-y: auto;">
                                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TablePageBalance" id="tblLeaveOpeningBulk">
                                                        <thead style="background-color: rgba(233, 236, 239, 1) !important; position: sticky; top: 0; z-index: 1;">
                                                            <tr class="trheading">
                                                                <th class="text-nowrap">
                                                                    <label>
                                                                        <input type="checkbox" class="form-check-input" id="AllCheckBox">
                                                                        All
                                                                    </label>
                                                                </th>
                                                                <th class="text-nowrap">Employee Name</th>
                                                                <th class="text-nowrap">Employee No.</th>
                                                                <th class="text-nowrap">Department Name</th>
                                                                <th class="text-nowrap">No Of Coff</th>
                                                                <th class="text-nowrap">Approved Coff</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="tblLoadEmployedetails">
                                                            @if (ViewBag.GetEmployeeList != null && ((IEnumerable<dynamic>)ViewBag.GetEmployeeList).Any())
                                                            {
                                                                foreach (var d in ViewBag.GetEmployeeList)
                                                                {
                                                                    <tr>
                                                                        <td class="text-center">
                                                                            <input type="checkbox" class="form-check-input rowCheckbox" value="@d.EmployeeId">
                                                                        </td>
                                                                        <td>@(d.EmployeeName ?? "")</td>
                                                                        <td>@(d.EmployeeNo ?? "")</td>
                                                                        <td>@(d.DepartmentName ?? "")</td>
                                                                        <td>
                                                                            <input type="text" class="form-control noOfCoff" value="@(d.NoOfCoff ?? 0)" />
                                                                            <small class="text-danger error-noOfCoff"></small>
                                                                        </td>
                                                                        <td>
                                                                            <input type="text" class="form-control approvedCoff" value="@(d.ApprovedCoff ?? 0)" />
                                                                            <small class="text-danger error-approvedCoff"></small>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Submit button -->
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm" onclick="LeaveOpneingbalance()">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "ESS_Leave_CoffMonthlyCredit", new { area = "ESS" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

    </div>
</div>
<script>
    $(document).ready(function () {
        $('#txtCmpId').select2();
        $('#txtBranchId').select2();
        $('.TablePageBalance').DataTable({
            destroy: true,        // Allows the table to be reinitialized
            searching: true,      // Enables the search box
            paging: false,        // Disables pagination
            info: true,          // Disables the table information display (e.g., "Showing 1 to 10 of 50 entries")
            ordering: false,      // Disables column sorting
            bFilter: true         // Enables the filtering functionality (search box)
        });

    });
</script>
<script>
    function ChangeConpany() {
        debugger;
        $("#txtBranchId").find("option").remove();
        var CmpId = $("#txtCmpId").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: "@Url.Action("GetBusinessUnit", "ESS_Leave_CoffMonthlyCredit")",
            data: { CmpId: CmpId },
            success: function (data) {
                debugger;
                if (data != null) {
                    var data1 = data.data;
                    $("#txtBranchId").append("<option value=''>--Select--</option>");
                    $.each(data1, function (i, p) {
                        $("#txtBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }
            }
        })
    }
</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function (value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   }, "erreur expression reguliere"
);


    $("#SaveForm").validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            MonthYear: {
                required: true,
            }
        },
        messages: {
            CmpId: {
                required: "Campany name is required",
            },
            BranchId: {
                required: "Business unit is required",
            },
            MonthYear: {
                required: " Month/Year is required",
            }
        },
    });
</script>

<script>
    var CheckValid = true;
    $(document).on("input", ".approvedCoff", function () {
        let row = $(this).closest("tr");
        let noOfCoff = parseFloat(row.find(".noOfCoff").val()) || 0;
        let approvedCoff = parseFloat($(this).val()) || 0;
        // clear old error
        row.find(".error-approvedCoff").text("");
        if (approvedCoff > noOfCoff) {
            CheckValid = false;
            row.find(".error-approvedCoff").text("Approved Coff cannot be greater than No Of Coff");
        }
        else
        {
            CheckValid = true;
        }
    });
    // Select All functionality
    $(document).on("change", "#AllCheckBox", function () {
        $(".rowCheckbox").prop("checked", $(this).prop("checked"));
    });

    // If any row unchecked -> uncheck "All"
    $(document).on("change", ".rowCheckbox", function () {
        if (!$(this).prop("checked")) {
            $("#AllCheckBox").prop("checked", false);
        }
    });

   function LeaveOpneingbalance() {
    debugger;

    var companyId = Number($("#txtCmpId").val());
    var BranchId = Number($("#txtBranchId").val());
    var MonthYear = $("#txtMonthYear").val();

    var Year = null;
    var Month = null;

    if (MonthYear) {
        var parts = MonthYear.split("-"); // ["2025", "08"]
        Year = parseInt(parts[0]);
        Month = parseInt(parts[1]);
    }

    var CoffMonthlyCreditList = [];

    // Loop through selected rows
    $('#tblLoadEmployedetails .rowCheckbox:checked').each(function () {
        var row = $(this).closest('tr');
        var data = {};
        data.EmployeeId = $(this).val();
        var noOfCoff = row.find("input.noOfCoff").val();
        var approvedCoff = row.find("input.approvedCoff").val();

        data.NoOfCoff = noOfCoff ? parseFloat(noOfCoff) : 0;
        data.ApprovedCoff = approvedCoff ? parseFloat(approvedCoff) : 0;

        CoffMonthlyCreditList.push(data);
    });
    if (CoffMonthlyCreditList == "") {
        debugger;
        Swal.fire({
            icon: "error",
            text: "Select atleast one record",
            allowOutsideClick: false
        });
        return false;
    }
    if (CheckValid==false) {
        Swal.fire({
            icon: "error",
            text: "Approved Coff cannot be greater than No Of Coff ",
            allowOutsideClick: false
        });
        return false;
    }

    $(".Userloaderbg").css("display", "flex");
    $.ajax({
        type: "POST",
        url: "@Url.Action("SaveUpadte", "ESS_Leave_CoffMonthlyCredit")",
        data: JSON.stringify({
            companyId: companyId,
            BranchId: BranchId,
            Month: Month,
            Year: Year,
            CoffMonthlyCreditList: CoffMonthlyCreditList
        }),
        contentType: "application/json; charset=utf-8",
        dataType: "json",
        success: function (data) {
            debugger;
            $(".Userloaderbg").css("display", "none");
            var Message1 = data.Message;
            var Icon1 = data.Icon;

            if (Icon1 && Message1) {
                Swal.fire({
                    icon: Icon1,
                    text: Message1,
                    allowOutsideClick: false
                }).then(function () {
                    var url = '@Url.Action("ESS_Leave_LeaveOpneingBalance", "ESS_Leave_LeaveOpneingBalance")';
                    window.location.href = url;
                });
            }
        },
        error: function (xhr, status, error) {
            console.error("Error:", error);
            console.error("Response:", xhr.responseText);
        }
    });
}


</script>