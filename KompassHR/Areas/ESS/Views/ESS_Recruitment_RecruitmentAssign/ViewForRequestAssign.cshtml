<script>

    var resourceData = @Html.Raw(Json.Encode(ViewBag.ResourceApprovalList));

    function printDiv() {
        var divElements = document.getElementById('card').innerHTML;
        var oldPage = document.body.innerHTML;
        document.body.innerHTML =
          "<html><head></head><body>    " +
        divElements + "    </body>";
        window.print();
        document.body.innerHTML = oldPage;
    }

    $('#UpdateResourcesRecruitment').validate({
        rules: {
            ResponsibleRecruitmentEmployeeId: {
                required: true,
            },
            ClosingDate:{
                required: true,
            },
        },
        messages: {
            ResponsibleRecruitmentEmployeeId:{
                required: "Responsible Recruitment Employee is required",
            },
            ClosingDate:{
                required: "Closing date is required",
            },

        },
    });

    var form = $("#UpdateResourcesRecruitment");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger
        form.valid();
        if (form.valid() == false) {

            return false;
        }

        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;

                debugger;
                var EmpolyeeId = $("#ddlResponsibleRecruitmentEmployeeId").val();
                var BudgetApproved = $("#txtBudgetApproved").val();
                var MaxBudget = $("#txtMaxBudget").val();
                var LegalBondApplicable = $("#txtLegalBondApplicable").val();
                var LegalBondDuration = $("#txtLegalBondDuration").val();
                if (EmpolyeeId == "")
                {
                    $('#ErrorEmployee').html("EmpoloyeeName is required");
                }
                var date = $("#txtdate").val();
                if (date == "")
                {
                    $('#ErrorDate').html("Date is required");
                }
                $(".Userloaderbg").css("display", "flex");
                $.ajax({
                    url: '@Url.Action("UpdateEployee", "ESS_Recruitment_RecruitmentAssign")',
                
                    method: "get",
                    data: { EmpolyeeId: EmpolyeeId, date: date,BudgetApproved:BudgetApproved,MaxBudget:MaxBudget,LegalBondApplicable:LegalBondApplicable,LegalBondDuration:LegalBondDuration },
                    success: function (response) {
                        debugger;
                        //if (response.Icon == "success") {
                        if (response == true) {
                            Swal.fire({
                                icon: "success",
                                text: "Record Save Successfully",
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            })
                            .then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("ESS_Recruitment_RecruitmentAssign", "ESS_Recruitment_RecruitmentAssign")';
                                } else if (
                                    /* Read more about handling dismissals below */
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })

                            //}
                        }
                    }
                });
            }
        })
    });


    $("#ddlResponsibleRecruitmentEmployeeId").change(function () {
        $('#ErrorEmployee').html("");
    })


    $(document).ready(function () {
        debugger;
        $("#ddlResponsibleRecruitmentEmployeeId").select2();
        $("#ddlResponsibleRecruitmentEmployeeId").select2();
        var List=   @Html.Raw(Json.Encode(ViewBag.ResourceApprovalList));
        var closingDate=List[19].Value;
        var date1=new Date(closingDate);
        var date = new Date();
        var date1 = new Date(closingDate);
        if (isNaN(date1.getTime())) {
            console.error('Invalid date:', closingDate);
        } else {
            var dateString = new Date(date1.getTime() - (date1.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
            $("#txtdate").val(dateString);
        }        $("#txtdate").val(dateString);
        var today = new Date().toISOString().split('T')[0];
        document.getElementById("txtdate").setAttribute("min", today);
        debugger;
        var ApproverList = @Html.Raw(Json.Encode(ViewBag.ApproverList));
        $("#txtBudgetApproved").select2();
        $("#txtLegalBondApplicable").select2();
        debugger
        $("#txtLegalBondApplicable").val(ApproverList[0].LegalBondApplicable).select2();
