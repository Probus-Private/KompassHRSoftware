    <hr>
    <div class="invoice">
        <form role="form" action='@Url.Action("UpdateEployee", "ESS_Recruitment_RecruitmentAssign", new { area = "ESS" })' id="UpdateResourcesRecruitment" method="post" enctype="multipart/form-data">

            <div class="row">
                <div class="col-md-6">
                    <div class="row mb-15px">
                        <label class="form-label col-form-label col-md-4">
                            Responsible For Recruitment <span class="important">*</span>
                        </label>
                        <div class="col-md-8">
                            @Html.DropDownListFor(model => model.ResponsibleRecruitmentEmployeeId, new SelectList(ViewBag.ResponsibleRecruitment, "Id", "Name"), "--Select--", new { id = "ddlResponsibleRecruitmentEmployeeId", @class = "form-control select", name = "ResponsibleRecruitmentEmployeeId" })
