                        </label>
                        <div class="col-md-8">
                            @Html.TextBoxFor(model => model.ClosingDate, ViewBag.ResourceApprovalList.ClosingDate as string, new { @class = "form-control", @id = "txtdate", type = "date",name= "ClosingDate" })
