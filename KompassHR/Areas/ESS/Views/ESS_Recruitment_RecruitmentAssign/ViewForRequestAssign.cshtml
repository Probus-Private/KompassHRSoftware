                                               new SelectListItem {Text ="Yes", Value="true"},

                                                                      }, "--Select--",
                                               new { @class = "form-control", id = "txtLegalBondApplicable", name = "LegalBond", autocomplete = "Off" })

                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="row mb-15px">
                        <label class="form-label col-form-label col-md-4">
                            Legal Bond(Month)
                            @*<span class="important">*</span>*@
                        </label>
                        <div class="col-md-8">
                            @Html.TextBoxFor(model => model.LegalBondDuration, ViewBag.ResourceApprovalList.LegalBondDuration as string, new { @class = "form-control", id = "txtLegalBondDuration", type = "text", name = "LegalBondDuration", autocomplete = "Off", onkeypress = " return numbervalidate(event)", Maxlength = 2 })
                            @Html.ValidationMessageFor(model => model.LegalBondDuration, "", new { @class = "help-block", id = "ErrortxtLegalBondDuration", @style = "color:red" })
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
