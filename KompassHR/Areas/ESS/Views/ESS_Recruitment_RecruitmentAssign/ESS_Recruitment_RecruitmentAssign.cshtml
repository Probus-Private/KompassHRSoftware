
@{
    ViewBag.Title = "ESS_Recruitment_RecruitmentAssign";
    Layout = "~/Views/Shared/_LayoutPageSmartHR.cshtml";
}

<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/additional-methods.min.js"></script>

<script>
  
    $(document).ready(function () {

        $('.nav-link').removeClass('active');
        $('.tab-pane').removeClass('show active');

        $('#Menu-tab').addClass('active');
        $('#Menu-tab-pane').addClass('show active');

        $('#RecruitmentMenulink').addClass('active');
    });
</script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>



<div id="content" class="app-content content">
<!-- Breadcrumb -->
    <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb ">
        <div class="my-auto mb-2">
            <h2 class="mb-1">Recruitment Assign</h2>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })"><i class="ti ti-smart-home"></i></a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })" class="fs-14"> Recruitment </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Recruitment Assign</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex my-xl-auto right-content align-items-center flex-wrap gap-3 mb-2">
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <!-- /Breadcrumb -->
   
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse">
                <div class="panel-heading">
                    <h4 class="panel-title"> Recruitment Assign - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>

                    </div>
                   
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                           A Resource Requisition List typically includes a justification or rationale for why the requested resources are necessary. This justification may include project timelines, anticipated workload, specific project requirements, or any other factors influencing the resource needs.                     
                    </p>
                </div>               
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("RecruitmentAssignedList", "ESS_Recruitment_RecruitmentAssign", new { area = "ESS" })">
                                <button type="submit" id="btnManualUpload"
                                        class="btn btn-primary btn-sm">
                                    Recruitment Assign List
                                </button>
                            </a>
                            <br />
                       
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage2" id="data-table-combine"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="trheading">
                                                <th class="text-nowrap">View</th>
                                                @*<th class="text-nowrap">Assign</th>*@
                                                <th class="text-nowrap text-center">Requisition No </th>
                                                <th class="text-nowrap text-center"> Requisition Date</th>
                                                <th class="text-nowrap text-center">Company Name </th>
                                                <th class="text-nowrap text-center">Business Unit</th>
                                                <th class="text-nowrap text-center">Department Name </th>
                                                <th class="text-nowrap text-center">Designation Name</th>
                                                <th class="text-nowrap text-center">Grade Name</th>
                                                <th class="text-nowrap text-center">Priority  </th>
                                                <th class="text-nowrap text-center"> Confidential</th>
                                                <th class="text-nowrap text-center">Total Position</th>
                                                <th class="text-nowrap text-center">Position Type</th>
                                                <th class="text-nowrap text-center">Work Type</th>
                                                <th class="text-nowrap text-center">Closing Date</th>
                                                <th class="text-nowrap text-center">Requisition Status </th>
                                                <th class="text-nowrap text-center">Resource Request Raised By</th>
                                              
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.AssignRequest)
                                            {
                                                <tr>

                                                    <td class="text-center">
                                                        <button type="button" id="btnDelete" onclick="UploadCandidate('@d.DocNo','@d.ResourceId_Encrypted')"
                                                                class="btn btn-sm btn-icon btn-warning">
                                                            <i class="fa fa-eye"></i>
                                                        </button>
                                                    </td>                                                   
                                                    <td class="text-nowrap">@d.DocNo</td>
                                                    <td class="text-nowrap">@d.DocDate</td>
                                                    <td class="text-nowrap">@d.CompanyName</td>
                                                    <td class="text-nowrap">@d.BranchName</td>
                                                    <td class="text-nowrap">@d.DepartmentName</td>
                                                    <td class="text-nowrap">@d.DesignationName</td>
                                                    <td class="text-nowrap">@d.GradeName</td>
                                                    <td class="text-nowrap">@d.Priority </td>
                                                    <td class="text-nowrap">@d.Confidential</td>
                                                    <td class="text-nowrap">@d.TotalPositions</td>
                                                    <td class="text-nowrap">@d.PositionType</td>
                                                    <td class="text-nowrap">@d.WorkType</td>
                                                    <td class="text-nowrap">@d.ClosingDate</td>
                                                    <td class="text-nowrap">@d.Status</td>
                                                    <td class="text-nowrap">@d.RequestRaisedBy</td>
                                                   

                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>


<script>
    function UploadCandidate(DocNo,ResourceId_Encrypted) {
        debugger
        var url = '@Url.Action("ViewForRequestAssign", "ESS_Recruitment_RecruitmentAssign")?ResourceId_Encrypted=' + ResourceId_Encrypted + '&DocNo=' + DocNo;
        window.location.href = url;
    }
</script>