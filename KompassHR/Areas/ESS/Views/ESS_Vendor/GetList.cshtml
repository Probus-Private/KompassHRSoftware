<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Vendor-List
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_HRSpaceMenu", "ESS_HRSpaceMenu", new {id = 41, ScreenId=651, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Active Vendor - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Below is a list of all active Vendors
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="/ESS/ESS_Vendor/ESS_Vendor">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                        </div>
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <div class="row">
                                    <div class="col-md-12">
                                        <!-- BEGIN table-responsive -->
                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage VendorDetails" id="tblVendorDetails"
                                               style="width: 100%;">
                                            <thead>
                                                <tr class="text-center">
                                                    
                                                    <th class="fixed-side">Action</th>
                                                    <th class="fixed-side1">Company Name</th>
                                                    <th class="fixed-side2">Vendor Type</th>
                                                    <th class="text-nowrap width-45">Date Of Establishment</th>
                                                    <th class="text-nowrap width-45">Nature</th>
                                                    <th class="text-nowrap width-45">Registered Address</th>
                                                    <th class="text-nowrap width-45">Operational Address</th>
                                                    <th class="text-nowrap width-45">GSTIN</th>
                                                    <th class="text-nowrap width-45">PAN</th>
                                                    <th class="text-nowrap width-45">TAN</th>
                                                    <th class="text-nowrap width-45">Certificate</th>
                                                    <th>VendorId</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetEmployeeInfoList)
                                                {
                                                    <tr>
                                                        
                                                        <td class="text-center">
                                                            <button type="button" data-bs-toggle="offcanvas"
                                                                    href="#offcanvasExample" id="btnActionList" onclick="VendorDetails(this)" class="btn btnpress ListBtn">
                                                                <i class="fa-solid fa-list"></i>
                                                            </button>
                                                        </td>
                                                        <td class="text-nowrap 6">@d.CompanyName</td>
                                                        <td class="text-nowrap 7">@d.VendorType</td>
                                                        <td class="text-nowrap 8">@d.DateOfEstablishment</td>
                                                        <td class="text-nowrap 9">@d.NatureOfBusiness</td>
                                                        <td class="text-nowrap 10">@d.RegisteredAddress</td>
                                                        <td class="text-nowrap 11">@d.OprationalAddress</td>
                                                        <td class="text-nowrap 12">@d.GSTIN</td>
                                                        <td class="text-nowrap 13">@d.PAN</td>
                                                        <td class="text-nowrap 15">@d.TAN</td>
                                                        <td hidden class="text-nowrap 50">@d.Certificate</td>
                                                        <td>@d.VendorId</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </div>
        </div>
    </div>
</div>



<!-- Start panel -->
<div class="row">
    <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false"
         data-bs-scroll=true>
        <div class="offcanvas-header" style="border-bottom: 1px solid #d3d3d38a;">
            <h6 class="offcanvas-title text-center" id="VendorName"
                style="width: 100%;">
                <span id="EmpName">@Session["VendorName"]</span>
            </h6>
            <button type="button" class="btn-close text-reset"
                    data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div class="row">
                @foreach (var item in ViewBag.GetUserMenuList)
                {
                    <div class="col-md-4 col-6 d-flex justify-content-center">
                        <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" style="text-decoration:none !important;">
                            <div class="box2">
                                <div class="info">
                                    <i class="@item.Icon"></i>
                                    @*<img src="~/assets/MenuImages/@item.Icon" width="30px" height="30px" />*@
                                    <h7><b>@item.ScreenDisplayMenuName</b></h7>
                                    <div class="box2Checkmark">
                                        <i class="fa-regular fa-circle-check text-green FS-12PX" id="@($"{item.ScreenSourceMenuName}_Submit")"></i>
                                        <i class="fa-regular fa-circle-xmark text-red FS-12PX" id="@($"{item.ScreenSourceMenuName}_NotSubmit")"></i>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<script>
    function VendorDetails(tblRow) {
        debugger;
        var currentRow = $(tblRow).closest("tr");

        var CompanyName = currentRow.find("td:eq(1)").html();
        var VendorType = currentRow.find("td:eq(2)").html();
        var DateOfEstablishment = currentRow.find("td:eq(3)").html();
        var Nature = currentRow.find("td:eq(4)").html();
        var RegisteredAddress = currentRow.find("td:eq(5)").html();
        var OperationalAddress = currentRow.find("td:eq(6)").html();
        var GSTIN = currentRow.find("td:eq(7)").html();
        var PAN = currentRow.find("td:eq(8)").html();
        var TAN = currentRow.find("td:eq(9)").html();
        var VendorId = currentRow.find("td:eq(11)").html();

        $("#VendorName").html(CompanyName);

        $.ajax({
            type: "GET",
            url: '@Url.Action("VendorCheckForm", "ESS_Vendor")', 
            data: {
                VendorId:VendorId,
                CompanyName: CompanyName,
                GSTIN: GSTIN,
                PAN: PAN
            },
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                debugger;

                // Check if SetupContactDetails is false or 0 (both acceptable forms)
                if (!response.SetupContactDetails) {
                    $("#ESS_Vendor_ContactDetail_NotSubmit").show();
                    $("#ESS_Vendor_ContactDetails_Submit").hide();
                } else {
                    $("#ESS_Vendor_ContactDetail_NotSubmit").hide();
                    $("#ESS_Vendor_ContactDetails_Submit").show();
                }

                // Repeat for other sections if needed
                if (!response.SetupCompliance) {
                    $("#ESS_Vendor_Compliances_NotSubmit").show();
                    $("#ESS_Vendor_Compliances_Submit").hide();
                } else {
                    $("#ESS_Vendor_Compliances_NotSubmit").hide();
                    $("#ESS_Vendor_Compliances_Submit").show();
                }

                if (!response.SetupCapacityDomain) {
                    $("#ESS_Vendor_CapacityDomain_NotSubmit").show();
                    $("#ESS_Vendor_CapacityDomain_Submit").hide();
                } else {
                    $("#ESS_Vendor_CapacityDomain_NotSubmit").hide();
                    $("#ESS_Vendor_CapacityDomain_Submit").show();
                }

                if (!response.SetupDocumentUpload) {
                    $("#ESS_Vendor_DocumentUpload_NotSubmit").show();
                    $("#ESS_Vendor_DocumentUpload_Submit").hide();
                } else {
                    $("#ESS_Vendor_DocumentUpload_NotSubmit").hide();
                    $("#ESS_Vendor_DocumentUpload_Submit").show();
                }

                if (!response.SetupVendorAccess) {
                    $("#ESS_Vendor_VendorAccess_NotSubmit").show();
                    $("#ESS_Vendor_VendorAccess_Submit").hide();
                } else {
                    $("#ESS_Vendor_VendorAccess_NotSubmit").hide();
                    $("#ESS_Vendor_VendorAccess_Submit").show();
                }
            },
        });
    }
</script>
