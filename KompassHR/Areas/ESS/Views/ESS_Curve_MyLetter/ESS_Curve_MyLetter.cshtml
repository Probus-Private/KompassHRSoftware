<!-- Include html2pdf.js from CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script>
    var LetterName=@Html.Raw(Json.Encode(ViewBag.LetterName));
    function downloadPDF() {
        // Select the entire letter content
        const element = document.querySelector(".letter-box");

        // Dynamic file name (optional)
        const employee = "EmployeeName"; // Replace or fetch dynamically
        const today = new Date().toISOString().split("T")[0]; // YYYY-MM-DD
        const fileName = `Letter_${employee}_${today}.pdf`;

        // PDF options
        const options = {
            margin: 0.5,
            filename: LetterName,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
        };

        // Convert to PDF and save
        html2pdf().set(options).from(element).save();
    }


