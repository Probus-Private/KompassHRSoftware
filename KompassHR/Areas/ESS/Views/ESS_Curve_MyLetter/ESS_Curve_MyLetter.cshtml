<style>
    /* Common styling */
    .letter-box {
        border: 2px solid #ccc;
        background: #fff;
        padding: 50px 40px;
        border-radius: 12px;
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.08);
        font-family: 'Georgia', serif;
        font-size: 16px;
        line-height: 1.8;
        color: #333;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .formBx {
        border: 1px solid #ced4da;
        padding: 0.5rem 0.5rem;
        margin-bottom: 15px;
        padding-top: 15px;
    }

    h6 {
        margin-top: -20px;
        padding: 0 10px;
    }

    mark {
        background-color: #fff;
        font-size: 15px;
        padding: 0 5px;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .letter-box {
            padding: 30px 20px;
        }

        .letter-box h2 {
            font-size: 20px;
        }

        .letter-box p {
            font-size: 15px;
        }
    }

    /* Print-only rules */
    @@media print {
        body * {
            visibility: hidden !important;
        }

        .letter-box, .letter-box * {
            visibility: visible !important;
        }

        .letter-box {
            position: absolute !important;
            left: 0;
            top: 0;
            width: 100% !important;
            padding: 50px 40px !important;
            box-shadow: none !important;
            border: 2px solid #ccc !important;
            background: #fff !important;
        }

        .btn, button, nav, header, .breadcrumb, .row:first-child {
            display: none !important;
        }
    }
</style>



<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 style="font-size: 18px; font-family: Roboto, sans-serif; transform: translateY(4px); margin: 0;">
                Letters
            </h1>
            <ol class="breadcrumb" style="margin: 0; padding: 0; display: flex; list-style: none;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" alt="Home" style="height: 24px;">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Curve_MyLetter", "ESS_Curve_MyLetter", new { id = 20, ScreenId =678, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" alt="Back" style="height: 24px;">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 text-end mb-2">
            <!-- Confirm (Green) -->
            <button type="button" onclick="confirm()" class="btn btn-info me-2">
                <i class="fa fa-check-circle"></i> Confirm 
            </button>

            <!-- Print (Blue) -->
            <button type="button" onclick="window.print()" class="btn btn-primary me-2">
                <i class="fa fa-print"></i> Print
            </button>

            <!-- Download (Green) -->
            <button type="button" class="btn btn-success" onclick="downloadPDF()">
                <i class="fa fa-download"></i> Download
            </button>

        </div>
    </div>
    
                    <div class="row justify-content-center">
                        <div class="col-lg-10 col-md-11 col-sm-12">
                            <div class="letter-box" style="
                                 border 2px solid #ccc;
                                 background #fff;
                                 padding 50px 40px;
                                 border-radius 12px;
                                 box-shadow 0 0 20px rgba(0, 0, 0, 0.08);
                                 font-family 'Georgia' , serif;
                                 font-size 16px;
                                 line-height 1.8;
                                 color #333;
                                 position relative;
                                 ">



                                <!-- Letter Content -->
                                <div id="SomeDivWithLetter">
                                    @Html.Raw(ViewBag.Description)
                                    <textarea name="LetterTemplate" id="LetterTemplate" style="display: none;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
          
</div>


