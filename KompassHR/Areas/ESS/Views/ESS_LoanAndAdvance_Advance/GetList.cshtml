    .div1 td:nth-child(2) {
        position: sticky;
        left: 67px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 67px;
    }*/
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Advance
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_LoanAndAdvance_SubMenu", "ESS_LoanAndAdvance_SubMenu", new {id = 6, ScreenId=496, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Advance - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        View list of requested advance salary here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_LoanAndAdvance_Advance", "ESS_LoanAndAdvance_Advance", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>

                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage" id="fixed-header" style="width: 100%;">
                                                <thead>
                                                    <tr>
                                                        <th class="fixed-side">Update</th>
                                                        <th class="fixed-side1">Delete</th>
                                                        <th class="fixed-side1">Details</th>
                                                        <th class="fixed-side1">Advance Settlement</th>
                                                        <th hidden class="fixed-side1">AdvanceId</th>
                                                        <th class="text-nowrap">Doc No. </th>
                                                        <th class="text-nowrap">Doc Date </th>
                                                        <th class="text-nowrap">Employee Name </th>
                                                        <th class="text-nowrap">Advance Amount </th>
                                                        <th class="text-nowrap">From Month/Year </th>
                                                        <th class="text-nowrap">To Month/Year </th>
                                                        <th class="text-nowrap">No Of Installment </th>
                                                        <th class="text-nowrap">Installment Amount </th>
                                                        <th class="text-nowrap"> Paid Amount</th>
                                                        <th class="text-nowrap"> Balance Amount</th>
                                                        <th class="text-nowrap">Reason </th>
                                                        <th class="text-nowrap" hidden>IsAdvanceSettlement </th>
                                                        <th class="text-nowrap" hidden>Settlement Amount </th>
                                                        <th class="text-nowrap" hidden>Settlement Date </th>
                                                        <th class="text-nowrap">CreatedBy</th>
                                                        <th class="text-nowrap">CreatedDate</th>
                                                        <th class="text-nowrap">ModifiedBy</th>
                                                        <th class="text-nowrap">ModifiedDate</th>
                                                        <th class="text-nowrap">MachineName</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var d in ViewBag.GetAdvanceList)
                                                    {
                                                        <tr>

                                                            <td class="text-center">
                                                                <a onclick="UpdateAdvance('@d.AdvanceID_Encrypted')" id="UpdateBtn" style="cursor:pointer">
                                                                    <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                                </a>
                                                            </td>
                                                            <td class="text-center">
                                                                <a onclick="DeleteAdvance('@d.AdvanceID_Encrypted')" id="DeleteBtn" style="cursor:pointer">
                                                                    <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                </a>
                                                            </td>
                                                            @*<td class="text-center">
                                                                    <a onclick="DetailsAdvance('@d.AdvanceID_Encrypted')" id="DeleteBtn" style="cursor:pointer">
                                                                        <i class="fa-solid fa-eye text-primary fa-lg"></i>
                                                                    </a>
                                                                </td>*@
                                                            <td class="text-center">
                                                                <a data-bs-toggle="offcanvas"
                                                                   href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" style="cursor:pointer">
                                                                    <i class="fa-solid fa-eye text-primary fa-lg"></i>
                                                                </a>
                                                            </td>

                                                            <td class="text-center">
                                                                @if (d.IsAdvanceSettlement == "Yes")
                                                                {
                                                                    <span>Advance Settled</span>
                                                                }
                                                                else
                                                                {
                                                                    <a onclick="UpdateAdvanceSettlement('@d.AdvanceID_Encrypted')" id="UpdateAdvanceSettlementBtn" style="cursor:pointer" title="Advance Settlement">
                                                                        <i class="fa-solid fa-arrows-rotate fa-lg sm text-green-400"></i>
                                                                    </a>
                                                                }
                                                            </td>

                                                            <td hidden>@d.AdvanceID</td>
                                                            <td style="text-align:right">@d.DocNo</td>
                                                            <td>@d.DocDate</td>
                                                            <td>@d.EmployeeName</td>
                                                            <td style="text-align:right">@d.AdvanceAmount</td>
                                                            <td>@d.FromMonthYear</td>
                                                            <td>@d.ToMonthYear</td>
                                                            <td style="text-align:right">@d.NoOfInstallment</td>
                                                            <td style="text-align:right">@d.InstallmentAmount</td>
                                                            <td style="text-align:right">@d.PaidAmount</td>
                                                            <td style="text-align:right">@d.AdvanceBalance</td>
                                                            <td>@d.Remark</td>
                                                            <td hidden>@d.IsAdvanceSettlement</td>
                                                            <td hidden>@d.SettlementAmount</td>
                                                            <td hidden>@d.SettlementDate</td>
                                                            <td>@d.CreatedBy</td>
                                                            <td>@d.CreatedDate</td>
                                                            <td>@d.ModifiedBy</td>
                                                            <td>@d.ModifiedDate</td>
                                                            <td>@d.MachineName </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Start panel -->
<div class="row">
    <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false" data-bs-scroll="true">
        <div class="offcanvas-header border-bottom" style="background-color: #348fe2;">
            <h6 class="offcanvas-title text-center w-100" id="EmpName1">
                <span id="EmpName" style="color: #FFFFFF;"></span>

            </h6>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div class="row gy-3">

                <!-- Start Month Card -->
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Start Month: <span id="txtStartMonth"></span></b>
                        </div>

                    </div>
                </div>
                <br />
                <!-- End Month Card -->
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>End Month: <span id="txtEndMonth"></span></b>
                        </div>
                    </div>
                </div>
                <br />
                <!-- Advance Amount Card -->
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Advance Amount: <span id="txtAdvanceAmount"></span></b>
                        </div>
                    </div>
                </div>
                <br />
                <!-- Installment Amount Card -->
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Installment Amount: <span id="txtInstallmentAmount"></span></b>
                        </div>
                    </div>
                </div>
                <br />
                <!-- No of Installments Card -->
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>No Of Installment: <span id="txtNoOfInstallment"></span></b>
                        </div>
                    </div>
                </div>
                <br />
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Balance Amount : <span id="txtBalanceAmount"></span></b>
                        </div>
                    </div>
                </div>
                <div class="col-md-12" hidden>
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Advance Settlement (Yes/No) : <span id="txtAdvanceSettlement"></span></b>
                        </div>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Settlement Amount : <span id="txtSettlementAmount"></span></b>
                        </div>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body">
                            <b>Settlement Date : <span id="txtSettlementDate"></span></b>
                        </div>
                    </div>
                </div>
                <!-- Table Section -->
                <div class="col-md-12">
                    <div class="card shadow-sm border rounded-3">
                        <div class="card-body p-2">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle">
                                    <thead>
                                        <tr class="text-center">
                                            <th class="text-nowrap width-45">Sr.No</th>
                                            <th class="text-nowrap width-45">Month</th>
                                            <th class="text-nowrap width-45">Amount</th>
                                            <th class="text-nowrap width-45">Total Paid</th>
                                            <th class="text-nowrap width-45">Pending</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblAdvance"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div> <!-- /.row -->
        </div> <!-- /.offcanvas-body -->
    </div> <!-- /.offcanvas -->
</div>
<!-- END panel -->


<script>
    $(document).ready(function () {
        $("#ddlAdvanceEmployeeID").select2();
        $("#btnAdvanceGetList").click(function () {
            var url = '@Url.Action("GetList", "ESS_LoanAndAdvance_Advance")';
            window.location.href = url;
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

    });//Ready Funcation
</script>

<script>
    function UpdateAdvance(AdvanceID_Encrypted) {
        var url = '@Url.Action("ESS_LoanAndAdvance_Advance", "ESS_LoanAndAdvance_Advance")?AdvanceID_Encrypted=' + AdvanceID_Encrypted;
        window.location.href = url;
    }

    function UpdateAdvanceSettlement(AdvanceID_Encrypted) {
        var url = '@Url.Action("ESS_LoanAndAdvance_Advance", "ESS_LoanAndAdvance_Advance")?AdvanceID_Encrypted='
                  + AdvanceID_Encrypted + '&mode=settlement';
        window.location.href = url;
    }



    function DeleteAdvance(AdvanceID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_LoanAndAdvance_Advance")?AdvanceID_Encrypted=' + AdvanceID_Encrypted;
                //window.location.href = url;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

<script>
    function EmployeeDetails(tblRow) {
        debugger;
        var currentRow = $(tblRow).closest("tr");
        var AdvanceID = currentRow.find("td:eq(4)").html();
        var EmpName = currentRow.find("td:eq(7)").html();
        var EntryDate = currentRow.find("td:eq(6)").html();
        var StartMonth = currentRow.find("td:eq(9)").html();
        var EndMonth = currentRow.find("td:eq(10)").html();
        var NoOfInstallment = currentRow.find("td:eq(11)").html();
        var AdvanceAmount = currentRow.find("td:eq(8)").html();
        var InstallmentAmount = currentRow.find("td:eq(12)").html();
        var BalanceAmount = currentRow.find("td:eq(14)").html();
        var IsAdvanceSettlement = currentRow.find("td:eq(16)").html();
        var SettlementAmount = currentRow.find("td:eq(17)").html();
        var SettlementDate = currentRow.find("td:eq(18)").html();
        $("#EmpName").text(EmpName);
        $("#txtAdvanceAmount").text(AdvanceAmount);
        $("#txtStartMonth").text(StartMonth);
        $("#txtEndMonth").text(EndMonth);
        $("#txtNoOfInstallment").text(NoOfInstallment);
        $("#txtInstallmentAmount").text(InstallmentAmount);
        $("#txtBalanceAmount").text(BalanceAmount);
        $("#txtAdvanceSettlement").text(IsAdvanceSettlement);
        $("#txtSettlementAmount").text(SettlementAmount);
        $("#txtSettlementDate").text(SettlementDate);
        $.ajax({
            type: "GET",
            url: '@Url.Action("PayrollAdvance_Sidebar", "ESS_LoanAndAdvance_Advance")',
            data: { AdvanceID: AdvanceID },
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);

                // Clear existing rows
                $("#tblAdvance").empty();

                // Loop through each data row (array of key-value pairs)
                for (var i = 0; i < data.length; i++) {
                    var rowData = data[i]; // this is an array of key-value objects

                    var SrNo = rowData[0].Value;
                    var PaidMonthYear = rowData[1].Value;
                    var PaidAmount = rowData[2].Value;
                    var TotalPaidAmount = rowData[3].Value;
                    var PendingAmount = rowData[4].Value;

                    var row = `
                <tr class="text-center">
                    <td>${SrNo}</td>
                    <td>${PaidMonthYear}</td>
                    <td>${PaidAmount}</td>
                    <td>${TotalPaidAmount}</td>
                    <td>${PendingAmount}</td>
                </tr>
            `;

                    $("#tblAdvance").append(row);
                }
            }
        });

    }
</script>