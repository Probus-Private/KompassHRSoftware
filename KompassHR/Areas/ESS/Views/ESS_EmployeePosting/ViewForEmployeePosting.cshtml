<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>
    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>


<script>
//use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#FormCurrentOpening').validate({
        rules: {
            CandidateName: {
                required: true,
                regex:/^[a-zA-Z ]+$/
            },
            Gender: {
                required: true,

            },
            EmailId: {
                required: true,
                email:true,

            },
            MobileNo:{
                required:true,
                minimum:10,
                maximum:10,
            },
            TotalExperience:{
                required:true,
            },
            CTC:{
                required:true,
            },
            CurrentCity:{
                required:true,
                regex:/^[a-zA-Z ]+$/
            },
            CurrentWorking:{
                required:true,
            },

        },
        messages: {
            CandidateName: {
                required: "Company name is required",
                regex:"Please enter only alphabet"
            },
            Gender: {
                required: "Gender is required",

            },
            EmailId: {
                required: "EmailId code is required",
            },
            MobileNo: {
                required: "Mobile number is required",
            },
            TotalExperience: {
                required: "Total experience is required",
            },
            CTC: {
                required: "CTC is required",
            },
            CurrentCity: {
                required: "Current city is required",
            },
            CurrentWorking: {
                required: "Current working is required",
            },

        },
    });
</script>