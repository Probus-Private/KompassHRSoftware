                else{ $('#ErrorLastDesignation').html("");}

                if(CandidateType=="Experience")
                {
                    var LastDesignation=$("#txtLastDesignation").val();
                    var CurrentlyWorking=$("#txtCurrentlyWorking").val();
                    var LastCompanyName=$("#txtLastCompanyName").val();
                    var TotalExperience=$("#txtTotalExperience").val();
                    var ServingNoticePeriod=$("#txtServingNoticePeriod").val();
                    var NoticePeriodDays=$("#txtNoticePeriodDays").val();
                    if(LastDesignation=="")
                    {$('#ErrorLastDesignation').html("Current designation is required");return false}
                    if(CurrentlyWorking=="")
                    {$('#ErrorCurrentlyWorking').html("Currently working is required");return false}
                    if(LastCompanyName=="")
                    {$('#ErrorLastCompanyName').html("Last company name is required");return false}
                    if(TotalExperience=="")
                    {$('#ErrorTotalExperience').html("Total experience is required");return false}
                    if(ServingNoticePeriod=="")
                    {$('#ErrorServingNoticePeriod').html("Serving notice period is required");return false}

                }

                else{ $('#ErrorLastDesignation').html("");
                    $('#ErrorCurrentlyWorking').html("");
                    $('#ErrorLastCompanyName').html("");
                    $('#ErrorTotalExperience').html("");
                    $('#ErrorServingNoticePeriod').html("");
                    $('#ErrorNoticePeriodDays').html("");
                }

                var ResumeSource = $("#txtResumeSource option:selected").text().toLowerCase();
                var ResumeReferEmployeeId = $("#txtResumeReferEmployeeId option:selected").val();
                if(ResumeSource=="staff")
                {
                    if(ResumeReferEmployeeId!="")
                    {
                        $("#ErrorResumeReferEmployeeId").html("");
                    }
                    else{
                        $("#ErrorResumeReferEmployeeId").html("Referer Employee Name");return false;
                    }

                }
                else{
                    $("#ErrorResumeReferEmployeeId").html("");
                }

                $(".Userloaderbg").css("display", "flex");
                $("#SaveCandidateData").submit();

            } else if (
