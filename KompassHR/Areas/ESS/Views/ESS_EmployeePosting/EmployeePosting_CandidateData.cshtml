@model KompassHR.Areas.ESS.Models.ESS_Recruitment.Recruitment_Resume
@{
    ViewBag.Title = "ESS_Recruitment_CandidateData";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }


    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }



    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }


    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }


    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .Error {
        color: red;
    }

    select[readonly].select2-hidden-accessible + .select2-container .select2-selection {
        background: #eee;
        box-shadow: none;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Candidate Data
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_EmployeePosting", "ESS_EmployeePosting", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>

                </li>

            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Candidate Data - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>

                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add candidate data here !
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_EmployeePosting", new { area = "ESS" })' id="SaveCandidateData" method="post" enctype="multipart/form-data">
                                @*<form action="/ESS/ESS_Recruitment_CandidateData/SaveUpdate" id="SaveCandidateData" method="post" enctype="multipart/form-data">*@
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", id = "DocNo", type = "text", autocomplete = "Off", Value = @ViewBag.DocNo.DocNo, @readonly = "readonly", Style = "background-color: #eee;" })
                                                @Html.HiddenFor(model => model.ResumeId_Encrypted, new { id = "ResumeId_Encrypted" })
                                                @Html.HiddenFor(model => model.ResumeId)
                                                @Html.HiddenFor(model => model.Resume_ResourceId, new { id = "Resume_ResourceId", Value= @ViewBag.Resume_ResourceId })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", id = "txtDocDate", type = "date", name = "DocDate", autocomplete = "Off", @readonly = "readonly", Style = "background-color: #e9ecef;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Candidate Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Salutation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Salutation, new List<SelectListItem>{
                                                new SelectListItem {Text ="Mr.", Value="Mr."},
                                                new SelectListItem {Text ="Ms.", Value="Ms."},
                                                 new SelectListItem {Text ="Mrs.", Value="Mrs."},
                                              }, "--Select--", new { @class = "form-select", name = "Salutation", @id = "txtSalutationName" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-4">
                                                Candidate Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CandidateName, new { @class = "form-control", id = "txtCandidateName", type = "text", name = "CandidateName", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Mobile No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", id = "txtMobileNo", type = "text", name = "MobileNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">

                                            <label class="form-label col-form-label col-md-4">
                                                Alternate Mobile No

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.AlternateMobileNo, new { @class = "form-control", id = "txtAlternateMobileNo", type = "text", name = "AlternateMobileNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>

                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Email Id
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EmailId, new { @class = "form-control", id = "txtEmailId", type = "text", name = "EmailId", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Gender
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Gender, new List<SelectListItem>{
                                                                          new SelectListItem {Text ="Male", Value="Male"},
                                                                          new SelectListItem {Text ="Female", Value="Female"},
                                                                           new SelectListItem {Text ="Any", Value="Any"},
                                                                        }, "--Select--", new { @class = "form-select", id = "txtGender", type = "text", name = "Gender", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Date Of Birth
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DOB, new { @class = "form-control", id = "txtDOB", type = "date", name = "DOB", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Age

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Age, new { @class = "form-control", id = "txtAge", type = "number", name = "Age", autocomplete = "Off", onkeypress = "return event.charCode >=48", @readonly = "readonly", style = "background-color:#eee;" })
                                                <span id="ErrortxtAge" class="Error">
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current City
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CurrentCity, new { @class = "form-control", id = "txtCurrentCity", type = "text", name = "CurrentCity", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Marital Status
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.MaritalStatus,
                                               new List<SelectListItem>{new SelectListItem {Text ="Unmarried", Value="Unmarried"},
                                                                        new SelectListItem {Text ="Married ", Value="Married "},
                                                                           new SelectListItem {Text ="Widow", Value="Widow"},
                                                                        }, "--Select--", new { @class = "form-select", id = "txtMaritalStatus", type = "text", name = "MaritalStatus", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Highest Qualification <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.HighestQualification, new SelectList(ViewBag.GetQualificationName, "Id", "Name"), "--Select--", new { id = "txtHighestQualification", @class = "form-select", autocomplete = "off", name = "HighestQualification" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Specific Qualification <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.QualificationRemark, new { @class = "form-control", id = "txtQualificationRemark", type = "text", name = "QualificationRemark", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Nationality

                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Nationality, new SelectList(ViewBag.GetNationalityName, "Name", "Name"), new { id = "txtNationality", @class = "form-select", autocomplete = "off", name = "Nationality" })
                                                @*@Html.TextBoxFor(model => model.Nationality, new { @class = "form-control", id = "txtNationality", type = "text", name = "Nationality", autocomplete = "Off" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Family Info

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.FamilyDetails, new { @class = "form-control", id = "txtFamilyDetails", type = "text", name = "FamilyDetails", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Candidate Experince
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Candidate Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CandidateType,
                                                   new List<SelectListItem>{new SelectListItem {Text ="Fresher", Value="Fresher"},
                                                   new SelectListItem {Text ="Intern", Value="Intern"},
                                                   new SelectListItem {Text ="Experience", Value="Experience"},
                                                  }, "--Select--", new { @class = "form-select", id = "txtCandidateType", type = "text", name = "CandidateType", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Currently Working
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CurrentlyWorking,
                                                new List<SelectListItem>{new SelectListItem {Text ="Yes ", Value="true"},
                                                   new SelectListItem {Text ="No", Value="false"},
                                                  }, "--Select--", new { @class = "form-select", id = "txtCurrentlyWorking", type = "text", name = "CurrentlyWorking", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.CurrentlyWorking, "", new { @class = "help-block", @id = "ErrorCurrentlyWorking", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LastCompanyName, new { @class = "form-control", id = "txtLastCompanyName", type = "text", name = "LastCompanyName", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.LastCompanyName, "", new { @class = "help-block", @id = "ErrorLastCompanyName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Total Experience<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalExperience, new { @class = "form-control", id = "txtTotalExperience", type = "text", name = "TotalExperience", autocomplete = "Off", Maxlength = 2, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.TotalExperience, "", new { @class = "help-block", @id = "ErrorTotalExperience", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Relevant Experience<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.RelevantExperience, new { @class = "form-control", id = "txtRelevantExperience", type = "text", name = "RelevantExperience", autocomplete = "Off", Maxlength = 2, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.RelevantExperience, "", new { @class = "help-block", @id = "ErrorRelevantExperience", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current Designation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LastDesignation, new { @class = "form-control", id = "txtLastDesignation", type = "text", name = "LastDesignation", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.LastDesignation, "", new { @class = "help-block", @id = "ErrorLastDesignation", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Suitable For Designation<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.SutableForDesignation, new SelectList(ViewBag.Designation, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtSutableForDesignation", type = "text", name = "SutableForDesignation", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.SutableForDesignation, "", new { @class = "help-block", @id = "ErrorSutableForDesignation", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Technical Details
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TechnicalDetails, new { @class = "form-control", id = "txtTechnicalDetails", type = "text", name = "TechnicalDetails", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Communication Skill<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CommunicationSkill, new { @class = "form-control", id = "txtCommunicationSkill", type = "text", name = "CommunicationSkill", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Relevant Skill
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.RelevantSkill, new { @class = "form-control", id = "txtSkill", type = "text", name = "Skill", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Ready To Travel
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ReadyToTraval,
                            new List<SelectListItem>{new SelectListItem {Text ="Yes", Value="Yes"},
                                                   new SelectListItem {Text ="No", Value="No"},
                                                  }, "--Select--", new { @class = "form-select", id = "txtReadyToTraval", type = "text", name = "ReadyToTraval", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current CTC
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CTC, new { @class = "form-control", id = "txtCTC", type = "text", name = "CTC", autocomplete = "Off", onkeypress = " return numbervalidate(event)", Maxlength = 8 })
                                                @Html.ValidationMessageFor(model => model.ExpectedCTC, "", new { @class = "help-block", @id = "ErrorExpectedCTC", @style = "color:red" })
                                            </div>
                                        </div>
