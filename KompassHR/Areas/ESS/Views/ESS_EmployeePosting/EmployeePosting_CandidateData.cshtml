        if(allowedExtension.indexOf(type)>-1)
        {
        }
        else
        {
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf/docx/doc",
            })
            //alert('File type should be jpeg/jpg/png/pdf/docx/doc')
            document.getElementById("txtResumePath").value = null;
        }
        $("#lblFileName").text('');
    }

