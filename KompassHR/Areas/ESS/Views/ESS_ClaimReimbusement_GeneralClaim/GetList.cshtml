<script>
    function Delete(GeneralClaimId_Encrypted,Status) {

        if(Status!="Pending")
        {
            Swal.fire({
                icon: "error",
                text: "Approved/Rejected request can't delete",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                $(".Userloaderbg").css("display", "flex");
                window.location.href = '@Url.Action("Delete", "ESS_ClaimReimbusement_GeneralClaim")?GeneralClaimId_Encrypted=' + GeneralClaimId_Encrypted;
                //window.location.href = url;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }

        })
    }
</script>

<script>
    function SendCancelRequest() {
        var ddlManagerName = $('select#ddlManagerName option:selected').val();
        if (!ddlManagerName) {
            $("#ErrorMessage").html("Please select approver name");
            $("#ddlManagerName").focus();
            return false;
        }
        $("#ErrorMessage").html("");

        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes Submit!',
            cancelButtonText: 'No, cancel!'
        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                var ClaimId = localStorage.getItem('GeneralClaimId');
                var managerId = $("#ddlManagerName").val();
                var remark = $("#txtApproveRejectRemark").val();
                var origin = "GeneralClaim";
                $("#CancelModal").modal('hide');
                $(".Userloaderbg").css("display", "flex");
                
                $.ajax({
                    url: '@Url.Action("CancelRequest", "ESS_ClaimReimbusement_GeneralClaim")',
                    method: "GET",
                    data: { GeneralClaimId: ClaimId, ddlManagerId: managerId, Remark: remark, Origin: origin },
                    success: function (response) {
                        Swal.fire({
                            icon: response.Icon,
                            text: response.Message
                        }).then(() => {
                            if (response.Icon === "success") 
                            {
                                window.location.href = '@Url.Action("GetList", "ESS_ClaimReimbusement_GeneralClaim")';
                            }
                            $(".Userloaderbg").css("display","none");
                            $("#CancelModal").modal('hide');
                            $("#txtApproveRejectRemark").val("");
                        });
                    }
                });
            } else {
                $("#CancelModal").modal('hide');
                $("#ddlManagerName").val(null);
                $("#txtApproveRejectRemark").val("");
            }
        });
    }


    function DownloadFile(attachmentPath) {
        var correctedPath = attachmentPath.replace(/\//g, '\\');
        var url = '@Url.Action("DownloadAttachment", "ESS_ClaimReimbusement_GeneralClaim")';

        $.ajax({
            url: url,
            type: 'POST',
            data: { DownloadAttachment: correctedPath },
            success: function (response) {
                debugger;
                if (response.Success) {
                    var fileName = response.FileName;
                    var fileData = atob(response.FileData);  // Decode the base64 string
                    var byteArray = new Uint8Array(fileData.length);
                    for (var i = 0; i < fileData.length; i++) {
                        byteArray[i] = fileData.charCodeAt(i);
                    }

                    var blob = new Blob([byteArray], { type: response.ContentType });
                    var downloadUrl = window.URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = downloadUrl;
                    a.download = fileName;
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                    window.URL.revokeObjectURL(downloadUrl);
                }
                else {
                    Swal.fire({
                        icon: response.Icon || 'error',
                        text: response.Message || 'An error occurred.',
                        allowOutsideClick: false
                    });
                }
            },
            error: function (xhr, status, error) {
                Swal.fire({
                    icon: 'error',
                    text: 'An unexpected error occurred.',
                    allowOutsideClick: false
                });
            }
        });
    }
</script>


