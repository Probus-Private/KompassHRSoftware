<script>
    function ViewForApprover(GeneralClaimId_Encrypted, Type) {
        debugger
        Type="GeneralClaim";
        if (Type == 'GeneralClaim')
        {
            var url = '@Url.Action("ViewForGeneralClaim", "ESS_ClaimReimbusement_GeneralClaim")?GeneralClaimId_Encrypted=' + GeneralClaimId_Encrypted + '&Type=' + Type;
