    }

    function CancelRequestFun(GeneralClaimId,Status) {
        debugger;
        if(Status=="Pending" || Status=="Cancel")
        {
            if(Status=="Pending")
            {
                var Message="Pending request can't cancel";
                var Icon="error";
            }
            else{
                var Message="Request already cancel";
                var Icon="error";
            }

            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        localStorage.setItem('GeneralClaimId', GeneralClaimId);
        $("#CancelModal").modal('show');
    }
    //function CancelFuncation(TravelClaimId_Encrypted) {
    //    $('#myModalFinal').modal('show');
    //}
</script>
