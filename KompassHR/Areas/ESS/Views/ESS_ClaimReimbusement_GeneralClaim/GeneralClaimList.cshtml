
@{
    ViewBag.Title = "GeneralClaimList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
</style>


    <div id="content" class="app-content">
        <!-- BEGIN breadcrumb -->
        <ol class="breadcrumb float-xl-end">
            <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "Dashboard" })">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("ESS_ClaimReimbusement_Menu", "ESS_ClaimReimbusement_Menu", new {id = 8, ScreenId= 172, area = "ESS" })">Claim Menu</a></li>
        </ol>
        <!-- END breadcrumb -->
        <!-- BEGIN page-header -->
        <h1 class="page-header"> General Claim  </h1>
        <!-- END page-header -->
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                   
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">@*@i.SET_MODULES.FormName*@General Claim - List</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            This is the list of general claim.
                        </p>
                    </div>
                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="@Url.Action("ESS_ClaimReimbusement_GeneralClaim", "ESS_ClaimReimbusement_GeneralClaim", new { area = "ESS" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                               style="width: 100%;">
                                            <thead class="trheading">
                                                <tr>
                                                    @*<th class="fixed-side1">Cancel</th>
                                                    <th class="text-nowrap">Delete</th>*@
                                                    <th class="fixed-side1">Status</th>
                                                    <th class="text-nowrap">Auto/Manually</th>
                                                    <th class="text-nowrap">Doc No</th>
                                                    <th class="text-nowrap">Doc Date </th>
                                                    <th class="text-nowrap">Expence Category</th>
                                                    <th class="text-nowrap">Expence Amount</th>
                                                    <th class="text-nowrap">Expence Description</th>
                                                    <th class="text-nowrap">Attachment</th>
                                                    <th class="text-nowrap">ApproveRejectBy</th>
                                                    <th class="text-nowrap">ApproveRejectDate</th>
                                                    <th class="text-nowrap">ApproveRejectRemark</th>
                                                    <th class="text-nowrap">CreatedBy </th>
                                                    <th class="text-nowrap">Created Date</th>
                                                    <th class="text-nowrap">ModifiedBy</th>
                                                    <th class="text-nowrap">Modified Date </th>
                                                    <th class="text-nowrap">Machine Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GeneralClaimList)
                                                {
                                                    <tr>
                                                        @*<td class="text-center">
                                                            <button type="button" onclick="CancelFuncation('@d.GeneralClaimId_Encrypted')" id="btnDelete"
                                                                    class="btn btn-success ListBtn btnpress">
                                                                <i class="fa fa-times"></i>
                                                            </button>
                                                        </td>
                                                        
                                                        <td class="text-center fixed-side1">
                                                            <button type="button" onclick="DeleteGeneralClaims('@d.GeneralClaimId_Encrypted')" id="btnDelete"
                                                                    class="btn btn-danger ListBtn btnpress">
                                                                <i class="fa-solid fa-trash-alt"></i>
                                                            </button>
                                                        </td>*@
                                                        <td class="text-nowrap">@d.Status</td>
                                                        <td class="text-nowrap">@d.AutoApproval</td>
                                                        <td class="text-nowrap">@d.DocNo</td>
                                                        <td class="text-nowrap">@d.DocDate</td>
                                                        <td class="text-nowrap">@d.ExpenseCategoryName</td>
                                                        <td class="text-nowrap">@d.GeneralClaimAmount</td>
                                                        <td class="text-nowrap">@d.GeneralClaimDescription</td>
                                                        @if (d.AttachmentPath != "No" && d.AttachmentPath != "System.Web.HttpPostedFileWrapper")
                                                        {
                                                            <td class="text-center">
                                                                <a href="@Url.Action("DownloadAttachment","ESS_ClaimReimbusement_GeneralClaim", new { GeneralClaimId_Encrypted = @d.GeneralClaimId_Encrypted, GeneralClaimId = @d.GeneralClaimId })"><i class="fa fa-download"></i></a>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td>
                                                                File Not Found
                                                            </td>
                                                        }
                                                        <td class="text-nowrap">@d.ApproveRejectBy</td>
                                                        <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                        <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                        <td class="text-nowrap">@d.CreatedBy</td>
                                                        <td class="text-nowrap">@d.CreatedDate</td>
                                                        <td class="text-nowrap">@d.ModifiedBy</td>
                                                        <td class="text-nowrap">@d.ModifiedDate</td>
                                                        <td class="text-nowrap">@d.MachineName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- END panel -->
                    </div>
                </div>
            </div>
        </div>
    </div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            });
        }
    });//Ready Funcation
</script>

