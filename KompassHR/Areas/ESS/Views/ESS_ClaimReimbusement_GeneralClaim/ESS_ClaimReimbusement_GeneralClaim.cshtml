                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Amount
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => Model.GeneralClaimAmount, new { @class = "form-control mb-5px", id = "ExpenceAmount", name = "GeneralClaimAmount", type = "number", onkeypress = "return isNumberKey(event,this)", @style = "text-align:right" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-2">
                                                    Description
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-10">
                                                    @Html.TextAreaFor(model => model.GeneralClaimDescription, new { @class = "form-control", id = "ExpenceDescription", name = "ExpenceDescription" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Attachment
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => Model.AttachmentPath, new { @type = "file", name = "AttachmentPath", @class = "form-control", id = "AttachmentPath", @onchange = "ResetFile()" })

                                                    @if (Model.AttachmentPath != null)
                                                    {
                                                        if (Model.AttachmentPath != "No")
                                                        {
                                                            <p>
                                                                Existing File:
                                                                <a href="@Url.Action("DownloadAttachment", "ESS_ClaimReimbusement_GeneralClaim", new { GeneralClaimId_Encrypted = Model.GeneralClaimId_Encrypted })">Download Existing File</a>
                                                            </p>
                                                        }
                                                    }
                                                </div>

                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit"
                                                                    class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-floppy-disk"></i>
                                                                Submit
                                                            </button>
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm" id="btnGeneralClaimGetList">
                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
</div>


                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>

