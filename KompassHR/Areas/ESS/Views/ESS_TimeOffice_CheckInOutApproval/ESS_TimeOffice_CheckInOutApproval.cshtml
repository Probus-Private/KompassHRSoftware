<script>


    document.getElementById("txtFromDate").addEventListener("blur", function () {
        debugger
        var dateValue = this.value;

        if (dateValue.includes("-")) {
            var parts = dateValue.split("-");
            dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
        }
        var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
        if (!regex.test(dateValue)) {
            $("#ErrortxtFromDate").html("Please enter valid date in DD-MM-YYYY format");
            this.value = "";
            this.focus();
            return;
        } else {
            $("#ErrortxtFromDate").html("");
        }
    });


    document.getElementById("txtToDate").addEventListener("blur", function () {
        debugger
        var dateValue = this.value;

        if (dateValue.includes("-")) {
            var parts = dateValue.split("-");
            dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
        }
        var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
        if (!regex.test(dateValue)) {
            $("#ErrortxtToDate").html("Please enter valid date in DD-MM-YYYY format");
            this.value = "";
            this.focus();
            return;
        } else {
            $("#ErrortxtToDate").html("");
        }
    });

</script>

<script>
    function openMap() {
        debugger;
        let CheckInOutLocationId = $('#txtLocationName option:selected').val();
        if (CheckInOutLocationId == "") {
            $('#ErrorLocationName').html("Location name is required");
            return false;
        } else {
            $('#ErrorLocationName').html("");
        }

        var latitude = $("#txtDatabaseLatitude").val();
        var longitude = $("#txtDatabaseLongitude").val();

        if (isNaN(latitude) || isNaN(longitude) || latitude === "" || longitude === "") {
            $('#ErrorLocationName').html("Valid latitude and longitude are required");
            return false;
        }

        var mapsUrl = "https://www.google.com/maps?q=" + latitude + "," + longitude + "&z=15&output=embed";

        // Open the URL in a new tab
        window.open(mapsUrl, "_blank");
    }

</script>

<script>
    function ViewMap(latitude, longitude) {
        debugger;

        // Validate
        if (isNaN(latitude) || isNaN(longitude) || latitude === "" || longitude === "") {
            alert("Valid latitude and longitude are required");
            return false;
        }

        $('#ErrorLocationName').html(""); // clear any previous error

        // Google Maps URL
        var mapsUrl = "https://www.google.com/maps?q=" + latitude + "," + longitude + "&z=15&output=embed";

        // Open in new tab
        window.open(mapsUrl, "_blank");
    }
</script>

<script>
    function ViewSelfie(filePath, dateTime, locationName, direction,Id) {
        debugger;
        const encoded = encodeURIComponent(filePath);
        const selfieUrl = '/ESS_TimeOffice_CheckInOutApproval/ViewSelfie?filePath=' + encoded + '&EmployeeId=' + Id;;

        $('#selfieImage').attr('src', selfieUrl);

        const formattedDateTime = new Date(dateTime).toLocaleString('en-IN', {
            dateStyle: 'medium',
            timeStyle: 'short'
        });

        $('#selfieDetails').html(`
        <table class="table table-borderless mb-0" style="font-size: 14px;">
            <tr>
                <td><strong>&nbsp;📍&nbsp; Location</strong></td>
                <td>: ${locationName}</td>
            </tr>
            <tr>
                <td><strong>➡️ Direction</strong></td>
                <td>: ${direction}</td>
            </tr>
            <tr>
                <td><strong>🕒 Date & Time</strong></td>
                <td>: ${formattedDateTime}</td>
            </tr>
        </table>
    `);

        $('#selfieModal').modal('show');
    }



    function OpenModal()
    {
        debugger;
        let CheckInOutLocationId = $('#txtLocationName option:selected').val();
        if(CheckInOutLocationId=="")
        {
            $('#ErrorLocationName').html("Location name is required");

            return false;
        }
        else{ $('#ErrorLocationName').html("");}
        $("#myModal").modal('show');
    }

</script>
<script>
    $(document).ready(function () {
        $("#ddlEmployeeId").select2();

        $('.TabledataBulkClass').DataTable({
            scrollY: 350,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true,
            stripeClasses: []
        });
    });


    jQuery.validator.addMethod(
"regex",
 function (value, element, regexp) {
     if (regexp.constructor != RegExp)
         regexp = new RegExp(regexp);
     else if (regexp.global)
         regexp.lastIndex = 0;
     return this.optional(element) || regexp.test(value);
 }, "erreur expression reguliere"
);


    $('#formCheckInOutApproval').validate({
        rules: {
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },
            //EmployeeId: {
            //    required: true,
            //},
        },
        messages: {
            FromDate: {
                required: "From Date is required",
            },
            ToDate: {
                required: "To Date is required",
            },
            //EmployeeId: {
            //    required: "Employee Name is required",
            //},
        },
    });
    var form = $("#formCheckInOutApproval");
    form.validate();

    function Show() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#Date").removeClass('error');
            return false;
        }

        var from = $("#txtFromDate").val();
        var to = $("#txtToDate").val();
        if (Date.parse(from) > Date.parse(to)) {

            $("#ErrorToDate").html("From date should not be greater than todate");
            return false;
        }
        else {
            $("#ErrorToDate").html("");
        }

        $("#formCheckInOutApproval").submit();
    }

    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

    function AllApproveReject(Status) {
        debugger;
        $("#SelectAll").prop("checked", false);
        debugger;
        const RecordList = [];
        var RejectRemark = document.getElementById("txtApproveRejectRemark").value;

        $("#tbodyApproveReject tr input[type='checkbox']:checked").each(function () {
            var data = {};
            var currentRow = $(this).closest("tr");
            data.CheckInOutId = currentRow.find("td:eq(8)").text().trim(); // Column index 7 (8th column)
            data.Status = Status; // assuming 'Status' is defined somewhere
            data.Remark = RejectRemark; // assuming 'RejectRemark' is defined somewhere
            RecordList.push(data);
        });


        if (RecordList == "") {
            debugger;
            //  $("#myModalFinal").modal('hide');
            document.getElementById("txtApproveRejectRemark").value = "";
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        const dataToSend = {
            model: {
                ObjCheckInOut: RecordList
            },
        };
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: "@Url.Action("MultipleApproveRejectRequest", "ESS_TimeOffice_CheckInOutApproval")",
            data: JSON.stringify(dataToSend),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("ESS_TimeOffice_CheckInOutApproval", "ESS_TimeOffice_CheckInOutApproval")';
                        window.location.href = url;
                    });
                }
            }
        });
    }

    $("#txtFromDate, #txtToDate").on("change", function () {
        var from = $("#txtFromDate").val();
        var to = $("#txtToDate").val();
        if (Date.parse(from) > Date.parse(to)) {

            $("#ErrorToDate").html("To date always greater than From date");
            return false;
        }
        else {
            $("#ErrorToDate").html("");
        }
    });

    function AssignTaskDesc(encodedHtml) {
        debugger;
        $('#txtTaskStatus').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtTaskStatus').html(AssignDesc);
            //$('#txtTaskStatus').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#TaskDescription').html('');
        $('#tblTask tr').not(function () { return !!$(this).has('th').length; }).remove();
        $('#' + modalId).modal('hide');
    }
</script>