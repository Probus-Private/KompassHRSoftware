                    </a>
                </li>
            </ol>
        </div>
    </div>

    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">Check In/Out Approval- List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of check in/out for approve reject.
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <form role="form" action='@Url.Action("ESS_TimeOffice_CheckInOutApproval", "ESS_TimeOffice_CheckInOutApproval", new { area = "ESS" })' id="formCheckInOutApproval" method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        From Date
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", id = "txtFromDate", type = "Date", name = "FromDate" })
                                        @Html.ValidationMessageFor(model => model.FromDate, "", new { @class = "help-block", @id = "ErrortxtFromDate", @style = "color:red" })

                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        To Date
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", id = "txtToDate", type = "Date", name = "ToDate" })
                                        @Html.ValidationMessageFor(model => model.ToDate, "", new { @class = "help-block", @id = "ErrortxtToDate", @style = "color:red" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-2 col-12">
                                        Employee Name
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-4 col-10">
                                        @Html.DropDownListFor(model => model.EmployeeId, new SelectList(ViewBag.GetEmployees, "Id", "Name"), "--All--", new { @class = "form-control", id = "ddlEmployeeId", type = "text", name = "EmployeeId", autocomplete = "Off" })
                                    </div>
                                    <div class="col-md-2 col-2">
                                        <button type="button" onclick="Show()" class="btn btn-sm btn-success">
                                            Show
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <hr/>
                    <div class="row">
                        <div class="col-md-12 overflow-auto">
                            <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass" id="data-table-combine"
                                   style="width: 100%;">
                                <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                    <tr>
                                        <th class="text-nowrap text-center">All <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                        <th class="text-nowrap">Employee Name</th>
                                        <th class="text-nowrap">Location Name</th>
                                        <th class="text-nowrap">Type</th>
                                        <th class="text-nowrap">Origin</th>
                                        <th class="text-nowrap">Check In/Out Date </th>
                                        <th class="text-nowrap">Latitue </th>
                                        <th class="text-nowrap">Longitude </th>
                                        <th class="text-nowrap" hidden>CheckInOutId </th>
                                        <th class="fixed-side text-center">Remark</th>
                                        <th class="fixed-side text-center">Map View</th>
                                        <th class="text-nowrap">Selfie </th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyApproveReject">
                                    @foreach (var d in ViewBag.CheckInOutApproveRejectList)
                                    {
                                        <tr>
                                            <td><center><input type="checkbox" class="form-check-input" /></center></td>
                                            <td>@d.EmployeeName</td>
                                             <td>@d.LocationName</td>
                                            <td>@d.CheckInOutDirection</td>
                                            @if (@d.Origin != "")
                                            {
                                                <td>@d.Origin</td>
                                            }
                                            else
                                            {
                                                <td></td>
                                            }
                                            <td>@d.CheckInOutDateTime</td>
                                            <td>@d.CheckInOutLatitude</td>
                                            <td>@d.CheckInOutLongitude</td>
                                            <td hidden>@d.CheckInOutId</td>
                                            <td class="text-start text-center">
                                                <input type="hidden" id="hiddenDescription_@d.CheckInOutId" value="@d.Remarks" />
                                                <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.CheckInOutId').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                            </td>
                                            <td class="text-center">
                                                <i class="fa-solid fa-eye text-warning fa-lg" style="cursor: pointer;"
                                                   onclick="ViewMap('@d.CheckInOutLatitude', '@d.CheckInOutLongitude')"></i>
                                            </td>
                                            @if (d.SelfiePath != null)
                                            {
                                                <td class="text-center">
                                                    <i class="fa-solid fa-eye text-warning fa-lg" style="cursor: pointer;"
                                                       @*onclick="ViewSelfie('@d.SelfiePath','@d.CheckInOutDateTime','@d.LocationName','@d.CheckInOutDirection','@d.CheckInOutId')"></i>*@
                                                      onclick="ViewSelfie('@d.SelfiePath','@d.CheckInOutDateTime','@d.LocationName','@d.CheckInOutDirection','@d.EmployeeId')"></i>
                                                </td>
                                            }
                                            else
                                            {
                                                <td></td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row mb-20px">
                        <div class="LastShortLeaveBx">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            Remark
                                        </label>
                                        <div class="col-md-10">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="1"></textarea>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" class="btn btn-primary btn-sm" id="btnAllApprove" onclick="AllApproveReject('Approved')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Approve
                                                </button>
                                                <button type="button" class="btn btn-danger btn-sm" id="btnAllApprove" onclick="AllApproveReject('Rejected')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Reject
                                                </button>
                                                <a href="@Url.Action("GetApproveRejectList", "ESS_TimeOffice_CheckInOutApproval", new { area = "ESS" })">
                                                    <button type="button" class="btn btn-success btn-sm">
                                                        <i class="fa-solid fa-share-from-square"></i> Approve Reject List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>

