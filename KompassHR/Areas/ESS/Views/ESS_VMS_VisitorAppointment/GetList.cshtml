
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Visitor Appointment
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_VMS_Menu", "ESS_VMS_Menu",  new { id = 10,ScreenId=184, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Visitor Appointment - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of visitor appointments.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_VMS_VisitorAppointment", "ESS_VMS_VisitorAppointment", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                           style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th class="text-nowrap">Update</th>
                                                <th class="text-nowrap">Delete</th>
                                                <th class="text-nowrap">Doc No</th>
                                                <th class="text-nowrap">Company </th>
                                                <th class="text-nowrap">Business unit </th>
                                                <th class="text-nowrap">Visiting Business unit </th>
                                                <th class="text-nowrap">Appointment Date </th>
                                                <th class="text-nowrap">Appointment Time </th>
                                                <th class="text-nowrap">Visitor Name </th>
                                                <th class="text-nowrap">Host Name </th>
                                                @*<th class="text-nowrap">Entry Name </th>*@
                                                <th class="text-nowrap">Designation </th>
                                                <th class="text-nowrap">Visitor Type </th>
                                                <th class="text-nowrap">Addition Person </th>
                                                <th class="text-nowrap">MobileNo </th>
                                                <th class="text-nowrap">EmailID</th>
                                                <th class="text-nowrap">Visitor Company Name</th>
                                                <th class="text-nowrap">VIP </th>
                                                <th class="text-nowrap">Pupose</th>
                                                <th class="text-nowrap">Remark </th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.VisitorAppointment)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <a onclick="UpdateVisitorAppointment('@d.VisitorAppointmentID_Encrypted','@d.CmpId')" id="UpdateBtn" style="cursor:pointer;">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-center">
                                                        <a onclick="DeleteVisitorAppointment('@d.VisitorAppointmentID_Encrypted')" id="DeleteBtn" style="cursor:pointer;">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>

                                                    <td>@d.DocNo</td>
                                                    <td>@d.CompanyName</td>
                                                    <td>@d.BranchName</td>
                                                    <td>@d.VisitingBranchName</td>
                                                    <td>@d.AppointmentDate</td>
                                                    <td>@d.AppointmentTime</td>
                                                    <td>@d.VisitorName</td>
                                                    <td>@d.HostName</td>
                                                    <td>@d.Designation</td>
                                                    <td>@d.VisitorTypeName</td>
                                                    <td>@d.AdditionPerson</td>
                                                    <td>@d.MobileNo</td>
                                                    <td>@d.EmailID</td>
                                                    <td>@d.Company</td>
                                                    <td>@d.IsSpecial</td>
                                                    <td>@d.Purpose</td>
                                                    <td>@d.VisitorRemark</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>
    $('#fixed-header').DataTable({
        scrollY: 300,
        scrollX: true,
        scrollCollapse: true,
        searching: true,
        paging: true,
        fixedColumns: true,
        info: true,
        responsive: false
    });
</script>

<script>
    function UpdateVisitorAppointment(VisitorAppointmentID_Encrypted ,CmpId) {
        var url = '@Url.Action("ESS_VMS_VisitorAppointment", "ESS_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted + '&CmpId='+ CmpId;;
        window.location.href = url;    }

    function DeleteVisitorAppointment(VisitorAppointmentID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_VMS_VisitorAppointment")?VisitorAppointmentID_Encrypted=' + VisitorAppointmentID_Encrypted;
                //window.location.href = url;
                //leteButtons.fire(
                //  'Deleted!',
                //  'Your file has been deleted.',
                //  'success'
                //
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


</script>
