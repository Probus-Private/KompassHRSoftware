@model KompassHR.Areas.ESS.Models.ESS_TimeOffice.Leave_Master
@{
    ViewBag.Title = "ESS_TimeOffice_LeaveList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>


<!-- Required library for validation -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/additional-methods.min.js"></script>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new { id = 4, ScreenId=145, area = "ESS" })">Leave Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Leave</h1>
    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="@Url.Action("ESS_TimeOffice_Leave", "ESS_TimeOffice_Leave", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px"> <i class="fa-solid fa-plus"></i> &nbsp; Add </button>
                            </a>
                        </div>
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine"
                                       style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th hidden>LeaveMasterId_Encrypted</th>
                                            <th hidden>DocNo</th>
                                            <th class="fixed-side">Cancel</th>
                                            <th class="fixed-side1">Delete</th>
                                            <th class="fixed-side1">Status</th>
                                            <th class="text-nowrap text-center">Auto/Manually</th>
                                            <th class="text-nowrap text-center">Doc No </th>
                                            <th class="text-nowrap text-center">Doc Date </th>
                                            <th class="text-nowrap text-center">Day Type</th>
                                            <th class="text-nowrap text-center">Leave Type</th>
                                            <th class="text-nowrap text-center">For Date</th>
                                            @* <th class="text-nowrap text-center">For Time</th>*@
                                            <th class="text-nowrap text-center">Reason</th>
                                            <th class="text-nowrap text-center">Approve/Rejected by</th>
                                            <th class="text-nowrap text-center">Approve/Rejected Date</th>
                                            <th class="text-nowrap text-center">Rejected Reason</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.AllLeaves)
                                        {
                                            <tr>
                                                <th hidden>@d.LeaveMasterId_Encrypted</th>
                                                <th hidden>@d.DocNo</th>
                                                @if (@d.status == "L1- Approved" || @d.status == "L2- Approved")
                                                {
                                                    <td class="text-center">
                                                        <button href="#modal-dialogForHoldReject1" onclick="OpenModule('@d.DocNo','@d.LeaveMasterId_Encrypted')" type="button" class="btn btn-danger btnpress ListBtn" id="btnmodal-dialog1">
                                                            <i class="fa-solid fa-xmark"></i>
                                                        </button>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td class="text-center"></td>
                                                }

                                                @if (@d.status == "L1- Approved" || @d.status == "L2- Approved")
                                                {
                                                    <td class="text-center"></td>
                                                }
                                                else
                                                {
                                                    <td class="text-center">
                                                        <button type="button" id="btnDelete" onclick="DeleteLeave('@d.LeaveMasterId_Encrypted')"
                                                                class="btn btn-danger ListBtn btnpress">
                                                            <i class="fa-solid fa-trash-alt"></i>
                                                        </button>
                                                    </td>
                                                }
                                               
                                                <td class="text-nowrap">@d.ApprovedDay</td>
                                                <td class="text-nowrap">@d.ApprovedAutoManually</td>
                                                <td class="text-nowrap text-center">@d.DocNo</td>
                                                <td class="text-nowrap">@d.CreatedDate</td>
                                                <td class="text-nowrap">@d.LeaveMasterDayType</td>
                                                <td class="text-nowrap">@d.LeaveTypeShortName</td>
                                                <td class="text-nowrap">@d.ForDate</td>
                                                @*<td class="text-nowrap">@d.ForTime</td>*@
                                                <td class="text-nowrap">@d.Reason</td>
                                                <td class="text-nowrap">@d.ApproverName</td>
                                                <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Reject</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Approved('Cancel')" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress btn-sm CloseModel" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    let DocNo="";
    let LeaveMasterId_Encrypted="";


    function OpenModule(DocNo, LeaveMasterId_Encrypted) {
        debugger;

        DocNo = DocNo;
        LeaveMasterId_Encrypted = LeaveMasterId_Encrypted;
        localStorage.setItem('DocNo', DocNo);
        localStorage.setItem('LeaveMasterId_Encrypted', LeaveMasterId_Encrypted);

        $("#myModalFinal").modal('show');
    }

    function Approved(Approver) {
        {
            debugger

            var DocNo = localStorage.getItem('DocNo');
            var LeaveMasterId_Encrypted = localStorage.getItem('LeaveMasterId_Encrypted');

            const Approved = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            Approved.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes submit!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,

                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    debugger;

                    var DocId = $("#hdnLeaveId").val();
                    var Encrypted = $("#hdnEncryptedId").val();
                    var Origin = "Leave";

                    var Status = "";
                    var Remark = "";
                    if (Approver == "Cancel") {
                        Remark = $("#txtApproveRejectRemark").val();
                        Status = "Cancel";
                    }
                    //else {
                    //    Status = "Approved";
                    //}
                    $("#myModalFinal").modal('hide');
				  $(".Userloaderbg").css("display", "flex");
                    $.ajax({
                        url: "@Url.Action("ApproveLeaveRequest", "ESS_TimeOffice_Leave")",
                        method: "get",
                        data: { DocId: DocNo, Encrypted: LeaveMasterId_Encrypted, Status: Status, Remark: Remark, Origin: Origin },
                        success: function (response) {
                            debugger;
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (response.Icon == "error") {
                                if (Message1 != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        });

                                        $("#myModalFinal").modal('hide');
                                        $("#txtApproveRejectRemark").val("")
                                        .then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("ESS_TimeOffice_LeaveList", "ESS_TimeOffice_Leave")';
                                            } else if (
                                                /* Read more about handling dismissals below */
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {

                                            }
                                        })
                                    }
                                }
                            }
                            else {
                                var Message1 = response.Message;
                                var Icon1 = response.Icon;
                                if (response.Icon == "success") {
                                    if (Message1 != null) {
                                        if (Message1 != null) {
                                            Swal.fire({
                                                icon: Icon1,
                                                text: Message1,
                                                allowOutsideClick: () => {
                                                    const popup = Swal.getPopup()
                                                    popup.classList.remove('swal2-show')
                                                    setTimeout(() => {
                                                        popup.classList.add('animate__animated', 'animate__headShake')
                                                    })
                                                    setTimeout(() => {
                                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                                    }, 500)
                                                    return false
                                                }
                                            })
                                            .then((result) => {
                                                if (result.isConfirmed) {
                                                    window.location.href = '@Url.Action("ESS_TimeOffice_LeaveList", "ESS_TimeOffice_Leave")';
                                                } else if (
                                                    /* Read more about handling dismissals below */
                                                    result.dismiss === Swal.DismissReason.cancel
                                                ) {
                                                }
                                            })
                                            $("#myModalFinal").modal('hide');
                                            $("#txtApproveRejectRemark").val("");
                                        }
                                    }
                                }
                            }
                        }
                    });

                } else if (
                    /* Read more about handling dismissals below */
                            result.dismiss === Swal.DismissReason.cancel
                    ) {
                    $("#myModalFinal").modal('hide');
                    $("#ddlManagerName").val(null);
                    $("#txtApproveRejectRemark").val("");
                }
            })
        }
    }

    function DeleteLeave(LeaveMasterId_Encrypted) {

        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                $(".Userloaderbg").css("display", "flex");
                window.location.href = '@Url.Action("LeaveDelete", "ESS_TimeOffice_Leave")?LeaveMasterId_Encrypted='
                              + encodeURIComponent(LeaveMasterId_Encrypted);

                @*window.location.href = '@Url.Action("LeaveDelete", "ESS_TimeOffice_Leave")?LeaveMasterId_Encrypted=' + LeaveMasterId_Encrypted;*@

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>
