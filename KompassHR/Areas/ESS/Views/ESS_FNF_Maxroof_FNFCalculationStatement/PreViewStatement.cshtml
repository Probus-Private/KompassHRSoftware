<script>
    $("#btnSalaryDetailsList").on("click", function () {
        debugger

        var FNFCal_EmployeeId = $("#ddlFnfEmployee").val();

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetSalaryDetails", "ESS_FNF_Maxroof_FNFCalculationStatement")',
            data: { FNFCal_EmployeeId: FNFCal_EmployeeId },
            success: function (response) {
                debugger;

                let list = response.salaryList;
                let rows = "";

                if (!list || list.length === 0) {
                    $("#SalaryDetailsTableBody").html("<tr><td colspan='4'>No Data</td></tr>");
                    return;
                }

                list.forEach(function (item) {
                    // Convert array of Key/Value to object
                    let obj = {};
                    item.forEach(function (kv) {
                        obj[kv.Key] = kv.Value;
                    });

                    rows += `
                <tr>
                    <td class="text-nowrap">${obj.MonthYear || ''}</td>
                    <td class="text-end text-nowrap">${obj.SalaryPayableDays || 0}</td>
                    <td class="text-end text-nowrap">${obj.SalaryNetPay || 0}</td>
                    <td class="text-nowrap">${obj.Salary_IsHold || ''}</td>
                </tr>`;
                });

                $("#SalaryDetailsTableBody").html(rows);
            }
        });

    });
</script>
