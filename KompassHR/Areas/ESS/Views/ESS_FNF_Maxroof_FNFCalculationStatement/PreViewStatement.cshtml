<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Calculation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action(" Dashboard", "Dashboard" , new { area="" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu" , new { id=7, ScreenId=168, area="ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="alert alert-warning alert-dismissible rounded-0 mb-0 fade show">
        FNF Calculation Statement for print.
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-body combined-table-border table-container">
                    <div class="col-md-12 text-end">
                        <div class="BtnBx">
                            <div>
                                <button type="button" class="btn btn-info" id="btlPrintInvoice" onclick="DownloadInvoice()" hidden>
                                    <i class="fa-solid fa-download fa-xl"></i> Download
                                </button>
                                <button type="button" class="btn btn-success" id="btlPrintInvoice" onclick="PrintInvoice()">
                                    <i class="fa-solid fa-print fa-xl"></i> Print
                                </button>

                                <a href="@Url.Action("GetList", "ESS_FNF_Maxroof_FNFCalculationStatement" , new { area="ESS" })">
                                    <button type="button" class="btn btn-danger btn-sm" id="btnTrainingAgency">
                                        <i class="fa-solid bi-file-arrow-down"></i> Back
                                    </button>
                                </a>
                            </div>
                        </div>
                    </div>
                    <form role="form">
                        @if (ViewBag.GetFNFCalculationsdetailsList != null)
                        {
                            <div class="fnf-container" id="divPrint">
                                <div class="company-header">
                                    <!-- LOGO RIGHT TOP -->
                                    <div class="logo-top">
                                        <img src="@Session[" CompanyLogo"]" id="CompanyLogo" />
                                    </div>
                                    <!-- CENTER CONTENT -->
                                    <div class="company-center">
                                        <div class="company-name">
                                            @ViewBag.GetFNFCalculationsdetailsList.CompanyName
                                        </div>

                                        <div class="company-address">
                                            @ViewBag.GetFNFCalculationsdetailsList.Address
                                        </div>

                                        <div class="report-title">
                                            FINAL SETTLEMENT
                                        </div>
                                    </div>

                                </div>
                                <hr />

                                <div class="employee-details">
                                    <div class="row">
                                        <!-- First Column -->
                                        <div class="col-md-12">
                                            <div class="detail-row">
                                                <div class="detail-label">Employee No</div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.EmployeeNo</div>
                                            </div>

                                            <div class="detail-row">
                                                <div class="detail-label">Employee Name </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.EmployeeName </div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Department </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.Department</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Designation </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.Designation</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Location </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.BusinessUnit</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Date Of Joining </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.DOJ</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Resignation Date </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.ResignationDate</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Last Working Date </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.LastWorkingDate</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Last Salary Paid </div>
                                                <div>: @ViewBag.GetFNFCalculationsdetailsList.LastSalaryPaidMonth</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Notice Period as per application letter</div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.ShortFallNoticePay_Days}")</div>
                                            </div>

                                            <div class="detail-row">
                                                <div class="detail-label">Notice Period adjustable </div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.ShortFallNoticePay_Days}")</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">PL days payable </div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.PLDays}")</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Payable Days </div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.PayableDays}")</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Month Days </div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.MonthDays}")</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">LOP Days </div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.LOPDays}")</div>
                                            </div>
                                            <div class="detail-row">
                                                <div class="detail-label">Effective Workdays </div>
                                                <div>: @($"{ViewBag.GetFNFCalculationsdetailsList.EffectiveWorkDays}")</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>



                                <table class="salary-table">
                                    <thead>
                                        <tr>
                                            <th style="width:50%;text-align:center;" colspan="2"><b>Income</b></th>
                                            <th style="width:50%;text-align:center;" colspan="2"><b>Deduction </b></th>
                                        </tr>

                                    </thead>

                                    <tbody>
                                        @{
                                            var earnings = ViewBag.earnings as List<dynamic>;
                                            var deductions = ViewBag.deductions as List<dynamic>;

                                            int earnCount = earnings != null ? earnings.Count : 0;
                                            int dedCount = deductions != null ? deductions.Count : 0;

                                            int max = Math.Max(earnCount, dedCount);
                                        }

                                        @for (int i = 0; i < max; i++)
                                        {
                                            var e = (earnings != null && i < earnings.Count) ? earnings[i] : null;
                                            var d = (deductions != null && i < deductions.Count) ? deductions[i] : null;

                                            <tr>
                                                <td style="text-align:left;" class="label">
                                                    @(e != null ? (e.DisplayHead ?? e.Head) : "")
                                                </td>
                                                <td class="amount">
                                                    @(e != null ? e.EarningAmt : "")
                                                </td>

                                                <td style="text-align:left;" class="label">
                                                    @(d != null ? (d.DisplayHead ?? d.Head) : "")
                                                </td>
                                                <td class="amount">
                                                    @(d != null ? d.DeductionAmt : "")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tr>
                                        <td colspan="2" rowspan="2"></td>
                                        <td class="label">Advance:</td>
                                        <td style="text-align:right">@ViewBag.GetFNFCalculationsdetailsList.Advance</td>
                                    </tr>

                                    <tr>
                                        @*<td colspan="2"></td>*@
                                        <td class="label">TDS:</td>
                                        <td style="text-align:right">@ViewBag.GetFNFCalculationsdetailsList.TDS</td>
                                    </tr>
                                    <tr>
                                        <td class="label">Total Income:</td>
                                        <td style="text-align:right">@ViewBag.GetFNFCalculationsdetailsList.TotalIncome</td>
                                        <td class="label">Total Deduction:</td>
                                        <td style="text-align:right">@ViewBag.GetFNFCalculationsdetailsList.TotalDeduction</td>
                                    </tr>
                                    <tr>
                                        <td class="label"> Gratuity Applicable</td>
                                        <td>@ViewBag.GetFNFCalculationsdetailsList.Gratuity_Applicable</td>
                                        <td class="label">Total Service.</td>
                                        <td>@ViewBag.GetFNFCalculationsdetailsList.Gratuity_Service</td>
                                    </tr>
                                    <tr>
                                        <td class="label">Gratuity </td>
                                        <td style="text-align:right">@ViewBag.GetFNFCalculationsdetailsList.GratuityAmount</td>
                                        <td style="text-align:left" colspan="2">@ViewBag.GetFNFCalculationsdetailsList.GratuityAmountInWord</td>
                                    </tr>
                                    <tr>
                                        <td class="label">Net Pay </td>
                                        <td style="text-align:right">@ViewBag.GetFNFCalculationsdetailsList.FinalNetPayable</td>
                                        <td style="text-align:left" colspan="2">@ViewBag.GetFNFCalculationsdetailsList.FinalNetPayableInWord</td>
                                    </tr>
                                    <tr>
                                        <td class="label">Remark:</td>
                                        <td class="label" colspan="3">@ViewBag.GetFNFCalculationsdetailsList.EmployeeMakerRemark</td>
                                    </tr>
                                    <tr>
                                        <td class="label">Authorized By</td>
                                        <td class="label"><center>Signature</center></td>
                                        <td class="label" colspan="2"><center>Received and Signed</center></td>
                                    </tr>
                                    <tr>
                                        <td>@(ViewBag.GetFNFCalculationsdetailsList?.CheckedBy)</td>
                                        <td class="label"><center><img src="@Session[" SignaturePath"]" id="SignaturePath" height="43px" width="100px" /></center></td>
                                        <td class="label" colspan="2"></td>
                                    </tr>


                                    <tr>
                                        <td class="label" colspan="4"><img src="@Session[" Stamp"]" id="Stamp" style="height:100px;width:150px;padding-left: 40px" /></td>
                                    </tr>
                                </table>


                                <table class="salary-table"></table>
                            </div>
                                            }

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
