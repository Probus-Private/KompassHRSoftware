<script>
    $(document).ready(function () {
        $('title').html("FNF Calculation");
        var getddlPType = $("#ddlNoticePeriodType").val();
        if (getddlPType === "ByPolicy")
        {
            $("#divNoticePeriodValue").hide();
        }
        if (getddlPType === "Month" || getddlPType === "Days")
        {
            $("#divNoticePeriodValue").show();
        }
        else
        {
            $("#divNoticePeriodValue").hide();
        }


        $("#ddlNoticePeriodType").on("change", function (e, selectedValue) {debugger
            var val = $(this).val();
            $("#ddlNoticePeriodValue").empty();
            if (val === "ByPolicy") {
                $("#divNoticePeriodValue").hide();
                return;
            }
            $("#divNoticePeriodValue").show();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                url: '@Url.Action("GetNoticePeriodMonthDays", "ESS_FNF_Maxroof_FNFCalculationStatement")',
                data: { NoticePeriodType: val },
                success: function (data) {
                    $("#ddlNoticePeriodValue").append("<option value=''>--Select--</option>");
                    $.each(data.NoticePeriodMonthDays, function (i, p) {
                        $("#ddlNoticePeriodValue").append("<option value='" + p.Name + "'>" + p.Name + "</option>");
                    });
                    if (selectedValue) {
                        selectedValue = $.trim(selectedValue.toString());
                        $("#ddlNoticePeriodValue").val(selectedValue);
                        if ($("#ddlNoticePeriodValue").val() !== selectedValue) {
                            $("#ddlNoticePeriodValue option").filter(function () {
                                return $.trim($(this).text()) === selectedValue;
                            }).prop("selected", true);
                        }
                        $("#ddlNoticePeriodValue").trigger("change");
                    }
                }
            });
        });
    });

    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
    debugger;

    if (Message != null) {
        if (Icon != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                }
            }).then(function() {
                window.location.reload();
            });
        }
    }
</script>

<script>
    function AddFNFCalculation(EmployeeId, ResignId) {
        debugger;
        var baseUrl = '@Url.Action("ESS_FNF_Maxroof_FNFCalculationStatement", "ESS_FNF_Maxroof_FNFCalculationStatement")';

        var url = baseUrl
                  + "?FNFCal_EmployeeId=" + encodeURIComponent(EmployeeId)
                  + "&ResignationId=" + encodeURIComponent(ResignId);
        window.location.href = url;
    }


    function DeleteFNFCalculation(FNFCald) {debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_FNF_Maxroof_FNFCalculationStatement")?FNFCald=' + FNFCald;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }



