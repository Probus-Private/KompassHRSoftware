<script>
    function UpdateNoticePeriod(EmployeeId, ResignId,ResignationDate,LastWorkingDate,RelievingDate) {debugger
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            url: '@Url.Action("GetNoticePeriodDays", "ESS_FNF_Maxroof_FNFCalculationStatement")',
            data: { EmployeeId: EmployeeId },
            success: function (data) {

                if (data && data.info && data.info.length > 0) {debugger

                    var obj = {};
                    data.info.forEach(function (item) {
                        obj[item.Key] = item.Value;
                    });

                    $("#ddlNoticePeriodType").val(obj.NoticePeriodType);
                    $("#ddlNoticePeriodType").trigger("change", [obj.NoticePeriodDays]);
                    $("#ddlNoticePeriodValue").val(obj.NoticePeriodDays);

                    var dateStr = obj.NoticePeriodEndDate;
                    var parsedDate = new Date(dateStr.replace(/(\d{2})\/(\w{3})\/(\d{4})/, '$1 $2 $3'));
                    var yyyy = parsedDate.getFullYear();
                    var MM = ("0" + (parsedDate.getMonth() + 1)).slice(-2);
                    var dd = ("0" + parsedDate.getDate()).slice(-2);
                    var finalDate = `${yyyy}-${MM}-${dd}`;

                    var dateStr1 = ResignationDate;
                    var parsedDate1 = new Date(dateStr1.replace(/(\d{2})\/(\w{3})\/(\d{4})/, '$1 $2 $3'));
                    var yyyy = parsedDate1.getFullYear();
                    var MM = ("0" + (parsedDate1.getMonth() + 1)).slice(-2);
                    var dd = ("0" + parsedDate1.getDate()).slice(-2);
                    var finalDate1 = `${yyyy}-${MM}-${dd}`;

                    var dateLastWorkingDate = LastWorkingDate;
                    var parsedLastWorkingDate = new Date(dateLastWorkingDate.replace(/(\d{2})\/(\w{3})\/(\d{4})/, '$1 $2 $3'));
                    var yyyy = parsedLastWorkingDate.getFullYear();
                    var MM = ("0" + (parsedLastWorkingDate.getMonth() + 1)).slice(-2);
                    var dd = ("0" + parsedLastWorkingDate.getDate()).slice(-2);
                    var finalLastWorkingDate = `${yyyy}-${MM}-${dd}`;

                    var dateRelievingDate = RelievingDate;
                    var parsedRelievingDate = new Date(dateRelievingDate.replace(/(\d{2})\/(\w{3})\/(\d{4})/, '$1 $2 $3'));
                    var yyyy = parsedRelievingDate.getFullYear();
                    var MM = ("0" + (parsedRelievingDate.getMonth() + 1)).slice(-2);
                    var dd = ("0" + parsedRelievingDate.getDate()).slice(-2);
                    var finalRelievingDate = `${yyyy}-${MM}-${dd}`;

                    $("#txtNoticePeriodEndDate").val(finalDate);
                    $("#txtResignationDate").val(finalDate1);
                    $("#RelievingDate").val(finalRelievingDate);
                    $("#LastWorkingDate").val(finalLastWorkingDate);
                    $("#FnfEmployeeId").val(EmployeeId);
                    $("#FnfId").val(ResignId);
                } else {
                    $("#ddlNoticePeriodType").val("");
                    $("#ddlNoticePeriodValue").val("");
                }

                $('#NoticePeriodChangeModel').modal('show');
            },
            error: function () {
                alert("Error while loading notice period details.");
            }
        });
    }

    $("#ddlNoticePeriodType, #ddlNoticePeriodValue").on("change", function () {debugger

        var resignationDate = $("#txtResignationDate").val();
        var noticeType = $("#ddlNoticePeriodType").val();
        var noticeValue = parseInt($("#ddlNoticePeriodValue").val());

        if (!resignationDate || isNaN(noticeValue)) return;

        var relDate = new Date(resignationDate);

        // --- MONTH TYPE ---
        if (noticeType === "Month") {debugger

            let year = relDate.getFullYear();
            let month = relDate.getMonth() + noticeValue; // Add months
            let day = relDate.getDate();

            let temp = new Date(year, month, day);
            if (temp.getMonth() !== (month % 12)) {
                temp = new Date(year, month + 1, 0);
            }

            temp.setDate(temp.getDate() - 1);
            relDate = temp;
        }

        // --- DAYS TYPE ---
        if (noticeType === "Days") {debugger
            relDate.setDate(relDate.getDate() + noticeValue);
        }

        // Format date: yyyy-MM-dd
        var yyyy = relDate.getFullYear();
        var MM = ("0" + (relDate.getMonth() + 1)).slice(-2);
        var dd = ("0" + relDate.getDate()).slice(-2);

        var finalDate = `${yyyy}-${MM}-${dd}`;
        $("#txtNoticePeriodEndDate").val(finalDate);
    });


