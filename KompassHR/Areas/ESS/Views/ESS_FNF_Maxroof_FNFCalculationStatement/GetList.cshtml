@model KompassHR.Areas.ESS.Models.ESS_FNF.FNF_EmployeeResignation

@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isMaker = ViewBag.FNFMakerId != null;
    bool isChecker = ViewBag.FNFCheckerId != null;
    bool isAccount = ViewBag.AccountId != null;

    bool showAll = isMaker && isChecker && isAccount;

    // Default active tab based on role
    string activeTab = "";

    if (isMaker || showAll)
    {
        activeTab = "tabFNFEmployeeList";
    }
    else if (isChecker || showAll)
    {
        activeTab = "tabCheckerFNFPendingList";
    }
    else if (isAccount || showAll)
    {
        activeTab = "tabAccountFNFPendingList";
    }
    else
    {
        activeTab = "";
    }
}

<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 12px; /* rounded corners */
        font-weight: 600;
        white-space: nowrap;
    }

    .status-approved-bg {
        background-color: #d4edda;
        color: #155724;
    }

    .status-pending-bg {
        background-color: #fff3cd; /* light yellow */
        color: #856404; /* dark yellow */
    }

    .status-reject-bg {
        background-color: #f8d7da;
        color: #721c24;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Calculation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">FNF Calculation-List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
            </div>

            <div class="panel panel-inverse" data-sortable-id="index-1">
                <style>
                    .nav-tabs .nav-link.active {
                        background-color: #eee !important; /* Background for selected tab */
                        color: #000000 !important; /* Text color for selected tab */
                        font-weight: bold;
                        border-color: #ddd #ddd #fff;
                    }
                </style>
                @{
                    var headerColor = Session["HeaderColor"] != null ? Session["HeaderColor"].ToString() : "#49b6d6";
                    var headerTextColor = Session["HeaderTextColor"] != null ? Session["HeaderTextColor"].ToString() : "#ffffff";
                }

                <div class="row">
                    @if (isMaker)
                    {
                        <div class="col-md-12">
                            <button type="button" class="btn btn-danger btn-sm mb-10px" onclick="FNFCalculationRejectedList()">
                                &nbsp; Cheker Reject List (<span id="fnfRejectCount">@((TempData["FNFRejectCount"]))</span>)
                            </button>
                        </div>
                    }
                    <div class="col-md-12">
                        <!-- BEGIN tabs -->
                        <ul class="nav nav-tabs nav-tabs-inverse nav-justified"
                            style="background-color:#49b6d6" ; color:@headerTextColor">

                            @if (isMaker || showAll)
                            {
                                <li class="nav-item">
                                    <a href="#tabFNFEmployeeList"
                                       data-bs-toggle="tab"
                                       class="nav-link @(activeTab == "tabFNFEmployeeList" ? "active" : "")">
                                        <i class="fa fa-newspaper fa-lg me-5px"></i>
                                        Pending FNF Calculations (<span>@((TempData["FNFPendingCount"]))</span>)
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="#tabFNFCalculationDoneList"
                                       data-bs-toggle="tab"
                                       class="nav-link @(activeTab == "tabFNFCalculationDoneList" ? "active" : "")">
                                        <i class="fa fa-scroll fa-lg me-5px"></i>
                                        Completed FNF Calculations (<span>@((TempData["FNFCompleteCount"]))</span>)
                                    </a>
                                </li>
                            }

                            @if (isChecker || showAll)
                            {
                                <li class="nav-item">
                                    <a href="#tabCheckerFNFPendingList"
                                       data-bs-toggle="tab"
                                       class="nav-link @(activeTab == "tabCheckerFNFPendingList" ? "active" : "")">
                                        <i class="fa fa-scroll fa-lg me-5px"></i>
                                        Checker Approval (<span>@((TempData["CheckerFNFPendingCount"]))</span>)
                                    </a>
                                </li>
                            }

                            @if (isAccount || showAll)
                            {
                                <li class="nav-item">
                                    <a href="#tabAccountFNFPendingList"
                                       data-bs-toggle="tab"
                                       class="nav-link @(activeTab == "tabAccountFNFPendingList" ? "active" : "")">
                                        <i class="fa fa-scroll fa-lg me-5px"></i>
                                        Account Approval (<span>@((TempData["AccountFNFPendingCount"]))</span>)
                                    </a>
                                </li>
                            }

                            @if (isMaker || isChecker || isAccount || showAll)
                            {
                                <li class="nav-item">
                                    <a href="#tabCheckerAccountFNFApproveRejectList"
                                       data-bs-toggle="tab"
                                       class="nav-link @(activeTab == "tabCheckerAccountFNFApproveRejectList" ? "active" : "")">
                                        <i class="fa fa-scroll fa-lg me-5px"></i>
                                        Approve List (<span>@((TempData["Maker_checker_Account_ApproveRejectcount"]))</span>)
                                    </a>
                                </li>
                            }


                        </ul>
                        <!-- Tab Content -->
                        <div class="tab-content panel rounded-0 rounded-bottom mb-20px" data-sortable-id="index-3">
                            <!-- Calendar List -->
                            <div class="tab-pane fade @(activeTab == "tabFNFEmployeeList" ? "show active" : "")" id="tabFNFEmployeeList">
                                <div class="h-500px p-3" data-scrollbar="true">
                                    <div class="table-scroll">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage2" id="tbl3" style="width: 100%;">
                                                <thead class="text-center">
                                                    <tr>
                                                        <th class="text-nowrap text-center">
                                                            Add
                                                        </th>
                                                        <th class="text-nowrap text-center">
                                                            Action
                                                        </th>
                                                        <th class="text-nowrap text-center">Employee Name</th>
                                                        <th class="text-nowrap text-center">Employee No</th>
                                                        <th class="text-nowrap text-center">Department Name</th>
                                                        <th class="text-nowrap text-center">Designation Name</th>
                                                        <th class="text-nowrap text-center">Grade Name</th>
                                                        <th class="text-nowrap text-center">Date Of Joining</th>
                                                        <th class="text-nowrap text-center">Resignation Type</th>
                                                        <th class="text-nowrap text-center">Resignation Date</th>
                                                        <th class="text-nowrap text-center">Reason</th>
                                                        <th class="text-nowrap text-center">Notice Period Days</th>
                                                        <th class="text-nowrap text-center">Last Working Date</th>
                                                        <th class="text-nowrap text-center">Relieving Date</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var d in ViewBag.GetFNFPendingList)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <a onclick="AddFNFCalculation(@d.EmployeeId,@d.ResignId)" id="btnAdd" style="display:inline-flex; align-items:center;justify-content:center; width:26px; height:26px; background-color:#007bff;  color: white;border-radius: 50%; cursor: pointer;text-decoration: none;">
                                                                    <i class="fa-solid fa-plus"></i>
                                                                </a>
                                                            </td>
                                                            <td class="text-center">
                                                                <a onclick="UpdateNoticePeriod(@d.EmployeeId,@d.ResignId,'@d.ResignationDate','@d.LastWorkingDate','@d.RelievingDate')" id="btnUpdate" style="display:inline-flex; align-items:center;justify-content:center; width:26px; height:26px; background-color:#007bff;  color: white;border-radius: 50%; cursor: pointer;text-decoration: none;">
                                                                    <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                                </a>
                                                            </td>
                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                            <td class="text-nowrap">@d.EmployeeNo</td>
                                                            <td class="text-nowrap">@d.Department</td>
                                                            <td class="text-nowrap">@d.Designation</td>
                                                            <td class="text-nowrap">@d.Grade</td>
                                                            <td class="text-nowrap">@d.DOJ</td>
                                                            <td class="text-nowrap">@d.ResignationType</td>
                                                            <td class="text-nowrap">@d.ResignationDate</td>
                                                            <td class="text-nowrap">@d.Reason</td>
                                                            <td class="text-nowrap">@d.NoticePeriod</td>
                                                            <td class="text-nowrap">@d.LastWorkingDate</td>
                                                            <td class="text-nowrap">@d.RelievingDate</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- FNFCalculationDoneList -->
                            <div class="tab-pane fade @(activeTab == "tabFNFCalculationDoneList" ? "show active" : "")" id="tabFNFCalculationDoneList">
                                <div class="h-500px p-3" data-scrollbar="true">
                                    <div class="table-scroll">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage2" id="tbl3" style="width: 100%;">
                                                <thead class="text-center">
                                                    <tr>
                                                        <th class="fixed-side">Delete</th>
                                                        <th class="fixed-side text-center">Print</th>
                                                        <th class="fixed-side text-center">Send Approval</th>
                                                        <th class="text-nowrap text-center">Employee Name</th>
                                                        <th class="text-nowrap text-center">Employee No</th>
                                                        <th class="text-nowrap text-center">Department Name</th>
                                                        <th class="text-nowrap text-center">Designation Name</th>
                                                        <th class="text-nowrap text-center">Grade Name</th>
                                                        <th class="text-nowrap text-center">Date Of Joining</th>
                                                        <th class="text-nowrap text-center">Resignation Type</th>
                                                        <th class="text-nowrap text-center">Resignation Date</th>
                                                        <th class="text-nowrap text-center">Last Working Date</th>
                                                        <th class="text-nowrap text-center">Relieving Date</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (ViewBag.GetFNFCompleteList != null)
                                                    {
                                                        foreach (var d in ViewBag.GetFNFCompleteList)
                                                        {
                                                            <tr>
                                                                <td class="text-center">
                                                                    <a onclick="DeleteFNFCalculation('@d.FNFCald')" id="btnDelete" style="cursor:pointer;">
                                                                        <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                    </a>
                                                                </td>
                                                                <td class="text-center">
                                                                    <i class="fa-solid fa-print text-success fa-lg" style="cursor: pointer;"
                                                                       onclick="ViewStatement('@d.FNFEmployeeId','@d.ResignationId')"></i>
                                                                </td>
                                                                @if (!d.IsSendForApproval)
                                                                {
                                                                    <td class="text-center">
                                                                        <i class="fa-solid fa-paper-plane text-primary fa-lg"
                                                                           style="cursor: pointer;"
                                                                           onclick="SendToApproval('@d.FNFCald')">
                                                                        </i>
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-center">
                                                                        <i class="fa-solid fa-paper-plane fa-lg text-secondary"
                                                                           style="opacity: 0.4; cursor: not-allowed;">
                                                                        </i>
                                                                    </td>
                                                                }

                                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                                <td class="text-nowrap">@d.EmployeeNo</td>
                                                                <td class="text-nowrap">@d.Department</td>
                                                                <td class="text-nowrap">@d.Designation</td>
                                                                <td class="text-nowrap">@d.Grade</td>
                                                                <td class="text-nowrap">@d.DOJ</td>
                                                                <td class="text-nowrap">@d.ResignationType</td>
                                                                <td class="text-nowrap">@d.ReginationDate</td>
                                                                <td class="text-nowrap">@d.LastWorkingDate</td>
                                                                <td class="text-nowrap">@d.RelievingDate</td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- FNFCalculationDoneList -->
                            <div class="tab-pane fade @(activeTab == "tabCheckerFNFPendingList" ? "show active" : "")" id="tabCheckerFNFPendingList">
                                <div class="h-500px p-3" data-scrollbar="true">
                                    <div class="table-scroll">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage2" id="tbl3" style="width: 100%;">
                                                <thead class="text-center">
                                                    <tr>
                                                        <th style="text-align: center; justify-content: center;">ALL <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                                        <th class="fixed-side">View</th>
                                                        <th class="fixed-side text-center">Print</th>
                                                        <th class="text-nowrap text-center">Employee Name</th>
                                                        <th class="text-nowrap text-center">Employee No</th>
                                                        <th class="text-nowrap text-center">Department Name</th>
                                                        <th class="text-nowrap text-center">Designation Name</th>
                                                        <th class="text-nowrap text-center">Grade Name</th>
                                                        <th class="text-nowrap text-center">Date Of Joining</th>
                                                        <th class="text-nowrap text-center">Resignation Type</th>
                                                        <th class="text-nowrap text-center">Resignation Date</th>
                                                        <th class="text-nowrap text-center">Last Working Date</th>
                                                        <th class="text-nowrap text-center">Relieving Date</th>
                                                        <th class="text-nowrap text-center">Maker Name</th>
                                                        <th class="text-nowrap text-center">Maker Date</th>
                                                        <th class="text-nowrap text-center">Maker Remark</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tbodyApproveReject">
                                                    @if (ViewBag.GetCheckerFNFPendingList != null)
                                                    {
                                                        foreach (var d in ViewBag.GetCheckerFNFPendingList)
                                                        {
                                                            <tr>
                                                                <td>
                                                                    <span class="d-flex justify-content-center">
                                                                        <input type="checkbox" class="form-check-input" data-checked="email-checkbox" value="@d.FNFCald" id="tblCheckbox">
                                                                    </span>
                                                                </td>
                                                                <td class="text-center">
                                                                    <a onclick="ViewForApproval('@d.FNFCald','@d.FNFEmployeeId','@d.ResignationId','Checker')" id="btnDelete" style="cursor:pointer;">
                                                                        <i class="fa-solid fa-eye text-warning fa-lg"></i>
                                                                    </a>
                                                                </td>
                                                                <td class="text-center">
                                                                    <i class="fa-solid fa-print text-success fa-lg" style="cursor: pointer;"
                                                                       onclick="ViewStatement('@d.FNFEmployeeId','@d.ResignationId')"></i>
                                                                </td>

                                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                                <td class="text-nowrap">@d.EmployeeNo</td>
                                                                <td class="text-nowrap">@d.Department</td>
                                                                <td class="text-nowrap">@d.Designation</td>
                                                                <td class="text-nowrap">@d.Grade</td>
                                                                <td class="text-nowrap">@d.JoiningDate</td>
                                                                <td class="text-nowrap">@d.ResignationType</td>
                                                                <td class="text-nowrap">@d.ReginationDate</td>
                                                                <td class="text-nowrap">@d.LastWorkingDate</td>
                                                                <td class="text-nowrap">@d.RelievingDate</td>
                                                                <td class="text-nowrap">@d.MakerName</td>
                                                                <td class="text-nowrap">@d.EmployeeMakerDate</td>
                                                                @if (!string.IsNullOrEmpty(d.EmployeeMakerRemark))
                                                                {
                                                                    <td class="text-start text-center">
                                                                        <input type="hidden" id="hiddenRemark_@d.ResignationId" value="@d.EmployeeMakerRemark" />
                                                                        <i class="fa-solid fa-receipt fa-lg" onclick="Remark(encodeURIComponent(document.getElementById('hiddenRemark_@d.ResignationId').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-start text-center"></td>
                                                                }
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                @if (isChecker)
                                {
                                    <div class="row mb-20px">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" class="btn btn-primary btn-sm" id="btnAllApprove" onclick="AllApproveReject('Approved')">
                                                                <i class="fa-solid fa-floppy-disk"></i> Approve
                                                            </button>

                                                            <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" type="button" class="btn btn-success btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- FNFCalculationDoneList -->
                            <div class="tab-pane fade @(activeTab == "tabAccountFNFPendingList" ? "show active" : "")" id="tabAccountFNFPendingList">
                                <div class="h-500px p-3" data-scrollbar="true">
                                    <div class="table-scroll">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage2" id="tbl3" style="width: 100%;">
                                                <thead class="text-center">
                                                    <tr>
                                                        <th class="fixed-side">View</th>
                                                        <th class="fixed-side text-center">Print</th>
                                                        <th class="text-nowrap text-center">Employee Name</th>
                                                        <th class="text-nowrap text-center">Employee No</th>
                                                        <th class="text-nowrap text-center">Department Name</th>
                                                        <th class="text-nowrap text-center">Designation Name</th>
                                                        <th class="text-nowrap text-center">Grade Name</th>
                                                        <th class="text-nowrap text-center">Date Of Joining</th>
                                                        <th class="text-nowrap text-center">Resignation Type</th>
                                                        <th class="text-nowrap text-center">Resignation Date</th>
                                                        <th class="text-nowrap text-center">Last Working Date</th>
                                                        <th class="text-nowrap text-center">Maker Name</th>
                                                        <th class="text-nowrap text-center">Maker Date</th>
                                                        <th class="text-nowrap text-center">Maker Remark</th>
                                                        <th class="text-nowrap text-center">Checker Status</th>
                                                        <th class="text-nowrap text-center">Checker Name</th>
                                                        <th class="text-nowrap text-center">Checker Date</th>
                                                        <th class="text-nowrap text-center">Checker Remark</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (ViewBag.GetAccountFNFPendingList != null)
                                                    {
                                                        foreach (var d in ViewBag.GetAccountFNFPendingList)
                                                        {
                                                            <tr>
                                                                <td class="text-center">
                                                                    <a onclick="ViewForApproval('@d.FNFCald','@d.FNFEmployeeId','@d.ResignationId','Account')" id="btnDelete" style="cursor:pointer;">
                                                                        <i class="fa-solid fa-eye text-warning fa-lg"></i>
                                                                    </a>
                                                                </td>
                                                                <td class="text-center">
                                                                    <i class="fa-solid fa-print text-success fa-lg" style="cursor: pointer;"
                                                                       onclick="ViewStatement('@d.FNFEmployeeId','@d.ResignationId')"></i>
                                                                </td>

                                                                <td class="text-nowrap">@d.EmployeeName</td>
