                                <td class="text-left">${item.Makername || ''}</td>
                                <td class="text-left">${item.EmployeeMakerDate || ''}</td>
                                <td class="text-center"> ${makerRemarkHtml}</td>
                                <td class="text-center">${statusHtml}</td>
                                <td class="text-left">${item.Checkername || ''}</td>
                                <td class="text-left">${item.EmployeeCheckerDate || ''}</td>
                                <td class="text-center"> ${checkerRemarkHtml}</td>
