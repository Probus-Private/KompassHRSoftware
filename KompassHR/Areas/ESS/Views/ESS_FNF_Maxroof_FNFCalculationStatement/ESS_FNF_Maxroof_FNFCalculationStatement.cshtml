<script>
    function validateDifferentMonths() {debugger

        var a = $("#txtA_SalaryDate").val();
        var b = $("#txtB_SalaryDate").val();
        var c = $("#txtC_SalaryDate").val();

        var A_Salary_Applicable = $("#ddlA_Salary_Applicable").val();
        var B_Salary_Applicable = $("#ddlB_Salary_Applicable").val();
        var C_Salary_Applicable = $("#ddlC_Salary_Applicable").val();

        var FY_Preivous_Bonus_Year_Applicable = $("#ddlFY_Preivous_Bonus_Year_Applicable").val();
        var FY_Preivous_Bonus_Year = $("#ddlFY_Preivous_Bonus_Year").val();
        var FY_Current_Bonus_Year_Applicable = $("#ddlFY_Current_Bonus_Year_Applicable").val();
        var FY_Current_Bonus_Year = $("#ddlFY_Current_Bonus_Year").val();

        let inputs = $("#txtA_SalaryDate, #txtB_SalaryDate, #txtC_SalaryDate");
        inputs.css("border", "");
        $("#errorA_SalaryDate, #errorB_SalaryDate, #errorC_SalaryDate").text("");

        let error = false;
        if (A_Salary_Applicable === 'Yes' && a == "") {
            $("#errorA_SalaryDate").text("Please Select Month.");
            error = true;
        }

        if (B_Salary_Applicable === 'Yes' && b == "") {
            $("#errorB_SalaryDate").text("Please Select Month.");
            error = true;
        }

        if (C_Salary_Applicable === 'Yes' && c == "") {
            $("#errorC_SalaryDate").text("Please Select Month.");
            error = true;
        }

        if(FY_Preivous_Bonus_Year_Applicable === 'Yes' && FY_Preivous_Bonus_Year == "")
        {
            $("#errorFY_Preivous_Bonus_Year").text("Please Select Bonus Previous Year.");
            error = true;
        }
        else
        {
            $("#errorFY_Preivous_Bonus_Year").text("");
        }

        if(FY_Current_Bonus_Year_Applicable === 'Yes' && FY_Current_Bonus_Year == "")
        {
            $("#errorFY_Current_Bonus_Year").text("Please Select Bonus Current Year.");
            error = true;
        }
        else
        {
            $("#errorFY_Current_Bonus_Year").text("");
        }

        if (a && b && a === b) {
            $("#errorA_SalaryDate").text("Duplicate month.");
            $("#errorB_SalaryDate").text("Duplicate month.");
            error = true;
        }

        if (a && c && a === c) {
            $("#errorA_SalaryDate").text("Duplicate month");
            $("#errorC_SalaryDate").text("Duplicate month");
            error = true;
        }

        if (b && c && b === c) {
            $("#errorB_SalaryDate").text("Duplicate month");
            $("#errorC_SalaryDate").text("Duplicate month");
            error = true;
        }

        return !error;
    }

    // Validate on change
    $("#txtA_SalaryDate, #txtB_SalaryDate, #txtC_SalaryDate").change(function () {debugger
        validateDifferentMonths();
    });



    $(document).ready(function () {

        function calculateTotalEarningDeduction() {
            debugger
            let TotalIncome = parseFloat($("#txtTotalIncome").val()) || 0;

            let deduction = parseFloat($("#txtTotalDeduction").val()) || 0; // 👈 separate field
            let SalaryTDS = parseFloat($("#txtSalaryTDS").val()) || 0;

            let totalDeduction = deduction + SalaryTDS;
            $("#txtTotalDeduction").val(totalDeduction);

            let TotalNetPay = TotalIncome - totalDeduction;
            $("#txtNetPay").val(TotalNetPay.toFixed(2));
            $("#txtNetPayInWord").val(numberToWords(Math.round(TotalNetPay)));

            let GratuityAmount = parseFloat($("#txtGratuityAmount").val()) || 0;

            let FinalNetPayable = TotalNetPay + GratuityAmount;
            $("#txtFinalNetPayable").val(FinalNetPayable.toFixed(2));
            $("#txtFinalNetPayableInWord").val(numberToWords(Math.round(FinalNetPayable)));
        }

        function numberToWords(num) {

            num = Math.floor(num); // 👈 remove decimal

            let a = ['', 'One ', 'Two ', 'Three ', 'Four ', 'Five ', 'Six ', 'Seven ', 'Eight ', 'Nine ', 'Ten ',
                'Eleven ', 'Twelve ', 'Thirteen ', 'Fourteen ', 'Fifteen ', 'Sixteen ', 'Seventeen ', 'Eighteen ', 'Nineteen '];

            let b = ['', '', 'Twenty ', 'Thirty ', 'Forty ', 'Fifty ', 'Sixty ', 'Seventy ', 'Eighty ', 'Ninety '];

            if (num === 0) return "Zero Only";

            let str = '';

            let crore = Math.floor(num / 10000000);
            num %= 10000000;

            let lakh = Math.floor(num / 100000);
            num %= 100000;

            let thousand = Math.floor(num / 1000);
            num %= 1000;

            let hundred = Math.floor(num / 100);
            num %= 100;

            if (crore) str += a[crore] + "Crore ";
            if (lakh) str += a[lakh] + "Lakh ";
            if (thousand) str += a[thousand] + "Thousand ";
            if (hundred) str += a[hundred] + "Hundred ";

            if (num) {
                if (str !== '') str += "and ";
                str += (num < 20) ? a[num] : b[Math.floor(num / 10)] + a[num % 10];
            }

            return "Rupees " + str.trim() + " Only";
        }

        $("#txtSalaryTDS").on("input", function () {
            calculateTotalEarningDeduction();
        });
    });
</script>
<script>
    $(document).on('input', '.numeric', function () {
        // Remove any non-numeric characters except decimal
        this.value = this.value.replace(/[^0-9.]/g, '');

        // Allow only one decimal point
        const parts = this.value.split('.');
        if (parts.length > 2) {
            this.value = parts[0] + '.' + parts[1];
        }
    });

