                        <!-- Basic Salary Info -->

                        <div class="row mb-3">
                            <!-- Basic Salary Info -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-body">
                                    <style>
                                        #tblCombined thead th {
                                            border: 1px solid black; /* Apply border to header cells */
                                            padding: 5px; /* Add padding for better fit */
                                            text-align: center; /* Center-align text for a clean look */
                                            background-color: #f2f2f2; /* Optional: Add a light background color */
                                        }
                                        /* Add vertical borders to table columns */
                                        #tblCombined th,
                                        #tblCombined td {
                                            border-left: 1px solid black; /* Add a left border for vertical lines */
                                            border-right: 1px solid black; /* Add a right border for vertical lines */
                                            padding: 5px; /* Add padding for better spacing */
                                            text-align: right; /* Center-align the content */
                                        }

                                        /* Ensure the table headers have proper styling with borders */
                                        #tblCombined thead th {
                                            background-color: #f2f2f2; /* Optional: Light background for the header */
                                            border: 1px solid black; /* Full border for header cells */
                                        }

                                        /* Add an outer border for the table */
                                        #tblCombined {
                                            border: 1px solid black; /* Outer border for the entire table */
                                            border-collapse: collapse; /* Ensure borders do not double */
                                            width: 100%; /* Full width table */
                                        }

                                            /* Remove horizontal row borders, but keep vertical column borders */
                                            #tblCombined tbody td {
                                                border-top: none; /* No top border */
                                                border-bottom: none; /* No bottom border */
                                                padding: 2px 5px;
                                            }



                                            #tblCombined tfoot td {
                                                border: 1px solid black; /* Full borders for footer cells */
                                                padding: 8px; /* Add padding for spacing */
                                                text-align: center; /* Center-align footer content */
                                            }

                                            #tblCombined tfoot .hideBorder {
                                                border: none !important;
                                            }
                                    </style>
                                  
                                      <div class="row mb-3">
                                        <div class="row mb-3">
                                            <table id="tblCombined" class="table table-bordered" style="width:100%; table-layout: fixed;">
                                                <thead>
                                                    <tr>
                                                        <th style="width:50%" colspan="2"><b>Income (A)</b></th>
                                                        <th style="width:50%" colspan="2"><b>Deduction (B)</b></th>
                                                    </tr>
                                                </thead>

                                                <tbody>
                                                   @{
                                                       var earnings = Model.earnings;
                                                       var deductions = Model.deductions;

                                                       int earnCount = earnings != null ? earnings.Count : 0;
                                                       int dedCount = deductions != null ? deductions.Count : 0;

                                                       int max = Math.Max(earnCount, dedCount);
                                                }

                                                  @for (int i = 0; i < max; i++)
                                                  {
                                                      FNF_Earning_Info e = (earnings != null && i < earnings.Count) ? earnings[i] : null;
                                                      FNF_Deduction_Info d = (deductions != null && i < deductions.Count) ? deductions[i] : null;

                                                    <tr>
                                                        <td style="text-align:left;">
                                                            @(e != null ? (e.DisplayHead ?? e.Head) : "")
                                                        </td>
                                                        <td class="text-end">
                                                            @(e != null ? e.EarningAmt : "")
                                                        </td>

                                                        <td style="text-align:left;">
                                                            @(d != null ? (d.DisplayHead ?? d.Head) : "")
                                                        </td>
                                                        <td class="text-end">
                                                            @(d != null ? d.DeductionAmt : "")
                                                        </td>
                                                    </tr>
                                                  }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>

                                    <style>
                                        #tblCombined {
                                            border-collapse: collapse;
                                            width: 100%;
                                        }

                                            #tblCombined th {
                                                background-color: #f2f2f2;
                                                text-align: center;
                                                font-weight: 600;
                                                border: 1px solid #000;
                                                padding: 6px;
                                            }

                                            #tblCombined td {
                                                border-left: 1px solid #000;
                                                border-right: 1px solid #000;
                                                padding: 4px 6px;
                                            }

                                            #tblCombined tbody tr:last-child td {
                                                border-bottom: 1px solid #000;
                                            }
                                    </style>


                                    <div class="row mt-3">
                                        <div class="col-md-6">
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-2">
                                                <label class="col-md-4 col-form-label fw-medium">Advance</label>
                                                <div class="col-md-8">
                                                    <div class="input-group">
                                                        <span class="input-group-text">₹</span>
                                                        @Html.TextBoxFor(model => Model.AdvanceRecovered, new { @class = "form-control text-end", @id = "txtAdvanceRecovered", @readonly = "readonly" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row mt-3">
                                        <div class="col-md-6">
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-2">
                                                <label class="col-md-4 col-form-label fw-medium">TDS</label>
                                                <div class="col-md-8">
                                                    <div class="input-group">
                                                        <span class="input-group-text">₹</span>
                                                        @Html.TextBoxFor(model => Model.SalaryTDS, new { @class = "form-control text-end numeric", @id = "txtSalaryTDS" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mt-3">
                                        <div class="col-md-6">
                                            <div class="row mb-2">
                                                <label class="col-md-4 col-form-label fw-medium">Total Income</label>
                                                <div class="col-md-8">
                                                    <div class="input-group">
                                                        <span class="input-group-text">₹</span>
                                                        @Html.TextBoxFor(m => m.TotalIncome, new { @class = "form-control text-end fw-semibold", id = "txtTotalIncome", @readonly = "readonly" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
