                                                <label class="col-md-4 col-form-label fw-medium">Total Deduction</label>
                                                <div class="col-md-8">
                                                    <div class="input-group">
                                                        <span class="input-group-text">₹</span>
                                                        @Html.TextBoxFor(m => m.TotalDeduction, new { @class = "form-control text-end fw-semibold", id = "txtTotalDeduction", @readonly = "readonly" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                 

