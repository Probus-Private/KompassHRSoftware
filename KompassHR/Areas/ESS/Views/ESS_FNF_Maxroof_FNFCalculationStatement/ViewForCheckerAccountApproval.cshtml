<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Calculation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> FNF Calculation  - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        FNF Calculation Form.
                    </p>
                </div>
                <div class="panel-body combined-table-border table-container">
                    <form role="form" action='@Url.Action("SaveUpdate", "ESS_FNF_Maxroof_FNFCalculationStatement", new { area = "ESS" })' id="SaveFNFCalculation" method="post" data-parsley-validate="">
                        <!-- Employee Details Card -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0" style="color: #348fe2;"><i class="fa fa-id-card me-2"></i>Employee Details</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <!-- Left Column -->
                                    <div class="col-md-6">
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-user fa-sm"></i></span>
                                                Employee Name :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.EmployeeName
                                                @Html.HiddenFor(model => model.EmployeeName, new { @id = "hdnEmployeeName" })
                                                @Html.HiddenFor(model => model.FNFCald, new { @id = "FNFCald" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-building fa-sm"></i></span>
                                                Department :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Department
                                                @Html.HiddenFor(model => Model.Department, new { @id = "hdnDepartment" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-star fa-sm"></i></span>
                                                Grade :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Grade
                                                @Html.HiddenFor(model => Model.Grade, new { @id = "hdnGrade" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-chart-bar fa-sm"></i></span>
                                                Daily/Monthly :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.DailyMonthly
                                                @Html.HiddenFor(model => Model.DailyMonthly, new { @id = "hdnDailyMonthly" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-calendar-xmark fa-sm"></i></span>
                                                Resignation Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.ResignationDate
                                                @Html.HiddenFor(model => Model.ResignationDate, new { @id = "hdnResignationDate" })
                                            </div>
                                        </div>
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-bell fa-sm"></i></span>
                                                Notice Period :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.NoticePeriod
                                            </div>
                                        </div>
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-bell fa-sm"></i></span>
                                                End Of Notice Period :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.NoticePeriodEndDate
                                                @Html.HiddenFor(model => Model.NoticePeriodEndDate, new { @id = "hdnEndNoticePeriod" })
                                            </div>
                                        </div>

                                    </div>

                                    <!-- Right Column -->
                                    <div class="col-md-6">
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-id-card fa-sm"></i></span>
                                                Employee No :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.EmployeeNo
                                                @Html.HiddenFor(model => Model.EmployeeNo, new { @id = "hdnEmployeeNo" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-briefcase fa-sm"></i></span>
                                                Designation :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Designation
                                                @Html.HiddenFor(model => Model.Designation, new { @id = "hdnDesignation" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-industry fa-sm"></i></span>
                                                Business Unit :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.BusinessUnit
                                                @Html.HiddenFor(model => Model.BusinessUnit, new { @id = "hdnBranch" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-calendar-check fa-sm"></i></span>
                                                Joining Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.JoiningDate
                                                @Html.HiddenFor(model => Model.JoiningDate, new { @id = "hdnDOJ" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-hourglass-end fa-sm"></i></span>
                                                Last Working Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.LastWorkingDate
                                                @Html.HiddenFor(model => Model.LastWorkingDate, new { @id = "hdnLastWorkingDate" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-hourglass-end fa-sm"></i></span>
                                                Relieving Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.RelievingDate
                                                @Html.HiddenFor(model => Model.RelievingDate, new { @id = "hdnRelievingDate" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-lock fa-sm"></i></span>
                                                Service Bond Applicable :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Bond_Applicable
                                                @Html.HiddenFor(model => Model.Bond_Applicable, new { @id = "hdnServiceBondApplicable" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Input Parameters Card -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-body">
                                <div class="col-md-4" hidden>
                                    <button type="button" class="btn btn-success btn-sm" id="btnGetDetails">
                                        <i class="fa-solid fa-floppy-disk"></i>  Get Details
                                    </button>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                1. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.A_Salary_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes" },
                                                    new SelectListItem { Value = "No", Text = "No" , Selected = true}
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlA_Salary_Applicable", name = "A_Salary_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.A_SalaryDate, new { @class = "form-control form-control-sm", name = "A_SalaryDate", type = "Month", id = "txtA_SalaryDate" })
                                                <span class="text-danger small" id="errorA_SalaryDate"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                Leave Year
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.LeaveYear_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes", Selected = true },
                                                    new SelectListItem { Value = "No", Text = "No" }
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlLeaveYear_Applicable", name = "LeaveYear_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.DropDownListFor(model => model.LeaveMasterLeaveYearId, new SelectList(ViewBag.GetLeaveYear, "Id", "Name"), "--Not Applicable--", new { id = "ddlLeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-select form-select-sm", autocomplete = "off" })
                                            </div>
                                        </div>
                                        <div class="row mb-3" hidden>
                                            <label class="form-label col-form-label col-md-5">
                                                Bonus Previous Year
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.FY_Preivous_Bonus_Year_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes" },
                                                    new SelectListItem { Value = "No", Text = "No", Selected = true }
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlFY_Preivous_Bonus_Year_Applicable", name = "FY_Preivous_Bonus_Year_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.DropDownListFor(model => model.FY_Preivous_Bonus_Year, new SelectList(ViewBag.GetBonusYear, "Id", "Name"), "--Select--", new { id = "ddlFY_Preivous_Bonus_Year", name = "FY_Preivous_Bonus_Year", @class = "form-select form-select-sm", autocomplete = "off" })
                                                <span class="text-danger small" id="errorFY_Preivous_Bonus_Year"></span>
                                            </div>
                                        </div>
                                        <div class="row mb-3" hidden>
                                            <label class="form-label col-form-label col-md-5">
                                                Bonus Current Year
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.FY_Current_Bonus_Year_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes", Selected = true },
                                                    new SelectListItem { Value = "No", Text = "No" }
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlFY_Current_Bonus_Year_Applicable", name = "FY_Current_Bonus_Year_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.DropDownListFor(model => model.FY_Current_Bonus_Year, new SelectList(ViewBag.GetBonusYear, "Id", "Name"), "--Select--", new { id = "ddlFY_Current_Bonus_Year", name = "FY_Current_Bonus_Year", @class = "form-select form-select-sm", autocomplete = "off" })
                                                <span class="text-danger small" id="errorFY_Current_Bonus_Year"></span>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <!-- Action Buttons -->
