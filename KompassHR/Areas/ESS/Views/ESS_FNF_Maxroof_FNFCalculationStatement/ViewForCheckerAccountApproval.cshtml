    }

    /*.detail-label {
        width: 200px;
        font-weight: bold;
    }*/

    .label-icon {
        font-size: 14px;
        display: block;
        margin-bottom: 3px;
        width: 24px;
        color: #007bff; /* change color if needed */
    }

    .detail-label {
        font-weight: 600;
        display: flex;
        width: 200px;
        // flex-direction: column;
    }


    .section-header h6 {
        color: #495057;
        font-weight: 600;
    }

    /*.detail-row {
        display: flex;
        align-items: center;
        padding: 8px 0;
    }

    .detail-label {
        min-width: 200px;
        font-weight: 500;
    }*/

    .detail-value {
        flex: 1;
        font-weight: 400;
        color: #212529;
    }

    .input-group-text {
