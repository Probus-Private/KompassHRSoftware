<script>
    $(document).ready(function () {
        debugger;
        var A_SalaryDate = @Html.Raw(Json.Encode(TempData["A_SalaryDate"]));
        $("#txtA_SalaryDate").val(A_SalaryDate);

        var B_SalaryDate = @Html.Raw(Json.Encode(TempData["B_SalaryDate"]));
        $("#txtB_SalaryDate").val(B_SalaryDate);

        var C_SalaryDate = @Html.Raw(Json.Encode(TempData["C_SalaryDate"]));
        $("#txtC_SalaryDate").val(C_SalaryDate);


        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });

    function SendToApproval() {
        let FnfCalId = $("#FnfCalId").val();
        const SendButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        SendButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, Send it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("SendToApproval", "ESS_FNF_Maxroof_FNFCalculationStatement")?FNFCald=' + FnfCalId;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

