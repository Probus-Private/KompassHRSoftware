                        <!-- Earning Section -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fa fa-arrow-up me-2"></i>Earnings (A)</h5>
                            </div>
