<script>
    $(document).on('input', '.numeric', function () {
        // Remove any non-numeric characters except decimal
        this.value = this.value.replace(/[^0-9.]/g, '');

        // Allow only one decimal point
        const parts = this.value.split('.');
        if (parts.length > 2) {
            this.value = parts[0] + '.' + parts[1];
        }
    });
</script>
<script>
    function OpenModule()
    {
        $("#myModalFinal").modal('show');
    }

    function Approved(Approver,Process) {
        debugger;
        let FNFCald = $("#FNFCald").val();
        var Status = "";
        var Remark = "";
        if (Approver == "Rejected") {
            Remark = $("#txtApproveRejectRemark").val();
            Status = "Rejected";
        }
        else {
            Status = "Approved";
            Remark = "";
        }
        let Url="";
        if (Process === 'Checker') {
            Url = '@Url.Action("ForFNFCheckerApproval", "ESS_FNF_Maxroof_FNFCalculationStatement", new { area = "ESS" })';
        } else {
            Url = '@Url.Action("ForFNFAccountApproval", "ESS_FNF_Maxroof_FNFCalculationStatement", new { area = "ESS" })';
        }

        $.ajax({
            url: Url,
            method: "Post",
            data: {FNFCald:FNFCald, Status: Status, Remark: Remark },
            success: function (response) {
                debugger;

                var Message1 = response.Message;
                var Icon1 = response.Icon;

                if (Message1) {debugger

                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup();
                            popup.classList.remove('swal2-show');
                            setTimeout(() => popup.classList.add('animate__animated', 'animate__headShake'));
                            setTimeout(() => popup.classList.remove('animate__animated', 'animate__headShake'), 500);
                            return false;
                        }
                    }).then((result) => {

                        $("#txtApproveRejectRemark").val("");

                        if (result.isConfirmed) {debugger
                            $("#myModalFinal").modal('hide');
                            window.location.href = '@Url.Action("GetList", "ESS_FNF_Maxroof_FNFCalculationStatement")';
                        }
                    });
                }

                // Hide modal for success case
                if (Icon1 !== "error") {
                    $("#myModalFinal").modal('hide');
                    $("#txtApproveRejectRemark").val("");
                }
            }
        });
    }


</script>

