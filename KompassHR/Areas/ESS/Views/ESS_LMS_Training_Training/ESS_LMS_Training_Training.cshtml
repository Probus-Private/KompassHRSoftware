
@{
    ViewBag.Title = "ESS_LMS_Training_Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
      margin: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f5f5f5;
    }

    .container {
      display: grid;
      grid-template-columns: repeat(3, 1fr); /* Default: 3 columns */
      gap: 20px;
      padding: 40px;
      max-width: 1200px;
      margin: auto;
    }

    .card {
      background-color: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      text-align: center;
      transition: transform 0.2s;
      cursor: pointer;
      text-decoration: none !important;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card img {
      width: 100%;
      height: 140px;
      /*object-fit: cover;*/
    }

    .card h3 {
      margin: 0;
      padding: 12px;
      font-weight: 500;
      color: #333;
      font-size: 16px;
    }

    /* Responsive for mobile */
    @@media (max-width: 768px) {
      .container {
        grid-template-columns: 1fr; /* Show only 1 column on mobile */
      }
    }
</style>

<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<link href="~/assets/MyCSS/MenuImages.css" rel="stylesheet" />
<link href="~/Content/Site.css" rel="stylesheet" />

<div id="content" class="app-content">
    <div class="pageHeader d-flex align-items-center justify-content-between" style="flex-wrap:nowrap;">
        <h5 class="page-header text-center text-md-start">Training </h5>
        <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
            <li style="margin-right: 10px;">
                <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                    <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                </a>
            </li>
            <li>
                <a href="@Url.Action("ESS_LMS_TrainingMenu", "ESS_LMS_TrainingMenu",  new { id = 38,ScreenId=587, area = "ESS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row g-2">
                        <!-- g-2 gives consistent spacing without breaking the row -->
                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-purple">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-archive fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Training Course</div>
                                    <div class="stats-number">
                                        <a href="@Url.Action("GetList", "ESS_Training_TraningCategory")" style="color:white;">@TempData["Training_Category"]</a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 76.3%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-teal">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-globe fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Training Category</div>
                                    <div class="stats-number">
                                        <a href="@Url.Action("GetList", "ESS_Training_TraningSubCategory", new { area = "ESS" })" style="color:white;">@TempData["Training_SubCategory"]</a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 40.5%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-purple">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-archive fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Training</div>
                                    <div class="stats-number" style="font-size:12px;">
                                        External Trainer:
                                        <a href="@Url.Action("GetList", "ESS_Training_TrainingTrainer", new { area = "ESS" })" style="color:white;">@TempData["External_Trainer"]</a><br />
                                        Internal Trainer:
                                        <a href="@Url.Action("GetList", "ESS_Training_TrainingInternal", new { area = "ESS" })" style="color:white;">@TempData["Training_Internal"]</a><br />
                                        Training Agency:
                                        <a href="@Url.Action("GetList", "ESS_Training_Training_Agency", new { area = "ESS" })" style="color:white;">@TempData["Training_Agency"]</a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 76.3%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-orange">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-file-alt fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Training Calender</div>
                                    <div class="stats-number">
                                        <a href="@Url.Action("GetList", "ESS_Training_TrainingCalender", new { area = "ESS" })" style="color:white;">@TempData["Training_Calender"] </a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 23.5%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-teal">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-globe fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Training Plan</div>
                                    <div class="stats-number">
                                        <a href="@Url.Action("GetTrainingPlanList", "ESS_Training_TrainingPlan", new { area = "ESS" })" style="color:white;">@TempData["Training_Plan"]</a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 40.5%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-orange">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-file-alt fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Training Conduct</div>
                                    <div class="stats-number">
                                        <a href="@Url.Action("GetTrainingConductList", "ESS_Training_TrainingConduct", new { area = "ESS" })" style="color:white;">@TempData["Training_Conduct"]</a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 23.5%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="gradientLine-Div">
                        <div class="gradientLine1"> </div>
                        <div><strong>Menu</strong></div>
                        <div class="gradientLine2"> </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="row" style="padding: 0px 5px;">
                                @foreach (var item in ViewBag.GetUserMenuList)
                                {
                                    <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" class="col-md-2 col-3 d-flex" style="text-decoration:none !important; padding: 0px 5px;">

                                        <div class="quickLinks-box" style="margin-bottom: 10px;">
                                            <img src="~/assets/MenuImages/@item.Icon" width="50px" height="50px" />
                                            <h3>@item.ScreenDisplayMenuName</h3>
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>

                    @*<div class="container">
                        @foreach (var item in ViewBag.GetUserMenuList)
                        {
                            <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" class="card">
                                <img src="~/assets/MenuImages/@item.Icon" alt="@item.ScreenDisplayMenuName" />
                                <h3>@item.ScreenDisplayMenuName</h3>
                            </a>
                        }
                    </div>*@


                </div>
            </div>
        </div>
    </div>

</div>
<div class="row">
    <div class="col-lg-12 col-md-12">
        <div class="panel panel-inverse" data-sortable-id="index-1">
            <div class="panel-body" style="max-height:fit-content;">
            </div>
        </div>
    </div>
</div>

