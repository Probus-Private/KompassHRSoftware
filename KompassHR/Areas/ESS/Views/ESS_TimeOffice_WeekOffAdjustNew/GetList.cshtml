<script>
    document.addEventListener('DOMContentLoaded', function () {debugger
        const chkAllCheckbox = document.getElementById('chkAll');
        const dateWOFromDate = document.getElementById('dateWOFromDate');
        const dateWOAdjustDate = document.getElementById('dateWOAdjustDate');
        const chkAllVal = chkAllCheckbox.value;

        if (chkAllVal === "1") {
            chkAllCheckbox.checked = true;
            dateWOFromDate.disabled = true;
            dateWOAdjustDate.disabled = true;
        } else {
            chkAllCheckbox.checked = false;
            //WOfromdate.style.display = ''; // show date fields
            //WOAdjustDate.style.display = ''; // show date fields
            dateWOFromDate.disabled = false;
            dateWOAdjustDate.disabled = false;
        }
    });
</script>
