
@{
    ViewBag.Title = "Loan Settlement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
        /* ===== EMPLOYEE SUMMARY CARD ===== */
        .employee-card {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 16px 20px;
            margin-bottom: 20px;
        }

        .emp-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px 24px;
        }

        .emp-item {
            display: flex;
            flex-direction: column;
        }

        .emp-label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        /*.emp-value {
        font-size: 14px;
        font-weight: 700;
        color: #1f2937;
    }*/

        .emp-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            background: #dcfce7;
            color: #047857;
            width: fit-content;
        }

        .page-title {
            font-size: 22px;
            font-weight: 700;
            color: #1e293b;
        }

        .page-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .page-actions img {
                width: 24px;
                height: auto;
                cursor: pointer;
            }

        body {
            background: #f4f6fa;
            font-family: 'Segoe UI', sans-serif;
        }

        .review-wrapper {
            max-width: 1400px;
            margin: 20px auto;
            padding: 22px;
            background: #ffffff;
            border-radius: 10px;
            border: 1px solid #d1d5db;
        }

        .section-title {
            font-size: 15px;
            font-weight: 700;
            color: #1e3a8a;
            margin-bottom: 12px;
            padding: 8px 12px;
            background: #eef2ff;
            border-left: 4px solid #1e3a8a;
        }

        .info-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            background: #f9fafb;
            margin-bottom: 20px;
        }

            .info-table td {
                padding: 10px;
                border: 1px solid #d1d5db;
            }

            .info-table .label {
                background: #f1f5f9;
                font-weight: 600;
                width: 15%;
            }

        .calc-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .calc-table th {
                background: #e5e7eb;
                padding: 10px;
                border: 1px solid #c7cdd4;
                text-align: center;
                font-weight: 600;
            }

            .calc-table td {
                padding: 10px;
                border: 1px solid #d1d5db;
                text-align: center;
                background: #f8fafc;
            }

                .calc-table td.left {
                    text-align: left;
                    background: #ffffff;
                }

                .calc-table td.weightage {
                    background: #fef3c7;
                    font-weight: 700;
                }

                .calc-table td.score {
                    background: #dcfce7;
                    font-weight: 700;
                    color: #065f46;
                }

        .final-score {
            margin-top: 20px;
            padding: 16px;
            background: #ecfdf5;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            text-align: center;
            font-weight: 700;
            font-size: 18px;
            color: #047857;
        }
</style>

<div id="content" class="app-content">
    <div class="review-wrapper">
        <div class="row mb-3">
            <div class="col-md-12 d-flex justify-content-between align-items-center">
                <h1 class="page-title mb-0">
                    Competency Evaluation
                </h1>
                <div class="page-actions">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })"
                       title="Home">
                        <img src="~/assets/MenuImages/Home.png" alt="Home">
                    </a>

                    <a href="@Url.Action("ESS_PMS_Menu", "ESS_PMS_Menu",
                new { id = 11, ScreenId = 594, area = "ESS" })"
                       title="Back">
                        <img src="~/assets/MenuImages/Back.png" alt="Back">
                    </a>
                </div>
            </div>
        </div>
        <div class="section-title">Employee Information</div>
        <div class="employee-card">
            @foreach (var d in ViewBag.EmpInfo)
            {
                <div class="emp-grid">

                    <div class="emp-item">
                        <span class="emp-label">Employee Name</span>
                        <span class="emp-value">@d.EmployeeName</span>
                    </div>

                    <div class="emp-item">
                        <span class="emp-label">Department</span>
                        <span class="emp-value">@d.DepartmentName</span>
                    </div>

                    <div class="emp-item">
                        <span class="emp-label">Designation</span>
                        <span class="emp-value">@d.DesignationName</span>
                    </div>

                    <div class="emp-item">
                        <span class="emp-label">Total Competencies</span>
                        <span class="emp-value">@d.TotalCompetencies</span>
                    </div>

                    <div class="emp-item">
                        <span class="emp-label">Status</span>
                        <span class="emp-badge">@d.Status</span>
                    </div>

                </div>
            }
        </div>


        <!-- COMPETENCY TABLE -->
        <div class="section-title">Competency Evaluation</div>

        <table class="calc-table">
            <thead>
                <tr>
                    <th>Framework</th>
                    <th>Competency</th>
                    <th>Appraisee Rating</th>
                    <th>Appraiser Rating</th>
                    <th>Weightage</th>
                    <th>Weightage × Rating</th>

                </tr>
            </thead>

            <tbody>
                @foreach (var c in ViewBag.CompetencyInfo)
            {
                    <tr class="comp-row">
                        <td class="left">@c.Framework</td>
                        <td class="left">@c.Competency</td>
                        <td>@c.AppraiseeRating</td>
                        <td class="rating" data-rating="@c.AppraiserRating">
                            @c.AppraiserRating
                        </td>
                        <td class="weightage" data-weightage="@c.Weightage">
                            @c.Weightage
                        </td>
                        <td class="score">0</td>

                    </tr>
                }
            </tbody>

            <tfoot>
                <tr>
                    <td colspan="4"><b>Total</b></td>
                    <td id="totalWeightage" class="weightage">0</td>
                    <td id="totalScore" class="score">0</td>
                </tr>
                <tr>
                    <td colspan="5"><b>Final Competency Score</b></td>
                    <td id="finalCompetencyScore" class="score">0</td>
                </tr>
            </tfoot>
        </table>

        <div class="final-score">
            Final Appraisal (Competency) Rating :
            <b><span id="finalScoreText"></span></b>
        </div>

    </div>

</div>

<script>
        function calculateCompetencyScore() {

            let totalWeightage = 0;
            let totalScore = 0;

            document.querySelectorAll(".comp-row").forEach(row => {

                let rating = parseFloat(row.querySelector(".rating").dataset.rating) || 0;
                let weightage = parseFloat(row.querySelector(".weightage").dataset.weightage) || 0;

                let score = rating * weightage;

                row.querySelector(".score").innerText = score.toFixed(2);

                totalWeightage += weightage;
                totalScore += score;
            });

            document.getElementById("totalWeightage").innerText = totalWeightage.toFixed(2);
            document.getElementById("totalScore").innerText = totalScore.toFixed(2);

            let finalScore =
                totalWeightage > 0
                    ? (totalScore / totalWeightage).toFixed(2)
                    : "0.00";

            document.getElementById("finalCompetencyScore").innerText = finalScore;
            document.getElementById("finalScoreText").innerText = finalScore;
        }

        document.addEventListener("DOMContentLoaded", calculateCompetencyScore);
</script> 