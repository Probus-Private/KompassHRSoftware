@model KompassHR.Areas.Reports.Models.DailyAttendanceReportFilter

@{
    ViewBag.Title = "ESS_TMS_ProjectProgressReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Required library for validation -->
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }
    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .width-45 {
        width: 45px !important;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Project Progress Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_TMSReports", "ESS_TMS_TMSReports", new { id = 12, ScreenId = 232, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Project Progress Report<b></b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("ESS_TMS_ProjectProgressReport", "ESS_TMS_ProjectProgressReport", new { area = "ESS" })" id="ProjectProgressReport" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", type = "date", name = "FromDate", id = "txtFromDate" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", type = "date", name = "ToDate", id = "txtToDate" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Project Name
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ProjectID, new SelectList(ViewBag.TMSProject, "Id", "Name"), "--All--", new { id = "ddlProjectID", name = "ProjectID", @class = "form-select", onchange = "onProjectChange()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Status
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownListFor(model => model.Status, new List<SelectListItem>
                                                {
                                                    new SelectListItem { Text = "Select", Value = "" },
                                                    new SelectListItem { Text = "Pending", Value = "Pending" },
                                                    new SelectListItem { Text = "Complete", Value = "Complete" }
                                                }, new { @class = "form-select", id = "ddlStatus", name = "Status" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnShow">
                                                    Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="panel-body" data-scrollbar="false">
                                                <!-- BEGIN table-responsive -->
                                                <div class="table-scroll div1">
                                                    <div class="table-wrap">
                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage tblAddData">
                                                            <thead style="background-color: rgba(233, 236, 239, 1) !important; width:auto">
                                                                <tr>
                                                                    <th class="text-nowrap">Type</th>
                                                                    <th class="text-nowrap">Client Name</th>
                                                                    <th class="text-nowrap">Project Name</th>
                                                                    <th class="text-nowrap">Module Name</th>
                                                                    <th class="text-nowrap">Employee Name</th>
                                                                    <th class="text-nowrap">Task Status</th>
                                                                    <th class="text-nowrap">Complete Percentage</th>
                                                                    <th class="text-nowrap">Task Date</th>
                                                                    <th class="text-nowrap">Task Title</th>
                                                                    <th class="text-nowrap">Task Description</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblTmsReports">
                                                                @if (ViewBag.GetProjectProgressReport != null)
                                                                {
                                                                    foreach (var d in ViewBag.GetProjectProgressReport)
                                                                    {
                                                                        <tr>
                                                                            <td class="text-nowrap">@d.Type</td>
                                                                            <td class="text-nowrap">@d.ClientName</td>
                                                                            <td class="text-nowrap">@d.ProjectName</td>
                                                                            <td class="text-nowrap">@d.ModuleName</td>
                                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                                            <td class="text-nowrap">@d.TaskStatus</td>
                                                                            <td class="text-nowrap">@d.CompletePercentage</td>
                                                                            <td class="text-nowrap">@d.TaskDate</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-start text-center">
                                                                                <input type="hidden" id="hiddenDescription_@d.Id" value="@d.TaskDescription" />
                                                                                <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.Id').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                                <!-- END table-responsive -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>
<div class="modal fade" id="modal_basic3" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Task Description</h4>
                <div class="panel-heading-btn">
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div id="txtTaskStatus"></div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" id="btnCancel" class="btn btn-success btnpress" onclick="dismissModal('modal_basic3')">
                    <i class="fa-solid fa-floppy-disk"> </i> Ok
                </button>
            </div>
        </div>
    </div>
</div>

<script>

    $(document).ready(function () {
        $("#ddlProjectID").select2();
        $("#ddlStatus").select2();
    });//ready function
    $("#ProjectProgressReport").validate({
        rules: {
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },
            ProjectID: {
                required: true,
            },
            Status: {
                required: true,
            },
        },
        messages: {
            FromDate: {
                required: "From Date is required"
            },
            ToDate: {
                required: "To Date is required"
            },
            ProjectID: {
                required: "Project Name is required",
            },
            Status: {
                required: "Status Name is required",
            },
        }
    });

    var form = $("#ProjectProgressReport");
    form.validate();
    $("#btnShow").click(function () {
        debugger;
       
        form.valid();
        if (form.valid() == false) {
            $("#txtFromDate").removeClass("error");
            $("#txtToDate").removeClass("error");
            return false;
        }
        $("#ProjectProgressReport").submit();
    });
</script>

<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth, day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

    function AssignTaskDesc(encodedHtml) {
        debugger;
        $('#txtTaskStatus').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtTaskStatus').html(AssignDesc);
            //$('#txtTaskStatus').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#TaskDescription').html('');
        $('#tblTask tr').not(function () { return !!$(this).has('th').length; }).remove();
        $('#' + modalId).modal('hide');
    }
</script>
