
@{
    ViewBag.Title = "ESS_TimeOffice_CancelApproval";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .fa-share-from-square {
        transform: rotate(180deg);
    }

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
          background-color: rgba(233, 236, 239, 0.5) !important;
      }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 60px; /* Set the width for the first column */
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Cancel Approval Request
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new {id = 5, ScreenId=150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Cancel Approval Request - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of positions authorised by manager.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage3">
                                    <thead>
                                        <tr class="trheading text-center">
                                            <th class="fixed-side">View</th>
                                            <th class="text-nowrap text-center">Employee Name</th>
                                            <th class="text-nowrap text-center">Origin</th>
                                            <th class="text-nowrap text-center">Pending Since</th>
                                            <th class="text-nowrap text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.TimeOfficeCancelApprovalList)
                                        {
                                            <tr>
                                                <td class="text-center">
                                                    <a id="btnUpdate" onclick="ViewForApprover('@d.DocId_Encrypted','@d.Origin')">
                                                        <i class="fa-solid fa-eye text-danger fa-lg"></i>
                                                    </a>
                                                </td>
                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                <td class="text-nowrap">@d.Origin</td>
                                                <td class="text-nowrap">@d.PendingSince</td>
                                                <td class="text-nowrap">@d.Status</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="row">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <a href="@Url.Action("ESS_Leave_CancelApproveRejectedList", "ESS_TimeOffice_CancelApproval", new { area = "ESS" })">
                                                <button type="submit" id="btnManualUpload" class="btn btn-primary btn-sm">
                                                    Canceled List
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Reject</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                       aria-hidden="true">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Approved()" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress btnClear" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    function ViewForApprover(DocId_Encrypted, Origin) {
        debugger
        if (Origin == 'Leave') {
            var url = '@Url.Action("ViewForLeaveCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }

        if (Origin == 'OD') {
            var url = '@Url.Action("ViewForODCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'PM') {
            var url = '@Url.Action("ViewForCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'PG') {
            var url = '@Url.Action("ViewForPGCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'WFH') {
            var url = '@Url.Action("ViewForWFHCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'SL') {
            var url = '@Url.Action("ViewForSLCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'CO') {
            var url = '@Url.Action("ViewForCoffRequestCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'SC') {
            var url = '@Url.Action("ViewForShiftChangeRequestCancelApprover", "ESS_TimeOffice_CancelApproval")?DocId_Encrypted=' + DocId_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }

    }
    var Resource = "";
    var ResourceEncrypted = "";
    function OpenModule(ResourceId, ResourceId_Encrypted) {
        debugger;
        Resource = ResourceId;
        ResourceEncrypted = ResourceId_Encrypted;
        $("#myModalFinal").modal('show');
    }


    function Approved(ResourceId, ResourceId_Encrypted) {
        debugger
        var DocId = "";
        var Encrypted = "";
        var Status = "";
        if (ResourceId_Encrypted != undefined) {
            DocId = ResourceId;
            Encrypted = ResourceId_Encrypted;
            Status = "Approved";
        }
        else {
            DocId = Resource;
            Encrypted = ResourceEncrypted;
            Status = "Rejected";
        }
        var Remark = "";
        if (Status == "Rejected") {
            Remark = $("#txtApproveRejectRemark").val();
        }

        $.ajax({
            url: "@Url.Action("ForCancelApprovalRequest", "ESS_TimeOffice_CancelApproval")",
            method: "get",
            data: { DocId: DocId, Encrypted: Encrypted, Status: Status, Remark: Remark },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });

                            $("#myModalFinal").modal('hide');
                            $("#txtApproveRejectRemark").val("");
                            location.reload();
                        }
                    }
                }
                else {
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon == "success") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                                $("#myModalFinal").modal('hide');
                                $("#txtApproveRejectRemark").val("");
                                location.reload();
                            }
                        }
                    }
                }
            }
        });
    }
</script>


