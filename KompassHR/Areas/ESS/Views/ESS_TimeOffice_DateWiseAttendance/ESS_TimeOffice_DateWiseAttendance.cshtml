<script>
   var Atten_Regu_MaxDay = @Html.Raw(Json.Encode(TempData["Atten_Regu_MaxDay"]));
</script>


<script>
    document.getElementById("dateFromDate").addEventListener("blur", function () {
        var dateValue = this.value;
        if (dateValue.includes("-")) {
            var parts = dateValue.split("-"); 
            dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
        }
        var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
        if (!regex.test(dateValue)) {
            $("#ErrordateFromDate").html("Please enter valid date in DD-MM-YYYY format");
            this.value = "";
            this.focus();
            return;
        } else {
            $("#ErrordateFromDate").html("");
        }
    });




    function handleDateChange(selectedDate) {
        debugger;
        var currentDate1 = new Date();
        var CheckNewDate = new Date(selectedDate);
        if (currentDate1.getDate() == CheckNewDate.getDate()) {
            currentDate1.setDate(currentDate1.getDate() + 0);
            var SetMaxDays = currentDate1.toISOString().split('T')[0];
            document.getElementById("dateToDate").setAttribute("max", SetMaxDays);
        }
        else
        {
            CheckNewDate.setDate(CheckNewDate.getDate() + Atten_Regu_MaxDay);
            var GetNewDate = CheckNewDate.toDateString();
            var CheckNewDate = new Date(GetNewDate);
            var year = CheckNewDate.getFullYear();
            var month = ("0" + (CheckNewDate.getMonth() + 1)).slice(-2);
            var day = ("0" + CheckNewDate.getDate()).slice(-2);
            var isoDate = year + "-" + month + "-" + day;
            var CheckNewDates = new Date(isoDate);

            if (currentDate1 < CheckNewDates) {
                currentDate1.setDate(currentDate1.getDate() + 0);
                var SetMaxDays = currentDate1.toISOString().split('T')[0];
                document.getElementById("dateToDate").setAttribute("max", SetMaxDays);

                const fromDate = document.getElementById('dateFromDate');
                const toDate = document.getElementById('dateToDate');
                toDate.min = fromDate.value;
            }
            else
            {
                CheckNewDate.setDate(CheckNewDate.getDate() + 0);
                var SetMaxDays = CheckNewDate.toISOString().split('T')[0];
                document.getElementById("dateToDate").setAttribute("max", SetMaxDays);

                const fromDate = document.getElementById('dateFromDate');
                const toDate = document.getElementById('dateToDate');
                toDate.min = fromDate.value;
            }
        }
    }
</script>

