<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Overdue Task Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_TMSReports", "ESS_TMS_TMSReports", new { id = 12, ScreenId = 232, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Overdue Task Report<b></b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("ESS_TMS_OverdueTasksReport", "ESS_TMS_OverdueTasksReport", new { area = "ESS" })" id="SaveOverdueTaskReport" method="post">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Client Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ClientId, new SelectList(ViewBag.TMSClient, "Id", "Name"), "--Select--", new { id = "txtClientID", name = "ClientID", @class = "form-select" })
                                                <span class="text-danger" id="ErrorClientId"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Project Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ProjectId, new SelectList(ViewBag.TMSProject, "Id", "Name"), "--Select--", new { id = "txtProjectID", name = "ProjectID", @class = "form-select" })
                                                <span class="text-danger" id="ErrorProjectId"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Module Name
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ModuleId, new SelectList(ViewBag.TMSModule, "Id", "Name"), "--All--", new { id = "txtModuleID", name = "ModuleID", @class = "form-select" })
                                                <span class="text-danger" id="ErrorModuleId"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="col-md-4 col-form-label">
                                                Employee Name 
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.EmployeeId, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "--All--", new { @class = "form-select", id = "ddlEmployeeId" })
                                                <span class="text-danger" id="ErrorEmployeeId"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", type = "date", name = "FromDate", id = "txtFromDate" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", type = "date", name = "ToDate", id = "txtToDate" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-10">
                                            </div>
                                            <div class="col-md-2">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                            <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('title').html("Overdue Task Report");
        $("#ddlEmployeeId").select2();
        $("#txtProjectID").select2();
        $("#txtClientID").select2();
        $("#txtModuleID").select2();

        // Get current date
        var today = new Date();

        // Format as YYYY-MM-DD (HTML5 date input format)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0');
        var dd = String(today.getDate()).padStart(2, '0');

        var currentDate = yyyy + '-' + mm + '-' + dd;

        // Set default values if empty
        if (!$('#txtFromDate').val()) {
            $('#txtFromDate').val(currentDate);
        }
        if (!$('#txtToDate').val()) {
            $('#txtToDate').val(currentDate);
        }

        // Add date validation
        $('#txtFromDate, #txtToDate').change(function () {
            validateDateRange();
        });

        function validateDateRange() {
            const fromVal = $('#txtFromDate').val();
            const toVal = $('#txtToDate').val();

            if (fromVal && toVal) {
                if (toVal < fromVal) {
                    $('#monthError').show();
                } else {
                    $('#monthError').hide();
                }
            }
        }

        var Title = @Html.Raw(Json.Encode(TempData["Title"]));
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            $(".Userloaderbg").css("display","none");
            if (Message != null) {
                var Text = "Your Download File Path Is "+Title+"";
                Swal.fire({
                    title: Message,
                    icon: Icon,
                    text: Text,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }

        $("#txtProjectID").on("change", function () {debugger
            debugger;
            var projectId = document.getElementById("txtProjectID").value;
            var clientId = document.getElementById("txtClientID").value;
            $("#txtModuleID").find("option").remove();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetModule", "ESS_TMS_OverdueTasksReport")',
                data: { ProjectId: projectId, clientId: clientId },
                success: function (response) {
                    // Handle Module Dropdown
                    var $moduleDropdown = $("#txtModuleID");
                    $moduleDropdown.empty().append("<option value=''>--All--</option>");

                    if (response.data && response.data.length > 0) {
                        $.each(response.data, function (i, module) {debugger
                            $moduleDropdown.append(
                                $("<option>").val(module.Id).text(module.Name)
                            );
                        });
                    }
                },
                error: function () {
                    console.error("Failed to fetch data.");
                    $("#txtModuleID").empty().append("<option value=''></option>");
                }
            });
        });

        $("#txtClientID").on("change", function () {debugger
            var clientId = document.getElementById("txtClientID").value;
            $("#txtProjectID").find("option").remove();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetProject", "ESS_TMS_OverdueTasksReport", new { area = "ESS" })',
                data: { Clientd: clientId },
                success: function (data) {
                    // Populate Business Unit dropdown
                    var Project = data.Project || [];
                    if (Project.length > 0) {
                        $("#txtProjectID").append("<option value=''>--Select--</option>");
                        $.each(Project, function (i, p) {
                            $("#txtProjectID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                },
                error: function () {
                    alert("Error loading business units or managers.");
                }
            });
        });
    });
</script>
<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0' + hours : hours;
        minutes = minutes < 10 ? '0' + minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth, day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>

<script>
    $("#SaveOverdueTaskReport").validate({
        rules: {
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },
            ClientId: {
                 required: true,
            },
            ProjectId: {
                required: true,
            },
            //EmployeeId: {
            //    required: true,
            //},
        },
        messages: {
            FromDate: {
                required: "From Date is required"
            },
            ToDate: {
                required: "To Date is required"
            },
            ClientId: {
                required: "Project Name is required"
            },
            ProjectId: {
                required: "Project Name is required"
            },
            //EmployeeId: {
            //    required: "Employee Name is required"
            //},
        }
    });

    var form = $("#SaveOverdueTaskReport");
    form.validate();
    function downloadExcelFile() {
        debugger;

        form.valid();
        if (form.valid() == false) {
            $("#txtFromDate").removeClass("error");
            $("#txtToDate").removeClass("error");
            return false;
        }
        var ClientId =$("#txtClientID").val();
        var ProjectId =$("#txtProjectID").val();
        var ModuleId =$("#txtModuleID").val();
        var EmployeeId =$("#ddlEmployeeId").val();
        var FromDate =$("#txtFromDate").val();
        var ToDate =$("#txtToDate").val();

        $.ajax({
            url: '@Url.Action("DownloadExcelFile", "ESS_TMS_OverdueTasksReport")',
            method: 'GET',
            data:{ClientId:ClientId,
                ProjectId:ProjectId,
                ModuleId:ModuleId,
                EmployeeId:EmployeeId,
                FromDate:FromDate,
                ToDate:ToDate
            },
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                // Format dates for filename
                var formattedDate = convertMonthYearFormat(FromDate);
                var formattedToDate = convertMonthYearFormat(ToDate);

                // Create and download file
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'EmployeeWiseTMSReport('+formattedDate+' to '+formattedToDate+').xlsx';
                anchorElement.click();
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }
</script>

