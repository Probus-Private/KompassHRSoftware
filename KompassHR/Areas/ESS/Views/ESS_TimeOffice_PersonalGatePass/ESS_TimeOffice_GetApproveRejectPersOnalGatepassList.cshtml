                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new {id = 5, ScreenId=150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
   
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Personal Gatepass - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> 
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of personal gatepass list.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_TimeOffice_PersonalGatePass", "ESS_TimeOffice_PersonalGatePass", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="trheading">
                                                <th class="text-nowrap">Cancel</th>
                                                <th class="text-nowrap">Delete</th>
                                                <th class="text-nowrap">Status</th>
                                                <th class="text-start text-nowrap">Doc No </th>
                                                <th class="text-start text-nowrap">Req Date</th>
                                                <th class="text-start text-nowrap">Shift</th>
                                                <th class="text-start text-nowrap">For Time</th>
                                                <th class="text-start text-nowrap">Reason</th>
                                                <th class="text-start text-nowrap">Approve/Rejected by</th>
                                                <th class="text-start text-nowrap">Approve/Rejected Date</th>
                                                <th class="text-start text-nowrap">Rejected Reason</th>
                                                <th class="text-nowrap text-center">Auto/Manually</th>
                                                <th class="text-nowrap text-center">Out/In Time</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.PersoanlGetpass)
                                            {
                                                <tr>
                                                    @if (@d.CancelStatus != " ")
                                                    {
                                                        <td class="text-center"> @d.CancelStatus</td>
                                                    }
                                                    else
                                                    {
                                                        <td class="text-center">
                                                            <a href="#modal-dialogForHoldReject1" onclick="CancelRequestFun(@d.PersonalGatepassId,'@d.Status')" id="btnmodal-dialog1">
                                                                <i class="fa-solid fa-xmark fa-xl text-dark" style="color:black"></i>
                                                            </a>
                                                        </td>
                                                    }
                                                    <td class="text-center">
                                                        <a id="btnDelete" onclick="DeletePersonalGetPass('@d.PersonalGatepassId_Encrypted','@d.PersonalGatepassId','@d.Status')"
                                                           style="cursor:pointer">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-nowrap">
                                                        <i class="fa-solid fa-circle-info text-success fa-lg" style="cursor: pointer;" onclick="ApproveStatus(@d.PersonalGatepassId)"></i> &nbsp;
                                                        @d.ApprovedDay
                                                    </td>
                                                    <td class="text-nowrap">@d.DocNo</td>
                                                    <td class="text-nowrap">@d.ReqDate</td>
                                                    <td class="text-nowrap">@d.PersonalGatepassShiftName</td>
                                                    <td class="text-nowrap">@d.ForTime</td>
                                                    <td class="text-nowrap">@d.Reason</td>
                                                    <td class="text-nowrap">@d.ApprovedBy</td>
                                                    <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                    <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                    <td class="text-nowrap">@d.ApprovedAutoManually</td>
                                                    <td class="text-nowrap">@d.Visitor_INOut</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>

