                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

        <div class="col-md-4">
            <div class="panel panel-inverse" data-sortable-id="index">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Conflict Employee</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>

                <div class="panel-body" data-scrollbar="true" style="height:400px;">

                    <table class="table table-bordered table-hover mb-0 text-dark TablePage1" id="tblLeaveBalance">
                        <thead>
                            <tr style="background-color:#eee">
                                <th class="text-center">Conflict Employee</th>
                                <th class="text-center">From Date</th>
                                <th class="text-center">To Date</th>
                                @*<th class="text-center">Total Days</th>*@
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in ViewBag.GetConflictEmployee)
                            {
                                <tr>
                                    <td class="text-nowrap">@d.EmployeeName</td>
                                    <td class="text-nowrap">@d.FromDate</td>
                                    <td class="text-nowrap">@d.ToDate</td>
                                    @*<td class="text-nowrap">@d.TotalDays</td>*@
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    document.getElementById("txtFromDate").addEventListener("blur", function () {
        var dateValue = this.value;
        if (dateValue.includes("-")) {
            var parts = dateValue.split("-"); 
            dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
        }
        var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
        if (!regex.test(dateValue)) {
            $("#ErrortxtFromDate").html("Please enter valid date in DD-MM-YYYY format");
            this.value = "";
            this.focus();
            return;
        } else {
            $("#ErrortxtFromDate").html("");
        }
    });


  

    $(document).ready(function () {
        var GetMinMaxDate = @Html.Raw(Json.Encode(TempData["GetMinMaxDate"]));
        debugger;
        var MinDate = GetMinMaxDate[0].Value;
        var MaxDate = GetMinMaxDate[1].Value;
        var currentDate = new Date();
        var currentDateMax = new Date();
        //For MinDate Set

        currentDate.setDate(currentDate.getDate() - MinDate); //2 Meanse Currect daye plus 2 days enabled only
        currentDateMax.setDate(currentDateMax.getDate() + MaxDate); //2 Meanse Currect daye plus 2 days enabled only
        var SetMinDays = currentDate.toISOString().split('T')[0];
        var SetMaxDays = currentDateMax.toISOString().split('T')[0];
        document.getElementById("txtToDate").setAttribute("min", SetMinDays);
        document.getElementById("txtToDate").setAttribute("max", SetMaxDays);
        document.getElementById("txtFromDate").setAttribute("min", SetMinDays);
        document.getElementById("txtFromDate").setAttribute("max", SetMaxDays);

        $("#ddlShiftNameId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#txtToDate").val(dateString);
        $("#txtFromDate").val(dateString);

    });//Ready Funcation
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       debugger;
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveShiftChange").validate({

        rules: {
            FromDate: {
                required: true,

            },
            ToDate: {
                required: true,

            },
            ShiftChangeShiftId: {
                required: true,

            },
            ShiftChangeReason: {
                required:true,
            },

        },
        messages: {
            FromDate: {
                required: "From date is required",

            },
            ToDate: {
                required: "To date is required",

            },
            ShiftChangeShiftId: {
                required: "Shift name is required",

            },
            ShiftChangeReason: {
                required: "Reason is required",
            },

        }
    });

    //<-----------------------------Alreay exist---------------------------------->
    var form = $("#SaveShiftChange");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtToDate").removeClass('error');
            $("#txtFromDate").removeClass('error');
            return false;
        }
        var ToDate = $("#txtToDate").val();
        var FromDate = $("#txtFromDate").val();
        var ShiftNameId = $("#ddlShiftNameId").val();
        var StartDate= document.getElementById('txtFromDate').value;
        var EndDate= document.getElementById('txtToDate').value;
        var eDate = new Date(EndDate);
        var sDate = new Date(StartDate);
        if(StartDate!= '' && EndDate!= '' && sDate > eDate)
        {
            $("#ErrortxtToDate").html("To date should not be less than from date.");
            $("#txtToDate").val('');
            return false;
        }
        else{
            $("#ErrortxtToDate").html("");
        }

        $(".Userloaderbg").css("display","flex");
        $.ajax({
            url: '@Url.Action("IsShiftChangeExists", "ESS_TimeOffice_ShiftChange")',
            method:"get",
            data:{ShiftNameId:ShiftNameId,FromDate:FromDate,ToDate:ToDate},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                $(".Userloaderbg").css("display","none");
                if (response.Icon=="error" || response.Icon=="") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });

                        }
                    }
                    return false;
                }
                else{
                    $(".Userloaderbg").css("display","flex");
                    $("#SaveShiftChange").submit();
                }
            }
        });

    });

    //$("#txtToDate").change(function () {
    //    debugger;



    //    var StartDate= document.getElementById('txtFromDate').value;
    //    var EndDate= document.getElementById('txtToDate').value;
    //    var eDate = new Date(EndDate);
    //    var sDate = new Date(StartDate);
    //    if(StartDate!= '' && EndDate!= '' && sDate > eDate)
    //    {
    //        $("#ErrortxtToDate").html("To date should not be less than from date.");
    //        $("#txtToDate").val('');

    //    }
    //    else{
    //        $("#ErrortxtToDate").html("");
    //    }
    //});



    $("#txtToDate").blur(function () {

        var input = document.getElementById("txtToDate");

        if (!input.checkValidity()) {
            $("#ErrortxtToDate").html("Please enter valid date");
            input.value = "";
            return;
        }

        $("#ErrortxtToDate").html("");

        var from = $("#txtFromDate").val();
        var to = $("#txtToDate").val();

        if (from && to) {
            var sDate = new Date(from);
            var eDate = new Date(to);

            if (sDate > eDate) {
                $("#ErrortxtToDate").html("To date should not be less than From date");
                $("#txtToDate").val("");
            }
        }

    });



</script>

<script>
    debugger;
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>