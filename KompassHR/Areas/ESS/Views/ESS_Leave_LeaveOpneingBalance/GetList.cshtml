@model KompassHR.Areas.ESS.Models.ESS_Leave.Leave_OpeningBalance
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Opening balance
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
   
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Leave Opening balance  - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Leave Opening balance
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("GetList", "ESS_Leave_LeaveOpneingBalance", new { area = "ESS" })'  id="SaveLeaveOpneingBalance" method="post">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="@Url.Action("ESS_Leave_LeaveOpneingBalance", "ESS_Leave_LeaveOpneingBalance", new { area = "ESS" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Company
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.ComapnyName, "Id", "Name"), "--Select--", new { id = "txtCmpID", name = "CmpID", @class = "form-select", autocomplete = "off", onChange = "ChangeConpany()" })
                                        <span id="ErrortxtCmpID" class="Error"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Business Unit
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(model => model.LeaveOpeningBalanceBranchID, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { id = "txtBranchname", name = "LeaveOpeningBalanceSettingId", @class = "form-select", autocomplete = "off" })
                                        <span id="ErrortxtBranchname" class="Error"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Leave Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(model => model.LeaveOpeningBalanceLeaveYearId, new SelectList(ViewBag.GetLeaveYear, "Id", "Name"), "--Select--", new { id = "LeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-control", autocomplete = "off" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Leave Type
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-7">
                                        @Html.DropDownListFor(model => model.LeaveOpeningBalanceLeaveTypeId, new SelectList(ViewBag.LeaveTypeName, "Id", "Name"), "--Select--", new { id = "LeaveOpeningBalanceLeaveTypeId", name = "LeaveTypeId", @class = "form-select", autocomplete = "off" })
                                        <span id="ErrorLeaveOpeningBalanceLeaveTypeId" class="Error"></span>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn btn-primary btn-sm" id="btnGetAllEmployeeInformation" onclick="GetAllEmployeeInformation()">
                                            Show
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered align-middle TablePage" id="tblSelectAllCheckbox"
                                   style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th class="text-center" colspan="2">
                                            <label><input type="checkbox" class="allChecked" name="checkbox" id="AllCheckBox" onclick="toggle(this);" value="value">  All</label>
                                            <a id="DeleteBtn" onclick="DeleteAllOpeningbalance()" style="cursor:pointer;">
                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                            </a>
                                        </th>
                                        <th></th>
                                        <th></th>
                                        <th> </th>
                                        <th> </th>
                                        <th> </th>
                                        <th> </th>
                                        <th> </th>
                                        <th> </th>
                                        <th> </th>
                                        <th> </th>

                                    </tr>

                                    <tr>
                                        <th class="text-nowrap">Select</th>
                                        <th class="text-nowrap">Delete</th>
                                        <th class="text-nowrap">Leave Year Type</th>
                                        <th class="text-nowrap">Company Name </th>
                                        <th class="text-nowrap">Busniess unit </th>
                                        <th class="text-nowrap">Employee Name </th>
                                        <th class="text-nowrap">No Of Leave</th>
                                        <th class="text-nowrap">Employee No</th>
                                        <th class="text-nowrap">Date Of Joining </th>
                                        <th class="text-nowrap">Confirmation Date </th>
                                        <th class="text-nowrap">Department </th>
                                        <th class="text-nowrap">Designation </th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.OpneingBalancelist)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <input type="checkbox" id="ChkCheckbox" />
                                            </td>
                                            <td class="text-center">
                                                <a id="DeleteBtn" onclick="DeleteOpneingbalance('@d.LeaveOpeningBalanceId_Encrypted')" style="cursor:pointer;">
                                                    <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                </a>
                                            </td>
                                            <td>@d.LeaveTypeName</td>
                                            <td>@d.CompanyName</td>
                                            <td>@d.BranchName</td>
                                            <td>@d.EmployeeName</td>
                                            <td>@d.NoOfLeave</td>
                                            <td>@d.EmployeeNo</td>
                                            <td>@d.JoiningDate</td>
                                            <td>@d.ConfirmationDate</td>
                                            <td>@d.DepartmentName</td>
                                            <td>@d.DesignationName</td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function(){
        $('#txtCmpID').select2();
        $('#txtBranchname').select2();
        $('#LeaveMasterLeaveYearId').select2();
        $('#LeaveOpeningBalanceLeaveTypeId').select2();

    })


    function ChangeConpany() {
        debugger;
        $("#txtBranchname").find("option").remove();
        $("#LeaveMasterLeaveYearId").find("option").remove();
        $("#LeaveOpeningBalanceLeaveTypeId").find("option").remove();
        var CmpId = $("#txtCmpID").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: "@Url.Action("GetBusinessUnit", "ESS_Leave_LeaveOpneingBalance")",
            data: { CmpId: CmpId },
            success: function (data) {
                debugger;
                if (data != null) {
                    var data1 = data.data;
                    var LeaveYear = data.LeaveYear;
                    var LeaveType = data.LeaveType;
                    $("#txtBranchname").append("<option value=''>--Select--</option>");
                    $.each(data1, function (i, p) {
                        $("#txtBranchname").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });

                    $("#LeaveOpeningBalanceLeaveTypeId").append("<option value=''>--Select--</option>");
                    for (var i = 0; i < LeaveType.length; i++) {
                        $("#LeaveOpeningBalanceLeaveTypeId").append("<option value='" + LeaveType[i].Id + "'>" + LeaveType[i].Name + "</option>");
                    }

                    $("#LeaveMasterLeaveYearId").append("<option value=''>--Select-- </option>");
                    for (var i = 0; i < LeaveYear.length; i++) {
                        $("#LeaveMasterLeaveYearId").append("<option value='" + LeaveYear[i].Id + "'>" + LeaveYear[i].Name + "</option>");
                    }
                }
            }
        })
    }

    jQuery.validator.addMethod(
  "regex",
      function (value, element, regexp) {
          if (regexp.constructor != RegExp)
              regexp = new RegExp(regexp);
          else if (regexp.global)
              regexp.lastIndex = 0;
          return this.optional(element) || regexp.test(value);
      }, "erreur expression reguliere"
   );

    $('#SaveLeaveOpneingBalance').validate({
        rules: {
            CmpID: {
                required: true,
            },
            LeaveOpeningBalanceBranchID: {
                required: true,
            },
            LeaveOpeningBalanceLeaveYearId: {
                required: true,
            },
            LeaveOpeningBalanceLeaveTypeId: {
                required: true,
            },

        },
        messages: {
            CmpID: {
                required: "Select company name",
            },
            LeaveOpeningBalanceBranchID: {
                required: "Select business unit",
            },
            LeaveOpeningBalanceLeaveYearId: {
                required: "Select leave year",
            },
            LeaveOpeningBalanceLeaveTypeId: {
                required: "Select leave type",
            },
        },
    });

    var form = $("#SaveLeaveOpneingBalance");
    form.validate();
    function GetAllEmployeeInformation() {
        debugger;
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        $("#SaveLeaveOpneingBalance").submit();
    }

</script>


<script>



    function toggle(source) {
        debugger;
        var checkboxes = document.querySelectorAll('input[type="checkbox"]');
        for (var i = 0; i < checkboxes.length; i++) {
            if (checkboxes[i] != source)
                checkboxes[i].checked = source.checked;
        }
    }




    function DeleteOpneingbalance(LeaveOpeningBalanceId_Encrypted) {
        debugger;
        $("#AllCheckBox").prop("checked", false)
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Leave_LeaveOpneingBalance")?LeaveOpeningBalanceId_Encrypted=' + LeaveOpeningBalanceId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


