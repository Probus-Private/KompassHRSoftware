                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyProfile, "Id", "Name"), "--Select--", new { id = "ddlCompanyName", @class = "form-select", autocomplete = "off", name = "CompanyId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Buisness Unit
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetMasBranch, "Id", "Name"), "All", new { @class = "form-select", type = "text", id = "ddlBuniessUnit", name = "BranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">Start Date <span class="important">*</span></label>
                                            <div class="col-md-9">
                                                @*@Html.TextBoxFor(model => model.StartDate, new { @class = "form-control", @id = "StartDate", name = "StartDate", type = "date" })*@
                                                @Html.TextBoxFor(model => model.StartDate, new { @class = "form-control", @id = "StartDate", name = "StartDate", type = "month" })


                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">End Date <span class="important">*</span></label>
                                            <div class="col-md-9">
                                                @*@Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", @id = "EndDate", name = "EndDate", autocomplete = "off", type = "date" })*@
                                                @Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", @id = "EndDate", name = "EndDate", autocomplete = "off", type = "month" })


                                             </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-10">
                                            </div>
                                            <div class="col-md-2">
                                                <div class="BtnBx">
                                                    <div>
