    function downloadExcelFile() {
        debugger
        $(".Userloaderbg").css("display", "flex");

        var BranchId = encodeURIComponent($("#ddlBuniessUnit").val());
        var CmpId = encodeURIComponent($("#ddlCompanyName").val());

        var startMonth = $("#StartDate").val();  
        var endMonth = $("#EndDate").val();     

        if (!startMonth || !endMonth) {
            Swal.fire({ icon: 'error', text: 'Please select both Start and End Month.' });
            $(".Userloaderbg").hide();
            return false;
        }

        // Convert to yyyy-MM-dd
        function toYYYYMMDD(day, ym) {
            if (!ym || ym.indexOf("-") === -1) return "";
            const parts = ym.split("-");
            if (parts.length !== 2) return "";

            const year = parts[0];
            const month = parts[1];

            return `${year}-${month}-${day}`;
        }

        function lastDayOfMonth(ym) {
            if (!ym || ym.indexOf("-") === -1) return 0;

            const parts = ym.split("-");
            if (parts.length !== 2) return 0;

            const year = parseInt(parts[0]);
            const month = parseInt(parts[1]);

            return new Date(year, month, 0).getDate();
        }

        let StartDate, EndDate;

        if (startMonth === endMonth) {
            let last = lastDayOfMonth(startMonth);
            StartDate = toYYYYMMDD("01", startMonth);
            EndDate = toYYYYMMDD(last, startMonth);
        } else {
            let lastEndMonth = lastDayOfMonth(endMonth);
            StartDate = toYYYYMMDD("01", startMonth);
            EndDate = toYYYYMMDD(lastEndMonth, endMonth);
        }

        StartDate = encodeURIComponent(StartDate);
        EndDate = encodeURIComponent(EndDate);

        var url = `@Url.Action("DownloadExcelFile", "ESS_Recruitment_ResourcesRequestReport")?CmpId=${CmpId}&BranchId=${BranchId}&StartDate=${StartDate}&EndDate=${EndDate}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: { responseType: 'blob' },
            success: function (data) {
                $(".Userloaderbg").css("display", "none");

                if (data.size == 0) {
                    Swal.fire({ icon: 'error', text: 'Record Not Found' });
                    return false;
                }

                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'ResourceRequestReports.xlsx';
                anchorElement.click();
                window.URL.revokeObjectURL(url);
            },
            error: function (xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }

</script>