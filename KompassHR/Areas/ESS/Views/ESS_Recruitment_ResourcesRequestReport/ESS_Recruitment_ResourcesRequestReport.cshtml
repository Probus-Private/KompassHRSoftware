<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCompanyName").select2();
        $("#ddlBuniessUnit").select2();
        $("#ddlCompanyName").on("change", function () {
            $("#ddlBuniessUnit").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_Recruitment_ResourcesRequestReport")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlBuniessUnit").append("<option value=''>All</option>");
                        $.each(data, function (i, p) {
                            debugger;
                            $("#ddlBuniessUnit").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })



        //use for add regex function
        jQuery.validator.addMethod(
      "regex",
            function (value, element, regexp) {
                if (regexp.constructor != RegExp)
                    regexp = new RegExp(regexp);
                else if (regexp.global)
                    regexp.lastIndex = 0;
                return this.optional(element) || regexp.test(value);
            }, "erreur expression reguliere"
    );

        $("#ResourceRequestReport").validate({
            rules: {
                StartDate: {
                    required: true,
                },
                EndDate: {
                    required: true,
                },
                CompanyId: {
                    required: true,
                },
            },
            messages: {
                StartDate: {
                    required: "Start Date is required"
                },
                EndDate: {
                    required: "End Date is required"
                },
                CompanyId: {
                    required: "Company name is required",
                },
            }
        });

        var form = $("#ResourceRequestReport");
        form.validate();

    });

