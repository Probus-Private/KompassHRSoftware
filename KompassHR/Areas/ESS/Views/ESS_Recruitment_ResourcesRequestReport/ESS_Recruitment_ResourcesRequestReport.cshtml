                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Recruitment_ReportsMenu", "ESS_Recruitment_ReportsMenu", new {id = 1, ScreenId=256, area = "ESS" })">
