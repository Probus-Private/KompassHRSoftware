                                            <div class="col-md-8">
                                                <input class="form-control"
                                                       type="file"
                                                       name="Photo1"
                                                       id="Photo1"
                                                       accept="image/jpeg, image/jpg, image/png"
                                                       onchange="validateFileType(this)" />
