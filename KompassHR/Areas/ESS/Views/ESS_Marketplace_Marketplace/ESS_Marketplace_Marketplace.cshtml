        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 1px 5px rgba(0, 0, 0, 0.05);
    }

        .info-card .icon {
            font-size: 24px;
            margin-right: 15px;
        }

        .info-card .text-content {
            flex: 1;
        }

        .info-card .title {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        .info-card .number a {
            font-size: 20px;
            font-weight: 700;
            text-decoration: none;
        }

        .info-card .description {
            font-size: 12px;
        }

    .bg-soft-blue {
        background-color: #e8f1fa;
        color: #004085;
    }

    .bg-soft-green {
        background-color: #e6f4ea;
        color: #155724;
    }

    .bg-soft-yellow {
        background-color: #fff3cd;
        color: #856404;
    }

    .info-card a {
        color: inherit;
