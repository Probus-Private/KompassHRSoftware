                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        @if (!string.IsNullOrEmpty(ViewBag.Photo1FileName))
                                        {
                                            <button type="button" class="btn btn-info" onclick="viewFile('@ViewBag.Photo1FileName', '@TempData["p_Id"]')">
                                                <i class="fas fa-eye"></i> View Photo
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Photo 2
                                            </label>
                                            <div class="col-md-8">
                                                <input class="form-control" type="file" name="Photo2" id="Photo2" accept=".jpg,.jpeg,.png" onchange="validateFileType(this)" />
                                                <span class="text-danger" id="Photo2Error" style="font-size: 12px;"></span>

                                                @if (!string.IsNullOrEmpty(ViewBag.Photo2FileName))
                                                {
                                                    <small class="form-text text-muted">Current file: @ViewBag.Photo2FileName</small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        @if (!string.IsNullOrEmpty(ViewBag.Photo2FileName))
                                        {
                                            <button type="button" class="btn btn-info" onclick="viewFile('@ViewBag.Photo2FileName', '@TempData["p_Id"]', '@ViewBag.Filepath')">
                                                <i class="fas fa-eye"></i> View Photo
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Photo 3
                                            </label>
                                            <div class="col-md-8">
                                                <input class="form-control" type="file" name="Photo3" id="Photo3" accept=".jpg,.jpeg,.png" onchange="validateFileType(this)" />
                                                <span class="text-danger" id="Photo3Error" style="font-size: 12px;"></span>

                                                @if (!string.IsNullOrEmpty(ViewBag.Photo3FileName))
                                                {
                                                    <small class="form-text text-muted">Current file: @ViewBag.Photo3FileName</small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        @if (!string.IsNullOrEmpty(ViewBag.Photo3FileName))
                                        {
                                            <button type="button" class="btn btn-info" onclick="viewFile('@ViewBag.Photo3FileName', '@TempData["p_Id"]', '@ViewBag.Filepath')">
                                                <i class="fas fa-eye"></i> View Photo
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="submit" id="SubmitBtn" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" id="btnGetList" class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var ddmmyyyy = [date.getFullYear(), mnth, day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
    function viewFile(fileName, postId) {
        debugger;
        var url = '/ESS/ESS_Marketplace_Marketplace/ViewFile?postId=' + encodeURIComponent(postId) + '&fileName=' + encodeURIComponent(fileName);
        window.open(url, '_blank');
    }


    function validateFileType(input) {
        const allowedExtensions = ['jpg', 'jpeg', 'png'];
        const file = input.files[0];
        const inputId = input.id;
        const errorSpanId = inputId + "Error"; // e.g., Photo1Error

        // Clear previous error
        document.getElementById(errorSpanId).textContent = "";

        if (file) {
            const fileExtension = file.name.split('.').pop().toLowerCase();
            if (!allowedExtensions.includes(fileExtension)) {
                document.getElementById(errorSpanId).textContent = "Only JPG, JPEG, and PNG files are allowed.";
                input.value = ''; // Clear file input
            }
        }
    }

</script>

<script>
    $(document).ready(function () {
        $("#MarketPlaceCategoryID1").select2();

        $("#btnGetList").click(function () {
            var url='@Url.Action("GetList", "ESS_Marketplace_Marketplace", new { area = "ESS" })';
            window.location.href = url;
        });

        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
        $("#dateDocDate").val(dateString);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.remove('swal2-show');
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake');
                    });
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake');
                    }, 500);
                    return false;
                }
            });
        }

        $("#formReset").click(function () {
            $("#SaveMarketPlace")[0].reset();
        });

        @*var DocDate = @Html.Raw(Json.Encode(TempData["DocDate"]));
        if (DocDate == "") {
            var date = new Date();
            var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
            $("#dateDocDate").val(dateString);
        } else {
            var convertedDate = convertDate(DocDate);
            $("#dateDocDate").val(convertedDate);
        }*@
    });

    jQuery.validator.addMethod(
        "regex",
        function(value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        },
        "Invalid input"
    );

    $('#SaveMarketPlace').validate({
        rules: {
            DocDate: {
                required: true,
            },
            MarketPlaceCategoryID: {
                required: true,
            },
            MarketPlacePostTitle: {
                required: true,
            },
            MarketPlacePostDesciption: {
                required: true,
            },
            ContactNo: {
                required: true,
            },
        },
        messages: {
            DocDate: {
                required: "Doc Date is required",
            },
            MarketPlaceCategoryID: {
                required: "Category name is required",
            },
            MarketPlacePostTitle: {
                required: "Title is required",
            },
            MarketPlacePostDesciption: {
                required: "Description is required",
            },
            ContactNo: {
                required: "Contact number is required"
            },
        },
    });
</script>