                                            @ViewBag.GetTotalPostCount
                                        </a>
                                    </div>
                                    <div class="description">Total posts allowed this month</div>
                                </div>
                            </div>
                        </div>

                        <!-- Post -->
                        <div class="col-md-4 col-sm-6 mb-3">
                            <div class="info-card bg-soft-green">
                                <div class="icon"><i class="fa fa-globe"></i></div>
                                <div class="text-content">
                                    <div class="title">Post</div>
                                    <div class="number">
                                        <a>
                                            @ViewBag.EmployeePostCount
                                        </a>
                                    </div>
                                    <div class="description">Posts submitted this month</div>
                                </div>
                            </div>
                        </div>

                        <!-- Balance -->
                        <div class="col-md-4 col-sm-6 mb-3">
                            <div class="info-card bg-soft-yellow">
                                <div class="icon"><i class="fa fa-archive"></i></div>
                                <div class="text-content">
                                    <div class="title">Balance</div>
                                    <div class="number">
                                        <a>
                                            @ViewBag.RemainingCount
                                        </a>
                                    </div>
                                    <div class="description">Remaining posts this month</div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <form action="/ESS/ESS_Marketplace_Marketplace/SaveUpdate" id="SaveMarketPlace" method="post" enctype="multipart/form-data">
                                @Html.HiddenFor(model => model.Photo1)
                                @Html.HiddenFor(model => model.Photo2)
                                @Html.HiddenFor(model => model.Photo3)
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { id = "txtDocNo", name = "DocNo", @class = "form-control", @readonly = "readonly", type = "text", Value = TempData["DocNo"], style = "background-color: #e9ecef; color: #495057;" })
                                                @Html.HiddenFor(model => model.MarketPlacePostID_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { id = "dateDocDate", name = "DocDate", @class = "form-control", type = "date", @readonly = "readonly", style = "background-color: #e9ecef; color: #495057;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Market Place Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.MarketPlaceCategoryID, new SelectList(ViewBag.GetMarketCategory, "MarketPlaceCategoryID", "MarketPlaceCategory"), "--Select--", new { id = "MarketPlaceCategoryID1", name = "MarketPlaceCategoryID1", @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Title
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.MarketPlacePostTitle, new { id = "MarketPlacePostTitle", name = "MarketPlacePostTitle", @class = "form-control", type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.MarketPlacePostDesciption, new { id = "MarketPlacePostDesciption", name = "MarketPlacePostDesciption", @class = "form-control", type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Price
