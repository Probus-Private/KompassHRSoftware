
@{
    ViewBag.Title = "TrainingSubCategoryDocumentView";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .loader {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 600px;
    }

        .loader::after {
            content: "";
            width: 50px;
            height: 50px;
            border: 6px solid #ccc;
            border-top-color: #007bff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    #DocBody {
        height: 360px; /* Set desired height */
        width: 100%; /* Or use a fixed width like 400px */
        overflow-y: auto; /* Enables vertical scroll when needed */
        overflow-x: hidden; /* Hides horizontal scroll */
    }

    .Error {
        text-align: left;
        height: 35px;
    }
</style>
<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                View Training Sub-Category Document
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "ESS_Training_TraningSubCategory", new {  area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
        <div class="box-footer text-right" style="background-color: #f5f5f5; padding: 5px 10px;">
            <div class="form-inline d-inline-block">

            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xs-12">
            <div class="box box-info">
                <div class="box-body">
                    <!-- Main Grid -->
                    <div class="row">
                        <!-- Left Column (4 cols) - Table with File List -->
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header text-white" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">File List</div>
                                <div class="card-body p-0">

                                    <table class="table table-bordered table-striped m-0">
                                        <thead>
                                            <tr>
                                                <th class="text-center" hidden><small>Training Sub-Category Doc Id</small></th>
                                                <th class="text-center"><small>File Name</small></th>
                                                <th class="text-center" hidden><small>Type</small></th>
                                                <th class="text-center"><small>Status</small></th>
                                                <th class="text-center"><small>Show</small></th>
                                            </tr>
                                        </thead>
                                        <tbody id="fileListTableBody">
                                            <!-- Populated by JS -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column (8 cols) - Gallery (PDF/Image/Video) -->
                        <div class="col-md-8">
                            <div class="panel panel-inverse" data-sortable-id="index-1">
                                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                                    <h4 class="panel-title"> Document </h4>
                                    <div class="panel-heading-btn">
                                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" style="background-color: white;" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                                    </div>
                                </div>
                                <!-- Main Footer with Checkbox and Button -->
                                <div class="box-footer text-right" style="background-color: #f5f5f5; padding: 5px 10px; display:none" id="divDocAgree">
                                    <div class="form-inline d-inline-block">
                                        <label class="checkbox-inline" style="margin-right: 10px; font-size: 13px;">
                                            <input type="checkbox" id="DocagreeCheck" style="margin-right: 5px;">
                                            I have reviewed the document and I agree with its contents.
                                        </label>
                                        <button type="button" class="btn btn-primary btn-sm" id="btnDocSeeSubmit" onclick="submitReadDocumentSure()">Submit</button>
                                    </div>
                                </div>

                                <!-- Error Message Section (Initially Hidden) -->
                                <div class="box-footer text-left" style="background-color: #fff; padding: 5px 10px; display: none;" id="divErrorDocagreeCheck">
                                    <span id="ErrorDocagreeCheck" class="Error text-danger" style="font-size: 12px;"></span>
                                </div>

                                <div class="box-body" id="DocBody">
                                    <div class="gallery-row row" id="modalContent1">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    const fileList = @Html.Raw(Json.Encode(TempData["FileList"]));
    const timestamp = new Date().getTime(); // For cache busting

    fileList.forEach((file, index) => {
        const fileType = file.FileType.toUpperCase();
        //const fileSrc = `${file.FileSrc}?v=${timestamp}`;
        const baseSrc = file.FileSrc.replace(/\\/g, "/"); // replace \ with /
        const fileSrc = `${baseSrc}`; // only one query string
        const Title = file.Title;
        const TrainingSubCategoryDocId = file.TrainingSubCategoryDocId;
        var isValid = file.IsReadDocument;
        let iconClass = '';
        switch (fileType) {
            case 'PDF':
                iconClass = 'fa-file-pdf text-danger';
                break;
            case 'JPG':
            case 'JPEG':
            case 'PNG':
                iconClass = 'fa-file-image text-warning';
                break;
            case 'MP4':
            case 'WEBM':
            case 'AVI':
                iconClass = 'fa fa-video-camera';
                break;
            default:
                iconClass = 'fa-file text-secondary';
        }
        // Append to table with preview icon

        const statusIcon = Boolean(isValid)
            ? '<i class="fa fa-check fa-xl" style="color:green;"></i>'
            : '<i class="fa fa-times fa-xl" style="color:red;"></i>';
        $('#fileListTableBody').append(`
        <tr>
            <td hidden>${TrainingSubCategoryDocId}</td>
            <td><i class="fa ${iconClass} fa-lg"></i> &nbsp ${file.DocumentPath || 'Unnamed'}</td>
            <td hidden>${fileType}</td>
            <td class="text-center">${statusIcon}</td>
            <td class="text-center">
            <i class="fa fa-eye fa-lg" style="cursor:pointer; color:blue;"
               onclick="previewFile('${fileSrc}', '${fileType}' , '${TrainingSubCategoryDocId}')"></i>
            </td>
        </tr>
    `);

        // Optional: still render thumbnails on the right if needed
        if (fileType === "PDF") {
            $("#PDFfileContainer").append(`
            <div class="pdf-wrapper mb-3" onclick='showPDF("${fileSrc}")'>
                <iframe src="${fileSrc}#toolbar=0&navpanes=0&scrollbar=0" height="100%" width="100%"></iframe>
            </div>
        `);
        }
        if (["JPG", "PNG", "JPEG"].includes(fileType)) {
            $("#ImagefileContainer").append(`
            <div class="image-wrapper mb-3" onclick='showImage("${fileSrc}")'>
                <img src="${fileSrc}" height="200px" width="100%" />
            </div>
        `);
        }
        if (["MP4", "AVI"].includes(fileType)) {
            $("#VideofileContainer").append(`
            <div class="video-wrapper mb-3" onclick='showVideo("${fileSrc}", "${fileType.toLowerCase()}")'>
                <video height="150px" width="100%" id="videoPlayer">
                    <source src="${fileSrc}" id="ViewVideo" type="video/${fileType.toLowerCase()}">
                </video>
            </div>
        `);
        }
    });


    function previewFile(fileSrc, fileType, TrainingCalenderDocId) {
        debugger;
        //if (isValid=="true")
        //{
        //    $("#divDocAgree").show();
        //}
        //if (isValid=="" || isValid=="null")
        //{
        //    $("#divDocAgree").show();
        //}
        //else{
        //    $("#divDocAgree").hide();
        //}

        //document.getElementById('DocagreeCheck').checked = false;
        //$('#hdnTrainingCalenderDocId').val(TrainingCalenderDocId);

        fileType = fileType.toUpperCase();
        if (fileType === "PDF")
        {
            showPDF(fileSrc);
        }
        if (["JPG", "PNG", "JPEG"].includes(fileType))
        {
            showImage(fileSrc);
        }
        if (["MP4", "AVI"].includes(fileType))
        {
            showVideo(fileSrc, fileType.toLowerCase());
        }
    }


    function showPDF(src) {
        debugger;
        var timestamp = new Date().getTime(); // Add timestamp to prevent caching
        const fullSrc = `${src}?v=${timestamp}#toolbar=0&navpanes=0&scrollbar=0`;
        const html = `<iframe src="${fullSrc}" width="100%" height="100%"></iframe>`;
        $('#modalContent1').html(html).css('height', '600px');
        // Create iframe element dynamically
        const iframe = document.createElement('iframe');
        iframe.src = fullSrc;
        iframe.width = '100%';
        iframe.height = '100%';
        iframe.style.border = 'none';

        // Once PDF iframe is loaded, replace loader with iframe
        iframe.onload = function () {
            $('#modalContent1').html(iframe);
        };
        $('#modalContent1').html(html);
        //new bootstrap.Modal('#mediaModal').show();
    }

    function showImage(src) {
        debugger;
        const html = `<img src="${src}" class="img-fluid" />`;
        $('#modalContent1').html(html).css('height', '400px');
        $('#modalContent1').html(html);
        //new bootstrap.Modal('#mediaModal').show();
    }
    function showVideo(src, type) {
        debugger;
        const html = `
        <video controls autoplay controlsList="nodownload noplaybackrate" disablePictureInPicture>
            <source src="${src}" type="video/${type}">
            Your browser does not support the video tag.
        </video>`;

        $('#modalContent1').html(html).css('height', '400px');
    }

</script>

<script>
    function submitReadDocumentSure()
    {
        if (!document.getElementById('DocagreeCheck').checked) {
            $("#ErrorDocagreeCheck").html("Please agree to the documents before submitting.");
            $("#divErrorDocagreeCheck").show();
            return;
        } else {
            $("#ErrorDocagreeCheck").html("");
            $("#divErrorDocagreeCheck").hide();
        }
        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, do it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                submitReadDocument();
            } else if (result.dismiss === Swal.DismissReason.cancel) {
                Swal.fire({
                    icon: 'info',
                    title: 'Cancelled',
                    text: 'Your action was cancelled.',
                    confirmButtonText: 'OK' // shows OK button
                });
            }
        });

    }


</script>

