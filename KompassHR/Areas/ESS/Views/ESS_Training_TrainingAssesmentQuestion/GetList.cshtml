
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .fixed-side {
        position: sticky !important;
        left: 0;
        z-index: 1;
    }*/
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Training Assesment Question
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_LMS_Training_Training", "ESS_LMS_Training_Training",  new { id = 38,ScreenId=589, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Training Assesment Question-List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of training assesment questions created.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_Training_TrainingAssesmentQuestion", "ESS_Training_TrainingAssesmentQuestion", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="TablePage"
                                           style="width: 100%;">
                                        <thead class="text-center">
                                            <tr>
                                                <th class="fixed-side">Update</th>
                                                <th class="fixed-side">Delete</th>
                                                <th class="fixed-side1">View</th>    
                                                <th class="text-nowrap">Training Calender </th>
                                                <th class="text-nowrap">Language  </th>
                                                <th class="text-nowrap">Question Type</th>
                                                <th class="text-nowrap">Question </th>
                                                <th class="text-nowrap">Created By</th>
                                                <th class="text-nowrap">Created Date</th>
                                                <th class="text-nowrap">Modify By</th>
                                                <th class="text-nowrap">Modified Date </th>
                                                <th class="text-nowrap">Machine Name</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetTrainingAssesmentQuesion)
                                            {
                                                <tr>

                                                    <td class="text-center">
                                                        <a onclick="UpdateTrainingAssesmentQuestion('@d.Training_AssesmentQuestionId_Encrypted')" id="btnUpdate" style="cursor:pointer;  ">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-center">
                                                        <a onclick="DeleteTrainingAssesmentQuestion('@d.Training_AssesmentQuestionId')" id="btnDelete" style="cursor:pointer;">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-center" style="width: 80px;">
                                                        <a onclick="View('@d.Training_AssesmentQuestionId')" id="btnView" style="cursor:pointer;">
                                                            <i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-nowrap">@d.TrainingCalenderName</td>
                                                    <td class="text-nowrap">@d.LangauageName</td>
                                                    <td>@d.QuestionType</td>
                                                    <td>@d.Question</td>
                                                    <td>@d.CreatedBy</td>
                                                    <td>@d.CreatedDate</td>
                                                    <td>@d.ModifiedBy</td>
                                                    <td>@d.ModifiedDate</td>
                                                    <td>@d.MachineName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>
<div class="modal fade" id="QuestionDetails" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"></h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="row">
                                    <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass tblAddData" style="width: 100%;" id="tblEmployeeHistoryHead">
                                        <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th class="text-nowrap" style="text-align: center">Options </th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblBodyQuestionDetails"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('title').html("Training Agency");
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>
<script>
        $(document).ready(function() {
            $("#btnUpdate").click(function() {
                $("#txtQuestionType").prop("disabled", true);
            });
        });
</script>
<script>
    function UpdateTrainingAssesmentQuestion(Training_AssesmentQuestionId_Encrypted) {debugger;
        var url = '@Url.Action("ESS_Training_TrainingAssesmentQuestion", "ESS_Training_TrainingAssesmentQuestion")?Training_AssesmentQuestionId_Encrypted=' + Training_AssesmentQuestionId_Encrypted;
        window.location.href = url;
    }


    function DeleteTrainingAssesmentQuestion(Training_AssesmentQuestionId) {debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Training_TrainingAssesmentQuestion")?Training_AssesmentQuestionId=' + Training_AssesmentQuestionId;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
    function View(Training_AssesmentQuestionId){
        debugger;
        $.ajax({
            type: "GET",
            url: '@Url.Action("View", "ESS_Training_TrainingAssesmentQuestion")',
            data: { Training_AssesmentQuestionId},
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                const data = JSON.parse(response);
                const modal = $('#QuestionDetails');
                const tableBody = $('#tblBodyQuestionDetails');

                modal.modal(data.length > 0 ? 'show' : 'hide');
                tableBody.empty(); // Clear existing rows

                if (data) {
                    data.forEach(item => {
                        const row = $('<tr>');

                        const optionsCell = item.find(e => e.Key === "options");
                       
                        row.append(`<td>${optionsCell ? optionsCell.Value : ''}</td>`);
                        
                        tableBody.append(row);
                    });
                }
            }
        });
    }
</script>

