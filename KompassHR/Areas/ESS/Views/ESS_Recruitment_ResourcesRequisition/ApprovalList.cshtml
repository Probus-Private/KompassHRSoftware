              { extend: 'excel', className: 'btn-sm' }
              
            ],
            responsive: false,
            colReorder: false,
            keys: true,
            rowReorder: false,
            select: false,
            buttons:true,
            processing: true,
            serverSide: false,
            stateSave: true,
        };

        if ($(window).width() <= 767) {
            options.rowReorder = false;
            options.colReorder = false;
        }
        $('.TablePageRecruit').DataTable(options);
     })
       
