                                        </tr>


                                        <tr>
                                            <th>
                                                <span class="text-dark">Maximum Experience.</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.MaxExperience</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Must have Technical Skills</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.MusthaveTechnicalSkills</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Residence</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.Residence</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Currency</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.Currency</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Maximum Budget</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.MaxBudget</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Maximum Age</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.MaxAge</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Marital Status</span><br />
                                            </th>
                                            <td>@ViewBag.ResourceApprovalList.PreferredMaritalStatus</td>
                                        </tr>
                                        <tr></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <!-- END table-responsive -->
                        <hr />

                        @if (ViewBag.ApprovalRemarkList.Count != 0)
                        {
