                                   style="width: 100%;">
                                <thead>
                                    <tr class="trheading">
                                        <th class="text-nowrap">Approved By</th>
                                        <th class="text-nowrap">Remark</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.ApprovalRemarkList)
                                    {
                                        <tr>
                                            <td class="text-nowrap">@d.EmployeeName</td>
                                            <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                        </tr>
                                    }
