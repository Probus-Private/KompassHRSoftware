<script>

    function openFileModal(fileUrl) {
        $("#filePreviewFrame").attr("src", fileUrl);
        $("#filePreviewModal").modal("show");
    }

    $(document).ready(function () {
        debugger;
        window.onload = function () {
            var content = document.getElementById("content");
            content.scrollIntoView({ behavior: "smooth", block: "center" });
        };

        var List = @Html.Raw(Json.Encode(ViewBag.ResourceApprovalList));
        debugger;
        var Encrypted=List[1].Value;
        var id=List[0].Value;
        var Remark=List[42].Value;
        $("#summernote").val(Remark);
        $("#txtResourceId_Encrypted").val(Encrypted);
        $("#txtResourceId").val(id);

        //cleanText =Remark.code().replace(/<\/?[^>]+(>|$)/g, "");

        //$("#summernote").val(cleanText);
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        @*var Remark=@Html.Raw(Json.Encode(ViewBag.ResourceApprovalList.Remark))
        $('#summernotedata').summernote('code', Remark);*@

        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }
    });
</script>



<script>
    function printDiv() {

        //Get the HTML of div
        var divElements = document.getElementById('card').innerHTML;
        //Get the HTML of whole page
        var oldPage = document.body.innerHTML;

        //Reset the page's HTML with div's HTML only
        document.body.innerHTML =
          "<html><head></head><body>    " +
        divElements + "    </body>";

        //Print Page
        window.print();

        //Restore orignal HTML
        document.body.innerHTML = oldPage;
    }
    var StatusMark="";
    function OpenModule(Approver)
    {
        debugger;
        StatusMark=Approver;
        $("#myModalFinal").modal('show');
    }


    function Approved()
    {
        debugger
        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;

                var DocId=$("#txtResourceId").val();
                var Encrypted=$("#txtResourceId_Encrypted").val();
                var Status="";
                var Remark="";
                if(StatusMark=="Rejected")
                {
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="Rejected";

                }
                else{
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="Approved";
                }
                $(".Userloaderbg").css("display", "flex");
                $("#myModalFinal").modal('hide');
                $.ajax({
                    url: "@Url.Action("ForApprovalCandidate", "ESS_Recruitment_ResourcesRequisition")",
                    method:"get",
                data:{DocId:DocId,Encrypted:Encrypted,Status:Status,Remark:Remark},
                success:function(response){
                    debugger;
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon=="error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });

                                $("#myModalFinal").modal('hide');
                                $("#txtApproveRejectRemark").val("")
                                .then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("ApprovalList", "ESS_Recruitment_ResourcesRequisition")';
                                    } else if (
                                        /* Read more about handling dismissals below */
                                        result.dismiss === Swal.DismissReason.cancel
                                    ) {

                                    }
                                })


                            }
                        }

                    }

                    else{
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon=="success") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    })
                                    .then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("ApprovalList", "ESS_Recruitment_ResourcesRequisition")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })

                                    $("#myModalFinal").modal('hide');
                                    $("#txtApproveRejectRemark").val("");


                                }
                            }
                        }


                    }
                }
            });
                @*window.location.href = '@Url.Action("Delete", "Setting_EventAndNews_Announcement")?AnnouncementID_Encrypted=' + AnnouncementID_Encrypted;
                //window.location.href = url;*@

            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    $("#CloseModel").click(function () {
        $("#txtApproveRejectRemark").val('');
    })

</script>

