<script>
        $(document).ready(function () {
            var Message = @Html.Raw(Json.Encode(TempData["Message"]));
            var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
            debugger;
            if (Message != null) {
                if (Icon != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            // return false
                        }
                    }).then(function() {
                        window.location.reload();
                    });
                }
            }

        });
</script>


<script>

    function UpdateFuncation(DesignationId,DepartmentId,CmpId,ResourceId_Encrypted) {
        debugger;
        var url = '@Url.Action("ESS_Recruitment_ResourcesRequisition", "ESS_Recruitment_ResourcesRequisition")?ResourceId_Encrypted=' + ResourceId_Encrypted + '&CmpId='+CmpId+'&DepartmentId='+DepartmentId+'&DesignationId='+DesignationId;
            window.location.href = url;
    }

    function ViewFuncation(DesignationId,DepartmentId,CmpId,ResourceId_Encrypted,EditOrView) {
        debugger;
        var url = '@Url.Action("ESS_Recruitment_ResourcesRequisition", "ESS_Recruitment_ResourcesRequisition")?ResourceId_Encrypted=' + ResourceId_Encrypted + '&CmpId='+CmpId+'&DepartmentId='+DepartmentId+'&DesignationId='+DesignationId+'&EditOrView='+"View";
        window.location.href = url;
    }

    var Encrypted="";
    function OpenModule(ResourceId_Encrypted)
    {
        Encrypted=ResourceId_Encrypted;
        $("#myModalFinal").modal('show');
    }
    function Approved() {
            const DeleteButtons = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            DeleteButtons.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes, close it!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    var Remark=$("#txtApproveRejectRemark").val();
                    window.location.href = '@Url.Action("Delete", "ESS_Recruitment_ResourcesRequisition")?ResourceId_Encrypted=' + Encrypted+'&Remark='+Remark;
                } else if (
                    /* Read more about handling dismissals below */
                    result.dismiss === Swal.DismissReason.cancel
                ) {

                }
            })
        }




    function DeleteFunction(ResourceId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Do you really want to remove this record?',
            text: "Warning: Deleting this record is permanent.!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("DeleteRecruitment", "ESS_Recruitment_ResourcesRequisition")?ResourceId_Encrypted=' + ResourceId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>