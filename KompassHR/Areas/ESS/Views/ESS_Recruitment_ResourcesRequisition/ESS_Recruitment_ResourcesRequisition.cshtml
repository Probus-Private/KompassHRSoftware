@model KompassHR.Areas.ESS.Models.ESS_Recruitment.Recruitment_ResourceRequest
@{
    ViewBag.Title = "ESS_Recruitment_ResourcesRequisition";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>

<style>
    .card-row-title {
        color:  blue;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }


    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }



    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }


    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Resource Request
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Resource Request - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>

                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        To make a resource request, complete this form.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Recruitment_ResourcesRequisition", new { area = "ESS" })' id="SaveResourcesRecruitment" method="post" enctype="multipart/form-data">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-8">
                                                Resource Requisition Number (System Generated)
                                            </label>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", id = "DocNo", type = "text", autocomplete = "Off", Value = @ViewBag.DocNo.DocNo, @readonly = "readonly", Style = "background-color: #e9ecef;" })
                                                @Html.HiddenFor(model => model.ResourceId_Encrypted)
                                                @Html.HiddenFor(model => model.ResourceId)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Requisition Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", id = "txtDocDate", type = "date", name = "DocDate", autocomplete = "Off", @readonly = "readonly", Style = "background-color: #e9ecef;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Job Information
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCmpId", type = "text", name = "CmpId", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.CmpId, "", new { @class = "help-block", id = "ErrorCmpId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ResourceBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtBranchId", type = "text", name = "ResourceBranchId", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.ResourceBranchId, "", new { @class = "help-block", id = "ErrorResourceBranchId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Department
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.DepartmentID, new SelectList(ViewBag.DepatmentList, "Id", "Name"), "--Select--", new { @class = "form-control", id = "txtDepartment", type = "text", name = "Department", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.DepartmentID, "", new { @class = "help-block", id = "ErrorDepartmentID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Designation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.DesignationID, new SelectList(ViewBag.DesignationList, "Id", "Name"), "--Select--", new { @class = "form-control", id = "txtDesignation", type = "text", name = "Designation", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.DesignationID, "", new { @class = "help-block", id = "ErrorDesignationID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Grade
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.GradeID, new SelectList(ViewBag.GradeList, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtGrade", type = "text", name = "Grade", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.GradeID, "", new { @class = "help-block", id = "ErrorGradeID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Total Position
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalPositions, new { @class = "form-control", id = "txtTotalPositions", type = "text", name = "TotalPositions", autocomplete = "Off", onkeypress = " return numbervalidate(event)", Maxlength = 3 })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Position Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PositionTypeID, new SelectList(ViewBag.PositionType, "Id", "Name"), "--Select--", new { @class = "form-control", id = "txtPositionType", type = "text", name = "PositionType", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.PositionTypeID, "", new { @class = "help-block", id = "ErrorPositionTypeID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6" id="ReplacementDiv">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                If Replacement
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.EmployeeifReplacement, new SelectList(ViewBag.GetReplacementEmployee, "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlEmployeeifReplacement", type = "text", name = "EmployeeifReplacement", autocomplete = "Off" })
                                                @*@Html.TextBoxFor(model => model.EmployeeifReplacement, new { @class = "form-control", id = "txtEmployeeifReplacement", type = "text", name = "EmployeeifReplacement", autocomplete = "Off" })*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Closing Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ClosingDate, new { @class = "form-control", id = "txtClosingDate", type = "date", name = "ClosingDate", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Work Type @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @{
                                                    var workTypeList = ViewBag.WorkType as IEnumerable<dynamic>; // or the correct model type
                                                    var defaultSelectedValue = workTypeList?.FirstOrDefault()?.Id;
                                                }
                                                @Html.DropDownListFor(model => model.WorkTypeID,
                                                new SelectList(workTypeList ?? new List<dynamic>(), "Id", "Name", defaultSelectedValue),
                                                new { @class = "form-select", id = "txtWorkType", type = "text", name = "WorkType", autocomplete = "Off" })

                                                @*@Html.DropDownListFor(model => model.WorkTypeID, new SelectList(ViewBag.WorkType, "Id", "Name", ViewBag.WorkType[0].Id), new { @class = "form-select", id = "txtWorkType", type = "text", name = "WorkType", autocomplete = "Off" })*@
                                                @Html.ValidationMessageFor(model => model.WorkTypeID, "", new { @class = "help-block", id = "ErrorWorkTypeID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Legal Bond@*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LegalBond, new List<SelectListItem>{
                                               new SelectListItem {Text ="No", Value="false"},
                                               new SelectListItem {Text ="Yes", Value="true"},

                                                                      }, "--Select--",
                                               new { @class = "form-control", id = "txtLegalBond", name = "LegalBond", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Legal Bond (In Months)
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LegalBondDuration, new { @class = "form-control", id = "txtLegalBondDuration", type = "number", name = "LegalBondDuration", autocomplete = "Off", onkeypress = " return numbervalidate(event)", Maxlength = 2 })
                                                @Html.ValidationMessageFor(model => model.LegalBondDuration, "", new { @class = "help-block", id = "ErrortxtLegalBondDuration", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Priority
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Priority, new List<SelectListItem>{new SelectListItem {Text ="High", Value="High"},
                                                                                                                        new SelectListItem {Text ="Medium", Value="Medium"},
                                                                                                                          new SelectListItem {Text ="Low", Value="Low"},
                                                                                                     }, "--Select--", new { @class = "form-control", id = "txtPriority", type = "text", name = "Priority", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-4"></div>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.Confidential)
                                                @*<input type="checkbox" class="form-check-inline">*@
                                                <label class="form-label"> Confidential </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Technical Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Candidate Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CandidateType,
                                                   new List<SelectListItem>{new SelectListItem {Text ="Fresher", Value="Fresher"},
                                                   new SelectListItem {Text ="Intern", Value="Intern"},
                                                   new SelectListItem {Text ="Experience", Value="Experience"},
                                                  }, "--Select--", new { @class = "form-select", id = "txtCandidateType", type = "text", name = "CandidateType", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Min. Experience (In Years)
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MinExperience, new { @class = "form-control", id = "txtMinExperience", type = "text", name = "MinExperience", autocomplete = "Off", Maxlength = 3, onkeypress = " return numbervalidate(event)" })
                                                @*@Html.ValidationMessageFor(model => model.MinExperience, "", new { @class = "help-block", id = "ErrortxtMinExperience", @style = "color:red" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Max. Experience (In Years)
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MaxExperience, new { @class = "form-control", id = "txtMaxExperience", type = "text", name = "MaxExperience", autocomplete = "Off", Maxlength = 3, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.MaxExperience, "", new { @class = "help-block", id = "ErrorMaxExperience", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Preferred Technical Skills

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PreferredTechnicalSkills, new { @class = "form-control", id = "txtPreferredTechnicalSkills", type = "text", name = "PreferredTechnicalSkills", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Must Have Technical Skills
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MusthaveTechnicalSkills, new { @class = "form-control", id = "txtMusthaveTechnicalSkills", type = "text", name = "MusthaveTechnicalSkills", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Qualification
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Qualification, new { @class = "form-control", id = "txtQualification", type = "text", name = "Qualification", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Budget Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Position Budgeted@*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PositionBudgeted, new List<SelectListItem>{new SelectListItem {Text ="No", Value="false"},
                                                                                                                               new SelectListItem {Text ="Yes", Value="true"}, },
                                                                                                                               "--Select--", new { @class = "form-control", id = "txtPositionBudgeted", type = "text", name = "PositionBudgeted", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Currency @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Currency, new SelectList(ViewBag.Currency, "Id", "Name", ViewBag.Currency[0].Id), new { @class = "form-select", id = "txtCurrency", type = "text", name = "Currency", autocomplete = "Off" })
                                                @*@Html.DropDownListFor(model => model.Currency, new SelectList(ViewBag.Currency, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCurrency", type = "text", name = "Currency", autocomplete = "Off" })*@
                                                @*@Html.DropDownListFor(model => model.Currency, new SelectList(ViewBag.Currency, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCurrency", name = "Currency" })*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Min. Budget (in lakhs)@*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MinBudget, new { @class = "form-control", id = "txtMinBudget", type = "number", name = "MinBudget", autocomplete = "Off", onkeypress = "return event.charCode >=48" })
                                                @Html.ValidationMessageFor(model => model.MinBudget, "", new { id = "ErrorMinBudget", @style = "color:red", @class = "help-block" })

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
