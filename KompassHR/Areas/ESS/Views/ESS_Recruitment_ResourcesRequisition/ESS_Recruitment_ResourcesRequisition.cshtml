<script>
    $("#myForm").submit(function (e) {
        e.preventDefault(); // Prevent form from submitting normally

        var formData = new FormData(this); // Capture form data

        $.ajax({
            url: '@Url.Action("SaveUpdate", "ESS_Recruitment_ResourcesRequisition")',
            type: 'POST',
            data: formData,
            contentType: false,
            processData: false,
            success: function (response) {
                if (!response.success) {
                    Swal.fire({
                        icon: response.icon,
                        title: "Error",
                        text: response.message
                    });
                } else {
                    Swal.fire({
                        icon: response.icon,
                        title: "Success",
                        text: response.message
                    }).then(() => {
                        location.reload(); // Reload the page if needed
                    });
                }
            },
            error: function () {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "Something went wrong. Please try again."
                });
            }
        });
    });
</script>

