<script>
    var summernoteLoaded = false;

    $('#Description').summernote({
        height: 600,
        fontNames: [
            'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New',
            'Georgia', 'Helvetica', 'Impact', 'Lucida Console',
            'Tahoma', 'Times New Roman', 'Trebuchet MS', 'Verdana',
            'Open Sans', 'Roboto', 'Lato', 'Montserrat', 'Poppins',
            'Calibri', 'Cambria', 'Garamond', 'Bookman', 'Candara'
        ],
        fontNamesIgnoreCheck: [
            'Open Sans', 'Roboto', 'Lato', 'Montserrat', 'Poppins'
        ],
        toolbar: [
            ['style', ['style']],
            ['font', ['bold', 'italic', 'underline', 'clear', 'fontname']],
            ['fontsize', ['fontsize']],
            ['color', ['color']],
            ['para', ['ul', 'ol', 'paragraph']],
            ['table', ['table']],
            ['insert', ['link', 'picture']],
            ['view', ['fullscreen', 'codeview', 'help']]
        ],
        callbacks: {
            onInit: function () {
                summernoteLoaded = true;
                // Load ViewBag data properly after init
                var LetterDescription = @Html.Raw(Json.Encode(ViewBag.LetterDescription));
                if (LetterDescription) {
                    $('#Description').summernote('code', LetterDescription);
                }
            }
        }
    });
</script>


<script>

    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveLetter").validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            LetterId: {
                required: true,
            },
            Letter_EmployeeId: {
                required: true,
            },

            ClosingDate: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Please select company",
            },
            BranchId: {
                required: "Please select branch",
            },
            LetterId: {
                required: "Please select letter name",
            },
            Letter_EmployeeId: {
                required: "Please select employee",
            },

            ClosingDate: {
                required: "Please select closing date",
            },
        },
    });

    //IsValidation Check
    var form = $("#SaveLetter");
    form.validate();

    $("#btnshow").click(function(){
        debugger
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        else{
            $("#SaveLetter").submit();
        }
    });

    $("#btnSubmit").click(function(){
        var CmpId = $('#ddlCmpID').val();
        var BranchId = $('#ddlBranchId').val();
        var LetterId = $('#LetterId').val();
        var Letter_EmployeeId = $('#Letter_EmployeeId').val();
        var ClosingDate=$('#ClosingDate').val();
        var Description =  $('#Description').val();
        var Letter_DetailId_Encrypeted=$("#Letter_DetailId_Encrypeted").val();

        if (Description=="") {
            $("#ErrorDescription").html("Please enter description");
            return false
        }
        $.ajax({
            url: '@Url.Action("SaveUpdate", "ESS_HRSpace_Issuance", new { area = "ESS" })',
            method: 'POST',
            data: {
                CmpId: CmpId,
                BranchId: BranchId,
                LetterId: LetterId,
                Letter_EmployeeId: Letter_EmployeeId,
                Description: Description,
                ClosingDate: ClosingDate,
                Letter_DetailId_Encrypeted:Letter_DetailId_Encrypeted
            },
            success: function (response) {
                debugger;
                //var data = JSON.parse(response);
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                Swal.fire({
                    icon: Icon1,
                    text: Message1,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup();
                        popup.classList.remove('swal2-show');
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake');
                        });
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake');
                        }, 500);
                        return false;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        @*window.location.href = '@Url.Action("ESS_HRSpace_Issuance", "ESS_HRSpace_Issuance")';*@
                        //window.open('/ESS/ESS_HRSpace_Issuance/PrintLetter?id=' + response.Id);
                        window.location.href = '@Url.Action("PrintLetter", "ESS_HRSpace_Issuance", new { area="ESS"})' + '?id=' + response.Id;

                    } else if (
                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                    }
                })
            },
            error: function (xhr, status, error) {
                console.error('SaveUpdate AJAX error:', status, error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to save data. Please try again.'
                });
            }
        });
    });
</script>


<script>
        $(document).ready(function () {
            debugger
            $("#ddlCmpID").select2();
            $("#ddlBranchId").select2();
            $("#LetterId").select2();
            $("#Letter_EmployeeId").select2();

            // Load ViewBag data
            var LetterDescription = @Html.Raw(Json.Encode(ViewBag.LetterDescription));
            if (LetterDescription != null) {
                if (summernoteLoaded) {
                    $('#Description').summernote('code', LetterDescription);
                } else {
                    $('#Description').val(LetterDescription);
                }
            }

            var BranchId = @Html.Raw(Json.Encode(ViewBag.BranchId));
            if (BranchId != null) {
                $("#ddlBranchId").val(BranchId).trigger('change');
            }

            var ClosingDate = @Html.Raw(Json.Encode(ViewBag.ClosingDate));
            if (ClosingDate != null) {
                ClosingDate=convertDate(ClosingDate);
                $("#ClosingDate").val(ClosingDate).trigger('change');
            }

            var EmployeeId = @Html.Raw(Json.Encode(ViewBag.EmployeeId));
            if (EmployeeId != null) {
                $("#Letter_EmployeeId").val(EmployeeId).trigger('change');
            }

            var Message = @Html.Raw(Json.Encode(TempData["Message"]));
            var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
            if (Message != null && Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup();
                        popup.classList.remove('swal2-show');
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake');
                        });
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake');
                        }, 500);
                        return false;
                    }
                });
            }

            $("#ddlCmpID").on("change", function () {
                var CmpId = $("#ddlCmpID").val();
                $.ajax({
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("GetBusinessUnit", "ESS_HRSpace_Issuance", new { area = "ESS" })',
                    data: { CmpId: CmpId },
                    success: function (data) {
                        $("#ddlBranchId").empty().append("<option value=''>--Select--</option>");
                        $("#LetterId").empty().append("<option value=''>--Select--</option>");
                        if (data.BranchName != null) {
                            $.each(data.BranchName, function (i, p) {
                                $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                        if (data.GetLetterList != null) {
                            $.each(data.GetLetterList, function (i, p) {
                                $("#LetterId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('GetBusinessUnit AJAX error:', status, error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Failed to load business units.'
                        });
                    }
                });
            });

            $("#LetterId").on("change", function () {
                var BranchId = $("#ddlBranchId").val();
                var CmpId=$("#ddlCmpID").val();
                var LetterName =$("#LetterId option:selected").text();
                $.ajax({
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("GetEmployee", "ESS_HRSpace_Issuance", new { area = "ESS" })',
                    data: { ddlBranchId: BranchId,CmpId:CmpId ,LetterName:LetterName},
                    success: function (data) {
                        $("#Letter_EmployeeId").empty().append("<option value=''>--Select--</option>");
                        if (data.GetEmployeeList != null) {
                            $.each(data.GetEmployeeList, function (i, p) {
                                $("#Letter_EmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('GetEmployee AJAX error:', status, error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Failed to load employees.'
                        });
                    }
                });
            });
        });
</script>


