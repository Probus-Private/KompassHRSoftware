                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
                <div id="TaskDescription" style="padding:30px;"></div>
                <div class="modal-footer">
                    <button type="button" id="btnCancel1" class="btn btn-success btnpress" onclick="dismissModal('modal_basic2')">
                        <i class="fa-solid fa-floppy-disk"> </i> Ok
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- #End modal-dialog -->
    <!-- #Start modal-dialog -->
    <div class="modal fade" id="modal_basic3" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
