<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                My Pending Task
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_Menu", "ESS_TMS_Menu",  new { id = 12,ScreenId=194, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">My Pending Task- List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine">
                                        <thead>
                                            <tr>
                                                <th hidden>TaskAssignId</th>
                                                <th class="text-nowrap text-center">Add</th>
                                                <th class="text-nowrap text-center">Status List</th>
                                                <th class="text-nowrap text-center">Task Assigner Name</th>
                                                <th class="text-nowrap text-center">Doc No</th>
                                                <th class="text-nowrap text-center">Doc Date</th>
                                                <th class="text-nowrap text-center">Project Name</th>
                                                <th class="text-nowrap text-center">Module name</th>
                                                <th class="text-nowrap text-center">Client name</th>
                                                <th class="text-nowrap text-center">Task Category</th>
                                                <th class="text-nowrap text-center">Task SubCategory</th>
                                                <th class="text-nowrap text-center">Task Tittle</th>
                                                <th class="text-nowrap text-center">Description</th>
                                                <th class="text-nowrap text-center">Task Type</th>
                                                <th class="text-nowrap text-center">For Date</th>
                                                <th class="text-nowrap text-center">For Time</th>
                                                <th class="text-nowrap text-center">Priority</th>
                                                <th class="text-nowrap text-center">Task Status</th>
                                                <th class="text-nowrap text-center">Assign File</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.EmployeeTaskSeet)
                                            {
                                                <tr>
                                                    <td hidden>@d.TaskAssignID</td>
                                                    <td class="fixed-side">
                                                        <button type="button" class="btn btn-success btn-sm btnpress" style="padding: 2px 6px; font-size: 10px; line-height: 1.2; border-radius: 3px;" onclick="AddEmployeeTaskSheet('@d.TaskAssignID','@d.DocNo','@d.TaskTittle','@d.StartDate','@d.TaskAssignerName','@d.ForDate', '@d.ForTime','@d.Priority','@d.ProjectName','@d.ModuleName','@d.Clientname','@d.TaskCategoryName','@d.TaskSubCategoryName')">
                                                            + Add
                                                        </button>
                                                    </td>
                                                    <td class="text-nowrap text-center docNo">
                                                        <i class="fa-solid fa-list" onclick="CompleteTask('@d.TaskAssignID')" style="cursor:pointer; color: blue;"></i>
                                                        @*<button type="button" class="btn btn-success btn-sm btnpress" onclick="CompleteTask('@d.TaskAssignID')">
                                                                List
                                                            </button>*@
                                                    </td>
                                                    <td class="text-nowrap text-nowrap">@d.TaskAssignerName</td>
                                                    <td class="text-nowrap">@d.DocNo</td>
                                                    <td class="text-nowrap">@d.docdate</td>
                                                    <td class="text-nowrap">@d.ProjectName</td>
                                                    <td class="text-nowrap">@d.ModuleName</td>
                                                    <td class="text-nowrap">@d.Clientname</td>
                                                    <td class="text-nowrap">@d.TaskCategoryName</td>
                                                    <td class="text-nowrap">@d.TaskSubCategoryName</td>
                                                    <td class="text-nowrap">@d.TaskTittle</td>
                                                    <td class="text-start text-center">
                                                        <input type="hidden" id="hiddenDescription_@d.TaskAssignID" value="@d.Description" />
                                                        <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.TaskAssignID').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                    </td>
                                                    <td class="text-nowrap">@d.TaskType</td>
                                                    <td class="text-nowrap">@d.ForDate</td>
                                                    <td class="text-nowrap">@d.ForTime</td>
                                                    <td class="text-center">@d.Priority</td>
                                                    <td class="text-center">@d.Status</td>
                                                    <td class="text-center">
                                                        @if (@d.AssignFilePath != "")
                                                        {
                                                            <a href="@Url.Action("DownloadAttachment","ESS_TMS_EmployeeTaskSheet", new { DownloadAttachment = @d.AssignFilePath })"><i class="fa fa-download"></i></a>
                                                        }
                                                        else
                                                        {
                                                            <i class="fa-solid fa-xmark" style="color: red;"></i>
                                                        }

                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>


