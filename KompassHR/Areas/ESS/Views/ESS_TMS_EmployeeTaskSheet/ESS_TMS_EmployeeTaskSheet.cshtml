                        var row = $('<tr>');
                        // Array of table values
                        var rowData = [
                            { value: jsonObject.DocNo || '', classes: 'text-nowrap text-center' },
                            { value: jsonObject.DocDate || '', classes: 'text-nowrap text-center' },
                            //{
                            //    value: '<i class="fa-solid fa-receipt fa-lg" onclick="CompleteTask2(\'' + encodeURIComponent(jsonObject.WorkOnTask) + '\')" style="cursor:pointer; color: #ff5b57;"></i>',
                            //    classes: 'text-nowrap text-center'
                            //},
                            {
                                value: '<input type="hidden" id="hiddenDescription_' + jsonObject.DocNo + '" value="' + encodeURIComponent(jsonObject.WorkOnTask) + '" />' +
                                       '<i class="fa-solid fa-receipt fa-lg" onclick="CompleteTask2(document.getElementById(\'hiddenDescription_' + jsonObject.DocNo + '\').value)" style="cursor:pointer; color: #ff5b57;"></i>',
                                classes: 'text-nowrap text-center'
                            },
                            //{ value: jsonObject.WorkOnTask || '', classes: 'text-nowrap text-center' },
                            { value: jsonObject.TaskStatus || '', classes: 'text-nowrap text-center' },
                            { value: jsonObject.CompletePercentage || '', classes: 'text-nowrap text-center' },
                            { value: jsonObject.TaskTime || '', classes: 'text-nowrap text-center' },
                            { value: SetLink, classes: 'text-nowrap text-center' }
                        ];

                        // Dynamically append each cell to the row
                        rowData.forEach(function (data) {
                            $('<td>')
                                .addClass(data.classes)
                                .html(data.value)
                                .appendTo(row);
                        });

                        // Append the row to the table body
                        $('#tblTask tbody').append(row);
                    });
                }


                else {
                    $('#modal_basic2').modal('show');
                }




                //var Getdata = data;
                //console.log(Getdata)
                //$('#tblTask tr').not(function () { return !!$(this).has('th').length; }).remove();
                //if (Getdata != null) {
                //    for (var i = 0; i <= Getdata.length - 1; i++) {
                //        var table = document.getElementById("tblTask");
                //        var rowCount = table.rows.length;
                //        var row = table.insertRow(rowCount);
                //        var TaskAssign = Getdata[i];
                //        var count = $('#GettdChild').length;
                //        row.insertCell(0).innerHTML = "" + TaskAssign[0].Value + "";
                //        //row.insertCell(1).innerHTML = "" + convertDate(TaskAssign[1].Value) + "";
                //        row.insertCell(1).innerHTML = "" + TaskAssign[1].Value + "";
                //        row.insertCell(2).innerHTML = "" + TaskAssign[2].Value + "";
                //        row.insertCell(3).innerHTML = "" + TaskAssign[3].Value + "";
                //        row.insertCell(4).innerHTML = "" + TaskAssign[4].Value + "";
                //        if (TaskAssign[5].Value == null || TaskAssign[5].Value == "") {
                //            row.insertCell(5).innerHTML = "File Not available";
                //        } else {
                //            row.insertCell(5).innerHTML = "" + '<span><a type="button" href="DownloadFile?FilePath= ' + TaskAssign[5].Value + '" download> <i class="fa-solid fa-download"></i> </a> </span>' + "";
                //        }
                //    }
                //    $('#modal_basic2').modal('show');
                //}
