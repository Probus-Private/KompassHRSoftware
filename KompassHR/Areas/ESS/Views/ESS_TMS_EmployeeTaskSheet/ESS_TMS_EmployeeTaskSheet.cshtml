    function CompleteTask(TaskAssignId) {
        debugger;
        $.ajax({
            async: true,
            type: 'GET',
            dataType: 'JSON',
            contentType: 'application/json; charset=utf-8',
            url: '@Url.Action("GetChildTask", "ESS_TMS_EmployeeTaskSheet")',
