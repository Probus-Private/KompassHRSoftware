            <div class="modal-content">
                <div class="modal-header bg-black text-white">
                    <h4 class="modal-title">Task Description</h4>
                    <div class="panel-heading-btn">
                    </div>
                </div>
                <div class="modal-body">
                    <!-- BEGIN panel -->
                    <div class="modal-body-content">
                        <div class="row">
                            <div class="col-md-12">
                                <form>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <div id="txtTaskStatus"></div>
                                                @* @Html.TextArea("TaskStatus", new { @class = "summernote", style = "border: 2px solid #000; padding: 10px;", id = "txtTaskStatus", @placeholder = "Description....", autocomplete = "Off", contenteditable = "false" })*@
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnCancel" class="btn btn-success btnpress" onclick="dismissModal('modal_basic3')">
                        <i class="fa-solid fa-floppy-disk"> </i> Ok
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- #End modal-dialog -->
</div>
<script>
    function CompleteTask2(encodedHtml)
    {
        debugger;
        $('#TaskDescription').html('');
        const WorkOnTask = decodeURIComponent(encodedHtml);
        $('#TaskDescription').html(WorkOnTask);
    }
    function AssignTaskDesc(encodedHtml)
    {
        debugger;
        $('#txtTaskStatus').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtTaskStatus').html(AssignDesc);
            //$('#txtTaskStatus').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#TaskDescription').html('');
        $('#tblTask tr').not(function () { return !!$(this).has('th').length; }).remove();
        $('#' + modalId).modal('hide');
    }
</script>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed || result.isDismissed) {
                    location.reload();
                }
            });
        }
    });
</script>

