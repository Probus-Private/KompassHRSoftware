        debugger;
        var url = '@Url.Action("ESS_TMS_WorkOnTask", "ESS_TMS_WorkOnTask")?TaskAssignID=' + TaskAssignID  + '&TaskTittle=' + TaskTittle + '&DocNo=' + DocNo + '&StartDate=' + StartDate  + '&AssignerName=' + AssignerName + '&DateOrTime=' + DateOrTime + '&AssignTime=' + ForTime+ '&Priority=' + Priority +'&ProjectName=' +ProjectName + '&ModuleName=' +ModuleName +'&Clientname=' +Clientname+'&TaskCategoryName=' +TaskCategoryName +'&TaskSubCategoryName='+TaskSubCategoryName;
