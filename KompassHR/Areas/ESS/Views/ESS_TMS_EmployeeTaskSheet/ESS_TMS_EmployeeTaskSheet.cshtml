                    data.forEach((item) => {
                        // Convert each item's array to JSON object
                        const jsonObject = item.reduce((acc, pair) => {
                            acc[pair.Key] = pair.Value;
                            return acc;
                        }, {});

                        // Generate the download URL
                        let SetLink = '';
                        if (jsonObject.FilePath && jsonObject.FilePath !== "") {
                            let downloadUrl = '@Url.Action("DownloadAttachment", "ESS_TMS_EmployeeTaskSheet", new { DownloadAttachment = "__FILE_PATH__" })';
