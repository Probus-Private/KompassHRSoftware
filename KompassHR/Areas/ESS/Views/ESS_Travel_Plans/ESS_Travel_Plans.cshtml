
@{
    ViewBag.Title = "ESS_Travel_Plans";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model KompassHR.Areas.ESS.Models.ESS_Travel.Travel_Plan_Travel

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    .trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .dataTables_scrollBody::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 6px;
        height: 3px;
        background-color: #F5F5F5;
    }

    .dataTables_scrollBody::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item">
            <a href="javascript:;">
                <button type="button" class="btn btn-danger d-lg-block m-l-15" onclick="location.href='@Url.Action("Traveldesk", "TravelDesk", new { area = "TravelDesk" })'" style="float:right;"><i class="icon-prev"></i>&nbsp;Back To Home  </button>
            </a>
        </li>
        @*<li class="breadcrumb-item"><a href="javascript:;">Resource Request</a></li>
            <li class="breadcrumb-item active">Resource Request</li>*@
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">You creating a new travel plan <small>Travel plans are created under your travel calendars</small></h1>
    <!-- END page-header -->
    <!-- BEGIN panel -->
    <div class="alert alert-warning alert-dismissible rounded-0 mb-0 fade show">
        This is the individual travel itinerary.
    </div>
    <br />


    <!-- END panel -->
    <!-- BEGIN row -->
    <div class="row">
        <!-- BEGIN col-6 -->
        <div class="col-xl-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse">
                <div class="panel-heading ui-sortable-handle">
                    <h4 class="panel-title">CREATE PLANS</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>

                <div class="panel-body">
                    <div class="alert alert-muted">

                        You have created travel calendar for <code>@ViewBag.TravelPurpose</code>, where the descrition is  <code>@ViewBag.PurposeDescription</code>,
                        You are travelling <code>@ViewBag.TravelType</code>Your tour would start on<code>@Convert.ToDateTime(ViewBag.TourStart).ToString("dd/MMM/yyy")</code> and should end On<code>
                            @Convert.ToDateTime(ViewBag.TourEnd).ToString("dd/MMM/yyy")
                        </code> You mentioned in the travel note that @ViewBag.TravelNote .
                    </div>

                    <br />
                    <!-- END invoice-header -->
                    <!-- BEGIN nav-tabs -->
                    <ul id="ioniconsTab" class="nav nav-pills mb-5">
                        <li class="nav-item"><a href="#outline" data-bs-toggle="tab" class="nav-link active d-flex align-items-center"><ion-icon name="aperture-outline" class="fs-16px"></ion-icon><span class="d-none d-lg-inline ms-2">TRAVEL</span></a></li>
                        <li class="nav-item ms-2"><a href="#filled" data-bs-toggle="tab" class="nav-link d-flex align-items-center"><ion-icon name="aperture" class="fs-16px"></ion-icon><span class="d-none d-lg-inline ms-2"> ACCOMMODATION</span></a></li>
                        <li class="nav-item ms-2"><a href="#sharp" data-bs-toggle="tab" class="nav-link d-flex align-items-center"><ion-icon name="aperture-sharp" class="fs-16px"></ion-icon><span class="d-none d-lg-inline ms-2">TRANSPORT</span></a></li>
                        @*<li class="nav-item ms-2"><a href="#logo" data-bs-toggle="tab" class="nav-link d-flex align-items-center"><ion-icon name="logo-apple" class="fs-16px"></ion-icon><span class="d-none d-lg-inline ms-2">REQUEST</span> </a></li>*@
                    </ul>
                    <!-- END nav-tabs -->
                    <hr class="bg-gray-500" />
                    <!-- BEGIN tab-content -->
                    <div id="ioniconsTabContent" class="tab-content rounded-bottom fs-13px">
                        <!-- BEGIN tab-pane -->
                        <div class="tab-pane fade show active" id="outline">
                            <!-- BEGIN row -->
                            <div class="row">
                                <div class="invoice">

                                    <!-- END invoice-company -->
                                    <!-- BEGIN invoice-content -->
                                    <div class="panel-body">
                                        @*<form action="/OnBoarding/OnBoarding/BasicDetailsPage" class="form-horizontal" data-parsley-validate="true" name="demo-form">*@
                                        @using (Html.BeginForm("Save", "ESS_Travel_Plans", FormMethod.Post, new { id = "SavePlan", enctype = "multipart/form-data" }))
                                        {
                                        <div class="form-group row" hidden>

                                        </div>
                                        <div class="form-group row">
                                            <div class="col-md-6" hidden>
                                                <label class="mb-2">Plan Type<span class="text-danger">*</span></label>
                                                @Html.DropDownListFor(model => model.PlanType, new SelectList(new List<object>() {
                                           new {text="Travel",value="Travel"},
                                       }, "text", "value"), new { @class = "form-control form-select", @id = "PlanType" })
                                                @Html.ValidationMessageFor(model => model.PlanType, "", new { @class = "help-block", id = "ErrorPlanType", @style = "color:red" })

                                            </div>
                                            <div class="col-md-6">
                                                <label class="mb-2">Doc No <span class="text-danger"></span></label>
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNoT", type = "text", id = "DocNoT", Value = @ViewBag.DocNoT.DocNo, autocomplete = "Off", @readonly = "readonly", Style = "background-color: lightgray;" })
                                                @Html.ValidationMessageFor(model => model.DocNo, "", new { @class = "help-block", id = "ErrorDocNoT", @style = "color:red" })

                                            </div>
                                            <div class="col-md-6">
                                                <label class="mb-2">Select your prefered travel mode<span class="text-danger">*</span></label>

                                                @Html.DropDownListFor(model => model.Mode, new SelectList(new List<object>() {
                                           new {text="Air",value="Air"},
                                           new {text="Train",value="Train"},
                                           new {text="Bus",value="Bus"}
                                       }, "text", "value"), "--Select--", new { @class = "form-control form-select", @id = "ModeT" })
                                                @Html.ValidationMessageFor(model => model.Mode, "", new { @class = "help-block", id = "ErrorModeT", @style = "color:red" })
                                            </div>

                                        </div>
                                        <br />
                                        <div class="form-group row">
                                            <div class="col-md-6">
                                                <label class="mb-2">Your journey starts on<span class="text-danger">*</span></label>
                                                @Html.TextBoxFor(model => model.StartDate, new { @class = "form-control", Type = "date", id = "StartDateT" })
                                                @Html.ValidationMessageFor(model => model.StartDate, "", new { @class = "help-block", id = "ErrorStartDateT", @style = "color:red" })


                                            </div>
                                            <div class="col-md-6">
                                                <label class="mb-2">Journey ends on <span class="text-danger"></span></label>
                                                @Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", Type = "date", id = "EndDateT" })
                                                @Html.ValidationMessageFor(model => model.EndDate, "", new { @class = "help-block", id = "ErrorEndDateT", @style = "color:red" })
                                            </div>

                                        </div>
                                        <div class="form-group row">
                                            <div class="col-md-6">
                                                <label class="mb-2">Start Location<span class="text-danger">*</span></label>
                                                @Html.TextBoxFor(model => model.StartLocation, new { @class = "form-control", id = "StratLocationT", type = "text" })
                                                @Html.ValidationMessageFor(model => model.StartLocation, "", new { @class = "help-block", id = "ErrorStratLocationT", @style = "color:red" })
                                            </div>

                                            <div class="col-md-6">
                                                <label class="mb-2">Start Time <span class="text-danger">*</span></label>

                                                @Html.TextBoxFor(model => model.StartTime, new { @class = "form-control", id = "timepicker", type = "time" })
                                                @Html.ValidationMessageFor(model => model.StartTime, "", new { @class = "help-block", id = "ErrorStartTimeT", @style = "color:red" })


                                            </div>
                                        </div>
                                        <div class="form-group row">
                                            <div class="col-md-6">
                                                <label class="mb-2">End Location<span class="text-danger">*</span></label>
                                                @Html.TextBoxFor(model => model.EndLocation, new { @class = "form-control", id = "EndLocationT", type = "text" })
                                                @Html.ValidationMessageFor(model => model.EndLocation, "", new { @class = "help-block", id = "ErrorEndLocationT", @style = "color:red" })
                                            </div>
                                            <div class="col-md-6">
                                                <label class="mb-2">End Time <span class="text-danger"></span></label>
                                                <div class="input-group bootstrap-timepicker">
                                                    @Html.TextBoxFor(model => model.EndTime, new { @class = "form-control", id = "timepicker3", type = "Time" })
                                                    <span class="input-group-text input-group-addon">
                                                        <i class="fa fa-clock"></i>
                                                    </span>
                                                    @Html.ValidationMessageFor(model => model.EndTime, "", new { @class = "help-block", id = "ErrorEndTime", @style = "color:red" })
                                                </div>
                                            </div>

                                        </div>

                                        <div class="form-group row">
                                            <div class="col-md-6">
                                                <label class="mb-2">What is your meal preference <span class="text-danger"></span></label>
                                                @Html.DropDownListFor(model => model.TravelMealPreference, new SelectList(new List<object>() {
                                           new {text="Vegetarian ",value="Vegetarian"},
                                           new {text="Non-Vegetarian",value="Non-Vegetarian"},
                                             new {text="Meal not available",value="Meal not available"},
                                               new {text="Meal not required",value="Meal not required"},
                                       }, "text", "value"), "--Select--", new { @class = "form-control form-select", @id = "TravelMealPreferenceT" })
                                                @Html.ValidationMessageFor(model => model.Mode, "", new { @class = "help-block", id = "ErrorTravelMealPreferenceT", @style = "color:red" })


                                            </div>

                                        </div>
                                        <div class="form-group row">
                                            <div class="col-md-6">
                                                <label class="mb-2">Who should make the booking? <span class="text-danger">*</span></label>
                                                @Html.DropDownListFor(model => model.BookingType, new SelectList(new List<object>() {
                                                    new {text="Travel Desk",value="Travel Desk"},
                                           new {text="Self Booking ",value="Self Booking"},


                                       }, "text", "value"), new { @class = "form-control form-select", @id = "BookingTypeT" })
                                                @Html.ValidationMessageFor(model => model.BookingType, "", new { @class = "help-block", id = "ErrorBookingTypeT", @style = "color:red" })

                                            </div>
                                            <div class="col-md-4" id="UpladDocsT">
                                                <label class="mb-2">Upload Docs <span class="text-danger">*</span></label>
                                                <div class="col-lg-8">
                                                    <span class="btn btn-info fileinput-button me-1">
                                                        <i class="fa fa-fw fa-plus"></i>
                                                        <span></span>
                                                        <input type="file" id="UploadDocs" name="UploadDocs" multiple="multiple">


                                                    </span>
                                                </div>
                                                @Html.ValidationMessage("ErrorUploadDocsT", "", new { @class = "help-block", id = "ErrorUploadDocsT", @style = "color:red" })


                                            </div>


                                        </div>


                                        <div class="form-group row">


                                            <div class="col-md-12">
                                                <label class="mb-2">Add a note to your booking.<span class="text-danger">*</span></label>
                                                @Html.TextAreaFor(model => model.Note, new { @class = "form-control", id = "NoteT", autocomplete = "off", row = "3", autofocus = "autofocus" })
                                                @Html.ValidationMessageFor(model => model.Note, "", new { @class = "help-block", id = "ErrorNoteT", @style = "color:red" })


                                            </div>

                                        </div>
                                        <div class="form-group row">
                                            <div class="col-md-6">
                                                @Html.HiddenFor(model => model.TravelCalenderID, new { @class = "form-control", Value=ViewBag.TravelCalenderID, id = "TRAVELCAL_Fid" })
                                                @Html.HiddenFor(model => model.TravelPlanID_Encrypted, new { id = "TravelPlanID_Encrypted" })
                                                @Html.HiddenFor(model => model.TravelBranchID, new { id = "TravelBranchIDT" })
                                                @Html.HiddenFor(model => model.CmpId, new { id = "CmpIdT" })
                                                <div hidden>
                                                    @Html.TextBoxFor(model => model.DocDate, new { Type = "date", id = "DocDateT" })

                                                </div>



                                            </div>


                                        </div>

                                        <br />

                                        <center>
                                            <button type="button" id="btnSubmit"
                                                    class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                            </button>

                                        </center>
                                        @*</form>*@
                                        }
                                    </div>

                                    <!-- END invoice-content -->
                                    <div class="col-md-12">
                                        <!-- BEGIN panel -->
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                                                <h4 class="panel-title"> Travel Plan - List</h4>
                                                <div class="panel-heading-btn">
                                                    <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                                                       data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                                                </div>
                                            </div>
                                            <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                                                <p class="pb-0">
                                                    View Travel Calender status here!
                                                </p>
                                            </div>
                                            <div class="panel-body">
                                                <div class="row overflow-auto">
                                                    <div class="col-12">
                                                        <!-- BEGIN table-responsive -->
                                                        <div class="table-scroll div1">
                                                            <div class="table-wrap">
                                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine"
                                                                       style="width: 100%;">
                                                                    <thead>
                                                                        <tr class="trheading">
                                                                            <th class="text-nowrap text-center">Update</th>
                                                                            <th class="text-nowrap text-center">Delete</th>
                                                                            <th hidden class="text-nowrap text-center">TravelPlanID_Encrypted</th>
                                                                            <th hidden class="text-nowrap text-center">TravelPlanEmployeeId</th>
                                                                            <th hidden class="text-nowrap text-center">DocNo</th>
                                                                            <th hidden class="text-nowrap text-center">TravelCalenderID</th>
                                                                            <th class="text-nowrap text-center">PlanType</th>
                                                                            <th class="text-nowrap text-center">Mode</th>
                                                                            <th class="text-nowrap text-center">StartDate</th>
                                                                            <th class="text-nowrap text-center">EndDate</th>
                                                                            <th class="text-nowrap text-center">StartTime</th>
                                                                            <th class="text-nowrap text-center">EndTime</th>
                                                                            <th class="text-nowrap text-center">StartLocation</th>
                                                                            <th class="text-nowrap text-center">EndLocation</th>
                                                                            <th class="text-nowrap text-center">TravelMealPreference</th>
                                                                            <th class="text-nowrap text-center">Note</th>
                                                                            <th class="text-nowrap text-center">BookingType</th>
                                                                            <th class="text-nowrap text-center">BookingStatus</th>
                                                                            <th class="text-nowrap text-center">CancelPlanDescription</th>
                                                                            <th class="text-nowrap text-center">TravelConfirmed</th>
                                                                            <th class="text-nowrap text-center">RejectionRemark</th>
                                                                            <th hidden class="text-nowrap text-center">CompId</th>
                                                                            <th hidden class="text-nowrap text-center">BranchId</th>

                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var d in ViewBag.TravelPlanDetails)
                                                                        {
                                                                            <tr>
                                                                                <td class="text-center">
                                                                                    <button type="button" id="UpdateBtn"
                                                                                           class="btn btn-success btnpress ListBtn">
                                                                                        <i class="fa-solid fa-pencil-alt"></i>
                                                                                    </button>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <button type="button" id="btnCancel" onclick="DeleteTravel('@d.TravelPlanID_Encrypted')"
                                                                                            class="btn btn-danger ListBtn btnpress">
                                                                                        <i class="fa-solid fa-xmark"></i>
                                                                                    </button>
                                                                                </td>
                                                                                <td hidden class="text-nowrap">@d.TravelPlanID_Encrypted</td>
                                                                                <td hidden class="text-nowrap">@d.TravelPlanEmployeeId</td>
                                                                                <td hidden class="text-nowrap">@d.DocNo</td>
                                                                                <td hidden class="text-nowrap">@d.TravelCalenderID</td>
                                                                                <td class="text-nowrap">@d.PlanType</td>
                                                                                <td class="text-nowrap">@d.Mode</td>
                                                                                <td class="text-nowrap">@Convert.ToDateTime(d.StartDate).ToString("yyyy-MM-dd")</td>
                                                                                <td class="text-nowrap">@Convert.ToDateTime(d.EndDate).ToString("yyyy-MM-dd")</td>
                                                                                <td class="text-nowrap">@d.StartTime</td>
                                                                                <td class="text-nowrap">@d.EndTime</td>
                                                                                <td class="text-nowrap">@d.StartLocation</td>
                                                                                <td class="text-nowrap">@d.EndLocation</td>
                                                                                <td class="text-nowrap">@d.TravelMealPreference</td>
                                                                                <td class="text-nowrap">@d.Note</td>
                                                                                <td class="text-nowrap">@d.BookingType</td>
                                                                                <td class="text-nowrap">@d.BookingStatus</td>
                                                                                <td class="text-nowrap">@d.CancelPlanDescription</td>
                                                                                <td class="text-nowrap">@d.TravelConfirmed</td>
                                                                                <td class="text-nowrap">@d.RejectionRemark</td>
                                                                                <td hidden class="text-nowrap">@d.CmpId</td>
                                                                                <td hidden class="text-nowrap">@Convert.ToDateTime(d.DocDate).ToString("yyyy-MM-dd")</td>
                                                                                <td hidden class="text-nowrap">@d.TravelBranchID</td>

                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- END panel -->
                                        </div>
                                    </div>
                                    <!-- BEGIN invoice-footer -->
                                    <div id="footer" class="app-footer m-0">
                                        &copy; 2023 Probus All Right Reserved
                                    </div>
                                    <!-- END invoice-footer -->
                                </div>
                            </div>
                            <!-- END row -->
                        </div>
                        <!-- END tab-pane -->
                        <!-- BEGIN tab-pane -->
                        <div class="tab-pane fade" id="filled">
                            <div class="row">

                                <!-- GRP EDITED-->
                                <div class="invoice">

                                    <div class="invoice-content">
                                        <!-- BEGIN table-responsive -->
                                        <div class="panel-body">
                                            @*<form action="/OnBoarding/OnBoarding/BasicDetailsPage" class="form-horizontal" data-parsley-validate="true" name="demo-form">*@
                                            @using (Html.BeginForm("SaveA", "ESS_Travel_Plans", FormMethod.Post, new { id = "SavePlanA", enctype = "multipart/form-data" }))
                                            {


                                                <div class="form-group row">
                                                    <div class="col-md-6" hidden>
                                                        <label class="mb-2">Plan Type<span class="text-danger">*</span></label>
                                                        @Html.DropDownListFor(model => model.PlanType, new SelectList(new List<object>() {
                                           new {text="Accomodation",value="Accomodation"},
                                       }, "text", "value"), new { @class = "form-control form-select", @id = "PlanType" })
                                                        @Html.ValidationMessageFor(model => model.PlanType, "", new { @class = "help-block", id = "ErrorPlanType", @style = "color:red" })

                                                    </div>
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <label class="mb-2">Doc No <span class="text-danger"></span></label>
                                                            @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNoA", type = "text", id = "DocNoA", Value = @ViewBag.DocNoA.DocNo, autocomplete = "Off", @readonly = "readonly", Style = "background-color: lightgray;" })
                                                            @Html.ValidationMessageFor(model => model.DocNo, "", new { @class = "help-block", id = "ErrorDocNoA", @style = "color:red" })

                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="mb-2">Mode<span class="text-danger">*</span></label>

                                                            @Html.DropDownListFor(model => model.Mode, new SelectList(new List<object>() {

                                            new {text="Regular",value="Regular"},
                                            new {text="Premium",value="Premium"},
                                            new {text="Deluxe",value="Deluxe"},

                                       }, "text", "value"), "--Select--", new { @class = "form-control form-select", @id = "ModeA" })
                                                            @Html.ValidationMessageFor(model => model.Mode, "", new { @class = "help-block", id = "ErrorModeA", @style = "color:red" })
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <div class="row">
                                                            <div class="col-md-4">
                                                                <label class="mb-2">Breakfast <span class="text-danger">*</span></label>
                                                                @Html.DropDownListFor(model => model.BKAirlineName, new SelectList(new List<object>() {
                                           new {text=true,value="YES"},
                                           new {text=false,value="NO"},
                                       }, "text", "value"), "--Select--", new { @class = "form-control form-select", @id = "Breakfast" })
                                                                @Html.ValidationMessageFor(model => model.BKAirlineName, "", new { @class = "help-block", id = "ErrorBreakfast", @style = "color:red" })

                                                            </div>
