
@{
    ViewBag.Title = "ESS_Requisition_Menu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .box {
        width: 100px;
        height: 100px;
        backdrop-filter: blur(25px) saturate(00%);
        background-color: rgba(255, 255, 255, 1);
        border-radius: 12px;
        border: 3px solid rgba(255, 255, 255, 1);
        margin: 5px;
        box-shadow: inset 0 15px 25px rgba(0, 0, 0, 0.03), inset 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
    }

        .box:hover {
            /* BORDER:2PX SOLID #666; */
            border: 2px solid #007bff;
            cursor: pointer;
            transform: translateY(-4px);
        }


        .box .info i {
            font-size: 18px;
            width: 100%;
            text-align: center;
            margin-bottom: 15px;
            color: #007bff;
        }

        .box :hover.INFO i,
        .box:hover .info h7 {
            COLOR: #000;
        }

        .box .info h7 {
            font-size: 11px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Requisition Menu </h1>
    <!-- END page-header -->

    @*Start New UI*@
    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
        <p class="pb-0">
            
        </p>
    </div>
    <br />
    <div class="row">
        <div class="col-lg-12 col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="panel-body" style="max-height: fit-content;">
                    <div class="row">

                        <div class="col-md-12">
                            <div class="row">
                                @foreach (var item in ViewBag.GetUserMenuList)
                                {
                                    <div class="col-md-1-5 col-6 d-flex ">
                                        <div class="box">
                                            <a href="@item.ScreenUrl" style="text-decoration:none !important;">
                                                <div class="info">
                                                    <i class="@item.Icon"></i>
                                                    <h7><b>@item.ScreenDisplayMenuName</b></h7>
                                                </div>
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @*End New UI*@

    <div class="row">
        <div class="col-md-3">
            <div class="col-lg-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Menu List</h4>
                    </div>

                    <div class="panel-body" style="background: #f5f8ff;">
                        <div class="widget-list rounded mb-4" data-id="widget">
                            <div class="row">
                                <div href="#" class="widget-list-item" style="background: #f5f8ff;">
                                    <div class="widget-list-content">
                                        <h4 class="widget-list-title">Received</h4>
                                    </div>
                                    <div class="widget-list-action text-nowrap text-gray-600 fw-bold text-decoration-none">
                                        <a href="/ESS/ESS_Inbox_Inbox/ESS_Inbox_Inbox" class="btn btn-sm btn-icon btn-warning"><i class="fa fa-eye"></i></a>
                                    </div>
                                    <br />
                                </div>
                            </div>

                            <div class="row">
                                <div href="#" class="widget-list-item" style="background: #f5f8ff;">
                                    <div class="widget-list-content">
                                        <h4 class="widget-list-title">Sent</h4>
                                    </div>
                                    <div class="widget-list-action text-nowrap text-gray-600 fw-bold text-decoration-none">
                                        <a href="/ESS/ESS_Outbox_Outbox/ESS_Outbox_Outbox" class="btn btn-sm btn-icon btn-warning"><i class="fa fa-eye"></i></a>
                                    </div>
                                    <br />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
