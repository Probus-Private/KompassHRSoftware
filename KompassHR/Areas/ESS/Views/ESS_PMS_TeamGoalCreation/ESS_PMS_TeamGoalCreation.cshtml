<script>
    $(".summernote").summernote({
        placeholder: '',
        height: "300"
    });

    $("#btnGetList").on("click", function () {
        debugger
        window.location.href = "@Url.Action("GetList", "ESS_PMS_TeamGoalCreation", new { area = "ESS" })";
    });

    function addNewObjective() {
        var objectiveModal = new bootstrap.Modal(document.getElementById('ObjectiveModal'), {
            backdrop: 'static',
            keyboard: true
        });
        objectiveModal.show();
    }


$(document).ready(function () {
   
    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
    debugger;
    if (Message != null) {
        if (Message != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
        }
    }

    var isUpdate = "@ViewBag.AddUpdateTitle" === "Update";
    var modelObjectiveId = "@Model.ObjectiveId";
    var modelAlignType = "@Model.AlignWithType";
    var modelAlignWith = "@Model.AlignWith";

    /* =========================================
       GLOBAL OBJECTIVE LOADER FUNCTION
    ========================================== */

    function loadObjectives(origin, selectedValue) {

        var $ddl = $("#txtObjectives");
        $ddl.empty().append('<option value="">--Select--</option>');

        $.ajax({
            url: '/ESS_PMS_TeamGoalCreation/OriginWiseObjective',
            type: 'GET',
            data: { Origin: origin },
            dataType: 'json',
            success: function (response) {

                $.each(response, function (i, row) {

                    var obj = {};
                    $.each(row, function (j, kv) {
                        obj[kv.Key] = kv.Value;
                    });

                    $ddl.append(
                        $('<option/>', {
                            value: obj.Id,
                            text: obj.Name,
                            "data-objectiveid": obj.ObjectiveId
                        })
                    );
                });

                if (selectedValue) {
                    $ddl.val(selectedValue).trigger("change.select2");
                }
            }
        });
    }

    var EMPId = @Html.Raw(Json.Encode(TempData["Employeeid"]));
    if (EMPId && EMPId.length > 0) {
        var empArray = EMPId.split(',');
        $("#ddlEmployeeId").val(empArray).trigger("change.select2");
    }

    var isAlign = $("#txtIsAlign").val();
    debugger
    if (isAlign == "true") {
        $("#alignWithContainer").show();
    } else {
