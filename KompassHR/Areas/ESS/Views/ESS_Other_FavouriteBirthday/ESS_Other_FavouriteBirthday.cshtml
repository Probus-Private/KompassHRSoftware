        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="/ESS/ESS_WorkForce_Menu/ESS_WorkForce_Menu/?id=29">Favourite Birthday Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Favourite Birthday</h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Favourite Birthday - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        
                           
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        
                        
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/ESS/ESS_Other_FavouriteBirthday/SaveUpdate" id="SaveFavouriteBirthday" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.FavouriteBirthdayName, new { @class = "form-control", type = "text", name = "FavouriteBirthdayName", id = "txtFavouriteBirthdayName", autocomplete = "Off" })
                                                @Html.HiddenFor(model => model.FavouriteBirthdayID_Encrypted)
                                                @*<input type="text" class="form-control" id="EmpName" />*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                DOB
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FavouriteBirthdayDate, new { @class = "form-control", type = "date", name = "FavouriteBirthdayDate", id = "dateFavouriteBirthdayDate", autocomplete = "Off" })
                                                @*<input type="date" class="form-control" />*@
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">
                                                    Last Record :
                                                    <span> @ViewBag.LastRecored</span>
                                                </div>
                                            </div>

                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>

                                                        <button type="button" id="btnGetFavouriteBirthdayList" class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        //To get List
        $("#btnGetFavouriteBirthdayList").click(function () {
            var url = '@Url.Action("GetList", "ESS_Other_FavouriteBirthday")';
            window.location.href = url;
        });

        //form reset
        $("#formReset").click(function () {
            $("#SaveFavouriteBirthday")[0].reset()
        })

        // When we Update Get Date On Same Manner
        var dt = @Html.Raw(Json.Encode(TempData["FavouriteBirthdayDate"]));
        if(dt == null || dt == "")
        {

        }
        else
        {
            var FavouriteBirthdayDatedt =  convertDate(dt);
            $("#dateFavouriteBirthdayDate").val(FavouriteBirthdayDatedt);
        }
    });
</script>


<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveFavouriteBirthday').validate({
        rules: {
            FavouriteBirthdayName: {
                required: true,
                regex:/^[a-zA-Z ]+$/
            },
            FavouriteBirthdayDate: {
                required: true,

            },
        },
        messages: {
            FavouriteBirthdayName: {
                required: "This field is required",
                regex:"Please enter only alphabet"
            },
            FavouriteBirthdayDate: {
                required: "This field is required",

            },

        },
    });

    //IsValidation Check FavouriteBirthdayDate
    var form = $("#SaveFavouriteBirthday");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var FavouriteBirthdayName=$("#txtFavouriteBirthdayName").val();
        var FavouriteBirthdayID_Encrypted=$("#FavouriteBirthdayID_Encrypted").val();
        $.ajax({
            url:"IsFavouriteBirthdayExists",
            method:"get",
            data:{FavouriteBirthdayName:FavouriteBirthdayName,FavouriteBirthdayID_Encrypted:FavouriteBirthdayID_Encrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveFavouriteBirthday").submit();

                }
            }
        });

    });
</script>



