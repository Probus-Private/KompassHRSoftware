 function loadKraHistory(ownObjectiveId) {

    $.get('@Url.Action("GetKRAHistory", "ESS_PMS_Performance")',
        { OwnObjectiveId: ownObjectiveId },
        function (res) {

            let box = $("#kraHistoryBox");
            let list = $("#kraHistoryList");
            list.empty();

            if (!res || res.length === 0 || res.error) {
                list.html(`
                    <div style="font-size:12px;color:#777;">
                        No previous check-ins found.
                    </div>
                `);
                box.show();
                return;
            }

            res.forEach(function (rowArr) {
                debugger
                // 🔹 Convert [{Key,Value}] → object
                let row = {};
                rowArr.forEach(x => row[x.Key] = x.Value);

                // 🔹 Attachment block (only if file exists)
                let attachmentHtml = "";

                if (row.AttachmentPath && row.AttachmentPath.trim() !== "") {
                    debugger
                    let fileName = row.AttachmentPath.split('/').pop();   // only file name
                    let docId = row.P_Id || row.PerformanceId;            // adjust if needed

                    attachmentHtml = `
        <div class="checkin-attachment" style="margin-top:6px;">
            <a href="javascript:void(0)"
               class="view-attachment"
               data-file="${fileName}"
               data-docid="${docId}">
                <i class="fa fa-paperclip"></i> View Attachment
            </a>
        </div>
    `;
                }



                list.append(`
                    <div class="checkin-card">
                        <div class="checkin-header">
                            ${convertDate(row.KraUpdatedDate)} • ${row.PercentageValue}%
                        </div>

                        <div class="checkin-body">
                            <div>
                                <span>Actual Value:</span>
                                <b>${row.ActualValue}</b>
                                <small>(${row.Status})</small>
                            </div>

                            <div class="checkin-comment">
                                <span>Comment:</span>
                                ${row.Comment || "-"}
                            </div>

                            ${attachmentHtml}
                        </div>
                    </div>
                `);
            });

            box.show();
        }
    );
}


