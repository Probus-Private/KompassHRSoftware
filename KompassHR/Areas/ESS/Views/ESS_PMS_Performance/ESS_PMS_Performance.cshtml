<div id="content" class="app-content">
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">

            <!-- Page Title -->
            <h1 style="font-size:20px; font-weight:600; margin:0;">
                My OKRs
            </h1>

            <!-- Home & Back Buttons -->
            <nav aria-label="breadcrumb">
                <ol style="list-style:none; padding:0; margin:0; display:flex; align-items:center;">
                    <li style="margin-right:10px;">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })"
                           aria-label="Home" title="Home">
                            <img src="~/assets/MenuImages/Home.png"
                                 style="width:24px; height:auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ESS_PMS_Menu", "ESS_PMS_Menu",
                                new { id = 11, ScreenId = 594, area = "ESS" })"
                           aria-label="Back" title="Back">
                            <img src="~/assets/MenuImages/Back.png"
                                 style="width:24px; height:auto;" alt="Back">
                        </a>
                    </li>
                </ol>
            </nav>

        </div>
    </div>
    <div class="okr-section" style="border:1px solid #dfe4ee; background:#fff; border-radius:6px; margin-bottom:25px;">

        <div class="okr-header toggle-team"
             style="padding:10px 14px; background:#f6f8fc; cursor:pointer; display:flex; align-items:center; gap:8px; border-bottom:1px solid #e5e9f2;">
            <i class="fa fa-users" style="color:#264478;"></i>
            <span style="font-weight:600; color:#2b3d6b;">Team</span>
            <i class="fa fa-chevron-down" style="margin-left:auto; color:#264478;"></i>
        </div>
        <div class="team-objectives" style="display:none; padding:10px 15px;">
@foreach (var obj in list.Where(x => x.DisplaySection == "Team"))
{
                <div class="okr-objective" style="padding:10px 0; border-bottom:1px solid #ececec;">

                    <div class="objective-toggle toggle-kra"
                         data-id="@obj.ObjectiveId"
                         style="display:flex; align-items:center; gap:12px; cursor:pointer; padding:6px 0;">

                        <i class="fa fa-caret-right"
                           id="caret-team-@obj.ObjectiveId"
                           style="font-size:14px; color:#54647e; margin-right:4px; transition:0.2s;"></i>

                        <span style="font-size:14px; color:#1f2e54; font-weight:600; flex:1;">
                            @obj.ObjectiveTitle
                        </span>

                        <span style="font-size:13px; color:#98a2b3; margin-right:10px;">
                            @obj.Timeline
                        </span>

                        <div style="width:140px;">
                            <div style="height:6px; background:#e6e6e6; border-radius:4px;">
                                <div style="height:6px; width:@obj.ProgressPercentage%; background:#2b6ded; border-radius:4px;"></div>
                            </div>
                            <div style="font-size:12px; text-align:right; color:#5f6b7b;">
                                @obj.ProgressPercentage%
                            </div>
                        </div>
                    </div>

                    <div class="kra-container"
                         id="team-kra-@obj.ObjectiveId"
                         style="padding-left:26px; display:none; margin-top:10px;">
                    </div>

                </div>
            }

        </div>
    </div>

    <div class="okr-section" style="border:1px solid #dfe4ee; background:#fff; border-radius:6px; margin-bottom:25px;">

        <div class="okr-header toggle-individual"
             style="padding:10px 14px; background:#f6f8fc; cursor:pointer; display:flex; align-items:center; gap:8px; border-bottom:1px solid #e5e9f2;">
            <i class="fa fa-user" style="color:#264478;"></i>
            <span style="font-weight:600; color:#2b3d6b;">Individual</span>
            <i class="fa fa-chevron-down" style="margin-left:auto; color:#264478;"></i>
        </div>
        <div class="individual-objectives" style="display:none; padding:10px 15px;">

@foreach (var obj in list.Where(x => x.DisplaySection == "Individual"))
{
                <div class="okr-objective" style="padding:10px 0; border-bottom:1px solid #ececec;">

                    <!-- Objective header row (tree node) -->
                    <div class="objective-toggle toggle-kra"
                         data-id="@obj.ObjectiveId"
                         style="display:flex; align-items:center; gap:12px; cursor:pointer; padding:6px 0;">

                        <i class="fa fa-caret-right"
                           id="caret-ind-@obj.ObjectiveId"
                           style="font-size:14px; color:#54647e; margin-right:4px; transition:0.2s;"></i>

                        <span style="font-size:14px; color:#1f2e54; font-weight:600; flex:1;">
                            @obj.ObjectiveTitle
                        </span>

                        <span style="font-size:13px; color:#98a2b3; margin-right:10px;">
                            @obj.Timeline
                        </span>

                        <div style="width:140px;">
                            <div style="height:6px; background:#e6e6e6; border-radius:4px;">
                                <div style="height:6px; width:@obj.ProgressPercentage%; background:#2b6ded; border-radius:4px;"></div>
                            </div>
                            <div style="font-size:12px; text-align:right; color:#5f6b7b;">
                                @obj.ProgressPercentage%
                            </div>
                        </div>
                    </div>

                    <!-- KRA container (tree child) -->
                    <div class="kra-container"
                         id="ind-kra-@obj.ObjectiveId"
                         style="padding-left:26px; display:none; margin-top:10px;">
                    </div>

                </div>
            }

        </div>
    </div>

</div>

<div id="sidebarBackdrop" class="sidebar-backdrop"></div>

<div class="sidebar" id="performanceFormSidebar">

    <div class="sidebar-header d-flex justify-content-between align-items-center">
        <h4 class="sidebar-title">Check-In</h4>
        <button type="button" class="btn-close" id="closePerformanceSidebar"></button>
    </div>

    <div class="sidebar-body">
        <form id="PerformanceUpdateForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input type="hidden" id="PerformanceObjectiveId">
            <input type="hidden" id="HiddenObjectiveId">
            <input type="hidden" id="ciTargetRaw">
            <input type="hidden" id="ciUOMType">
            <div class="objective-block">
                <div class="objective-title" id="ciObjective">Objective Title Here</div>
                <div class="kra-title" id="keyResultName">KRA Title Here</div>
            </div>
            <hr>
            <div class="detail-grid">
                <div class="label">UOM</div>           <div class="value" id="ciUOM"></div>
                <div class="label">Target</div>        <div class="value" id="ciTarget"></div>
                <div class="label">Smart</div>         <div class="value" id="ciSmart"></div>
                <div class="label">KPI Category</div>  <div class="value" id="ciKPICategory"></div>
                <div class="label">KPI</div>           <div class="value" id="ciKPI"></div>
                <div class="label">Visibility</div>    <div class="value" id="ciVisibility"></div>
                <div class="label">Start → End</div>   <div class="value" id="ciDates"></div>
                <div class="label">Description</div>   <div class="value" id="ciDescription"></div>
            </div>
            <hr>
            <div class="form-section">
                <label class="form-label">Actual Value Done</label>
                <input type="number" id="txtActualValue" class="form-control">

                <div class="live-progress">
                    Progress: <b id="progressValue">0%</b>
                </div>

                <label class="form-label mt-3">Status</label>
                <select id="Status" class="form-select">
                    <option value="Not Started">⚪ Not Started</option>
                    <option value="On Track">🟢 On Track</option>
                    <option value="At Risk">🟡 At Risk</option>
                    <option value="In Trouble">🔴 In Trouble</option>
                    <option value="Completed">🔵 Completed</option>
                </select>


                <label class="form-label mt-3">Period</label>
                <select id="ddlPeriod" class="form-select"></select>
                <input type="hidden" id="ObjectivePeriodId">

                <label class="form-label mt-3">Check-In Date</label>
                <input type="date" id="checkInDate" class="form-control">

                <label class="form-label mt-3">Comment</label>
                <textarea id="Comment" class="form-control" rows="3"></textarea>
            </div>
            <label class="form-label mt-3">
                Attachment
                <small class="text-muted">(optional)</small>
            </label>

            <div class="attachment-box">
                <input type="file"
                       id="CheckInAttachment"
                       class="form-control"
                       accept=".pdf,.jpg,.jpeg,.png" />

                <small class="text-muted d-block mt-1">
                    Allowed: PDF, JPG, JPEG, PNG(Max 5 MB)
                </small>

                <div id="attachmentPreview" class="mt-2" style="display:none;">
                    <i class="fa fa-paperclip"></i>
                    <span id="attachmentName"></span>
                    <a href="javascript:void(0)" class="text-danger ms-2" id="removeAttachment">
                        Remove
                    </a>
                </div>
            </div>

            <div class="action-buttons">
                <button type="button" class="btn btn-light" id="cancelBtn">Cancel</button>
                <button type="button" class="btn btn-primary" id="updateBtn">Update</button>
            </div>
            <div class="action-buttons">
                <button type="button" class="btn btn-success" id="btnFinalSubmit">Final Submit</button>
            </div>

            <div id="kraHistoryBox" style="display:none; margin-top:20px;">
                <h5 style="font-size:14px; font-weight:600; color:#374151; margin-bottom:8px;">
                    Previous Check-Ins
                </h5>

                <div id="kraHistoryList" style="max-height:180px;
                     overflow-y:auto;
                     border:1px solid #ddd;
                     background:#fafafa;
                     padding:10px;
                     border-radius:6px;
                     ">
                </div>
            </div>

        </form>
    </div>
</div>

<!-- Attachment Viewer Modal -->
<div class="modal fade" id="attachmentModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Attachment Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" style="height:80vh;">
                <iframe id="attachmentFrame"
                        src=""
                        style="width:100%; height:100%; border:none;"></iframe>
            </div>

        </div>
    </div>
</div>


<script>
    $(document).ready(function () {


     
            var Message = @Html.Raw(Json.Encode(TempData["Message"]));
            var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
            debugger;
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                }
            }


        let today = new Date().toISOString().split("T")[0];
        $("#checkInDate").val(today);
        $("#txtActualValue").on("input", function () {

            let value = parseFloat($(this).val());
            let target = parseFloat($("#ciTargetRaw").val());
            let uom = $("#ciUOMType").val().trim();
            let percent = 0;

            if (isNaN(value) || isNaN(target) || target <= 0) {
                $("#progressValue").text("0%");
                return;
            }

            switch (uom) {

                // 🔒 Percentage-based KPI
                case "Percentage (%)":
                    percent = (value / target) * 100;

                    // optional cap (if you don't want >100%)
                    if (percent > 100) percent = 100;

                    break;

                    // 🚀 Over-achievement allowed
                case "Number":
                case "Count":
                case "Units":
                case "Hours":
                case "Days":
                case "Amount (? / $)":
                case "Quality Score":
                case "Rating":
                default:
                    percent = (value / target) * 100;
                    break;
            }

            // 🎨 UX: Highlight over-achievement
            if (percent > 100) {
                $("#progressValue").css("color", "#16a34a"); // green
            } else {
                $("#progressValue").css("color", "#2563eb"); // normal
            }

            $("#progressValue").text(percent.toFixed(2) + "%");
        });
    });

    $("#CheckInAttachment").on("change", function () {

        if (this.files.length === 0) return;

        const file = this.files[0];
        const allowedTypes = [
            "application/pdf",
            "image/jpeg",
            "image/png"
        ];

        if (!allowedTypes.includes(file.type)) {
            swal("Only PDF, JPG, JPEG, PNG files are allowed", "", "warning");
            $(this).val('');
            $("#attachmentPreview").hide();
            return;
        }

        if (file.size > 5 * 1024 * 1024) {
            swal("File size must be under 5 MB", "", "warning");
            $(this).val('');
            $("#attachmentPreview").hide();
            return;
        }

        // ✅ Preview
        $("#attachmentName").text(file.name);
        $("#attachmentPreview").show();
    });



$(document).on("click", ".objective-toggle", function (e) {
    e.preventDefault();
    e.stopPropagation();
    let id = $(this).data("id");
    let $section   = $(this).closest(".team-objectives, .individual-objectives");
    let $container = $(this).closest(".okr-objective").find(".kra-container");
    let $caret     = $(this).find(".fa-caret-right");
    if ($container.is(":visible")) {
        $container.slideUp(150);
        $caret.css("transform", "rotate(0deg)");
        return;
    }
    $section.find(".kra-container")
        .not($container)
        .slideUp(0);
    $section.find(".fa-caret-right")
        .not($caret)
        .css("transform", "rotate(0deg)");
    $caret.css("transform", "rotate(90deg)");
    $.ajax({
        url: '@Url.Action("ObjectiveWise", "ESS_PMS_Performance")',
        type: "GET",
        data: { ObjectiveId: id },
        success: function (data) {

            let isTeam = $section.hasClass("team-objectives");

            let filteredData = data.filter(itemArr => {
                let KRA = Array.isArray(itemArr)
                    ? Object.fromEntries(itemArr.map(x =>[x.Key, x.Value]))
                    : itemArr;

                return isTeam
                    ? KRA.SourceTable === "Team"
                    : KRA.SourceTable === "Own";
            });
            if (filteredData.length === 0) {
                $container.html("<div style='padding:10px;color:#777;'>No KRA found.</div>");
                $container.slideDown();
                return;
            }
            let html = `
                <table class="okr-table">
                    <tr><th>KRA</th><th>Progress</th></tr>`;
            filteredData.forEach(itemArr => {
