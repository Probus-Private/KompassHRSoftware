<script>

    $("#updateBtn").click(function () {
        debugger

        // 🔴 Period mandatory validation
        let periodId = $("#ddlPeriod").val();

        if (!periodId || periodId === "" || periodId === "0") {
            Swal.fire({
                icon: "warning",
                title: "Period Required",
                text: "Please select a Period before final submit."
            });
            $("#ddlPeriod").focus();
            return;
        }

        let data = {
            OwnObjectiveCreationId: $("#PerformanceObjectiveId").val(),
            PercentageValue: $("#progressValue").text().replace("%", ""),
            ActualValue: $("#txtActualValue").val(),
            Status: $("#Status").val(),
            Comment: $("#Comment").val(),
            KraUpdatedDate: $("#checkInDate").val(),
            ObjectivePeriodId: $("#ddlPeriod").val(),
            ProcessType: "Save"   // ⭐ VERY IMPORTANT
        };

        SavePerformance(data);
    });


    $("#btnFinalSubmit").click(function () {
        debugger
        // 🔴 Period mandatory validation
        let periodId = $("#ddlPeriod").val();

        if (!periodId || periodId === "" || periodId === "0") {
            Swal.fire({
                icon: "warning",
                title: "Period Required",
                text: "Please select a Period before final submit."
            });
            $("#ddlPeriod").focus();
            return;
        }

        Swal.fire({
            title: "Submit For Approval?",
            text: "After final submit you cannot update this KRA.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, Submit"
        }).then(result => {

            if (!result.isConfirmed) return;

            let data = {
                OwnObjectiveCreationId: $("#PerformanceObjectiveId").val(),
                PercentageValue: $("#progressValue").text().replace("%", ""),
                ActualValue: $("#txtActualValue").val(),
                ObjectivePeriodId: periodId,   // ✅ guaranteed value
                Status: $("#Status").val(),
                Comment: $("#Comment").val(),
                KraUpdatedDate: $("#checkInDate").val(),
                ProcessType: "FinalSubmit"
            };

            SavePerformance(data);
        });
    });


    $(document).on("click", ".toggle-team", function (e) {
        e.preventDefault();
        e.stopPropagation();
        let box = $(".team-objectives");
        if (box.data("open") === 1) {
            box.slideUp(180);
            box.data("open", 0);
        } else {
            box.slideDown(180);
            box.data("open", 1);
        }
    });

    $(document).on("click", ".toggle-individual", function (e) {
        e.preventDefault();
        e.stopPropagation();
        let box = $(".individual-objectives");
        if (box.data("open") === 1) {
            box.slideUp(180);
            box.data("open", 0);
        } else {
            box.slideDown(180);
            box.data("open", 1);
        }
    });

   function SavePerformance(data) {
    debugger;

    let formData = new FormData();

    // 🔹 Append model fields
    formData.append("OwnObjectiveCreationId", data.OwnObjectiveCreationId);
    formData.append("PercentageValue", data.PercentageValue);
    formData.append("ActualValue", data.ActualValue);
    formData.append("Status", data.Status);
    formData.append("Comment", data.Comment);
    formData.append("KraUpdatedDate", data.KraUpdatedDate);
    formData.append("ObjectivePeriodId", data.ObjectivePeriodId);
    formData.append("ProcessType", data.ProcessType);

    // 🔹 Append file
    let fileInput = document.getElementById("CheckInAttachment");
    if (fileInput && fileInput.files.length > 0) {
        formData.append("file", fileInput.files[0]); // name MUST be "file"
    }

    $.ajax({
        url: '@Url.Action("SaveUpdate", "ESS_PMS_Performance")',
        type: "POST",
        data: formData,
        contentType: false,   
        processData: false,   
        success: function (res) {
            $("#performanceFormSidebar").removeClass("show");
            $("#sidebarBackdrop").hide();
            location.reload();
        },
        error: function () {
            Swal.fire("Error", "Upload failed", "error");
        }
    });
}



