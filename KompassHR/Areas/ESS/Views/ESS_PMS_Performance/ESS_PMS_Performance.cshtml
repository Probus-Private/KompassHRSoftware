function RefreshObjectiveProgress(objectiveId) {
    $.ajax({
        url: '@Url.Action("GetObjectiveProgress", "ESS_PMS_Performance")',
        type: "GET",
        data: { ObjectiveId: objectiveId },
        success: function (avg) {
            let value = 0;
            if (Array.isArray(avg) && avg.length > 0) {
                value = parseFloat(avg[0].Value || Object.values(avg[0])[0]) || 0;
            } else if (typeof avg === "object") {
                value = parseFloat(Object.values(avg)[0]) || 0;
            } else {
                value = parseFloat(avg) || 0;
            }
            console.log("REFRESHED AVG:", value);
            let row = $(`button.add-kra-btn[data-id='${objectiveId}']`).closest("tr");
            if (row.length === 0) {
                console.warn("Row not found for objective:", objectiveId);
                return;
            }
            let bar = row.find(".progress-bar");
            let text = row.find("small");
            bar.css("width", value + "%");
            text.text(value.toFixed(0) + "%");
        }
    });
}

