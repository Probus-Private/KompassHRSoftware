function convertDate(data) {
    var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
    var date = millisecTodate(getdate);
    return date;
}

function loadPeriods(ownObjectiveCreationId) {
    debugger;
    $.get('@Url.Action("GetObjectivePeriods")',
        { ownObjectiveCreationId: ownObjectiveCreationId },
        function (res) {
            debugger
            let ddl = $("#ddlPeriod");
            ddl.empty();

            if (!res || res.length === 0) {
                ddl.append(`<option>No Periods</option>`);
                return;
            }

            let rows = [];

            // 🔹 Handle both response shapes
            if (Array.isArray(res[0]) && Array.isArray(res[0][0])) {
                rows = res[0];          // nested
            } else if (Array.isArray(res[0])) {
                rows = res;             // flat
            }

            let firstAvailableId = null;

            rows.forEach(function (rowArr) {

                // ✅ Convert [{Key,Value}] → object
                let row = {};
                rowArr.forEach(function (x) {
                    row[x.Key.trim()] = (x.Value || "").toString().trim();
                });

                let isSubmitted = row.IsFinalSubmit === "Yes";
                let disabled = isSubmitted ? "disabled" : "";
                let status = isSubmitted ? " (Submitted)" : "";

                ddl.append(`
                    <option value="${row.ObjectivePeriodId}" ${disabled}>
                        ${row.PeriodLabel}${status}
                    </option>
                `);

                if (!isSubmitted && firstAvailableId === null) {
                    firstAvailableId = row.ObjectivePeriodId;
                }
            });

            // ✅ Auto-select first open period
            if (firstAvailableId) {
                ddl.val(firstAvailableId);
                $("#ObjectivePeriodId").val(firstAvailableId);
            }
        }
    );
}



