    // Context menu variables
    let currentCell = null;
    let currentEmployeeId = null;
    let currentDate = null;
    let currentValue = null;

    // Show context menu - Fixed positioning
    function showAttendanceContextMenu(cell, event) {
        currentCell = $(cell);
        currentEmployeeId = currentCell.data('employeeid');
        currentDate = currentCell.data('date');
        currentValue = currentCell.find('.att-text').text().trim();

        // Check if value contains AB (for AB/EL case)
        var allowedValues = ['P','AB','PH','PH(P)','WO','AB/P','P/AB','HD','LWP/AB','AB/LWP','OD/AB','WFH/AB','AB/WFH','AB/SL',
   'CO/AB','AB/CO','CL/AB','AB/CL','SL/AB','AB/SL','EL/AB','AB/EL','PL/AB','AB/PL',
   'P/OD','P/WFH','OD/P','WFH/P','P/CO','P/CL','P/SL','P/EL','EL/P','P/PL','PL/P','P/LWP','LWP/P','CL/P',
   'SL/P','WFH/P','CO/P'];
        if (!allowedValues.includes(currentValue) && !currentValue.includes('AB')) {
            hideContextMenu();
            return;
        }

        var dateParts = currentDate.split('-');
        if (dateParts.length === 3) {
            var day = dateParts[0];
            var month = dateParts[1];
            var year = '20' + dateParts[2]; // Convert yy to yyyy

            // Format as DD/MM/YYYY
            var formattedDate = day + '/' + month + '/' + year;

            // Update both button spans
            $('#txtpresentdate').text(formattedDate);
            $('#txtabsentdate').text(formattedDate);
        }

        // Get context menu element
        const contextMenu = $('#attendanceContextMenu');

        // Get cell position relative to viewport
        const cellRect = cell.getBoundingClientRect();

        // Position context menu right next to the cell
        // You can adjust these offsets as needed
        const offsetX = 5; // 5px right of cell
        const offsetY = 5; // 5px below cell

        let posX = cellRect.right + offsetX;
        let posY = cellRect.top + offsetY;

        // If context menu would go off screen to the right, show it to the left
        if (posX + 180 > window.innerWidth) {
            posX = cellRect.left - 180 - offsetX;
        }

        // If context menu would go off screen to the bottom, show it above
        if (posY + 100 > window.innerHeight) {
            posY = cellRect.top - 100 - offsetY;
        }

        // Show context menu
        contextMenu.css({
            left: posX + 'px',
            top: posY + 'px',
            display: 'block'
        });
    }

    // Alternative method using mouse coordinates (if you prefer click position)
    function showAttendanceContextMenuAtClick(cell, event) {
        currentCell = $(cell);
        currentEmployeeId = currentCell.data('employeeid');
        currentDate = currentCell.data('date');
        currentValue = currentCell.find('.att-text').text().trim();

        // Check if value contains AB (for AB/EL case)
        var allowedValues = ['P', 'AB', 'AB/EL'];
        if (!allowedValues.includes(currentValue) && !currentValue.includes('AB')) {
            hideContextMenu();
            return;
        }

        // Get context menu element
        const contextMenu = $('#attendanceContextMenu');

        // Use mouse click coordinates
        const clickX = event.clientX;
        const clickY = event.clientY;

        // Show context menu right at click position
        contextMenu.css({
            left: (clickX + 5) + 'px', // 5px offset from click
            top: (clickY + 5) + 'px', // 5px offset from click
            display: 'block'
        });

        // Adjust if goes off screen
        const menuWidth = contextMenu.outerWidth();
        const menuHeight = contextMenu.outerHeight();

        if (clickX + menuWidth > window.innerWidth) {
            contextMenu.css('left', (clickX - menuWidth - 5) + 'px');
        }

        if (clickY + menuHeight > window.innerHeight) {
            contextMenu.css('top', (clickY - menuHeight - 5) + 'px');
        }
    }

    // Close context menu when clicking elsewhere
