                                                        </div>
                                                        <div class="col-lg-3 ps-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_A, new { @class = "form-control", type = "text", name = "RatePartA_A", id = "txtRatePartA_A" })
                                                        </div>
                                                    </div>

                                                    <div class="mb-2 row align-items-center g-1">
                                                        <label class="col-lg-6 col-form-label"> Educational Allowance <span class="important">*</span> </label>
                                                        <div class="col-lg-3 pe-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_HRA, new { @class = "form-control", type = "text", name = "RatePartA_HRA", id = "txtRatePartA_HRA" })
                                                        </div>
                                                        <div class="col-lg-3 ps-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_A, new { @class = "form-control", type = "text", name = "RatePartA_A", id = "txtRatePartA_A" })
                                                        </div>
                                                    </div>

                                                    <div class="mb-2 row align-items-center g-1">
                                                        <label class="col-lg-6 col-form-label"> Entertainment Allowance <span class="important">*</span> </label>
                                                        <div class="col-lg-3 pe-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_HRA, new { @class = "form-control", type = "text", name = "RatePartA_HRA", id = "txtRatePartA_HRA" })
                                                        </div>
                                                        <div class="col-lg-3 ps-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_A, new { @class = "form-control", type = "text", name = "RatePartA_A", id = "txtRatePartA_A" })
                                                        </div>
                                                    </div>

                                                    <div class="mb-2 row align-items-center g-1">
                                                        <label class="col-lg-6 col-form-label"> Medical Allowance <span class="important">*</span> </label>
                                                        <div class="col-lg-3 pe-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_HRA, new { @class = "form-control", type = "text", name = "RatePartA_HRA", id = "txtRatePartA_HRA" })
                                                        </div>
                                                        <div class="col-lg-3 ps-1">
                                                            @Html.TextBoxFor(model => model.RatePartA_A, new { @class = "form-control", type = "text", name = "RatePartA_A", id = "txtRatePartA_A" })
                                                        </div>
