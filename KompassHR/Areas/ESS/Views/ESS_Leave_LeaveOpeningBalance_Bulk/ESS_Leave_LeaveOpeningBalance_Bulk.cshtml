    function validateTextbox(uniqueId) {
        debugger
        var currentRow = $(uniqueId).closest("tr");
        var validationMessage = currentRow.find('#validationMessage_').val();
        var textboxValue = currentRow.find('#txtnumber_').val();

        var pattern = /^[1-9]\d*(\.(0|5))?$/;
        if (pattern.test(textboxValue)) {
            validationMessage.textContent = ''; // Clear validation message
        } else {
            currentRow.find('#txtnumber_').val('');
            Swal.fire({
                title: "",
                text: ".5 is Constant",
                icon: "warning",
                confirmButtonText: "OK"
            }).then(() => {
                currentRow.find('#txtnumber_').val('0'); // Set the textbox to 0 after OK is clicked
            });
            return false;
        }
    }

    var formNormal = $("#SaveBulkUpload");
    formNormal.validate();
    function downloadExcelFile() {
        debugger;
        formNormal.valid();
        if (formNormal.valid() == false) {
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        //$(".Userloaderbg").css("display", "flex");
        var CmpId = encodeURIComponent($("#ddlCompanyId").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        var LeaveYearId = encodeURIComponent($("#ddlLeaveYearId").val());
        var LeaveTypeId = encodeURIComponent($("#ddlLeaveTypeId").val());
        var url = `@Url.Action("DownloadExcelFile", "ESS_Leave_LeaveOpeningBalance_Bulk")?CmpId=${CmpId}&BranchId=${BranchId}&LeaveYearId=${LeaveYearId}&LeaveTypeId=${LeaveTypeId}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                //var formattedDate = convertDateFormat(FromDate);
                //var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'LeaveOpeningBalance.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }
</script>

