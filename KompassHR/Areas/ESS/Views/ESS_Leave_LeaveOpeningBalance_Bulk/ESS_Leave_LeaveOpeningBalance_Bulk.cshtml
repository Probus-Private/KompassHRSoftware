<script>
    $(document).ready(function () {
        $("#ddlLeaveTypeId option").each(function () {
            var val = $(this).val();
            if (val) {
                var item = @Html.Raw(Json.Encode(ViewBag.LeaveTypeName));
                var match = item.find(x => x.Id == val);
                if (match) {
                    $(this).attr("data-typeid", match.LeaveTypeId);
                }
            }
        });

        $("#ddlCompanyId").select2();
        $("#ddlBranchId").select2();
        $("#ddlLeaveYearId").select2();
        $("#ddlLeaveTypeId").select2();

        
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        $('.TabledataBulkClass').DataTable({
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true, // Enable horizontal scrolling to align the header
            searching: true, // Enable searching
            autoWidth: true, // Prevent automatic column resizing issues
            stripeClasses: [], // Disable alternating row colors
            columnDefs: [
                { targets: '_all', className: 'dt-head-center' } // Optional: Center align header text
            ],
            fixedHeader: false // Ensure the header stays fixed while scrolling
        });
      
    });//Ready Funcation
</script>


<script>


    function ResetFile()  {
        debugger;
        let allowedExtension = ['application/vnd.ms-excel'];
        let fileInput = document.getElementById('txtAttachFile');

        if (fileInput.files.length > 0) {
            let type = fileInput.files[0].type;

            if (allowedExtension.indexOf(type) === -1) {
                $("#ErrorFile").text('File type should be Excel (.xlsx)');
                fileInput.value = null;
                return false;
            }
        }

        $("#ErrorFile").text('');
    }


    $("#btnfileupload").click(function(){
        debugger;
        var fileInput = document.getElementById('txtAttachFile');
        if (fileInput.files.length === 0) {
            Swal.fire({
                icon:  "error",
                text: "Please import excel file",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        $('#tblLoadEmployedetails').not(function(){return!!$(this).has('th').length;}).remove();
        $("#SaveBulkUpload").submit();
    })



    function ChangeCompany() {
        debugger;
        $("#ddlBranchId").find("option").remove();
        $("#ddlLeaveYearId").find("option").remove();
        $("#ddlLeaveTypeId").find("option").remove();
        var CmpId = $("#ddlCompanyId").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: "@Url.Action("GetBusinessUnit", "ESS_Leave_LeaveOpeningBalance_Bulk")",
            data: { CmpId: CmpId },
            success: function (data) {
                debugger;
                if (data != null) {
                    var data1 = data.data;
                    var LeaveYear = data.LeaveYear;
                    var LeaveType = data.LeaveType;

                    var leaveTypeList = LeaveType.map(function (arr) {
                        var obj = {};
                        arr.forEach(function (item) {
                            obj[item.Key] = item.Value;
                        });
                        return obj;
                    });
                    
                    $("#ddlBranchId").append("<option value=''>--Select--</option>");
                    $.each(data1, function (i, p) {
                        $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });

                    $("#ddlLeaveTypeId").append("<option value=''>--Select--</option>");
                    for (var i = 0; i < leaveTypeList.length; i++) {
                        $("#ddlLeaveTypeId").append(
                                    $("<option>")
                                        .val(leaveTypeList[i].Id)
                                        .text(leaveTypeList[i].Name)
                                        .attr("data-typeid", leaveTypeList[i].LeaveTypeId)  // use attr instead of .data
                                );
                    }


                    //$("#ddlLeaveTypeId").append("<option value=''>--Select--</option>");
                    //for (var i = 0; i < LeaveType.length; i++) {
                    //    $("#ddlLeaveTypeId").append("<option value='" + LeaveType[i].Id + "'>" + LeaveType[i].Name + "</option>");
                    //}

                    $("#ddlLeaveYearId").append("<option value=''>--Select-- </option>");
                    for (var i = 0; i < LeaveYear.length; i++) {
                        $("#ddlLeaveYearId").append("<option value='" + LeaveYear[i].Id + "'>" + LeaveYear[i].Name + "</option>");
                    }
                }
            }
        })
    }


    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>
<script>

    // use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveBulkUpload').validate({
        rules: {
            CmpID: {
                required: true,
            },
            LeaveOpeningBalanceBranchID: {
                required: true,
            },

            LeaveOpeningBalanceLeaveYearId: {
                required: true,
            },
            LeaveOpeningBalanceLeaveTypeId: {
                required: true,
            },
        },
        messages: {
            CmpID: {
                required: "Company name is required",
            },
            LeaveOpeningBalanceBranchID: {
                required: "Business unit is required",
            },
            LeaveOpeningBalanceLeaveYearId: {
                required: "Leave Year is required",
            },
            LeaveOpeningBalanceLeaveTypeId: {
                required: "Leave Type is required",
            },
        },
    });
    var formNormal = $("#SaveBulkUpload");
    formNormal.validate();
    function funSave() {
        debugger;
        formNormal.valid();
        if (formNormal.valid() == false) {
            return false;
        }
        $("#SelectAll").prop("checked", false);
        var LeaveOpeningBalance = [];


        // Iterate through checked checkboxes in the table body only
        $('#tblLoadEmployedetails :checkbox:checked').each(function () {
            var row = $(this).closest('tr'); // Get the closest row
            var data = {
                EmployeeNo: row.find('td').eq(1).text(), // Hidden column
                LeaveType: row.find('td').eq(8).text(), // Hidden column
                //LeaveType: row.find('td').eq(6).find('input').val(),
                YearlyLeave: row.find('td').eq(9).find('input').val(),
            };

            // Push the data object to the array
            LeaveOpeningBalance.push(data);
        });
        if (LeaveOpeningBalance.length==0)
        {
            var Message="Select atleast one employee";
            var Icon="error";
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)

                            return false
                        }
                    })
                    return false;
                }
            }
        }
        var CmpID= $("#ddlCompanyId").val();
        var BranchId= $("#ddlBranchId").val();
        var LeaveYearId= $("#ddlLeaveYearId").val();
        //var LeaveTypeId= $("#ddlLeaveTypeId").val();
        debugger;
        var selectedOption = $("#ddlLeaveTypeId option:selected");
        var SettingId = selectedOption.val();     
        var LeaveTypeId = selectedOption.attr("data-typeid");
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpadte", "ESS_Leave_LeaveOpeningBalance_Bulk")',
            data: JSON.stringify({ LeaveOpeningBalance: LeaveOpeningBalance,LeaveTypeId:LeaveTypeId,LeaveYearId:LeaveYearId,SettingId:SettingId,BranchId:BranchId,CmpID:CmpID}),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (data != null) {
                    if(Icon1=="error")
                    {
                        $(".Userloaderbg").css("display", "none");
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                    else{
                        if (Message1 != null) {
