<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }

        var List = @Html.Raw(Json.Encode(ViewBag.ResourceApprovalList));
        debugger;
        var Encrypted=List[1].Value;
        var id=List[0].Value;
        $("#txtResourceId_Encrypted").val(Encrypted);
        $("#txtResourceId").val(id);

    });
</script>



<script>
    function printDiv() {

        //Get the HTML of div
        var divElements = document.getElementById('card').innerHTML;
        //Get the HTML of whole page
        var oldPage = document.body.innerHTML;

        //Reset the page's HTML with div's HTML only
        document.body.innerHTML =
          "<html><head></head><body>    " +
        divElements + "    </body>";

        //Print Page
        window.print();

        //Restore orignal HTML
        document.body.innerHTML = oldPage;
    }





    //var Resource="";
    //var ResourceEncrypted="";
    //var Status="";
    function OpenModule()
    {
        debugger;
        $("#myModalFinal").modal('show');
    }


    function Approved(Approver)
    {
        debugger;
        //debugger
        //var DocId="";
        //var Encrypted="";

        //if(ResourceId_Encrypted!=undefined)
        //{
        //    DocId=ResourceId;
        //    Encrypted=ResourceId_Encrypted;
        //    Status="Approved";
        //}
        //else
        //{
        //    DocId=Resource;
        //    Encrypted=ResourceEncrypted;
        //    Status="Rejected";
        //}
        var DocId=$("#txtResourceId").val();
        var Encrypted=$("#txtResourceId_Encrypted").val();
        var Status="";
        var Remark="";
        if(Approver=="Rejected")
        {
            Remark = $("#txtApproveRejectRemark").val();
            Status="Rejected";

        }
        else{
            Status="Approved";
        }


        $.ajax({
            url: "@Url.Action("ForApprovalCandidate", "ESS_Recruitment_ResourcesRequisition")",
            method:"get",
        data:{DocId:DocId,Encrypted:Encrypted,Status:Status,Remark:Remark},
        success:function(response){
            debugger;
            var Message1 = response.Message;
            var Icon1 = response.Icon;
            if (response.Icon=="error") {
                if (Message1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });

                        $("#myModalFinal").modal('hide');
                        $("#txtApproveRejectRemark").val("")
                        .then((result) => {
                            if (result.isConfirmed) {
                               window.location.href = '@Url.Action("ApprovalList", "ESS_Recruitment_ResourcesRequisition")';
                            } else if (
                                /* Read more about handling dismissals below */
                                result.dismiss === Swal.DismissReason.cancel
                            ) {

                            }
                        })


                    }
                }

            }

            else{
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="success") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            })
                            .then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("ApprovalList", "ESS_Recruitment_ResourcesRequisition")';
                                } else if (
                                    /* Read more about handling dismissals below */
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })

                            $("#myModalFinal").modal('hide');
                            $("#txtApproveRejectRemark").val("");


                        }
                    }
                }


            }
        }
    });

    }

    $("#CloseModel").click(function () {
        $("#txtApproveRejectRemark").val('');
    })

</script>

