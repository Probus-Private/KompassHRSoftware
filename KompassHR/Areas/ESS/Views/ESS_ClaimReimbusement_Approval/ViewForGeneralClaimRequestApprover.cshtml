                font-size: 14px;
                padding: 8px;
            }

        .float-end {
            float: none !important;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-top: 10px;
        }

            .float-end .btn {
                width: 100%;
                font-size: 14px;
            }

        .fa-solid, .fa-regular, address {
            font-size: 14px;
        }

        .hidden-print {
            display: block;
        }

        @@media print {
            .hidden-print {
