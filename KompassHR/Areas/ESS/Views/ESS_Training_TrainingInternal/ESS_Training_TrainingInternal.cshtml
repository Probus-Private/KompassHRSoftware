    {debugger;
        let allowedExtension = ['image/jpeg', 'image/jpg', 'image/png','application/pdf'];
        let type = document.getElementById('fileupload').files[0].type;

        if(allowedExtension.indexOf(type)>-1)
        {
        }else{
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf",
            })
            document.getElementById("fileUploadFile").value = null;
        }

        $("#lblFileName").text('');
    }
</script>
<script>
    function calculateContractDuration(fromMonthValue, toMonthValue) {
        if (!fromMonthValue || !toMonthValue) return "";

        const fromDate = new Date(fromMonthValue + "-01");
        const toDate = new Date(toMonthValue + "-01");

        if (toDate < fromDate) return "Invalid range";

        const fromYear = fromDate.getFullYear();
        const fromMonth = fromDate.getMonth(); // 0-based
        const toYear = toDate.getFullYear();
        const toMonth = toDate.getMonth();

        const totalMonths = (toYear - fromYear) * 12 + (toMonth - fromMonth) + 1;

        return totalMonths + " Month" + (totalMonths !== 1 ? "s" : "");
    }

    $(document).ready(function () {debugger;
        $('#txtfromMonth, #txtToMonth').on('change', function () {
            const fromMonthVal = $('#txtfromMonth').val();
            const toMonthVal = $('#txtToMonth').val();
            const duration = calculateContractDuration(fromMonthVal, toMonthVal);
            $('#txtContractDuration').val(duration);
        });
    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const fromMonth = document.getElementById("txtfromMonth");
        const toMonth = document.getElementById("txtToMonth");
        const errorSpan = document.getElementById("monthError");

        function validateMonthRange() {
            if (!fromMonth.value || !toMonth.value) return;

            const from = new Date(fromMonth.value + "-01");
            const to = new Date(toMonth.value + "-01");

            if (to < from) {
                errorSpan.style.display = "inline";
               // toMonth.classList.add("is-invalid");
            } else {
                errorSpan.style.display = "none";
              //  toMonth.classList.remove("is-invalid");
            }
        }

        toMonth.addEventListener("change", validateMonthRange);
        fromMonth.addEventListener("change", validateMonthRange); // Optional: to revalidate if FromMonth changes
    });
</script>
