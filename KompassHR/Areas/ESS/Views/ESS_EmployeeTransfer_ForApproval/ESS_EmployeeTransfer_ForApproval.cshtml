
@{
    ViewBag.Title = "ESS_EmployeeTransfer_ForApproval";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
          background-color: rgba(233, 236, 239, 0.5) !important;
      }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }



    th:nth-child(1), td:nth-child(1) {
        width: 60px; /* Set the width for the first column */
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Approval Request
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_HRSpace_EmployeeTransferMenu", "ESS_HRSpace_EmployeeTransferMenu",  new { id = 41, ScreenId=708, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Approval Request - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of positions authorised by manager.
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">

                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage5">
                                    <thead>
                                        <tr class="trheading text-center">
                                            <th class="fixed-side text-center">View</th>
                                            <th hidden>DocId</th>
                                            <th hidden>DocID_Encrypted</th>
                                            @*<th class="text-nowrap text-center">
                                                ALL <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" />
                                            </th>*@
                                          
                                            <th class="text-nowrap text-center">Doc No</th>
                                            <th class="text-nowrap text-center">Doc Date</th>
                                            <th class="text-nowrap text-center">Employee Name</th>
                                            <th class="text-nowrap text-center">From Unit</th>
                                            <th class="text-nowrap text-center">To Unit</th>
                                            <th class="text-nowrap text-center">Transfer Order BY</th>
                                           <th class="text-nowrap text-center">Reason</th>
                                            <th class="text-nowrap text-center">Pending Since</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tbodyApproveReject">
                                        @foreach (var d in ViewBag.EmployeeTransferApprovalList)
                                        {
                                            <tr>
                                                <td class="text-center">
                                                    <i class="fa-solid fa-eye text-warning fa-lg" id="btnUpdate" style="cursor: pointer;" onclick="ViewForApprover('@d.DocID_Encrypted', '@d.Origin',@d.EmployeeId,@d.ToBranchId,@d.DocID)"></i>
                                                </td>
                                                <td hidden>@d.DocID</td>
                                                <td hidden>@d.DocID_Encrypted</td>
                                                @*<td style="width:10px">
                                                    <span class="d-flex justify-content-center">
                                                        <input type="checkbox" class="form-check-input" data-checked="email-checkbox" value="@d.DocID_Encrypted" id="tblCheckbox">
                                                    </span>
                                                </td>*@
                                               
                                                <td class="text-nowrap">@d.DocNo</td>
                                                <td class="text-nowrap">@d.DocDate</td>
                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                <td class="text-nowrap">@d.FromBranchName</td>
                                                <td class="text-nowrap">@d.ToBranchName</td>
                                                <td class="text-nowrap">@d.TransferOrderBY</td>
                                                <td class="text-nowrap">@d.Reason</td>
                                                <td class="text-nowrap">@d.PendingScience</td>
                                                
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="row mb-20px">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                @*<button type="button" class="btn btn-primary " id="btnAllApprove" onclick="AllApproveReject('Approved')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Approve
                                                </button>
                                                     
                                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" type="button" class="btn btn-danger" id="btnmodal-dialog1" value="Rejected">Reject</button>*@
                                             
                                                <button type="submit" id="btnManualUpload" onclick="location.href='@Url.Action("EmployeeTransferApprovedRejectedList", "ESS_EmployeeTransfer_ForApproval", new { area = "ESS" })'" class="btn btn-danger btn-sm">
                                                    Approved Rejected List
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>
<script>
    //function ApproveStatus() {
    //    $('#RequestInfoModal').modal('show');
    //}
    function ViewForApprover(DocID_Encrypted, Origin, EmployeeId, ToBranchId, DocID) {
        debugger
        if (Origin == 'Trans_BU') {
