@model KompassHR.Areas.ESS.Models.ESS_ManpowerAllocation.Manpower_IDELock

@{
    ViewBag.Title = "ESS_ManpowerAllocation_IDELock";
    Layout = "~/Views/Shared/_Layout.cshtml";
}





<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                IDE Lock
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ManpowerAllocation_Menu", "ESS_ManpowerAllocation_Menu",  new {id =35, ScreenId=278, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">IDE Lock- @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        IDE lock for mapping
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_ManpowerAllocation_IDELock", new { area = "ESS" })' id="SaveIDELock" method="post">
                                @Html.HiddenFor(model => model.IDE_Encrypted_Id, new { id = "txtIDE_Encrypted_Id" })
                                @Html.HiddenFor(model => model.IDEId, new { id = "txtIDEId" })

                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <div class="row mb-12px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"),"--Select--", new { @class = "form-select", type = "text", name = "CmpId", id = "ddlCmpId", onchange = "OnCompanyChange()" })
                                                    <span id="ErrorddlCompanyId" class="Error"></span>                                              
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <div class="row mb-12px">
                                            <label class="form-label col-form-label col-md-4">
                                                Buisness Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BUName, "Id", "Name"),"--Select--", new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                                    <span id="ErrorddlBranchId" class="Error"></span>                                                                                                
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <div class="row mb-12px">
                                            <label class="form-label col-form-label col-md-4">
                                                Month/Year
                                            </label>
                                            <div class="col-md-8">
                                                @if (ViewBag.AddUpdateTitle == "Add")
                                                {
                                                    @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", name = "MonthYear", type = "month", id = "txtMonthYear", Value = TempData["MonthYear"] })
                                                }
                                                @if (ViewBag.AddUpdateTitle == "Update")
                                                {
                                                    @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "month", id = "txtMonthYear", Value = TempData["MonthYear"], @readonly = "readonly" })
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "ESS_ManpowerAllocation_IDELock", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnDesignationGetList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
    debugger;
    if (Message != null) {
        if (Icon != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    // return false
                }
            }).then(function() {
                window.location.reload();
            });
        }
    }
</script>
<script>
    function OnCompanyChange() {
        debugger
        var CmpId = document.getElementById("ddlCmpId").value;

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetBuisnessUnit", "ESS_ManpowerAllocation_IDELock")',
            data: { CmpId: CmpId},
            success: function (data) {
                var $BusinessUnitDropdown = $("#ddlBranchId");
                $BusinessUnitDropdown.empty();

                if (data && data.length > 0) {
                    $BusinessUnitDropdown.append("<option value=''>--Select--</option>");
                    $.each(data, function (i, module) {
                        $BusinessUnitDropdown.append(
                            $("<option>").val(module.Id).text(module.Name)
                        );
                    });
                } else {
                    $BusinessUnitDropdown.append("<option>--Select--</option>");
                }
            },
            error: function () {
                console.error("Failed to fetch modules.");
                $("#ddlBranchId").empty().append("<option>Error loading modules</option>");
            }
        });
    }

    $(document).ready(function () {
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
    });
</script>



<script>
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveIDELock').validate({
        rules: {
            CmpId: {
                required: true,
            },
            MonthYear:{
                required: true,
            },

            BranchId: {
                required: true,
            },
        },
        messages: {
              CmpId: {
                  required: "Company Name is required",

              },
              MonthYear:{
                  required: "Month Year is required",
              },
              BranchId: {
                  required: "Business Unit name is required",
              },


        },
    });

    var form = $("#SaveIDELock");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if (form.valid() == false) {
            debugger
            return false;
        }
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var MonthYear = $("#txtMonthYear").val();
        var IDE_Encrypted_Id = $("#txtIDE_Encrypted_Id").val();
        var IDEId = $("#txtIDEId").val();

        $.ajax({
            type: "GET",
            url: '@Url.Action("IsLockExists", "ESS_ManpowerAllocation_IDELock")',            
            data: {
                CmpId: CmpId,BranchId:BranchId,
                IDE_Encrypted_Id: IDE_Encrypted_Id,
                IDEId: IDEId, MonthYear: MonthYear
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveIDELock").submit();
                }
            }
        });
    });
</script>