                                            @Html.HiddenFor(model => model.EmployeeId, new { id = "hdnEmployeeId" })

                                        </div>
                                        <div class="col-md-4">
                                            <a href="@Url.Action("SearchEmployee", "Ess_Tax_PanAdharUpdate", new { area = "ESS" })">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnSearch">
                                                    <i class="fa-solid fa-magnifying-glass"></i> Search
                                                </button>
                                            </a>
                                        </div>

                                    </div>
                                </div>
                                <div class="card shadow-sm rounded">
                                    <div class="card-header text-center bg-light">
                                        <h4 class="card-title">Employee Information</h4>
                                    </div>
                                    <div class="card-body p-1">
                                        <div class="row">
                                            <div class="col-12 col-md-12 mb-0">
                                                <div class="invoice-from">
                                                    @* <small class="text-muted d-block">From : </small>*@
                                                    <address class="custom-font">
                                                        <i class="fa-solid fa-user"></i>&nbsp;&nbsp;<span><strong>Employee Name : </strong><span id="EmployeeName" class="EmployeeName"></span> - <span id="EmployeeNo" class="EmployeeNo"> </span></span><br />
