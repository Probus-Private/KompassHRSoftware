    var form = $("#PanAadhaarUpdate");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var PAN =$("#txtPAN").val();
        var Aadhaar =$("#txtAadhaar").val();
        var EmployeeId = $("#hdnEmployeeId").val();
        $.ajax({
            url:'@Url.Action("IsPANAaddhaarExists", "Ess_Tax_PanAdharUpdate")',
            method:"get",
            data:{PAN:PAN,Aadhaar:Aadhaar,EmployeeId:EmployeeId},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#PanAadhaarUpdate").submit();

                }
            }
        });
    });
</script>

