                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Aadhaar No.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.AadhaarNo, new { @class = "form-control", type = "text", id = "txtAadhaar", autocomplete = "Off", name = "AadhaarNo", @disabled = "disabled", @maxlength = "12", oninput = "this.value = this.value.replace(/[^0-9]/g, '')" })
