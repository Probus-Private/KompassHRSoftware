                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.PAN, new { @class = "form-control", type = "text", id = "txtPAN", autocomplete = "Off", name = "PAN", @disabled = "disabled", onkeyup = "this.value = this.value.toUpperCase();" })
