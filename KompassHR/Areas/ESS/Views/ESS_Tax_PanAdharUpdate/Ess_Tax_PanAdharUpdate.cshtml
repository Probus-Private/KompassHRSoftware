                                                                    <i class="fa-solid fa-share-from-square"></i> List
                                                                </button>
                                                            </a>*@
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            @*<button type="button" class="btn btn-danger btn-sm" id="btnGetFNFList">
                                    <i class="fa-solid fa-share-from-square"></i> List
                                </button>*@
                        </div>

                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        $('#txtPAN').on('input', function () {
            // Convert input to uppercase
            this.value = this.value.toUpperCase();

            // PAN regex pattern
            var panPattern = /^[A-Z]{5}[0-9]{4}[A-Z]{1}$/;
            var panValue = this.value;

            if (panPattern.test(panValue)) {
                $('#panError').hide(); // Hide error if valid
            } else {
                $('#panError').show(); // Show error if invalid
            }
        });

        debugger;
        if (Message != null || Icon !=null ) {
            //swal("", AlreadyExist, "warning");
            if (Message != null) {
                Swal.fire({
                    //title: 'Saved',
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        //ask
    });
</script>
<script>
    $("#btnSearch").on("click", function (event) {
        event.preventDefault(); // Prevent form submission and page reload
        debugger;
        var EmployeeNo = $("#txtEmployeeNo").val();
        if(EmployeeNo==""){
            $('#ErrorEmployeeNo').text('Employee No is required').css('color', 'red').show();
        }
        else{
            $('#ErrorEmployeeNo').text('Employee No is required').css('color', 'red').hide();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("SearchEmployee", "Ess_Tax_PanAdharUpdate")',
                data: { EmployeeNo: EmployeeNo },
                success: function (data) {
                    const result = data[0].reduce((acc, item) => {
                        acc[item.Key] = item.Value;
                        return acc;
                    }, {});
                    debugger;
                    // Now 'result' contains the formatted object
                    console.log(result);
                    $("#hdnEmployeeId").val(result.EmployeeId);
                    $(".EmployeeNo").html(result.EmployeeNo);
                    $(".EmployeeName").html(result.EmployeeName);
                    $(".CompanyName").html(result.CompanyName);
                    $(".BranchName").html(result.BranchName);
                    $(".DepartmentName").html(result.DepartmentName);
                    $(".DesignationName").html(result.DesignationName);
                    $(".GradeName").html(GradeName);
                    $(".PAN").html(result.PAN);
                    $(".AadhaarNo").html(result.AadhaarNo);
                    $(".PANAadhaarLink").html(result.PANAadhaarLink);
                    $("#txtPAN").val(result.PAN);
                    $("#txtAadhaar").val(result.AadhaarNo);
                    $("#chkPANAadhaarLink").prop("checked", result.PANAadhaarLink);
                    $('#txtPAN').prop('disabled', false);
                    $('#txtAadhaar').prop('disabled', false);

                },
                error: function (xhr, status, error) {
                    console.log("Error: " + error);
                }
            });
        }

    });

</script>
<script>
    $("#formReset").click(function () {
        $("#PanAadhaarUpdate")[0].reset();
    })
</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#PanAadhaarUpdate").validate({
        rules: {
            EmployeeNo:
                {
                    required: true,
                },
            PAN: {
                required: true,

            },
            AadhaarNo:{
                required: true,
            }
        },
    messages: {
        EmployeeNo:
                {
                    required: "Employee No is required",
                },
            PAN: {
                required: "PAN No is required",

                },

            AadhaarNo:{
                required: "Aadhaar No is required",
            },
        }
    });
