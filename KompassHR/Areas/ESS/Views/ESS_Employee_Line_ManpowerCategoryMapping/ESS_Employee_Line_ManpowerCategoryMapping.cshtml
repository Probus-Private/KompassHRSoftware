<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Line and Manpower Category Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ManpowerAllocation_Menu", "ESS_ManpowerAllocation_Menu",  new { id = 35,ScreenId=278, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Line and Manpower Category Mapping - @ViewBag.AddUpdateTitle </h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the form of Line and Manpower Category Mapping .
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_Employee_Line_ManpowerCategoryMapping", "ESS_Employee_Line_ManpowerCategoryMapping", new { area = "ESS" })' id="formLineManpowercatmap" method="post">
                                

                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlCmpId", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlBranchId", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Second Row - Perfect Alignment -->
                                <div class="row align-items-end">
                                    <!-- Unit (under Company Name) -->
                                    @*<div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Sub Unit <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.UnitId, new SelectList(ViewBag.GetUnitName, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlUnitId", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>*@

                                    <!-- This column starts exactly where Business Unit starts -->
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Line <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.LineId, new SelectList(ViewBag.GetLine, "Id", "Name"), "--Select--", new { @class = "form-control", id = "ddlLineId" })
                                                <span id="ErrorLineId" class="Error"></span>
                                            </div>

                                            <!-- Show Button - right next to Line dropdown -->
                                            <div class="col-md-2 d-flex align-items-end pb-2">
                                                <button type="button" id="btnshow" onclick="ShowManpowerCategory()" class="btn btn-primary btn-sm w-100">
                                                    Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="table-responsive">
                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TablePageAccess">
                                                    <thead style="background-color: rgba(233, 236, 239, 1) !important; position: sticky; top: 0; z-index: 1;">
                                                        <tr class="trheading">
                                                            <th class="text-center" style="width:70px;"><label><input type="checkbox" class="allChecked" name="checkbox" id="AllCheckBox" value="value"><b>&nbsp; All</b></label></th>
                                                            <th class="text-nowrap" hidden> Manpower Category Id</th>
                                                            <th class="text-Left">Manpower Category</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblKPISubCategory" style="max-height: 250px; overflow-y: auto;">
                                                        @if (ViewBag.GetManpowerCategoryList != null)
                                                        {
                                                            foreach (var d in ViewBag.GetManpowerCategoryList)
                                                            {
                                                                <tr>
                                                                    <td class="text-center">
                                                                        @{
                                                                            var check = d.IsActive ? "checked" : "";
                                                                        }
                                                                        <input type="checkbox" id="chkIsActive_@d.KPISubCategoryId" @check style="cursor:pointer" />
                                                                    </td>
                                                                    <td hidden>@d.KPISubCategoryId</td>
                                                                    <td>@d.KPISubCategoryFName</td>
                                                                </tr>
                                                               }
                                                             }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                    Submit
                                                </button>
                                                <a href="@Url.Action("GetList", "ESS_Employee_Line_ManpowerCategoryMapping", new { area = "ESS" })">
                                                    <button type="button" class="btn btn-danger btn-sm" id="btnPunchMissingList">
                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlLineId").select2();
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlUnitId").select2();


        $('.TablePageAccess').DataTable({
            destroy: true,
            searching: true,
            paging: false,
            info: true,
            ordering: false,
            bFilter: true
        });

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_Employee_Line_ManpowerCategoryMapping")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlUnitId").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetSubUnit", "ESS_Employee_Line_ManpowerCategoryMapping")',
                data: { BranchId: BranchId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlUnitId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlUnitId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formLineManpowercatmap').validate({
        rules: {
            CmpId: {
                required: true,
            },
            Month: {
                required: true,
            },
            LineId:
                {
                    required: true,
                },
            BranchId: {
                required: true,
            }
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            Month: {
                required: "Month is required",
            },
            LineId: {
                required: "Line is required",
            },
            BranchId: {
                required: "Buisness Unit is required",
            },
        },
    });

    var form = $("#formLineManpowercatmap");
    form.validate();

    function ShowManpowerCategory() {debugger
        var LineId = $("#ddlLineId").val();
        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");

        $("#formLineManpowercatmap").submit();
    }
</script>

<script>
    $("#AllCheckBox").on("click", function () {
        debugger;
        var isChecked = $(this).prop('checked');
        $("#tblKPISubCategory tr").each(function () {
            $(this).find("input").prop('checked', isChecked);
        });
    });

    $("#btnSubmit").click(function () {
        debugger

        var rowCount = $('#tblKPISubCategory tr').length;
        if (rowCount === 0) {
            Swal.fire({
                icon: 'warning',
                text: 'Please add at least one manpower category to the list!',
                allowOutsideClick: false
            });
            return false;
        }
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();

        $(".Userloaderbg").css("display", "flex");
        var table = document.getElementById("tblKPISubCategory");
        var LineId = $("#ddlLineId").val();


        var rowCount = table.rows.length;
        var LineManpowerCategoryMap = [];

        for (var i = 0; i < rowCount; i++) {
            debugger
            var data = {};
            var checkbox = table.rows[i].cells[0].children[0]; // Get the checkbox in the first cell
            //if (checkbox.checked) {  // Only collect data if the checkbox is checked
                data.LineId = LineId;
                data.IsActive = checkbox.checked;
                data.KPISubCategoryId = table.rows[i].cells[1].innerHTML;
                LineManpowerCategoryMap.push(data);
            //}
        }

        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpadte", "ESS_Employee_Line_ManpowerCategoryMapping")',
            //url: "SaveUpadte",
            data: JSON.stringify({ LineManpowerCategoryMap: LineManpowerCategoryMap, LineId: LineId, CmpId: CmpId, BranchId: BranchId }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then(function () {
                            var url = '@Url.Action("ESS_Employee_Line_ManpowerCategoryMapping", "ESS_Employee_Line_ManpowerCategoryMapping")';
                            window.location.href = url;
                        })
                    }
                }
            }
        });
    });
</script>
