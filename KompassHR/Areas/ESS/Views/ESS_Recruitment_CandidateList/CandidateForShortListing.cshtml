@model KompassHR.Areas.ESS.Models.ESS_Recruitment.Recruitment_Resume
@{
    ViewBag.Title = "CandidateForShortListing";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var Item = ViewBag.GetCandidateForShortList;
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .note-toolbar {
        display: none;
    }

    .note-editable {
        height: 100% !important;
        [contenteditable="false"];
    }

    .table, tr, td, th, .invoice, .smallFrom {
        border: none;
        font-size: 13px;
        font-family: Arial;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Candidate Details
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <hr />

    <div class="invoice">
        <!-- BEGIN invoice-company -->
        <div class="invoice-company">

            @if (Item.ResumeStatus == "Rejected")
            {
                <span class="float-end hidden-print">
                    <button type="button" class="btn  btn-primary" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>

                    <button href="#modal-dialogForHoldReject1" onclick="OpenModule('ShortListed')" type="button" class="btn btn-success" id="btnmodal-dialog1" value="Rejected">Shortlist</button>
                </span>
            }
            else if (Item.ResumeStatus == "Pending")
            {
                <span class="float-end hidden-print">
                    <button type="button" class="btn  btn-primary btn-sm" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>

                    <button type="button" class="btn btn-success btn-sm" id="btnCandidateManualUpload" @*onclick="CandidateShortList()"*@ onclick="OpenModule('ShortListed')"><i class="fa-solid fa-check-double"></i>ShortList</button>
                    <button href="#modal-dialogForHoldReject1" onclick="OpenModule('Rejected')" type="button" class="btn btn-danger btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>
                </span>
            }
            else if (Item.ResumeStatus == "ShortListed")
            {
                <span class="float-end hidden-print">
                    <button type="button" class="btn  btn-primary" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>
                    <button href="#modal-dialogForHoldReject1" onclick="OpenModule('Rejected')" type="button" class="btn btn-danger" id="btnmodal-dialog1" value="Rejected">Reject</button>
                </span>
            }
            Recruitment for @Item.designationname
            @Html.HiddenFor(model => model.ResumeId_Encrypted, new { id = "txtResumeId_Encrypted" })
            @Html.HiddenFor(model => model.ResumeId, new { id = "txtResumeId" })
        </div>
        <!-- END invoice-company -->

        <form class="form">
            <div class="card">
                <div id="card">
                    <div class="invoice-header">
                        <div class="invoice-from">
                            <address class="mt-5px mb-5px">
                                <i class="fa-solid fa-user"> </i>&nbsp;&nbsp;     <strong class="text-dark">@Item.CandidateName</strong><br />
                                <i class="fa-solid fa-phone-volume"> </i>&nbsp;&nbsp;    <b>Phone:</b> +91-@Item.MobileNo <br />
                                <i class="fa-solid fa-envelope"> </i>&nbsp;&nbsp;<b>Email:</b>&nbsp;  @Item.EmailId
                            </address>
                        </div>
                        <div class="invoice-to">
                            <small>   </small>
                            <br />
                            <address class="mt-5px mb-5px">
                                <i class="fa-solid fa-building"> </i>&nbsp;&nbsp; &nbsp; <b> Current Organization:</b>&nbsp; @Item.LastCompanyName<br />
                                <i class="fa-regular fa-handshake"> </i>&nbsp;&nbsp;  <b>  Current Designation: </b>&nbsp; @Item.LastDesignation<br />
                                <i class="fa-solid fa-info"></i> &nbsp;&nbsp; &nbsp; <b>Experience:</b> &nbsp;@Item.TotalExperience<br />
                            </address>
                        </div>

                        <div class="invoice-date">
                            <small> </small>
                            <br />
                            <div class="date text-dark mt-5px"></div>
                            <div class="invoice-detail">
                                <i class="fa-solid fa-calendar-days"></i> <b> Notice Period (Days): </b>@Item.NoticePeriodDays<br />
                            </div>
                        </div>
                    </div>
                    <!-- END invoice-header -->
                    <!-- BEGIN invoice-content -->
                    <div class="invoice-content">
                        <!-- BEGIN table-responsive -->
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table ">
                                    <tbody>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Current CTC</span><br />
                                            </th>
                                            <td>@Item.CTC</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Gender</span><br />
                                            </th>
                                            <td>@Item.Gender</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Current City</span><br />
                                            </th>
                                            <td>@Item.CurrentCity</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Nationality</span><br />
                                            </th>
                                            <td>@Item.Nationality</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Qualification Type</span><br />
                                            </th>
                                            <td>@Item.CandidateType</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Technical Skill</span><br />
                                            </th>
                                            <td>@Item.TechnicalDetails </td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">HR Notes</span><br />
                                            </th>
                                            <td>@Item.HRComment </td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(Item.ResumePath))
                                        {
                                            <tr>
                                                <td><strong>Resume File</strong></td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(Item.ResumePath))
                                                    {
                                                        <a href="@Url.Action("DownloadFile", "ESS_Recruitment_CandidateList", new { filePath = Item.ResumeFullPath })" class="btn btn-link p-0 m-0">
                                                            <i class="fa fa-download"></i> Download
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }



                                    </tbody>
                                </table>
                            </div>

                            <div class="col-md-6">
                                <table class="table ">
                                    <tbody>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Expected CTC</span><br />
                                            </th>
                                            <td>@Item.ExpectedCTC</td>

                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Marital Status </span><br />
                                            </th>
                                            <td>@Item.MaritalStatus</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Ready to Travel</span><br />
                                            </th>
                                            <td>@Item.ReadyToTraval</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Age</span><br />
                                            </th>
                                            <td>@Item.Age</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Highest Qualification</span><br />
                                            </th>
                                            <td>@Item.HighestQualification</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Communication Skill</span><br />
                                            </th>
                                            <td>@Item.CommunicationSkill</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Candidate Comment</span><br />
                                            </th>
                                            <td>@Item.CandidateComment</td>
                                        </tr>

                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <hr />
                        @if (ViewBag.ApprovalRemarkList.Count != 0)
                        {
                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine"
                                   style="width: 100%;">
                                <thead>
                                    <tr class="trheading">
                                        <th class="text-nowrap">Approved By</th>
                                        <th class="text-nowrap">Remark</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.ApprovalRemarkList)
                                    {
                                        <tr>
                                            <td class="text-nowrap">@d.EmployeeName</td>
                                            <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                    </div>
                    <!-- END invoice-content -->
                </div>
            </div>
        </form>
    </div>
</div>


<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark</h4>

            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" onclick="Approved()" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btn-sm btnpress CloseModel" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }

        var List = @Html.Raw(Json.Encode(Item));
        debugger;
        var Encrypted=List[0][1].Value;
        var id=List[0][0].Value;
        $("#txtResumeId_Encrypted").val(Encrypted);
        $("#txtResumeId").val(id);

    });

    function CandidateShortList(){
        debugger;
        var ResumeId_Encrypted = $("#txtResumeId_Encrypted").val();
        var url = '@Url.Action("CandidateShortListed", "ESS_Recruitment_CandidateList")?ResumeId_Encrypted=' + ResumeId_Encrypted;
        window.location.href = url;
    }


    function printDiv() {

        //Get the HTML of div
        var divElements = document.getElementById('card').innerHTML;
        //Get the HTML of whole page
        var oldPage = document.body.innerHTML;

        //Reset the page's HTML with div's HTML only
        document.body.innerHTML =
          "<html><head></head><body>    " +
        divElements + "    </body>";

        //Print Page
        window.print();

        //Restore orignal HTML
        document.body.innerHTML = oldPage;
    }
</script>

<script>
    $(document).on('click', '#btnCancel', function () {
        $('#txtApproveRejectRemark').val('');
    });

    var StatusMark="";
    function OpenModule(ShortListed)
    {
        debugger;
        StatusMark=ShortListed;
        $("#myModalFinal").modal('show');
    }

    function Approved()
    {
        debugger
        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;

                var DocId=$("#txtResourceId").val();
                var ResumeId_Encrypted = $("#txtResumeId_Encrypted").val();
                var Status="";
                var Remark="";
                if(StatusMark=="Rejected")
                {
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="Rejected";

                }
                else if(StatusMark=="ShortListed"){
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="ShortListed";
                }

                $(".Userloaderbg").css("display", "flex");
                $("#myModalFinal").modal('hide');
                $.ajax({
                    url: "@Url.Action("CandidateShortListed", "ESS_Recruitment_CandidateList")",
                    method:"get",
                    data:{ResumeId_Encrypted:ResumeId_Encrypted,Status:Status,Remark:Remark},
                    success:function(response){
                        debugger;
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon=="error") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    });

                                    $("#myModalFinal").modal('hide');
                                    $("#txtApproveRejectRemark").val("")
                                    .then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("ESS_Recruitment_CandidateList", "ESS_Recruitment_CandidateList")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })
                                }
                            }
                        }
                        else{
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (response.Icon=="success") {
                                if (Message1 != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        })
                                        .then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("ESS_Recruitment_CandidateList", "ESS_Recruitment_CandidateList")';
                                            } else if (
                                                /* Read more about handling dismissals below */
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {

                                            }
                                        })
                                        $("#myModalFinal").modal('hide');
                                        $("#txtApproveRejectRemark").val("");
                                    }
                                }
                            }
                        }
                    }
                });
            }
        })
    }
</script>