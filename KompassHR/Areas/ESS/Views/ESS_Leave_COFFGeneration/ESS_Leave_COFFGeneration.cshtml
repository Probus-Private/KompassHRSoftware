<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                COFF Generation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> COFF Generation - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Leave_COFFGeneration", new { area = "ESS" })' id="SaveCOFFGeneration" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @id = "txtDocNo", name = "DocNo", @class = "form-control", autocomplete = "off", Value = @ViewBag.DocNo.DocNo, Style = "background-color: lightgray;", @readonly = "readonly" })
                                                @Html.HiddenFor(model => model.CoffGenerationID_Encrypted, new { id = "CoffGenerationID_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @id = "txtDocDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date", Style = "background-color: lightgray;", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @id = "ddlCompanyName", name = "CmpID", @class = "form-select" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CoffGenerationBranchID, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @id = "txtBranchId", name = "CoffGenerationBranchID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CoffGenerationEmployeeID, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { @id = "ddlCoffGenerationEmployeeID", name = "CoffGenerationEmployeeID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Days
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Approvenoofcoff, new SelectList(ViewBag.GetCOFFGenerationDay, "Name", "Name"), "--Select--", new { @id = "ddlCoffGenerationDays", name = "CoffGenerationDays", @class = "form-select", autocomplete = "off" })
                                                @*@Html.DropDownListFor(model => model.CoffGenerationDays, new List<SelectListItem>{ new SelectListItem {Text ="0.5", Value="0.5"},
                                                     new SelectListItem {Text ="1", Value="1"},
                                                     new SelectListItem {Text ="1.5", Value="1.5"},
                                                     new SelectListItem {Text ="2", Value="2"}
                                                    }, "--Select--", new { @class = "form-select", name = "CoffGenerationDays", @id = "ddlCoffGenerationDays" })*@

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Coff Generation Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CoffGenerationDate, new { @id = "txtCoffGenerationDate", name = "CoffGenerationDate", @class = "form-control", type = "date" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Remark
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.Reason, new { @id = "txtReason", name = "Reason", @class = "form-control", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr id="DivHrRow" />
                                <div class="row" id="DivHiddenRow1">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Coff Exprired Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CoffExpriredDate, new { @id = "txtCoffExpriredDate", name = "CoffExpriredDate", @class = "form-control", type = "date" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row" id="DivHiddenRow2">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Extension Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ExtensionDate, new { @id = "txtExtensionDate", name = "ExtensionDate", @class = "form-control", type = "date" , onkeydown = "return false;" })
                                                @Html.ValidationMessageFor(model => model.ExtensionDate, "", new { @class = "help-block", @id = "ErrorExtensionDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Extension Remark
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.ExtensionRemark, new { @id = "txtExtensionRemark", name = "ExtensionRemark", @class = "form-control", autocomplete = "off" })
                                                @Html.ValidationMessageFor(model => model.ExtensionRemark, "", new { @class = "help-block", @id = "ErrorExtensionRemark", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>

    $("#btnGetList").click(function () {
        debugger;
        var url = '@Url.Action("GetList", "ESS_Leave_COFFGeneration")';
        window.location.href = url;
    });

    $(document).ready(function () {
        $("#DivHiddenRow1").hide();
        $("#DivHiddenRow2").hide();
        $("#DivHrRow").hide();
        $("#ddlCompanyName").select2();
        $("#txtBranchId").select2();
        $("#ddlCoffGenerationEmployeeID").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $("#ddlCompanyName").change(function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_Leave_COFFGeneration")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#txtBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });

        $("#txtBranchId").change(function () {
            debugger;
            $("#ddlCoffGenerationEmployeeID").find("option").remove();
            $("#ddlCoffGenerationDays").find("option").remove();
            var Buninessunit = $("#txtBranchId").val();
            var companyId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "ESS_Leave_COFFGeneration")',
                data: { Buninessunit: Buninessunit, companyId: companyId },
                success: function (data) {
                    debugger;
                    var GetEmployee1= data.GetEmployee;
                    var GetCOFFGenerationDay1= data.GetCOFFGenerationDay;
                    if (GetEmployee1 != null) {
                        $("#ddlCoffGenerationEmployeeID").append("<option value=''>--Select-- </option>");
                        $.each(GetEmployee1, function (i, p) {
                            $("#ddlCoffGenerationEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    if (GetCOFFGenerationDay1 != null) {
                        $("#ddlCoffGenerationDays").append("<option value=''>--Select-- </option>");
                        $.each(GetCOFFGenerationDay1, function (i, p) {
                            $("#ddlCoffGenerationDays").append("<option value='" + p.Name + "'>" + p.Name + "</option>");
                        });
                    }
                }
            });

        });



        var AddUpdateTitle = @Html.Raw(Json.Encode(ViewBag.AddUpdateTitle));
        if (AddUpdateTitle=="Update")
        {
            debugger;
            $("#DivHiddenRow1").show();
            $("#DivHiddenRow2").show();
            $("#DivHrRow").show();
            $("#txtCoffExpriredDate").attr("disabled","disabled");
            $("#txtBranchId").attr("disabled","disabled");
            $("#ddlCoffGenerationEmployeeID").attr("disabled","disabled");
            $("#ddlCoffGenerationDays").attr("disabled","disabled");
            $("#ddlCompanyName").attr("disabled","disabled");
            $("#txtReason").attr("disabled","disabled");
            $("#txtCoffGenerationDate").attr("disabled","disabled");
            @*var ExtensionDate = @Html.Raw(Json.Encode(TempData["ExtensionDate"]));
            $("#txtExtensionDate").val(ExtensionDate);*@
            var date = new Date();
            var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
            $("#txtExtensionDate").val(dateString);

        }

        $("#txtExtensionDate").change(function () {
            debugger;

            var ExtensionDate = new Date($('#txtExtensionDate').val());
            var CoffExpriredDate = new Date($('#txtCoffExpriredDate').val());
            if (ExtensionDate <= CoffExpriredDate) {
                var Message="The 'Extension Date' cannot be earlier than the 'Coff Exprired Date'.";
                var Icon="error";
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $("#txtExtensionDate").val(null);
                    }
                })
            }
        });

        var DocDate = @Html.Raw(Json.Encode(TempData["DocDate"]));
        var CoffGenerationDate = @Html.Raw(Json.Encode(TempData["CoffGenerationDate"]));
        var CoffExpriredDate = @Html.Raw(Json.Encode(TempData["CoffExpriredDate"]));
        $("#txtCoffExpriredDate").val(CoffExpriredDate);
        if(CoffGenerationDate =="" || CoffGenerationDate ==null || DocDate==""|| DocDate==null)
        {
            var date = new Date();
            var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
            $("#txtDocDate").val(dateString);
            $("#txtCoffGenerationDate").val(dateString);
        }
        else
        {
            var GetCoffGenerationDate =  convertDate(CoffGenerationDate);
            $("#txtCoffGenerationDate").val(GetCoffGenerationDate);

            var GetDocDate =  convertDate(DocDate);
            $("#txtDocDate").val(GetDocDate);
        }
    });//ready function


    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveCOFFGeneration').validate({
        rules: {
            DocDate: {
                required: true,
            },
            CmpID: {
                required: true,
            },
            CoffGenerationBranchID: {
                required:true,
            },
            CoffGenerationEmployeeID: {
                required:true,
            },
            CoffGenerationDays:{
                required:true,
            },
            CoffGenerationDate: {
                required:true,
            },
            Reason: {
                required:true,
            }
        },
        messages: {
            DocDate: {
                required:"Doc Date is required",
            },
            CmpID: {
                required:"Comapny name is required",
            },
            CoffGenerationBranchID: {
                required:"Buniess Unit is required",
            },
            CoffGenerationEmployeeID: {
                required:"Employee Name is required"
            },
            CoffGenerationDays: {
                required:"Days is required",
            },
            CoffGenerationDate: {
                regex:"CoffGeneration date is required"
            },
            Reason: {
                required:"Remark is required"
            }

        },
    });

    var form = $("#SaveCOFFGeneration");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtEstablishedDate").removeClass("error");
            return false;
        }
        var CoffGenerationDate=$("#txtCoffGenerationDate").val();
        var CoffGenerationIDEncrypted =$("#CoffGenerationID_Encrypted").val();
        var CoffGenerationEmployeeID =$("#ddlCoffGenerationEmployeeID").val();
        if (CoffGenerationIDEncrypted!="")
        {
            var ExtensionDate=$("#txtExtensionDate").val();
            var ExtensionRemark =$("#txtExtensionRemark").val();
            if (ExtensionDate=="")
            {
                $("#ErrorExtensionDate").html("Extension date is required");return false;
            }else{$("#ErrorExtensionDate").html("");}
            if (ExtensionRemark=="")
            {
                $("#ErrorExtensionRemark").html("Extension remark is required");return false;
            }else{$("#ErrorExtensionRemark").html("");}
        }

        $.ajax({
            url: '@Url.Action("CoffGenerationExists", "ESS_Leave_COFFGeneration")',
            method:"get",
            data:{CoffGenerationDate:CoffGenerationDate,CoffGenerationIDEncrypted:CoffGenerationIDEncrypted,CoffGenerationEmployeeID:CoffGenerationEmployeeID},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveCOFFGeneration").submit();
                }
            }
        });

    });


</script>

<script>

    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>