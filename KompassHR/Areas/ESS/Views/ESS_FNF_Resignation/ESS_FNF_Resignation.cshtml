                                             </div>
                                        </div>
                                    </div>

                                </div>


                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="col-md-2"></label>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsImmediatelyRelieve)
                                                &nbsp;  <label class="form-check-label form-label">Does the Company Permit Immediate Relieving</label>
                                            </div>
                                            <div class="col-md-4">
                                                @Html.CheckBoxFor(model => model.IsNoticePeriodPurchase)
                                                &nbsp;  <label class="form-check-label form-label">Is There an Option to Buy Out the Notice Period</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="row">
                                        <label class="form-label col-form-label col-md-4">
                                            Attachment
                                        </label>
                                        <div class="col-md-8">
                                            <input class="form-control" type="file" name="AssignFilePath" />
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Remark
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        @Html.TextAreaFor(model => model.Remark, new { @class = "summernote", style = "border: 1px solid #000;", id = "Remark", @required = "required", autocomplete = "Off", contenteditable = "true" })
                                    </div>
                                </div>
                                <hr />
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            For Future Communication Details
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Mobile Numer
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PrimaryMobile, new { @class = "form-control", name = "MobileNumer", type = "text", id = "txtMobileNumer", autocomplete = "Off", maxlength = "10", pattern = "\\d{10}", oninput = "this.value = this.value.replace(/[^0-9]/g, '')" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                E-Mail ID
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PersonalEmailId, new { @class = "form-control", name = "MailID", type = "email", id = "txtMailID", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Address
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.FullAddress, new { @class = "form-control", name = "Address", id = "txtAddress", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <br />
                                <div class="row" hidden>
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div class="col-md-12">
                                                @Html.CheckBoxFor(model => model.AcceptTerms, new { @id = "ChkacceptTerms" })
                                                @*@Html.CheckBoxFor(model => model.AcceptTerms)*@
                                                &nbsp;  <label class="form-check-label form-label">I agree to the terms and conditions.</label><a href="#" id="readMoreLink" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#readMoreModal">Read More</a>
                                                <br /><span id="ErrorChkacceptTerms" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row" align="right">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "ESS_FNF_Resignation", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetResignationList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="readMoreModal" tabindex="-1" aria-labelledby="readMoreModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
