<script>
    $(document).ready(function() {
        debugger;
        $("#FnfReasonId").select2();
        var FnfEmpolyeeDetails = @Html.Raw(Json.Encode(ViewBag.EmployeeDetails));

        //$("#dateLastWorkingDate")

        var LastWorkingDate = @Html.Raw(Json.Encode(TempData["LastWorkingDate"] ?? ""));
        $("#dateLastWorkingDate").val(LastWorkingDate);
        $('#readMoreModal').on('shown.bs.modal', function () {
            debugger;
            var rawContent ='@Html.Raw(ViewBag.TermAndConditionName?.TermsAndConditionName ?? "")'
            if(rawContent!="")
            {
                $('#termsEditor').html(rawContent);
            }
            $('#termsEditor').summernote('disable');
        });

        $("#dateLastWorkingDate").on("change", function () {debugger;
            let lastWorking = new Date($(this).val());
            let resignation = new Date($("#dateResignationDate").val());
            let noticeEnd = new Date($("#hdnNoticePeriodEndDate").val());
            $("#errLastWorkingDate").text("");
            if ($(this).val() === "") {
                return;
            }
            // Validation 1: Last working date should NOT be greater than notice period end date
            if (lastWorking > noticeEnd) {debugger
                $("#errLastWorkingDate").text("Last working date cannot be greater than notice period end date.");
                return;
            }
            // Validation 2: Last working date should NOT be less than resignation date
            if (lastWorking < resignation) {debugger
                $("#errLastWorkingDate").text("Last working date cannot be less than resignation date.");
                return;
            }
        });

    });
</script>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null)     if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $("#myModal").modal('show');

                    } else if (
                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                    }
                })
            }
        }

        $("#formReset").click(function () {
            $("#SaveResignation")[0].reset()
        });
    });
</script>

<script>

    $("#SaveResignation").validate({
        rules: {
            FnfEmployeeId: {
                required: true,
            },
            ResignationDate: {
                required: true,
            },
            FnfReasonId: {
                required: true,
            },
            LastWorkingDate :
                {
                    required:true,
                },
            //AcceptTerms:
            //    {
            //        required:true,
            //    },
        },
        messages: {

            FnfEmployeeId: {
                required: "Please select the Employee Name",
            },
            ResignationDate: {
                required: "Resignation date is required",
            },
            FnfReasonId: {
                required: "Please Select the reason",
            },
            LastWorkingDate:{
                required:"Actual Last Working Date is required",
            },
            //AcceptTerms:{
            //    required:"Select Terms And Conditions",
            //},
        },
        errorPlacement: function (error, element) {
            if (element.attr("id") === "acceptTerms") {
                error.insertAfter(element.next("label")); // Place error message below the checkbox
            } else {
                error.insertAfter(element); // Default placement for other fields
            }
        }

    });


    var form = $("#SaveResignation");
    form.validate();

    $("#btnSubmit").click(function () {
        // function SaveResignation() {
        //var isChecked = $("#ChkacceptTerms").prop('checked');
        //if (!isChecked) {
        //    $("#ErrorChkacceptTerms").html("You must accept the terms.");
        //    return false;
        //} else {
        //    $("#ErrorChkacceptTerms").html("");
        //}
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#dateResignationDate").removeClass('error');
            return false;
        }
        var FnfIDEncrypted=$("#FnfID_Encrypted").val();
        $.ajax({
            url: '@Url.Action("IsFnfResignationExists", "ESS_FNF_Resignation")',
            method:"get",
            data:{FnfIDEncrypted:FnfIDEncrypted},
            success:function(response){
                debugger;
                $(".Userloaderbg").css("display", "none");
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $(".Userloaderbg").css("display", "flex");
                    $("#SaveResignation").submit();
                    //   SendMail();

                }
            }
        });
        //}
    });
</script>
<script>
    $(".summernote").summernote({
        placeholder: 'Enter your Remark here...',
        height: 300,
        toolbar: [
            ['style', ['bold', 'italic', 'underline', 'clear']],
            ['para', ['ul', 'ol', 'paragraph']],
            ['view', ['fullscreen']]
        ]
    });

    $(document).ready(function() {
        $(".Userloaderbg").css("display", "none");
        $('#readMoreModal').on('shown.bs.modal', function () {
            $('#termsEditor').summernote({
                height: 200, // Set editor height
                toolbar: false, // Disable the toolbar for read-only view
                disableDragAndDrop: true, // Disable dragging
                codeviewFilter: false,
                codeviewIframeFilter: true
            });

            // Set Summernote content as read-only
            $('#termsEditor').summernote('disable');
        });
    });

</script>

