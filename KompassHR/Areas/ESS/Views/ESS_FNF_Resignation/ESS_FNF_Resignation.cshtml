                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i> Notice Period End Date : @ViewBag.EmployeeDetails.NoticePeriodEndDate </h6>
                                                @Html.HiddenFor(model => model.NoticePeriodEndDate, new { id = "hdnNoticePeriodEndDate" })
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Resignation
                                        </div>
                                    </div>
                                </div>
