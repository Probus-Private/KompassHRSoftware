                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Reason <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.FnfReasonId, new SelectList(ViewBag.GetReasonName, "ReasonId", "ReasonName"), "--Select--", new { id = "FnfReasonId", @class = "form-select", autocomplete = "off", name = "Reason" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Resignation Date <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ResignationDate, new { @class = "form-control", type = "date", id = "dateResignationDate", autocomplete = "off" , Value = today , min = today, max = today })
                                            </div>
                                        </div>
                                    </div>


                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Actual Last Working Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LastWorkingDate, new { @class = "form-control", name = "LastWorkingDate", type = "date", id = "dateLastWorkingDate" })
