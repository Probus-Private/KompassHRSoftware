@model KompassHR.Areas.ESS.Models.ESS_FNF.FNF_EmployeeResignation
@using System.Text.RegularExpressions

@{
    ViewBag.Title = "ESS_FNF_Resignation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var a = ViewBag.EmployeeDetails;
    string today = DateTime.Now.ToString("yyyy-MM-dd");
