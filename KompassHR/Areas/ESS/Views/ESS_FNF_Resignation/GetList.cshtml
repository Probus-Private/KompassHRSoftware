<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>

    function Delete(FnfId) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_FNF_Resignation")?FnfId=' + FnfId;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>

<script>
    function ShowResignationHistory() {
        $.ajax({
            url: '@Url.Action("GetResignationHistory", "ESS_FNF_Resignation")',
            method: "GET",
            success: function (data) {
                const jsonData = JSON.parse(data);
                $('#EmployeeListModel').modal('show');
                $('#EmployeeListTitle').text('Resigned Employee History'); // Set the modal title
                $("#tbodyEmployeeList").empty();
                $.each(jsonData, function (index, item) {debugger;
                    var row = `<tr>
                                <td class="text-center">${item.SN}</td>
                                <td class="text-left">${item.EmployeeName}</td>
                                <td class="text-left">${item.DepartmentName}</td>
                                <td class="text-left">${item.DesignationName}</td>
                                <td class="text-left">${item.GradeName}</td>
                                <td class="text-left">${item.DOJ}</td>
                                <td class="text-left">${item.ResignationDate}</td>
                                <td class="text-left">${item.RelievingDate}</td>
                                <td class="text-left">${item.ReasonName}</td>
                                <td class="text-left">${item.Status}</td>
                                <td class="text-left">${item.RevokeDate}</td>
                           </tr>`;
                    $("#tbodyEmployeeList").append(row);
                });
            }
        });
    }
</script>


