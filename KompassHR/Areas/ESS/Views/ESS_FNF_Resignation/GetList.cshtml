.status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 12px; /* rounded corners */
    font-weight: 600;
    white-space: nowrap;
}

.status-approved-bg {
    background-color: #d4edda;
    color: #155724;
}

.status-pending-bg {
    background-color: #fff3cd; /* light yellow */
    color: #856404;           /* dark yellow */
}

.status-reject-bg {
    background-color: #f8d7da;
    color: #721c24;
