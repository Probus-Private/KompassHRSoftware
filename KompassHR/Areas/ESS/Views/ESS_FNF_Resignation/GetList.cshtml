@model KompassHR.Areas.ESS.Models.ESS_FNF.FNF_EmployeeResignation

@{
    // var action = (ViewBag.AddRevoke.Add_Revoke as string)?.Trim();

    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
    // var action = (ViewBag.AddRevoke as string)?.Trim();
}

<style>
    /* Improved Typography */
    body {
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        color: #333;
        line-height: 1.5;
    }

    /* Timeline Container */
    .timeline-container {
        max-width: 800px;
        margin: 0 auto;
        position: relative;
        padding-left: 67px;
    }

        .timeline-container::before {
            content: '';
            position: absolute;
            left: 30px;
            top: 0;
            bottom: 0;
            width: 5px;
            background: black;
        }

    /* Timeline Items */
    .timeline-item {
        position: relative;
        margin-bottom: 30px;
    }

    .timeline-header {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

    .timeline-badge {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        position: absolute;
        left: -60px;
        font-size: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .timeline-title {
        font-weight: 600;
        font-size: 1.2rem;
        color: #4b8dc9;
        margin-left: 9px;
        font-family: 'Roboto', sans-serif;
    }

    .timeline-content {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        border: 1px solid rgba(0, 0, 0, 0.125);
    }

    /* Detail Rows */
    .detail-row {
        display: flex;
        margin-bottom: 12px;
        align-items: baseline;
    }

    .detail-label {
        font-weight: 600;
        color: #555;
        min-width: 160px;
        font-size: 0.95rem;
        width: 250px;
    }

    .detail-value {
        color: #333;
        font-size: 0.95rem;
        font-weight: 500;
    }

    /* Status Badges */
    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

        .status-badge.Approved {
            background: #e6f7ed;
            color: #0a5c36;
            border: 1px solid #b1e6cb;
        }

        .status-badge.Pending {
            background: #fff8e6;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        .status-badge.Rejected {
            background: #fde8e8;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

    /* History Button */
    .history-btn {
        background: #ffc107;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        color: #333;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        font-weight: 600;
        font-size: 0.95rem;
    }

        .history-btn:hover {
            background: #e0a800;
            transform: translateY(-1px);
        }

        .history-btn i {
            font-size: 1.1rem;
        }

    /* Color Classes */
    .bg-danger {
        background: #dc3545;
    }

    .bg-info {
        background: #17a2b8;
    }

    .bg-warning {
        background: #ffc107;
        color: #333;
    }

    /* Modal Styling */
    #RequestInfoModal .modal-content {
        border-radius: 10px;
    }

    #RequestInfoModal .modal-body {
        padding: 25px;
    }

    /* Timeline in Modal */
    #timelineMainDiv .timeline-item {
        margin-bottom: 20px;
        display: flex;
        align-items: flex-start;
    }

    #timelineMainDiv .iconGreen,
    #timelineMainDiv .iconRed,
    #timelineMainDiv .iconBlue,
    #timelineMainDiv .iconYellow {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
        flex-shrink: 0;
        font-size: 16px;
    }

    #timelineMainDiv .iconGreen {
        background-color: #d4edda;
        color: #155724;
    }

    #timelineMainDiv .iconRed {
        background-color: #f8d7da;
        color: #721c24;
    }

    #timelineMainDiv .iconBlue {
        background-color: #cce5ff;
        color: #004085;
    }

    #timelineMainDiv .iconYellow {
        background-color: #fff3cd;
        color: #856404;
    }

    #timelineMainDiv .text {
        flex-grow: 1;
    }

    #timelineMainDiv .timelineRemark {
        margin-bottom: 5px;
        font-weight: 500;
        font-size: 0.95rem;
    }

    #timelineMainDiv small {
        color: #6c757d;
        font-size: 0.85rem;
        display: block;
        margin-bottom: 3px;
    }

    .text-red {
        color: red;
    }

    .text-green {
        color: green;
    }
</style>

<!-- Add this to your head section -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

