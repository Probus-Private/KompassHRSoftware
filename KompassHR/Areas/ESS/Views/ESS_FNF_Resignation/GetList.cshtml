<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Resignation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Resignation Status</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        View resignation status here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-6">
                            @if (ViewBag.AddRevoke == "Add")
                            {
                                <a class="btn btn-primary btn-sm mb-10px" href="@Url.Action("ESS_FNF_Resignation", "ESS_FNF_Resignation", new { area = "ESS" })">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </a>
                            }
                           @if (ViewBag.AddRevoke == "Revoke" && !(ViewBag.ResignationDetails?.LatestStatus?.Contains("Approved") ?? false))
                           {
                            <a class="btn btn-danger btn-sm mb-10px" href="@Url.Action("Delete", "ESS_FNF_Resignation", new { area = "ESS" })">
                                <i class="fa-solid fa-trash-alt fa-lg" style="color:white"></i> &nbsp; Revoke
                            </a>
                           }

                        </div>
                        <div class="col-md-6 text-end">
                            <button type="button" class="btn btn-info btn-sm mb-10px" onclick="ShowResignationHistory(@(ViewBag.ResignationApprovalList?.EmployeeId ?? "0"))">
                                <i class="fas fa-sitemap"></i> &nbsp; History
                            </button>
                        </div>
                    </div>
                </div>


                @*THIS CODE FOR TIMELINE*@

                <div class="profile-content" style="padding:1px;">
                    <div class="tab-content p-0">
                        <div class="tab-pane fade show active" id="profile-post">

                            <div class="timeline-container">
                                <!-- Resignation Section -->
                                <div class="timeline-item">
                                    <div class="timeline-header">
                                        <div class="timeline-badge bg-danger">
                                            <i class="fas fa-file-signature"></i>
                                        </div>
                                        <div class="timeline-title">Resignation Details</div>
                                    </div>
                                    <div class="timeline-content">
                                        <div class="detail-row">
                                            <span class="detail-label">Resignation No:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.DocNo)</span>
                                        </div>
                                        <div class="detail-row">
                                            <span class="detail-label">Resignation Date:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.ResignationDate)</span>
                                        </div>

                                        <div class="detail-row">
                                            <span class="detail-label">Actual Last Working Date:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.LastWorkingDate)</span>
                                        </div>
                                        <div class="detail-row">
                                            <span class="detail-label">Notice Period End Date :</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.NoticePeriodEndDate)</span>
                                        </div>
                                        <div class="detail-row">
                                            <span class="detail-label">Relieving Date:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.RelievingDate)</span>
                                        </div>
                                        <div class="detail-row">
                                            <span class="detail-label">Reason:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.Reason)</span>
                                        </div>
                                        <div class="detail-row">
                                            <span class="detail-label">Status:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.LatestStatus)</span>
                                        </div>
                                        <div class="detail-row">
                                            <span class="detail-label">Approve/Reject Date:</span>
                                            <span class="detail-value">@(ViewBag.ResignationDetails?.LatestStatusDate)</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Acknowledgement Section -->
                                <div class="timeline-item">
                                    <div class="timeline-header">
                                        <div class="timeline-badge bg-info">
                                            <i class="fas fa-handshake"></i>
                                        </div>
                                        <div class="timeline-title">Acknowledgement</div>
                                    </div>
                                    <div class="timeline-content">
                                        <table class="table table-bordered align-middle" id="TablePage"
                                               style="width: 100%;">
                                            <thead class="text-center">
                                                <tr>
                                                    <th class="text-nowrap">Status </th>
                                                    <th class="text-nowrap">Acknowledged By Name</th>
                                                    <th class="text-nowrap">Acknowledgement Date</th>
                                                    <th class="text-nowrap">Acknowledgement Time</th>
                                                    <th class="text-nowrap">Remark</th>

                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.AcknowledgementDetails)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <span class="status-badge
                                                                @(d.AckStatus == "Approved" ? "status-approved-bg" :
                                                                  d.AckStatus == "Pending"  ? "status-pending-bg"  :
                                                                       "status-reject-bg")">
                                                                                    @d.AckStatus
                                                            </span>
                                                        </td>

                                                        <td>@d.AcknowledgedByName</td>
                                                        <td>@d.AckDate</td>
                                                        <td>@d.AckTime</td>
                                                        @if (!string.IsNullOrEmpty(d.Remark))
                                                        {
                                                            <td class="text-start text-center">
                                                                <input type="hidden" id="hiddenRemark_@d.AcknowledgedByName" value="@d.Remark" />
                                                                <i class="fa-solid fa-receipt fa-lg" onclick="AcknowledgedRemark(encodeURIComponent(document.getElementById('hiddenRemark_@d.AcknowledgedByName').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                            </td>

                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <!-- Resignation Status -->
                                <div class="timeline-item">
                                    <div class="timeline-header">
                                        <div class="timeline-badge bg-green-500">
                                            <i class="fas fa-check-double"></i>
                                        </div>
                                        <div class="timeline-title">Resignation Approval Status</div>
                                    </div>
                                    <div class="timeline-content">
                                        <table class="table table-bordered align-middle" id="TablePage"
                                               style="width: 100%;">
                                            <thead class="text-center">
                                                <tr>
                                                    <th class="text-nowrap">Level </th>
                                                    <th class="text-nowrap">Status</th>
                                                    <th class="text-nowrap">Approval Name</th>
                                                    <th class="text-nowrap">Approval Date</th>
                                                    <th class="text-nowrap">Remark</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.ApprovalDetail)
                                                {
                                                    <tr>
                                                        <td class="text-nowrap" style="text-align:center">@d.ApprovalLevel</td>
                                                        <td class="text-center">
                                                            <span class="status-badge
                                                                @(d.ApprovalStatus == "Approved" ? "status-approved-bg" :
                                                                  d.ApprovalStatus == "Pending"  ? "status-pending-bg"  :
                                                                       "status-reject-bg")">
                                                                @d.ApprovalStatus
                                                            </span>
                                                        </td>
                                                        <td>@d.EmployeeName</td>
                                                        <td>@d.ApprovalDate</td>
                                                        <td class="text-start text-center">
                                                            @if (!string.IsNullOrEmpty(d.ApprovalRemark))
                                                            {
                                                                <input type="hidden" id="hiddenRemark_@d.ApprovalLevel" value="@d.ApprovalRemark" />
                                                                <i class="fa-solid fa-receipt fa-lg" onclick="ApprovalRemark(encodeURIComponent(document.getElementById('hiddenRemark_@d.ApprovalLevel').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                            }
                                                        </td>

                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <!-- No Dues Status -->
                                <div class="timeline-item" hidden>
                                    <div class="timeline-header">
                                        <div class="timeline-badge bg-purple-700">
                                            <i class="fas fa-clipboard-check"></i>
                                        </div>
                                        <div class="timeline-title">No Dues Status</div>
                                    </div>
                                    <div class="timeline-content">
                                        <table class="table table-bordered align-middle" id="TablePage"
                                               style="width: 100%;">
                                            <thead class="text-center">
                                                <tr>
                                                    <th class="text-nowrap">Status</th>
                                                    <th class="text-nowrap">Dues Type</th>
                                                    <th class="text-nowrap">Approval Name</th>
                                                    <th class="text-nowrap">Approval Date</th>
                                                    <th class="text-nowrap">Remark</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.DuesDetails)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <span class="status-badge
                                                                @(d.DuesStatus == "Approved" ? "status-approved-bg" :
                                                                  d.DuesStatus == "Pending"  ? "status-pending-bg"  :
                                                                       "status-reject-bg")">
                                                                @d.DuesStatus
                                                            </span>
                                                        </td>
                                                        <td class="text-nowrap">@d.DuesType</td>
                                                        <td>@d.EmployeeName</td>
                                                        <td>@d.ApprovalDate</td>
                                                        <td class="text-start text-center">
                                                            @if (!string.IsNullOrEmpty(d.ApprovalRemark))
                                                            {

                                                                <input type="hidden" id="hiddenRemark_@d.EmployeeName" value="@d.ApprovalRemark" />
                                                                <i class="fa-solid fa-receipt fa-lg" onclick="ApprovalRemark(encodeURIComponent(document.getElementById('hiddenRemark_@d.EmployeeName').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <!-- FNF Calculation -->
                                <div class="timeline-item">
                                    <div class="timeline-header">
                                        <div class="timeline-badge bg-black">
                                            <i class="fas fa-calculator"></i>
                                        </div>
                                        <div class="timeline-title">FNF Calculation</div>
                                    </div>
                                    <div class="timeline-content">
                                        <table class="table table-bordered align-middle" id="TablePage"
                                               style="width: 100%;">
                                            <thead class="text-center">
                                                <tr>
                                                    <th class="text-nowrap">Status</th>
                                                    <th class="text-nowrap">Type</th>
                                                    <th class="text-nowrap">Employee Name</th>
                                                    <th class="text-nowrap">FNF Date</th>
                                                    <th class="text-nowrap">Remark</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.FNFDetails)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <span class="status-badge
                                                                @(d.FNFStatus == "Approved" ? "status-approved-bg" :
                                                                  d.FNFStatus == "Pending"  ? "status-pending-bg"  :
                                                                       "status-reject-bg")">
                                                                @d.FNFStatus
                                                            </span>
                                                        </td>
                                                        <td>@d.Type</td>
                                                        <td>@d.EmployeeName</td>
                                                        <td>@d.FNFDate</td>
                                                        <td class="text-start text-center">
                                                            @if (!string.IsNullOrEmpty(d.FNFRemark))
                                                            {

                                                                <input type="hidden" id="hiddenRemark_@d.EmployeeName" value="@d.FNFRemark" />
                                                                <i class="fa-solid fa-receipt fa-lg" onclick="ApprovalRemark(encodeURIComponent(document.getElementById('hiddenRemark_@d.EmployeeName').value))" style="cursor:pointer; color: #ff5b57;"></i>

                                                            }
                                                        </td>
                                                    </tr>

                                                }
                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- #Start modal-dialog -->
<div class="modal fade" id="EmployeeListModel" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title" id="EmployeeListTitle">@*Employee List*@</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body" style="height: 500px; overflow-y: auto;">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
