<script>
    function GetInvoice() {
        var printContents = document.getElementById("divPrint").innerHTML;
        var printWindow = window.open('', '', 'height=800,width=1000');

        printWindow.document.write('<html><head>');
        printWindow.document.write('<link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css">');

        printWindow.document.write(`
        <style>

            /* FORCE A4 PORTRAIT */
            @@page {
                size: A4 portrait;
                margin: 5mm;
            }

            @@media print {

                /* Scale entire content */
                body {
                    //zoom: 85%;
                    -webkit-print-color-adjust: exact;
                }

                /* Global text size */
                body, td, div, span {
                    font-size: 12px !important;
                }

                /* Row layout */
                .row {
                    display: flex !important;
                    flex-wrap: wrap !important;
                }

                .col-md-6 {
                    flex: 0 0 50% !important;
                    max-width: 50% !important;
                }

                /* Company Header */
                   .company-header {
                          display: flex;
                          align-items: center;
                          justify-content: space-between;
                          padding: 10px 20px;
                          margin-bottom: 5px;
                    }

                .company-logo img {
                        height: 60px;
                        width: 60px;
                    }

                .company-center {
                        flex: 1;
                    text-align: center;
                    }

                .company-name {
                    font-size: 22px !important;
                    font-weight: 900 !important;
                        margin: 0;
                    }

                .company-address {
                    font-size: 14px !important;
                    margin-top: 3px;
                    }

                .report-title {
                    text-align: center;
                    font-size: 16px;
                    font-weight: 600;
                    margin-top: 5px;
                    }

                .date-line {
                font-size: 12px;
                white-space: nowrap;
                text-align: right;
                    }

                /* Details Row Format */
                .detail-row {
                    display: flex;
                    margin-bottom: 2px !important;
                }

                .detail-label {
                    width: 200px;
                    font-weight: bold;
                }

                /* Salary Table */
                .salary-table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-top: 10px;
                    font-size: 14px !important;
                }

                .salary-table td {
                    border: 1px solid #aaa;
                    padding: 5px 7px !important;
                }

                /* Prevent page breaks inside tables */
                table, tr, td, .fnf-container {
                    page-break-inside: avoid !important;
                }
            }
        </style>
    `);

        printWindow.document.write('</head><body>');
        printWindow.document.write(printContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.focus();
        printWindow.print();
        printWindow.close();
    }

</script>

<script>
    const today = new Date();

    // Extract date parts
    const day = String(today.getDate()).padStart(2, '0');
    const month = today.toLocaleString('en-US', { month: 'short' }); // e.g. Nov
    const currentYear = today.getFullYear();
    const lastYear = currentYear - 1;

    // Format: "12/Nov/2025"
    const formattedDate = `${day}/${month}/${currentYear}`;

    // Insert into the div
    document.getElementById('date-line').textContent = `Date: ${formattedDate}`;
    document.getElementById('last-year').textContent = `Last Year - ${lastYear}`;
    document.getElementById('current-year').textContent = `Current Year - ${currentYear}`;
</script>