<script>
    function validateDifferentMonths() {debugger

        var a = $("#txtA_SalaryDate").val();
        var b = $("#txtB_SalaryDate").val();
        var c = $("#txtC_SalaryDate").val();

        var A_Salary_Applicable = $("#ddlA_Salary_Applicable").val();
        var B_Salary_Applicable = $("#ddlB_Salary_Applicable").val();
        var C_Salary_Applicable = $("#ddlC_Salary_Applicable").val();

        var FY_Preivous_Bonus_Year_Applicable = $("#ddlFY_Preivous_Bonus_Year_Applicable").val();
        var FY_Preivous_Bonus_Year = $("#ddlFY_Preivous_Bonus_Year").val();
        var FY_Current_Bonus_Year_Applicable = $("#ddlFY_Current_Bonus_Year_Applicable").val();
        var FY_Current_Bonus_Year = $("#ddlFY_Current_Bonus_Year").val();

        let inputs = $("#txtA_SalaryDate, #txtB_SalaryDate, #txtC_SalaryDate");
        inputs.css("border", "");
        $("#errorA_SalaryDate, #errorB_SalaryDate, #errorC_SalaryDate").text("");

        let error = false;
        if (A_Salary_Applicable === 'Yes' && a == "") {
            $("#errorA_SalaryDate").text("Please Select Month.");
            error = true;
        }

        if (B_Salary_Applicable === 'Yes' && b == "") {
            $("#errorB_SalaryDate").text("Please Select Month.");
            error = true;
        }

        if (C_Salary_Applicable === 'Yes' && c == "") {
            $("#errorC_SalaryDate").text("Please Select Month.");
            error = true;
        }

        if(FY_Preivous_Bonus_Year_Applicable === 'Yes' && FY_Preivous_Bonus_Year == "")
        {
            $("#errorFY_Preivous_Bonus_Year").text("Please Select Bonus Previous Year.");
            error = true;
        }
        else
        {
            $("#errorFY_Preivous_Bonus_Year").text("");
        }

        if(FY_Current_Bonus_Year_Applicable === 'Yes' && FY_Current_Bonus_Year == "")
        {
            $("#errorFY_Current_Bonus_Year").text("Please Select Bonus Current Year.");
            error = true;
        }
        else
        {
            $("#errorFY_Current_Bonus_Year").text("");
        }

        if (a && b && a === b) {
            $("#errorA_SalaryDate").text("Duplicate month.");
            $("#errorB_SalaryDate").text("Duplicate month.");
            error = true;
        }

        if (a && c && a === c) {
            $("#errorA_SalaryDate").text("Duplicate month");
            $("#errorC_SalaryDate").text("Duplicate month");
            error = true;
        }

        if (b && c && b === c) {
            $("#errorB_SalaryDate").text("Duplicate month");
            $("#errorC_SalaryDate").text("Duplicate month");
            error = true;
        }

        return !error;
    }

    // Validate on change
    $("#txtA_SalaryDate, #txtB_SalaryDate, #txtC_SalaryDate").change(function () {debugger
        validateDifferentMonths();
    });



    $(document).ready(function () {

        function calculateTotalEarningDeduction() {debugger
            let TotalUnpaidSalaryAmount = parseFloat($("#txtTotalUnpaidSalaryAmount").val()) || 0;
            let TotalBonus_Amount = parseFloat($("#txtTotalBonus_Amount").val()) || 0;
            let TotalLeaveEncashmentAmount = parseFloat($("#txtTotalLeaveEncashmentAmount").val()) || 0;

            let OtherEarningA_Amount = parseFloat($("#txtOtherEarningA_Amount").val()) || 0;
            let OtherEarningB_Amount = parseFloat($("#txtOtherEarningB_Amount").val()) || 0;
            let TotalOtherEarning = OtherEarningA_Amount + OtherEarningB_Amount;
            $("#txtTotalOtherEarning").val(TotalOtherEarning);

            // Calculate Earning(A)
            let totalEarning = TotalUnpaidSalaryAmount + TotalBonus_Amount + TotalLeaveEncashmentAmount + TotalOtherEarning;
            $("#txtTotalAmountPayable").val(totalEarning);

            // Calculate Deduction(B)
            let OtherDeductionA_Amount = parseFloat($("#txtOtherDeductionA_Amount").val()) || 0;
            let OtherDeductionB_Amount = parseFloat($("#txtOtherDeductionB_Amount").val()) || 0;
            let OtherAmount = parseFloat($("#txtOtherAmount").val()) || 0;
            let MinServiceBondDeduction = parseFloat($("#txtMinServiceBondDeduction").val()) || 0;
            let SalaryTDS = parseFloat($("#txtSalaryTDS").val()) || 0;
            let NoticePeriodDayAmount = parseFloat($("#txtNoticePeriodDayAmount").val()) || 0;

            let totalDeduction = OtherDeductionA_Amount + OtherDeductionB_Amount + OtherAmount + MinServiceBondDeduction + SalaryTDS + NoticePeriodDayAmount;
            $("#txtTotalAmountDeduction").val(totalDeduction);

            let TotalNetPay = totalEarning - totalDeduction;
            $("#txtNetAmountPayable").val(TotalNetPay);
        }

        $("#txtOtherEarningA_Amount, #txtOtherEarningB_Amount, #txtTotalBonus_Amount, #txtTotalLeaveEncashmentAmount, #txtOtherDeductionA_Amount, #txtOtherDeductionB_Amount, #txtOtherAmount,#txtMinServiceBondDeduction,#txtSalaryTDS,#txtNoticePeriodDayAmount")
            .on("keyup change", function () {
                calculateTotalEarningDeduction();
            });
    });
</script>
<script>
    $(document).on('input', '.numeric', function () {
        // Remove any non-numeric characters except decimal
        this.value = this.value.replace(/[^0-9.]/g, '');

        // Allow only one decimal point
        const parts = this.value.split('.');
        if (parts.length > 2) {
            this.value = parts[0] + '.' + parts[1];
        }
    });

    $("#btnSalaryDetailsList").on("click", function () {debugger

        var FNFCal_EmployeeId = $("#ddlFnfEmployee").val();

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetSalaryDetails", "ESS_FNF_SM_FNFCalculationStatement")',
            data: { FNFCal_EmployeeId: FNFCal_EmployeeId },
            success: function (response) {
                debugger;

                let list = response.salaryList;
                let rows = "";

                if (!list || list.length === 0) {
                    $("#SalaryDetailsTableBody").html("<tr><td colspan='4'>No Data</td></tr>");
                    return;
                }

                list.forEach(function (item) {
                    // Convert array of Key/Value to object
                    let obj = {};
                    item.forEach(function(kv) {
                        obj[kv.Key] = kv.Value;
                    });

                    rows += `
                <tr>
                    <td class="text-nowrap">${obj.MonthYear || ''}</td>
                    <td class="text-end text-nowrap">${obj.SalaryPayableDays || 0}</td>
                    <td class="text-end text-nowrap">${obj.SalaryNetPay || 0}</td>
                    <td class="text-nowrap">${obj.Salary_IsHold || ''}</td>
                </tr>`;
                });

                $("#SalaryDetailsTableBody").html(rows);
            }
        });

    });


    $(".bonus-btn").on("click", function () {

        var FNFCal_EmployeeId = $("#ddlFnfEmployee").val();
        var yearType = $(this).data("year"); // CY or PY

        var FY_Current_Bonus_Year = $("#ddlFY_Current_Bonus_Year").val();
        var FY_Preivous_Bonus_Year = $("#ddlFY_Preivous_Bonus_Year").val();

        var isCurrentApplicable =
            $("#ddlFY_Current_Bonus_Year_Applicable").val() === "Yes";

        var isPreviousApplicable =
            $("#ddlFY_Preivous_Bonus_Year_Applicable").val() === "Yes";

        // Validation
        if (!validateDifferentMonths()) {
            return;
        }

        // Sidebar title
        $("#BonusdetailsLabel").text( yearType === "CY"? "Current Year Bonus Details" : "Previous Year Bonus Details"
        );

        // Decide applicability & year
        let isApplicable = false;
        let bonusYear = null;

        if (yearType === "CY") {
            isApplicable = isCurrentApplicable;
            bonusYear = FY_Current_Bonus_Year;
        } else if (yearType === "PY") {
            isApplicable = isPreviousApplicable;
            bonusYear = FY_Preivous_Bonus_Year;
        }

        if (!isApplicable) {
            $("#BonusTableBody").html(
                "<tr><td colspan='4' class='text-center text-muted'>data not available</td></tr>"
            );
            return;
        }

        // Single AJAX call
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetBonusDetails", "ESS_FNF_SM_FNFCalculationStatement")',
            data: {
                FNFCal_EmployeeId: FNFCal_EmployeeId,
                BonusYear: bonusYear
            },
            success: function (response) {

                let list = response.BonusList;
                let rows = "";

                if (!list || list.length === 0) {
                    $("#BonusTableBody").html(
                        "<tr><td colspan='4' class='text-center text-muted'>data not available</td></tr>"
                    );
                    return;
                }

                list.forEach(function (item) {
                    let obj = {};
                    item.forEach(function (kv) {
                        obj[kv.Key] = kv.Value;
                    });

                    rows += `
                    <tr>
                        <td class="text-nowrap">${obj.MonthYear || ""}</td>
                        <td class="text-end text-nowrap">${obj.SalaryPayableDays || 0}</td>
                        <td class="text-end text-nowrap">${obj.RatePartB_Bonus || 0}</td>
                        <td class="text-end text-nowrap">${obj.SalaryBonusContribution || 0}</td>
                    </tr>`;
                });

                $("#BonusTableBody").html(rows);
            }
        });
    });

