<script>
    $(document).ready(function () {
        debugger;
        var A_SalaryDate = @Html.Raw(Json.Encode(TempData["A_SalaryDate"]));
        $("#txtA_SalaryDate").val(A_SalaryDate);

        var B_SalaryDate = @Html.Raw(Json.Encode(TempData["B_SalaryDate"]));
        $("#txtB_SalaryDate").val(B_SalaryDate);

        var C_SalaryDate = @Html.Raw(Json.Encode(TempData["C_SalaryDate"]));
        $("#txtC_SalaryDate").val(C_SalaryDate);



        toggleSalaryDate("#ddlA_Salary_Applicable", "#txtA_SalaryDate");
        toggleSalaryDate("#ddlB_Salary_Applicable", "#txtB_SalaryDate");
        toggleSalaryDate("#ddlC_Salary_Applicable", "#txtC_SalaryDate");
        // Run toggle for Bonus Year Applicable dropdowns
        toggledropdown("#ddlFY_Preivous_Bonus_Year_Applicable", "#ddlFY_Preivous_Bonus_Year");
        toggledropdown("#ddlFY_Current_Bonus_Year_Applicable", "#ddlFY_Current_Bonus_Year");
        toggledropdown("#ddlLeaveYear_Applicable", "#ddlLeaveMasterLeaveYearId");


        $("#ddlA_Salary_Applicable").change(function () {
            toggleSalaryDate("#ddlA_Salary_Applicable", "#txtA_SalaryDate");
        });

        $("#ddlB_Salary_Applicable").change(function () {
            toggleSalaryDate("#ddlB_Salary_Applicable", "#txtB_SalaryDate");
        });

        $("#ddlC_Salary_Applicable").change(function () {
            toggleSalaryDate("#ddlC_Salary_Applicable", "#txtC_SalaryDate");
        });

        $("#ddlFY_Preivous_Bonus_Year_Applicable").change(function () {debugger
            toggledropdown("#ddlFY_Preivous_Bonus_Year_Applicable", "#ddlFY_Preivous_Bonus_Year");
        });

        $("#ddlFY_Current_Bonus_Year_Applicable").change(function () {
            toggledropdown("#ddlFY_Current_Bonus_Year_Applicable", "#ddlFY_Current_Bonus_Year");
        });

        $("#ddlLeaveYear_Applicable").change(function () {
            toggledropdown("#ddlLeaveYear_Applicable", "#ddlLeaveMasterLeaveYearId");
        });

        
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#ddlFY_Preivous_Bonus_Year_Applicable").on("change", function () {
            debugger;
            var FY_Preivous_Bonus_Year_Applicable = $("#ddlFY_Preivous_Bonus_Year_Applicable").val();
            if(FY_Preivous_Bonus_Year_Applicable == 'Yes')
            {
                FY_Preivous_Bonus_Year_Applicable=true;
            }
            else
            {
                FY_Preivous_Bonus_Year_Applicable=false;
            }
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBonusPreviousYear", "ESS_FNF_SM_FNFCalculationStatement")',
                data: { FY_Preivous_Bonus_Year_Applicable: FY_Preivous_Bonus_Year_Applicable},
                success: function (data) {
                    debugger;
                    if (data.BonusPreviousYear !=null) {
                        $("#ddlFY_Preivous_Bonus_Year").empty();
                        if(FY_Preivous_Bonus_Year_Applicable ==true)
                        {
                            $.each(data.BonusPreviousYear, function(i, p) {
                                $("#ddlFY_Preivous_Bonus_Year").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                            });
                        }
                        else{
                            $("#ddlFY_Preivous_Bonus_Year").append("<option value=''>--Select---</option>");
                        }
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#ddlFY_Current_Bonus_Year_Applicable").on("change", function () {
            debugger;
            var FY_Current_Bonus_Year_Applicable = $("#ddlFY_Current_Bonus_Year_Applicable").val();
            if(FY_Current_Bonus_Year_Applicable == 'Yes')
            {
                FY_Current_Bonus_Year_Applicable=true;
            }
            else
            {
                FY_Current_Bonus_Year_Applicable=false;
            }
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBonusCurrentYear", "ESS_FNF_SM_FNFCalculationStatement")',
                data: { FY_Current_Bonus_Year_Applicable: FY_Current_Bonus_Year_Applicable},
                success: function (data) {
                    debugger;
                    if (data.BonusCurrentYear !=null) {
                        $("#ddlFY_Current_Bonus_Year").empty();
                        if(FY_Current_Bonus_Year_Applicable ==true)
                        {
                            $.each(data.BonusCurrentYear, function(i, p) {
                                $("#ddlFY_Current_Bonus_Year").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                            });
                        }
                        else{
                            $("#ddlFY_Current_Bonus_Year").append("<option value=''>--Select---</option>");
                        }

                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlLeaveYear_Applicable").on("change", function () {
            debugger;
            var LeaveYear_Applicable = $("#ddlLeaveYear_Applicable").val();
            var EmployeeId = $("#ddlFnfEmployee").val();
            if(LeaveYear_Applicable == 'Yes')
            {
                LeaveYear_Applicable=true;
            }
            else
            {
                LeaveYear_Applicable=false;
            }
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetLeaveYear", "ESS_FNF_SM_FNFCalculationStatement")',
                data: { LeaveYear_Applicable: LeaveYear_Applicable,EmployeeId:EmployeeId},
                success: function (data) {
                    debugger;
                    if (data.LeaveYear !=null) {
                        $("#ddlLeaveMasterLeaveYearId").empty();
                        if(LeaveYear_Applicable ==true)
                        {
                            $.each(data.LeaveYear, function(i, p) {
                                $("#ddlLeaveMasterLeaveYearId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                            });
                        }
                        else{
                            $("#ddlLeaveMasterLeaveYearId").append("<option value=''>--Not Applicable---</option>");
                        }

                    }
                }
            })
        });
    });

</script>
<script>
    $("#btnGetDetails").click(function () {debugger
        var FNFCal_EmployeeId = $("#ddlFnfEmployee").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url:"GetUnpaidSalaryDetails",
            data:{
                FNFCal_EmployeeId:FNFCal_EmployeeId
            },
            success:function(data){debugger
                $(".Userloaderbg").css("display", "none");
                debugger;
                if (data && data.GetUnpaidSalary && data.GetUnpaidSalary.length > 0) {

                    var arr = data.GetUnpaidSalary;
                    var obj = {};

                    // Convert Key/Value array → normal object
                    arr.forEach(function (item) {
                        obj[item.Key] = item.Value;
                    });
                    debugger
                    $("#ddlA_Salary_Applicable").val(obj.SM_UnpaidSalaryA_YesNo);
                    $("#ddlB_Salary_Applicable").val(obj.SM_UnpaidSalaryB_YesNo);
                    $("#ddlC_Salary_Applicable").val(obj.SM_UnpaidSalaryC_YesNo);

                    if (obj.SM_UnpaidSalaryA_Date) {
                        var dateObj = new Date(obj.SM_UnpaidSalaryA_Date);
                        var yyyy = dateObj.getFullYear();
                        var MM = ("0" + (dateObj.getMonth() + 1)).slice(-2);
                        $("#txtA_SalaryDate").val(yyyy + "-" + MM);
                    }
                    if (obj.SM_UnpaidSalaryB_Date) {
                        var dateObj = new Date(obj.SM_UnpaidSalaryB_Date);
                        var yyyy = dateObj.getFullYear();
                        var MM = ("0" + (dateObj.getMonth() + 1)).slice(-2);
                        $("#txtB_SalaryDate").val(yyyy + "-" + MM);
                    }


                    if (obj.SM_UnpaidSalaryC_Date) {
                        var dateObj = new Date(obj.SM_UnpaidSalaryC_Date);
                        var yyyy = dateObj.getFullYear();
                        var MM = ("0" + (dateObj.getMonth() + 1)).slice(-2);
                        $("#txtC_SalaryDate").val(yyyy + "-" + MM);
                    }

                    $("#ddlFY_Preivous_Bonus_Year_Applicable").val(obj.SM_PreivousBonus_YesNo);
                    $("#ddlFY_Current_Bonus_Year_Applicable").val(obj.SM_CurrentBonus_YesNo);
                    if (obj.SM_PreivousBonus_YearID) {
                        $("#ddlFY_Preivous_Bonus_Year")
                            .val(obj.SM_PreivousBonus_YearID.toString())
                            .trigger("change");
                    }
                    if (obj.SM_CurrentBonus_YearID) {
                        $("#ddlFY_Current_Bonus_Year")
                            .val(obj.SM_CurrentBonus_YearID.toString())
                            .trigger("change");
                    }
                    var leaveYearId = obj.SM_PreivousLeave_YearID; // "2025-2026"

                    $("#ddlLeaveYear_Applicable").val(obj.SM_PreivousLeave_YesNo);

                    if (obj.SM_PreivousLeave_YearID) {
                        $("#ddlLeaveMasterLeaveYearId")
                            .val(obj.SM_PreivousLeave_YearID.toString())
                            .trigger("change");
                    }

                    //$("#ddlLeaveMasterLeaveYearId option").each(function () {
                    //    if ($(this).text().trim() === leaveYearId.trim()) {
                    //        $("#ddlLeaveMasterLeaveYearId").val($(this).val());
                    //        return false;
                    //    }
                    //});

                    toggleSalaryDate("#ddlA_Salary_Applicable", "#txtA_SalaryDate");
                    toggleSalaryDate("#ddlB_Salary_Applicable", "#txtB_SalaryDate");
                    toggleSalaryDate("#ddlC_Salary_Applicable", "#txtC_SalaryDate");
                    toggledropdown("#ddlFY_Preivous_Bonus_Year_Applicable", "#ddlFY_Preivous_Bonus_Year");
                    toggledropdown("#ddlFY_Current_Bonus_Year_Applicable", "#ddlFY_Current_Bonus_Year");
                }
            }
        });
    });

    function toggleSalaryDate(dropdownId, textboxId) {
        if ($(dropdownId).val() === "No") { debugger
            $(textboxId).val("").prop("readonly", true);
        } else {
            $(textboxId).prop("readonly", false);
        }
    }

    function toggledropdown(dropdownId, textboxId) {debugger
        if ($(dropdownId).val() === "No") {debugger
            $(textboxId).val("").prop("readonly", true);
        } else {
            $(textboxId).prop("readonly", false);
        }
    }

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveFNFCalculation').validate({
        rules: {
            FNFCal_EmployeeId: {
                required: true,
            },
        },
        messages: {
            FNFCal_EmployeeId: {
                required: "Employee name is required",
            },
        },
    });

    var form = $("#SaveFNFCalculation");
    form.validate();

    //Calculate
    $("#btnLoad").click(function () {debugger
        $(".Userloaderbg").css("display", "flex");

        // Call validation function and STOP if validation fails
        if (!validateDifferentMonths()) {
            $(".Userloaderbg").css("display", "none");
            return false;
        }

        if (form.valid() == false) {
            $(".Userloaderbg").css("display", "none");
            return false;

        }
        debugger;
        var FNFCal_EmployeeId = $("#ddlFnfEmployee").val();
        var A_Salary_Applicable = $("#ddlA_Salary_Applicable").val();
        var B_Salary_Applicable = $("#ddlB_Salary_Applicable").val();
