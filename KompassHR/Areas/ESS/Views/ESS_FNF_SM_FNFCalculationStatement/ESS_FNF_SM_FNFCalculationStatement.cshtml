<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }



    .box2 {
        width: 100px;
        height: 100px;
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
        margin-bottom: 10px;
    }

        .box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.03), 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        }

            .box2:hover .info i {
                color: #ff9c19;
            }


        .box2 .info i {
            font-size: 20px;
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
            font-size: 12px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .FS-12PX {
        font-size: 12px !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }


    .fixed-side {
        position: sticky;
        left: 0px;
    }

    /*.fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #448bcd;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #448bcd 1px solid;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .empbx h4 {
        margin-bottom: 5px;
    }

    .empbx h6 i {
        font-size: 1rem;
        margin-right: 5px;
    }

    .empbx {
        margin-bottom: 20px;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }

    .employee-details {
        padding-top: 10px;
        margin-bottom: 20px;
        border-bottom: #448bcd 1px solid;
    }

    .detail-row {
        display: flex;
        margin-bottom: 5px;
    }

    /*.detail-label {
        width: 200px;
        font-weight: bold;
    }*/

    .label-icon {
        font-size: 14px;
        display: block;
        margin-bottom: 3px;
        width: 24px;
        color: #007bff; /* change color if needed */
    }

    .detail-label {
        font-weight: 600;
        display: flex;
        width: 200px;
        // flex-direction: column;
    }


    .section-header h6 {
        color: #495057;
        font-weight: 600;
    }

    /*.detail-row {
        display: flex;
        align-items: center;
        padding: 8px 0;
    }

    .detail-label {
        min-width: 200px;
        font-weight: 500;
    }*/

    .detail-value {
        flex: 1;
        font-weight: 400;
        color: #212529;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-right: none;
    }

    .form-control:readonly {
        background-color: #f8f9fa;
    }

    .border-primary {
        border-color: #0d6efd !important;
    }

    .border-success {
        border-color: #198754 !important;
    }

    .border-danger {
        border-color: #dc3545 !important;
    }

    /*.numeric {
        font-family: 'Courier New', monospace;
    }*/

    .card-header {
        border-radius: 0.375rem 0.375rem 0 0 !important;
    }
</style>
<style>
    #BonusdetailsSidebar .table thead {
        position: sticky;
        top: 0;
        z-index: 1;
    }

    #BonusdetailsSidebar .table td,
    #BonusdetailsSidebar .table th {
        vertical-align: middle;
        padding: 8px;
    }

    /*#BonusdetailsSidebar .table tbody tr:nth-child(even) {
        background-color: #f8f9fa;
    }*/

    #BonusdetailsSidebar .table tbody tr:hover {
        background-color: #eaf3ff;
        transition: 0.2s;
    }

    #LeaveEncashmentSidebar .table thead {
        position: sticky;
        top: 0;
        z-index: 1;
    }

    #LeaveEncashmentSidebar .table td,
    #LeaveEncashmentSidebar .table th {
        vertical-align: middle;
        padding: 8px;
    }

    /*#LeaveEncashmentSidebar .table tbody tr:nth-child(even) {
        background-color: #f8f9fa;
    }*/

    #LeaveEncashmentSidebar .table tbody tr:hover {
        background-color: #eaf3ff;
        transition: 0.2s;
    }
</style>
<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Calculation 
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> FNF Calculation  - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        FNF Calculation Form.
                    </p>
                </div>
                <div class="panel-body combined-table-border table-container">
                    <form role="form" action='@Url.Action("SaveUpdate", "ESS_FNF_SM_FNFCalculationStatement", new { area = "ESS" })' id="SaveFNFCalculation" method="post" data-parsley-validate="">

                        <!-- Employee Selection -->
                        <div class="card shadow-sm mb-4" hidden>
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-3 fw-semibold">
                                                Employee Name <span class="text-danger">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownListFor(model => model.FNFCal_EmployeeId, new SelectList(ViewBag.AllEmployeeName, "Id", "Name")
                                               , new { id = "ddlFnfEmployee", @class = "form-select form-select-sm", autocomplete = "off", name = "FNFCal_EmployeeId" })
                                                @Html.HiddenFor(model => model.FNFCal_Encrypted, new { @class = "form-control", id = "FnfCalId_Encrypted" })
                                                @Html.HiddenFor(model => model.ResignationId, new { @class = "form-control", id = "ResignId" })
                                                @Html.HiddenFor(model => model.FNFCald, new { @class = "form-control", id = "FNFCald" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Employee Details Card -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0" style="color: #348fe2;"><i class="fa fa-id-card me-2"></i>Employee Details</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <!-- Left Column -->
                                    <div class="col-md-6">
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-user fa-sm"></i></span>
                                                Employee Name :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_EmployeeName
                                                @Html.HiddenFor(model => model.EmployeeName, new { @id = "hdnEmployeeName" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-building fa-sm"></i></span>
                                                Department :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_Department
                                                @Html.HiddenFor(model => Model.Department, new { @id = "hdnDepartment" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-star fa-sm"></i></span>
                                                Grade :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_Grade
                                                @Html.HiddenFor(model => Model.Grade, new { @id = "hdnGrade" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-chart-bar fa-sm"></i></span>
                                                Daily/Monthly :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_DailyMonthly
                                                @Html.HiddenFor(model => Model.DailyMonthly, new { @id = "hdnDailyMonthly" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-calendar-xmark fa-sm"></i></span>
                                                Resignation Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_ReginationDate
                                                @Html.HiddenFor(model => Model.ReginationDate, new { @id = "hdnResignationDate" })
                                            </div>
                                        </div>
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-bell fa-sm"></i></span>
                                                Notice Period :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_NoticePeriod
                                            </div>
                                        </div>
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-bell fa-sm"></i></span>
                                                End Of Notice Period :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_NoticePeriodEndDate
                                                @Html.HiddenFor(model => Model.NoticePeriodEndDate, new { @id = "hdnEndNoticePeriod" })
                                            </div>
                                        </div>

                                    </div>

                                    <!-- Right Column -->
                                    <div class="col-md-6">
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-id-card fa-sm"></i></span>
                                                Employee No :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_EmployeeNo
                                                @Html.HiddenFor(model => Model.EmployeeNo, new { @id = "hdnEmployeeNo" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-briefcase fa-sm"></i></span>
                                                Designation :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_Desination
                                                @Html.HiddenFor(model => Model.Desination, new { @id = "hdnDesignation" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-industry fa-sm"></i></span>
                                                Business Unit :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_BusinessUnit
                                                @Html.HiddenFor(model => Model.BusinessUnit, new { @id = "hdnBranch" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-calendar-check fa-sm"></i></span>
                                                Joining Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_JoiningDate
                                                @Html.HiddenFor(model => Model.JoiningDate, new { @id = "hdnDOJ" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-hourglass-end fa-sm"></i></span>
                                                Last Working Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_LastWorkingDate
                                                @Html.HiddenFor(model => Model.LastWorkingDate, new { @id = "hdnLastWorkingDate" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-hourglass-end fa-sm"></i></span>
                                                Relieving Date :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_RelievingDate
                                                @Html.HiddenFor(model => Model.RelievingDate, new { @id = "hdnRelievingDate" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-lock fa-sm"></i></span>
                                                Service Bond Applicable :
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.SM_Bond_Applicable
                                                @Html.HiddenFor(model => Model.Bond_Applicable, new { @id = "hdnServiceBondApplicable" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Input Parameters Card -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-body">
                                <div class="col-md-4">
                                    <button type="button" class="btn btn-success btn-sm" id="btnGetDetails">
                                        <i class="fa-solid fa-floppy-disk"></i>  Get Details
                                    </button>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                1. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.A_Salary_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes" },
                                                    new SelectListItem { Value = "No", Text = "No" , Selected = true}
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlA_Salary_Applicable", name = "A_Salary_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.A_SalaryDate, new { @class = "form-control form-control-sm", name = "A_SalaryDate", type = "Month", id = "txtA_SalaryDate" })
                                                <span class="text-danger small" id="errorA_SalaryDate"></span>
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                2. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.B_Salary_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes" },
                                                    new SelectListItem { Value = "No", Text = "No", Selected = true }
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlB_Salary_Applicable", name = "B_Salary_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.B_SalaryDate, new { @class = "form-control form-control-sm", name = "B_SalaryDate", type = "Month", id = "txtB_SalaryDate" })
                                                <span class="text-danger small" id="errorB_SalaryDate"></span>
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                3. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.C_Salary_Applicable,
                                                new SelectList(new List<SelectListItem>
                                                {
                                                new SelectListItem { Value = "Yes", Text = "Yes" },
                                                new SelectListItem { Value = "No", Text = "No" , Selected = true}
                                                }, "Value", "Text"), "--Select--",
                                                new { id = "ddlC_Salary_Applicable", name = "C_Salary_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.C_SalaryDate, new { @class = "form-control form-control-sm", name = "C_SalaryDate", type = "Month", id = "txtC_SalaryDate" })
                                                <span class="text-danger small" id="errorC_SalaryDate"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                Bonus Previous Year
                                            </label>
                                            <div class="col-md-3">
                                                @Html.DropDownListFor(model => model.FY_Preivous_Bonus_Year_Applicable,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Value = "Yes", Text = "Yes" },
                                                    new SelectListItem { Value = "No", Text = "No", Selected = true }
                                                    }, "Value", "Text"), "--Select--",
                                                    new { id = "ddlFY_Preivous_Bonus_Year_Applicable", name = "FY_Preivous_Bonus_Year_Applicable", @class = "form-select form-select-sm", autocomplete = "off", @required = "required" })
                                            </div>
                                            <div class="col-md-4">
                                                @Html.DropDownListFor(model => model.FY_Preivous_Bonus_Year, new SelectList(ViewBag.GetBonusYear, "Id", "Name"), "--Select--", new { id = "ddlFY_Preivous_Bonus_Year", name = "FY_Preivous_Bonus_Year", @class = "form-select form-select-sm", autocomplete = "off" })
                                                <span class="text-danger small" id="errorFY_Preivous_Bonus_Year"></span>
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-5">
                                                Bonus Current Year
                                            </label>
