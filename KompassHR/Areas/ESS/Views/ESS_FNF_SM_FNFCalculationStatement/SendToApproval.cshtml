@model KompassHR.Areas.ESS.Models.ESS_FNF.SM_FNFCalculations

@{
    ViewBag.Title = "SendToApproval";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>

<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }



    .box2 {
        width: 100px;
        height: 100px;
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
        margin-bottom: 10px;
    }

        .box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.03), 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        }

            .box2:hover .info i {
                color: #ff9c19;
            }


        .box2 .info i {
            font-size: 20px;
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
            font-size: 12px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .FS-12PX {
        font-size: 12px !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }


    .fixed-side {
        position: sticky;
        left: 0px;
    }

    /*.fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #448bcd;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #448bcd 1px solid;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .empbx h4 {
        margin-bottom: 5px;
    }

    .empbx h6 i {
        font-size: 1rem;
        margin-right: 5px;
    }

    .empbx {
        margin-bottom: 20px;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }

    .employee-details {
        padding-top: 10px;
        margin-bottom: 20px;
        border-bottom: #448bcd 1px solid;
    }

    .detail-row {
        display: flex;
        margin-bottom: 5px;
    }

    /*.detail-label {
        width: 200px;
        font-weight: bold;
    }*/

    .label-icon {
        font-size: 14px;
        display: block;
        margin-bottom: 3px;
        width: 24px;
        color: #007bff; /* change color if needed */
    }

    .detail-label {
        font-weight: 600;
        display: flex;
        width: 200px;
        // flex-direction: column;
    }


    .section-header h6 {
        color: #495057;
        font-weight: 600;
    }

    /*.detail-row {
        display: flex;
        align-items: center;
        padding: 8px 0;
    }

    .detail-label {
        min-width: 200px;
        font-weight: 500;
    }*/

    .detail-value {
        flex: 1;
        font-weight: 400;
        color: #212529;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-right: none;
    }

    .form-control:readonly {
        background-color: #f8f9fa;
    }

    .border-primary {
        border-color: #0d6efd !important;
    }

    .border-success {
        border-color: #198754 !important;
    }

    .border-danger {
        border-color: #dc3545 !important;
    }

    .numeric {
        font-family: 'Courier New', monospace;
    }

    .card-header {
        border-radius: 0.375rem 0.375rem 0 0 !important;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Calculation Statement
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu", new { id = 7, ScreenId = 168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> FNF Calculation Statement - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        FNF Calculation Statement Form.
                    </p>
                </div>
                <div class="panel-body combined-table-border table-container">
                    <form role="form" action='@Url.Action("SaveUpdate", "ESS_FNF_SM_FNFCalculationStatement", new { area = "ESS" })' id="SaveFNFCalculation" method="post" data-parsley-validate="">

                      

                        <!-- Employee Details Card -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h6 class="mb-0"><i class="fa fa-id-card me-2"></i>Employee Details</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <!-- Left Column -->
                                    <div class="col-md-6">
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-user fa-sm"></i></span>
                                                Employee Name
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.EmployeeName
                                                @Html.HiddenFor(model => model.EmployeeName, new { @id = "hdnEmployeeName" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-building fa-sm"></i></span>
                                                Department
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Department
                                                @Html.HiddenFor(model => Model.Department, new { @id = "hdnDepartment" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-star fa-sm"></i></span>
                                                Grade
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Grade
                                                @Html.HiddenFor(model => Model.Grade, new { @id = "hdnGrade" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-chart-bar fa-sm"></i></span>
                                                Daily/Monthly
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.DailyMonthly
                                                @Html.HiddenFor(model => Model.DailyMonthly, new { @id = "hdnDailyMonthly" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-calendar-xmark fa-sm"></i></span>
                                                Resignation Date
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.ReginationDate
                                                @Html.HiddenFor(model => Model.ReginationDate, new { @id = "hdnResignationDate" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-bell fa-sm"></i></span>
                                                End Of Notice Period
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.NoticePeriodEndDate
                                                @Html.HiddenFor(model => Model.NoticePeriodEndDate, new { @id = "hdnEndNoticePeriod" })
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Right Column -->
                                    <div class="col-md-6">
                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-id-card fa-sm"></i></span>
                                                Employee No
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.EmployeeNo
                                                @Html.HiddenFor(model => Model.EmployeeNo, new { @id = "hdnEmployeeNo" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-briefcase fa-sm"></i></span>
                                                Designation
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Desination
                                                @Html.HiddenFor(model => Model.Desination, new { @id = "hdnDesignation" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-industry fa-sm"></i></span>
                                                Business Unit
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.BusinessUnit
                                                @Html.HiddenFor(model => Model.BusinessUnit, new { @id = "hdnBranch" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-calendar-check fa-sm"></i></span>
                                                DOJ
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.JoiningDate
                                                @Html.HiddenFor(model => Model.JoiningDate, new { @id = "hdnDOJ" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-hourglass-end fa-sm"></i></span>
                                                Last Working Date
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.LastWorkingDate
                                                @Html.HiddenFor(model => Model.LastWorkingDate, new { @id = "hdnLastWorkingDate" })
                                            </div>
                                        </div>

                                        <div class="detail-row">
                                            <div class="detail-label fw-medium text-muted">
                                                <span class="label-icon text-primary me-2"><i class="fa fa-lock fa-sm"></i></span>
                                                Service Bond Applicable
                                            </div>
                                            <div class="detail-value">
                                                @ViewBag.EmployeeDetails.Bond_Applicable
                                                @Html.HiddenFor(model => Model.Bond_Applicable, new { @id = "hdnServiceBondApplicable" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                       
                        <!-- Earning Section -->
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fa fa-arrow-up me-2"></i>Earnings (A)</h5>
                            </div>
                            <div class="card-body">
                                <!-- Basic Salary Info -->
                                <div class="row mb-4">
                                    <div class="col-md-6 mb-3">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4 fw-medium">
                                                Gross Salary
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => Model.GrossSalary, new { @class = "form-control text-end fw-semibold", @id = "txtGrossSalary", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4 fw-medium">
                                                Basic Salary
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => Model.BasicSalary, new { @class = "form-control text-end fw-semibold", @id = "txtBasicSalary", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Unpaid Salary -->
                                <div class="section-header mb-3">
                                    <h6 class="border-bottom pb-2"><i class="fa fa-calendar-days me-2"></i>Unpaid Salary</h6>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-4">
                                                1. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.A_SalaryDate, new { @class = "form-control", name = "A_SalaryDate", type = "text", id = "txtUnpaidA_SalaryDate", @readonly = "readonly" })
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-4">
                                                2. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.B_SalaryDate, new { @class = "form-control", name = "B_SalaryDate", type = "text", id = "txtUnpaidB_SalaryDate", @readonly = "readonly" })
                                            </div>
                                        </div>
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                3. Unpaid Salary Month
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.C_SalaryDate, new { @class = "form-control", name = "C_SalaryDate", type = "text", id = "txtUnpaidC_SalaryDate", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-4">
                                                Amount
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => Model.UnpaidSalaryA_Amount, new { @class = "form-control text-end", @id = "txtUnpaidSalaryA_Amount", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-4">
                                                Amount
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => Model.UnpaidSalaryB_Amount, new { @class = "form-control text-end", @id = "txtUnpaidSalaryB_Amount", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Amount
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => Model.UnpaidSalaryC_Amount, new { @class = "form-control text-end", @id = "txtUnpaidSalaryC_Amount", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Unpaid Salary -->
                                <div class="row mt-3">
                                    <div class="col-md-8 text-end">
                                        <label class="form-label col-form-label text-end fw-bold">
                                            <b>Total Unpaid Salary</b>
                                        </label>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="input-group">
                                            <span class="input-group-text bg-light fw-bold">₹</span>
                                            @Html.TextBoxFor(model => Model.TotalUnpaidSalaryAmount, new { @class = "form-control text-end fw-bold border-primary", @id = "txtTotalUnpaidSalaryAmount", @readonly = "readonly" })
                                        </div>
                                    </div>
                                </div>

                                <!-- Bonus Details -->
                                <div class="section-header mb-3 mt-4">
                                    <h6 class="border-bottom pb-2"><i class="fa fa-gift me-2"></i>Bonus Details</h6>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-4">
                                                Previous Year
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PreivousBonus_Remark, new { @class = "form-control", name = "PreivousBonus_Remark", id = "txtPreivousBonus_Remark", @readonly = "readonly" })
                                            </div>
                                        </div>
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Current Year
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CurrentBonus_Remark, new { @class = "form-control", name = "BonusCurrentYear", id = "txtCurrentBonus_Remark", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-3">
                                            <label class="form-label col-form-label col-md-4">
                                                Amount
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => model.BonusPreviousYearAmount, new { @class = "form-control text-end", name = "BonusPreviousYearAmount", id = "txtBonusPreviousYearAmount", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Amount
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <span class="input-group-text">₹</span>
                                                    @Html.TextBoxFor(model => Model.BonusCurrentYearAmount, new { @class = "form-control text-end", @id = "txtBonusCurrentYearAmount", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Bonus -->
                                <div class="row">
                                    <div class="col-md-8 text-end">
                                        <label class="form-label col-form-label text-end fw-bold">
                                            <b>Total Bonus Amount</b>
                                        </label>
                                    </div>
                                    <div class="col-md-4">
