<div id="content" class="app-content content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Recruitment Attrition Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Recruitment_ReportsMenu", "ESS_Recruitment_ReportsMenu", new {id = 1, ScreenId=256, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse">
                <div class="panel-heading">
                    <h4 class="panel-title">Recruitment Attrition Report </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_Recruitment_AttritionReports", "ESS_Recruitment_AttritionReports", new { area = "ESS" })' id="SaveDateWiseReports" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyProfile, "Id", "Name"), "--Select--", new { id = "ddlCompanyName", @class = "form-select", autocomplete = "off", name = "CompanyId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetMasBranch, "Id", "Name"), "All", new { @class = "form-select", type = "text", id = "ddlBuniessUnit", name = "BranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.Year, new { @class = "form-control", id = "txtyear", type = "number", name = "year", autocomplete = "Off", Maxlength = 4 })
                                            </div>
                                        </div>
                                    </div>
                                    @*<div class="col-md-2">
                                            <div class="row mb-15px">
                                                <div class="col-md-4">
                                                    <button type="submit" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployee">
                                                        Show
                                                    </button>
                                                </div>
                                            </div>
                                        </div>*@
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-10">
                                            </div>
                                            <div class="col-md-2">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                            <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                            @*<div class="row">
                                    <div class="col-md-12">
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="panel-body" data-scrollbar="true">
                                                <!-- BEGIN table-responsive -->
                                                <div class="table-scroll div1">
                                                    <div class="table-wrap">
                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage tblAddData">
                                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                                <tr>
                                                                    <th class="text-nowrap">Month</th>
                                                                    <th class="text-nowrap">New Employee</th>
                                                                    <th class="text-nowrap">Employee Left</th>
                                                                    <th class="text-nowrap">Active Employee</th>
                                                                    <th class="text-nowrap">Total Employee</th>

                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var d in ViewBag.ManpowerAttritionList)
                                                                {
                                                                    <tr>
                                                                        <td>@d.MonthYear</td>
                                                                        <td>@d.NewJoinee</td>
                                                                        <td>@d.left</td>
                                                                        <td>@d.Opening</td>
                                                                        <td>@d.closing</td>

                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                                <!-- END table-responsive -->
                                            </div>
                                        </div>
                                    </div>
                                </div>*@

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCompanyName").select2();
        $("#ddlBuniessUnit").select2();

        $("#ddlCompanyName").on("change", function () {
            $("#ddlBuniessUnit").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_Recruitment_AttritionReports")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlBuniessUnit").append("<option value=''>All</option>");
                        $.each(data, function (i, p) {
                            debugger;
                            $("#ddlBuniessUnit").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })

    });
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
        function (value, element, regexp) {
            if (regexp.constructor != RegExp)
                regexp = new RegExp(regexp);
            else if (regexp.global)
                regexp.lastIndex = 0;
            return this.optional(element) || regexp.test(value);
        }, "erreur expression reguliere"
);

    $("#SaveDateWiseReports").validate({
        rules: {
            Year: {
                required: true,
            },
            CmpId: {
                required: true,
            },
        },
        messages: {
            Year: {
                required: "Year is required"
            },
            CmpId: {
                required: "Company name is required",
            },
        }
    });
    var form = $("#SaveDateWiseReports");
    form.validate();


    function downloadExcelFile() {
        debugger
    $(".Userloaderbg").css("display", "flex");
    var CmpId = encodeURIComponent($("#ddlCompanyName").val());
    var BranchId = encodeURIComponent($("#ddlBuniessUnit").val());
    var Year = encodeURIComponent($("#txtyear").val());

    if (!form.valid()) {
        $(".Userloaderbg").css("display", "none");
        Swal.fire({
            icon: 'error',
            text: 'Please fill all required fields correctly',
            allowOutsideClick: () => {
                const popup = Swal.getPopup();
                popup.classList.remove('swal2-show');
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake');
                });
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake');
                }, 500);
                return false;
            }
        });
        return false;
    }

    var url = '@Url.Action("DownloadExcelFile", "ESS_Recruitment_AttritionReports", new { area = "ESS" })?CmpId=' + CmpId + '&BranchId=' + BranchId + '&Year=' + Year;

    $.ajax({
        url: url,
        method: 'GET',
        xhrFields: {
            responseType: 'blob'
        },
        success: function (data) {
            debugger
            if (data.size == 0) {
                Swal.fire({
                    icon: 'error',
                    text: 'No records found',
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup();
                        popup.classList.remove('swal2-show');
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake');
                        });
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake');
                        }, 500);
                        return false;
                    }
                });
                $(".Userloaderbg").css("display", "none");
                return false;
            }

            var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
            var anchorElement = document.createElement('a');
            var url = window.URL.createObjectURL(blob);
            anchorElement.href = url;
            anchorElement.download = 'AttritionReport_' + Year + '.xlsx';
            anchorElement.click();
            window.URL.revokeObjectURL(url);
            $(".Userloaderbg").css("display", "none");
        },
        error: function (xhr, status, error) {
            debugger
            console.error('Error downloading file:', error);
            Swal.fire({
                icon: 'error',
                text: 'Error downloading file',
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.remove('swal2-show');
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake');
                    });
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake');
                    }, 500);
                    return false;
                }
            });
            $(".Userloaderbg").css("display", "none");
        }
    });
}
</script>
