<script>
    $(document).ready(function () {
        $("#ddlDirecation").prop("disabled", true);
        $("#txtTotalMinutes").prop("disabled", true);
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        $("#txtDesignation").select2();
        $("#txtDepartment").select2();
        $("#txtGrade").select2();

        var Doc = @Html.Raw(Json.Encode(TempData["DocDate"]));
        var ClosingDate = @Html.Raw(Json.Encode(TempData["ClosingDate"]));

        if(Doc =="" || ClosingDate == "")
        {

        }
        else
        {
            var DocDate =  convertDate(Doc);
            var ClosingDate =  convertDate(ClosingDate);

            $("#txtDocDate").val(DocDate);
            $("#txtClosingDate").val(ClosingDate);
        }
    });//ready function


    function DeleteFunction(ResourceId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("DeleteRecruitment", "ESS_Resources_Recruitment")?ResourceId_Encrypted=' + ResourceId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }




    var date = new Date();
    var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
    $("#txtDocDate").val(dateString);

    $("#btnGetList").click(function () {
        var url = '@Url.Action("GetList", "ESS_Resources_Recruitment")';
        window.location.href = url;
    })

</script>
