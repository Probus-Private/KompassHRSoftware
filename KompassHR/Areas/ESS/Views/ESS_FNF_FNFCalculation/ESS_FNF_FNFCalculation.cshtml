<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                FNF Calculation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
               </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ FNF Calculation - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Below is a list of all resign employees, consultants, trainees
                    </p>
                </div>
                <div class="panel-body">
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <div class="row">
                                <div class="col-md-12">
                                    <!-- BEGIN table-responsive -->
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage EmployeeDetails" id="tblEmployeeDetails"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="text-center">
                                                <th class="fixed-side">Action</th>
                                                <th class="fixed-side1">Employee Name</th>
                                                <th class="fixed-side2">Employee No.</th>
                                                <th hidden Class="text-nowrap width-45">EmployeeId</th>
                                                <th hidden Class="text-nowrap width-45">CmpId</th>
                                                <th hidden Class="text-nowrap width-45">BranchId</th>

                                                <th class="text-nowrap width-45">Company Name</th>
                                                <th class="text-nowrap width-45">Business Unit</th>
                                                <th class="text-nowrap width-45">Grade</th> 
                                                <th class="text-nowrap width-45">Department</th>
                                                <th class="text-nowrap width-45">Designation</th>
                                                <th class="text-nowrap width-45">Primary Mobile No.</th>
                                                <th class="text-nowrap width-45">Joining Date</th>
                                                <th class="text-nowrap width-45">Leaving Date</th>
                                                <th class="text-nowrap width-45">Work Duration</th>
                                                <th class="text-nowrap width-45">Notice Period Days</th>
                                                <th hidden class="text-nowrap 49">EmployeeDepartmentID</th>
                                                <th hidden class="text-nowrap 49">EmployeeDesignationID</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetEmployeeInfoList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button type="button" data-bs-toggle="offcanvas"
                                                                href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn  btnpress ListBtn">
                                                            <i class="fa-solid fa-list"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-nowrap 1">@d.employeename</td>
                                                    <td class="text-nowrap 2">@d.employeeno</td>
                                                    <td hidden class="text-nowrap 3">@d.EmployeeId</td>
                                                    <td hidden class="text-nowrap 4">@d.CmpID</td>
                                                    <td hidden class="text-nowrap 5">@d.EmployeeBranchId</td>
                                                    <td class="text-nowrap 6">@d.CompanyName</td>
                                                    <td class="text-nowrap 7">@d.BusinessUnit</td>
                                                    <td class="text-nowrap 8">@d.gradename</td>
                                                    <td class="text-nowrap 9">@d.departmentname</td>
                                                    <td class="text-nowrap 10">@d.designationname</td>                                                  
                                                    <td class="text-nowrap 11">@d.PrimaryMobile</td>
                                                    <td class="text-nowrap 12">@d.joiningdate</td>
                                                    <td class="text-nowrap 13">@d.LastWorkingDate</td>
                                                    <td class="text-nowrap 14">@d.WorkDuration</td>
                                                    <td class="text-nowrap 15">@d.NoticePeriodDays</td>
                                                    <td hidden class="text-nowrap 50">@d.EmployeeDepartmentID</td>
                                                    <td hidden class="text-nowrap 50">@d.EmployeeDesignationID</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<!-- Start panel -->
<div class="row">
    <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false"
         data-bs-scroll=true>
        <div class="offcanvas-header" style="border-bottom: 1px solid #d3d3d38a;">
            <h6 class="offcanvas-title text-center" id="EmpName1"
                style="width: 100%;">
                <span id="EmpName">@Session["FNFEmployeeName"]</span>
            </h6>
            <button type="button" class="btn-close text-reset"
                    data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div class="row">
                @foreach (var item in ViewBag.GetUserMenuList)
                {
                    <div class="col-md-4 col-6 d-flex justify-content-center">
                        <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" style="text-decoration:none !important;">
                            <div class="box2">
                                <div class="info">
                                    <i class="@item.Icon"></i>
                                    <h7><b>@item.ScreenDisplayMenuName</b></h7>
                                    <div class="box2Checkmark">
                                        <i class="fa-regular fa-circle-check text-green FS-12PX" id="@($"{item.ScreenSourceMenuName}_Submit")"></i>
                                        <i class="fa-regular fa-circle-xmark text-red FS-12PX" id="@($"{item.ScreenSourceMenuName}_NotSubmit")"></i>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- END panel -->



<script>
    function EmployeeDetails(tblRow) {
        debugger;
        var currentRow = $(tblRow).closest("tr");
        var a = this.SetUpAddress;
        //var EmpId = currentRow.find("td:eq(3)").html();
        //var CmpId = currentRow.find("td:eq(4)").html();
        //var BranchId = currentRow.find("td:eq(5)").html();
        //var EmpName = currentRow.find("td:eq(1)").html();
        //var EmployeeNo = currentRow.find("td:eq(2)").html();
        //var EmpDesignation = currentRow.find("td:eq(9)").text(); 
        //var EmpDepartment = currentRow.find("td:eq(10)").html();
        //var EmpDoj = currentRow.find("td:eq(11)").html();
        //var EmpDepartmentId = currentRow.find("td:eq(15)").html();
        //var EmpDesignationId = currentRow.find("td:eq(16)").html();

        var EmpId = currentRow.find("td:eq(3)").text();
        var CmpId = currentRow.find("td:eq(4)").text();
        var BranchId = currentRow.find("td:eq(5)").text();
        var EmpName = currentRow.find("td:eq(1)").text();
        var EmployeeNo = currentRow.find("td:eq(2)").text();
        var EmpDesignation = currentRow.find("td:eq(9)").text(); // will show HR & Admin correctly
        var EmpDepartment = currentRow.find("td:eq(10)").text();
        var EmpDoj = currentRow.find("td:eq(12)").text();
        var EmpDepartmentId = currentRow.find("td:eq(16)").text();
        var EmpDesignationId = currentRow.find("td:eq(17)").text();


        $("#EmpName").html(EmpName);
        $.ajax({
            type: "GET",
            url: '@Url.Action("FNFCalculationForm", "ESS_FNF_FNFCalculation")',
            data: { EmpId: EmpId, CmpId: CmpId, BranchId: BranchId, EmpName: EmpName, EmpDoj: EmpDoj, EmpDepartment: EmpDepartment, EmpDesignation: EmpDesignation, EmployeeNo: EmployeeNo, EmpDepartmentId: EmpDepartmentId, EmpDesignationId: EmpDesignationId },
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                if (data == 0) {
                    $("#FNFDetails_NotSubmit").show();
                    $("#FNFDetails_Submit").hide();

                    $("#LeaveCalculation_NotSubmit").show();
                    $("#LeaveCalculation_Submit").hide();

                    $("#BonusCalculation_NotSubmit").show();
                    $("#BonusCalculation_Submit").hide();
                    
                    $("#SalaryCalculation_NotSubmit").show();
                    $("#SalaryCalculation_Submit").hide();

                    $("#GratuityCalculation_NotSubmit").show();
                    $("#GratuityCalculation_Submit").hide();

                    $("#TDSCalculation_NotSubmit").show();
                    $("#TDSCalculation_Submit").hide();

                    $("#Requisition_NotSubmit").show();
                    $("#Requisition_Submit").hide();

                    $("#UpdateManager_NotSubmit").show();
                    $("#UpdateManager_Submit").hide();

                    $("#AssetDetails_NotSubmit").show();
                    $("#AssetDetails_Submit").hide();

                    $("#Dues_NotSubmit").show();
                    $("#Dues_Submit").hide();

                    $("#AccessLock_NotSubmit").show();
                    $("#AccessLock_Submit").hide();
                }
                else
                {
                    var data = JSON.parse(response);
                    var FNFSetupFNFDetails = data[0][31].Value;
                    if (FNFSetupFNFDetails == true) {
                        $("#FNFDetails_Submit").show();
                        $("#FNFDetails_NotSubmit").hide();
                    }
                    else {
                        $("#FNFDetails_NotSubmit").show();
                        $("#FNFDetails_Submit").hide();
                    }

                    var FNFSetupLeaveCalculation = data[0][32].Value;
                    if (FNFSetupLeaveCalculation == true) {
                        $("#LeaveCalculation_Submit").show();
                        $("#LeaveCalculation_NotSubmit").hide();
                    }
                    else {
                        $("#LeaveCalculation_NotSubmit").show();
                        $("#LeaveCalculation_Submit").hide();
                    }

                    var FNFSetupBonusCalculation = data[0][33].Value;
                    if (FNFSetupBonusCalculation == true) {
                        $("#BonusCalculation_Submit").show();
                        $("#BonusCalculation_NotSubmit").hide();
                    }
                    else {
                        $("#BonusCalculation_NotSubmit").show();
                        $("#BonusCalculation_Submit").hide();
                    }

                    var FNFSetupSalaryCalculation = data[0][34].Value;
                    if (FNFSetupSalaryCalculation == true) {
                        $("#SalaryCalculation_Submit").show();
                        $("#SalaryCalculation_NotSubmit").hide();
                    }
                    else {
                        $("#SalaryCalculation_NotSubmit").show();
                        $("#SalaryCalculation_Submit").hide();
                    }
                 
                    var FNFSetupGratuityCalculation = data[0][35].Value;
                    if (FNFSetupGratuityCalculation == true) {
                        $("#GratuityCalculation_Submit").show();
                        $("#GratuityCalculation_NotSubmit").hide();
                    }
                    else {
                        $("#GratuityCalculation_NotSubmit").show();
                        $("#GratuityCalculation_Submit").hide();
                    }
                    var FNFSetupTDSCalculation = data[0][36].Value;
                    if (FNFSetupTDSCalculation == true) {
                        $("#TDSCalculation_Submit").show();
                        $("#TDSCalculation_NotSubmit").hide();
                    }
                    else {
                        $("#TDSCalculation_NotSubmit").show();
                        $("#TDSCalculation_Submit").hide();
                    }

                    var FNFSetupRequisition = data[0][37].Value;
                    if (FNFSetupRequisition == true) {
                        $("#Requisition_Submit").show();
                        $("#Requisition_NotSubmit").hide();
                    }
                    else {
                        $("#Requisition_NotSubmit").show();
                        $("#Requisition_Submit").hide();
                    }

                    var FNFSetupUpdateManager = data[0][38].Value;
                    if (FNFSetupUpdateManager == true) {
                        $("#UpdateManager_Submit").show();
                        $("#UpdateManager_NotSubmit").hide();
                    }
                    else {
                        $("#UpdateManager_NotSubmit").show();
                        $("#UpdateManager_Submit").hide();
                    }

                    var FNFSetupAssetDetails = data[0][39].Value;
                    if (FNFSetupAssetDetails == true) {
                        $("#AssetDetails_Submit").show();
                        $("#AssetDetails_NotSubmit").hide();
                    }
                    else {
                        $("#AssetDetails_NotSubmit").show();
                        $("#AssetDetails_Submit").hide();
                    }

                    var FNFSetupDues = data[0][40].Value;
                    if (FNFSetupDues == true) {
                        $("#Dues_Submit").show();
                        $("#Dues_NotSubmit").hide();
                    }
                    else {
                        $("#Dues_NotSubmit").show();
                        $("#Dues_Submit").hide();
                    }

                    var FNFSetupAccessLock = data[0][41].Value;
                    if (FNFSetupAccessLock == true) {
                        $("#AccessLock_Submit").show();
                        $("#AccessLock_NotSubmit").hide();
                    }
                    else {
                        $("#AccessLock_NotSubmit").show();
                        $("#AccessLock_Submit").hide();
                    }
                }
            }
        });
    }
</script>

