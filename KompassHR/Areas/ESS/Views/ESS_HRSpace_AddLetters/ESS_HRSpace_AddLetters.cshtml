    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* ✅ Fix: Table pasted from Word should show completely */
   
    /* --- FIX for table getting cut in Summernote --- */
.note-editable {
    overflow-x: auto !important;
    overflow-y: auto !important;
    white-space: normal !important;
    word-break: break-word !important;
    max-width: 100% !important;
    /*min-height: 400px !important;*/
}

/* BODY editor only */
#Letter_Description + .note-editor .note-editable {
    min-height: 400px !important;
}

/* HEADER editor */
#Letter_Header + .note-editor .note-editable {
    min-height: 100px !important;
}

/* FOOTER editor */
#Letter_Footer + .note-editor .note-editable {
    min-height: 100px !important;
}

.note-editable table {
    width: auto !important;
    max-width: none !important;
    border-collapse: collapse !important;
    table-layout: auto !important;
}

.note-editable table td,
.note-editable table th {
    border: 1px solid #000 !important;
    padding: 6px !important;
    white-space: normal !important;
    vertical-align: middle !important;
}

