<script>
    var Message = @Html.Raw(Json.Encode(TempData["Message"]));
    var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
    if (Message != null) {
        if (Icon != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    // return false
                }
            }).then(function() {
                window.location.reload();
            });
        }
    }
</script>



<script>
    // Helper function to format a Date object as 'YYYY-MM-DD'
    function formatToYYYYMMDD(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0'); // 0-based index
        const day = String(date.getDate()).padStart(2, '0'); // Always '01' here
        return `${year}-${month}-${day}`;
    }
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveLetter").validate({
        rules: {
            CmpId: {
                required: true,
            },
            HRSpace_letterMaster_Id: {
                required: true,
            },
            Letter_Description: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Please select company",
            },
            HRSpace_letterMaster_Id: {
                required: "Please select letter",
            },
            Letter_Description: {
                required: "Please enter description ",
            },
        },

    });
    //IsValidation Check
    var form = $("#SaveLetter");
    form.validate();
    $("#btnSubmit").click(function () {

        $("#CmpId").select2();
        $("#HRSpace_letterMaster_Id").select2();

        debugger;
        form.valid();
        if(form.valid()==false)
        {
            //$("#dateToDate").removeClass('error');
            return false;
        }
        var CmpId = $("#CmpId").val();
        var LetterId_Encrypted = $("#LetterId_Encrypted").val();
        var HRSpace_letterMaster_Id = $("#HRSpace_letterMaster_Id").val();
        $.ajax({
            url: "@Url.Action("IsLetterExists", "ESS_HRSpace_AddLetters")",
            method:"get",
            data: { CmpId: CmpId, LetterId_Encrypted: LetterId_Encrypted ,HRSpace_letterMaster_Id:HRSpace_letterMaster_Id},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveLetter").submit();
                }
            }
        });

    });
</script>
