<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Letters
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new {area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_HRSpace_LettersMenu", "ESS_HRSpace_LettersMenu", new { id = 41, ScreenId =668, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Letters - @ViewBag.AddUpdateTitle</h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define company-wise Letters here!
                    </p>
                </div>

                <div class="panel-body" style="height: 100% !important;">
                    <form role="form" action='@Url.Action("SaveUpdate", "ESS_HRSpace_AddLetters", new { area = "ESS" })' id="SaveLetter" method="post">
                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-2">
                                Company <span class="important">*</span>
                            </label>
                            <div class="col-md-8">
                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "CmpId" })
                                @Html.HiddenFor(model => model.LetterId_Encrypted, new { id = "LetterId_Encrypted" })
                            </div>
                        </div>

                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-2">
                                Letter <span class="important">*</span>
                            </label>
                            <div class="col-md-8">
                                @Html.DropDownListFor(model => model.HRSpace_letterMaster_Id, new SelectList(ViewBag.GetLetters, "Id", "Name"), "--Select--", new { @class = "form-select", id = "HRSpace_letterMaster_Id" })
                                @*@Html.TextBoxFor(model => model.LetterName, new { id = "LetterName", @class = "form-control", autocomplete = "off" })*@
                            </div>
                        </div>

                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-2">
                                Letter Header <span class="important">*</span>
                            </label>
                            <div class="col-md-8">
                                @Html.TextAreaFor(model => model.Letter_Header, new { @class = "summernote", id = "Letter_Header" })
                            </div>
                        </div>

                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-2">
                                Letter Body <span class="important">*</span>
                            </label>
                            <div class="col-md-8">
                                @Html.TextAreaFor(model => model.Letter_Description, new { @class = "summernote", id = "Letter_Description" })
                            </div>
                        </div>

                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-2">
                                Letter Footer <span class="important">*</span>
                            </label>
                            <div class="col-md-8">
                                @Html.TextAreaFor(model => model.Letter_Footer, new { @class = "summernote", id = "Letter_Footer" })
                            </div>
                        </div>

                        <!-- ✅ Added Checkbox Row -->
                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-2">
                                Send to Employee?
                            </label>
                            <div class="col-md-8">
                                <label class="form-check">
                                    @Html.CheckBoxFor(model=>model.IsSendToEmployee, new { @class = "form-check-input", id = "IsSendToEmployee" })
                                    <span class="form-check-label">Do you want to send this letter to the employee?</span>
                                </label>
                            </div>
                        </div>

                        <div class="text-center mt-3">
                            <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                <i class="fa-solid fa-floppy-disk"></i> Submit
                            </button>
                            <a href="@Url.Action("GetList", "ESS_HRSpace_AddLetters", new { area = "ESS" })" class="btn btn-danger btn-sm">
                                <i class="fa-solid fa-share-from-square"></i> List
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>




<script>
    $(".summernote").each(function () {
        debugger
       

        $(this).summernote({
            placeholder: '',
            fontNames: [
                'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New', 'Futura Md BT',
                'Georgia', 'Helvetica', 'Impact', 'Lucida Console',
                'Tahoma', 'Times New Roman', 'Trebuchet MS', 'Verdana',
                'Open Sans', 'Roboto', 'Lato', 'Montserrat', 'Poppins',
                'Calibri', 'Cambria', 'Garamond', 'Bookman', 'Candara'
            ],
            fontNamesIgnoreCheck: [
                'Open Sans', 'Roboto', 'Lato', 'Montserrat', 'Poppins'
            ],
            toolbar: [
                ['style', ['bold', 'italic', 'underline', 'clear']],
                ['font', ['fontsize', 'color']],
                ['fontname', ['fontname']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture']],
                ['view', ['fullscreen', 'codeview']]
            ],
            callbacks: {
                onPaste: function (e) {
                    var clipboardData = (e.originalEvent || e).clipboardData;
                    var htmlData = clipboardData.getData('text/html');
                    if (htmlData) {
                        e.preventDefault();
                        htmlData = htmlData.replace(/\swidth=(")?\d+(\.\d+)?(pt|px|%)?(")?/gi, '');
                        htmlData = htmlData.replace(/<table/gi, '<table style="width:auto;"');
                        document.execCommand('insertHTML', false, htmlData);
                    }
                }
            }
        });

    });


