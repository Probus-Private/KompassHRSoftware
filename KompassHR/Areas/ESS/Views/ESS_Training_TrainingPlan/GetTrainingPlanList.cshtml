    function ViewEmployeePending(TrainingCalenderId, Batch) {
        debugger;
        var url = '@Url.Action("ShowPendingEmployeeList", "ESS_Training_TrainingConduct")';
        $.getJSON(url, { TrainingCalenderId: TrainingCalenderId, Batch: Batch }, function (data) {
            debugger;
            const jsonData = JSON.parse(data);
            $('#EmployeeListModel').modal('show');
            
           
            $("#tbodyEmployeeList").empty();
            $.each(jsonData, function (index, item) {debugger;
                var icon = item.IsTrainingConduct
                ? '<i class="fas fa-check-circle fa-lg text-success"></i>'
                : '<i class="fas fa-times-circle fa-lg text-danger"></i>';
                var row = `<tr>
                                <td class="text-center">${item.SN}</td>
                                <td class="text-center">${icon}</td>
                                <td class="text-left">${item.EmployeeName}</td>
                                <td class="text-left">${item.DesignationName}</td>
                                <td class="text-left">${item.DepartmentName}</td>
                                <td class="text-right">${item.PrimaryMobile}</td>
                                <td class="text-left">${item.PersonalEmailId}</td>
                           </tr>`;
                $("#tbodyEmployeeList").append(row);
            });
        });
    }

    function DeleteTrainingPlan(TrainingPlan_MasterId) {debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Training_TrainingPlan")?TrainingPlan_MasterId=' + TrainingPlan_MasterId;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>
