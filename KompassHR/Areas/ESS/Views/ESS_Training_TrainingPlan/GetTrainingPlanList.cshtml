        var url = '@Url.Action("ShowEmployeeList", "ESS_Training_TrainingPlan")';
        $.getJSON(url, { TrainingCalenderId: TrainingCalenderId, Batch: Batch }, function (data) {
            debugger;
            const jsonData = JSON.parse(data);
            $('#EmployeeListModel').modal('show');
            $("#dynamictitle").html(ListType + '-' + "List");
            //$('#tblEmployeeList tr').not(function(){ return !!$(this).has('th').length; }).remove();
            // Destroy previous instance if exists
