@model KompassHR.Areas.Reports.Models.DailyAttendanceReportFilter
@{
    ViewBag.Title = "ESS_TimeOffice_Pending_AttenRegularization";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>



<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>



<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/ESS/ESS_TimeOffice_Menu/ESS_TimeOffice_Menu/?id=5">Attendance Menu</a></li>
    </ol>
    <h1 class="page-header"> Pending Employee For Attendance Regularization </h1>



    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Pending Employee For Attendance Regularization</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row">
                            <div class="col-md-12">
                                <form role="form" action="/ESS/ESS_TimeOffice_Pending_AttenRegularization/ESS_TimeOffice_Pending_AttenRegularization" id="SavePendingAttenRegularization" method="post">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    Company Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-9">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), new { @class = "form-select", id = "txtCmpId", type = "text", name = "CmpId" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    Business Unit
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-9">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), new { @class = "form-select", id = "txtBranchId", type = "text", name = "BranchId" })
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    From date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-9">
                                                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", id = "txtFromDate", type = "date", name = "FromDate" })
                                                    <span id="ErrortxtFromDate" class="Error"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    To Date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-7">
                                                    @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", id = "txtToDate", type = "date", name = "ToDate" })
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployee()">
                                                        Show
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        @*<div class="col-md-2">
                                                <div class="row mb-15px">
                                                    <div class="col-md-4">
                                                        <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployee()">
                                                            Show
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>*@
                                    </div>
                                </form>
                                <div class="row">
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="tbl" style="width: 100%;">
                                                <thead>
                                                    <tr class="trheading">
                                                        <th class="text-nowrap text-center">Get Detail</th>
                                                        <th class="text-nowrap text-center">Attendance Date</th>
                                                        <th class="text-nowrap text-center"> Employee Count</th>
                                                        <th class="text-nowrap text-center">Regularized Employee Count</th>
                                                        <th class="text-nowrap text-center">Regularized Employee Percentage</th>
                                                        <th class="text-nowrap text-center">Pending Employee Count</th>
                                                        <th class="text-nowrap text-center">Pending Employee Percentage</th>


                                                    </tr>
                                                </thead>
                                                <tbody id="tblAbnormalReport">
                                                    @foreach (var d in ViewBag.PendingAttenRegularization)
                                                    {
                                                        <tr>
                                                            <td class="text-nowrap text-center">
                                                                @if (d.Detail == "Detail")
                                                                {
                                                                    <button type="button" id="btnDelete" onclick="DetailEmployee('@d.AttendanceDate')"
                                                                            class="btn btn-warning btnpress ListBtn">
                                                                        <i class="fa-solid fa-eye"></i>
                                                                    </button>

                                                                }
                                                                else
                                                                {
                                                                    <a type="button" class="btn btn-success ListBtn btnpress" href="~/ESS/ESS_Recruitment_ResourcesRequisition/DownloadFile?ResourceRequest=@d.AttachFile" download>
                                                                        <i class="fa-solid fa-download"></i>
                                                                    </a>
                                                                }
                                                            </td>
                                                            <td class="text-nowrap">@d.AttendanceDate</td>
                                                            <td class="text-nowrap">@d.EmployeeCount</td>
                                                            <td class="text-nowrap">@d.RegularizedEmployeeCount</td>
                                                            <td class="text-nowrap">@d.RegularizedEmployeePercentage</td>
                                                            <td class="text-nowrap">@d.PendingEmployeeCount</td>
                                                            <td class="text-nowrap">@d.PendingEmployeePercentage</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#txtBranchId").select2();
        $("#txtCmpId").select2();

        var CheckEmptyDate = document.getElementById('txtFromDate').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtFromDate').value = SetTodaysDate;
            document.getElementById('txtToDate').value = SetTodaysDate;
        }

        $("#txtCmpId").on("change", function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#txtCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        //$("#txtBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#txtFromDate, #txtToDate").on("change", function () {
            debugger;
            var input = document.getElementById("txtFromDate").value;
            var input1 = document.getElementById("txtToDate").value;
            //define two date object variables with dates inside it
            fromDateObj = new Date(input);
            toDateObj = new Date(input1);
            //calculate time difference
            var time_difference = toDateObj.getTime() - fromDateObj.getTime();
            //calculate days difference by dividing total milliseconds in a day
            var days_differences = time_difference / (1000 * 60 * 60 * 24);
            var days_difference = days_differences + 1;
            // Check if toDate is greater than fromDate
            var from = $("#txtFromDate").val();
            var to = $("#txtToDate").val();
            if (Date.parse(from) > Date.parse(to)) {

                $("#ErrortxtFromDate").html("From date should not be greater than todate");
                return false;
            }
            else {
                $("#ErrortxtFromDate").html("");
            }
            if (days_difference > 31) {
                $("#ErrortxtFromDate").html("You should not allow greter than 31 days");
            }
        });

    })



    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SavePendingAttenRegularization').validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },

        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            BranchId: {
                required: "Business unit is required",
            },
            FromDate: {
                required: "From date is required",
            },
            ToDate: {
                required: "To date is required",
            },


        },
    });

    var form = $("#SavePendingAttenRegularization");
    form.validate();
    function LoadEmployee() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#txtToDate").removeClass("error");
            $("#txtFromDate").removeClass("error");
            return false;
        }
        $("#SavePendingAttenRegularization").submit();
    }




    function DetailEmployee(AttendanceDate) {
        var BranchId = $("#txtBranchId").val();
        var url = '@Url.Action("PendingEmployeeDetails", "ESS_TimeOffice_Pending_AttenRegularization")?AttendanceDate=' + AttendanceDate + '&BranchId=' + BranchId;
        window.location.href = url;

    }
</script>

