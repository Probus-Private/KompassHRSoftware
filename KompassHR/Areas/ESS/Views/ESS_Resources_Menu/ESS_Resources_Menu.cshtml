
@{
    ViewBag.Title = "ESS_Resources_Menu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .box {
        width: 100px;
        height: 100px;
        backdrop-filter: blur(25px) saturate(00%);
        background-color: rgba(255, 255, 255, 1);
        border-radius: 12px;
        border: 3px solid rgba(255, 255, 255, 1);
        margin: 5px;
        box-shadow: inset 0 15px 25px rgba(0, 0, 0, 0.03), inset 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
    }

        .box:hover {
            /* BORDER:2PX SOLID #666; */
            border: 2px solid #007bff;
            cursor: pointer;
            transform: translateY(-4px);
        }


        .box .info i {
            font-size: 18px;
            width: 100%;
            text-align: center;
            margin-bottom: 15px;
            color: #007bff;
        }

        .box :hover.INFO i,
        .box:hover .info h7 {
            COLOR: #000;
        }

        .box .info h7 {
            font-size: 11px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .Col-md-2 {
        margin: 10px 0;
    }
</style>





<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Resource Requisition </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-lg-6 col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Menu </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        
                          
                    </div>
                </div>
                <div class="panel-body" style="max-height: fit-content; background: #f5f8ff;">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-3 col-6 d-flex justify-content-center">
                                    <div class="box">
                                        <a href="/ESS/ESS_Resources_Recruitment/ESS_Resources_Recruitment"
                                           style="text-decoration: none; color: #000;">
                                            <div class="info">
                                                <i class="fa-solid fa-file-signature"></i>
                                                <h7><b>Recruitment</b></h7>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



