</div>



  <!-- Action Taken on Ticket Modal -->

<div class="modal fade" id="actionModal" tabindex="-1" aria-labelledby="actionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="actionModalLabel">
                    <i class="fa-solid fa-clipboard-check me-2"></i> Action Taken
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="info-block">
                    <strong><h5><i class="fa-solid fa-ticket me-2 text-primary"></i> Ticket ID</h5></strong>
                    <p id="modal-ticket-id" class="text-muted mb-0">-</p>
                </div>

                <div class="info-block">
                    <strong><h5><i class="fa-solid fa-calendar-day me-2 text-warning"></i> Resolution Date</h5></strong>
                    <p id="modal-date" class="text-muted mb-0">-</p>
                </div>

                <div class="info-block">
                    <strong><h5><i class="fa-solid fa-circle-check me-2 text-success"></i> Resolution Result</h5></strong>
                    <p id="modal-result" class="text-muted mb-0">-</p>
                </div>

                <div class="info-block">
                    <strong><h5><i class="fa-solid fa-comments me-2 text-info"></i> Resolution Comment</h5></strong>
                    <p id="modal-comment" class="text-muted mb-0">-</p>
                </div>                
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark me-1"></i> Close
                </button>
            </div>

        </div>
    </div>
</div>





<script>
    function fillActionModal(id, result, comment, date) {
        debugger
        // Remove old stuck backdrops (safety)
        document.querySelectorAll('.modal-backdrop').forEach(e => e.remove());

        document.getElementById("modal-ticket-id").textContent = id || "-";
        document.getElementById("modal-result").textContent = result || "-";
        document.getElementById("modal-comment").textContent = comment || "-";
        document.getElementById("modal-date").textContent = date || "-";

        var modal = new bootstrap.Modal(document.getElementById("actionModal"));
        modal.show();
    }
</script>

