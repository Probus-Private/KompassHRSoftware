<script>

    $(document).ready(function () {

        document.getElementById("txtFromDate").addEventListener("blur", function () {
            debugger
            var dateValue = this.value;

            if (dateValue.includes("-")) {
                var parts = dateValue.split("-"); 
                dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
            }
            var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
            if (!regex.test(dateValue)) {
                $("#ErrortxtFromDate").html("Please enter valid date in DD-MM-YYYY format");
                this.value = "";
                this.focus();
                return;
            } else {
                $("#ErrortxtFromDate").html("");
            }
        });

        document.getElementById("txtToDate").addEventListener("blur", function () {
            debugger
            var dateValue = this.value;

            if (dateValue.includes("-")) {
                var parts = dateValue.split("-"); 
                dateValue = parts[2] + "-" + parts[1] + "-" + parts[0];
            }
            var regex = /^(0[1-9]|[12][0-9]|3[01])-(0[1-9]|1[0-2])-(19|20)\d\d$/;
            if (!regex.test(dateValue)) {
                $("#ErrortxtToDate").html("Please enter valid date in DD-MM-YYYY format");
                this.value = "";
                this.focus();
                return;
            } else {
                $("#ErrortxtToDate").html("");
            }
        });


        //Validation for back day days
        @*var BackDatedDays = @Html.Raw(Json.Encode(ViewBag.GetBackDatedDays));
        var fromDateInput = document.getElementById("txtFromDate");
        var toDateInput = document.getElementById("txtToDate");
        var currentDate = new Date();
        var minDate = new Date();
        minDate.setDate(currentDate.getDate() - BackDatedDays);
        var minDateString = minDate.toISOString().split('T')[0];
        fromDateInput.setAttribute("min", minDateString);
        toDateInput.setAttribute("min", minDateString);*@
        //End Validation for back day days
        $("#ddlShift").select2();
        $("#ddlEmployeeID").select2();

        document.querySelector('#txtDocNo').style.backgroundColor = '#e9ecef';
        document.querySelector('#txtTotalDuration').style.backgroundColor = '#e9ecef';
        document.querySelector('#txtTotalDays').style.backgroundColor = '#e9ecef';
        $("#ddlDirecation").prop("disabled", true);
        $("#txtTotalMinutes").prop("disabled", true);
        $("#txtFromTime").attr('readOnly', true);
        $("#txtToTime").attr('readOnly', true);
        document.querySelector('#txtFromTime').style.backgroundColor = '#eee';
        document.querySelector('#txtToTime').style.backgroundColor = '#eee';
      
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
      
        $('#ddlEmployeeID').change(function () {
            $("#ddlShift").find("option").remove();
            var EmployeeID=$("#ddlEmployeeID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeShift", "ESS_ContractorAttendance_OutDoor")',

                data: { EmployeeID: EmployeeID },
                success: function (data) {
                    debugger;
                    var ddlShift=data.GetShiftList;
                    var GetEmployeeNameShort=data.GetEmployeeNameShort;
                    localStorage.setItem("OutDoorCompanyShortPeriod", GetEmployeeNameShort[0].Value);
                    localStorage.setItem("OutDoorCompanyIstHalfDuration", GetEmployeeNameShort[1].Value);
                    localStorage.setItem("OutDoorCompanyIIndHalfDuration", GetEmployeeNameShort[2].Value);
                    localStorage.setItem("OutDoorCompanyFullDayDuration", GetEmployeeNameShort[3].Value);
                    if (data == false) {
                        $("#ddlShift").find("option").remove();
                        $("#ddlShift").append("<option value=''>All </option>");
                    }
                    else {
                        if (ddlShift != null) {
                            $("#ddlShift").append("<option value=''>--Select-- </option>");
                            $.each(ddlShift, function (i, p) {
                                $("#ddlShift").append("<option value='" + p.ShiftId + "'>" + p.ShiftName + "</option>");
                            });
                        }
                    }
                }
            })
        });




        $("#btnGetList").click(function () {
            var url = '@Url.Action("ESS_ContractorAttendance_GetList", "ESS_ContractorAttendance_OutDoor")';
            window.location.href = url;
        })
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];

        var BeforeTime;
        var BeforeDuration;
        $('#OutDoorCompanyType').change(function () {
            debugger;
            $("#ddlDirecation").val(null);
            var SelectedDay = $('#OutDoorCompanyType').val();
            var FromTime = $("#txtFromTime").val();
            var ToTime = $("#txtToTime").val();
            //Ask Time Diff Code Start
            $.ajax({
                type: "Get",
                url: "GetTotalDuration",
                data: { FromTime:FromTime , ToTime:ToTime},
                dataType: "text",
                success: function (data) {
                    debugger;
                    var a = JSON.parse(data);
                    var GetnewTime = a.data.Hours*60 + a.data.Minutes;
                    $('#txtTotalDuration').val(GetnewTime);
                    var TotalTime = $('#txtTotalMinutes').val();
                    var GetTotalTime=TotalTime.replaceAll("Min", "");
                    var SetTotalTime =Number(GetTotalTime);
                    if(GetnewTime>SetTotalTime)
                    {
                        $("#ErrortxtTotalDuration").html("Total duration not greater than : " + TotalTime );
                        return false;
                    }
                    else{
                        $("#ErrortxtTotalDuration").html("");
                    }
                }
            });

            var SelectedDay = $('#OutDoorCompanyType').val();
           
            var Duration = localStorage.getItem("OutDoorCompanyShortPeriod");
            var IstHalfDuration = localStorage.getItem("OutDoorCompanyIstHalfDuration");
            var IIndHalfDuration = localStorage.getItem("OutDoorCompanyIIndHalfDuration");
            var FullDayDuration = localStorage.getItem("OutDoorCompanyFullDayDuration");

            @*var Duration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyShortHrs));
            var IstHalfDuration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyIstHalfDuration));
            var IIndHalfDuration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyIIndHalfDuration));
            var FullDayDuration = @Html.Raw(Json.Encode(ViewBag.OutDoorCompanyFullDayDuration));*@
            if(SelectedDay == "Full Day" )
            {
                debugger;
                var ShiftId = $("#ddlShift").val();
                //$("#txtToDate").prop("disabled", false);
                $("#txtToDate").prop("readonly", false);
                $.ajax({
                    async: true,
                    type: 'GET',
                    dataType: 'JSON',
                    contentType: 'application/json; charset=utf-8',
                    url: 'OutDoorType',
                    data: { DayType:"Full Day",ShiftId: ShiftId },
                    success: function (data){
                        debugger;
                        var SetData = Object.values(data[0]);

                        $('#txtFromTime').val(SetData[0].Value);
                        $('#txtToTime').val(SetData[1].Value);
                        BeforeTime=SetData[1].Value;
                        //localStorage.setItem('Obj',BeforeTime)
                        $('#txtTotalDuration').val(SetData[2].Value);
                        BeforeDuration=SetData[2].Value;

                        //Ashafak Added
                        var TotalTime = $('#txtTotalMinutes').val();
                        var GetTotalTime=TotalTime.replaceAll("Min", "");
                        var SetTotalTime =Number(GetTotalTime);
                        var TotalDuration = $('#txtTotalDuration').val();
                        if(TotalDuration>SetTotalTime)
                        {
                            $("#ErrortxtTotalDuration").html("Total duration not greater than : " + TotalTime );
                            return false;
                        }
                        else{
                            $("#ErrortxtTotalDuration").html("");
                        }
                        // $('#txtTotalDuration').val(b);
                    },
                });
                $("#txtTotalDays").val('1')
                $("#txtFromDate").val(dateString);
                $("#txtToDate").val(dateString);
                $("#txtTotalMinutes").val(FullDayDuration + ' Min');
                document.querySelector('#txtToDate').style.backgroundColor = '';
                $("#ddlDirecation").prop("disabled", true);
                //$("#txtTotalMinutes").prop("readOnly", true);
               // document.querySelector('#txtTotalMinutes').style.backgroundColor = '#eee';
                $("#txtToDate").attr('readOnly', false);
