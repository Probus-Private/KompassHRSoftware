                                            </div>
                                        </div>
                                    </div>
                                   
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3" style="width:12.5%;">Reason <span class="important">*</span></label>
                                            <div class="col-md-9" style="width:87.5%">
                                                @Html.TextAreaFor(model => model.Reason, new { @name = "Reason", @class = "form-control", @id = "txtReason", rows = "2" })
                                            </div>
                                        </div>
                                    </div>
