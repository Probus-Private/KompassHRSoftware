                                                @Html.TextBoxFor(model => model.ToTime, new { @name = "ToTime", @class = "form-control", @id = "txtToTime", type = "time" })
                                                @Html.ValidationMessageFor(model => model.ToTime, "", new { @class = "help-block", id = "ErrortxtToTime", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">Total Duration (Min)</label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.TotalDuration, new { @name = "TotalDuration", @class = "form-control", @id = "txtTotalDuration", type = "text", @readonly = "readonly" })
                                                @Html.ValidationMessageFor(model => model.TotalDuration, "", new { @class = "help-block", id = "ErrortxtTotalDuration", @style = "color:red" })
