</div>

<script>
    $(document).ready(function () {
    debugger
  var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
        if (Message != null) {
        Swal.fire({
        icon: Icon,
        text: Message,
        allowOutsideClick: () => {
        const popup = Swal.getPopup()
        popup.classList.remove('swal2-show')
        setTimeout(() => {
        popup.classList.add('animate__animated', 'animate__headShake')
        })
        setTimeout(() => {
        popup.classList.remove('animate__animated', 'animate__headShake')
        }, 500)
        return false
        }
        });
        }
        }

      });
</script>

<script>

    function UpdateLoan(TravelPlanID_Encrypted) {
        var url = '@Url.Action("TravelApproval", "ESS_Travel_ManagerApprovalTravel")?TravelPlanID_Encrypted=' + TravelPlanID_Encrypted;
            window.location.href = url;
    }
    function Accomodation(AccomodationPlanID_Encrypted) {
        var url = '@Url.Action("AccomodationApproval", "ESS_Travel_ManagerApprovalTravel")?AccomodationPlanID_Encrypted=' + AccomodationPlanID_Encrypted;
            window.location.href = url;
    }
    function LocTrans(LocalTranPlanID_Encrypted) {
        var url = '@Url.Action("LocTransportApproval", "ESS_Travel_ManagerApprovalTravel")?LocalTranPlanID_Encrypted=' + LocalTranPlanID_Encrypted;
        window.location.href = url;
    }
</script>


