                                                        <i class="fa-solid fa-pencil-alt"></i>
                                                    </button>
                                                </td>
                                              
                                                <td hidden class="text-nowrap">@d.LTPlanEmployeeId</td>
                                                <td hidden class="text-nowrap">@d.TravelCalenderID</td> 
                                                <td class="text-nowrap">@d.PlanType</td>
                                                <td class="text-nowrap">@d.Mode</td>
                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                <td class="text-nowrap">@Convert.ToDateTime(d.StartDate).ToString("yyyy-MM-dd")</td>
                                                <td class="text-nowrap">@Convert.ToDateTime(d.EndDate).ToString("yyyy-MM-dd")</td>
                                                <td class="text-nowrap">@d.StartLocation</td>
                                                <td class="text-nowrap">@d.EndLocation</td>
                                                <td class="text-nowrap">@d.Note</td>
                                                <td class="text-nowrap">@d.BookingType</td>
                                                <td class="text-nowrap">@d.BookingStatus</td>
                                                <td class="text-nowrap">@d.CancelPlanDescription</td>
                                                <td class="text-nowrap">@d.RejectionRemark</td>
                                            </tr>
                                        }
    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
