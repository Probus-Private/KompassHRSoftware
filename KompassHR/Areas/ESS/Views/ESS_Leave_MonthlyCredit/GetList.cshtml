@model KompassHR.Areas.ESS.Models.ESS_Leave.LeaveMonthlyCredit
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Monthly Credit List
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Leave Monthly Credit - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Monthly Credit.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("GetList", "ESS_Leave_MonthlyCredit", new { area = "ESS" })' id="SaveMainForm" method="post">
                        <div class="row">
                            <div class="col-md-5">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Company
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyName, "Id", "Name"), "--Select--", new { id = "txtCmpID", name = "CmpId", @class = "form-select", autocomplete = "off" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                       Month/Year
                                        <spaMonthn class="important">*</spaMonthn>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.TextBoxFor(model => model.MonthYear, new { id = "txtMonthYear", type = "Month", name = "MonthYear", @class = "form-control" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="row mb-15px">
                                    <div class="col-md-8">
                                        <button type="button" class="btn btn-primary btn-sm  mb-10px" onclick="SaveForm()">
                                            Show
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_Leave_MonthlyCredit", "ESS_Leave_MonthlyCredit", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp;  Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="tblSelectAllCheckbox"
                                           style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th class="text-nowrap">Delete</th>
                                                <th class="text-nowrap">Company Name</th>
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Leave Type Name </th>
                                                <th class="text-nowrap">No.Of Leaves </th>
                                                @*<th class="text-nowrap">Leave Group Name </th>*@
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.OpneingBalancelist)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <i class="fa-solid fa-trash-alt fa-lg" style="color: red; cursor: pointer;" onclick="Delete('@d.LeaveOpeningBalanceId')"></i>
                                                        @*<button type="button" id="DeleteBtn" onclick="Delete('@d.LeaveOpeningBalanceId')" class="btn btn-danger ListBtn btnpress">
                                                                <i class="fa-solid fa-trash-alt fa-lg" onclick="Delete('@d.LeaveOpeningBalanceId')"></i>
                                                            </button>*@
                                                    </td>
                                                    <td>@d.CompanyName</td>
                                                    <td>@d.EmployeeName</td>
                                                    <td>@d.LeaveType</td>
                                                    <td>@d.NoOfLeave</td>
                                                    @*<td>@d.LeaveGroupName</td>*@
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->

        </div>
    </div>
</div>


<script>
    jQuery.validator.addMethod(
   "regex",
         function (value, element, regexp) {
             if (regexp.constructor != RegExp)
                 regexp = new RegExp(regexp);
             else if (regexp.global)
                 regexp.lastIndex = 0;
             return this.optional(element) || regexp.test(value);
         }, "erreur expression reguliere"
 );

    $("#SaveMainForm").validate({
        rules: {
            CmpId: {
                required: true,
            },
            MonthYear: {
                required: true,
            },

        },
        messages: {
            CmpId: {
                required: "Company name is required"
            },
            MonthYear: {
                required: "Leave type is required",
            },
        },
        errorPlacement: (error, element) => 
            element.hasClass("select2-hidden-accessible") 
                ? error.insertAfter(element.next('.select2')) 
                : error.insertAfter(element)

    });

    var form = $("#SaveMainForm");
    form.validate();
    function SaveForm() {
        debugger;
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
        }
        $("#SaveMainForm").submit();
    }
</script>

<script>
    $(document).ready(function ()
    {
        $("#txtCmpID").select2();
        $("#ddlLeaveSettingId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message) { Swal.fire({ icon: Icon, text: Message, allowOutsideClick: false })
           .then(() => location.reload());}
    });
</script>

<script>
    function Delete(LeaveOpeningBalanceId) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick:false

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Leave_MonthlyCredit")?LeaveOpeningBalanceId=' + LeaveOpeningBalanceId;
            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {
            }
        })
    }
</script>