<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Contractor Shift Change
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ContractorAttendance_Menu", "ESS_ContractorAttendance_Menu",  new { id = 27,ScreenId=333, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Contractor Shift Change - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>


                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Locate the specific shift for which you want to change the description.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form action="/ESS/ESS_ContractorAttendance_ShiftChange/SaveUpdateShiftChange" id="saveShiftChange" method="post" enctype="multipart/form-data">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        @Html.HiddenFor(model => Model.ShiftChangeID)
                                        @Html.HiddenFor(model => Model.ShiftChangeID_Encrypted, new { id = "ShiftChangeID_Encrypted" })
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => Model.DocNo, new { @class = "form-control mb-5px", id = "DocNo", name = "DocNo", @readonly = "readonly", Value = @ViewBag.DocNo.DocNo, @style = "Background-Color :#eee" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">Employee Name <span class="important">*</span></label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ShiftChangeEmployeeid, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeId", name = "ShiftChangeEmployeeid", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label label class="form-label col-form-label col-md-4">
                                                Shift Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ShiftChangeShiftId, new SelectList(ViewBag.GetShiftList, "ShiftId", "ShiftName"), "--Select--", new { id = "ddlShiftNameId", name = "ShiftNameId", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromDate, new { name = "FromDate", @class = "form-control", id = "txtFromDate", type = "date" })
                                                <span id="ErrortxtFromDate" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new { name = "ToDate", @class = "form-control", id = "txtToDate", type = "date" })
                                                <span id="ErrortxtToDate" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label label class="form-label col-form-label col-md-2">
                                                Reason
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.ShiftChangeReason, new { name = "ShiftChangeReason", @class = "form-control", id = "txtShiftChangeReason" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("ESS_ContractorAttendance_GetList", "ESS_ContractorAttendance_ShiftChange", new { area = "ESS" })">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm" id="btnShiftChangeGetList">
                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger;
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#txtToDate").val(dateString);
        $("#txtFromDate").val(dateString);
        $("#ddlEmployeeId").select2();
        $("#ddlShiftNameId").select2();

        $("#ddlEmployeeId").change(function(){
            var EmployeeID=$("#ddlEmployeeId").val();
            $("#ddlShiftNameId").find("option").remove();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeShift", "ESS_ContractorAttendance_ShiftChange")',
                data: { EmployeeID: EmployeeID },
                success: function (data) {
                    debugger;
                    if (data == false) {
                        $("#ddlShiftNameId").find("option").remove();
                        $("#ddlShiftNameId").append("<option value=''>All </option>");
                    }
                    else {
                        if (data != null) {
                            $("#ddlShiftNameId").append("<option value=''>--Select-- </option>");
                            $.each(data, function (i, p) {
                                $("#ddlShiftNameId").append("<option value='" + p.ShiftId + "'>" + p.ShiftName + "</option>");
                            });
                        }
                    }
                }
            })
        })
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

    });//Ready Funcation
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       debugger;
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#saveShiftChange").validate({

        rules: {
            FromDate: {
                required: true,

            },
            ToDate: {
                required: true,

            },
            ShiftChangeEmployeeid: {
                required:true,
            },
            ShiftChangeShiftId: {
                required: true,

            },
            ShiftChangeReason: {
                required:true,
            },


        },
        messages: {

            FromDate: {
                required: "From date is required",

            },
            ToDate: {
                required: "To date is required",

            },
            ShiftChangeEmployeeid: {
                required: "Employee name is required",
            },
            ShiftChangeShiftId: {
                required: "Shift name is required",

            },
            ShiftChangeReason: {
                required: "Reason is required",
            },


        }
    });

    //<-----------------------------Alreay exist---------------------------------->
    var form=$("#saveShiftChange");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtFromDate").removeClass('error');
            $("#txtToDate").removeClass('error');
            return false;
        }
        
        var FromDate = $("#txtFromDate").val();
        var ToDate = $("#txtToDate").val();

        if ($("#txtFromDate").val() && $("#txtToDate").val()) {
            if (ToDate < FromDate) {
                $("#ErrortxtToDate").html("To Date should not be earlier than From Date!").css("color", "red");
                $("#txtToDate").val(""); // Clear the invalid date
                return false;
            } else {
                $("#ErrortxtToDate").html(""); // Clear the error message if valid
            }
        }

        var ShiftChangeId_Encrypted = $("#ShiftChangeId_Encrypted").val();
        var ShiftChangeEmployeeId = $("#ddlEmployeeId").val();
        $(".Userloaderbg").css("display","flex");
        $.ajax({
            url:'@Url.Action("IsWorkerShiftChangeExists", "ESS_ContractorAttendance_ShiftChange")',
            method:"get",
            data:{ShiftChangeEmployeeId:ShiftChangeEmployeeId,FromDate:FromDate,ToDate:ToDate,ShiftChangeId_Encrypted:ShiftChangeId_Encrypted},
            success:function(response){
                debugger;

                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    return false;
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            })
                            $(".Userloaderbg").css("display","none");
                        }
                    }
                    return false;
                }
                else{
                    $(".Userloaderbg").css("display","flex");
                    $("#saveShiftChange").submit();

                }
            }
        });

    });
</script>

