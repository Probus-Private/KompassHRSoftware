
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<style>
    .width-45 {
        width: 45px !important;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }
    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->   
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="/ESS/ESS_WorkForce_Menu/ESS_WorkForce_Menu/?id=29">Fine & Penalty Menu</a></li>
    </ol>

    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Fine/Penalty </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Fine/Penalty - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of fines/ penalty levied.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="/ESS/ESS_FineAndDamage_Fine/ESS_FineAndDamage_Fine">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle" id="fixed-header"
                                                   style="width: 100%;">
                                                <thead>
                                                    <tr>
                                                        <th class="text-nowrap">Update</th>
                                                        <th class="text-nowrap">Delete</th>
                                                        <th class="text-nowrap">Doc No. </th>
                                                        <th class="text-nowrap">Doc Date </th>
                                                        <th class="text-nowrap">Employee Name </th>
                                                        <th class="text-nowrap">Penalty Amount </th>
                                                        <th class="text-nowrap">Description </th>
                                                        <th class="text-nowrap">Deduction Month  </th>
                                                        <th class="text-nowrap">Created By</th>
                                                        <th class="text-nowrap">Created Date </th>
                                                        <th class="text-nowrap">Modified By</th>
                                                        <th class="text-nowrap">Modified Date </th>
                                                        <th class="text-nowrap">Machine Name</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var d in ViewBag.GetFinePenaltyList)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <button type="button" onclick="UpdateFine('@d.PenaltyID_Encrypted')" id="UpdateBtn"
                                                                        class="btn btn-success btnpress ListBtn">
                                                                    <i class="fa-solid fa-pencil-alt"></i>
                                                                </button>
                                                            </td>
                                                            <td class="text-center">
                                                                <button type="button" onclick="DeleteFine('@d.PenaltyID_Encrypted')" id="DeleteBtn"
                                                                        class="btn btn-danger ListBtn btnpress">
                                                                    <i class="fa-solid fa-trash-alt"></i>
                                                                </button>
                                                            </td>
                                                            <td>@d.DocNo</td>
                                                            <td>@d.DocDate</td>
                                                            <td>@d.EmployeeName</td>
                                                            <td style="text-align:right">@d.PenaltyAmount</td>
                                                            <td>@d.PenaltyDescription</td>
                                                            <td>@d.DeductionMonth</td>
                                                            <td>@d.CreatedBy</td>
                                                            <td>@d.CreatedDate</td>
                                                            <td>@d.ModifiedBy</td>
                                                            <td>@d.ModifiedDate</td>
                                                            <td>@d.MachineName</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    function UpdateFine(PenaltyID_Encrypted) {
        var url = '@Url.Action("ESS_FineAndDamage_Fine", "ESS_FineAndDamage_Fine")?PenaltyID_Encrypted=' + PenaltyID_Encrypted;
        window.location.href = url;
    }

    function DeleteFine(PenaltyID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_FineAndDamage_Fine")?PenaltyID_Encrypted=' + PenaltyID_Encrypted;
                //window.location.href = url;
                DeleteButtons.fire(
                    'Deleted!',
                    'Your file has been deleted.',
                    'success'
                )
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

