@model KompassHR.Areas.ESS.Models.ESS_FineAndDamage.Payroll_FineAndPenalty
@{
    ViewBag.Title = "ESS_FineAndDamage_Fine";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>


<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->  
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="/ESS/ESS_WorkForce_Menu/ESS_WorkForce_Menu/?id=29">Fine & Penalty Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Fine/Penalty </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Fine/Penalty - <b>@ViewBag.AddUpdateTitle</b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define fine deductions here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/ESS/ESS_FineAndDamage_Fine/SaveUpdate" id="SaveFine" method="post">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.                                           
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNo", type = "text", id = "txtDocNo", autocomplete = "Off", @readonly = "readonly", Value = @ViewBag.DocNo.DocNo, Style = "background-color: #eee;" })
                                                @Html.HiddenFor(model => model.PenaltyID_Encrypted, new { id = "PenaltyID_Encrypted" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", type = "date", id = "dateDocDate", Name = "DocDate" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.PenaltyEmployeeID, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "--Select--", new { id = "ddlPenaltyEmployeeID", @class = "form-select", autocomplete = "off", name = "PenaltyEmployeeID" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Penalty Amount
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PenaltyAmount, new { @class = "form-control", type = "text", id = "PenaltyAmount", autocomplete = "Off", Name = "PenaltyAmount", @style = "text-align:right", onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>                                   
                                </div>

                                <div class="row mb-15px"> 
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Deduction Month
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DeductionMonth, new { @class = "form-control", type = "date", id = "txtDeductionMonth", autocomplete = "Off", Name = "DeductionMonth" })
                                            </div>
                                        </div>
                                    </div>
                                                                       
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.PenaltyDescription, new { @class = "form-control", type = "text", id = "txtPenaltyDescription", autocomplete = "Off", Name = "PenaltyDescription" })
                                            </div>
                                        </div>
                                    </div>
                                </div>       
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">
                                                    Last Record :
                                                    <span>@ViewBag.LastRecored</span>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnFineGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
        //use for add regex function
        jQuery.validator.addMethod(
      "regex",
       function(value, element, regexp) {
           if (regexp.constructor != RegExp)
               regexp = new RegExp(regexp);
           else if (regexp.global)
               regexp.lastIndex = 0;
           return this.optional(element) || regexp.test(value);
       },"erreur expression reguliere"
    );

        $("#SaveFine").validate({
            rules: {
                DocDate: {
                    required: true,
                },
                PenaltyEmployeeID: {
                    required: true,
                },
                PenaltyName: {
                    required: true,
                },
                PenaltyAmount: {
                    required: true,
                },
                PenaltyDescription: {
                    required: true,
                },
                DeductionMonth: {
                    required: true,
                },
            },
            messages: {
                DocDate: {
                    required: "Doc date is required",
                },
                PenaltyEmployeeID: {
                    required: "Employee name is required",
                },
                PenaltyName: {
                    required: "Penalty name is required",
                },
                PenaltyAmount: {
                    required: "Penalty amount is required",
                },
                PenaltyDescription: {
                    required: "Penalty description  is required",
                },
                DeductionMonth: {
                    required: "Deduction month is required",
                },
            }
        });

        var form = $("#SaveFine");
        form.validate();
        $("#btnSubmit").click(function () {
            debugger;
            form.valid();
            if(form.valid()==false)
            {
                $("#txtDeductionMonth").removeClass('error');
                $("#dateDocDate").removeClass('error');
                return false;
            }
            var PenaltyEmployeeID=$("#ddlPenaltyEmployeeID").val();
            var DeductionMonth=$("#txtDeductionMonth").val();
            var PenaltyID_Encrypted=$("#PenaltyID_Encrypted").val();


            $.ajax({
                url:"IsFineExists",
                method:"Get",
                data:{PenaltyEmployeeID:PenaltyEmployeeID,DeductionMonth:DeductionMonth,PenaltyID_Encrypted:PenaltyID_Encrypted},
                success:function(response){
                    debugger;
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon=="error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                            }
                        }
                    }
                    else{
                        $("#SaveFine").submit();

                    }
                }
            });

        });
</script>

<script>
 $(document).ready(function () {
     $("#ddlPenaltyEmployeeID").select2();
     $("#btnFineGetList").click(function () {
         var url = '@Url.Action("GetList", "ESS_FineAndDamage_Fine")';
         window.location.href = url;
     });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }

     var Doc = @Html.Raw(Json.Encode(TempData["DocDate"]));
     var DDate = @Html.Raw(Json.Encode(TempData["DeducationMonth"]));
     debugger;
     if(Doc =="" ||DDate == "")
     {

     }
     else
     {
         var DocDate =  convertDate(Doc);
         var DeducationMonth = convertDate (DDate);      
         $("#txtDeductionMonth").val(DeducationMonth);
         $("#dateDocDate").val(DocDate);
     }

     $("#formReset").click(function () {
         $("#SaveFine")[0].reset()
     });

     var date = new Date();
     var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
     $("#dateDocDate").val(dateString);
 });//Ready Funcation

</script>

<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>
<script>
    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>

