@model KompassHR.Areas.ESS.Models.ESS_Other.Mas_AdditionNotify
@{
    ViewBag.Title = "ESS_Other_AdditionalNotify";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/additional-methods.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>


<div id="content" class="app-content">

    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="/ESS/ESS_WorkForce_Menu/ESS_WorkForce_Menu/?id=29">Additional Notification</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Additional Notification</h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Additional Notification - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        
                           
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add aditional recipients here!
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/ESS/ESS_Other_AdditionalNotify/SaveUpdate" id="SaveAdditionalNotify" method="post" data-parsley-validate="">
                                <div class="row">                                  
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Email
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.AdditionNotifyEmailID, new { @class = "form-control", name = "AdditionNotifyEmailID", @id = "txtAdditionNotifyEmailID", type = "text" })
                                                @Html.HiddenFor(model => model.AdditionNotifyId_Encrypted,new { id= "AdditionNotifyId_Encrypted" })                                               
                                            </div>
                                        </div>
                                    </div>
                                </div>



                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">
                                                    Last Record :
                                                    <span> @ViewBag.LastRecored</span>
                                                </div>
                                            </div>

                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="submit" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i>
                                                            Submit
                                                        </button>


                                                        <button type="button" id="btnGetAdditionalNotifyList" class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>

    <div class="row">
        <div class="table-scroll div1">
            <div class="table-wrap">
                <table class="table table-bordered align-middle" id="TestTable"  style="width: 100%;">
                    <thead>
                        <tr>
                            <th class="fixed-side">Update</th>
                            <th class="fixed-side1">Delete</th>
                            <th class="text-nowrap">Employee Name </th>
                        </tr>
                    </thead>
                    
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<script>
    var columns = [];
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#btnSubmit").click(function () {
            var AdditionNotifyIdTeamEmployeeID=$("#AdditionNotifyIdTeamEmployeeID").val();
            var AdditionNotifyEmployeeID=$("#AdditionNotifyEmployeeID").val();
            var AdditionNotifyId_Encrypted=$("#AdditionNotifyId_Encrypted").val();
            $.ajax({
                url:"IsAdditionNotifyExists",
                method:"get",
                data:{AdditionNotifyEmployeeID:AdditionNotifyEmployeeID,AdditionNotifyIdTeamEmployeeID:AdditionNotifyIdTeamEmployeeID,AdditionNotifyId_Encrypted:AdditionNotifyId_Encrypted},
                success:function(response){
                    debugger;
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon=="error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                            }
                        }
                    }
                    else{
                        $("#SaveAdditionNotify").submit();

                    }
                }
            });
        });

        //ForGet list
        $("#btnGetAdditionalNotifyList").click(function () {
            var url = '@Url.Action("GetList", "ESS_Other_AdditionalNotify")';
            window.location.href = url;
        });

        $("#formReset").click(function () {
            $("#SaveAdditionalNotify")[0].reset()
        })

    });//Ready Close


</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveAdditionalNotify").validate({
        rules: {
            AdditionNotifyEmailID: {
                required: true,

            }
        },
        messages: {
            AdditionNotifyEmailID: {
                required: "This field is required",

            }
        },

    });
</script>

