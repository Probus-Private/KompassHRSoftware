@model KompassHR.Areas.ESS.Models.ESS_FNF.FNF_Calculation

@{
    ViewBag.Title = "ESS_FNF_FNFLeaveCalculation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>

<style>
    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }



    .box2 {
        width: 100px;
        height: 100px;
        padding: 15px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
        margin-bottom: 10px;
    }

        .box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.03), 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        }

            .box2:hover .info i {
                color: #ff9c19;
            }


        .box2 .info i {
            font-size: 20px;
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
            font-size: 12px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .FS-12PX {
        font-size: 12px !important;
    }

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    .width-45 {
        width: 45px !important;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Calculation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave Calculation -@ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add bonus calculation details here!
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_FNF_FNFLeaveCalculation", new { area = "ESS" })' id="LeaveCalculation" method="post" enctype="multipart/form-data">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="empbx">
                                            <span>
                                                <h4> <i class="fa-solid fa-user"></i> @Session["FNFEmployeeName"] -  @Session["FNFEmployeeId"] </h4>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2"> Leave Year </label>
                                            <div class="col-md-4">
                                                @Html.DropDownListFor(model => model.LeaveMasterLeaveYearId, new SelectList(ViewBag.GetLeaveYear, "Id", "Name"), new { id = "LeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-select", autocomplete = "off" })

                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnShow">
                                                    Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div class="panel-body" data-scrollbar="false">
                                                <!-- BEGIN table-responsive -->
                                                <div class="table-scroll div1">
                                                    <div class="table-wrap">
                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage tblAddData">
                                                            <thead style="background-color: rgba(233, 236, 239, 1) !important; width:auto">
                                                                <tr>
                                                                    <th class="text-nowrap">Leave Name</th>
                                                                    <th class="text-nowrap">Opening Balance</th>
                                                                    <th class="text-nowrap">Jan</th>
                                                                    <th class="text-nowrap">Feb</th>
                                                                    <th class="text-nowrap">Mar</th>
                                                                    <th class="text-nowrap">Apr</th>
                                                                    <th class="text-nowrap">May</th>
                                                                    <th class="text-nowrap">June</th>
                                                                    <th class="text-nowrap">Jul</th>
                                                                    <th class="text-nowrap">Aug</th>
                                                                    <th class="text-nowrap">Sep</th>
                                                                    <th class="text-nowrap">Oct</th>
                                                                    <th class="text-nowrap">Nov</th>
                                                                    <th class="text-nowrap">Dec</th>
                                                                    <th class="text-nowrap">Total</th>
                                                                    <th class="text-nowrap">Closing Balance</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblTmsReports">
                                                                @if (ViewBag.GetLeaveCalculation != null)
                                                                {
                                                                    foreach (var d in ViewBag.GetLeaveCalculation)
                                                                    {
                                                                        <tr>
                                                                            <td class="text-nowrap">@d.LeaveName</td>
                                                                            <td class="text-nowrap">@d.ClientName</td>
                                                                            <td class="text-nowrap">@d.ProjectName</td>
                                                                            <td class="text-nowrap">@d.ModuleName</td>
                                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                                            <td class="text-nowrap">@d.TaskStatus</td>
                                                                            <td class="text-nowrap">@d.CompletePercentage</td>
                                                                            <td class="text-nowrap">@d.TaskDate</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-nowrap">@d.TaskTittle</td>
                                                                            <td class="text-start text-center">
                                                                                <input type="hidden" id="hiddenDescription_@d.Id" value="@d.TaskDescription" />
                                                                                <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.Id').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                                <!-- END table-responsive -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row">
                                    <div class="col-md-5"></div>
                                    <div class="col-md-3">
                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-5 col-form-label">Total Present<span class="important">*</span></label>
                                            <div class="col-lg-7">
                                                @Html.TextBoxFor(model => model.CurrentBasic_DA, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>

                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-5 col-form-label">Total Coff<span class="important">*</span></label>
                                            <div class="col-lg-7">
                                                @Html.TextBoxFor(model => model.GratuityYear, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-6 col-form-label">Total (Present + Coff)Days <span class="important">*</span></label>
                                            <div class="col-lg-6">
                                                @Html.TextBoxFor(model => model.RountOf_GratuityYear, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>

                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-6 col-form-label">PL Calculated<span class="important">*</span></label>
                                            <div class="col-lg-6">
                                                @Html.TextBoxFor(model => model.GratuityAmount, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>

                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-6 col-form-label">Total PL <span class="important">*</span></label>
                                            <div class="col-lg-6">
                                                @Html.TextBoxFor(model => model.GratuityAmount, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>
                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-6 col-form-label">Excess CL Consumed <span class="important">*</span></label>
                                            <div class="col-lg-6">
                                                @Html.TextBoxFor(model => model.GratuityAmount, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>

                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-6 col-form-label">Excess SL Consumed <span class="important">*</span></label>
                                            <div class="col-lg-6">
                                                @Html.TextBoxFor(model => model.GratuityAmount, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>
                                        <div class="mb-2 row align-items-center">
                                            <label class="col-lg-6 col-form-label">Total Leave Encashment <span class="important">*</span></label>
                                            <div class="col-lg-6">
                                                @Html.TextBoxFor(model => model.GratuityAmount, new { @class = "form-control", type = "text" })
                                            </div>
                                        </div>


                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" data-bs-toggle="offcanvas"
                                                                href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn  btnpress ListBtn">
                                                            <i class="fa-solid fa-list"></i>
                                                        </button>
                                                        <button type="button" id="btnsubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("ESS_FNF_FNFCalculation", "ESS_FNF_FNFCalculation", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnTrainer">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>

</div>
<div class="row">
    @Html.Action("FNF_SidebarMenu", "ESS_FNF_FNFEmployeeDetails")
</div>
