@model KompassHR.Areas.ESS.Models.ESS_PMS.PMS_HRMapping
@{
    ViewBag.Title = "ESS_PMS_HRMapping";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                HR Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_PMS_Menu", "ESS_PMS_Menu", new { id = 11, ScreenId = 594, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">PMS HR-Mapping - @ViewBag.AddUpdateTitle</h4>

                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        PMS HR Mapping
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form"
                                  action='@Url.Action("SaveHRMapping", "ESS_PMS_HRMapping", new { area = "ESS" })'
                                  id="SaveCompetencyMapping"
                                  method="post"
                                  data-parsley-validate="true">

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Company Name <span class="text-danger">*</span>
                                        </label>
                                        @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-control", name = "CmpID", id = "txtCmpID" })
                                        @Html.Hidden("CompetencyMappingId_Encrypted", "", new { id = "CompetencyMappingId_Encrypted" })
                                        <span class="text-danger small d-none" id="errCmp">
                                            Please select Company
                                        </span>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Business Unit <span class="text-danger">*</span>
                                        </label>
                                        @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BUName, "Id", "Name"), "--Select--", new { @class = "form-control", name = "BranchId", id = "txtBranchId" })
                                        <span class="text-danger small d-none" id="errBranch">
                                            Please select Branch
                                        </span>

                                    </div>
                                </div>

                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Department 
                                        </label>
                                        @Html.DropDownListFor(model => model.DepartmentId, new SelectList(ViewBag.GetDept, "Id", "Name"), "--Select--", new { @class = "form-control", name = "DepartmentId", id = "txtDepartmentId" })
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-dark fw-semibold">
                                            Designation 
                                        </label>
                                        @Html.DropDownListFor(model => model.DesignationId, new SelectList(ViewBag.GetDesg, "Id", "Name"), "--Select--", new { @class = "form-control", name = "DesignationId", id = "txtDesignationId" })
                                    </div>
                                </div>

                                <div class="row mb-4 align-items-end">
                                    <div class="col-md-5">
                                        <label class="form-label text-dark fw-semibold">
                                            Responsible HR <span class="text-danger">*</span>
                                        </label>
                                        @Html.DropDownListFor(
            model => model.ResponsibleHR,
            new SelectList(ViewBag.GetEmployeeInfo, "Id", "Name"),
            "--Select--",
            new
            {
                @class = "form-control",
                name = "ResponsibleHR",
                id = "txtResponsibleHR"
            })
                                        <span class="text-danger small d-none" id="errHR">
                                            Please select Responsible HR
                                        </span>
                                    </div>

                                    <div class="col-md-2 text-start">
                                        <button type="button"
                                                id="btnShowEmployees"
                                                class="btn btn-info btn-sm mt-4">
                                            <i class="fa fa-eye"></i> Show
                                        </button>
                                    </div>
                                </div>

                                    @*<div class="row mb-3">
                                        <div class="col-md-12 text-end">
                                            <button type="button" id="btnShowEmployees" class="btn btn-info btn-sm">
                                                <i class="fa fa-eye"></i> Show
                                            </button>
                                        </div>
                                    </div>*@
                                    <div class="row mt-3" id="employeeSection" style="display:none;">
                                        <div class="col-md-12">
                                            <div class="card border">
                                                <div class="card-header bg-light fw-semibold">
                                                    <input type="checkbox" id="chkAllEmployees" />
                                                    <label for="chkAllEmployees" class="ms-1">Select All Employees</label>
                                                </div>
                                                <div class="card-body" style="max-height:300px; overflow-y:auto;">
                                                    <div class="row" id="employeeList">
                                                        <!-- Employees will load here -->
                                                    </div>
                                                    <input type="hidden" name="SelectedEmployeeIds" id="SelectedEmployeeIds" />

                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                                            </button>
                                                            @*<a href="@Url.Action("GetList", "ESS_PMS_CompetencyMapping", new { area = "ESS" })">
                                                                <button type="button" class="btn btn-danger btn-sm" id="btnDocumentCategory">
                                                                    <i class="fa-solid fa-share-from-square"></i> List
                                                                </button>
                                                            </a>*@
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
</form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>

       
   
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }





        $("#txtCmpID, #txtBranchId, #txtDepartmentId, #txtDesignationId, #txtResponsibleHR").select2();

        $("#txtCmpID").change(function () {
            let cmpId = $(this).val();
            $("#txtBranchId").empty().append('<option value="">--Select--</option>');
            if (cmpId) {
                $.getJSON('/ESS_PMS_HRMapping/GetBranchByCompany',
                    { cmpId: cmpId },
                    function (data) {
                        $.each(data, function (i, item) {
                            $("#txtBranchId").append(
                                $('<option>').val(item.Id).text(item.Name)
                            );
                        });
                    });
            }
        });

        $("#btnShowEmployees").click(function () {

            let valid = true;

            if (!$("#txtCmpID").val()) {
                $("#errCmp").removeClass("d-none");
                valid = false;
            } else {
                $("#errCmp").addClass("d-none");
            }

            if (!$("#txtBranchId").val()) {
                $("#errBranch").removeClass("d-none");
                valid = false;
            } else {
                $("#errBranch").addClass("d-none");
            }

            if (!$("#txtResponsibleHR").val()) {
                $("#errHR").removeClass("d-none");
                valid = false;
            } else {
                $("#errHR").addClass("d-none");
            }

            if (!valid) return;

            // 🔹 Load employees
            $.ajax({
                url: '/ESS_PMS_HRMapping/GetEmployees',
                type: 'GET',
                data: {
                    CmpId: $("#txtCmpID").val(),
                    BranchId: $("#txtBranchId").val(),
                    DeptId: $("#txtDepartmentId").val(),
                    DesgId: $("#txtDesignationId").val(),
                    ResponsibleHR: $("#txtResponsibleHR").val()
                },
                success: function (res) {

                    $("#employeeList").empty();
                    $("#employeeSection").show();

                    if (res.length === 0) {
                        $("#employeeList").html('<p class="text-muted">No employees found</p>');
                        return;
                    }

                    $.each(res, function (i, emp) {
                        $("#employeeList").append(`
                <div class="col-md-4 mb-2">
                    <input type="checkbox"
                           class="empChk"
                           value="${emp.EmployeeId}"
                           ${emp.IsChecked ? "checked" : ""} />
                    <span class="ms-1">${emp.EmployeeName}</span>
                </div>
            `);
                    });
                }
            });
        });

       
        $(document).on("change", "#chkAllEmployees", function () {
            $(".empChk").prop("checked", $(this).is(":checked"));
        });

        
        $("#btnSubmit").click(function () {

            if (!$("#txtResponsibleHR").val()) {
                $("#errHR").removeClass("d-none");
                return;
            } else {
                $("#errHR").addClass("d-none");
            }

            let selected = [];
            $(".empChk:checked").each(function () {
                selected.push($(this).val());
            });

            $("#SelectedEmployeeIds").val(selected.join(","));

            $("#SaveCompetencyMapping").submit();
        });
    });

</script>
