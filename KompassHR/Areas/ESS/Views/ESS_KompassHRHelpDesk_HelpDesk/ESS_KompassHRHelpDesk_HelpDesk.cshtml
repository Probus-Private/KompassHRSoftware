@model KompassHR.Areas.ESS.Models.ESS_KompassHR_HelpDesk.Kompass_HelpDesk
@{
    ViewBag.Title = "ESS_KompassHRHelpDesk_HelpDesk";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
     label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="dashboard-container">
        <!-- Sidebar -->
        <!-- Main Content -->
        <div class="main-content">
            <div class="pageHeader d-flex align-items-center justify-content-between" style="flex-wrap:nowrap;">
                <h5 class="page-header text-center text-md-start">Help Desk Query 🙋‍♀️</h5>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ESS_KompassHRHelpDesk_Menu", "ESS_KompassHRHelpDesk_Menu",  new { id = 44,ScreenId=793, area = "ESS" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                        </a>
                    </li>
                </ol>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="panel panel-inverse">
                        <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                            <h4 class="panel-title">Raise a Help Desk Ticket - <b>@ViewBag.AddUpdateTitle</b></h4>
                        </div>

                        <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0">
                            <p>Raise your query here.</p>
                        </div>

                        <div class="panel-body">
                            <form id="saveHelpDesk" action='@Url.Action("SaveUpdate", "ESS_KompassHRHelpDesk_HelpDesk", new { area = "ESS" })' method="post" enctype="multipart/form-data">
                                @Html.HiddenFor(m => m.HelpDeskId_Encrypted)
                                @Html.HiddenFor(m => m.HelpDeskId)
                                <!-- Ticket Information -->
                                <div class="form-section-card">
                                    <h5 class="form-section-title">Ticket Information</h5>
                                    <div class="row">
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="DocNo">Doc No <span class="required-star">*</span></label>
                                            @Html.TextBoxFor(m => m.HelpDesk_DocNo, new { @class = "form-control", id = "DocNo", @readonly = "readonly", Value = @ViewBag.DocNo })
                                        </div>
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="dateDocDate">Doc Date <span class="required-star">*</span></label>
                                            @Html.TextBoxFor(m => m.HelpDesk_DocDate, new { @class = "form-control", id = "dateDocDate", @readonly = "readonly", type = "date" ,name= "HelpDesk_DocDate" })
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="ddlRequestType">Request Type <span class="required-star">*</span></label>
                                            @Html.DropDownListFor(m => m.HelpDesk_RequestType, new List<SelectListItem>
                                    {
                                        new SelectListItem { Text = "Bug Fix", Value = "Bug Fix" },
                                        new SelectListItem { Text = "Enhancement", Value = "Enhancement" },
                                        new SelectListItem { Text = "New Development", Value = "New Development" },
                                        new SelectListItem { Text = "Data Issue", Value = "Data Issue" },
                                        new SelectListItem { Text = "Other", Value = "Other" },
                                    }, "--- Select Type ---", new { @class = "form-select", id = "ddlRequestType" })
                                        </div>
                                        <!-- Hidden textbox for "Other" -->
                                        <div class="col-lg-6 col-md-12 mb-3" id="divOtherType" style="display:none;">
                                            <label class="form-label" for="txtOtherType">Please specify <span class="required-star">*</span></label>
                                            @Html.TextBoxFor(model => model.RequestType_DescriptionOther, new { @class="form-control",id= "RequestType_DescriptionOther" })
                                            @*<input type="text" id="txtOtherType" name="HelpDesk_OtherRequestType" class="form-control" placeholder="Enter details for Other">*@
                                        </div>
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="ddlPriority">Priority Level <span class="required-star">*</span></label>
                                            @Html.DropDownListFor(m => m.HelpDesk_Priority, new List<SelectListItem>
                                    {
                                        new SelectListItem { Text = "Low", Value = "Low" },
                                        new SelectListItem { Text = "Medium", Value = "Medium" },
                                        new SelectListItem { Text = "High", Value = "High" },
                                        new SelectListItem { Text = "Critical (System Down)", Value = "Critical" },
                                    }, "--- Select Priority ---", new { @class = "form-select", id = "ddlPriority" ,name= "HelpDesk_Priority" })
                                        </div>
                                    </div>
                                </div>

                                <!-- Request Details -->
                                <div class="form-section-card">
                                    <h5 class="form-section-title">Details of Request/Issue</h5>
                                    <div class="row">
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="ModuleName">Module Name<span class="required-star">*</span></label>
                                            @Html.DropDownListFor(m => m.ModuleName,new SelectList(ViewBag.GetModules, "Name", "Name"),"--Select--", new { @class = "form-control", id = "ModuleName" })
                                        </div>
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="TicketRaiseTitle">Ticket Title <span class="required-star">*</span></label>
                                            @Html.TextBoxFor(m => m.HelpDesk_Title, new { @class = "form-control", id = "TicketRaiseTitle", placeholder = "Enter title" })
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label" for="Description">Description <span class="required-star">*</span></label>
                                        @Html.TextAreaFor(m => m.HelpDesk_Description, new { @class = "form-control", id = "Description", rows = 6, placeholder = "Describe your issue" })
                                    </div>
                                    @*<div class="mb-3">
                                        <label class="form-label">Attachment</label>
                                        <div class="file-upload-box" onclick="document.getElementById('txtFilePath').click()">
                                            <i class="fa-solid fa-cloud-arrow-up me-2"></i>
                                            <span>Click to upload files</span>
                                            <input type="file" name="FilePath" class="d-none" id="txtFilePath" onchange="showFileName(this)" />
                                        </div>
                                        <div id="fileInfo" class="mt-2 small text-muted"></div>
                                    </div>*@

                                    <div class="mb-3">
                                        <label class="form-label">Attachment</label>
                                        <div class="file-upload-box" onclick="document.getElementById('txtFilePath').click()">
                                            <i class="fa-solid fa-cloud-arrow-up me-2"></i>
                                            <span>Click to upload files</span>
                                            <input type="file" name="FilePath" class="d-none" id="txtFilePath" onchange="validateAndShowFile(this)" />
                                        </div>
                                        <div id="fileInfo" class="mt-2 small text-muted"></div>
                                    </div>
                                </div>

                                <div class="form-section-card">
                                    <h5 class="form-section-title">Result</h5>
                                    <div class="row">
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="ExpectedResult">Expected Result <span class="required-star">*</span></label>
                                            @Html.TextBoxFor(m => m.ExpectedResult, new { @class = "form-control", id = "ExpectedResult" ,name= "ExpectedResult",placeholder= "Enter expected result " })
                                        </div>
                                        <div class="col-lg-6 col-md-12 mb-3">
                                            <label class="form-label" for="ActualResult">Actual Result <span class="required-star">*</span></label>
                                            @Html.TextBoxFor(m => m.ActualResult, new { @class = "form-control", id = "ActualResult",  name = "ActualResult", placeholder = "Enter actual result " })
                                        </div>
                                    </div>
                                </div>
                                <!-- Buttons -->
                                <div class="text-end">
                                    <button type="button" id="btnSubmit" class="btn btn-success btn-sm me-2"><i class="fa-solid fa-floppy-disk"></i> Submit</button>
                                    @*<button type="button" class="btn btn-secondary btn-sm" id="btnTicketRaiseGetList"><i class="fa-solid fa-share-from-square"></i> List</button>*@
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

        <style>

                .file-upload-box {
                border: 2px dashed #ccc;
                border-radius: 8px;
                padding: 20px;
                text-align: center;
                cursor: pointer;
                background: #f8f9fa;
            }
            .file-upload-box:hover {
                border-color: #007bff;
                background: #e3f2fd;
            }
                .form-section-card {
                    border: 1px solid #e9ecef;
                    border-radius: 8px;
                    margin-bottom: 2rem;
                    padding: 1.5rem;
                    background: #fff;
                }

                .form-section-title {
                    font-size: 1.25rem;
                    font-weight: 600;
                    color: #007bff;
                    margin-bottom: 1.5rem;
                    border-bottom: 2px solid #007bff33;
                    padding-bottom: .5rem;
                }

                .form-label {
                    font-weight: 500;
                    margin-bottom: .25rem;
                }

                .form-control, .form-select {
                    border-radius: 4px;
                    padding: .5rem .75rem;
                }

                .required-star {
                    color: #dc3545;
                    font-weight: 700;
                }

                .priority-dot {
                    display: inline-block;
                    height: 10px;
                    width: 10px;
                    border-radius: 50%;
                    margin-right: 6px;
                }

                .req-icon {
                    margin-right: 6px;
                }

                .priority-dot {
                display: inline-block;
                height: 10px;
                width: 10px;
                border-radius: 50%;
                margin-right: 6px;
            }

            .priority-dot.text-success { background-color: #28a745; }
            .priority-dot.text-warning { background-color: #ffc107; }
            .priority-dot.text-orange { background-color: #fd7e14; }
            .priority-dot.text-danger { background-color: #dc3545; }
        </style>

        <script>
    $(document).ready(function () {
        $('#ddlRequestType').change(function () {
            var selected = $(this).val();
            if (selected === "Other") {
                $('#divOtherType').show();
            } else {
                $('#divOtherType').hide();
                $('#txtOtherType').val(''); // clear previous value
            }
        });
    });
        </script>

        <script>


            function validateAndShowFile(input) {
                const file = input.files[0];
                const fileInfo = document.getElementById("fileInfo");
                const maxSizeMB = 5; // ✅ Max 5 MB
                const maxSizeBytes = maxSizeMB * 1024 * 1024;

                if (file) {
                    if (file.size > maxSizeBytes) {
                        alert(`File size exceeds ${maxSizeMB} MB. Please upload a smaller file.`);
                        input.value = ""; // Clear the file input
                        fileInfo.innerHTML = "";
                        return;
                    }

                    // ✅ Show selected file info
                    const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);
                    fileInfo.innerHTML = `<i class="fa-solid fa-file"></i> ${file.name} (${fileSizeMB} MB)`;
                    fileInfo.className = 'mt-2 small text-success';
                }
            }
   

    function ResetFile() {
        document.getElementById('txtFilePath').value = '';
        document.getElementById('fileInfo').innerHTML = '';
    }
    function formatOption(option) {
        if (!option.id) return option.text;
        var el = $(option.element), val = el.val();
        var iconHtml = '';

        // Priority
        if(el.parent().attr('id')=='ddlPriority') {
            if(val=='Low') iconHtml='<span class="priority-dot text-success"></span>';
            else if(val=='Medium') iconHtml='<span class="priority-dot text-warning"></span>';
            else if(val=='High') iconHtml='<span class="priority-dot text-orange"></span>';
            else if(val=='Critical') iconHtml='<span class="priority-dot text-danger"></span>';
        }

        // Request Type
        if(el.parent().attr('id')=='ddlRequestType') {
            if(val=='Bug Fix') iconHtml='<i class="fa-solid fa-bug text-danger req-icon"></i>';
            else if(val=='Enhancement') iconHtml='<i class="fa-solid fa-wrench text-primary req-icon"></i>';
            else if(val=='New Development') iconHtml='<i class="fa-solid fa-code text-success req-icon"></i>';
            else if(val=='Data Issue') iconHtml='<i class="fa-solid fa-database text-warning req-icon"></i>';
            else if(val=='Other') iconHtml='<i class="fa-solid fa-question-circle text-secondary req-icon"></i>';
        }

        return $('<span>' + iconHtml + ' ' + option.text + '</span>');
    }


    $(document).ready(function () {
        // Format for Select2 with icons/dots

        // Initialize Select2
        $('#ddlPriority, #ddlRequestType, #ModuleName').select2({
            width: '100%',
            templateResult: formatOption,       // For dropdown list
            templateSelection: formatOption     // For selected value display
        });

        // Initialize Select2
        //$('#ddlPriority, #ddlRequestType').select2({ width:'100%', templateResult:formatOption, templateSelection:formatOption });

        // Set default date
        if(!$("#dateDocDate").val()) {
            var today = new Date().toISOString().split('T')[0];
            $("#dateDocDate").val(today);
        }



        // TempData SweetAlert
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        // Go to list
        $("#btnTicketRaiseGetList").click(function(){
            window.location.href='@Url.Action("GetList","ESS_KompassHRHelpDesk_HelpDesk")';
        });
    });
        </script>


