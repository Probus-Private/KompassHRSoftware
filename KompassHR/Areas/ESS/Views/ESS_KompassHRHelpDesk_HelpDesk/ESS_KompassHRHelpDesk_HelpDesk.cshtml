        <script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#saveHelpDesk").validate({
        rules: {
            HelpDesk_DocDate: {
                required: true,
            },
            HelpDesk_Priority: {
                required: true,
            },
            HelpDesk_RequestType: {
                required: true,
            },

            HelpDesk_Title: {
                required: true,
            },
            HelpDesk_Description: {
                required: true,
            },
            ExpectedResult: {
                required: true,
            },
            ActualResult: {
                required: true,
            },
            ModuleName: {
                required: true,
            },
        },
        messages: {
            HelpDesk_DocDate: {
                required: "This field is required",
            },
            HelpDesk_Priority: {
                required: "This field is required",
            },
            HelpDesk_RequestType: {
                required: "This field is required",
            },
            HelpDesk_Title: {
                required: "This field is required",
            },
            HelpDesk_Description: {
                required: "This field is required",
            },
            ExpectedResult: {
                required: "This field is required",
            },
            ActualResult: {
                required: "This field is required",
            },
            ModuleName: {
                required: "This field is required",
            },
        },

    });
    //IsValidation Check
    var form = $("#saveHelpDesk");
    form.validate();
    $("#btnSubmit").click(function () {

        debugger;
        form.valid();
        if(form.valid()==false)
        {
            //$("#dateToDate").removeClass('error');
            return false;
        }

        else{
            $("#saveHelpDesk").submit();
        }

    });
        </script>
