
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 67px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 67px;
    }*/
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Help Desk</h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Ticket_Menu", "ESS_Ticket_Menu",  new { id = 13,ScreenId=199, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Help Desk - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This list displays all submitted help desk requests along with their current status. You can view, track, or update each request as required.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_KompassHRHelpDesk_HelpDesk", "ESS_KompassHRHelpDesk_HelpDesk", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                           style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th class="fixed-side">Update</th>
                                                <th class="fixed-side1">Delete</th>
                                                <th class="text-nowrap">Doc No</th>
                                                <th class="text-nowrap">Doc Date </th>
                                                <th class="text-nowrap">Title</th>
                                                <th class="text-nowrap">Request Type</th>
                                                <th class="text-nowrap">Description</th>
                                                <th class="text-nowrap">Download Attachment</th>
                                                <th class="text-nowrap">Priority</th>
                                                <th class="text-nowrap">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetList)
                                            {
                                                <tr>
                                                    <td class="text-nowrap text-center">
                                                        @if (d.Status == "In-Process")
                                                        {
                                                            <a onclick="UpdateHelpDesk('@d.HelpDeskId_Encrypted')" id="btnUpdate" style="cursor:pointer;">
                                                                <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a title="You Cant't be Update ,Ticket @d.Status" style="cursor:pointer;">
                                                                <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap text-center">
                                                        @if (d.Status == "In-Process")
                                                        {
                                                            <a onclick="DeleteHelpDesk('@d.HelpDeskId_Encrypted')" id="btnDelete" style="cursor:pointer;">
                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a style="cursor:pointer;">
                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                            </a>
                                                        }
                                                    </td>

                                                    <td>@d.HelpDesk_DocNo</td>
                                                    <td>@d.DocDate</td>
                                                    <td>@d.HelpDesk_Title</td>
                                                    <td>@d.HelpDesk_RequestType</td>
                                                    <td>@d.HelpDesk_Description</td>
                                                    @if (d.FilePath != "No" && d.FilePath != "System.Web.HttpPostedFileWrapper")
                                                    {
                                                        <td class="text-center">                                                            
                                                            <a href="@Url.Action("DownloadAttachment","ESS_KompassHRHelpDesk_HelpDesk", new { DownloadAttachment = @d.AttachFile })"><i class="fa fa-download"></i></a>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td>
                                                            File Not Found
                                                        </td>
                                                    }
                                                    <td>@d.HelpDesk_Priority</td>
                                                    <td>@d.Status</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>
<script>


    
        function UpdateHelpDesk(HelpDeskId_Encrypted) {
            debugger
            var url = '@Url.Action("ESS_KompassHRHelpDesk_HelpDesk", "ESS_KompassHRHelpDesk_HelpDesk")?HelpDeskId_Encrypted=' + HelpDeskId_Encrypted;
            window.location.href = url;
        }

        function DownloadAttachment(HelpDeskId_Encrypted) {
            var url = '@Url.Action("DownloadAttachment", "ESS_KompassHRHelpDesk_HelpDesk")?HelpDeskId_Encrypted=' + HelpDeskId_Encrypted;
            window.location.href = url;
        }

        function DeleteHelpDesk(HelpDeskId_Encrypted) {
            debugger
            const DeleteButtons = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            DeleteButtons.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Delete", "ESS_KompassHRHelpDesk_HelpDesk")?HelpDeskId_Encrypted=' + HelpDeskId_Encrypted;

                } else if (
                    result.dismiss === Swal.DismissReason.cancel
                ) {

                }
            })
        }
    

</script>






