                    {
                        $('#ErrorTourStart').html("");
                    }
                    else
                    {

                        $('#ErrorTourEnd').html("Please enter date greater than tour start date!");
                        $('#TourEnd').val('');
                        $('#TourEnd').val('');
                        $('#TourEnd').focus();
                        return false;
                    }
               
            }



            const differenceInDays = dateDiffInDays(date1, date2); // Calculate the difference
            var v1 = parseFloat(differenceInDays);
            var v2 = parseFloat(1);
            var v3= parseFloat(v1+v2)
            $("#NoofDays1").val(v3);
        })
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
