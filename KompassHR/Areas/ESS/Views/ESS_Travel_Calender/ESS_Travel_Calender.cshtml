                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TourEnd, new { @class = "form-control", name = "TourEnd", type = "date", id = "TourEnd", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.TourEnd, "", new { @class = "help-block", id = "ErrorTourEnd", @style = "color:red" })

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                No of days
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.NoofDays, new { @class = "form-control", Type = "text", id = "NoofDays1",@readonly="readonly"})

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Additional Employee with me
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.AdditionalEmployee, new { @class = "form-control", name = "AdditionalEmployee", type = "text", id = "AdditionalEmployee", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Confidential <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Confidential, new SelectList(new List<object>() {
                                           new {text="Yes",value="Yes"},
                                              new {text="No",value="No"},
                                       }, "text", "value"), "--Select--", new { @class = "form-control form-select", @id = "Confidential" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Travel Note
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TravelNote, new { @class = "form-control", name = "TravelNote", type = "text", id = "TravelNote", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                </div> 

                                <br /> 
                                <div class="row" align="right">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="/ESS/ESS_Travel_Calender/GetList">
                                                            <button type="button" id="btnGetList"
                                                                    class="btn btn-danger btn-sm">
                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

