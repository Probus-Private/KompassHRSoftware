                }
            }
          

        });


        $("#TourEnd").change(function(){
            debugger
            function dateDiffInDays(date1, date2) {
                const diffInMs = Math.abs(date2 - date1); // Difference in milliseconds
                const msPerDay = 1000 * 60 * 60 * 24; // Number of milliseconds in a day

                return Math.floor(diffInMs / msPerDay); // Convert milliseconds to days
            }
            var TourStart =$("#TourStart").val();
            var TourEnd =$("#TourEnd").val();
            // Example usage
            const date1 = new Date(TourStart); // First date
            const date2 = new Date(TourEnd); // Second date

            if(TourStart!="" && TourEnd =="")
