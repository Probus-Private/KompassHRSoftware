                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Travel Calender Request - <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>

                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                      Travel Desk
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/ESS/ESS_Travel_Calender/Save" id="SaveCalender" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc
                                                No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNo", type = "text", id = "DocNo",Value = @ViewBag.DocNo.DocNo, autocomplete = "Off", @readonly = "readonly", Style = "background-color: lightgray;" })
                                                @Html.HiddenFor(model => model.TravelCalenderID_Encrypted, new { id = "TravelCalenderID_Encrypted" })
                                                @Html.HiddenFor(model => model.TravelBranchID, new { id = "TravelBranchID" })
                                                @Html.HiddenFor(model => model.CmpId, new { id = "CmpId" })
                                                @Html.HiddenFor(model => model.DocDate, new { id = "DocDate" })

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                              Travel Purpose
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TravelCalenderTravelPurposeID, new SelectList(ViewBag.GetPurposeName, "TravelPurposeID", "TravelPurpose"), "--Select--", new { id = "TravelCalenderTravelPurposeID", @class = "form-select", autocomplete = "off", name = "TravelCalenderTravelPurposeID" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Purpose Description
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PurposeDescription, new { @class = "form-control", name = "PurposeDescription", type = "text", id = "PurposeDescription", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Travel Type
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TravelType, new SelectList(new List<object>() {
                                           new {text="International",value="International"},
                                              new {text="Domestic",value="Domestic"},
                                              new {text="Local",value="Local"},
                                       }, "text", "value"), "--Select--", new { @class = "form-control form-select", @id = "TravelType" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                               Day Type
                                            </label>
                                            <div class="col-md-8">
