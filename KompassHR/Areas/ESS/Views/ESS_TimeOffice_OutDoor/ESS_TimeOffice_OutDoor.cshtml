                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        The employee indicates the date(s) and duration of the outdoor assignment, including the start and end times. This helps managers and supervisors plan and allocate resources effectively.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_TimeOffice_OutDoor", new { area = "ESS" })' id="SaveOutDoor" method="post" data-parsley-validate="true">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            @Html.HiddenFor(model => Model.OutDoorCompanyID)
                                            <label class="form-label col-form-label col-md-4"> Doc No. @*<span class="important">*</span>*@</label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => Model.DocNo, new { @class = "form-control mb-5px", @id = "txtDocNo", Value = @ViewBag.DocNo.DocNo, @readonly = "readonly" })
                                                @Html.HiddenFor(model => model.OutDoorCompanyID_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4"> Shift <span class="important">*</span> </label>
                                            <div class="col-md-8">
                                                <input type="hidden" name="OutDoorCompanyShiftName" id="ShiftName" />
