                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.TotalMinutes, new { @name = "TotalMinutes", @class = "form-control", @id = "txtTotalMinutes", Type = "text", @readonly = "readonly", @style = "background-color:#eee;" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-2" id="divMaxAllow">
                                        <div class="row mb-15px">
                                            <div class="col-md-12 d-flex align-items-center">
                                                @Html.CheckBoxFor(model => model.IsNightShift, new { id = "chkIsNightShift", @class = "IsNightShift" })
                                                <label class="form-label col-form-label ms-2">Is Night Shift</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row" id="HdnDirecationandTotalMinutes">
                                    @*<div class="col-md-6" id="Direcation">
