                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromTime, new { @name = "FromTime", @class = "form-control", @id = "txtFromTime", type = "time" })
                                                @Html.ValidationMessageFor(model => model.FromTime, "", new { @class = "help-block", id = "ErrortxtFromTime", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4"> To Time <span class="important">*</span></label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToTime, new { @name = "ToTime", @class = "form-control", @id = "txtToTime", type = "time" })
                                                @Html.ValidationMessageFor(model => model.ToTime, "", new { @class = "help-block", id = "ErrortxtToTime", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">Total (Min) </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalDuration, new { @name = "TotalDuration", @class = "form-control", @id = "txtTotalDuration", type = "text", @readonly = "readonly" })
                                                @Html.ValidationMessageFor(model => model.TotalDuration, "", new { @class = "help-block", id = "ErrortxtTotalDuration", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">Total Days </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalDays, new { @name = "TotalDays", @class = "form-control", @id = "txtTotalDays", type = "text", @readonly = "readonly" })
                                                @* @Html.TextBox("TotalDays", null, new { @name = "TotalDays", @class = "form-control", @id = "txtTotalDays", type = "text", @readonly = "readonly" })*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Visiting Unit
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VisitingBranchID, new SelectList(ViewBag.VisitingBranchName, "Id", "Name"), "Other", new { @class = "form-control", id = "txtVisitingBranchID", name = "VisitingBranchID" })
                                                @Html.ValidationMessageFor(model => model.VisitingBranchID, "", new { @class = "help-block", id = "ErrorVisitingBranchID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Reason
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.Reason, new { @name = "Reason", @class = "form-control", @id = "txtReason" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @*<div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3" style="width: 16.5%;"> Addition Notify </label>
                                                <div class="col-md-9" style="min-width: 83.5%; max-width: 100%;">
                                                    @Html.DropDownListFor(model => model.AdditionNotify, new MultiSelectList(ViewBag.GetAdditionalList, "Name", "Name"), new { id = "ddlAdditionNotify", name = "AdditionNotify", @class = "form-control multiple-select2", @multiple = "multiple" })

                                                </div>
                                            </div>
                                        </div>
                                    </div>*@
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                @*<div class="title d-flex align-items-center">
                                                        Last Record :
                                                        <span>@ViewBag.LastRecored</span>
                                                    </div>*@
                                            </div>
                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm" value="Submit">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("ESS_TimeOffice_GetApproveRejectList", "ESS_TimeOffice_OutDoor", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

        <div class="col-md-4">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Attendance Log </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row" style="max-height:350px; overflow-y:auto;">
                        <!-- BEGIN table-responsive -->
                        <table class="table table-bordered align-middle" id="fixed-header" style="width: 100%;">
                            <thead style="background-color:#eee">
                                <tr>
                                    <th class="text-center">Date & Time</th>
                                    <th class="text-center">I / O</th>
                                    <th class="text-center">Remark</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in ViewBag.GetDeviceLogsList)
                                {
                                    <tr>
                                        <td>@d.LogDate</td>
                                        @if (@d.Direction == "IN")
                                        {
                                            <td class="text-center"><i class="fa-solid fa-circle-down fa-lg" style="color: #5cce40; padding: 0px;"></i></td>
                                        }
                                        @if (@d.Direction == "OUT")
                                        {
                                            <td class="text-center"><i class="fa-solid fa-circle-up fa-lg" style="color:#fe6966; padding: 0px;"></i></td>
                                        }
                                        <td class="text-nowrap">@d.C1</td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                        <!-- END table-responsive -->
                    </div>
                </div>
            </div>
        </div>
