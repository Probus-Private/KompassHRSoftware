                                                @Html.ValidationMessageFor(model => model.FromDate, "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">To Date<span class="important">*</span></label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new
                                           {
                                               @name = "ToDate",
                                               @class = "form-control",
                                               @id = "txtToDate",
                                               Type = "date"@*, onkeydown = "return false*@ })
                                                @Html.ValidationMessageFor(model => model.ToDate, "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
