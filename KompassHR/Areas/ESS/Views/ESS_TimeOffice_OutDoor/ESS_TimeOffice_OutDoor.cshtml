                                                new SelectListItem {Text ="Short Period", Value="Short Period"},
                                                new SelectListItem {Text ="Full Day", Value="Full Day"},
                                                //new SelectListItem {Text ="1st Half", Value="1st Half"},
                                                //new SelectListItem {Text ="2nd Half", Value="2nd Half"}
                                            }, "--Select--", new { @class = "form-select", name = "OutDoorCompanyType", @id = "OutDoorCompanyType" })
                                            </div>
                                        </div>
                                    </div>

