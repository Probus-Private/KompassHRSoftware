                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.Direction, new List<SelectListItem>{
                                                    new SelectListItem {Text ="Shift InTime", Value="Shift InTime"},
                                                    new SelectListItem {Text ="Shift Between", Value="Shift Between"},
                                                    new SelectListItem {Text ="Shift OutTime", Value="Shift OutTime"}
                                                  }, "--Select--", new { @class = "form-select", name = "Year", @id = "ddlDirecation" })
                                                    @Html.ValidationMessageFor(model => model.Direction, "", new { @class = "help-block", id = "ErrorddlDirecation", @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>*@

                                </div>
                                <div class="row">
