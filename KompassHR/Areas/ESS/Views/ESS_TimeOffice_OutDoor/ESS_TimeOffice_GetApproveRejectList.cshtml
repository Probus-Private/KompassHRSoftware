</style>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Outdoor
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new {id = 5, ScreenId=150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Outdoor - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of schedule and planned outdoor activities.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="@Url.Action("ESS_TimeOffice_OutDoor", "ESS_TimeOffice_OutDoor", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                        </div>
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="tblOutDoorList" style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th class="text-nowrap">Cancel</th>
                                            <th class="text-nowrap">Delete</th>
                                            <th class="text-nowrap">Status</th>
                                            <th class="text-nowrap">Invoice</th>
                                            <th class="text-nowrap text-center">Doc No </th>
                                            @*<th class="text-nowrap text-center">Doc Date </th>*@
                                            <th class="text-nowrap text-center">Shift</th>
                                            <th class="text-nowrap text-center">OutDoor Type</th>
                                            @*<th class="text-nowrap text-center">Direction</th>*@
                                            <th class="text-nowrap text-center">For Date</th>
                                            <th class="text-nowrap text-center">For Time</th>
                                            <th class="text-nowrap text-center">Reason</th>
                                            <th class="text-nowrap text-center">Visiting Unit</th>
                                            <th class="text-nowrap text-center">Approve/Rejected by</th>
                                            <th class="text-nowrap text-center">Approve/Rejected Date</th>
                                            <th class="text-nowrap text-center">Rejected Reason</th>
                                            <th class="text-nowrap text-center">Auto/Manually</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.OutDoorCompanyAll)
                                        {
                                        <tr>
                                            @if (@d.CancelStatus != "")
                                                {
                                                <td class="text-center"> @d.CancelStatus</td>
                                                }
                                                else
                                                {
                                                <td class="text-center">
                                                    <a href="#modal-dialogForHoldReject1" onclick="CancelRequestFun(@d.OutDoorCompanyId,'@d.Status')" id="btnmodal-dialog1">
                                                        <i class="fa-solid fa-xmark fa-xl text-dark" style="color:black"></i>
                                                    </a>
                                                </td>
                                                }
                                            <td class="text-center">
                                                <a id="btnCancel" onclick="DeleteOutDoor('@d.OutDoorCompanyId_Encrypted','@d.OutDoorCompanyId','@d.Status')"
                                                   style="cursor:pointer">
                                                    <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                </a>
                                            </td>
                                            <td class="text-nowrap">
                                                <i class="fa-solid fa-circle-info text-success fa-lg" style="cursor: pointer;" onclick="ApproveStatus(@d.OutDoorCompanyId)"></i> &nbsp;
                                                @d.ApprovedDay
                                            </td>
                                            <td class="text-center">
                                                <a onclick="InvoiceFun(@d.OutDoorCompanyId)">
                                                    <i class="fa-solid fa-download text-danger fa-lg" style="color:black"></i>
                                                </a>
                                            </td>
                                            <td class="text-nowrap">@d.DocNo</td>
                                            @*<td class="text-nowrap">@d.CreatedDate</td>*@
                                            <td class="text-nowrap">@d.OutDoorCompanyShiftName</td>
                                            <td class="text-nowrap">@d.OutDoorCompanyType</td>
                                            @*<td class="text-nowrap">@d.Direction</td>*@
                                            <td class="text-nowrap">@d.ForDate</td>
                                            <td class="text-nowrap">@d.ForTime</td>
                                            <td class="text-nowrap">@d.Reason</td>
                                            <td class="text-nowrap">@d.VisitingUnit</td>
                                            <td class="text-nowrap">@d.ApprovedBy</td>
                                            <td class="text-nowrap">@d.ApproveRejectDate</td>
                                            <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                            <td class="text-nowrap">@d.ApprovedAutoManually</td>
                                        </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>


