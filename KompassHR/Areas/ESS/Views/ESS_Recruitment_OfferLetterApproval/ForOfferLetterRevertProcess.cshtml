<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Offer Letter Approval
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>

            </ol>
        </div>
    </div>

    <div class="alert alert-warning alert-dismissible rounded-0 mb-0 fade show">
        The system routes the request to the appropriate approver(s). This could involve multiple levels of approval based on the organization's hierarchy or approval matrix.
    </div>
    <div class="invoice">
        <!-- BEGIN invoice-company -->
        <div class="invoice-company">
            <span class="float-end hidden-print">
                @if (ViewBag.OfferLetterApprovalRevert.OffterLetterStatus == "Rejected")
                {
                    <button type="button" class="btn btn-success" onclick="OpenModal('Approved')">Approve</button>

                }
                else
                {
                    <button type="button" class="btn btn-danger" onclick="OpenModal('Rejected')">Reject</button>
                }
            </span>

            <div style="color:white">.</div>
        </div>
        <!-- END invoice-company -->
        <!-- BEGIN invoice-header -->



        <div class="invoice-header">
            <div class="invoice-from">
                <small></small>
                <address class="mt-5px mb-5px">
                    <i class="fa-solid fa-user"> </i> <strong class="text-dark">&nbsp;@ViewBag.OfferLetterApprovalRevert.CandidateName</strong><br />
                    <i class="fa-solid fa-phone-volume"> </i>&nbsp;    <b>Phone:</b>&nbsp; +@ViewBag.OfferLetterApprovalRevert.MobileNo <br />
                    <i class="fa-solid fa-envelope"> </i>&nbsp;&nbsp;<b>Email:</b>&nbsp;  @ViewBag.OfferLetterApprovalRevert.EmailId
                    @Html.HiddenFor(model => model.OfferLetterGenId_Encrypted, new { id = "txtOfferLetterGenId_Encrypted" })
                    @Html.HiddenFor(model => model.OfferLetterGenId, new { id = "txtOfferLetterGenId" })
                </address>
            </div>
            <div class="invoice-to">
                <small></small>
                <address class="mt-5px mb-5px">
                    <i class="fa-solid fa-building"> </i>&nbsp;&nbsp; &nbsp; <b> Current Organization:</b>&nbsp; @ViewBag.OfferLetterApprovalRevert.LastCompanyName<br />
                    <i class="fa-regular fa-handshake"> </i>&nbsp;&nbsp;  <b>  Current Designation: </b>&nbsp; @ViewBag.OfferLetterApprovalRevert.LastDesignation<br />
                    <i class="fa-solid fa-info"></i> &nbsp;&nbsp; &nbsp; <b>Experience:</b> &nbsp;@ViewBag.OfferLetterApprovalRevert.TotalExperience<br />
                </address>
            </div>
        </div><br />

        <div class="invoice-content">
            <div class="row">
                <div class="col-12">
                    <div class="card-body">

                        <form action="/Recruitment/Recruitment/EmployeesOfferLettersByMananger" method="post">
                            <input type="hidden" name="fid" id="hdMainId" />
                            <input class="control-label col-md-2" data-val="true" data-val-number="The field Fid must be a number." data-val-required="The Fid field is required." id="fid" name="Fid" type="hidden" value="17" />
                            <div class="panel-body">
                                <div class="row myModal">
                                    <div class="col-12" style="border: 1px solid #000;">
                                        <div>
                                            @Html.Raw(ViewBag.OfferLetterApprovalRevert.OfferLetterTemplate)
                                            @*<textarea autocomplete="Off" class="form-control summernote" cols="20" height="auto" id="summernote" name="JobDescription" rows="2" style="font-size:16px" Value="">@ViewBag.OfferLetterApprovalList.OfferLetterTemplate</textarea>
                                            <span class="field-validation-valid help-block" data-valmsg-for="OfferLetterHR" data-valmsg-replace="true" id="ErrorOfferLettermngr" readonly="readonly" style="color:red"></span>*@
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <br />
                        </form>

                        <br /><br /><br />
                        <!-- END table-responsive -->
                        <!-- BEGIN invoice-price -->
                        <!-- END invoice-price-->
                    </div>
                </div>
            </div>
        </div>

        <div id="footer" class="app-footer m-0">
            &copy; Probus Software Pvt. ltd
        </div>
    </div>
</div>


<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark</h4>

            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtFinalApproveRejectRemark" class="form-control" rows="4"></textarea>

                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" onclick="ApproveOfferLetter()" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress btnClear" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));


        $('#summernote[disabled="disabled"]').next().find(".note-editable").attr("contenteditable", false);
        //document.getElementById("summernote").disabled=true;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var List = @Html.Raw(Json.Encode(ViewBag.OfferLetterApprovalRevert));
        debugger;
        var Encrypted=List[0][1].Value;
        var id=List[0][0].Value;
        $("#txtOfferLetterGenId_Encrypted").val(Encrypted);
        $("#txtOfferLetterGenId").val(id);

    });


</script>

