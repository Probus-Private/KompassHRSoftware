                                                    <tr class="text-center">
                                                        <th class="text-nowrap">Action</th>
                                                        <th class="text-nowrap">Vendor</th>
                                                        <th class="text-nowrap">Agreement Start Date</th>
                                                        <th class="text-nowrap">Agreement End Date</th>
                                                        <th class="text-nowrap">Scope of Services</th>
                                                        <th class="text-nowrap">SLA Details</th>
                                                        <th class="text-nowrap">Service Charges</th>
                                                        <th class="text-nowrap">Payment Terms</th>
                                                        <th class="text-nowrap">Bank Name</th>
                                                        <th class="text-nowrap">IFSC Code</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @if (ViewBag.ComplianceDetails != null)
                                                    {
                                                        foreach (var d in ViewBag.ComplianceDetails)
                                                        {
                                                            <tr>
                                                                <td class="text-center">
                                                                    <button type="button"
                                                                            onclick="EditCompliance('@d.VendorComplianceId_Encrypted')"
