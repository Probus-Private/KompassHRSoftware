                                                @Html.HiddenFor(model => model.VendorComplianceId_Encrypted, new { id = "txtVendorComplianceId" })




                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Agreement Start Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.AgreementStartDate, new { @class = "form-control",name= "AgreementStartDate", id = "txtAgreementStartDate",type="date" ,autocomplete = "Off" })
