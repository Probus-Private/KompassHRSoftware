                                                                <td class="text-nowrap">
                                                                    @Convert.ToDateTime(d.AgreementEndDate).ToString("dd/MM/yyyy")
                                                                </td>
                                                                <td>@d.ScopeOfServices</td>
                                                                <td>@d.SLADetails</td>
                                                                <td class="text-end">@d.ServiceCharges</td>
                                                                <td>@d.PaymentTerms</td>
                                                                <td>@d.BankName</td>
                                                                <td class="text-nowrap">@d.IFSCCode</td>
                                                            </tr>
