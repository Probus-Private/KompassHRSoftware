</div>
<div class="row">
    @Html.Action("Vendor_SidebarMenu", "ESS_Vendor_ContactDetails")
</div>

<script>
    $(document).ready(function () {
        debugger
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });

        }
    });


    $("#SaveVendorCompliance").validate({
        rules: {
            ScopeOfServices: {
                required: true
            },
            AgreementStartDate: {
                required: true
            },
            AgreementEndDate: {
                required: true
            },
            SLADetails: {
                required: true
            },
            ServiceCharges: {
                required: true
            },
            PaymentTerms: {
                required: true
            },
            BankName: {
                required: true
            },
            IFSCCode: {
                required: true
            },
        },
        messages: {
            ScopeOfServices: {
                required: "Scope Of Services is required"
            },
            AgreementStartDate: {
                required: "Agreement Start Date is required"
            },
            AgreementEndDate: {
                required: "Agreement End Date is required"
            },
            SLADetails: {
                required: "SLA Details is required"
            },
            ServiceCharges: {
                required: "Service Charges No is required"
            },
            PaymentTerms: {
                required: "Payment Terms is required"
            },
            BankName: {
                required: "Bank Name is required"
            },
            IFSCCode: {
                required: "IFSC Code is required"
            },
        }
    });

    var form1 = $("#SaveVendorCompliance");
    form1.validate();
    $('#btnSubmit').click(function () {
        debugger
        if (form1.valid() == false) {
            return false;
        }
        var VendorComplianceId_Encrypted = $("#txtVendorComplianceId").val();
        var VendorId=$("#txtVendorId").val();
        $.ajax({
            url: "@Url.Action("IsComplianceExist", "ESS_Vendor_Compliance")",
            method: "get",
            data: { VendorComplianceId_Encrypted: VendorComplianceId_Encrypted,VendorId:VendorId},
            success: function (response) {
                debugger
                if (response.Icon=="error") {
                    debugger;
                    if (response.Message != null) {
                        Swal.fire({
                            icon: response.Icon,
                            text: response.Message,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });
                    }
                }
                else{
                    $("#SaveVendorCompliance").submit();
                }

            }
        });
    });

 function EditCompliance(id) {
    $.ajax({
        url: '@Url.Action("GetComplianceById", "ESS_Vendor_Compliance")',
        type: 'GET',
        data: { id: id },
        success: function (res) {

            var data = convertKeyValueArray(res);

            $("#txtVendorComplianceId").val(data.VendorComplianceId_Encrypted);
            $("#txtScopeOfServices").val(data.ScopeOfServices);
            $("#txtSLADetails").val(data.SLADetails);
            $("#txtServiceCharges").val(data.ServiceCharges);
            $("#txtPaymentTerms").val(data.PaymentTerms);
            $("#txtBankName").val(data.BankName);
            $("#txtIFSCCode").val(data.IFSCCode);

            $("#txtAgreementStartDate").val(convertDate(data.AgreementStartDate));
            $("#txtAgreementEndDate").val(convertDate(data.AgreementEndDate));

            $("#btnSubmit").html('<i class="fa-solid fa-pen"></i> Update');
        }
    });
}


    // Helper for yyyy-MM-dd (HTML5 date input)
    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

    function convertKeyValueArray(arr) {
        var obj = {};
        $.each(arr, function (i, item) {
            obj[item.Key] = item.Value;
        });
        return obj;
    }


</script>

