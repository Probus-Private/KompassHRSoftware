                                            <label class="form-label col-form-label col-md-12">
                                                SLA Details
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.SLADetails, new { @class = "form-control", id = "txtSLADetails", autocomplete = "Off",name= "SLADetails" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Service Charges
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.ServiceCharges, new { @class = "form-control", id = "txtServiceCharges", autocomplete = "Off", Maxlength = 50,name= "ServiceCharges" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Payment Terms
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PaymentTerms, new { @class = "form-control", id = "txtPaymentTerms", autocomplete = "Off", Maxlength = 50,name= "PaymentTerms" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Bank Name
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.BankName, new { @class = "form-control", id = "txtBankName", autocomplete = "Off", Maxlength = 50,name= "BankName" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                IFSC Code
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.IFSCCode, new { @class = "form-control", id = "txtIFSCCode", autocomplete = "Off", Maxlength = 50,name= "IFSCCode" })
                                            </div>
                                        </div>
                                    </div>

                                    @*<div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Cancelled Check Upload
                                            </label>
                                            <div class="col-md-12">
                                                <input type="file" class="form-control" id="fileCancelledCheck" name="CancelledCheckUpload" />
                                                @if (!string.IsNullOrEmpty(Model.CancelledCheckUpload))
                                                {
                                                    <a href="@Model.CancelledCheckUpload" target="_blank">View Uploaded File</a>
                                                }
                                            </div>
                                        </div>
                                    </div>*@
                                </div>

                                <div class="row mb-20px">
                                    <div class="LastShortLeaveBx">
