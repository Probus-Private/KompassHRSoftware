                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.ScopeOfServices, new { @class = "form-control", id = "txtScopeOfServices", autocomplete = "Off", Maxlength = 50 ,name= "ScopeOfServices" })
