<div id="content" class="app-content">
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                KRA
            </h1>
            <nav aria-label="breadcrumb">
                <ol style="list-style: none; padding: 0; margin: 0; display: flex; align-items: center;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })" aria-label="Go to Dashboard" title="Home">
                            <img src="~/assets/MenuImages/Home.png" style="width: 24px; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("GetList", "ESS_PMS_OwnGoalCreation", new { id = 11, ScreenId=60, area = "ESS" })" aria-label="Go Back" title="Back">
                            <img src="~/assets/MenuImages/Back.png" style="width: 24px; height: auto;" alt="Back">
                        </a>
                    </li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"];">
                    <h4 class="panel-title">KRA - @ViewBag.AddUpdateTitle</h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Create your personal goals within the PMS system.
                    </p>
                </div>

                <div class="panel-body" style="padding: 1.5rem;">
                    <form role="form" action="@Url.Action("SaveUpdate", "ESS_PMS_OwnGoalCreation", new { area = "ESS" })" id="OwnObjectiveCreation" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="Alignment1">
                                        Is Align <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.IsAlign, new List<SelectListItem>
                                        {
                                            new SelectListItem { Text = "--Select--", Value = "" },
                                            new SelectListItem { Text = "Yes", Value = "True" },
                                            new SelectListItem { Text = "No", Value = "False" }
                                        }, new { @class = "form-select", name = "IsAlign", @id = "txtIsAlign" })

                                        @Html.HiddenFor(model => model.OwnObjectiveCreationId_Encrypted, new { id = "OwnObjectiveCreationId_Encrypted" })
                                        @Html.HiddenFor(model => model.PMS_YearId, new { id = "PMS_YearId", Value = @ViewBag.Year })


                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6" id="alignWithContainer" style="display: none;">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="Alignment2">
                                        Align With <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownList("AlignWith", new List<SelectListItem>
                                        {
                                            new SelectListItem { Text = "--Select--", Value = "" },
                                            new SelectListItem { Text = "Team", Value = "Team" }
                                        }, new { @class = "form-select", name = "AlignWith", @id = "txtAlignWith" })
                                    </div>
                                </div>
                            </div>
                        </div>


                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-2" for="TargetType">
                                        Objectives <span class="important">*</span>
                                    </label>
                                    <div class="col-md-10">
                                        <div class="input-group" style="flex-wrap:nowrap;">
                                            @Html.DropDownList("ObjectiveId", new SelectList(ViewBag.ObjectiveList, "ObjectiveId", "ObjectiveTitle"), "--Select--", new { @class = "form-select", name = "ObjectiveId", @id = "txtObjectives" })

                                            <button type="button" class="btn btn-primary btn-sm Tooltip" onclick="addNewObjective()">
                                                <i class="fa fa-plus"></i>
                                                <span class="Tooltip-text">Add Objective</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-2" for="KRA">
                                        KRA <span class="important">*</span>
                                    </label>
                                    <div class="col-md-10">
                                        @Html.TextBoxFor(model => model.KRA, new { id = "txtKRA", @class = "form-control", placeholder = "Enter Key Result Area" })
                                        @*@Html.TextBoxFor(model => model.Target, new { id = "txtTarget", @class = "form-control", placeholder = "Enter target value" })*@


                                          </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="SmartPrinciple">
                                        Smart Principle <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownList("SmartPrinciple", new List<SelectListItem>{
                                            new SelectListItem {Text ="Specific", Value="Specific"},
                                            new SelectListItem {Text ="Measurable", Value="Measurable"},
                                            new SelectListItem {Text ="Achievable", Value="Achievable"},
                                            new SelectListItem {Text ="Relevant", Value="Relevant"},
                                            new SelectListItem {Text ="Time Bound", Value="Time Bound"},
                                        }, "--Select--", new { @class = "form-select", name = "SmartPrinciple", @id = "txtSmartPrinciple" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="UOM">
                                        UOM <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @*@Html.TextBoxFor(model => model.UOM, new { id = "txtUOM", @class = "form-control", placeholder = "e.g., Percentage, Number" })*@
                                        @Html.DropDownListFor(model => model.UOM, new SelectList(ViewBag.UOMList, "Name", "Name"), "--Select--", new { @class = "form-select", @id = "txtUOM" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="Target">
                                        Target <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @*@Html.TextBoxFor(model => model.Target, new { id = "txtTarget", @class = "form-control", placeholder = "Enter target value" })*@
                                     
                                        @Html.TextBoxFor(model => model.Target, new
                                   {
                                       id = "txtTarget",
                                       @class = "form-control",
                                       placeholder = "Enter target value",
                                       onkeypress = "return isNumberDecimal(event)",
                                       oninput = "validatePositiveNumber(this)"
                                   })   
                                           <span id="teamtarget"></span>

                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="Visibility">
                                        Visibility <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownList("Visibility", new List<SelectListItem>{
                                            new SelectListItem {Text ="Private", Value="Private"},
                                            new SelectListItem {Text ="Public", Value="Public"}
                                        }, "--Select--", new { @class = "form-select", name = "Visibility", @id = "txtVisibility" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="StartDate">
                                        Start Date <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.StartDate, "{0:yyyy-MM-dd}", new { id = "txtStartDate", @class = "form-control", type = "date" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="EndDate">
                                        End Date <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.EndDate, "{0:yyyy-MM-dd}", new { id = "txtEndDate", @class = "form-control", type = "date" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4">
                                        KPI Category<span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.KPICategory, new SelectList(ViewBag.CategoryList, "Name", "Name"), "--Select--", new { @class = "form-select", @id = "txtKPICategory", name = "KPICategory" })


                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4">
                                        KPI<span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.KPINameId, new SelectList(ViewBag.KPIList, "Id", "Name"), "--Select--", new { @class = "form-select", @id = "txtKPINameId", name = "KPINameId" })

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-2" for="Weightage">
                                        Description <span class="important">*</span>
                                    </label>
                                    <div class="col-md-10">
                                        <div class="input-group" style="align-items: center;">
                                            @Html.TextArea("KPIDiscription", "", new { id = "txtKPIDiscription", @class = "form-control", name = "KPIDiscription", @readonly = "readonly", Style = "background-color: #e9ecef;" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">

                            <div class="col-md-6">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-4" for="Weightage">
                                        Weightage <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        <div class="input-group" style="align-items: center;">
                                            @Html.TextBoxFor(model => model.Weightage, new { id = "txtWeightage", @class = "form-control", type = "number", min = "0", max = "100", placeholder = "0-100", style = "font-size: 0.9rem;" })
                                            <span class="input-group-text" id="weightageDisplay">
                                                @ViewBag.TotalWeightage / 100
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row">
                                    <label class="form-label col-form-label col-md-4">
                                        Target Type <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.TargetType, new SelectList(ViewBag.TragetTypeList, "Name", "Name"), "--Select--", new { @class = "form-select", @id = "txtTargetType" })


                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-2">
                                        Description
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-10">
                                        @Html.TextArea("Description", new { id = "txtDescription", name = "Description", @class = "summernote", autocomplete = "Off", style = "border: 2px solid #000; padding: 10px;", contenteditable = "true" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 text-end">
                                <div class="BtnBx" style="margin-top: 1rem;">
                                    <button type="button" id="SubmitBtn" class="btn btn-primary btn-sm">
                                        <i class="fa-solid fa-floppy-disk"></i> Save
                                    </button>
                                    <button type="button" id="btnGetList" class="btn btn-danger btn-sm">
                                        <i class="fa-solid fa-list"></i> List
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ObjectiveModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Create Objective</h4>
            </div>
            <div class="modal-body">
                <div class="modal-body-content">
                    <form role="form" action="@Url.Action("SaveObjective", "ESS_PMS_OwnGoalCreation", new { area = "ESS" })" id="ObjectiveForm" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-3" for="Origin">
                                        Origin <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        <select id="txtOrigin" name="Origin" class="form-select" readonly>
                                            <option value="Individual" selected>Individual</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-3" for="EmployeeId">
                                        Employee ID <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        <input type="text" id="txtEmployeeName" name="EmployeeId" class="form-control"
                                               value="@(Session["EmployeeName"]?.ToString() ?? "")" readonly />
                                        <input type="hidden" id="txtEmployeeId" name="EmployeeId" class="form-control"
                                               value="@(Session["EmployeeId"]?.ToString() ?? "")" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row align-items-center">
                                    <label class="form-label col-form-label col-md-3" for="ObjectiveTitle">
                                        Objective Title <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        <input type="text" id="txtObjectiveTitle" name="ObjectiveTitle" class="form-control"
                                               placeholder="Enter objective title" maxlength="200" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-primary btn-sm" id="SaveObjectiveBtn">
                                <i class="fa fa-save"></i> Save
                            </button>
                            <button type="button" class="btn btn-danger btn-sm CloseModel" id="CloseModel" data-bs-dismiss="modal">
                                <i class="fa fa-times"></i> Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        var selectedObjectiveId = '@Model.ObjectiveId';
        var CheckAddUpdate=@Html.Raw(Json.Encode(ViewBag.AddUpdateTitle));
        var isAlign=@Html.Raw(Json.Encode(ViewBag.IsAlign));

        if (CheckAddUpdate === "Update") {
            if(isAlign==true)
            {
                var AlighwithType = @Html.Raw(Json.Encode(ViewBag.AlignWithType));
                $("#txtIsAlign").val("True").trigger("change");

                setTimeout(function () {
                    $("#txtAlignWith").val(AlighwithType).trigger("change");
                }, 150);
            }
        }

        $('#ObjectiveModal').on('hidden.bs.modal', function () {
            // Reset form fields
            $('#ObjectiveForm')[0].reset();

            // Clear validation errors (if any)
            $('#ObjectiveForm').validate().resetForm();
            $('#ObjectiveForm').find('.error').removeClass('error');
        });

        var initialWeightage = parseFloat($("#txtWeightage").val()) || 0;
        var baseTotalWeightage = parseFloat(@ViewBag.TotalWeightage) || 0;
        var isUpdateMode = '@(Model.OwnObjectiveCreationId_Encrypted != null)' === 'True';
        var adjustedTotalWeightage = isUpdateMode
            ? baseTotalWeightage - initialWeightage
            : baseTotalWeightage;



        $(".input-group-text").text(baseTotalWeightage + " / 100");

        $("#txtWeightage").on("input", function() {
            debugger
            var $this = $(this);
            var value = $this.val();
            var inputWeightage = parseFloat(value) || 0;
            var $weightageDisplay = $this.siblings('.input-group-text');

            if (value !== "" && (isNaN(value) || inputWeightage < 0 || inputWeightage > 100)) {
                $this.val(value.slice(0, -1));
                $this.valid();
                return;
            }

            // Calculate proposed total weightage
            var proposedTotal = isUpdateMode
                ? (adjustedTotalWeightage + inputWeightage)
                : (baseTotalWeightage + inputWeightage);

            if (proposedTotal > 100) {
                $weightageDisplay.text(proposedTotal + " / 100 (Exceeds limit)");
                $this.valid();
            } else {
                $weightageDisplay.text(proposedTotal + " / 100");
                $this.valid();
            }
        });

        $("#txtObjectives").select2();
        $("#txtKPICategory").select2();
        $("#txtKPINameId").select2();
        $("#txtIsAlign").select2();

        var isAlign = $("#txtIsAlign").val();
        debugger
        if (isAlign == "True") {
            $("#alignWithContainer").show();
            // Get the current AlignWith value and trigger change
            var alignWithValue = $("#txtAlignWith").val();
            if (alignWithValue) {
                // Small delay to ensure DOM is ready
                setTimeout(function() {
                    $("#txtAlignWith").trigger("change");
                }, 100);
            }
        } else {
            $("#alignWithContainer").hide();
            $("#txtAlignWith").val("").trigger("change");
        }


        $("#txtIsAlign").on("change", function () {
            debugger
            var isAlign = $(this).val();
            if (isAlign === "True") {
                $("#alignWithContainer").show();
                $("#txtAlignWith").val("").trigger("change");
            } else {
                $("#alignWithContainer").hide();
                $("#txtAlignWith").val("");   // ❌ no trigger change

                // ✅ Load OWN objectives
                loadObjectives("");
            }
        });

        $("#txtAlignWith").on("change", function () {

            var Origin = $(this).val();

            var EmployeeId = $("#EmployeeId").val();
            var $objectiveDropdown = $("#txtObjectives");

            $objectiveDropdown.empty().append('<option value="">-- Select --</option>');

            if (!Origin) return;

            $.ajax({
                url: '/ESS_PMS_OwnGoalCreation/OriginWiseObjective',
                type: 'GET',
                data: { Origin: Origin, EmployeeId: EmployeeId },
                dataType: 'json',
                success: function (response) {
                    debugger


                    $.each(response, function (i, row) {

                        var obj = {};
                        $.each(row, function (j, kv) {
                            obj[kv.Key] = kv.Value;
                        });

                        $objectiveDropdown.append(
                            $('<option/>', {
                                value: obj.Id,
                                text: obj.Name
                            })
                        );
                    });

                    // 🔥 SAFE restore only in EDIT mode
                    if (!isNaN(selectedObjectiveId) && selectedObjectiveId > 0) {
                        $objectiveDropdown
                            .val(selectedObjectiveId.toString())
                            .trigger("change");

                        selectedObjectiveId = 0;
                    }

                }
            });
        });

        $("#txtObjectives").on("change", function () {
            debugger;

            var AlignWith = $("#txtAlignWith").val();
            var Objective = $("#txtObjectives").val();

            if (AlignWith != null && AlignWith !== "") {

                $.ajax({
                    url: '/ESS_PMS_OwnGoalCreation/ObjectiveWiseDetails',
                    type: 'GET',
                    data: { AlignWith: AlignWith, Objective: Objective },
                    dataType: 'json',
                    success: function (response) {
                        debugger;

                        var obj = {};
                        response.forEach(function (x) {
                            obj[x.Key] = x.Value;
                        });

                        $("#txtSmartPrinciple").val(obj.SmartPrinciple);
                        $("#txtUOM").val(obj.UOM);
                        $("#teamtarget")
                            .text("Team Target : " + obj.Target)
                            .css({
                                "margin-left": "10px",
                                "color": "#0d6efd",
                                "font-weight": "600"
                            });
                        $("#txtVisibility").val(obj.Visibility);
                        $("#txtStartDate").val(convertDate(obj.StartDate));
                        $("#txtEndDate").val(convertDate(obj.EndDate));
                        $("#txtTargetType").val(obj.TargetType);
                        selectedKPIId = obj.KPINameId;   // ⭐ THIS WAS MISSING
                        $("#txtKPICategory").val(obj.KPICategory).trigger("change");
                        setTimeout(function () {
                            $("#txtKPINameId").val(obj.KPINameId);
                        }, 300);
                        $("#txtKPINameId").val(obj.KPINameId);
                        $("#txtWeightage").val(obj.Weightage);
                        $("#txtWeightage").trigger("input");   // update display
                        $("#txtWeightage").valid();
                    }
                });
            }
        });

        var selectedKPIId = null;

        $("#txtKPICategory").on("change", function () {
            var Category = $(this).val();
            var $KPINameId = $("#txtKPINameId");
            if ($KPINameId.hasClass("select2-hidden-accessible")) {
                $KPINameId.select2("destroy");
            }
            $KPINameId.empty().append('<option value="">--Select--</option>');
            if (!Category) return;
            $.ajax({
                url: '@Url.Action("CategoryWiseKPI", "ESS_PMS_OwnGoalCreation", new { area = "ESS" })',
                type: 'GET',
                data: { Category: Category },
                dataType: 'json',
                success: function (response) {
                    debugger
                    if (response && response.length > 0) {
                        $.each(response, function (index, team) {
                            $KPINameId.append(
                                new Option(team.Name, team.Id, false, false)
                            );
                        });
                        $KPINameId.select2({
                            width: "100%",
                            placeholder: "--Select--"
                        });
                        if (selectedKPIId) {
                            $KPINameId.val(selectedKPIId).trigger("change");
                            selectedKPIId = null;
                        }
                    }
                }
            });
        });

        $("#txtKPINameId").on("change", function () {
            debugger
            var KPIID = $("#txtKPINameId").val();
            var $KPIDiscription = $("#txtKPIDiscription");
            $.ajax({
                url: '@Url.Action("KPIWiseDescription", "ESS_PMS_OwnGoalCreation", new { area = "ESS" })',
                type: 'GET',
                data: { KPIID: KPIID},
                dataType: 'json',
                success: function (response) {
                    debugger
                    if (response && response.length > 0) {
                        $("#txtKPIDiscription").val(response);
                    }
                }
            });
        });

    });

    $(".summernote").summernote({
        placeholder: '',
        height: "300"
    });

    $("#btnGetList").on("click", function () {
        debugger
        window.location.href = "@Url.Action("GetList", "ESS_PMS_OwnGoalCreation", new { area = "ESS" })";
    });
</script>

<script>

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

    function addNewObjective() {
        var objectiveModal = new bootstrap.Modal(document.getElementById('ObjectiveModal'), {
            backdrop: 'static',
            keyboard: true
        });
        objectiveModal.show();
    }

    $("#ObjectiveForm").validate({
        rules: {
            ObjectiveTitle: {
                required: true
            }
        },
        messages: {
            ObjectiveTitle: {
                required: "Please Enter Objective Title"
            }
        }
    });

    var form1 = $("#ObjectiveForm");
    form1.validate();
    $('#SaveObjectiveBtn').click(function () {
        console.log("Validating ObjectiveForm...");
        if (form1.valid() == false) {
            return false;
        }
        var ObjectiveTitle = $("#txtObjectiveTitle").val();
        var Origin = $("#txtOrigin").val();
        $.ajax({
            url: '/ESS_PMS_OwnGoalCreation/IsObjectiveExist',
            method: "get",
            data: { ObjectiveTitle: ObjectiveTitle, Origin: Origin },
            success: function (response) {
                debugger
                if (response.Icon == "error") {
                    //showAlert(response.Icon, response.Message);
                    Swal.fire({
                        icon: response.Icon || 'error',
                        text: response.Message || response.Message,
                        allowOutsideClick: false
                    });
                } else {
                    $("#ObjectiveForm").submit();
                    $('#ObjectiveModal').modal('hide');
                }
            }
        });
    });

    $("#OwnObjectiveCreation").validate({

        errorPlacement: function (error, element) {
            if (element.hasClass('select2-hidden-accessible')) {
               
                error.insertAfter(element.next('.select2'));
            } else if (element.parent('.input-group').length) {
                error.insertAfter(element.parent());
            } else {
                error.insertAfter(element);
            }
        },

        highlight: function (element) {
            $(element).closest('.form-group, .mb-3').addClass('has-error');
        },
        unhighlight: function (element) {
            $(element).closest('.form-group, .mb-3').removeClass('has-error');
        },
        rules: {
            IsAlign: {
                required: true
            },
            AlignWith: {
                required: {
                    depends: function (element) {
                        return $("#txtIsAlign").val() === "True"; // Check for string "true"
                    }
                }
            },
            ObjectiveId: {
                required: true
            },
            KRA: {
                required: true
            },
            SmartPrinciple: {
                required: true
            },
            UOM: {
                required: true
            },
            Target: {
                required: true
            },
            Visibility: {
                required: true
            },
            StartDate: {
                required: true
            },
            EndDate: {
                required: true
            },
            KPICategory:{
                required:true
            },
            KPINameId:{
                required:true
            },
            Weightage: {
                required: true,
                number: true,
                min: 0,
                max: 100,
                maxTotalWeightage: true
            },
            Description: {
                required: true
            },
            TargetType:{
                required: true
            },
        },
        messages: {
            IsAlign: {
                required: "Please select whether the objective is aligned"
            },
            AlignWith: {
                required: "Please select align with"
            },
            ObjectiveId: {
                required: "Please select Objective"
            },
            KRA: {
                required: "Please enter KRA"
            },
            SmartPrinciple: {
                required: "Please select Smart Principle"
            },
            UOM: {
                required: "Please enter UOM"
            },
            Target: {
                required: "Please enter target value"
            },
            Visibility: {
                required: "Please select Visibility"
            },
            StartDate: {
                required: "Please select Start Date"
            },
            EndDate: {
                required: "Please select End Date"
            },
            KPICategory:{
                required:"Please select Category"
            },
            KPINameId:{
                required:"Please select KPI Name"
            },
            Weightage: {
                required: "Please enter Weightage",
                number: "Please enter a valid number",
                min: "Weightage must be at least 0",
                max: "Weightage cannot exceed 100"
            },
            Description: {
                required: "Please enter Description"
            },
            TargetType:{
                required: "Please enter Target Type"
            }
        },
        ignore: [],
        onfocusout: function (element) {
            this.element(element);
        },
        onkeyup: function (element) {
            this.element(element);
        },
        debug: true
    });

    var form = $("#OwnObjectiveCreation");
    form.validate();

    $("#SubmitBtn").on("click", function () {
        debugger
        form.valid();

        var $objectiveDropdown = $("#txtObjectives").val();

        if (form.valid() == false) {
            return false;
        }

        var ObjectiveId=$("#txtObjectives").val();
        var GoalCreationIDEncrypted=$("#OwnObjectiveCreationId_Encrypted").val();
        $.ajax({
            url: '/ESS_PMS_OwnGoalCreation/IsOwnGoalExist',
            method: "get",
            data: { ObjectiveId: ObjectiveId, GoalCreationIDEncrypted: GoalCreationIDEncrypted },
            success: function (response) {
                debugger
                if (response.Icon == "error") {
                    //showAlert(response.Icon, response.Message);
                    Swal.fire({
                        icon: response.Icon || response.Icon,
                        text: response.Message || response.Message,
                        allowOutsideClick: false
                    });
                } else {
                    $("#OwnObjectiveCreation").submit();

                }
            }
        });
    });

    $.validator.addMethod("maxTotalWeightage", function (value, element) {
        var totalWeightage = parseFloat(@ViewBag.TotalWeightage) || 0; // Get TotalWeightage from ViewBag
        var inputWeightage = parseFloat(value) || 0; // Get input value
        return inputWeightage >= 0 && inputWeightage <= 100 && (totalWeightage + inputWeightage) <= 100;
    }, "The total weightage (current + input) must not exceed 100.");


    function updateWeightageDisplay(inputWeightage) {
        inputWeightage = parseFloat(inputWeightage) || 0;

        var proposedTotal = isUpdateMode
            ? (adjustedTotalWeightage + inputWeightage)
            : (baseTotalWeightage + inputWeightage);

        if (proposedTotal > 100) {
            $("#weightageDisplay").text(proposedTotal + " / 100 (Exceeds limit)");
        } else {
            $("#weightageDisplay").text(proposedTotal + " / 100");
        }
    }


    function loadObjectives(origin) {
        var $objectiveDropdown = $("#txtObjectives");
        $objectiveDropdown.empty().append('<option value="">--Select--</option>');

        $.ajax({
            url: '/ESS_PMS_OwnGoalCreation/OriginWiseObjective',
            type: 'GET',
            data: { Origin: origin },
            dataType: 'json',
            success: function (response) {
                debugger
                $.each(response, function (i, row) {
                    var obj = {};
                    $.each(row, function (j, kv) {
                        obj[kv.Key] = kv.Value;
                    });

                    $objectiveDropdown.append(
                        $('<option/>', {
                            value: obj.Id,
                            text: obj.Name
                        })
                    );
                });
            }
        });
    }
</script>

<script>
    function isNumberDecimal(evt) {
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode >= 48 && charCode <= 57)
            return true;
        if (charCode == 46)
            return true;
        return false;
    }

    function validatePositiveNumber(input) {
        if (input.value < 0) {
            input.value = input.value.replace('-', '');
        }
    }
</script>