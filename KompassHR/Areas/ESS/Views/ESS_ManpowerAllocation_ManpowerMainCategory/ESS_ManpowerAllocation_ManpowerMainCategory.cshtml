        //        contentType: "application/json; charset=utf-8",
        //        url: 'GetBusinessUnit',
        //        data: { CmpId: CmpId },
        //        success: function (data) {
        //            if (data != null) {
        //                $("#txtKPICategoryBranchId").append("<option value=0>--Select-- </option>");
        //                $.each(data, function (i, p) {
        //                    $("#txtKPICategoryBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
        //                });
        //            }
        //            else {
        //                $('#ErrorESSPassword').html(" ");
        //            }
        //        }
        //    })
        //});
    });

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );
    $('#SaveManpowerCategory').validate({
        rules: {
            //CmpID: {
            //    required: true,
            //},
            //KPICategoryBranchId: {
            //    required: true,
            //},
            KPICategoryName: {
                required: true,
            },

        },
        messages: {
            //CmpID: {
            //    required: "Company name  is required"
            //},
            //KPICategoryBranchId: {
            //    required: "Business unit is required"
            //},
            KPICategoryFName: {
                required: "KPI category name is required"
            },

        },
    });

    var form = $("#SaveManpowerCategory");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var KPICategoryId_Encrypted=$("#KPICategoryId_Encrypted").val();
        var KPICategoryName = $("#txtKPICategoryFName").val();

        $.ajax({
            async: true,
            type:"POST",
            url: '@Url.Action("IsManpowerMainAllocationExists", "ESS_ManpowerAllocation_ManpowerMainCategory")',
            data:JSON.stringify({KPICategoryId_Encrypted:KPICategoryId_Encrypted,KPICategoryName:KPICategoryName}),
            contentType: "application/json; charset=utf-8",
            dataType:"text",
            success:function(response){
                debugger;
                var Getdata = JSON.parse(response);
                var Message1 = Getdata.Message;
                var Icon1 = Getdata.Icon;
                if (Icon1=="error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });
                    }
                }
                else{
                    $("#SaveManpowerCategory").submit();
                }
            }
        });
    });

</script>
