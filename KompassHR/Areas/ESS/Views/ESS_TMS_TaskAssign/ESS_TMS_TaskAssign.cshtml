<script>
    // Format time input as HH:mm with validation
    function formatAndSetTime(value) {
        let raw = (value || '').replace(/[^0-9]/g, '').padEnd(4, '0').slice(0, 4);
        let hours = parseInt(raw.slice(0, 2)) || 0;
        let minutes = parseInt(raw.slice(2, 4)) || 0;

        // Handle hour overflow (24-hour format)
        if (hours >= 24) {
            hours = hours % 24;
        }

        // Handle minute overflow
        if (minutes >= 60) {
            hours += Math.floor(minutes / 60);
            minutes = minutes % 60;

            // Re-check hour overflow after minute adjustment
            if (hours >= 24) {
                hours = hours % 24;
            }
        }

        return {
            formattedTime: `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`,
            hours: hours,
            minutes: minutes
        };
    }

    function updateDurationDisplay(timeValue) {
        const result = formatAndSetTime(timeValue);
        const durationField = document.getElementById('txtTotalDuration');
        if (durationField) {
            durationField.value = `${result.hours} Hr : ${result.minutes} Min`;
        }
        return result.formattedTime;
    }

    function attachTimeHandlers(inputId) {
        const input = document.getElementById(inputId);
        if (!input) return;

        input.addEventListener('input', function(e) {
            // Allow only numbers and colon
            this.value = this.value.replace(/[^0-9:]/g, '');

            // Auto-insert colon after 2 digits
            if (this.value.length > 2 && !this.value.includes(':')) {
                this.value = this.value.substring(0, 2) + ':' + this.value.substring(2);
            }

            // Limit to 5 characters (HH:mm)
            if (this.value.length > 5) {
                this.value = this.value.substring(0, 5);
            }

            // Update duration display in real-time
            updateDurationDisplay(this.value);
        });

        input.addEventListener('blur', function() {
            const result = formatAndSetTime(this.value);
            this.value = result.formattedTime;
            updateDurationDisplay(this.value);
        });

        // Prevent invalid key presses
        input.addEventListener('keydown', function(e) {
            // Allow: backspace, delete, tab, escape, enter
            if ([8, 9, 13, 27, 46].includes(e.keyCode) ||
                // Allow: Ctrl+A, Ctrl+C, Ctrl+V, Ctrl+X
                (e.ctrlKey && [65, 67, 86, 88].includes(e.keyCode))) {
                return true;
            }

            // Allow colon only after 2 digits
            if (e.key === ':' && this.selectionStart >= 2) {
                return true;
            }

            // Allow numbers (main keyboard and numpad)
            if ((e.keyCode >= 48 && e.keyCode <= 57) ||
                (e.keyCode >= 96 && e.keyCode <= 105)) {
                return true;
            }

            e.preventDefault();
            return false;
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        attachTimeHandlers('txtTime');
    });
</script>


