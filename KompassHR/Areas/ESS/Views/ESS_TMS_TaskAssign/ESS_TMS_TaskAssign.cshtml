<script>

    $(document).ready(function () {debugger
        $("#txtAssignToEmployeeID").select2();
        $("#txtProjectID").select2();
        $("#txtModuleID").select2();
        $("#txtClientID").select2();
        $("#txtTaskCategoryId").select2();
        $("#txtTaskSubCategoryId").select2();
        $("#txtFromTime").prop("disabled", true);
        $("#txtToTime").prop("disabled", true);

        var SelectedDayTime = $('#txtTaskType').val();
       
        if(SelectedDayTime =="Day")
        {
            $("#txtDueDate").attr('readOnly', false);
            $("#txtFromTime").prop("disabled", true);
            $("#txtToTime").prop("disabled", true);
            $("#txtTime").prop("disabled", true);
            $("#txtStartDate").prop("disabled", false);
            $("#txtDueDate").prop("disabled", false);
        }
        if(SelectedDayTime =="Time")
        {
            debugger;
            $("#txtTime").prop("disabled", false);
            $("#txtDueDate").attr('readOnly', true);
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed || result.isDismissed) {
                    location.reload();
                }
            });
        }
        $("#btnGetList").click(function () {
            debugger;
            var url = '@Url.Action("GetListTaskAssign", "ESS_TMS_TaskAssign", new { area = "ESS" })';
            window.location.href = url;
        });


        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#txtDocDate").val(dateString);
        var Doc = @Html.Raw(Json.Encode(TempData["DocDate"]));
        if(Doc =="")
        {

        }
        else
        {
            var DocDate =  convertDate(Doc);
            $("#txtDocDate").val(DocDate);
        }

        // $("#txtStartDate").val(dateString);
        function strToMins(t) {
            var s = t.split(":");
            return Number(s[0]) * 60 + Number(s[1]);
        }

        function minsToStr(t) {
            return Math.trunc(t / 60)+':'+('00' + t % 60).slice(-2);
        }

    });//ready function


    // Custom method to check if Due Date is greater than or equal to Start Date
    $.validator.addMethod("dateGreaterThan", function (value, element, params) {
        var startDate = $(params).val(); // Get Start Date value
        if (!startDate || !value) return true; // Skip validation if either field is empty
        return new Date(value) >= new Date(startDate); // Compare dates
    }, "Due Date must be greater than or equal to Start Date.");


    // Custom method to check if Start Date is less than or equal to Due Date
    $.validator.addMethod("dateLessThan", function (value, element, params) {
        var dueDate = $(params).val(); // Get Due Date value
        if (!dueDate || !value) return true; // Skip validation if either field is empty
        return new Date(value) <= new Date(dueDate); // Allow same date or earlier dates
    }, "Start Date must be less than or equal to Due Date.");

    // Custom method to check if ToTime is greater than FromTime
    $.validator.addMethod("timeLessThan", function (value, element, params) {
        var fromTime = $(params).val(); // Get FromTime value
        if (!fromTime || !value) return true; // Skip validation if either field is empty
        var fromDate = new Date("1970/01/01 " + fromTime); // Parse FromTime
        var toDate = new Date("1970/01/01 " + value); // Parse ToTime
        return toDate > fromDate; // Allow ToTime to be the same or greater
    }, "To Time must be greater than From Time.");

    // Custom method to check if FromTime is less than ToTime
    $.validator.addMethod("timeGreaterThan", function (value, element, params) {
        var toTime = $(params).val(); // Get ToTime value
        if (!toTime || !value) return true; // Skip validation if either field is empty
        var fromDate = new Date("1970/01/01 " + value); // Parse FromTime
        var toDate = new Date("1970/01/01 " + toTime); // Parse ToTime
        return fromDate <= toDate; // Allow FromTime to be the same or less
    }, "From Time must be less than To Time.");

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

