                        </table>

                    </div>
                </div>
                <br />
                @*<div class="row">
                        <div class="col-md-12">
                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblShift" style="width: 100%;">
                                <thead style="background-color:#eee">
                                    <tr class="text-center">
                                        <th class="text-nowrap text-center">Action</th>
