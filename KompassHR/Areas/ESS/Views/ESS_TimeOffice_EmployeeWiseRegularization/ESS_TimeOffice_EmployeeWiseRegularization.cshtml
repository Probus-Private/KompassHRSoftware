<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Employee-wise Punch Adjustment
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_AttendanceRegularization_SubMenu", "ESS_TimeOffice_AttendanceRegularization_SubMenu", new {id = 5, ScreenId= 363, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Employee-wise Punch Adjustment </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        "Employee Wise Attendance Regularization" refers to the process of systematically managing and correcting attendance records for each individual employee.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_TimeOffice_EmployeeWiseRegularization", "ESS_TimeOffice_EmployeeWiseRegularization", new { area = "ESS" })' id="formRegularization" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <abel class="form-label col-form-label col-md-4">
                                                Company Name
                                            </abel>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCompanyName" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBusinessUnit, "Id", "Name"), new { @class = "form-select", name = "BusinessUnit", id = "ddlBranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", type = "date", name = "FromDate", id = "txtFromDate" })
                                                @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", type = "date", name = "ToDate", id = "txtToDate" })
                                                @Html.ValidationMessage("ToDate", "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.EmployeeID, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select-- ", new { @class = "form-select", name = "EmployeeName", id = "ddlEmployeeName" })
                                                <span id="ErrorddlEmployeeName" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-4">
                                            </div>
                                            <div class="col-8">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployeeAttendance()">
                                                    <i class="fa-solid fa-spinner"></i>&nbsp; Load Attendance
                                                </button>

                                                <button type="button" data-bs-toggle="offcanvas" class="btn btn-warning btnpress btn-sm" href="#offcanvasExample" id="btnActionList" onclick="funSetDate(this)" style="width:110px; margin-left: 5px;">
                                                    <i class="fa-solid fa-eye fa-lg blink"></i> &nbsp; Show Log
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="table-scroll divEmployeeLog">
                                        <div class="table-wrap">
                                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblEmployeeWise" style="width: 100%;">
                                                <thead class="table-active horizontal-scroll tblheadEmployeeLog" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="trheading">
                                                        <th class="text-start text-center">Action</th>
                                                        <th class="text-start text-center">Sr.No.</th>
                                                        <th class="text-start text-center">Date</th>
                                                        <th class="text-start text-center">In-Time</th>
                                                        <th class="text-start text-center">Out-Time</th>
                                                        <th class="text-start text-center">Remark</th>
                                                        <th hidden>Remark</th>
                                                        <th hidden>isRestricted</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @{
                                                        int SrNo = 0;
                                                    }
                                                    @if (ViewBag.EmployeeLog != null)
                                                    {
                                                        foreach (var d in ViewBag.EmployeeLog)
                                                        {
                                                            SrNo++;
                                                            string formattedInTime = "";
                                                            string formattedOutTime = "";

                                                            DateTime myMaxDate = @d.InOut_AttendanceDate.AddDays(1);
                                                            DateTime myMinDate = @d.InOut_AttendanceDate.AddDays(0);
                                                            string MaxDate = myMaxDate.ToString("yyyy-MM-ddTHH:mm");
                                                            string MinDate = myMinDate.ToString("yyyy-MM-ddTHH:mm");

                                                            bool isRestricted = @d.isRestricted;
                                                            //bool isRestricted = true;
                                                            <tr>
                                                                @if (@d.InOut_InTime != null)
                                                                {
                                                                    if (@d.InOut_InTime.ToString("yyyy-MM-ddTHH:mm") != "0001-01-01T00:00")
                                                                    {
                                                                        formattedInTime = @d.InOut_InTime.ToString("yyyy-MM-ddTHH:mm");
                                                                    }
                                                                    else
                                                                    {
                                                                        formattedInTime = "";
                                                                    }
                                                                }
                                                                @if (@d.InOut_OutTime != null)
                                                                {
                                                                    if (@d.InOut_OutTime.ToString("yyyy-MM-ddTHH:mm") != "0001-01-01T00:00")
                                                                    {
                                                                        formattedOutTime = @d.InOut_OutTime.ToString("yyyy-MM-ddTHH:mm");
                                                                    }
                                                                    else
                                                                    {
                                                                        formattedOutTime = "";
                                                                    }
                                                                }
                                                                <td class="text-center" style="background-color:#eee">
                                                                    @if (!isRestricted)
                                                                    {
                                                                        <a onclick="removeRow(this)" id="btnDelete" style="cursor:pointer;">
                                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                        </a>
                                                                    }
                                                                    else
                                                                    {
                                                                        <a style="cursor: not-allowed;" id="btnRestricted">
                                                                            <i class="fa-solid fa-lock text-dark fa-lg"></i>
                                                                        </a>
                                                                    }
                                                                </td>
                                                                <td class="text-center" style="background-color:#eee">@SrNo</td>
                                                                <td class="text-nowrap text-center"> <input type="date" value="@d.InOut_AttendanceDate.ToString("yyyy-MM-dd")" class="form-control" style="background-color:#eee" @(isRestricted ? "readonly" : "")></td>
                                                                @if (formattedInTime == "")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control InTime" id="txtInTime" min="@MinDate" max="@MaxDate" value="" name="timeInput" onclick="getRowNumber(this)" onchange="validateTimeInput(this)" style="width:170px" @(isRestricted ? "readonly" : "")>
                                                                        <span class="Error" id="ErrortxtInTime" style="display:none"></span>
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control InTime" id="txtInTime" min="@d.InOut_AttendanceDate.ToString("yyyy-MM-ddTHH:mm")" max="@MaxDate" value="@d.InOut_InTime.ToString("yyyy-MM-ddTHH:mm")" name="timeInput" onclick="getRowNumber(this)" onchange="validateTimeInput(this)" style="width:170px" @(isRestricted ? "readonly" : "")>
                                                                        <span class="Error" id="ErrortxtInTime" style="display:none"></span>
                                                                    </td>
                                                                }
                                                                @if (formattedOutTime == "")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control OutTime" id="txtOutTime" min="@MinDate" max="@MaxDate" value="" onclick="getRowNumber(this)" name="timeInput" onchange="validateTimeInput(this)" style="width:170px" @(isRestricted ? "readonly" : "")>
                                                                        <span class="Error" id="ErrortxtOutTime" style="display:none"></span>
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    //DateTime myDate = @d.InOut_AttendanceDate.AddDays(1);
                                                                    //string OutTimeMax = myDate.ToString("yyyy-MM-ddTHH:mm");
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control OutTime" id="txtOutTime" min="@d.InOut_AttendanceDate.ToString("yyyy-MM-ddTHH:mm")" max="@MaxDate" value="@d.InOut_OutTime.ToString("yyyy-MM-ddTHH:mm")" onclick="getRowNumber(this)" name="timeInput" onchange="validateTimeInput(this)" style="width:170px" @(isRestricted ? "readonly" : "")>
                                                                        <span class="Error" id="ErrortxtOutTime" style="display:none"></span>
                                                                    </td>
                                                                }
                                                                @*<td class="text-nowrap text-center"><input type="time" value="@d.InTime" class="form-control"></td>
                                                                    <td class="text-nowrap text-center"><input type="time" value="@d.OutTime" class="form-control"></td>*@
                                                                <td class="text-start text-center"><input type="text" id="txtRemark" class="form-control" value="@d.InOut_inoutnote" @(isRestricted ? "readonly" : "")></td>
                                                                <td class="text-start text-center" hidden>@d.InOut_EmployeeId</td>
                                                                <td class="text-start text-center" hidden>@d.isRestricted</td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <br />
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <span class="Error" id="ErrortblEmployeeWise" style="margin-top: 12px; margin-right:31px; font-size:15px;"></span>

                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>

                                                    <a href="@Url.Action("ESS_TimeOffice_AttendanceRegularization_SubMenu", "ESS_TimeOffice_AttendanceRegularization_SubMenu", new { id=5 , ScreenId=363, area = "ESS" })">
                                                        <button type="button" class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i> Back
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- Start panel -->
<div class="row">
    <div class="col-lg-12">
        <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false" data-bs-scroll=true>
