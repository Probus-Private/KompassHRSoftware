@model KompassHR.Areas.ESS.Models.ESS_Recruitment.Recruitment_Interview
@{
    ViewBag.Title = "ConductInterview";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>


<style>
    .table > :not(caption) > * > * {
        border-bottom: none;
    }

    .tblAddData td:nth-child(1) {
        display: none;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Conduct Interview <small>header small text goes here...</small>
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="panel panel-inverse">
        <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
            <h4 class="panel-title">Conduct Interview</h4>
            <div class="panel-heading-btn">
                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
            </div>
        </div>
        <br />
        <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
            <p class="pb-0">
                Depending on the organization's process, the list may serve as a tool for capturing interview feedback and evaluations from interviewers. This feedback can be used to assess candidates' qualifications, skills, and fit for the position.
            </p>
        </div>
        <div class="panel-body">
            <form action="/ESS/ESS_Recruitment_Interview/SaveUpdate" id="SaveInterviewSchedule" method="post">
                @*<form action="/Recruitment/Recruitment/SaveConductInterview" id="SaveConductInterview" method="post">*@
                <div class="col-md-12 row">
                    <div class="col-md-6">
                        <label for="form-field-8"><b><h6>Title :</h6></b></label>
                    </div>
                    <div class="col-md-6">
                        Conduct Interview
                    </div>
                </div>
                <div class="col-md-12 row">
                    <div class="col-md-6">
                        <label for="form-field-8"><b><h6>Interview Date :</h6></b></label>
                    </div>
                    <div class="col-md-6">
                        @ViewBag.ConductInterviewList.InterviewDate
                    </div>
                </div>
                <div class="col-md-12 row">
                    <div class="col-md-6">
                        <label for="form-field-8"><b><h6>Interview Time :</h6></b></label>
                    </div>
                    <div class="col-md-6">
                        @ViewBag.ConductInterviewList.InterviewTime
                    </div>
                </div>
                <div class="col-md-12 row">
                    <div class="col-md-6">
                        <label for="form-field-8"><b><h5>Join with Link:</h5></b></label>
                    </div>
                    <div class="col-md-6">
                        <a href="#" target="_blank">@ViewBag.ConductInterviewList.MeetingLink</a>
                    </div>
                </div>

                @if (ViewBag.ChecklistName.Count != 0)
                {
                    <table id="tableCheckList" class="table table-striped table-bordered align-middle tblAddData">
                        <thead class="text-center">
                            <tr>
                                <th hidden>Fid</th>
                                <th>Key Compentencies</th>
                                <th>Rate Out Of</th>
                                <th>Rate Obtained</th>
                                <th>Remark</th>
                            </tr>
                        </thead>
                        <tbody id="tbltableCheckListBody"></tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2"> <h3 class="text-center">Total</h3></td>
                                <td colspan="1"> <h3 class="text-center">Total</h3></td>
                                <td>
                                    <input type="text" class="form-control TotalCount" id="txtRateof" style="text-align:right" disabled="disabled" />
                                </td>
                                <td>
                                    <input type="text" class="form-control TotalCount" id="txtTotalCount" style="text-align:right" disabled="disabled" />
                                </td>
                            </tr>
                        </tfoot>

                    </table>

                }
                    <hr />

                <div class="form">
                        <div class="panel-body">
                            <div class="card-header">
                                <div class="row">
                                    <div class="row mb-15px">
                                        <div class="col-md-6">
                                            <div class="row">
                                                <label class="form-label col-form-label col-md-2">
                                                    Skills
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-10">
                                                    @Html.DropDownList("Name", new SelectList(ViewBag.GetSkillsList, "Name", "Name"), "--Select--", new { @class = "form-control select2", Id = "ddlSkillName", @required = "required" })
                                                    @Html.ValidationMessage("Name", "", new { @class = "help-block", id = "ErrorNameSkill", @style = "color:red" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row">
                                                <label class="form-label col-form-label col-md-2">
                                                    Remark
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-10">

                                                    @Html.DropDownList("Remark", new SelectList(ViewBag.GetRemarkList, "Name", "Name"), "--Select--", new { @class = "form-control select2", Id = "ddlRemark", @required = "required" })
                                                    @Html.ValidationMessage("Name", "", new { @class = "help-block", id = "ErrorRemark", @style = "color:red" })
                                                  </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label class="control-label"></label>
                                            <center><button type="button" class="btn btn-primary" id="btnAdd"> Add</button></center>
                                        </div>
                                    </div>
                                    <br />
                                    <!--/row-->
                                    <!--/span-->
                                </div>
                                <br />

                                <br />
                                <br />

                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered" id="AddedTable" style="width: 100%">
                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                <tr>
                                                    <th><center>Delete</center></th>
                                                    <th><center>Skills</center></th>
                                                    <th><center>Remark</center></th>

                                                </tr>
                                            </thead>
                                            <tbody id="tblskillName"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <hr />
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group row d-flex mb-3">
                            <label class="col-lg-3 col-form-label form-label" for="Remark">Result<span style="color:red">*</span></label>
                            <div class="col-lg-9">
                                @Html.DropDownListFor(model => model.InterviewStatus,
                            new List<SelectListItem>{new SelectListItem {Text ="Selected", Value="Selected"},
                                                   new SelectListItem {Text ="Hold", Value="Hold"},
                                                      new SelectListItem {Text ="Rejected", Value="Rejected"},
                                                  }, "--Select--", new { @class = "form-select", id = "ddlInterviewStatus", type = "text", name = "InterviewStatus", autocomplete = "Off" })
                                @Html.ValidationMessageFor(model => model.InterviewStatus, "", new { id = "ErrorInterviewStatus", @style = "color:red", @class = "help-block" })
                                @Html.HiddenFor(model => model.InterviewId, new { id = "txtInterviewId" })
                                @Html.HiddenFor(model => model.InterviewResumeId, new { id = "txtInterviewResumeId" })
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row" id="SelectCandidate">
                    <div class="col-md-12">
                        <div class="form-group row d-flex mb-3">
                            <label class="col-lg-3 col-form-label form-label" for="Remark">Remark</label>
                            <div class="col-lg-9">
                                @Html.TextBoxFor(model => model.Reason, new { @class = "form-control", id = "txtReason", type = "text", name = "Reason", autocomplete = "Off" })
                                @Html.ValidationMessage("Remark", "", new { @class = "help-block", id = "ErrorRemark", @style = "color:red" })
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-12">
                        <center>
                            <label class="mb-2">
                                <button type="button" class="btn btn-success" id="btnSubmit" >Submit</button>
                            </label>
                        </center>
                    </div>
                </div>
            </form>

        </div>
    </div>
    <!-- END panel -->
</div>


<!-- #Start Appprove Reject Modal -dialog -->
