<script>
    $(document).ready(function () {
        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        var ConductInterview = @Html.Raw(Json.Encode(ViewBag.ConductInterviewList));
        if(ConductInterview!=null)
        {
            var ResumeInterviewID= ConductInterview[3].Value;
            var InterviewID= ConductInterview[4].Value;
            $("#txtInterviewResumeId").val(ResumeInterviewID);
            $("#txtInterviewId").val(InterviewID);
        }

        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }

        var ChecklistName =@Html.Raw(Json.Encode(ViewBag.ChecklistName));
        debugger;
        if(ChecklistName!=null)
        {
            for(var i=0;i <= ChecklistName.length-1;i++)
            {
                var Count=0;
                var RateOf=$("#txtRateof").val();
                var RateCount=ChecklistName[i][2].Value
                Count=Number(RateOf)+Number(RateCount);
                $("#txtRateof").val(Count);
                var table = document.getElementById("tbltableCheckListBody");
                var rowCount = table.rows.length;
                var row = table.insertRow(rowCount);
                var count = $('#tbltableCheckListBody tr').length;

                row.insertCell(0).innerHTML = "" + ChecklistName[i][0].Value + "";
                row.insertCell(1).innerHTML = "" + ChecklistName[i][1].Value + "";
                row.insertCell(2).innerHTML = "" + ChecklistName[i][2].Value + "";
                row.insertCell(3).innerHTML = "<input type='text'  autocomplete = 'Off' id='txttableRate' onkeypress = 'return numbervalidate(event)' class='form-control Ratetxt'  onkeyup='AmountSum(this)'>" ;
                row.insertCell(4).innerHTML = "<input type='text'  autocomplete = 'Off' id='txttableRemark' class='form-control Remarktxt'>" ;
            }
        }
    });
</script>

<script>
    function isNumberKey(evt) {
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57))
            return false;
        return true;
    }

    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }

    $("#ddlSkillName").on("change", function () {
        debugger;
        $("#ddlRemark").find("option").remove();
        var Skill= $("#ddlSkillName").val();

        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: 'GetSkillsRemark',
            data: { Skill: Skill },
            success: function (data) {
                if (data !=null) {
                    $("#ddlRemark").append("<option value=0>--Select-- </option>");
                    $.each(data, function(i, p) {
                        $("#ddlRemark").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                    });
                }
                else {
                    $('#ErrorESSPassword').html(" ");
                }
            }
        })
    });
</script>

<script>
    $("#btnAdd").click(function () {
        debugger;
        var SkillName = $('#ddlSkillName').val();
        if(SkillName=="")
        {$('#ErrorNameSkill').html("Please select skill");  $("#ddlSkillName").focus(); return false;}
        else{ $('#ErrorNameSkill').html("");}
        var Remark = $('#ddlRemark option:selected').text();

        if(Remark!="--Select-- ")
        {
            $("#ErrorRemark").html("");
        }
        else{
            $("#ErrorRemark").html("Remark is required");return false;

        }
        var table = document.getElementById("tblskillName");
        var GetTableRecord = table.innerText;
        var CheckContaint = GetTableRecord.includes(SkillName);
        if (CheckContaint == true) {
            Swal.fire({
                title: "",
                text: "Remark already added against Assessment Result",
                icon: "warning",
                confirmButtonText: "OK"
            });
            return false;
        }
        else {
            debugger;

            var table = document.getElementById("tblskillName");
            var rowCount = table.rows.length;
            var row = table.insertRow(rowCount);
            var count = $('#tblskillName tr').length;
            row.insertCell(0).innerHTML = '<center><a type="button" id="btnDelete" class="btn btn-danger ListBtn btnpress" onclick="deleterow()"><i class="fa-solid fa-trash-alt"></i></a></center>';
            row.insertCell(1).innerHTML = ""+ SkillName + "";
            row.insertCell(2).innerHTML = ""+ Remark + "";


            $('#ddlSkillName').val('');
            $('#ddlRemark').val('');
        }
    })
</script>



<script>
    function AmountSum() {
        debugger;
        var tablett = document.getElementById("tbltableCheckListBody");
        var rowCount11 = tablett.rows.length;
        let total=0;
        for (var i = 0; i <= rowCount11; i++) {
            var LblValue = tablett.rows.item(i).cells;
            var AcheivedRate = LblValue[3].firstChild.value;
            var RateOutof= LblValue[2].innerText;
            if(Number(AcheivedRate)>Number(RateOutof))
            {
                Swal.fire({
                    title: "",
                    text: "Rate Obtained should not greater than rate out of",
                    icon: "warning",
                    confirmButtonText: "OK"

                });

                return false;
            }
            total = Number(AcheivedRate) + total;
            $("#txtTotalCount").val(total);
        }
    }


    function deleterow() {
        var table = document.getElementById("tblskillName");
        var rowCount = table.rows.length;

        table.deleteRow(rowCount -1);
    }
</script>

<script>
    $("#btnSubmit").click(function() {
        debugger
        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                debugger;
                var table = document.getElementById("tblskillName");
                var rowCount = table.rows.length;
                var TaskSkill = [];

                for (i = 0; i <= rowCount-1; i++) {
                    //var data = {};
                    var dataSkill = {};
                    dataSkill.Interview_Skill_Name = table.rows[i].cells[1].innerText;
                    dataSkill.Interview_Skill_Description = table.rows[i].cells[2].innerText;
                    TaskSkill.push(dataSkill);

                }

                debugger;
                var table = document.getElementById("tbltableCheckListBody");
                if(table!=null)
                {
                    var rowCount = table.rows.length;
                    var TaskChecklist = [];
                    var dataChecklist = {};
                    for (j = 0; j <= rowCount-1; j++) {
                        var dataChecklist = {};
                        dataChecklist.InterviewResultCheckListId = table.rows[j].cells[0].innerHTML;
                        dataChecklist.InterviewResultCheckListRate = table.rows[j].cells[2].innerHTML;
                        var LblValue = table.rows.item(j).cells;
                        dataChecklist.InterviwerRate= LblValue[3].firstChild.value;
                        dataChecklist.InterviewResultRemark= LblValue[4].firstChild.value;
                        TaskChecklist.push(dataChecklist);
                    }
                }
               

                var Result = $("#ddlInterviewStatus").val();
                var Reason = $("#txtReason").val();
                var InterviewResult= $("#txtTotalCount").val();
                var InterviewResumeId= $("#txtInterviewResumeId").val();
                var InterviewID=$("#txtInterviewId").val();
                if(Result!="")
                {
                    $("#ErrorInterviewStatus").html("");
                }
                else{
                    $("#ErrorInterviewStatus").html("Result is required");return false;
                    //$("#ErrorResult").hmtl("Result is required");return false;
                }

                if(TaskSkill.length==0)
                {
                    Swal.fire({
                        title: "",
                        text: "Please fill the interview checklist and skills",
                        icon: "warning",
                        confirmButtonText: "OK"

                    });

                    return false;
                }

                $(".Userloaderbg").css("display", "flex");

                $.ajax({
                    type: "POST",
                    url: "SaveUpdate",
                    data: JSON.stringify({Result:Result,Reason:Reason,InterviewResult:InterviewResult,InterviewResumeId:InterviewResumeId,InterviewID:InterviewID}),
                    contentType: "application/json; charset=utf-8",
                    dataType: "text",
                    success: function (response)
                    {
                        var data =  JSON.parse(response);
                        var Message1 = data.Message;
                        var Icon1 = data.Icon;
                        if (data !=null) {
                            if (Message1 != null) {

                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        // return false
                                    }

                                }).then(function () {
                                    var url = '@Url.Action("ESS_Recruitment_Interview", "ESS_Recruitment_Interview")';
                                    window.location.href = url;
                                });

                            }
                        }
                    }
                });

            } else if (
                /* Read more about handling dismissals below */
                    result.dismiss === Swal.DismissReason.cancel
              ) {

            }
        })
    })
</script>