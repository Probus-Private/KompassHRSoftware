@model KompassHR.Areas.ESS.Models.ESS_Recruitment.Recruitment_Interview
@{
    ViewBag.Title = "ViewForCoductInterview";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var @Item = ViewBag.CandiadateScheduleList;
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 15px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 25px;
    }

    .table, tr, td, th, .invoice, .smallFrom {
        border: none;
        font-size: 13px;
        font-family: Arial;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Candidate Details
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="alert alert-warning alert-dismissible rounded-0 mb-0 fade show">
        Candidates assessment results and interview comments are captured on this form.
    </div>
    <!-- END page-header -->
    <!-- BEGIN invoice -->
    <div class="invoice">
        <!-- BEGIN invoice-company -->
        <div class="invoice-company">
            @Html.HiddenFor(model => model.InterviewId_Encrypted, new { id = "txtInterviewId_Encrypted" })
            @Html.HiddenFor(model => model.InterviewId, new { id = "txtInterviewId" })
            <span class="float-end hidden-print">
                <button type="button" class="btn  btn-primary btn-sm" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>
                @if (Item.InterviewAccept == false)
                {
                    @*<a href="#" type="button" class="btn btn-success" id="btnAcceptInterview">Accept</a>*@
                    <button type="button" class="btn btn-success btn-sm" id="btnAcceptInterview" onclick="OpenModal('Approved')">Accept</button>
                    <button type="button" class="btn btn-danger btn-sm" id="btnRejectInterview" onclick="OpenModal('Rejected')">Reject</button>
                }
                else
                {
                    <button type="button" class="btn btn-success btn-sm" id="btnConductInterview">Conduct Interview</button>
                }
            </span>
            Recruitment for @Item.DesignationName
        </div>
        <!-- END invoice-company -->
        <form class="form">
            <div class="card">
                <div id="card">
                    <div class="invoice-header">
                        <div class="invoice-from">
                            <address class="mt-5px mb-5px">
                                <i class="fa-solid fa-user"> </i>     <strong class="text-dark">&nbsp;@Item.CandidateName</strong><br />
                                <i class="fa-solid fa-phone-volume"> </i>&nbsp;    <b>Phone:</b>&nbsp; +@Item.MobileNo <br />
                                <i class="fa-solid fa-envelope"> </i>&nbsp;&nbsp;<b>Email:</b>&nbsp;  @Item.EmailId
                            </address>
                        </div>
                        <div class="invoice-to">
                            <small>   </small>
                            <br />
                            <address class="mt-5px mb-5px">
                                <i class="fa-solid fa-building"> </i>&nbsp;&nbsp; &nbsp; <b> Current Organization:</b>&nbsp; @Item.LastCompanyName<br />
                                <i class="fa-regular fa-handshake"> </i>&nbsp;&nbsp;  <b>  Current Designation: </b>&nbsp; @Item.LastDesignation<br />
                                <i class="fa-solid fa-info"></i> &nbsp;&nbsp; &nbsp; <b>Experience:</b> &nbsp;@Item.TotalExperience<br />
                            </address>
                        </div>

                        <div class="invoice-date">
                            <small> </small>
                            <br />
                            <div class="date text-dark mt-5px"></div>
                            <div class="invoice-detail">
                                <i class="fa-solid fa-calendar-days"></i> <b> Notice Period (Days): </b>@Item.NoticePeriodDays<br />
                            </div>
                        </div>
                    </div>
                    <!-- END invoice-header -->
                    <!-- BEGIN invoice-content -->
                    <div class="invoice-content">
                        <!-- BEGIN table-responsive -->
                        <div class="row">
                            <div class="col-md-6">
                                <table class="table ">
                                    <tbody>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Interview Date</span><br />
                                            </th>
                                            <td>@Item.InterviewDate</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Current CTC</span><br />
                                            </th>
                                            <td>@Item.CTC</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Gender</span><br />
                                            </th>
                                            <td>@Item.Gender</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Current City</span><br />
                                            </th>
                                            <td>@Item.CurrentCity</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Nationality</span><br />
                                            </th>
                                            <td>@Item.Nationality</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Highest Qualification</span><br />
                                            </th>
                                            <td>@Item.HighestQualification</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Technical Skill</span><br />
                                            </th>
                                            <td>@Item.TechnicalDetails </td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">HR Notes</span><br />
                                            </th>
                                            <td>@Item.HRComment </td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(Item.ResumePath))
                                        {
                                            <tr>
                                                <td><strong>Resume File</strong></td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(Item.ResumePath))
                                                    {
                                                        <a href="@Url.Action("DownloadFile", "ESS_Recruitment_CandidateList", new { filePath = Item.ResumeFullPath })" class="btn btn-link p-0 m-0">
                                                            <i class="fa fa-download"></i> Download
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="col-md-6">
                                <table class="table ">
                                    <tbody>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Interview Time</span><br />
                                            </th>
                                            <td>@Item.InterviewTime</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Expected CTC</span><br />
                                            </th>
                                            <td>@Item.ExpectedCTC</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Marital Status </span><br />
                                            </th>
                                            <td>@Item.MaritalStatus</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Ready to Travel</span><br />
                                            </th>
                                            <td>@Item.ReadyToTraval</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Age</span><br />
                                            </th>
                                            <td>@Item.Age</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark"> Specific Qualification</span><br />
                                            </th>
                                            <td>@Item.QualificationRemark</td>
                                        </tr>

                                        <tr>
                                            <th>
                                                <span class="text-dark">Communication Skill</span><br />
                                            </th>
                                            <td>@Item.CommunicationSkill</td>
                                        </tr>
                                        <tr>
                                            <th>
                                                <span class="text-dark">Candidate Comment</span><br />
                                            </th>
                                            <td>@Item.CandidateComment</td>
                                        </tr>


                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <hr />
                        @if (ViewBag.ApprovalRemarkList.Count != 0)
                        {
                            <div class="col-md-12">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine"
                                       style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th class="text-nowrap">Approved By</th>
                                            <th class="text-nowrap">Remark</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.ApprovalRemarkList)
                                        {
                                            <tr>

                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <!-- END invoice-content -->
                </div>
            </div>
        </form>
    </div>
</div>
<!-- END #content -->
