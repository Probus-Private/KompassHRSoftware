<script>
    $(document).ready(function () {
        var List = @Html.Raw(Json.Encode(ViewBag.CandiadateScheduleList));
        debugger;
        var Encrypted=List[1].Value;
        var id=List[0].Value;
        $("#InterviewId_Encrypted").val(Encrypted);
        $("#InterviewId").val(id);


    });//ready
</script>
<script>
    function printDiv() {

        //Get the HTML of div
        var divElements = document.getElementById('card').innerHTML;
        //Get the HTML of whole page
        var oldPage = document.body.innerHTML;

        //Reset the page's HTML with div's HTML only
        document.body.innerHTML =
          "<html><head></head><body>    " +
        divElements + "    </body>";

        //Print Page
        window.print();

        //Restore orignal HTML
        document.body.innerHTML = oldPage;
    }

