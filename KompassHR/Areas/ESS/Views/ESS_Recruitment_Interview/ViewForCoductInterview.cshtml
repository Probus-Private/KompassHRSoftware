<script>

    var StatusMark="";
    function OpenModal(Approver){
        debugger;
        StatusMark=Approver;
        $("#myModalFinal").modal('show');
    }

    function Approved()
    {
        debugger
        const Approved = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        Approved.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                var Status="";
                var Remark="";
                if(StatusMark=="Rejected")
                {
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="Rejected";

                }
                else{
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="Approved";
                }
                $("#myModalFinal").modal('hide');
                $(".Userloaderbg").css("display", "flex");

                $.ajax({
                    url: "@Url.Action("InterviewAcceptReject", "ESS_Recruitment_Interview")",
                    method:"get",
                    data:{Status:Status,Remark:Remark},
                    success:function(response){
                        debugger;
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon=="error") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    });

                                    $("#myModalFinal").modal('hide');
                                    $("#txtApproveRejectRemark").val("")
                                    .then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("ESS_Recruitment_Interview", "ESS_Recruitment_Interview")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })
                                }
                            }

                        }

                        else{
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            if (response.Icon=="success") {
                                if (Message1 != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        })
                                        .then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("ESS_Recruitment_Interview", "ESS_Recruitment_Interview")';
                                            } else if (
                                                /* Read more about handling dismissals below */
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {

                                            }
                                        })

                                        $("#myModalFinal").modal('hide');
                                        $("#txtApproveRejectRemark").val("");
                                    }
                                }
                            }
                        }
                    }
                });

            }
        })
    }

    $("#btnConductInterview").click(function () {
        debugger;
        $.ajax({
            type: "get",
            url: "@Url.Action("GetChecklist", "ESS_Recruitment_Interview", new { area = "ESS" })",
            data: {},
            contentType: "application/json; charset=utf-8",
            dataType: "text",
      success: function (response) {
    debugger;
    if (response == "false") {
        Swal.fire({
            icon: 'warning',
            title: 'Checklist Not Found',
            text: 'A checklist has not been defined for this interview. Do you want to continue without it?',
            showCancelButton: true,
            confirmButtonText: 'Yes, Continue',
            cancelButtonText: 'No, Cancel',
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                var InterviewId_Encrypted = $("#txtInterviewId_Encrypted").val();
                var url = '@Url.Action("ConductInterview", "ESS_Recruitment_Interview")?InterviewId_Encrypted=' + InterviewId_Encrypted;
                window.location.href = url;
            }
        });
    }
    else {
        var InterviewId_Encrypted = $("#txtInterviewId_Encrypted").val();
        var url = '@Url.Action("ConductInterview", "ESS_Recruitment_Interview")?InterviewId_Encrypted=' + InterviewId_Encrypted;
        window.location.href = url;
    }
}


        })
    });
</script>
