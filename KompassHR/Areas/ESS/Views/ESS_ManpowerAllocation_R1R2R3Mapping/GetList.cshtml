<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                R1/R2/R3 Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ManpowerAllocation_R1R2R3Mapping", "ESS_ManpowerAllocation_R1R2R3Mapping",  new {id = 42,ScreenId=772, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">R1/R2/R3 Mapping - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of R1/R2/R3 Mapping created.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row align-items-center mb-3">
                               
                                
                                <div class="row">
                                    <div class="col-md-3">
                                        <a href="@Url.Action("ESS_ManpowerAllocation_R1R2R3Mapping", "ESS_ManpowerAllocation_R1R2R3Mapping", new { area = "ESS" })">
                                            <button type="button" class="btn btn-primary btn-sm mb-10px">
                                                <i class="fa-solid fa-plus"></i> &nbsp; Add
                                            </button>
                                        </a>
                                    </div>
                                    <div class="col-md-6 ">
                                        <div class="row align-items-center mb-3">
                                            <label class="form-label col-form-label col-md-2">
                                                Month/Year
                                            </label>
                                            <div class="col-md-8  d-flex align-items-center">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control me-2", name = "MonthYear", type = "month", id = "GetMonthYear" })
                                                <button type="button" class="btn btn-primary btn-sm" id="btnShow">
                                                    Show
                                                </button>
                                             </div>
                                        </div>
                                    </div>
                                    @*<div class="col-md-3">
                                        <button type="button" class="btn btn-primary btn-sm" id="btnShow">
                                            Show
                                        </button>
                                    </div>*@
                                    </div>

                                    <!-- BEGIN table-responsive -->
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                                   style="width: 100%;">
                                                <thead>
                                                    <tr>
                                                        <th class="fixed-side">Update</th>
                                                        <th class="fixed-side1">Delete</th>
                                                        <th class="fixed-side1">Copy</th>
                                                        <th class="text-nowrap">MonthYear</th>
                                                        <th class="text-nowrap">Company Name</th>
                                                        <th class="text-nowrap">Buisness Unit</th>
                                                        <th class="text-nowrap">R1 From Date</th>
                                                        <th class="text-nowrap">R1 To Date</th>
                                                        <th class="text-nowrap">R2 From Date</th>
                                                        <th class="text-nowrap">R2 To Date</th>
                                                        <th class="text-nowrap">R3 From Date</th>
                                                        <th class="text-nowrap">R3 To Date</th>
                                                        <th class="text-nowrap">CreatedBy </th>
                                                        <th class="text-nowrap">Created Date</th>
                                                        <th class="text-nowrap">ModifiedBy</th>
                                                        <th class="text-nowrap">Modified Date </th>
                                                        <th class="text-nowrap">Machine Name</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var d in ViewBag.GetMappingList)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <a onclick="UpdateMapping('@d.R1R2R3MappingId_Encrypted')" id="btnUpdate" style="cursor:pointer;">
                                                                    <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                                </a>
                                                            </td>


                                                            <td class="text-center">
                                                                <a onclick="DeleteMapping('@d.R1R2R3MappingId')" id="btnDelete" style="cursor:pointer;">
                                                                    <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                </a>
                                                            </td>

                                                            <td class="text-center">
                                                                <a onclick="CopyMapping('@d.R1R2R3MappingId','@d.MonthYear')" id="btnCopy" style="cursor:pointer;">
                                                                    <i class="bi bi-copy fs-5"></i>
                                                                </a>
                                                            </td>


                                                            <td>@d.MonthYear.ToString("MMM/yyyy")</td>
                                                            @*<td>@d.MonthYear.ToString("MMM'/'yyyy")</td>*@
                                                            <td>@d.ShortName</td>
                                                            <td>@d.BranchName</td>
                                                            <td>@d.R1FromDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                            <td>@d.R1ToDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                            <td>@d.R2FromDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                            <td>@d.R2ToDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                            <td>@d.R3FromDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                            <td>@d.R3ToDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                            <td>@d.CreatedBy</td>
                                                            <td>@d.CreatedDate</td>
                                                            <td>@d.ModifiedBy</td>
                                                            <td>@d.ModifiedDate</td>
                                                            <td>@d.MachineName</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

 <script>
        $(document).ready(function () {
            debugger
        $("#btnShow").on("click", function () {
            debugger;
            let monthYear = $("#GetMonthYear").val();  
            if (!monthYear) {
                Swal.fire({
                    icon: "warning",
                    title: "Please select a MonthYear"
                });
                return;
            }
            window.location.href = '@Url.Action("GetList", "ESS_ManpowerAllocation_R1R2R3Mapping", new { area = "ESS" })' + "?MonthYear=" + monthYear;
        });
    });
    </script>

<script>
    $(document).ready(function () {
        debugger
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>

<script>
    function CopyMapping(R1R2R3MappingId,MonthYear) {
        debugger
        Swal.fire({
            //title: "Select From",
            title: '<div style="background:black; color:white; padding:5px;Font-Size:15px; border-radius:4px;">Copy Model</div>',
            html: `<div style="text-align:left ">
                <label style="display:block; margin-bottom:10px;Font-Size:15px; ">Company:</label>
                <select id="ddlCmpId" class="form-select">
                    <option value="">-- Select Company --</option>
                    @foreach (var cmp in ViewBag.CompanyName)
                    {
                        <option value="@cmp.Id">@cmp.Name</option>
                    }
                </select>
                <br>
                <label  style="display:block; margin-bottom:10px;Font-Size:15px;">Buisness Unit:</label>
                
                <select id="ddlBranchId" class="form-select">
                    <option value="">-- Select Branch --</option>
                    @foreach (var br in ViewBag.BUName)
                    {
                        <option value="@br.Id">@br.Name</option>
                    }
                </select>
            </div> 
            `,
            focusConfirm: false,
            confirmButtonText: "Copy",
            cancelButtonText: "Cancel",
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            showCancelButton: true,
            customClass: {
                confirmButton: 'btn-sm px-2',
                cancelButton: 'btn-sm px-2'
            },
            didOpen: () => {
            
                $("#ddlCmpId").on("change", function () {
                    debugger
                    let CmpId = $(this).val();
                    if (CmpId) {
                        $.get('@Url.Action("GetBuisnessUnit", "ESS_ManpowerAllocation_R1R2R3Mapping")', { CmpId: CmpId }, function (data) {
                            let branchDropdown = $("#ddlBranchId");
                            branchDropdown.empty();
                            branchDropdown.append('<option value="">-- Select Branch --</option>');
                            $.each(data, function (i, br) {
                                branchDropdown.append('<option value="' + br.Id + '">' + br.Name + '</option>');
                            });
                        });
                    } else {
                        $("#ddlBranchId").html('<option value="">-- Select Branch --</option>');
                    }
                });
            },
            preConfirm: () => {
                let company = document.getElementById("ddlCmpId").value;
                let branch = document.getElementById("ddlBranchId").value;

                if (!company) 
                {
                    $("#ddlCmpId").after('<div class="text-danger small mt-1" id="cmpError">Please select a Company</div>');
                    return false;
                } else 
                {
                    $("#cmpError").remove();
                }
               
                if (!branch) 
                {
                    $("#ddlBranchId").after('<div class="text-danger small mt-1" id="cmpError">Please select a Buisness Unit</div>');
                    return false;
                } else 
                {
                    $("#BranchError").remove();
                }
                return { company, branch };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                let company = result.value.company;
                let branch = result.value.branch;
           
                $.post('@Url.Action("CopyMapping", "ESS_ManpowerAllocation_R1R2R3Mapping")',
                       { R1R2R3MappingId: R1R2R3MappingId, CmpId: company, BranchId: branch,MonthYear:MonthYear },
                       //function (response) {
                       //    window.location.reload();
                       //});

                       function (response) {
                           if (response && response.Message) {
                               Swal.fire({
                                   icon: response.Icon,
                                   title: response.Message
                               }).then(() => {
                                   if (response.Icon === "success") {
                                       window.location.reload();
                                   }
                               });
                           } else {
                          
                               window.location.reload();
                           }
                       
                       });
            }
        });
    }
            function UpdateMapping(R1R2R3MappingId_Encrypted) {
                debugger
                var url = '@Url.Action("ESS_ManpowerAllocation_R1R2R3Mapping", "ESS_ManpowerAllocation_R1R2R3Mapping")?R1R2R3MappingId_Encrypted=' + R1R2R3MappingId_Encrypted;
                window.location.href = url;
            }

            function DeleteMapping(R1R2R3MappingId) {debugger;
                const DeleteButtons = Swal.mixin({
                    customClass: {
                        cancelButton: ' btnpress',
                        confirmButton: ' btnpress'
                    },
                    buttonsStyling: true
                })
                DeleteButtons.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'No, cancel!',
                    reverseButtons: false,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }

                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("DeleteMapping", "ESS_ManpowerAllocation_R1R2R3Mapping")?R1R2R3MappingId=' + R1R2R3MappingId;

                    } else if (
                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                    }
                })
            }
        
</script>
