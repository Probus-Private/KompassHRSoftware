</script>


<script>
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveR1R2R3Mapping').validate({
        rules: {
            CmpId: {
                required: true,
            },
            MonthYear:{
                required: true,
            },

            BranchId: {
                required: true,
            },
            R1FromDate: {
                required: true,
            },
            R1ToDate: {
                required: true,
            },
            R2FromDate: {
                required: true,
            },
            R2ToDate: {
                required: true,
            },
            R3FromDate: {
                required: true,
            },
            R3ToDate: {
                required: true,
            },

        },
        messages: {
              CmpId: {
                  required: "Company Name is required",
              },
              MonthYear:{
                  required: "Month Year is required",
              },
              BranchId: {
                  required: "Business Unit name is required",
              },
              R1FromDate:{
                  required: "This date is required",
              },
              R1ToDate:{
                  required: "This date is required",
              },
              R2FromDate:{
                  required: "This date is required",
              },
              R2ToDate:{
                  required: "This date is required",
              },
              R3FromDate:{
                  required: "This date is required",
              },
              R3ToDate:{
                  required: "This date is required",
              }
        },
    });

    var form = $("#SaveR1R2R3Mapping");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtR1FromDate").removeClass('error');
            return false;
        }
        //var CmpId = $("#txtCmpId").val();
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();

        var R1R2R3MappingId_Encrypted = $("#txtR1R2R3MappingId_Encrypted").val();
        var R1R2R3MappingId=$("#txtR1R2R3MappingId").val();


        $.ajax({
            url:"IsR1R2R3MappingExists",
            method:"get",
            data: {
                CmpId: CmpId,BranchId:BranchId,
                R1R2R3MappingId_Encrypted:R1R2R3MappingId_Encrypted,
                R1R2R3MappingId:R1R2R3MappingId
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveR1R2R3Mapping").submit();
                }
            }
        });
    });
</script>


<script>
    function OnCompanyChange() {
        debugger
        var CmpId = document.getElementById("ddlCmpId").value;

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetBuisnessUnit", "ESS_ManpowerAllocation_R1R2R3Mapping")',
            data: { CmpId: CmpId},
            success: function (data) {
                var $BusinessUnitDropdown = $("#ddlBranchId");
                $BusinessUnitDropdown.empty();

                if (data && data.length > 0) {
                    $BusinessUnitDropdown.append("<option value=''>--Select--</option>");
                    $.each(data, function (i, module) {
                        $BusinessUnitDropdown.append(
                            $("<option>").val(module.Id).text(module.Name)
                        );
                    });
                } else {
                    $BusinessUnitDropdown.append("<option>--Select--</option>");
                }
            },
            error: function () {
                console.error("Failed to fetch modules.");
                $("#ddlBranchId").empty().append("<option>Error loading modules</option>");
            }
        });
    }
</script>