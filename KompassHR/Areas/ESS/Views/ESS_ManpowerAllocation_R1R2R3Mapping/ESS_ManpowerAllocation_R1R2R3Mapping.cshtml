<script>
    $(document).ready(function () {
        debugger
       var MonthYear = @Html.Raw(Json.Encode(TempData["MonthYear"]));
        $("#txtMonthYear").val(MonthYear);
        var R1FromDate = @Html.Raw(Json.Encode(TempData["R1FromDate"]));
        $("#txtR1FromDate").val(R1FromDate);
        var R1ToDate = @Html.Raw(Json.Encode(TempData["R1ToDate"]));
        $("#txtR1ToDate").val(R1ToDate);
        var R2FromDate = @Html.Raw(Json.Encode(TempData["R2FromDate"]));
        $("#txtR2FromDate").val(R2FromDate);
        var R2ToDate = @Html.Raw(Json.Encode(TempData["R2ToDate"]));
        $("#txtR2ToDate").val(R2ToDate);
        var R3FromDate = @Html.Raw(Json.Encode(TempData["R3FromDate"]));
        $("#txtR3FromDate").val(R3FromDate);
        var R3ToDate = @Html.Raw(Json.Encode(TempData["R3ToDate"]));
        $("#txtR3ToDate").val(R3ToDate);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#formReset").click(function () {
            $("#SaveR1R2R3Mapping")[0].reset();
        });

    });
</script>


<script>
    $(document).ready(function () {

        $("#txtMonthYear").change(function () {
            debugger;
            var monthYear = $(this).val();
            if (monthYear) {
                var parts = monthYear.split("-");
                var year = parseInt(parts[0]);
                var month = parseInt(parts[1]);

                // first day of month
                var firstDay = year + "-" + (month < 10 ? "0" + month : month) + "-01";

                // last day of month
                var lastDayDate = new Date(year, month, 0);
                var lastDay = year + "-" + (month < 10 ? "0" + month : month) + "-" + (lastDayDate.getDate());


                $("#txtR1FromDate, #txtR1ToDate, #txtR2FromDate, #txtR2ToDate, #txtR3FromDate, #txtR3ToDate")
                    .attr("min", firstDay)
                    .attr("max", lastDay)
                    .val("");
                $("#txtR1FromDate").val(firstDay).prop("readonly", true);;
                $("#txtR3ToDate").val(lastDay).prop("readonly", true);;
            }
        });

        $("#txtR1FromDate, #txtR1ToDate, #txtR2FromDate, #txtR2ToDate, #txtR3FromDate, #txtR3ToDate").change(function () {
            var r1From = $("#txtR1FromDate").val();
            var r1To = $("#txtR1ToDate").val();
            var r2From = $("#txtR2FromDate").val();
            var r2To = $("#txtR2ToDate").val();
            var r3From = $("#txtR3FromDate").val();
            var r3To = $("#txtR3ToDate").val();

            $("#ErrorR1ToDate, #ErrorR2FromDate, #ErrorR2ToDate, #ErrorR3FromDate, #ErrorR3ToDate").text("");

            // Convert to Date objects for comparison
            function parseDate(dateStr) {
                return dateStr ? new Date(dateStr) : null;
            }
            function diffDays(start, end) {
                return Math.floor((end - start) / (1000 * 60 * 60 * 24));
            }
            var dR1From = parseDate(r1From);
            var dR1To = parseDate(r1To);
            var dR2From = parseDate(r2From);
            var dR2To = parseDate(r2To);
            var dR3From = parseDate(r3From);
            var dR3To = parseDate(r3To);

            // Validate R1
            if (dR1From && dR1To && dR1To < dR1From) {
                $("#ErrorR1ToDate").text("R1 To Date must be greater than or equal to R1 From Date");
                $("#txtR1ToDate").val("");
            }

            // Validate gap between R1 and R2
            if (dR1To && dR2From) {
                var expectedR2From = new Date(dR1To);
                expectedR2From.setDate(expectedR2From.getDate() + 1);
                if (dR2From.getTime() !== expectedR2From.getTime()) {
                    $("#ErrorR2FromDate").text("R2 From Date must be the day after R1 To Date");
                    $("#txtR2FromDate").val("");
                }
            }

            // Validate R2 To
            if (dR2From && dR2To) {
                if (dR2To < dR2From) {
                    $("#ErrorR2ToDate").text("R2 To Date must be greater than or equal to R2 From Date");
                    $("#txtR2ToDate").val("");
                }
                else {
                    var totalDays = diffDays(dR2From, dR2To);
                    if (totalDays < 0) {
                        $("#ErrorR2ToDate").text("R2 To Date must cover consecutive days without gaps");
                        $("#txtR2ToDate").val("");
                    }
                }
            }

            // Validate R3 From
            if (dR2To && dR3From) {
                var expectedR3From = new Date(dR2To);
                expectedR3From.setDate(expectedR3From.getDate() + 1);
                if (dR3From.getTime() !== expectedR3From.getTime()) {
                    $("#ErrorR3FromDate").text("R3 From Date must be the day after R2 To Date");
                    $("#txtR3FromDate").val("");
                }
            }

            // Validate R3
            if (dR3From && dR3To && dR3To < dR3From) {
                $("#ErrorR3ToDate").text("R3 To Date must be greater than or equal to R3 From Date");
                $("#txtR3ToDate").val("");
            }
        });

        //    if (r1From && r1To && r1To < r1From) {
        //        $("#ErrorR1ToDate").text("R1 To Date must be greater than or equal to R1 From Date");
        //        $("#txtR1ToDate").val("");
        //    }
        //    else{
        //        $("#ErrorR1ToDate").text("");
        //    }

        //    if (r1To && r2From && r2From < r1To) {
        //        $("#ErrorR2FromDate").text("R2 From Date must be greater than or equal to R1 To Date");
        //        $("#txtR2FromDate").val("");
        //    }
        //    else{
        //        $("#ErrorR2FromDate").text("");
        //    }
        //            if (r2From && r2To && r2To < r2From) {
        //                $("#ErrorR2ToDate").text("R2 To Date must be greater than or equal to R2 From Date");
        //                $("#txtR2ToDate").val("");
        //            }
        //        else{
        //            $("#ErrorR2ToDate").text("");
        //        }
        //    if (r2To && r3From && r3From < r2To) {
        //        $("#ErrorR3FromDate").text("R3 From Date must be greater than or equal to R2 To Date");
        //        $("#txtR3FromDate").val("");
        //    }
        //    else{
        //        $("#ErrorR3FromDate").text("");
        //    }
        //    if (r3From && r3To && r3To < r3From) {
        //        $("#ErrorR3ToDate").text("R3 To Date must be greater than or equal to R3 From Date");
        //        $("#txtR3ToDate").val("");
        //    }
        //    else{
        //        $("#ErrorR3ToDate").text("");
        //    }
        //});
