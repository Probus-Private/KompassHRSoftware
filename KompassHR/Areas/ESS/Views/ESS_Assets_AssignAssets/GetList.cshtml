
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Assign Assets List
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Assets_AssignAssets", "ESS_Assets_AssignAssets",  new {id = 47,ScreenId=838, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Asset - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of assets.

                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_Assets_AssignAssets", "ESS_Assets_AssignAssets", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                           style="width: 100%;">
                                        <thead>
                                            <tr>
                                                @*<th style="display:none;"></th>*@
                                                <th class="fixed-side">Update</th>
                                                <th class="fixed-side1">Delete</th>
                                                <th class="text-nowrap"> Date</th>
                                                @*<th class="text-nowrap"> Company Name</th>
                                                <th class="text-nowrap"> Branch Name</th>*@
                                                <th class="text-nowrap"> Employee Name</th>
                                                <th class="text-nowrap"> Asset Name </th>
                                                <th class="text-nowrap"> Asset Remark </th>
                                                <th class="text-nowrap"> Required Alert </th>
                                                <th class="text-nowrap"> Required Alert Date</th>
                                                <th class="text-nowrap"> Alert Remark</th>
                                                <th class="text-nowrap">CreatedBy </th>
                                                <th class="text-nowrap">Created Date</th>
                                                <th class="text-nowrap">ModifiedBy</th>
                                                <th class="text-nowrap">Modified Date </th>
                                                <th class="text-nowrap">Machine Name</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                           @foreach (var d in ViewBag.GetAssetList)
                                           {
                                           <tr>

                                           @*<td style="display:none;"></td>*@
                                            <td class="text-center">
                                       
                                              <a onclick="UpdateAsset('@d.AssetId_Encrypted')" id="btnUpdate" style="cursor:pointer;">
                                              <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                               </a>
 
                                                 </td>

                                                 <td class="text-center">
                                                   <a onclick="DeleteAsset('@d.AssetId_Encrypted')" id="btnDelete" style="cursor:pointer;">
                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                  </a>
                                                 </td>
                                                                                           
                                               <td>@($"{d.Date.ToString("dd")}/{d.Date.ToString("MMM")}/{d.Date.Year}")</td>

                                                                                                 @*<td>@d.Date</td>*@
                                                                                                @*<td>@d.CompanyName</td>*@
                                                                                                @*<td>@d.BranchName</td>*@
                                                                                                <td>@d.EmployeeName</td>
                                                                                                <td>@d.AssetName1</td>
                                                                                                <td>@d.Remark</td>
                                                                                                @if (d.RequiredAlert == true)
                                                                                                {
                                                                                                    <td>Yes</td>

                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <td>No</td>
                                                                                                }

                                                                                                <td>@d.RequiredAlertDate</td>
                                                                                                <td>@d.AssetRemark</td>
                                                                                         
                                                    <td>@d.CreatedBy</td>
                                                    <td>@($"{d.CreatedDate.ToString("dd")}/{d.CreatedDate.ToString("MMM")}/{d.CreatedDate.Year}")</td>
                                                    <td>@d.ModifiedBy</td>
                                                    <td>@d.ModifiedDate</td>
                                                    <td>@d.MachineName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>



<!-- #Start modal-dialog -->
<div class="modal fade" id="modal_basic3" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Description</h4>
                <div class="panel-heading-btn">

                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div id="txtTaskStatus"></div>
                                            @* @Html.TextArea("TaskStatus", new { @class = "summernote", style = "border: 2px solid #000; padding: 10px;", id = "txtTaskStatus", @placeholder = "Description....", autocomplete = "Off", contenteditable = "false" })*@
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" id="btnCancel" class="btn btn-success btnpress" onclick="dismissModal('modal_basic3')">
                    @*<i class="fa-solid fa-floppy-disk"> </i> Ok*@
                    OK
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->
<script>
    function AssignTaskDesc(encodedHtml)
    {
        $('#txtTaskStatus').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtTaskStatus').html(AssignDesc);
        });
    }

    function dismissModal(modalId) {
        $('#' + modalId).modal('hide');
    }
</script>

<script>
    $(document).ready(function () {
        debugger
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
</script>


<script>
    function UpdateAsset(AssetId_Encrypted) {
        debugger
        var url = '@Url.Action("ESS_Assets_AssignAssets", "ESS_Assets_AssignAssets")?AssetId_Encrypted=' + AssetId_Encrypted;
        window.location.href = url;
    }

    function DeleteAsset(AssetId_Encrypted) {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Assets_AssignAssets")?AssetId_Encrypted=' + AssetId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>

