<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function (value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   }, "erreur expression reguliere"
);

    $('#AssetSaveUpdate').validate({

        rules: {
            //CompanyId:{
            //    required: true,
            //},
            //BranchId:{
            //    required: true,
            //},
            Date: {
                required: true,
            },
            AssetName: {
                required: true,
            },
            Remark: {
                required: true,
            },

        },
        messages: {
            //CompanyId:{
            //    required: "Company name is required",
            //},
            //BranchId:{
            //    required: "Branch Name is required",
            //},
            Date: {
                required: "Date Is Required",
            },
            AssetName: {
                required: "Asset Name Is Required",
            },
            Remark: {
                required: "Asset Remark Is Required",
            },

        },
    });

    var form = $("#AssetSaveUpdate");
    form.validate();
    $("#btnSubmit").click(function () {
        if (form.valid() == false) {
            return false;
        }
        var AssetId_Encrypted = $("#AssetId_Encrypted").val();
        var AssetEmployeeId=$('#ddlAssetEmployeeId').val();
        var AssetName = $('#ddlAssetId').val();
       // var CompanyId=$('#ddlCompanyId').val();
        //var BranchId=$('#ddlBranchId').val();
        $.ajax({
            url: '@Url.Action("IsAssetExists", "ESS_Assets_AssignAssets")',
            method: "get",
            data: { AssetEmployeeId: AssetEmployeeId, AssetName: AssetName,AssetId_Encrypted:AssetId_Encrypted},
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else {
                    $("#AssetSaveUpdate").submit();

                }
            }
        });

    });
</script>


<script>
    function DeleteAsset(AssetId_Encrypted) {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Assets_AssignAssets")?AssetId_Encrypted=' + AssetId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>


