    $(document).ready(function () {
        debugger;

        var Date = @Html.Raw(Json.Encode(TempData["Date"]));
        $("#Date").val(Date);
        var RequiredAlertDate = @Html.Raw(Json.Encode(TempData["RequiredAlertDate"]));
        $("#txtOnDate").val(RequiredAlertDate);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: false
                }).then(function () {
                    window.location.reload();
                });
            }
        }


        $("#txtOnDate").val(new Date().toISOString().split("T")[0]);
        $("#chkRequiredAlert").on("change", function () {
            debugger
            var isChecked = $(this).is(":checked");

            if (isChecked) {
                $("#txtOnDate").prop("disabled", false).css("background-color", "#fff");
            } else {
                $("#txtOnDate").prop("disabled", true).css("background-color", "#eee");
            }
        });

        // Ensure the date input is disabled by default if the checkbox is unchecked
        if (!$("#chkRequiredAlert").is(":checked")) {
            $("#txtOnDate").prop("disabled", true).css("background-color", "#eee");
            $("#txtOnDate").val(new Date().toISOString().split("T")[0]);
        }

        $("#ddlAssetId").on("change", function () {
            debugger;
      
        var AssetId = $("#ddlAssetId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetAlertRemark", "ESS_Assets_AssignAssets")',
                data: { AssetId: AssetId },
                success: function (data) {
                    debugger;
                    if (data.success) {
                        $("#txtAlertRemark").val(data.remark); // Set the remark in the textarea
                    } else {
                        alert(data.message); // Show error message if any
                    }
                }
            })
        });

        $("#ddlCompanyId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            // $("#ddlEmployeeID").find("option").remove();
            var CompanyId = $("#ddlCompanyId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetBusinessUnit", "ESS_Assets_AssignAssets")',
                data: { CompanyId: CompanyId},
                success: function (data) {
                    if (data != null) {
                        $("#ddlBranchId").append("<option value=''>All </option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    if (data != null) {
                        $("#ddlAssetEmployeeId").append("<option value=''>All </option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $("#ddlAssetEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlAssetEmployeeId").find("option").remove();
            var BranchId = $("#ddlBranchId").val()||null;
            var CompanyId = $("#ddlCompanyId").val();
            // var GetYear = $("#txtFromDate").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetEmployee", "ESS_Assets_AssignAssets")',
                data: { CompanyId:CompanyId, BranchId: BranchId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlAssetEmployeeId").append("<option value=''>All </option>");
                        $.each(data, function (i, p) {
                            $("#ddlAssetEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

    })

</script>*@

