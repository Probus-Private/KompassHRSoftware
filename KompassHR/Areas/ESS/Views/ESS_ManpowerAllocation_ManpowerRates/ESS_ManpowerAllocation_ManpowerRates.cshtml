        $("#txtManpowerRateManDays").keyup(function()
        {
            var RateManDays= Number(document.getElementById('txtManpowerRateManDays').value);
            if(RateManDays>31)
            {
                $("#ErrorManpowerRateManDays").html("Man days should not greater than 31 days");return false;
            }
            else
            {
                $("#ErrorManpowerRateManDays").html("");
            }
        })

        var FromDate = @Html.Raw(Json.Encode(TempData["FromDate"]));
        var ToDate = @Html.Raw(Json.Encode(TempData["ToDate"]));
