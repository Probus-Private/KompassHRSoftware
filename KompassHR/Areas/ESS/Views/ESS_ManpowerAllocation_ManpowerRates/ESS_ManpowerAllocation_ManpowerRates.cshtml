        var ManpowerRateToDate = $("#txtManpowerRateToDate").val();
        var ManpowerRateKPISubCategoryId = $("#ddlManpowerRateKPISubCategoryId").val();
        var ManpowerRateMonth = $("#ddlManpowerRateMonth").val();


        $.ajax({
            url: '@Url.Action("IsManpowerRatesExists", "ESS_ManpowerAllocation_ManpowerRates")',
            method:"get",
            data: {ManpowerRateId_Encrypted:ManpowerRateId_Encrypted,ManpowerRate:ManpowerRate,ManpowerRateKPICategoryId:ManpowerRateKPICategoryId,ManpowerRateFromDate:ManpowerRateFromDate,ManpowerRateToDate:ManpowerRateToDate,ManpowerRateKPISubCategoryId:ManpowerRateKPISubCategoryId},
