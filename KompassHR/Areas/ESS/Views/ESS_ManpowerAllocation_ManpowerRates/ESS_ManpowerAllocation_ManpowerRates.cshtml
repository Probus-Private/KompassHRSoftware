                                                        <th class="text-nowrap">Sub Category Name</th>
                                                        <th class="text-nowrap">From Date </th>
                                                        <th class="text-nowrap">To Date</th>
                                                        <th class="text-nowrap"> Rates</th>

                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>



