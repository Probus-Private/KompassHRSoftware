@model KompassHR.Areas.ESS.Models.ESS_Warning.Warning_Employee
@{
    ViewBag.Title = "ESS_Warning_EmployeeWarning";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
               Employee Warning
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_HRSpaceMenu", "ESS_HRSpaceMenu", new {id = 41, ScreenId=651, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
                @*<li class="breadcrumb-item active" id="backButton"><a href="#">Back</a></li>*@
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Employee Warning - <b>@ViewBag.AddUpdateTitle</b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>


                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        
                        
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/ESS/ESS_Warning_EmployeeWarning/SaveUpdate" id="saveEmployeeWarning" method="post">
                                <div class="row mb-15px">
                                    @Html.HiddenFor(model => Model.WarningEmpID_Encrypted)
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => Model.DocNo, new { @class = "form-control", id = "DocNo", name = "DocNo", @readonly = "readonly", Value = @ViewBag.DocNo.DocNo,Style = "background-color: #eee;"  })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { name = "DocDate", @class = "form-control", id = "dateDocDate", type = "date" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.WarningEmployeeID, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "--Select--", new { id = "ddlWarningEmployeeID", name = "WarningEmployeeID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Total Warning
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBox("TotalWarning", "", new { @class = "form-control", id = "TotalWarning", name = "TotalWarning", @readonly = "readonly", disabled = "disabled", Value = 0 })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                This Month
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBox("ThisMonthTotal", "", new { @class = "form-control", id = "ThisMonthTotal", name = "ThisMonthTotal", @readonly = "readonly", disabled = "disabled", Value = 0 })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Warning Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.WarningID, new SelectList(ViewBag.GetWarningType, "WarningID", "WarningType"), "--Select--", new { id = "WarningID", name = "WarningID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.Description, new { @class = "form-control", id = "Description", name = "Description" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">
                                                    Last Record :
                                                    <br />
                                                    <span>@ViewBag.LastRecored</span>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="submit" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnEmployeeWarningGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- BEGIN scroll-top-btn -->
<a href="javascript:;" class="btn btn-icon btn-circle btn-success btn-scroll-to-top"
   data-toggle="scroll-to-top"><i class="fa fa-angle-up"></i></a>
<!-- END scroll-top-btn -->
<!-- END #app -->
<script>
    debugger;
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }

</script>

<script>
    $(document).ready(function () {
        debugger;
        $("#ddlWarningEmployeeID").select2();
        var dt = @Html.Raw(Json.Encode(TempData["DocDate"]));

        if(dt != null )
        {
            var VoucherDatedt =  convertDate(dt);
            $("#DocDate").val(VoucherDatedt);

        }

        var TotalWraing = @Html.Raw(Json.Encode(TempData["TotalWarning"]));
        var MothTotal = @Html.Raw(Json.Encode(TempData["MonthTotal"]));
        $("#TotalWarning").val(TotalWraing);
        $("#ThisMonthTotal").val(MothTotal);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }

        $("#btnEmployeeWarningGetList").click(function () {
            window.location.href= '@Url.Action("GetList", "ESS_Warning_EmployeeWarning")';
        });
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#dateDocDate").val(dateString);

    });//Ready Funcation

    var today = new Date().toISOString().split('T')[0];
    document.getElementById("dateDocDate").setAttribute("min", today);
    document.getElementById("dateDocDate").setAttribute("max", today);
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       debugger;
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#saveEmployeeWarning").validate({

        rules: {
            DocDate:{
                required:true,
            },
            WarningEmployeeID: {
                required: true,

            },
            WarningID: {
                required: true,

            },

            Description:{
                required:true,
            }
        },

        messages: {

            DocDate: {
                required: "This field is required",
            },
            WarningEmployeeID: {
                required: "This field is required",

            },
            WarningID: {
                required: "This field is required",
            },

            Description:{
                required: "This field is required",
            },
        }
    });

    //<-----------------------------Alreay exist---------------------------------->
    var form=$("#saveEmployeeWarning");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#DocDate").removeClass('error');
            //$('#txtCorporationDate').removeClass('error');
            return false;
        }
        debugger;
        var DocNo=$("#DocNo").val();
        var DocDate=$("#DocDate").val();
        var WarningEmployeeID=$("#WarningEmployeeID").val();
        var WarningEmpID_Encrypted=$("#WarningEmpID_Encrypted").val();
        var WarningID=$("#WarningID").val();
        var Description=$("#Description").val();
        $.ajax({
            url: '/ESS_Warning_EmployeeWarning/IsEmployeeWarningExists',
            method:"get",

            data:{DocNo:DocNo,
                DocDate:DocDate,
                EmployeerID:EmployeerID,
                WarningEmpID_Encrypted:WarningEmpID_Encrypted,
                WarningID:WarningID,
                Description:Description
            },
            success:function(response){
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    debugger;
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });
                    }
                }
                else{
                    //End BtnSubmit
                    $("#saveEmployeeWarning").submit();
                }
            }
        });
    });
</script>


<script>
    $(document).ready(function () {
        $("#ddlWarningEmployeeID").change(function () {debugger;
            debugger;
            var WarningEmployeeID = $("#ddlWarningEmployeeID").val();
            $.ajax({
                async: true,
                type: 'GET',
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                url: '/ESS_Warning_EmployeeWarning/GetEmployeeWarningDetail',
                data: { WarningEmployeeID: WarningEmployeeID },
                success: function (data) {
                    debugger;
                    $('#TotalWarning').val(data.TotalWarning);
                    $('#ThisMonthTotal').val(data.MonthTotal)
                    //$('#TotalWarning').html(data.TotalWarning);


                },
            });
        });
    });

</script>
<script>
    document.getElementById('backButton').addEventListener('click', function (event) {
        event.preventDefault();
        if (window.history.length > 1) {
            window.history.back();
        } else {
            window.location.href = this.href;
        }
    });
</script>