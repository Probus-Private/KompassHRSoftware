<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                COFF Requisition
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Coff Requisition - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="@Url.Action("ESS_Leave_COFFRequistion", "ESS_Leave_COFFRequistion", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                        </div>

                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine" style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th hidden>CoffRequestID_Encrypted</th>
                                            <th hidden>DocNo</th>
                                            <th class="fixed-side">Cancel</th>
                                            <th class="fixed-side1">Delete</th>
                                            <th class="fixed-side1">Status</th>
                                            <th class="text-nowrap text-center">Doc No </th>
                                            <th class="text-nowrap text-center">Doc Date </th>
                                            <th class="text-nowrap text-center">Day Type</th>
                                            <th class="text-nowrap text-center">For Date</th>
                                            <th class="text-nowrap text-center">Days</th>
                                            <th class="text-nowrap text-center">Reason</th>
                                            <th class="text-nowrap text-center">Approve/Rejected by</th>
                                            <th class="text-nowrap text-center">Approve/Rejected Date</th>
                                            <th class="text-nowrap text-center">Rejected Reason</th>
                                            <th class="text-nowrap text-center">Coff Generated Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.GetCoffRequest)
                                        {
                                            <tr>
                                                <th hidden>@d.CoffRequestID_Encrypted</th>
                                                <th hidden>@d.DocNo</th>
                                                @if (@d.CancelStatus != "")
                                                {
                                                    <td class="text-center"> @d.CancelStatus</td>
                                                }
                                                else
                                                {
                                                    <td class="text-center">
                                                        <a href="#modal-dialogForHoldReject1" onclick="CancelRequestFun(@d.CoffRequestID,'@d.Status')" id="btnmodal-dialog1">
                                                            <i class="fa-solid fa-xmark fa-xl text-dark" style="color:black"></i>
                                                        </a>
                                                    </td>
                                                }

                                                @if (@d.status == "L1- Approved" || @d.status == "L2- Approved")
                                                {
                                                    <td class="text-center"></td>
                                                }
                                                else
                                                {
                                                    <td class="text-center">
                                                        <a id="btnDelete" onclick="DeleteCoffRequest('@d.CoffRequestID_Encrypted','@d.Status')"
                                                           style="cursor:pointer">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>
                                                }
                                                <td class="text-nowrap">
                                                    <i class="fa-solid fa-circle-info text-success fa-lg" style="cursor: pointer;" onclick="ApproveStatus(@d.CoffRequestID)"></i> &nbsp;
                                                    @d.ApprovedDay
                                                </td>
                                                @*<td class="text-nowrap">@d.ApprovedDay</td>*@
                                                <td class="text-nowrap text-center">@d.DocNo</td>
                                                <td class="text-nowrap">@d.CreatedDate</td>
                                                <td class="text-nowrap">@d.CoffRequestDayType</td>
                                                <td class="text-nowrap">@d.ForDate</td>
                                                <td class="text-nowrap">@d.TotalDays</td>
                                                <td class="text-nowrap">@d.Reason</td>
                                                <td class="text-nowrap">@d.ApproverName</td>
                                                <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                <td class="text-nowrap">@d.CoffGenerationDate</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<!-- #Start Cancel Request dialog -->
<div class="modal fade" id="CancelModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h5 class="modal-title"> Remark For Cancel</h5>

            </div>
            <div class="modal-body">
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <h6> Select Approver Name</h6>

                                            @Html.DropDownList("Id", new SelectList(ViewBag.GetManagerEmployee, "Id", "Name"), "--Select--", new { @class = "form-select", Id = "ddlManagerName" })
                                            <h1></h1>
                                            <span id="ErrorMessage" class="Error" style="color:red"></span>
                                            <h6> Enter Remark </h6>
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>

                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="SendCancelRequest()" id="btnReject" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"> </i> Submit
                </button>
                <button type="button" id="btnCancel" class="btn btn-danger btnpress btn-sm CloseModel" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End Cancel Request dialog -->

