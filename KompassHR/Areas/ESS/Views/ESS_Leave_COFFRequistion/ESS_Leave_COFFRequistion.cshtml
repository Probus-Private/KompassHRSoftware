<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                COFF Requisition
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> COFF Requisition  - Add @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Leave_COFFRequistion", new { area = "ESS" })' id="SaveCOFFRequest" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @id = "txtDocNo", name = "DocNo", @class = "form-control", autocomplete = "off", Value = @ViewBag.DocNo.DocNo, Style = "background-color: lightgray;", @readonly = "readonly" })
                                                @Html.HiddenFor(model => model.CoffRequestID_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @id = "txtDocDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date", Style = "background-color: lightgray;", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Shift
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CoffShiftId, new SelectList(ViewBag.GetShiftList, "ShiftId", "ShiftName"), "--Select--", new { id = "ddlCoffShiftId", name = "CoffShiftId", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Day Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CoffRequestDayType, new List<SelectListItem>{
                                                                                 new SelectListItem {Text ="Full Day", Value="Full Day"},
                                                                                 new SelectListItem {Text ="1st Half", Value="1st Half"},
                                                                                 new SelectListItem {Text ="2nd Half", Value="2nd Half"}
                                                                                }, "--Select--", new { @class = "form-select", name = "CoffRequestDayType", @id = "ddlCoffRequestDayType" })
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromDate, new { @id = "txtFromDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date" })
                                                @*@Html.DropDownListFor(model => model.CoffGenerationEmployeeID, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { @id = "ddlCoffGenerationEmployeeID", name = "CoffGenerationEmployeeID", @class = "form-select", autocomplete = "off" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new { @id = "txtToDate", name = "DocDate", @class = "form-control", autocomplete = "off", type = "date" })
                                                @Html.ValidationMessageFor(model => model.ToDate, "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Total Days
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalDays, new { @id = "txtTotalDays", name = "TotalDays", @class = "form-control", autocomplete = "off", Style = "background-color: lightgray;", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Reason
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.Reason, new { @id = "txtReason", name = "Reason", @class = "form-control", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "ESS_Leave_COFFRequistion", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

        <div class="col-md-4">
            <div class="row">
                <div class="col-md-12">
                    <div class="panel panel-inverse" data-sortable-id="index">
                        <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                            <h4 class="panel-title">Available COFF</h4>
                            <div class="panel-heading-btn">
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                            </div>
                        </div>
                        <div class="panel-body" data-scrollbar="true" style="height:330px;">
                            <table class="table table-bordered table-hover mb-0 text-dark text-center" id="tblCoffRequest">
                                <thead>
                                    <tr style="background-color:#eee">
                                        <th>Select </th>
                                        <th hidden>COFF Generation ID</th>
                                        <th>Generation Date</th>
                                        <th>Available Coff</th>
                                        <th> Valid Till</th>

                                    </tr>
                                </thead>
                                <tbody id="tblCOFFRequestBody">

                                    @foreach (var d in ViewBag.GetGeneratedDays)
                                    {
                                        DateTime coffExpiredDate;
                                        bool isDateParsed = DateTime.TryParse(d.CoffExpriredDate?.ToString(), out coffExpiredDate);
                                        <tr class="coff-row">
                                            <td class="text-center">
                                                @if (isDateParsed && coffExpiredDate > DateTime.Today)
                                                {
                                                    <input type="checkbox" name="name" id="txtCoffGenerationID" value="@d.CoffGenerationID" />
                                                }
                                                else
                                                {
                                                    <span class="Error" style="color:red">Expired</span>
                                                }
                                            </td>
                                            <td hidden class="text-nowrap">@d.CoffGenerationID</td>
                                            <td class="text-nowrap">@d.CoffGenerationDate</td>
                                            <td class="text-nowrap">@d.Approvenoofcoff</td>
                                            <td class="text-nowrap">@d.CoffExpriredDate</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
        $("#txtDocDate").val(dateString);

        $("#ddlCoffShiftId").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $("#txtFromDate,#txtToDate").change(function () {
            debugger;
            var StartDate= document.getElementById('txtFromDate').value;
            var CoffRequestDayType= $("#ddlCoffRequestDayType").val();
            var EndDate= document.getElementById('txtToDate').value;
            if(StartDate==""){
                $('#ErrortxtToDate').html("To date should not be less than from date"); return false;
                $("#txtToDate").val("");
            }
            else{
                $('#ErrortxtToDate').html("");
            }
            var sDate = new Date(StartDate);
            var eDate = new Date(EndDate);
            var Time = Math.abs(eDate - sDate);
            var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;


            if(CoffRequestDayType=="Full Day")
            {
                $("#txtTotalDays").val(days);
                // $("#txtTotalDays").val(1);
            }
            else if(CoffRequestDayType=="1st Half")
            {
                var StartDate= document.getElementById('txtFromDate').value;
                $("#txtToDate").val(StartDate);
                $("#txtTotalDay").val("0.5");
            }
            else if(CoffRequestDayType=="2nd Half")
            {
                var StartDate= document.getElementById('txtFromDate').value;
                $("#txtToDate").val(StartDate);
                $("#txtTotalDay").val("0.5");
            }
            let toDateValue = $("#txtToDate").val();
            //if (!toDateValue) return; // Exit if no toDate is selected

            // Create a date object for 'toDate' and reset the time to 00:00:00
            let toDate = new Date(toDateValue);
            toDate.setHours(0, 0, 0, 0); // Reset time

            // Loop through each row inside the #tblCOFFRequestBody table
            $("#tblCOFFRequestBody .coff-row").each(function () {
                let row = $(this);

                // Get the expired date from the 4th <td> (index 3) and reset its time
                let expiredDateText = row.find("td").eq(4).text().trim();
                let expiredDate = new Date(expiredDateText);
                expiredDate.setHours(0, 0, 0, 0); // Reset time

                // Target the .text-center <td> where the checkbox or "Expired" text goes
                let textCenterCell = row.find(".text-center");

                if (expiredDate < toDate) {
                    // If expired, remove checkbox and show "Expired" text
                    textCenterCell.find(".coff-checkbox").remove();
                    if (!textCenterCell.find(".Error").length) {
                        textCenterCell.html('<span class="Error" style="color:red">Expired</span>');
                    }
                } else {
                    // If not expired, show checkbox and remove "Expired" text
                    if (!textCenterCell.find(".coff-checkbox").length) {
                        let coffID = row.find(".coff-id").text(); // Get the ID
                        textCenterCell.html(`<input type="checkbox" class="coff-checkbox" name="name" value="${coffID}" />`);
                    }
                    textCenterCell.find(".Error").remove();
                }
            });

            var StartDate=$("#txtFromDate").val();
            var EndDate=$("#txtToDate").val();

            var sDate = new Date(StartDate);
            var eDate = new Date(EndDate);
            var Time = Math.abs(eDate - sDate);
            var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;
            if(StartDate!= '' && EndDate!= '' && sDate > eDate)
            {
                $("#ErrortxtToDate").html("To date should not be less than from date.");
                $("#txtToDate").val('');
                return false;
            }
            else{
                $("#ErrortxtToDate").html("");
            }



        });

        $("#ddlCoffRequestDayType").change(function () {
            debugger;
            var StartDate= document.getElementById('txtFromDate').value;
            var EndDate= document.getElementById('txtToDate').value;
            var CoffRequestDayType= $("#ddlCoffRequestDayType").val();
            if(CoffRequestDayType=="Full Day")
            {
                //var sDate = new Date(StartDate);
                //var eDate = new Date(EndDate);
                //var Time = Math.abs(eDate - sDate);
                //var days = Math.ceil(Time/(1000 * 60 * 60 * 24))+1;
                $("#txtToDate").removeAttr('readOnly', true);
                $("#txtTotalDays").val(1);
            }
            else if(CoffRequestDayType=="1st Half")
            {
                $("#txtToDate").val("");
                $("#txtFromDate").val("");
                $("#txtTotalDays").val(0.5);
                $("#txtToDate").attr('readOnly', true);
            }
            else if(CoffRequestDayType=="2nd Half")
            {
                $("#txtToDate").val("");
                $("#txtFromDate").val("");
                $("#txtTotalDays").val(0.5);
                $("#txtToDate").attr('readOnly', true);
            }

        });

    })//ready Function


