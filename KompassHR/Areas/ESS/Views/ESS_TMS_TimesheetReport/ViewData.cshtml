
@{
    ViewBag.Title = "ViewData";
    Layout = "~/Views/Shared/_Layout.cshtml";


    var list = (IEnumerable<dynamic>)ViewBag.Getdata;
    var hasData = ViewBag.Getdata != null && ViewBag.Getdata.Count > 0;
    var header = hasData ? ViewBag.Getdata[0] : null;
    var leaveGroups = hasData ? (from e in list group e by new { e.LeaveTypeShortName, e.LeaveYear } into g select g) : null;
}
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                TimeSheet Reports
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_TimesheetReport", "ESS_TMS_TimesheetReport", new {id = 12, ScreenId=900, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> TimeSheet Report</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        TimeSheet Reports.
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" href="@Url.Action("ESS_TMS_TimesheetReport", "ESS_TMS_TimesheetReport" , new { area = "ESS" })" id="formLeaveReport" method="post">
                            <!--Begin Data-->

                            <table style="width:100%; border-collapse: collapse; border:1.5px solid #ccc;">
                                <thead></thead>

                                @if (ViewBag.Getdata == null || ViewBag.Getdata.Count == 0)
                                {

                                }
                                else
                                {
                                    //var header = ViewBag.Getdata[0];
                                    //var List = (IEnumerable<dynamic>)ViewBag.Getdata;

                                    //var leaveGroups = from e in List group e by new { e.LeaveTypeShortName, e.LeaveYear } into g select g;
                                    <tbody>
                                        <tr>
                                            <td style="padding:0 !important;">

                                                <table class="emi-table1" style="width:100%; border-collapse: collapse; border:1px solid #ccc; margin-bottom:25px;">
                                                    <tbody>
                                                        <tr>
                                                            <td style="border:1px solid #ccc; padding:5px; text-align:center; font-weight:bold; background:#f5f5f5; height:40px; font-size:18px;" colspan="4">
                                                                @header.CompanyName
                                                            </td>
                                                        </tr>

                                                        <tr>
                                                            <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Employee No</td>
                                                            <td style="border:1px solid #ccc; padding:5px;">@header.EmployeeNo</td>
                                                            <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Employee Name</td>
                                                            <td style="border:1px solid #ccc; padding:5px;">@header.EmployeeName</td>
                                                        </tr>

                                                        <tr>
                                                            <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Billing Month</td>
                                                            <td style="border:1px solid #ccc; padding:5px;">@header.MonthYear</td>
                                                            <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Customer Location</td>
                                                            <td style="border:1px solid #ccc; padding:5px;">@header.BranchName</td>
                                                        </tr>

                                                    </tbody>
                                                </table>

                                                @foreach (var leaveGroup in leaveGroups)
                                                {
                                                    var leaveHeader = leaveGroup.First();

                                                    <table class="emi-table" style="width:100%; border-collapse: collapse; border:1px solid #ccc; margin-bottom:20px;">
                                                        <thead>
                                                            @{
                                                                int Sr_No = 1;
                                                            }
                                                            <tr>
                                                                <td style="border:1px solid #ccc; padding:5px; text-align:center; font-weight:bold; background:#f5f5f5; height:40px; font-size:18px;" colspan="9">
                                                                    Timesheet Information
                                                                </td>
                                                            </tr>

                                                            <tr class="emi-header">
                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center; width:50px;">Sr.No</th>
                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center;">Dates</th>
                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center;">Task Title</th>

                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center;">In Out Status</th>
                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center;"> In Time</th>
                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center;">Out Time</th>
                                                                <th style="border:1px solid #ccc; padding:5px; text-align:center;">Duration</th>
                                                                @*<th style="border:1px solid #ccc; padding:5px; text-align:center;">Holiday/Weekoff</th>*@

                                                            </tr>
                                                        </thead>

                                                        <tbody>
                                                            @foreach (var d in leaveGroup)
                                                            {

                                                                <tr>
                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:right;">@Sr_No</td>
                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.Dates</td>
                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:left;">@d.TaskTitle</td>

                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.InOutStatus</td>
                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.InTime</td>
                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.OutTime</td>
                                                                    <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.Duration</td>
                                                                </tr>
                                                                Sr_No++;
                                                            }
                                                            <tr>
                                                                <td></td>
                                                                <td></td>
                                                                <td></td>
                                                                <td></td>
                                                                <td></td>
                                                                <td style="font-weight:bold; border:1px solid #ccc; padding:5px;text-align:center;">Total Duration</td>
                                                                <td style="border:1px solid #ccc; padding:5px; text-align:right;">@header.TotalDuration</td>

                                                            </tr>


                                                        </tbody>
                                                    </table>
                                                    <br />
                                                   }
                                            </td>
                                        </tr>
                                    </tbody>
                                   }
                            </table>

                            <!--End Data-->
                            <!--Begin Data-->

                            <table class="emi-table" style="width:100%; border-collapse: collapse; border:1px solid #ccc; margin-bottom:20px;">
                                <thead>
                                    <tr class="emi-header">
                                        <th style="border:1px solid #ccc; padding:5px; text-align:center;">Sr.No</th>
                                        <th style="border:1px solid #ccc; padding:5px; text-align:center;">Day Classification</th>
                                        <th style="border:1px solid #ccc; padding:5px; text-align:center;">Days</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">1</td>
                                        <td style="border:1px solid #ccc; padding:5px;">Holiday</td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@header.TotalPH</td>
                                    </tr>

                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">2</td>
                                        <td style="border:1px solid #ccc; padding:5px;">Week Off</td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@header.TotalWO</td>
                                    </tr>

                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">3</td>
                                        <td style="border:1px solid #ccc; padding:5px;">Leave Balance</td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@header.NoOfLeave</td>
                                    </tr>

                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">4</td>
                                        <td style="border:1px solid #ccc; padding:5px;">Total present</td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@header.TotalPresent</td>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">5</td>
                                        <td style="border:1px solid #ccc; padding:5px;">Total Absent</td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@header.TotalAbsent</td>
                                    </tr>


                                </tbody>
                            </table>

                            <!--End Data-->
                            <!---Begin-->

                            @*<table class="emi-table2" style="width:100%; border-collapse: collapse; border:1px solid #ccc; margin-bottom:20px;">*@
                            <table style="width:100%; border-collapse:collapse;">
                                <thead>
                                    <tr class="emi-header">
                                        <th style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            Approving Authority Name
                                        </th>
                                        <th style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            Signature
                                        </th>
                                        <th style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            Date
                                        </th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            @header.ResponsiblePerson
                                        </td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;"></td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            @header.SignatureDate
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                                  
                                    <!--End-->
                        </form>
                    </div>
                </div>

            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

