
@{
    ViewBag.Title = "CategoryView";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .loader {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 600px;
    }

        .loader::after {
            content: "";
            width: 50px;
            height: 50px;
            border: 6px solid #ccc;
            border-top-color: #007bff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    #DocBody {
        height: 400px; /* Set desired height */
        width: 100%; /* Or use a fixed width like 400px */
        overflow-y: auto; /* Enables vertical scroll when needed */
        overflow-x: hidden; /* Hides horizontal scroll */
    }

    .Error {
        text-align: left;
        height: 35px;
    }
</style>

<style>
    .mfa-input {
        width: 45px;
        height: 55px;
        font-size: 24px;
        border: 2px solid #ccc;
        border-radius: 10px;
        margin: 0 4px;
        transition: all 0.2s ease;
    }

        .mfa-input:focus {
            border-color: #007bff;
            outline: none;
            box-shadow: 0 0 8px rgba(0, 123, 255, 0.4);
        }
</style>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                @TempData["Cat_SubCatName"]
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_LMS_Category", "ESS_LMS_Category", new {id = 38, ScreenId=560, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
        <br /><br />
        <div class="box-footer text-right" style="background-color: #f5f5f5; padding: 5px 10px;">
            <div class="form-inline d-inline-block">
                <label class="checkbox-inline" style="margin-right: 10px; font-size: 13px;">
                    @TempData["CategoryDesc"]
                </label>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xs-12">
            <div class="box box-info">
                <div class="box-body">
                    <!-- Main Grid -->
                    <div class="row">
                        <!-- Left Column (4 cols) - Table with File List -->
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header text-white" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">File List</div>
                                <div class="card-body p-0">
                                    <input type="hidden" id="hdnLibraryDocId" />
                                    <input type="hidden" id="hdnIsReadDocument" />
                                    <input type="hidden" id="hdnLMSLibraryId" value="@TempData["LMSLibraryId"]" />
                                    <input type="hidden" id="hdnLMSCategoryId" value="@TempData["LMSCategoryId"]" />
                                    <table class="table table-bordered table-striped m-0">
                                        <thead>
                                            <tr>
                                                <th class="text-center" hidden><small>LibraryDocId</small></th>
                                                <th class="text-center"><small>File Name</small></th>
                                                <th class="text-center" hidden><small>Type</small></th>
                                                <th class="text-center"><small>Status</small></th>
                                                <th class="text-center"><small>Show</small></th>
                                            </tr>
                                        </thead>
                                        <tbody id="fileListTableBody">
                                            <!-- Populated by JS -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column (8 cols) - Gallery (PDF/Image/Video) -->
                        <div class="col-md-8">
                            <div class="panel panel-inverse" data-sortable-id="index-1">
                                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                                    <h4 class="panel-title"> Document </h4>
                                    <div class="panel-heading-btn">
                                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" style="background-color: white;" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                                    </div>
                                </div>
                                <!-- Main Footer with Checkbox and Button -->
                                <div class="box-footer text-right" style="background-color: #f5f5f5; padding: 5px 10px; display:none" id="divDocAgree">
                                    <div class="form-inline d-inline-block">
                                        <label class="checkbox-inline" style="margin-right: 10px; font-size: 13px;">
                                            <input type="checkbox" id="DocagreeCheck" style="margin-right: 5px;">
                                            I have reviewed the document and I agree with its contents.
                                        </label>
                                        <button type="button" class="btn btn-primary btn-sm" id="btnDocSeeSubmit" onclick="submitReadDocumentSure()">Submit</button>
                                    </div>
                                </div>

                                <!-- Error Message Section (Initially Hidden) -->
                                <div class="box-footer text-left" style="background-color: #fff; padding: 5px 10px; display: none;" id="divErrorDocagreeCheck">
                                    <span id="ErrorDocagreeCheck" class="Error text-danger" style="font-size: 12px;"></span>
                                </div>

                                <div class="box-body" id="DocBody">
                                    <div class="gallery-row row" id="modalContent1">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Footer -->
                <div class="box-footer text-right" style="background-color: #f5f5f5; padding: 5px 10px;">
                    <div class="d-flex align-items-center">
                        <!-- First div containing checkbox and submit button -->
                        <div class="align-items-center mr-3" id="divFinalSubmit">
                            <label class="checkbox-inline" style="margin-right: 10px; font-size: 13px;">
                                <input type="checkbox" id="FinalgreeCheck" style="margin-right: 5px;">
                                I have reviewed the entire document and hereby submit it as final.
                            </label>

                            <button type="button" class="btn btn-primary btn-sm" id="btnFinalSubmit" onclick="FinalSubmitSure()">Submit</button> &nbsp;&nbsp;
                        </div>

                        @{
                            var isAssessment = TempData["IsAssessment"] != null && Convert.ToBoolean(TempData["IsAssessment"]);
                        }
                        @if (isAssessment)
                        {
                            <div>
                                <span id="spnFinalSubmit"></span>
                                <button type="button" class="btn btn-success btn-sm" id="btnIsAssesment" onclick="GoToAssesment()"><i class="fa-solid fa-pen-to-square"></i> Assessment</button>
                            </div>
                        }
                        &nbsp;&nbsp;
                        <div>
                            <span id="spnAssessmentSubmit"></span>
                            <button type="button" class="btn btn-primary btn-sm" id="feedbackTrigger"> <i class="fa-solid fa-comments"></i> Give Feedback</button>
                            @*<button type="button" class="btn btn-secondary btn-sm " id="feedbackTrigger">
                                <img src="~/assets/MenuImages/LMSfeedback.png"  alt="Good Feedback" width="16" height="16" style="margin-right: 5px;">
                                Give Feedback
                            </button>*@
                           
                        </div>
                    </div>
                </div>
                <!-- Error Message Section (Initially Hidden) -->
                <div class="box-footer text-left" style="background-color: #fff; padding: 5px 10px; display: none;" id="divErrorFinalgreeCheck">
                    <span id="ErrorFinalgreeCheck" class="Error text-danger" style="font-size: 12px;"></span>
                </div>
            </div>
        </div>
    </div>
</div>


