            <div class="modal-header bg-black text-white">
                <h5 class="modal-title" id="mfaModalLabel">LMS - OTP</h5>
                <!-- Close Button -->
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <h3 class="mb-4">Enter the 6-digit OTP from your email.</h3>
                <form id="EmailOTP">
                    <div class="d-flex justify-content-center align-items-center gap-2">
                        <div class="d-flex">
                            <input type="text" class="mfa-input text-center mx-1 form-control" maxlength="1" />
                            <input type="text" class="mfa-input text-center mx-1 form-control" maxlength="1" />
                            <input type="text" class="mfa-input text-center mx-1 form-control" maxlength="1" />
                            <input type="text" class="mfa-input text-center mx-1 form-control" maxlength="1" />
                            <input type="text" class="mfa-input text-center mx-1 form-control" maxlength="1" />
                            <input type="text" class="mfa-input text-center mx-1 form-control" maxlength="1" />
                        </div>
                        <button type="button" id="pasteButton" class="btn btn-light ms-2" title="Paste from clipboard" hidden>
