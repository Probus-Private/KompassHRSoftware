
@{
    ViewBag.Title = "ESS_LMS_SubCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<link href="~/assets/MyCSS/MenuImages.css" rel="stylesheet" />
<link href="~/Content/Site.css" rel="stylesheet" />
<!-- ================== End SWEEand css ================== -->

<head>
    <style>
        .box {
            width: 100px;
            height: 100px;
            backdrop-filter: blur(25px) saturate(00%);
            background-color: rgba(255, 255, 255, 1);
            border-radius: 12px;
            border: 3px solid rgba(255, 255, 255, 1);
            margin: 5px;
            box-shadow: inset 0 15px 25px rgba(0, 0, 0, 0.03), inset 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
            padding: 15px 0px;
            font-family: 'Montserrat', sans-serif;
            position: relative;
            z-index: 0;
        }

            .box:hover {
                /* BORDER:2PX SOLID #666; */
                border: 2px solid #007bff;
                cursor: pointer;
                transform: translateY(-4px);
            }


            .box .info i {
                font-size: 18px;
                width: 100%;
                text-align: center;
                margin-bottom: 15px;
                color: #007bff;
            }

            .box :hover.INFO i,
            .box:hover .info h7 {
                COLOR: #000;
            }

            .box .info h7 {
                font-size: 11px;
                text-align: center;
                display: flex;
                justify-content: center;
                font-weight: 900 !important;
                text-transform: capitalize;
                margin-bottom: 2px;
                padding: 0 10px;
                color: #444;
            }

        .Col-md-2 {
            margin: 10px 0;
        }

        a .icon2 {
            text-align: center;
            width: 100%;
        }

            a .icon2 i {
                font-size: 40px;
                color: #007bff;
            }

        .icon2 h7 {
            font-weight: 600;
        }

        .callout {
            /*position: fixed;*/
            bottom: 35px;
            right: 20px;
            margin-left: 20px;
            max-width: 300px;
        }

        .callout-header {
            padding: 25px 15px;
            background: #FFFACD;
            font-size: 20px;
            color: black;
            border: solid;
        }

        .callout-container {
            padding: 15px;
            background-color: #ccc;
            color: black;
            border: solid;
        }

        .closebtn {
            position: absolute;
            top: 5px;
            right: 15px;
            color: white;
            font-size: 30px;
            cursor: pointer;
        }

            .closebtn:hover {
                color: lightgrey;
            }

        .card {
            height: 150px; /* Set a fixed height */
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
    </style>

</head>

<body>
    <div id="content" class="app-content">
        <div class="pageHeader d-flex align-items-center justify-content-between" style="flex-wrap:nowrap;">
            <h5 class="page-header text-center text-md-start">@TempData["CategoryName"]</h5>
            <ol class="breadcrumb float-md-end mb-0">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" class="img-fluid" style="max-width: 100%;float:right" />
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_LMS_Category", "ESS_LMS_Category", new {id = 38, ScreenId=560, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
        
       
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p>
                            Here's a detailed breakdown of LMS (Learning Management System) Sub-Categories, in the same descriptive style as the HRMS-LMS categories list.
                        </p>
                    </div>
                    <div class="panel-body" style="max-height: max-content; background: #fff;" id="PolicyLibrary">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="container">
                                    <div class="row">
                                       @foreach (var d in ViewBag.SubCategory)
                                       {
                                        <div class="col-md-4 col-sm-6 col-12 mb-3">
                                            <div class="card shadow border">
                                                <!-- Header: Icon and Name -->
                                                <div class="card-header bg-white d-flex align-items-center p-2 border-bottom">
                                                    <img src="~/assets/MenuImages/LMSSubCategories.png" style="height: 30px;" /> &nbsp;&nbsp;
                                                    <h5 class="mb-0">@d.Title</h5>
                                                </div>

                                                <!-- Body: Remark -->
                                                <div class="card-body p-2">
                                                    <p class="text mb-0" style="font-size: 0.875rem;">@d.Description</p>
                                                </div>

                                                <!-- Footer: Button and Counts -->
                                                <div class="card-footer bg-white d-flex justify-content-between p-1">
                                                    <!-- Show ImageCount, PDFCount, and VideoCount -->
                                                    <div class="d-flex align-items-center">
                                                        <i class="fa fa-file-image text-warning" style="font-size: 20px; margin-right: 5px;"></i>
                                                        <span>@d.ImageCount</span>
                                                    </div>

                                                    <div class="d-flex align-items-center">
                                                        <i class="fa fa-file-pdf text-danger" style="font-size: 20px; margin-right: 5px;"></i>
                                                        <span>@d.PDFCount</span>
                                                    </div>

                                                    <div class="d-flex align-items-center">
                                                        <i class="fa fa-video-camera" style="font-size: 20px; margin-right: 5px;"></i>
                                                        <span>@d.VideoCount</span>
                                                    </div>

                                                    <div class="d-flex align-items-center">
                                                        <i class="fa @(d.IsFinalSubmit == true ? "fa-check-circle" : "fa-times-circle")"
                                                           style="font-size: 20px; margin-right: 5px; color: @(d.IsFinalSubmit == true ? "green" : "red");"></i>
                                                        <span style="color: @(d.IsFinalSubmit == true ? "green" : "red");">
                                                            @((d.IsFinalSubmit == true) ? "Yes" : "No")
                                                        </span>
                                                    </div>


                                                    <!-- Button Link -->
                                                    <a href="@Url.Action("CategoryView", "ESS_LMS_SubCategory", new { LMSCategoryId = d.LMSCategoryId , LMSLibraryId=d.LMSLibraryId, SubCategoryName=d.Title, CategoryName =@TempData["CategoryName"],CategoryDesc=d.FullDescription, IsAssessment = d.IsAssessmentRequired, IsDigitalSignature = d.IsDigitalSignature })"
                                                       class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center"
                                                       style="width: 20px; height: 20px; padding: 0;">
                                                        <i class="fa fa-arrow-right" style="font-size: 0.75rem;"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                       }

                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>



