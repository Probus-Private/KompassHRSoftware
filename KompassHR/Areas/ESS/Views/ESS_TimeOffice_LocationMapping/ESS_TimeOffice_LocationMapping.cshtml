<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Location Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new {id = 5, ScreenId=150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">  Location Mapping - <Span>@ViewBag.AddUpdateTitle</Span></h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Define Location Mapping here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "ESS_TimeOffice_LocationMapping", new { area = "ESS" })" id="SaveLocationGroup" method="post" data-parsley-validate="true">                                
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Location Group Name <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.GroupName, new { @class = "form-control", type = "text", id = "GroupName", autocomplete = "Off", @required = "required" })
                                                @Html.HiddenFor(model => model.LocationRegistrationMappingIMasterId_Encrypted)                                       
                                             </div>
                                        </div>
                                    </div>                                    
                                </div>
                                
                                <hr class="mt-0">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                            </label>
                                            <div class="col-md-5">
                                                <table class="table table-bordered align-middle tblAddData" id="tblLocationList" style="width: 100%;">
                                                    <thead style="text-align: center;">
                                                        <tr style="background-color: lightgray; border: 1px solid lightslategray;">
                                                            <th hidden class="text-nowrap ">LocationId</th>
                                                            <th style="border: 1px solid lightslategray;" class="text-nowrap width-45">Select</th>
                                                            <th style="border: 1px solid lightslategray;" class="text-nowrap ">Location Name</th>                                                                                                                        
                                                        </tr>
                                                    </thead>
                                                  <tbody>
                                                      
                                                  </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "ESS_TimeOffice_LocationMapping", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnShiftGroupList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>




<script>
    $(document).ready(function () {
        
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

  

      

    });//ready funcation
</script>



<script>

    var SelectedLocationList = @Html.Raw(Json.Encode(ViewBag.SelectedLocationList));
    if(SelectedLocationList!=null || SelectedLocationList!="")
    {
        var table = document.getElementById("tblLocationList");
        $.each(SelectedLocationList, function (data1, value) {
            debugger;
            //var rowCount = data.length;
            var rowCount = table.rows.length;
            var row = table.insertRow(rowCount);
            var count = SelectedLocationList.length;
            row.insertCell(0).innerHTML = ""+'<input id="chk" type="checkbox" name="checkBoxName" class="form-check-input" Value="'+value[0].Value+'" '+value[1].Value+'>'+""
            //row.insertCell(1).innerHTML = "" + value[2].Value + "";

            row.insertCell(1).innerHTML = "<div style='text-align: left;'>" + value[2].Value + "</div>";

        });
    }
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );
    $('#SaveLocationGroup').validate({
        rules: {
           
            GroupName: {
                required: true,
            },           
        },
        messages: {           
            GroupName: {
                required: "Location group name is required"
            },
           
        },
    });

    var form = $("#SaveLocationGroup");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }

        debugger
        var LocationRegistrationMappingIMasterId_Encrypted=$("#LocationRegistrationMappingIMasterId_Encrypted").val();
       
        var GroupName = $("#GroupName").val();
      debugger

        var lstLocationGroup=[];
        $(':checkbox:checked').each(function (i) {
            debugger;
            var data1 = {};
            data1.LocationRegistrationId = $(this).val();
            var currentRow = $(this).closest("tr");
            data1.LocationRegistrationId.value = currentRow.find("td:eq(1)").html();
           
            lstLocationGroup.push(data1);
        });
        debugger;
        if (lstLocationGroup == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Please select atleast one Location group",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }

        $.ajax({
            async: true,
            type:"POST",
            url: '@Url.Action("IsLocationGroupExists", "ESS_TimeOffice_LocationMapping")',
            data:JSON.stringify({LocationRegistrationMappingIMasterId_Encrypted:LocationRegistrationMappingIMasterId_Encrypted,GroupName:GroupName,lstLocationGroup:lstLocationGroup}),
            contentType: "application/json; charset=utf-8",
            dataType:"text",
            success:function(response){
                debugger;
               var Getdata = JSON.parse(response);
               var Message1 = Getdata.Message;
               var Icon1 = Getdata.Icon;
               if (Icon1=="error") {
                    if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                    }
                }
                else{
                    $("#SaveLocationGroup").submit();
                }
            }
        });
    });
</script>