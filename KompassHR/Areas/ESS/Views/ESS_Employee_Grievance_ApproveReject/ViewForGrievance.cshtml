@model KompassHR.Areas.ESS.Models.ESS_EmployeeGrievance.Employee_RaiseGrievance

@{
    ViewBag.Title = "ViewForGrievance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>


<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }
</style>
<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Raise Grievance
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "ESS_Employee_Grievance_ApproveReject",  new { id = 42,ScreenId=686, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">Raise Grievance- @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Raise Grievance here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Employee_RaiseGrievance", new { area = "ESS" })' id="SaveRaiseGrievance" method="post">
                                @Html.HiddenFor(model => model.RaiseGrievanceId_Encrypted, new { id = "txtRaiseGrievanceId_Encrypted" })
                                @Html.HiddenFor(model => model.RaiseGrievanceId, new { id = "txtRaiseGrievanceId" })


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Grievance Raise Date
                                            </label>
                                            <div class="col-md-8">
                                                <input type="text" id="txtGrievanceRaiseDate" readonly name="GrievanceRaiseDate" class="form-control" Style = "background-color: #eee;" />
                                            </div>
                                        </div>
                                    </div>


                                    <div class="col-md-5">
                                        <div class="row mb-12px">
                                            <label class="form-label col-form-label col-md-2">
                                                Doc Id
                                            </label>
                                            <div class="col-md-5">
                                                <input type="text" id="txtdocId" readonly name="DocId" class="form-control" Style = "background-color: #eee;" />
                                            </div>
                                        </div>
                                    </div>

                                </div>


                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Grievance Category
                                            </label>
                                            <div class="col-md-10">
                                                <input type="text" id="txtGrievanceCategory" readonly name="GrievanceCategory" class="form-control" Style = "background-color: #eee;"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Grievance SubCategory
                                            </label>

                                            <div class="col-md-10">
                                                <input type="text" id="txtGrievanceSubCategory" readonly name="GrievanceSubCategory" class="form-control" Style = "background-color: #eee;" />

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.Description, new { @class="summernote",id= "txtDescription" ,name= "Description" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>


                    <span class="float-end hidden-print">
                        @*<button type="button" class="btn  btn-primary" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>*@
                        <a href="#modal-dialogForApproval1" onclick="Approved('Approved')" type="button" class="btn btn-success" id="btnmodal-dialog" value="Approved"><i class="fa-solid fa-check-double"></i>Approve</a>
                        <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" type="button" class="btn btn-danger" id="btnmodal-dialog1" value="Rejected">Reject</button>
                        @*<button href="#modal-dialogForHoldReject1"  onclick="Approved('Approved')" type="button" class="btn btn-danger" id="btnmodal-dialog1" value="Rejected">Reject</button>*@

                    </span>

                </div>
            </div>
            <!-- END panel -->

        </div>
    </div>

    <!-- #Start Appprove Reject Modal -dialog -->
    <div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header bg-black text-white">
                    <h4 class="modal-title"> Remark For Reject</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                           aria-hidden="true" id="CloseModel">
                            <i class="fa fa-xmark"></i>
                        </a>
                    </div>
                </div>
                <div class="modal-body">
                    <!-- BEGIN panel -->
                    <div class="modal-body-content">
                        <div class="row">
                            <div class="col-md-12">
                                <form>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
                <div class="modal-footer">
                    <button type="button" onclick="Approved('Rejected')" id="btnReject" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk"> </i> Submit
                    </button>
                    <button type="button" id="btnCancel" class="btn btn-danger btnpress CloseModel" data-bs-dismiss="modal">
                        <i class="fa-solid fa-share-from-square"></i> Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- #End modal-dialog -->

    <script>
        //$(".summernote").summernote({
        //    placeholder: 'Description...',
        //    height: "300"
        //}).summernote('disable');

        $(".summernote").summernote({      
            height: "300"
        }).summernote('disable');
    </script>

    <script>
        $(document).ready(function () {debugger
            var Category = @Html.Raw(Json.Encode(TempData["GrievanceCategory"]));
            var SubCategory = @Html.Raw(Json.Encode(TempData["GrievanceSubCategory"]));
            var RaiseDate = @Html.Raw(Json.Encode(TempData["GrievanceRaiseDate"]));
            var DocId=@Html.Raw(Json.Encode(TempData["DocId"]));
            var Description = @Html.Raw(Json.Encode(TempData["Description"]));
            $("#txtGrievanceCategory").val(Category);
            $("#txtGrievanceSubCategory").val(SubCategory);
            $("#txtGrievanceRaiseDate").val(RaiseDate);
            $("#txtdocId").val(DocId);
            // $("#txtDescription").val(Description);
            //$(".summernote").summernote('code', Description);

            if (Description != null) {
            $('#txtDescription').summernote('code', Description);
            }
        });
    </script>

    <script>
        function OpenModule()
        {
            debugger;
            $("#myModalFinal").modal('show');
        }

        function Approved(Approver)
        {
            const Approved = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            Approved.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes Submit!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,

                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    debugger;
              
                    $(".Userloaderbg").css("display","flex");
                    //var RaiseGrievanceId=$("#txtRaiseGrievanceId").val();
                    var RaiseGrievanceId_Encrypted=$("#txtRaiseGrievanceId_Encrypted").val();
                    // var Origin=$("#hdnOrigin").val();
                    var Status="";
                    var ApproveRejectRemark="";
                    if(Approver=="Rejected")
                    {
                        ApproveRejectRemark = $("#txtApproveRejectRemark").val();
                        Status="Rejected";
                    }
                    else{
                        Status="Approved";
                    }
                    $("#myModalFinal").modal('hide');
                    $.ajax({
                        url: "@Url.Action("ApproveRequest", "ESS_Employee_Grievance_ApproveReject")",
                        method:"POST",
                        data:{RaiseGrievanceId_Encrypted:RaiseGrievanceId_Encrypted,Status:Status,ApproveRejectRemark:ApproveRejectRemark},
                        success:function(response){
                            debugger;
                            var Message1 = response.Message;
                            var Icon1 = response.Icon;
                            var ApproverMode1 = response.ApproverMode;
                            $(".Userloaderbg").css("display","none");
                            $("#myModalFinal").modal('hide');
                            $("#txtApproveRejectRemark").val("")
                            if (Message1 != null) {debugger
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("GetList", "ESS_Employee_Grievance_ApproveReject")';

                                        }
                                    })
                                }
                            }
                        }
                    });

                } else if (

                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                }
            })
        }
    </script>
