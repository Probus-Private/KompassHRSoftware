
@{
    ViewBag.Title = "ApproveRejectGetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Raise Grievance
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "ESS_Employee_Grievance_ApproveReject",  new {id=42,ScreenId=674, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Raise Grievance - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Raise Grievance created.

                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">

                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                           style="width: 100%;">
                                        <thead>
                                            <tr>

                                                @*<th class="fixed-side text-center">View</th>*@
                                                <th class="text-nowrap text-center">Doc No</th>
                                                <th class="text-nowrap text-center">Employee Name</th>
                                                <th class="text-nowrap">GrievanceRaiseDate</th>
                                                <th class="text-nowrap">Grievance Category</th>
                                                <th class="text-nowrap">Grievance SubCategory</th>
                                                <th class="text-nowrap">Description</th>
                                                <th class="text-nowrap">GrievanceFilePath</th>
                                                <th class="text-nowrap">Status</th>
                                                <th class="text-nowrap">Approve Rejected Date</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetRaiseGrievanceList)
                                            {
                                                <tr>


                                                    @*<td class="text-center">
                                                            <i class="fa-solid fa-eye text-danger fa-lg" onclick="ViewForGrievance('@d.RaiseGrievanceId_Encrypted')"></i>
                                                        </td>*@
                                                    <td>@d.DocId</td>
                                                    <td>@d.EmployeeName</td>
                                                    <td>@d.GrievanceRaiseDate.ToString("dd'/'MMM'/'yyyy")</td>
                                                    <td>@d.GrievanceCategory</td>
                                                    <td>@d.GrievanceSubCategory</td>
                                                    <td class="text-start text-center">
                                                        <input type="hidden" id="hiddenDescription_@d.RaiseGrievanceId" value="@d.Description" />
                                                        <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.RaiseGrievanceId').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                    </td>

                                                    @if (string.IsNullOrEmpty(d.GrievanceFilePath) || d.GrievanceFilePath == "File Not Found")
                                                    {
                                                        <td class="text-center text-muted">No file uploaded</td>
                                                    }
                                                    else
                                                    {
                                                        <td class="text-center">
                                                            <a id="btnshow"
                                                               href="@Url.Action("DownloadFile", "ESS_Employee_Grievance_ApproveReject", new {RaiseGrievanceId = d.RaiseGrievanceId,fileName = Path.GetFileName(d.GrievanceFilePath)})"
                                                               style="cursor:pointer;">
                                                                <i class="fa-solid fa-download fa-lg text-primary"></i>
                                                            </a>
                                                        </td>
                                                    }
                                                    <td>@d.Status</td>
                                                    <td>@d.ModifiedDate.ToString("dd'/'MMM'/'yyyy hh:mm tt")</td>

                                                    @*<td>@d.ModifiedDate</td>*@
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>

</div>



<!-- #Start modal-dialog -->
<div class="modal fade" id="modal_basic3" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Description</h4>
                <div class="panel-heading-btn">

                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div id="txtTaskStatus"></div>
                                            @* @Html.TextArea("TaskStatus", new { @class = "summernote", style = "border: 2px solid #000; padding: 10px;", id = "txtTaskStatus", @placeholder = "Description....", autocomplete = "Off", contenteditable = "false" })*@
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" id="btnCancel" class="btn btn-success btnpress" onclick="dismissModal('modal_basic3')">
                    @*<i class="fa-solid fa-floppy-disk"> </i> Ok*@
                    OK
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->
<script>
    function AssignTaskDesc(encodedHtml)
    {
        $('#txtTaskStatus').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtTaskStatus').html(AssignDesc);
            //$('#txtTaskStatus').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#' + modalId).modal('hide');
    }
</script>

<script>
    $(document).ready(function () {
        // Fetch the message and icon from TempData
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false,
                confirmButtonText: 'OK'
            }).then(() => location.reload());
        }
    });//Ready Funcation
</script>

