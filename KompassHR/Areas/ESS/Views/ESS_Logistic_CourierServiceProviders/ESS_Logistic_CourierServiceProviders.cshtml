@model KompassHR.Areas.ESS.Models.ESS_Logistic.Logistic_CourierServiceProvider

@{
    ViewBag.Title = "ESS_Logistic_CourierServiceProviders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Required library for validation -->
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }
</style>

<div id="content" class="app-content">
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 class="fs-5 fw-bold m-0" style="font-family: Roboto;">
                Courier Service Provider
            </h1>
            <ol class="list-unstyled d-flex m-0 p-0">
                <li class="me-3">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })" title="Home">
                        <img src="~/assets/MenuImages/Home.png" alt="Home" class="img-fluid" style="max-height: 24px;">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Logistic_Menu", "ESS_Logistic_Menu", new { id = 43, ScreenId = 765, area = "ESS" })" title="Back">
                        <img src="~/assets/MenuImages/Back.png" alt="Back" class="img-fluid" style="max-height: 24px;">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">
                        <i class="fas fa-file-signature"></i> Courier Service Provider - @ViewBag.AddUpdateTitle
                    </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand" title="Expand">
                            <i class="fa fa-expand"></i>
                        </a>
                    </div>
                </div>

                <div class="alert alert-info d-flex align-items-center mb-0 rounded-0">
                    <div class="me-3">
                        <i class="fas fa-info-circle fa-2x"></i>
                    </div>
                    <div>
                        <h5 class="alert-heading mb-1">Courier Service Provider Information</h5>
                        <p class="mb-0">This form is for creating and managing courier service provider information system.</p>
                    </div>
                </div>

                <div class="panel-body">
                    <form role="form" action='@Url.Action("SaveUpdate", "ESS_Logistic_CourierServiceProviders", new { area = "ESS" })' id="SaveCourierServiceProvider" method="post" novalidate>
                        <div class="card mb-4">
                            <div class="card-header bg-light">
                                <h5 class="card-title mb-0">
                                    <i class="fas fa-id-card me-2"></i>Basic Information
                                </h5>
                            </div>
                            <div class="card-body">
                                <!-- Courier Service Provider Name -->
                                <div class="mb-3">
                                    <label for="CourierServiceProviderName" class="form-label">
                                        Courier Service Provider <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-building"></i></span>
                                        @Html.TextBoxFor(m => m.CourierServiceProviderName, new { @class = "form-control", maxlength = "100", autocomplete = "off", placeholder = "Enter Courier Service Provider", required = "required", id = "CourierServiceProviderName" })
                                        @Html.HiddenFor(m => m.CourierServiceProviderID_Encrypted)
                                    </div>
                                </div>

                                <!-- Address -->
                                <div class="mb-3">
                                    <label for="Address" class="form-label">
                                        Address <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-map-marked-alt"></i></span>
                                        @Html.TextAreaFor(m => m.Address, new { @class = "form-control", rows = 3, autocomplete = "off", placeholder = "Legal registered address of the company", required = "required", id = "Address" })
                                    </div>
                                </div>

                                <!-- Mobile and WhatsApp -->
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="MobileNo" class="form-label">Mobile No.</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                            @Html.TextBoxFor(m => m.MobileNo, new { @class = "form-control", maxlength = "10", onkeypress = "return onlyNumbers(event);", autocomplete = "off", pattern = "\\d{10}", placeholder = "10-digit Mobile Number", id = "MobileNo" })
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="WhatappsNo" class="form-label">WhatsApp No.</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fab fa-whatsapp"></i></span>
                                            @Html.TextBoxFor(m => m.WhatappsNo, new { @class = "form-control", maxlength = "10", onkeypress = "return onlyNumbers(event);", autocomplete = "off", pattern = "\\d{10}", placeholder = "10-digit WhatsApp Number", id = "WhatappsNo" })
                                        </div>
                                    </div>
                                </div>

                                <!-- Email -->
                                <div class="mb-3">
                                    <label for="EmailId" class="form-label">Email Id</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                        @Html.TextBoxFor(m => m.EmailId, new { @class = "form-control", type = "email", autocomplete = "off", placeholder = "Enter Email Id", id = "EmailId" })
                                    </div>
                                </div>

                                <!-- Parcel Type and Service Provider Type -->
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="CourierType" class="form-label">
                                            Parcel Type <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-list"></i></span>
                                            @Html.DropDownListFor(m => m.CourierType,
                                            new SelectList(new[] {
                                                new { Value = "", Text = "--Select--" },
                                                new { Value = "Document", Text = "Document" },
                                                new { Value = "Parcel", Text = "Parcel" },
                                                new { Value = "Both", Text = "Both" }
                                            }, "Value", "Text"),
                                            new { @class = "form-select", required = "required", id = "CourierType" })
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="Destination" class="form-label">
                                            Service Provider Type <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-list"></i></span>
                                            @Html.DropDownListFor(m => m.Destination,
                                            new SelectList(new[] {
                                                new { Value = "", Text = "--Select--" },
                                                new { Value = "Domestic", Text = "Domestic" },
                                                new { Value = "International", Text = "International" },
                                                new { Value = "Both", Text = "Both" }
                                            }, "Value", "Text"),
                                            new { @class = "form-select", required = "required", id = "Destination" })
                                        </div>
                                    </div>
                                </div>

                                <!-- Buttons -->
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="submit" id="btnSubmit" class="btn btn-primary">
                                        <i class="fa-solid fa-floppy-disk me-1"></i> Submit
                                    </button>
                                    <a href="@Url.Action("GetList", "ESS_Logistic_CourierServiceProviders", new { area = "ESS" })" class="btn btn-danger">
                                        <i class="fa-solid fa-share-from-square me-1"></i> List
                                    </a>
                                </div>

                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $("#btnGetList").click(function () {
        window.location.href = '@Url.Action("GetList", "ESS_Logistic_CourierServiceProviders", new { area = "ESS" })';
    });

    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        $("#formReset").click(function () {
            $("#SaveCourierServiceProvider")[0].reset();
        });

    });//Ready Funcation
</script>

<script>

    function onlyNumbers(evt) {
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveCourierServiceProvider').validate({
        rules: {
            CourierServiceProviderName: {
                required: true,
            },
            MobileNo: {
            },
            EmailId:{
                email:true,
            },
            WhatappsNo: {
            },
            CourierType:{
                required:true,
            },
            Destination: {
                required:true,
            },
            Address: {
                required:true,
            },
        },
        messages: {
            CourierServiceProviderName: {
                required: "Courier Service Provider is required",
            },
            MobileNo: {
                minlength: "Please enter 10 digits Mobile No.",
                maxlength: "Please enter 10 digits Mobile No.",
            },
            EmailId: {
                email:"Please enter valid EmailId."
            },
            WhatappsNo: {
                minlength: "Please enter 10 digits WhatsApp no.",
                maxlength: "Please enter 10 digits WhatsApp no.",
            },
            CourierType:{
                required:"Parcel Type is required.",
            },
            Destination: {
                required:"Service Provider is required.",
            },
            Address: {
                required:"Address is required.",
            },
        },

        errorElement: "span",
        errorPlacement: function (error, element) {
            error.addClass("invalid-feedback");
            if (element.parent('.input-group').length) {
                error.insertAfter(element.parent());
            }
            else {
                error.insertAfter(element);
            }
        },
        highlight: function (element, errorClass, validClass) {
            $(element).addClass("is-invalid").removeClass("is-valid");
        },
        unhighlight: function (element, errorClass, validClass) {
            $(element).removeClass("is-invalid").addClass("is-valid");
        },
        submitHandler: function (form) {
            form.submit();
        }
    });

    var form = $("#SaveCourierServiceProvider");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var CourierServiceProvider=$("#txtCourierServiceProvider").val();
        var CourierServiceProviderID_Encrypted=$("#CourierServiceProviderID_Encrypted").val();
        var MobileNo=$("#txtMobileNo").val();
        var WhatappsNo=$("#txtWhatappsNo").val();
        var Email=$("#txtEmail").val();
        var CourierType=$("#ddlCourierType").val();
        var Destination=$("#ddlDestination").val();

        $.ajax({
            url:"IsCourierServiceProviderExists",
            method:"get",
            data:{CourierServiceProvider:CourierServiceProvider,
                CourierServiceProviderID_Encrypted:CourierServiceProviderID_Encrypted,
                MobileNo:MobileNo,
                WhatappsNo:WhatappsNo,
                Email:Email,
                CourierType:CourierType,
                Destination:Destination
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveCourierServiceProvider").submit();

                }
            }
        });
    });
</script>

