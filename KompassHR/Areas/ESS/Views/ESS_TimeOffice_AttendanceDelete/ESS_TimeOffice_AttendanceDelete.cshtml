@model KompassHR.Areas.ESS.Models.ESS_TimeOffice.EmployeeWiseAttendance
@{
    ViewBag.Title = "ESS_TimeOffice_AttendanceDelete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

