<script>
    function EmployeeDetails(tblRow) {
        debugger;
        var currentRow = $(tblRow).closest("tr");
        // var a = this.SetUpAddress;

        var MobileNo = currentRow.find("td:eq(11)").html();
        var HostEmployeeId = currentRow.find("td:eq(2)").html();
        var VisitorPurposeId = currentRow.find("td:eq(3)").html();
        var VisitorName = currentRow.find("td:eq(6)").html();
        var Designation = currentRow.find("td:eq(10)").html();
        var EmailID = currentRow.find("td:eq(12)").html();
        var CompanyName = currentRow.find("td:eq(13)").html();
        var VisitorAppointmentID = currentRow.find("td:eq(17)").html();
        var url = '@Url.Action("ESS_VMS_VisitorInformation", "ESS_VMS_VisitorInformation")?VisitorPurposeId=' + VisitorPurposeId + '&HostEmployeeId=' + HostEmployeeId + '&VisitorName=' + VisitorName + '&Designation=' + Designation + '&EmailID=' + EmailID + '&CompanyName=' + CompanyName + '&MobileNo=' + MobileNo + '&VisitorAppointmentID=' + VisitorAppointmentID;
        window.location.href = url;
    }

    function CheckOutVisitor(VisitorId_Encrypted) {
        var url = '@Url.Action("UpdateCheckOutVisitor", "ESS_VMS_VisitorInformation")?VisitorId_Encrypted=' + VisitorId_Encrypted;
        window.location.href = url;
    }
    function PrintInvoice(VisitorId_Encrypted) {
        var url = '@Url.Action("VisitorPassInvoice", "ESS_VMS_Menu")?VisitorId_Encrypted=' + VisitorId_Encrypted;
        window.location.href = url;
    }
</script>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>