                                    <div class="stats-title">Today Appointment</div>
                                    <div class="stats-number">
                                        <a href="@Url.Action("ESS_VMS_TodaysAppointment", "ESS_VMS_TodaysAppointment", new { area = "ESS" })" id="anchorApprovals" style="color:white;" onClick="Showdata('RECR03','Approvals pending with me')">
                                            @TempData["TodayAppointment"]
                                        </a>
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 40.5%;"></div>
                                    </div>
                                    <div class="stats-desc"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-sm-6" onClick="location.href='@Url.Action("ESS_VMS_VisitorEntry", "ESS_VMS_VisitorEntry", new { area = "ESS" })';" style="cursor: pointer;">
