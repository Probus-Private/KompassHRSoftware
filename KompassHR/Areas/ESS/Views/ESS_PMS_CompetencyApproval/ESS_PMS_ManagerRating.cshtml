
@{
    ViewBag.Title = "ESS_PMS_ManagerRating";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div id="content" class="app-content">
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Competency Manager Rating
            </h1>            <nav aria-label="breadcrumb">
                                 <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                                     <li style="margin-right: 10px;">
                                         <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                                             <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                                         </a>
                                     </li>
                                     <li>
                                         <a href="@Url.Action("ESS_PMS_CompetencyApproval", "ESS_PMS_CompetencyApproval", new { id = 11, ScreenId = 830, area = "ESS" })">
                                             <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                                         </a>
                                     </li>
                                 </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"];">
                    <h4 class="panel-title">Competency Manager Rating - @ViewBag.AddUpdateTitle</h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Rate the competency!
                    </p>
                </div>

                <div class="panel-body" style="padding: 1.5rem;">

                    @foreach (var d in ViewBag.GetList)
                    {
                        <form role="form"
                              class="competency-form"
                              id="ManagerRatingForm"
                              action="@Url.Action("SaveManagerRating", "ESS_PMS_MyCompetencies", new { area = "ESS" })"
                              method="post">

                            <!-- HIDDEN VALUES -->
                            <input type="hidden" name="CompetencyId" value="@d.CompetencyId" />
                            <input type="hidden" name="CompetencyMappingId" value="@d.CompetencyMappingId" />
                            <input type="hidden" name="EmployeeCompetencyId_Encrypted" value="@d.EmployeeCompetencyId_Encrypted" />
                            <input type="hidden" name="EmployeeCompetencyId" value="@d.EmployeeCompetencyId" />

                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <div class="card-custom shadow-sm"
                                         style="border:1px solid #ddd; padding:20px; border-radius:10px; background:#ffffff;">

                                        <h5 class="section-title mb-3"
                                            style="font-size:17px; font-weight:600; border-bottom:2px solid #eee; padding-bottom:5px;">
                                            Competency Details
                                        </h5>

                                        <div class="row mb-2">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">Competency Type</label>
                                                <p class="form-control-static">@d.CompetencyType</p>
                                            </div>

                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">Category</label>
                                                <p class="form-control-static">@d.Category</p>
                                            </div>

                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">Designation</label>
                                                <p class="form-control-static">@d.DesignationName</p>
                                            </div>
                                        </div>

                                        <div class="row mb-2">
                                            <div class="col-md-8">
                                                <label class="form-label fw-bold">Competency Name</label>
                                                <p class="form-control-static">@d.CompetencyName</p>
                                            </div>

                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">Weightage</label>
                                                <p class="form-control-static">@d.Weightage</p>
                                            </div>
                                        </div>

                                        <div class="row mb-3">
                                            <div class="col-md-12">
                                                <label class="form-label fw-bold">Description</label>
                                                <div style="background:#f5f7fa; padding:12px; border-radius:6px; border:1px solid #ddd;">
                                                    @Html.Raw(d.CompetencyDescription)
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- EMPLOYEE SELF RATING DETAILS -->
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <div class="card-custom shadow-sm"
                                         style="border:1px solid #ddd; padding:20px; border-radius:10px; background:#f9f9f9;">

                                        <h5 class="section-title mb-3"
                                            style="font-size:17px; font-weight:600; border-bottom:2px solid #eee; padding-bottom:5px;">
                                            Employee Self Rating
                                        </h5>

                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">Employee Rating (Out of @d.Weightage)</label>
                                                <input type="text" class="form-control" value="@d.SelfRating" readonly />
                                            </div>

                                            <div class="col-md-8">
                                                <label class="form-label fw-bold">Employee Remark</label>
                                                <textarea class="form-control" readonly rows="3">@d.Remark</textarea>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- MANAGER RATING SECTION -->
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <div class="card-custom shadow-sm"
                                         style="border:1px solid #ddd; padding:20px; border-radius:10px; background:white;">

                                        <h5 class="section-title mb-3"
                                            style="font-size:17px; font-weight:600; border-bottom:2px solid #eee; padding-bottom:5px;">
                                            Manager Rating
                                        </h5>

                                        <div class="row mb-3">
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">Manager Rating (Out of @d.Weightage)</label>
                                                <input type="number" class="form-control"
                                                       name="ManagerRating"
                                                       min="0"
                                                       max="@d.Weightage"
                                                       placeholder="Enter manager rating" />
                                                <small class="text-danger error-rating"></small>
                                            </div>

                                            <div class="col-md-8">
                                                <label class="form-label fw-bold">Manager Remark</label>
                                                <textarea class="form-control"
                                                          name="ManagerRemark"
                                                          rows="3"
                                                          placeholder="Enter manager remark..."></textarea>
                                                <small class="text-danger error-remark"></small>

                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- BUTTONS -->
                            @*<div class="row">
                                <div class="col-md-12 text-end">
                                    <div class="BtnBx mt-3">

                                        <button type="submit" class="btn btn-primary btn-sm px-3">
                                            <i class="fa-solid fa-floppy-disk"></i> Submit Review
                                        </button>

                                        <a href="@Url.Action("CompetencyListForManager", "ESS_PMS_MyCompetencies", new { area = "ESS" })"
                                           class="btn btn-secondary btn-sm px-3">
                                            <i class="fa-solid fa-list"></i> Back to List
                                        </a>

                                    </div>
                                </div>
                            </div>*@


                            <div class="row">
                                <div class="col-md-12 text-end">
                                    <div class="BtnBx" style="margin-top: 1rem;">
                                        <button type="submit" id="SubmitBtn" class="btn btn-primary btn-sm">
                                            <i class="fa-solid fa-floppy-disk"></i> Save
                                        </button>
                                        <a href="@Url.Action("CompetencyListForManager", "ESS_PMS_MyCompetencies", new { area = "ESS" })"
                                            class="btn btn-danger btn-sm px-3"> 
                                           <i class="fa-solid fa-list"></i> List </a>
                                       </div>
                                </div>
                            </div>

                        </form>
                    }

                </div>
            </div>
        </div>
    </div>
</div>



<script>
$(document).ready(function () {

    $(".competency-form").on("submit", function (e) {
        e.preventDefault();

        var form = $(this);

        // clear previous errors
        form.find(".error-rating").text("");
        form.find(".error-remark").text("");

        var managerRating = form.find("input[name='ManagerRating']").val();
        var managerRemark = form.find("textarea[name='ManagerRemark']").val();

        var isValid = true;

        // ✅ Rating validation
        if (managerRating === "" || managerRating === null) {
            form.find(".error-rating").text("Manager Rating is required.");
            isValid = false;
        }

        // ✅ Remark validation
        if (managerRemark.trim() === "") {
            form.find(".error-remark").text("Manager Remark is required.");
            isValid = false;
        }

        if (!isValid) {
            return false; // ⛔ stop here, no swal
        }

        // ✅ Confirmation Swal (ONLY confirmation)
        Swal.fire({
            title: "Are you sure?",
            text: "Once submitted, you will not be able to edit this rating.",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#1e3a8a",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, Save",
            cancelButtonText: "Cancel"
        }).then((result) => {

            if (result.isConfirmed) {

                var dataToSend = {
                    EmployeeCompetencyId_Encrypted: form.find("input[name='EmployeeCompetencyId_Encrypted']").val(),
                    ManagerRating: managerRating,
                    ManagerRemark: managerRemark,
                    EmployeeCompetencyId: form.find("input[name='EmployeeCompetencyId']").val()
                };

                $.ajax({
                    url: "/ESS/ESS_PMS_CompetencyApproval/SaveManagerRating",
                    type: "POST",
                    data: dataToSend,
                    success: function (res) {

                        Swal.fire({
                            title: res.msg,
                            icon: res.icon,
                            confirmButtonText: "OK"
                        }).then(function () {
                            window.location.href = "/ESS/ESS_PMS_CompetencyApproval/ESS_PMS_CompetencyApproval";
                        });

                    },
                    error: function () {
                        Swal.fire("Error", "Something went wrong.", "error");
                    }
                });
            }
        });
    });

});
</script>


