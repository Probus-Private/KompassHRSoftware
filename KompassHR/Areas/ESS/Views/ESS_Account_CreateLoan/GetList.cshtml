                                        <thead>
                                            <tr>
                                                <th class="text-nowrap width-45">Update</th>
                                                <th class="text-nowrap width-45">Delete</th>
                                                <th class="text-nowrap width-45">View Details</th>
                                                <th class="text-nowrap width-45">Settlement</th>
                                                <th class="text-nowrap">EmployeeName</th>
                                                <th class="text-nowrap">Loan Type</th>
                                                <th class="text-nowrap">Loan Amount</th>
                                                <th class="text-nowrap">Interest</th>
                                                <th class="text-nowrap">Interest Amount</th>
                                                <th class="text-nowrap">Total Loan Amount</th>
                                                <th class="text-nowrap">No Of Installment</th>
                                                <th class="text-nowrap">Monthly Deduction Amount</th>
                                                <th class="text-nowrap">DeducationStartDate</th>
                                                <th class="text-nowrap">GuarantorName</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetLoanList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button type="button" id="UpdateBtn"
                                                                onclick="UpdateLoan('@d.LoanID_Encrypted')"
                                                                class="btn btn-success btnpress ListBtn">
                                                            <i class="fa-solid fa-pencil-alt"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button" id="DeleteBtn"
                                                                onclick="DeleteLoan('@d.LoanID_Encrypted')"
                                                                class="btn btn-danger ListBtn btnpress">
                                                            <i class="fa-solid fa-trash-alt"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-primary ListBtn btnpress viewLoan"
                                                                data-id="@d.LoanID"
                                                                data-amount="@d.LoanAmount"
                                                                data-interest="@d.LoanInterest"
                                                                data-tenure="@d.NoOfInstallment"
                                                                data-emi="@d.MonthlyDeductionAmount">
                                                            <i class="fa-solid fa-eye"></i>
                                                        </button>

                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button" id="Settlement"
                                                                onclick="SetLoan('@d.LoanID_Encrypted')"
                                                                class="btn btn-success ListBtn btnpress">
                                                            <i class="fa-solid fa-arrows-rotate"></i>
                                                        </button>
                                                    </td>
                                                   <td>@d.EmployeeName</td>
                                                    <td>@d.LoanType</td>
                                                    <td>@d.LoanAmount    </td>
                                                    <td>@d.LoanInterest</td>
                                                    <td>@d.InterestAmount</td>
                                                    <td>@d.TotalLoanAmount</td>
                                                    <td>@d.NoOfInstallment</td>
                                                    <td>@d.MonthlyDeductionAmount  </td>
                                                    <td>@d.DeducationStartDate.ToString("yyyy-MM-dd")</td>
                                                    <td>@d.GuarantorName1</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

