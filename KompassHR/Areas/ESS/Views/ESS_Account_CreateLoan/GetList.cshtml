<script>
    function DeleteLoan(LoanID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Account_CreateLoan")?LoanID_Encrypted=' + LoanID_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    function UpdateLoan(LoanID_Encrypted) {
        debugger;
        var url = '@Url.Action("ESS_Account_CreateLoan", "ESS_Account_CreateLoan", new { area = "ESS" })' + '?LoanID_Encrypted=' + LoanID_Encrypted;
        window.location.href = url;
    }

    function SetLoan(LoanID_Encrypted) {
        debugger;
        var url = '@Url.Action("ESS_Account_LoanSettlement", "ESS_Account_LoanSettlement", new { area = "ESS" })' + '?LoanID_Encrypted=' + LoanID_Encrypted;
        window.location.href = url;
    }

</script>

<script>
   $(document).on("click", ".viewLoan", function () {
    var LoanId = $(this).data("id");
    var loanAmount = $(this).data("amount") || 0;
    var interestRate = $(this).data("interest") || 0;
    var tenure = $(this).data("tenure") || 0;
    var emi = $(this).data("emi") || 0;

    $("#lblLoanAmount").text("₹ " + Math.round(loanAmount).toLocaleString("en-IN"));
    $("#lblInterestRate").text(interestRate + " %");
    $("#lblTenure").text(tenure + " Months");
    $("#lblEMI").text("₹ " + Math.round(emi).toLocaleString("en-IN"));

    $.ajax({
        url: '@Url.Action("GetLoanDetails", "ESS_Account_CreateLoan", new { area = "ESS" })',
        type: "GET",
        data: { LoanId: LoanId },
        success: function (res) {
            debugger
            if (res.success) {
                var scheduleHtml = "";
                $.each(res.data, function (i, row) {
                    debugger
                    var month = getValue(row, "MonthYear") || "";
                    var emi = getValue(row, "MonthlyEMIAmount") || 0;
                    var status = getValue(row, "Status") || "Pending";

                    scheduleHtml += `<tr>
                <td>${month}</td>
                <td>₹ ${Math.round(emi).toLocaleString("en-IN")}</td>
                <td>${status}</td>
                <td></td>
            </tr>`;
                });
                $("#scheduleTableBody").html(scheduleHtml);
                updateLoanSummaryCounts();

                var sidebar = new bootstrap.Offcanvas(document.getElementById("loanScheduleSidebar"));
                sidebar.show();

            }
        }

    });
});
    function updateLoanSummaryCounts() {
        let completed = 0, pending = 0, overdue = 0;

        $("#scheduleTableBody tr").each(function () {
            let status = $(this).find("td:eq(2)").text().trim(); // Status column
            if (status === "Paid" || status === "Settled") {
                completed++;
            } else if (status === "Pending") {
                pending++;
            } else if (status === "Overdue") {
                overdue++;
            }
        });

        $("#completedPayments").text(completed);
        $("#pendingPayments").text(pending);
        $("#overduePayments").text(overdue);
    }


</script>

<script>
    // Safe extractor for {Key, Value} array rows
    function getValue(row, key) {
        // Case 1: row is an array of {Key, Value}
        if (Array.isArray(row)) {
            for (var i = 0; i < row.length; i++) {
                if (row[i] && row[i].Key === key) {
                    return row[i].Value;
                }
            }
            return null;
        }

        // Case 2: row is already a plain object {MonthYear:'Apr-2026', ...}
        if (row && typeof row === 'object') {
            if (key in row) return row[key];
            // Case 3: object has numeric keys {0:{Key:'MonthYear',Value:'Apr-2026'}, ...}
            for (var prop in row) {
                if (row[prop] && row[prop].Key === key) {
                    return row[prop].Value;
                }
            }
        }
        return null;
    }
</script>
