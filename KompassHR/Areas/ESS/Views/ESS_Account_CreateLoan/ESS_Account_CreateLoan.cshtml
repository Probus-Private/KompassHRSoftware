        // Calculate the standard EMI based on the interest rate
        if (annualInterestRate > 0) {
            emi = (loanAmount * monthlyRate * Math.pow(1 + monthlyRate, months)) /
                  (Math.pow(1 + monthlyRate, months) - 1);
            emi = Math.round(emi);
        } else {
            // 0% Interest: EMI is Principal / Months (rounded)
            emi = Math.round(loanAmount / months);
            totalInterest = 0;
        }

        // Variable to hold the final (potentially adjusted) EMI for the summary
        var finalEmi = emi;

        // Loop to generate the repayment schedule
        for (var m = 1; m <= months; m++) {
            var interest = 0;
            var principal = 0;
            var currentEmi = emi; // Start with the standard EMI

            if (annualInterestRate > 0) {
                // Calculation for interest-bearing loan
                interest = Math.round(balance * monthlyRate);
                principal = emi - interest;
            } else {
                // Calculation for 0% interest loan
                interest = 0;
                principal = emi;
            }

            // --- 🎯 CORE FIX: ADJUST LAST PAYMENT ---
            if (m === months) {
                // For the last payment, the principal must be exactly the remaining balance
                principal = balance;
                currentEmi = principal + interest; // The final EMI is adjusted here
                finalEmi = currentEmi; // Update finalEmi for summary display
                balance = 0;
            } else {
                // Update balance for non-final months
                balance = balance - principal;
            }
            // Ensure non-final principal doesn't exceed balance and round balance
            balance = Math.round(Math.max(0, balance));
            // ----------------------------------------

            // Recalculate total interest paid (only applicable if > 0% rate)
            totalInterest += interest;

            scheduleHtml += `<tr>
                                 <td><strong>${m}</strong></td>
                                 <td>₹ ${currentEmi.toLocaleString("en-IN")}</td>
                                 <td class="text-danger">₹ ${interest.toLocaleString("en-IN")}</td>
                                 <td class="text-success">₹ ${principal.toLocaleString("en-IN")}</td>
                                 <td><strong>₹ ${balance.toLocaleString("en-IN")}</strong></td>
                              </tr>`;
        }

        // Calculate totals based on the loan amount and calculated interest
        var totalPayment = loanAmount + totalInterest;

        // Update summary fields
        $("#lblLoanAmount").text("₹ " + loanAmount.toLocaleString("en-IN"));
        $("#lblInterestRate").text((annualInterestRate * 100).toFixed(2) + " %");
        $("#lblTenure").text(months + " Months");
        // Use the adjusted 'finalEmi' in the summary here, if you want the schedule's EMI to be accurate
        $("#lblEMI").text("₹ " + finalEmi.toLocaleString("en-IN"));
        $("#lblTotalInterest").text("₹ " + totalInterest.toLocaleString("en-IN"));
        $("#lblTotalPayment").text("₹ " + totalPayment.toLocaleString("en-IN"));

        // Fill schedule table
        $("#scheduleTableBody").html(scheduleHtml);
    });
</script>








