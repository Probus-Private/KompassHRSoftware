<script>
    function calculateLoan() {
        let P = parseFloat($("#txtLoanAmount").val()) || 0;
        let annualRate = parseFloat($("#txtLoanInterest").val()) || 0;
        let n = parseInt($("#txtNoOfInstallment").val()) || 0;

        if (P <= 0 || n <= 0) {
            $("#txtInterestAmount, #txtTotalLoanAmount, #txtMonthlyDeductionAmount").val("");
            return;
        }

        let r = (annualRate / 100) / 12; // monthly rate
        let emi = 0, totalPayable = 0, interestAmount = 0;

        if (annualRate > 0) {
            emi = (P * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
            totalPayable = emi * n;
            interestAmount = totalPayable - P;
        } else {
            emi = P / n;
            totalPayable = P;
            interestAmount = 0;
        }

        emi = Math.round(emi);
        totalPayable = Math.round(totalPayable);
        interestAmount = Math.round(interestAmount);

        $("#txtMonthlyDeductionAmount").val(emi);
        $("#txtTotalLoanAmount").val(totalPayable);
        $("#txtInterestAmount").val(interestAmount);
    }

    $(document).ready(function () {
        // Trigger calc on input
        $("#txtLoanAmount, #txtLoanInterest, #txtNoOfInstallment").on("input", calculateLoan);

        // Auto-calc on page load (useful for edit case)
        calculateLoan();

        // Make calculated fields readonly
        $("#txtMonthlyDeductionAmount, #txtInterestAmount, #txtTotalLoanAmount")
            .prop("readonly", true)
            .css("background-color", "#eee");
    });
</script>

