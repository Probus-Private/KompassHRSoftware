
@{
    ViewBag.Title = "ESS_VMS_Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .col-md-1-5 {
        width: 12.45%;
    }

    .box {
        width: 130px;
        height: 130px;
        backdrop-filter: blur(25px) saturate(00%);
        background-color: rgba(255, 255, 255, 1);
        border-radius: 12px;
        border: 3px solid rgba(255, 255, 255, 1);
        margin: 5px;
        box-shadow: inset 0 15px 25px rgba(0, 0, 0, 0.03), inset 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
        padding: 25px 0px;
        font-family: 'Montserrat', sans-serif;
        position: relative;
        z-index: 0;
    }

        .box:hover {
            /* BORDER:2PX SOLID #666; */
            border: 2px solid #007bff;
            cursor: pointer;
            transform: translateY(-4px);
        }


        .box .info i {
            font-size: 22px;
            width: 100%;
            text-align: center;
            margin-bottom: 15px;
            color: #007bff;
        }

        .box :hover.INFO i,
        .box:hover .info h7 {
            COLOR: #000;
        }

        .box .info h7 {
            font-size: 12px;
            text-align: center;
            display: flex;
            justify-content: center;
            font-weight: 900 !important;
            text-transform: capitalize;
            margin-bottom: 2px;
            padding: 0 10px;
            color: #444;
        }

    .Col-md-2 {
        margin: 10px 0;
    }



    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }


    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 100px; /* Set the width for the first column */
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                VMS Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_VMS_Menu", "ESS_VMS_Menu",  new { id = 10,ScreenId=184, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Menu</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Generate and view various reports on visitor statistics, check-in/check-out trends, and other relevant data.
                    </p>
                </div>
                <div class="panel-body" style="max-height: fit-content;">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle " id="tblSelectAllCheckbox"
                                           style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th class="text-nowrap text-center">Action</th>
                                                <th class="text-nowrap">Report Name</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetUserMenuList)
                                            {
                                                <tr>
                                                    <td class="text-center" style="vertical-align: middle;">
                                                        <a href="@Url.Action(d.ViewName.ToString(), d.ControllerName.ToString(), new { area = d.AreaName.ToString(), id = d.ModuleID, ScreenId = d.ScreenId })"
                                                           style="text-decoration: none;">
                                                            <img src="@Url.Content("~/assets/MenuImages/Report.png")" alt="Report" style="width: 30px; height: auto; cursor: pointer; display: inline-block;" />
                                                        </a>
                                                    </td>
                                                    <td class="text-left">@d.ScreenDisplayMenuName</td>

                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            @*<div class="row">
                                    @foreach (var item in ViewBag.GetUserMenuList)
                                    {
                                        <div class="col-md-1-5 col-6 d-flex ">
                                            <div class="box">
                                                <a href="@item.ScreenUrl" style="text-decoration:none !important;">
                                                    <div class="info">
                                                        <i class="@item.Icon"></i>
                                                        <h7><b>@item.ScreenDisplayMenuName</b></h7>
                                                    </div>
                                                </a>
                                            </div>
                                        </div>
                                    }
                                </div>*@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        var MenuId = sessionStorage.getItem("GetModuleId");
    });
</script>
