<script>
    $(document).ready(function () {
        // Loop through all items
        $("[id^=hiddenPhoto1_]").each(function () {
            debugger
            const postId = this.id.split("_")[1];

            // Load all photos for the post (1, 2, 3)
            LoadBase64ImageOnLoad(postId, 1);
            LoadBase64ImageOnLoad(postId, 2);
            LoadBase64ImageOnLoad(postId, 3);
        });
    });

    function LoadBase64ImageOnLoad(postId, photoNum) {
        debugger
        const photoPath = $("#hiddenPhoto" + photoNum + "_" + postId).val();
        const targetImg = $("#photo" + photoNum + "_" + postId);

        if (!photoPath || photoPath === "") {
            targetImg.hide();
            return;
        }

        $.ajax({
            url: '/ESS/ESS_Marketplace_MarketplaceGallery/GetBase64Image',
            type: 'GET',
            data: { photoPath: photoPath },
            success: function (response) {
                if (response.success) {
                    targetImg.attr("src", response.base64Image).show();
                } else {
                    targetImg.hide();
                }
            },
            error: function () {
                targetImg.hide();
            }
        });
    }
</script>

<script>
    document.querySelectorAll('.carousel').forEach(function (carouselEl) {
        new bootstrap.Carousel(carouselEl, {
            interval: 3000,
            touch: true
        });
    });
</script>

<script>
    function toggleReadMore(postId) {
        var shortDesc = document.getElementById('shortDesc_' + postId);
        var fullDesc = document.getElementById('fullDesc_' + postId);
        if (shortDesc.style.display === 'none') {
            shortDesc.style.display = 'inline';
            fullDesc.style.display = 'none';
        } else {
            shortDesc.style.display = 'none';
            fullDesc.style.display = 'inline';
        }
    }
</script>