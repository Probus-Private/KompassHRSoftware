            /* Fix border overlap for rowspan/colspan */
            #fixed-header thead th[rowspan], #fixed-header thead th[colspan] {
                border: 1px solid #dee2e6; /* Ensure rowspan/colspan cells have borders */
                position: sticky; /* Ensure rowspan cells are sticky */
            }

        /* Prevent gaps between header rows */
        #fixed-header thead tr {
            background-color: #f8f9fa; /* Match th background */
        }

        /* Ensure non-first-column headers are not obscured */
        #fixed-header thead th:not(:first-child) {
            z-index: 35; /* Above tbody but below first column */
            background-color: #f8f9fa; /* Ensure consistent background */
        }

        /* Allow columns to size based on content, with a minimum */
        #fixed-header th:not(:first-child), #fixed-header td:not(:first-child) {
