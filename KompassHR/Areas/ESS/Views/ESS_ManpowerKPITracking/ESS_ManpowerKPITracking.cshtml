    }

    /* Container for the table with proper scrolling */
    .table-container {
        max-height: 700px; /* Set desired height for vertical scroll */
        width: 100%;
        overflow-x: auto; /* Enable horizontal scrolling */
        overflow-y: auto; /* Enable vertical scrolling */
        position: sticky; /* Ensure z-index context for sticky elements */
        z-index: 0; /* Base z-index for container */
    }

    /* Table styling */
    #fixed-header {
        width: 100%;
        border-collapse: separate; /* Use collapse for better rowspan/colspan handling */
        background-color: #fff; /* Solid background to prevent gaps */
        table-layout: auto; /* Let columns size based on content */
    }

        /* Fix all th elements in thead for vertical scrolling */
        #fixed-header thead th {
            position: sticky;
            top: 0; /* Initial top, will be overridden by JavaScript */
            background-color: #f8f9fa; /* Light background for header */
            z-index: 35; /* Above tbody and below first column */
            border: 1px solid #dee2e6; /* Consistent borders */
            padding: 8px;
            text-align: center;
            box-sizing: border-box;
            background-clip: padding-box; /* Prevent background bleed */
        }

        #fixed-header .th-zindex {
            z-index: 55 !important;
        }

        /* Fix first column in thead */
        #fixed-header thead th:first-child {
            position: sticky;
            left: 0;
            z-index: 40; /* Highest z-index to stay above all other cells */
            background-color: #f8f9fa; /* Match thead background */
