            min-width: 200px; /* Match thead first column width */
            box-shadow: 2px 0 4px rgba(0, 0, 0, 0.1); /* Subtle shadow for sticky effect */
        }

        /* Ensure table-primary first column matches background */
        #fixed-header tr.table-primary td {
