<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Function to set dynamic top positions for header rows
        function setHeaderTopPositions() {
            const table = document.querySelector('#fixed-header');
            if (!table) return; // Exit if table not found

            const headerRows = table.querySelectorAll('thead tr');
            if (headerRows.length === 0) return;

            let cumulativeHeight = 0;

            headerRows.forEach((row, index) => {
                const thElements = row.querySelectorAll('th');
                thElements.forEach(th => {
                    th.style.top = `${cumulativeHeight}px`;
                    th.style.zIndex = index === 0 ? 40 : 35; // Highest z-index for first row
                });
                cumulativeHeight += row.getBoundingClientRect().height;
            });

            // Force reflow to ensure sticky positioning
            table.style.display = 'none';
            table.offsetHeight; // Trigger reflow
            table.style.display = '';
        }

        // Run on page load with a delay
        setTimeout(setHeaderTopPositions, 100);

        // Re-run when tab is shown
        const kpiSheetTab = document.querySelector('a[href="#KPI-Sheet"]');
        if (kpiSheetTab) {
            kpiSheetTab.addEventListener('shown.bs.tab', () => {
                setTimeout(setHeaderTopPositions, 300); // Delay for tab content rendering
            });
        }

        // Re-run on window resize
        window.addEventListener('resize', () => setTimeout(setHeaderTopPositions, 100));
    });
</script>

















