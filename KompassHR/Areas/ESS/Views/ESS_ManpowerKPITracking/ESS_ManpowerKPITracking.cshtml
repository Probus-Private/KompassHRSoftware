        }

        /* Ensure table cells align properly */
        #fixed-header th, #fixed-header td {
            text-align: center;
            padding: 8px;
            border: 1px solid #dee2e6; /* Match Bootstrap table-bordered */
            box-sizing: border-box;
            vertical-align: middle; /* Center content vertically */
        }

        /* Table body background to prevent white lines */
        #fixed-header tbody {
            background-color: #fff; /* Solid background for body */
