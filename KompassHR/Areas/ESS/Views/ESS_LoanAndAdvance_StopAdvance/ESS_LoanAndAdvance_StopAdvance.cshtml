<script>
    $(document).ready(function () {
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlAdvanceEmployeeID").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.toggle('animate__headShake', true);
                    setTimeout(() => popup.classList.toggle('animate__headShake', false), 500);
                    return false;
                }
            }).then(() => location.reload());
        }


        $("#ddlCmpId").on("change", function () {
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_LoanAndAdvance_Advance")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })


        $("#ddlBranchId").on("change", function () {
            debugger
            $("#ddlAdvanceEmployeeID").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetEmployeeName", "ESS_LoanAndAdvance_StopAdvance")',
                data: { BranchId: BranchId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlAdvanceEmployeeID").append("<option value=''>--Select--</option>");
                        $.each(data, function(i, p) {
                            $("#ddlAdvanceEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
        $('.TablePageEarning').DataTable({
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
        });

    });//Ready Funcation


    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveStopAdvance").validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            MonthYear: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },

            BranchID: {
                required: "Business unit  is required",
            },
            MonthYear: {
                required: "Month year  is required",
            },
        }
    });

    var form = $("#SaveStopAdvance");
    form.validate();
    $("#btnShow").click(function () {
        if(form.valid()==false)
        {
            $("#dateMonthYear").removeClass('error');
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#SaveStopAdvance").submit();
    });
</script>

<script>
    var form = $("#SaveStopAdvance");
    form.validate();
    function funSave() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
        }
        //$("#SelectAll").prop("checked", false);
        var CmpId = $("#ddlCmpId").val();
        var BranchID = $("#ddlBranchId").val();
        var MonthYear = $("#dateMonthYear").val();

        var Obj_Bulk = [];
        $('#tblEmployeeListOther :checkbox:checked').each(function () {
            var row = $(this).closest('tr'); // Get the closest row
            var data = {
                StopAdvanceEmployeeID: row.find('td').eq(1).text(), // Hidden column
                AdvanceId: row.find('td').eq(2).text(), // Hidden column
                Remark: row.find('td').eq(6).find('input').val(),
            };

            // Push the data object to the array
            Obj_Bulk.push(data);
        });
        //  return false;
        if (Obj_Bulk.length==0)
        {
            var Message="Select atleast one employee";
            var Icon="error";
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)

                            return false
                        }
                    })
                    return false;
                }
            }
        }
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: '@Url.Action("IsStopAdvanceExists", "ESS_LoanAndAdvance_StopAdvance")',
            data: JSON.stringify({ Obj_Bulk: Obj_Bulk, CmpId: CmpId, MonthYear: MonthYear,BranchID:BranchID }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1=="error")
                {
                    $(".Userloaderbg").css("display", "none");
                    if (data != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                        // location.reload();
                    }
                }
                else
                {
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("SaveUpdate", "ESS_LoanAndAdvance_StopAdvance")',
                        data: JSON.stringify({ Obj_Bulk: Obj_Bulk, CmpId: CmpId, MonthYear: MonthYear,BranchID:BranchID }),
                        contentType: "application/json; charset=utf-8",
                        dataType: "text",
                        success: function (response) {
                            debugger;
                            var data = JSON.parse(response);
                            var Message1 = data.Message;
                            var Icon1 = data.Icon;
                            if (Icon1=="error")
                            {
                                $(".Userloaderbg").css("display", "none");
                                if (data != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        });
                                    }
                                    // location.reload();
                                }
                            }
                            else
                            {
                                if (data != null) {
                                    if (Message1 != null) {
                                        Swal.fire({
                                            icon: Icon1,
                                            text: Message1,
                                            allowOutsideClick: () => {
                                                const popup = Swal.getPopup()
                                                popup.classList.remove('swal2-show')
                                                setTimeout(() => {
                                                    popup.classList.add('animate__animated', 'animate__headShake')
                                                })
                                                setTimeout(() => {
                                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                                }, 500)
                                                return false
                                            }
                                        }).then((result) => {
                                            if (result.isConfirmed) {
                                                window.location.href = '@Url.Action("ESS_LoanAndAdvance_StopAdvance", "ESS_LoanAndAdvance_StopAdvance")';
                                            } else if (
                                                /* Read more about handling dismissals below */
                                                result.dismiss === Swal.DismissReason.cancel
                                            ) {

                                            }
                                        })
                                    }
                                    // location.reload();
                                }
                            }
                        }
                    });
                }


            }
        });

    }


    $("#btnApply").click(function () {
        debugger;
        //For  Remark============================================================
        var tableRemark=  $("#txttableRemark").val();
        if(tableRemark!="")
        {
            $("#txttableRemark").val();
        }
        else{
            var txtRemark=$("#txtRemark").val();
            $(".Remarktxt").val(txtRemark);
            $("#txtRemark").val("");
        }


    })
</script>
