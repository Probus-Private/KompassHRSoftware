<script>
    function AssignTaskDesc(encodedHtml) {
        $('#txtTaskStatus').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtTaskStatus').html(AssignDesc);
            //$('#txtTaskStatus').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#' + modalId).modal('hide');
    }
</script>

<script>
    $(document).ready(function () {
        $('title').html("TMS Pending Request List");
    })
    function ViewTaskForApprover(DocID_Encrypted, EmployeeId, Type) {
        debugger
        var url = '@Url.Action("ViewForTMSRequestApprover", "ESS_TMS_Approval")?DocID_Encrypted=' + DocID_Encrypted + '&EmployeeId=' + EmployeeId + '&Type=' + Type;
        window.location.href = url;
    }

    function ViewTimeSheetForApprover(DocID_Encrypted, EmployeeId, Type) {
        debugger
        var url = '@Url.Action("ViewForTimeSheetRequestApprover", "ESS_TMS_Approval")?DocID_Encrypted=' + DocID_Encrypted + '&EmployeeId=' + EmployeeId + '&Type=' + Type;
        window.location.href = url;
    }

    var Resource = "";
    var ResourceEncrypted = "";

    function OpenModule() {
        debugger;
        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");

            data.DocID = currentRow.find("td:eq(0)").html();
            data.DocId_Encrypted = currentRow.find("td:eq(1)").html();
            data.Origin = currentRow.find("td:eq(4)").html();
            //data.Status = Status;
            //data.RejectRemark = RejectRemark;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            // $("#myModalFinal").modal('hide');
            //document.getElementById("txtApproveRejectRemark").value = "";
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: false
            });
            return false;
        }

        $("#myModalFinal").modal('show');
    }

    function Approved(ResourceId, ResourceId_Encrypted) {
        debugger
        var DocId = "";
        var Encrypted = "";
        var Status = "";
        if (ResourceId_Encrypted != undefined) {
            DocId = ResourceId;
            Encrypted = ResourceId_Encrypted;
            Status = "Approved";
        }
        else {
            DocId = Resource;
            Encrypted = ResourceEncrypted;
            Status = "Rejected";
        }
        var Remark = "";
        if (Status == "Rejected") {
            Remark = $("#txtApproveRejectRemark").val();
        }

        $.ajax({
            url: "@Url.Action("ForApprovalCandidate", "ESS_Recruitment_Menu")",
            method: "get",
            data: { DocId: DocId, Encrypted: Encrypted, Status: Status, Remark: Remark },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });

                            $("#myModalFinal").modal('hide');
                            $("#txtApproveRejectRemark").val("");
                            location.reload();
                        }
                    }
                }
                else {
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon == "success") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                                $("#myModalFinal").modal('hide');
                                $("#txtApproveRejectRemark").val("");
                                location.reload();
                            }
                        }
                    }
                }
            }
        });
    }
</script>


<script>
    function AllApproveReject(Status) {
        debugger;
        var RejectRemark = document.getElementById("txtApproveRejectRemark").value;
        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");

            data.DocID = currentRow.find("td:eq(0)").html();
            data.DocId_Encrypted = currentRow.find("td:eq(1)").html();
            data.Origin = currentRow.find("td:eq(4)").html();;
            data.Status = Status;
            data.RejectRemark = RejectRemark;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            $("#myModalFinal").modal('hide');
            document.getElementById("txtApproveRejectRemark").value = "";
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }

        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: "@Url.Action("MultipleApproveRejectRequest", "ESS_TMS_Approval")",
            data: JSON.stringify({ ObjRecordList: RecordList }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("ESS_TMS_Approval", "ESS_TMS_Approval")';
                        window.location.href = url;
                    });
                }

                @*var url = '@Url.Action("Inbox", "Inbox")';
                window.location.href = url;*@
            }
        });
    }

    //Select All Checkboxes
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>
