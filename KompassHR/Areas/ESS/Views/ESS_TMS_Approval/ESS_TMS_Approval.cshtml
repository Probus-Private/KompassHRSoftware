
@{
    ViewBag.Title = "ESS_TMS_Approval";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    th:nth-child(4), td:nth-child(4) {
        width: 20px; /* Set the width for the first column */
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Approval Request
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_Menu", "ESS_TMS_Menu",  new { id = 12,ScreenId=194, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Approval Request - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of positions authorised by manager.
                    </p>
                </div>


                <div class="panel-body">
                    <div class="row">
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage3" id="data-table-combine" style="width: 100%;">
                                    <thead>
                                        <tr class="trheading text-center">
                                            @*<th hidden>Not Work</th>*@
                                            <th hidden>DocId</th>
                                            <th hidden>DocId_Encrypted</th>
                                            <th style="text-align: center; justify-content: center;">ALL <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                            <th class="fixed-side text-center">View</th>
                                            <th class="text-nowrap">Type</th>
                                            <th class="text-nowrap">Doc No. </th>
                                            <th class="text-nowrap">Doc Date </th>
                                            <th class="text-start text-nowrap">Employee Name</th>
                                            <th class="text-nowrap">Client Name </th>
                                            <th class="text-nowrap">Project Name </th>
                                            <th class="text-nowrap">Module Name </th>
                                            <th class="text-nowrap">Task Category </th>
                                            <th class="text-nowrap">Task SubCategory </th>
                                            <th class="text-nowrap">Task Title </th>
                                            <th class="text-nowrap">Task Description </th>
                                            <th class="text-nowrap">Date </th>
                                            <th class="text-nowrap">Task Time </th>
                                            <th class="text-nowrap">Task Status </th>
                                            @*<th class="text-nowrap">Complete Percentage </th>*@
                                            <th class="text-nowrap">Work Task File </th>
                                        </tr>
                                    </thead>
                                    <tbody id="tbodyApproveReject">
                                        @foreach (var d in ViewBag.TMSApprovalList)
                                        {
                                            <tr>
                                                @*<th hidden>Not Work</th>*@
                                                <td hidden>@d.DocId</td>
                                                <td hidden>@d.DocId_Encrypted</td>
                                                <td>
                                                    <span class="d-flex justify-content-center">
                                                        <input type="checkbox" class="form-check-input" data-checked="email-checkbox" value="@d.DocId_Encrypted" id="tblCheckbox">
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    @if (d.Type == "Task")
                                                    {
                                                        <a onclick="ViewTaskForApprover('@d.DocId_Encrypted','@d.EmployeeId','@d.Type')" style="cursor:pointer;">
                                                            <i class="fa-solid fa-eye fa-lg text-danger"></i>
                                                        </a>
                                                    }
                                                    else if (d.Type == "TimeSheet")
                                                    {
                                                        <a onclick="ViewTimeSheetForApprover('@d.DocId_Encrypted','@d.EmployeeId','@d.Type')" style="cursor:pointer;">
                                                            <i class="fa-solid fa-eye fa-lg text-danger"></i>
                                                        </a>
                                                    }
                                                </td>
                                                <td class="text-nowrap">@d.Type</td>
                                                <td class="text-nowrap">@d.DocNo</td>
                                                <td class="text-nowrap">@d.DocDate</td>
                                                <td class="text-start text-nowrap">@d.EmployeeName</td>
                                                <td class="text-nowrap">@d.ClientName</td>
                                                <td class="text-nowrap">@d.ProjectName</td>
                                                <td class="text-nowrap">@d.ModuleName</td>
                                                <td class="text-nowrap">@d.TaskCategoryName</td>
                                                <td class="text-nowrap">@d.TaskSubCategoryName</td>
                                                <td class="text-nowrap">@d.TaskTitle</td>
                                                <td class="text-start text-center">
                                                    <input type="hidden" id="hiddenDescription_@d.Type" value="@d.TaskDescription" />
                                                    <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.Type').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                </td>
                                                <td class="text-nowrap">@d.ForDate</td>
                                                <td class="text-nowrap">@d.ForTime</td>
                                                <td class="text-center">@d.TaskStatus</td>
                                                @*<td class="text-center">@d.CompletePercentage</td>*@
                                                <td class="text-center">
                                                    @if (@d.AssignFilePath != "")
                                                    {
                                                        <a href="@Url.Action("DownloadAttachment","ESS_TMS_Approval", new { DownloadAttachment = @d.AssignFilePath })"><i class="fa fa-download"></i></a>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-xmark" style="color: red;"></i>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="row mb-20px">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" class="btn btn-primary btn-sm" id="btnAllApprove" onclick="AllApproveReject('Approved')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Approve
                                                </button>

                                                <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" type="button" class="btn btn-success btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>

                                                @*<button type="button" class="btn btn-danger " id="btnAllApprove" onclick="AllApproveReject('Rejected')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Reject
                                                    </button>*@

                                                <a href="@Url.Action("TMSApprovedRejectedList", "ESS_TMS_Approval", new { area = "ESS" })">
                                                    <button type="submit" id="btnManualUpload" class="btn btn-danger btn-sm">
                                                        Approved Rejected List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>

    </div>
</div>

<!-- #Start Appprove Reject Modal -dialog -->
