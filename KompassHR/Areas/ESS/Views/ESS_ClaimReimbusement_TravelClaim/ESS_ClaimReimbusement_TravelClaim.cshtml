<script>
    function ResetFile(Origin) {
        debugger
        var a = Origin; // Correct concatenation

        let allowedExtension = [
            'image/jpeg',
            'image/jpg',
            'image/png',
            'application/pdf',
            'application/msword', // .doc
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document', // .docx
            'application/zip', // .zip
            'application/x-zip-compressed', // Some browsers use this for ZIP
            'multipart/x-zip' // Additional MIME type for ZIP
        ];

        let maxSize = 1 * 1024 * 1024; // 1 MB in bytes

        let fileInput = document.getElementById(a);

        if (!fileInput || !fileInput.files.length) {
            Swal.fire({
                icon: "error",
                text: "No file selected.",
            });
            return;
        }

        let file = fileInput.files[0];
        let type = file.type;
        let size = file.size;

        // Check file type
        if (allowedExtension.indexOf(type) === -1) {
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf/docx/doc/zip",
            });
            fileInput.value = null;
            return;
        }

        // Check file size
        if (size > maxSize) {
            Swal.fire({
                icon: "error",
                text: "File size should not exceed 1 MB.",
            });
            fileInput.value = null;
            return;
        }
    }
</script>

<script>
    document.querySelectorAll(".file-validation").forEach(function (input) {
        input.addEventListener("change", function () {
            const allowedTypes = [
                "image/jpeg",
                "image/jpg",
                "image/png",
                "application/pdf"
            ];
            const file = this.files[0];
            if (file && !allowedTypes.includes(file.type)) {
                Swal.fire({
                    text: 'Only Images and PDF files are allowed!',
                    icon: 'error',
                    allowOutsideClick: false
                });
                this.value = ""; // reset file input
            }
        });
    });

</script>



<script>
    $(document).ready(function () {

        $("#TravelClaimEmployeeId").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(function() {
                window.location.reload();
            });
        }


        $("#ddlTravelType").change(function () {
            debugger;
            var TravelType = $('select#ddlTravelType option:selected').text();
            if(TravelType=="Two Wheeler")
            {
                $('#txtTotalKMAmount').attr('readonly', false);
                $('#txtTotalKMAmount').css('background-color', '');
                $('#txtTotalKMAmount').val(0);
                $('#txtTotalKM').val(0);
                $('#txtTransportTicketAmount').val(0);
                $('#txtFoodAmount').val(0);
                $('#txtHotelLodgingAmount').val(0);
                $('#txtConveyanceRemark').val("");
                $('#txtConveyance').val(0);
                $('#txtOtherARemark').val("");
                $('#txtOtherA').val(0);
                $('#txtOtherBRemark').val("");
                $('#txtOtherB').val(0);
                $('#txtTotalAmount').val(0);

            }
            else if( TravelType=="Four Wheeler" )
            {
                $('#txtTotalKMAmount').val(0);
                $('#txtTotalKM').val(0);
                $('#txtTransportTicketAmount').val(0);
                $('#txtFoodAmount').val(0);
                $('#txtHotelLodgingAmount').val(0);
                $('#txtConveyanceRemark').val("");
                $('#txtConveyance').val(0);
                $('#txtOtherARemark').val("");
                $('#txtOtherA').val(0);
                $('#txtOtherBRemark').val("");
                $('#txtOtherB').val(0);
                $('#txtTotalAmount').val(0);
                $('#txtTotalKMAmount').attr('readonly', false);
                $('#txtTotalKMAmount').css('background-color', '');
            }
            else if( TravelType=="Public Transport")
            {
                $('#txtTotalKMAmount').attr('readonly', false);
                $('#txtTotalKMAmount').css('background-color', '');
                $('#txtTotalKMAmount').val(0);
                $('#txtTotalKM').val(0);
                $('#txtTransportTicketAmount').val(0);
                $('#txtFoodAmount').val(0);
                $('#txtHotelLodgingAmount').val(0);
                $('#txtConveyanceRemark').val("");
                $('#txtConveyance').val(0);
                $('#txtOtherARemark').val("");
                $('#txtOtherA').val(0);
                $('#txtOtherBRemark').val("");
                $('#txtOtherB').val(0);
                $('#txtTotalAmount').val("0");
            }

            $.ajax({
                async: true,
                type: 'GET',
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                url: '@Url.Action("GetTravelRate", "ESS_ClaimReimbusement_TravelClaim")',
                data: { TravelType: TravelType },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        $("#txtPerKMRate").val(data.data);
                    }
                },
            });
        })



        $("#txtTotalKMAmount,#txtTotalKM,#txtTransportTicketAmount,#txtFoodAmount,#txtHotelLodgingAmount,#txtConveyance,#txtOtherA,#txtOtherB").keyup(function (e) {
            debugger;

            $("#ErrortxtTotalKMAmount").html("");
            // var TotalAmount = $("#txtTotalAmount").val(AllTotal);
            var PerKMRate = Number($("#txtPerKMRate").val());
            var TotalKMAmount = Number($("#txtTotalKMAmount").val());
            var TotakKMRate = PerKMRate * TotalKMAmount;
            $("#txtTotalKM").val(TotakKMRate);

            var TotalKM = Number($("#txtTotalKM").val());
            var TransportTicketAmount = Number($("#txtTransportTicketAmount").val());
            var FoodAmount = Number($("#txtFoodAmount").val());
            var HotelLodgingAmount = Number($("#txtHotelLodgingAmount").val());
            var LocalConveyanceAmount = Number($("#txtConveyance").val());
            var Other1Amount = Number($("#txtOtherA").val());
            var Other2Amount = Number($("#txtOtherB").val());

            var AllTotal = TotalKM + TransportTicketAmount + FoodAmount + HotelLodgingAmount + LocalConveyanceAmount + Other1Amount + Other2Amount;
            var AllTotalRoundUp = Math.round(AllTotal);
            $("#txtTotalAmount").val(AllTotalRoundUp);
        });

        $("#formReset").click(function () {
            $("#FormTravelClaim")[0].reset()
        });
    });

    var date = new Date();
    var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
    $("#VoucherDate").val(dateString);
    $("#FromDate").val(dateString);
    $("#ToDate").val(dateString);


    function NotificationFunction(TravelClaimId_Encrypted) {
        debugger;
        $.ajax({
            type: "Get",
            url: '@Url.Action("GetContactDetails", "ESS_ClaimReimbusement_TravelClaim")',
            data: { TravelClaimId_Encrypted: TravelClaimId_Encrypted},
            dataType: "text",
            success: function (data) {
                debugger;
                var datas = JSON.parse(data);
                if (datas.data.length != 0)
                {
                    var Getdata = datas.data[0];
                    $('#lblManager1Name').html(Getdata[0].Value);
                    $('#lblManager1EmailId').html(Getdata[1].Value);
                    $('#lblManager1Mobile').html(Getdata[2].Value);

                    $('#lblManager2Name').html(Getdata[3].Value);
                    $('#lblManager2EmailId').html(Getdata[4].Value);
                    $('#lblManager2Mobile').html(Getdata[5].Value);

                    $('#lblHRName').html(Getdata[6].Value);
                    $('#lblHREmailId').html(Getdata[7].Value);
                    $('#lblHRMobile').html(Getdata[8].Value);

                    if (Getdata[9] == undefined)
                    {
                        $('#DivAccount').hide();
                    }
                    else
                    {
                        $('#DivAccount').show();
                        $('#lblAcName').html(Getdata[9].Value);
                        $('#lblAcEmailId').html(Getdata[10].Value);
                        $('#lblAcMobile').html(Getdata[11].Value);
                    }
                    $('#NotificationModalPopUp').modal('show');
                }
            }
        });
    }

