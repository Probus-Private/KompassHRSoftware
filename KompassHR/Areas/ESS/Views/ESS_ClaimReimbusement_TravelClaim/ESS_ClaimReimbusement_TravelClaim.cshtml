    .fixed-side1 {
        position: sticky;
        left: 62px;
    }*/

    /*TeamBX Css*/
    .teambx {
        border: 1px solid gray;
        padding: 10px;
        position: relative;
        display: flex;
        align-items: center;
        margin: 10px 5px;
        border-radius: 10px;
    }

        .teambx .teamheading {
            position: absolute;
            right: 0px;
            bottom: 5px;
            padding: 5px 15px;
            width: fit-content;
            border-radius: 20px 0px 0px 20px;
            background: #000;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 900;
        }

        .teambx .teamname {
            font-size: 16px;
            font-weight: 800;
            border-bottom: 1px solid lightgray;
            margin-bottom: 8px;
        }

    .teamname i {
        margin-right: 0 10px !important;
    }

    .teamcontactBx {
        font-size: 14px;
        text-align: left;
        font-weight: 600;
    }

        .teamcontactBx i {
            margin: 0 5px;
        }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Conveyance Claim
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ClaimReimbusement_Menu", "ESS_ClaimReimbusement_Menu", new {id = 8, ScreenId=172, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">

                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Conveyance Claim - Add</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Claim your travel expenses here!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form action="@Url.Action("SaveUpdate", "ESS_ClaimReimbusement_TravelClaim" , new { area = "ESS" })"  id="FormTravelClaim" method="post" enctype="multipart/form-data">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.VoucherNo, new { @class = "form-control", @id = "txtVoucherNo", Value = @TempData["TravelClaimId"], Readonly = "true", Style = "background-color: #eee;" })
                                                @Html.HiddenFor(model => model.TravelClaimId_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.VoucherDate, new { @name = "VoucherDate", @class = "form-control", @id = "VoucherDate", @type = "date", Readonly = "true", Style = "background-color: #eee;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                @*<div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-2">
                                                    Employee Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-10">
                                                    @Html.DropDownListFor(model => model.TravelClaimEmployeeId, new SelectList("", "Id", "Name"), "--Select--", new { id = "TravelClaimEmployeeId", @class = "form-control", name = "TravelClaimEmployeeId", type = "text" })
                                                    @Html.DropDownListFor(model => model.TravelClaimEmployeeId, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "--Select--", new { id = "TravelClaimEmployeeId", @class = "form-control", name = "TravelClaimEmployeeId", type = "text" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>*@
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Travel Type <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.TravelType, new SelectList(ViewBag.VehicleType, "Id", "Name"), "--Select--", new { name = "TravelType", id = "ddlTravelType", @class = "form-select", autocomplete = "off" })
                                                @*@Html.DropDownListFor(model => model.TravelType, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Two Wheeler", Value = "Two Wheeler"},
                                                    new SelectListItem { Text = "Four Wheeler", Value = "Four Wheeler"},
                                                    new SelectListItem { Text ="Public Transport",Value="Public Transport"}
                                                }, "--Select--", new { @id = "ddlTravelType", @class = "form-select", autocomplete = "off", name = "TravelType" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Per KM Rate
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PerKMRate, new { @class = "form-control", @id = "txtPerKMRate", autocomplete = "off", type = "number", @readonly = "readonly", Style = "background-color: #eee;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", @id = "FromDate", @type = "date" })
                                                <span class="Error" id="ErrorFromDate"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", @id = "ToDate", @type = "date" })
                                                <span class="Error" id="ErrorToDate"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Location <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.FromLocation, new { @class = "form-control", @id = "txtFromLocation", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Location
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.ToLocation, new { @class = "form-control", @id = "txtToLocation", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.Description, new { @class = "form-control", @rows = "2", @id = "txtDescription" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Travel Purpose <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.ClaimTravelPurposeId, new SelectList(ViewBag.ClaimTravelPurpose, "Id", "Name"), "--Select--", new { id = "ddlClaimTravelPurposeId", name = "ClaimTravelPurposeId", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <hr>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Total KM<span class="important">*</span>
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.TotalKM, new { @class = "form-control", @id = "txtTotalKMAmount", autocomplete = "off", @Value = "0", Readonly = "true", Style = "background-color: #e9ecef; text-align:right", type = "text" , onkeypress = " return numbervalidate(event)" })
                                                <span id="ErrortxtTotalKMAmount" class="Error"></span>
                                            </div>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.TotalKMAmount, new { @class = "form-control", @id = "txtTotalKM", @Value = "0", Readonly = "true", Style = "background-color: #e9ecef; text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgTotalKM" class="form-control file-validation" accept="image/*,.pdf" id="ImgTotalKM" onchange="ResetFile('ImgTotalKM')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-6">
                                                Transport (Ticket) Amount
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.Transport, new { @class = "form-control", @id = "txtTransportTicketAmount", @Value = "0", type = "number", style = "text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgTransport" class="form-control file-validation" accept="image/*,.pdf" id="ImgTransport" onchange="ResetFile('ImgTransport')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-6">
                                                Food Amount
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.Food, new { @class = "form-control", @id = "txtFoodAmount", @Value = "0", type = "number", style = "text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgFood" class="form-control file-validation" accept="image/*,.pdf" id="ImgFood" onchange="ResetFile('ImgFood')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-6">
                                                Hotel Lodging Amount
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.Hotel, new { @class = "form-control", @id = "txtHotelLodgingAmount", @Value = "0", type = "number", style = "text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgHotel" class="form-control file-validation" accept="image/*,.pdf" id="ImgHotel" onchange="ResetFile('ImgHotel')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Local Conveyance
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.ConveyanceRemark, new { @class = "form-control", @id = "txtConveyanceRemark", @placeholder = "Please enter text" })
                                                <span id="ErrorConveyanceRemark" class="Error"></span>
                                            </div>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.Conveyance, new { @class = "form-control", @id = "txtConveyance", @Value = "0", type = "number", style = "text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgConveyance" class="form-control file-validation" accept="image/*,.pdf" id="ImgConveyance" onchange="ResetFile('ImgConveyance')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Other 1
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.OtherARemark, new { @class = "form-control", @id = "txtOtherARemark", @placeholder = "Please enter text" })
                                                <span id="ErrorOtherARemark" class="Error"></span>
                                            </div>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.OtherA, new { @class = "form-control", @id = "txtOtherA", @Value = "0", type = "number", style = "text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgOtherA" class="form-control file-validation" accept="image/*,.pdf" id="ImgOtherA" onchange="ResetFile('ImgOtherA')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Other2
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.OtherBRemark, new { @class = "form-control", @id = "txtOtherBRemark", @placeholder = "Please enter text" })
                                                <span id="ErrorOtherBRemark" class="Error"></span>
                                            </div>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.OtherB, new { @class = "form-control", @id = "txtOtherB", @Value = "0", type = "number", style = "text-align:right" })
                                            </div>
                                            <div class="col-md-3">
                                                <input type="file" name="ImgOtherB" class="form-control file-validation" accept="image/*,.pdf" id="ImgOtherB" onchange="ResetFile('ImgOtherB')"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                            </label>
                                            <label class="form-label col-form-label col-md-3">
                                                Total Amount
                                            </label>
                                            <div class="col-md-3">
                                                @Html.TextBoxFor(model => model.TotalAmount, new { @class = "form-control", type = "number", @id = "txtTotalAmount", Readonly = "true", @Value = "0", Style = "background-color: #e9ecef; text-align:right" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "ESS_ClaimReimbusement_TravelClaim" , new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnList">
                                                                <i class="fa-solid fa-share-from-square"></i>List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
