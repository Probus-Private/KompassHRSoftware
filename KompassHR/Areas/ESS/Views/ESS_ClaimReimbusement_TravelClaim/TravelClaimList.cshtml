
@{
    ViewBag.Title = "TravelClaimList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
</style>
<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "Dashboard" })">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("ESS_ClaimReimbusement_Menu", "ESS_ClaimReimbusement_Menu", new {id = 8, ScreenId= 172, area = "ESS" })">Claim Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Travel Claim</h1>
    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@Travel Claim - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of travel claim.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_ClaimReimbusement_TravelClaim", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add 
                                </button>
                            </a>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage"  id="tblClaim_Travel" style="width: 100%;">
                                        <thead>
                                            <tr class="trheading">
                                                @*<th class="fixed-side">Cancel</th>
                                                <th class="fixed-side">Delete</th>*@
                                                <th class="fixed-side1">Status</th>
                                                <th class="text-nowrap">Auto/Manually</th>
                                                <th class="text-nowrap text-center">Doc No</th>
                                                <th class="text-nowrap text-center">Doc Date</th>
                                                <th class="text-nowrap text-center">Travel Type</th>
                                                <th class="text-nowrap text-center">Per KM Rate</th>
                                                <th class="text-nowrap text-center">From Date</th>
                                                <th class="text-nowrap text-center">To Date</th>
                                                <th class="text-nowrap text-center">From Location</th>
                                                <th class="text-nowrap text-center">To Location</th>
                                                <th class="text-nowrap text-center">Travel Purpose</th>
                                                <th class="text-nowrap text-center">Description</th>
                                                <th class="text-nowrap text-center">TotalKM</th>
                                                <th class="text-nowrap text-center">Total KM Amount</th>
                                                <th class="text-nowrap text-center">Transport</th>
                                                <th class="text-nowrap text-center">Total KM Path</th>
                                                <th class="text-nowrap text-center">Transport Path</th>
                                                <th class="text-nowrap text-center">Food</th>
                                                <th class="text-nowrap text-center">FoodPath</th>
                                                <th class="text-nowrap text-center">Hotel</th>
                                                <th class="text-nowrap text-center">Hotel Path</th>
                                                <th class="text-nowrap text-center">Conveyance</th>
                                                <th class="text-nowrap text-center">Conveyance Remark</th>
                                                <th class="text-nowrap text-center">Conveyance Path</th>
                                                <th class="text-nowrap text-center">Other A</th>
                                                <th class="text-nowrap text-center">Other A Remark</th>
                                                <th class="text-nowrap text-center">Other A Path</th>
                                                <th class="text-nowrap text-center">Other B</th>
                                                <th class="text-nowrap text-center">Other B Remark</th>
                                                <th class="text-nowrap text-center">Other B Path</th>
                                                <th class="text-nowrap text-center">Total Amount</th>
                                                <th class="text-nowrap text-center">Approve Reject By</th>
                                                <th class="text-nowrap text-center">Approve Reject Date</th>
                                                <th class="text-nowrap text-center">Approve Reject Remark</th>
                                                <th class="text-nowrap text-center">Created By</th>
                                                <th class="text-nowrap text-center">Created Date</th>
                                                <th class="text-nowrap text-center">Modified By</th>
                                                <th class="text-nowrap text-center">Modified Date</th>
                                                <th class="text-nowrap text-center">Machine Name</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetClaim_TravelList)
                                            {
                                                <tr>
                                                    @*<td class="text-center fixed-side">
                                                        <button type="button" onclick="CancelFuncation('@d.TravelClaimId_Encrypted')" id="btnDelete"
                                                                class="btn btn-warning ListBtn btnpress">
                                                            <i class="fa fa-times"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-center fixed-side1">
                                                        <button type="button" onclick="DeleteTravelClaim('@d.TravelClaimId_Encrypted')" id="btnDelete"
                                                                class="btn btn-danger ListBtn btnpress">
                                                            <i class="fa-solid fa-trash-alt"></i>
                                                        </button>
                                                    </td>*@
                                                    <td class="text-nowrap text-center">@d.ApprovedDay</td>
                                                    <td class="text-nowrap">@d.AutoApproval</td>
                                                    <td class="text-nowrap" style="text-align:right">@d.VoucherNo</td>
                                                    <td class="text-nowrap">@d.VoucherDate</td>
                                                    <td class="text-nowrap">@d.TravelType</td>
                                                    <td class="text-nowrap" style="text-align:right">@d.PerKMRate</td>
                                                    <td class="text-nowrap">@d.FromDate</td>
                                                    <td class="text-nowrap">@d.ToDate</td>
                                                    <td class="text-nowrap">@d.FromLocation</td>
                                                    <td class="text-nowrap">@d.ToLocation</td>
                                                    <td class="text-nowrap">@d.TravelPurpose</td>
                                                    <td class="text-nowrap">@d.Description</td>
                                                    <td class="text-nowrap" style="text-align:right">@d.TotalKM</td>
                                                    <td class="text-nowrap" style="text-align:right">@d.TotalKMAmount</td>
                                                    <td class="text-nowrap" style="text-align:right">@d.Transport</td>
                                                    <td class="text-center">
                                                        @if (d.ConveyancePath == "File Not Found")
                                                        {
                                                            <span>@d.ConveyancePath</span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.TotalKMPath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (d.TransportPath == "File Not Found")
                                                        {
                                                            <span>@d.TransportPath </span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.TransportPath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap" style="text-align:right">@d.Food</td>
                                                    <td class="text-center">
                                                        @if (d.FoodPath == "File Not Found")
                                                        {
                                                            <span>@d.FoodPath </span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.FoodPath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap" style="text-align:right">@d.Hotel</td>
                                                    <td class="text-center">
                                                        @if (d.HotelPath == "File Not Found")
                                                        {
                                                            <span>@d.HotelPath </span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.HotelPath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap" style="text-align:right">@d.Conveyance</td>
                                                    <td class="text-nowrap">@d.ConveyanceRemark</td>
                                                    <td class="text-center">
                                                        @if (d.ConveyancePath == "File Not Found")
                                                        {
                                                            <span>@d.ConveyancePath </span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.ConveyancePath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap" style="text-align:right">@d.OtherA</td>
                                                    <td class="text-nowrap">@d.OtherARemark</td>
                                                    <td class="text-center">
                                                        @if (d.ConveyancePath == "File Not Found")
                                                        {
                                                            <span>@d.OtherAPath </span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.OtherAPath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap" style="text-align:right">@d.OtherB</td>
                                                    <td class="text-nowrap">@d.OtherBRemark</td>
                                                    <td class="text-center">
                                                        @if (d.OtherBPath == "File Not Found")
                                                        {
                                                            <span>@d.OtherBPath </span>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("DownloadFile", "ESS_ClaimReimbusement_TravelClaim", new { area = "ESS", filePath = @d.OtherBPath})" download>
                                                                <i class="fa-solid fa-download fa-xl"></i>
                                                            </a>
                                                        }
                                                    </td>
                                                    <td class="text-nowrap" style="text-align:right">@d.TotalAmount</td>
                                                    <td class="text-nowrap">@d.ApproveRejectBy</td>
                                                    <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                    <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                    <td class="text-nowrap">@d.CreatedBy</td>
                                                    <td class="text-nowrap">@d.CreatedDate</td>
                                                    <td class="text-nowrap">@d.ModifiedBy</td>
                                                    <td class="text-nowrap">@d.ModifiedDate</td>
                                                    <td class="text-nowrap">@d.MachineName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>




