                                                            <button type="button" data-bs-toggle="offcanvas"
                                                                    href="#offcanvasExample" id="btnActionList" onclick="ApprovalHistory('@d.TravelClaimId_Encrypted')" class="btn  btnpress ListBtn">
                                                                <i class="fa-solid fa-list"></i>
                                                            </button>
                                                        </td>*@
