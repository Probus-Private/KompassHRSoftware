<style>
    .timeline {
        max-width: 400px;
        background-color: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

        .timeline:before {
            left: 32px;
        }

    .timeline-item {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

    .iconGreen {
        width: 24px;
        height: 24px;
        background-color: green;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .iconRed {
        width: 24px;
        height: 24px;
        background-color: #ff5b57;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 15px;
    }

    .text {
        flex-grow: 1;
    }

        .text p {
            margin: 0;
            font-size: 14px;
        }

        .text small {
            color: gray;
            font-size: 12px;
        }

    .button {
        text-align: center;
        margin-top: 20px;
    }

        .button button {
            background-color: #a8d935;
            border: none;
            padding: 10px 20px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            border-radius: 5px;
        }

            .button button:hover {
                background-color: #8cc62f;
            }
</style>

<div class="modal fade" id="RequestInfoModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body-content" style="position: relative;">
                <div class="timeline">
                    <div class="panel-heading-btn" style="margin-top: -13px; position: absolute; right: 8px;" data-bs-dismiss="modal">
                        <a href="javascript:;" class="btn btn-icon btn-danger btnClear"
                           aria-hidden="true" id="CloseModel">
                            <i class="fa fa-xmark"></i>
