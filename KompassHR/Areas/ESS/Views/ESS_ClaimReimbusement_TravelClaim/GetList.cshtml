                                                                </a>
                                                            }
                                                           
                                                        </td>
                                                        <td class="text-nowrap" style="text-align:right">@d.Food</td>
                                                        <td class="text-center">
                                                            @if (d.FoodPath == "File Not Found")
                                                            {
                                                                <i class="fa-solid fa-xmark fa-xl" style="color: red;"></i>
                                                            }
                                                            else
                                                            {
                                                                <a href="#">
                                                                    <i class="fa fa-download fa-xl" onclick="DownloadFile('@d.FoodPath.Replace("\\", "/")')"></i>
                                                                </a>
                                                            }                                                            
                                                        </td>
                                                        <td class="text-nowrap" style="text-align:right">@d.Hotel</td>
                                                        <td class="text-center">
                                                            @if (d.HotelPath == "File Not Found")
                                                            {
                                                                <i class="fa-solid fa-xmark fa-xl" style="color: red;"></i>
                                                            }
                                                            else
                                                            {
                                                                <a href="#">
                                                                    <i class="fa fa-download fa-xl" onclick="DownloadFile('@d.HotelPath.Replace("\\", "/")')"></i>
                                                                </a>
                                                            }
                                                           
                                                        </td>
                                                        <td class="text-nowrap" style="text-align:right">@d.Conveyance</td>
                                                        <td class="text-nowrap">@d.ConveyanceRemark</td>
                                                        <td class="text-center">
                                                            @if (d.ConveyancePath == "File Not Found")
                                                            {
                                                                <i class="fa-solid fa-xmark fa-xl" style="color: red;"></i>
                                                            }
                                                            else
                                                            {
                                                                <a href="#">
                                                                    <i class="fa fa-download fa-xl" onclick="DownloadFile('@d.ConveyancePath.Replace("\\", "/")')"></i>
                                                                </a>
                                                            }

                                                          
                                                        </td>
                                                        <td class="text-nowrap" style="text-align:right">@d.OtherA</td>
                                                        <td class="text-nowrap">@d.OtherARemark</td>
                                                        <td class="text-center">
                                                            @if (d.OtherAPath == "File Not Found")
                                                            {
                                                                <i class="fa-solid fa-xmark fa-xl" style="color: red;"></i>
                                                            }
                                                            else
                                                            {
                                                                <a href="#">
                                                                    <i class="fa fa-download fa-xl" onclick="DownloadFile('@d.OtherAPath.Replace("\\", "/")')"></i>
                                                                </a>
                                                            }

                                                            
                                                        </td>
                                                        <td class="text-nowrap" style="text-align:right">@d.OtherB</td>
                                                        <td class="text-nowrap">@d.OtherBRemark</td>
                                                        <td class="text-center">
                                                            @if (d.OtherBPath == "File Not Found")
                                                            {
                                                                <i class="fa-solid fa-xmark fa-xl" style="color: red;"></i>
                                                            }
                                                            else
                                                            {
                                                                <a href="#">
                                                                    <i class="fa fa-download fa-xl" onclick="DownloadFile('@d.OtherBPath.Replace("\\", "/")')"></i>
                                                                </a>
                                                            }
                                                            
                                                        </td>
                                                        @*<td class="text-nowrap" style="text-align:right">@d.TotalAmount</td>*@
                                                        <td>@d.TotalAmount</td>
                                                        <td>@d.ApprovedAmount</td>

                                                        <td class="text-nowrap">@d.ApprovedByName</td>
                                                        <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                        <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                        <td class="text-nowrap">@d.CreatedBy</td>
                                                        <td class="text-nowrap">@d.CreatedDate</td>
                                                        <td class="text-nowrap">@d.ModifiedBy</td>
                                                        <td class="text-nowrap">@d.ModifiedDate</td>
                                                        <td class="text-nowrap">@d.MachineName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- END panel -->
                    </div>
                </div>
            </div>
        </div>
    </div>


</body>
</html>


