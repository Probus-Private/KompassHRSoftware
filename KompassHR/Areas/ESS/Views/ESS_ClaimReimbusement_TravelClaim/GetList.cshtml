<script>
    function SendCancelRequest() {
        var ddlManagerName = $('select#ddlManagerName option:selected').val();
        if (!ddlManagerName) {
            $("#ErrorMessage").html("Please select approver name");
            $("#ddlManagerName").focus();
            return false;
        }
        $("#ErrorMessage").html("");

        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes Submit!',
            cancelButtonText: 'No, cancel!'
        }).then((result) => {
            if (result.isConfirmed) {
                var ClaimId = localStorage.getItem('TravelClaimId');
                var managerId = $("#ddlManagerName").val();
                var remark = $("#txtApproveRejectRemark").val();
                var origin = "TravelClaim";

                $("#CancelModal").modal('hide');
                $(".Userloaderbg").css("display", "flex");

                $.ajax({
                    url: '@Url.Action("CancelRequest", "ESS_ClaimReimbusement_TravelClaim")',
                    method: "GET",
                    data: { TravelClaimId: ClaimId, ddlManagerId: managerId, Remark: remark, Origin: origin },
                    success: function (response) {
                        Swal.fire({
                            icon: response.Icon,
                            text: response.Message
                        }).then(() => {
                            if (response.Icon === "success") {
                                window.location.href = '@Url.Action("GetList", "ESS_ClaimReimbusement_TravelClaim")';
                            }
                            $(".Userloaderbg").css("display","none");
                            $("#CancelModal").modal('hide');
                            $("#txtApproveRejectRemark").val("");
                        });
                    }
                });
            } else {
                $("#CancelModal").modal('hide');
                $("#ddlManagerName").val(null);
                $("#txtApproveRejectRemark").val("");
            }
        });
    }

</script>

<script>

    function DownloadFile(attachmentPath) {
        var correctedPath = attachmentPath.replace(/\//g, '\\');
        var url = '@Url.Action("DownloadAttachment", "ESS_ClaimReimbusement_TravelClaim")';

        $.ajax({
            url: url,
            type: 'POST',
            data: { DownloadAttachment: correctedPath },
            success: function (response) {
                debugger;
                if (response.Success) {
                    var fileName = response.FileName;
                    var fileData = atob(response.FileData);  // Decode the base64 string
                    var byteArray = new Uint8Array(fileData.length);
                    for (var i = 0; i < fileData.length; i++) {
                        byteArray[i] = fileData.charCodeAt(i);
                    }

                    var blob = new Blob([byteArray], { type: response.ContentType });
                    var downloadUrl = window.URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = downloadUrl;
                    a.download = fileName;
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                    window.URL.revokeObjectURL(downloadUrl);
                }
                else {
                    Swal.fire({
                        icon: response.Icon || 'error',
                        text: response.Message || 'An error occurred.',
                        allowOutsideClick: false
                    });
                }
            },
            error: function (xhr, status, error) {
                debugger
                Swal.fire({
                    icon: 'error',
                    text: 'An unexpected error occurred.',
                    allowOutsideClick: false
                });
            }
        });
    }

</script>


<script>

    function ApprovalHistory(TravelClaimId_Encrypted){
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetHistory", "ESS_ClaimReimbusement_TravelClaim")',
            data: { TravelClaimId_Encrypted:TravelClaimId_Encrypted },
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger
                
                if (response.ApprovalHistory && response.ApprovalHistory.length > 0) {          
                    debugger
                    $('#approvalHistoryContainer').empty();
                    let html = '<table class="table"><thead><tr><th>Property1</th><th>Property2</th></tr></thead><tbody>';               
                    $.each(response.ApprovalHistory, function (index, item) {                     
                        html += `<tr><td>${item.Property1 || 'N/A'}</td><td>${item.Property2 || 'N/A'}</td></tr>`;
                    });
                    html += '</tbody></table>';                    
                    $('#approvalHistoryContainer').html(html);
                } else {                  
                    $('#approvalHistoryContainer').html('<p>No approval history found.</p>');
                }
            },
            error: function (xhr, status, error) {              
                console.error('Error fetching approval history:', error);
                $('#approvalHistoryContainer').html('<p>Error loading approval history.</p>');
            }
        });
    }
</script>



<script>
    function ApproveStatus(DocId) {
        debugger
        $.ajax({
            url: '@Url.Action("RequestStatus", "ESS_ClaimReimbusement_TravelClaim")',
            method: "GET",
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            data: { DocId: DocId },
            success: function (response) {
                debugger
                $('#RequestInfoModal').modal('show');
                var data = JSON.parse(response);
                var timelineHtml = '';
                for (var i = 0; i < data.length; i++) {
                    var icon = '';
                    var iconColor='';
                    var textColor = '';
                    if (data[i][5].Value === 'success') {
                        icon = '✔';
                        iconColor ="iconGreen";
                        textColor = 'Green';
                    } else if (data[i][5].Value === 'error') {
                        icon = '✘';
                        iconColor ="iconRed";
                        textColor = 'Red';
                    } else {
                        icon = '⏳';
                        iconColor ="iconRed";
                        textColor = 'Black';
                    }

                    timelineHtml += '<div class="timeline-item">' +
                                '<div class="' + iconColor + '"><span class="timelineIcon">' + icon + '</span></div>' +
                                '<div class="text">' +
                                '<b><p class="timelineRemark" style="color:' + textColor + ';">' + data[i][2].Value + '</p></b>' +
                                '<small class="timelineEmployeeName" style="color:Black;">' + data[i][3].Value + '</small><br />' +
                                 '<small class="timelineDate" style="color:Black;">' + data[i][1].Value + '</small>' +
                                '</div>' +
                                '</div>';
                }
                $('#timelineMainDiv').html(timelineHtml);
            }
        });
    }

</script>