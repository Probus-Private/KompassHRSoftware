@model KompassHR.Areas.ESS.Models.ESS_ContractorAttendance.Mas_ContractorMapping
@{
    ViewBag.Title = "ESS_ContractorAttendance_ContractorMapping";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<!-- Required library for validation -->
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*.tblAddData td:nth-child(6), td:nth-child(7), td:nth-child(8), td:nth-child(9), td:nth-child(10) {
            text-align: center;
        }

        #tblUserRights td:nth-child(1) {
            display: none;
        }

        #tblUserRights td:nth-child(2) {
            display: none;
        }*/

    #tblContractorNameHead td:nth-child(2) {
        display: none;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 20px; /* Set the width for the first column */
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { area = "ESS" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("Setting_Contractor_Menu", "Setting_Contractor_Menu", new { id = 27, ScreenId=110,area = "Setting" })">Contractor Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Contractor Business Unit Mapping </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Contractor Business Unit Mapping - Add </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        User rights are determined by the sensitivity and criticality of the data or functions within the HRMS. For example, certain users may have read-only access, while others might have permission to modify or delete data. or Make any necessary adjustments or modifications if certain settings need to be customized for the target user.
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_ContractorAttendance_ContractorMapping", "ESS_ContractorAttendance_ContractorMapping", new { area = "ESS" })' id="SaveContractorMapping" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCmpId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.BranchID, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                                @Html.ValidationMessageFor(model => model.BranchID, "", new { @class = "help-block", id = "ErrorBranchID", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnshow" onclick="GetContractorMapping()">
                                                    Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-md-12">
                                        <!-- BEGIN table-responsive -->
                                        <div class="table-scroll">
                                            <div class="table-wrap">
                                                <table class="table table-bordered align-middle" id="tblContractorNameHead"
                                                       style="width: 100%;">
                                                    <thead class="text-center" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                        <tr>
                                                            <th class="fixed-side text-center">Select</th>
                                                            <th hidden class="fixed-side text-center">ContractorId</th>
                                                            <th class="fixed-side1 text-center">Contractor Name</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblContractorNamebody">
                                                        @foreach (var d in ViewBag.ContractorName)
                                                        {
                                                            <tr>

                                                                <td class="text-center">
                                                                    <input type="checkbox" id="txtContractorIdId" class="chk chkContractorId" Value="@d.Id" />
                                                                </td>
                                                                <td class="text-nowrap">@d.Id</td>
                                                                <td class="text-nowrap">@d.Name</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                    Submit
                                                </button>
                                                <a href="@Url.Action("GetList", "ESS_ContractorAttendance_ContractorMapping", new { area = "ESS" })">
                                                    <button type="button" class="btn btn-danger btn-sm" id="btnGetUserAccessPolicyList">
                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                    </button>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_ContractorAttendance_ContractorMapping")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        //var data1 = data.data;
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
        $('#tblContractorNameHead').DataTable({
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
            stripeClasses: [] // Disable alternating row colors
        });
        //$('#tblContractorNameHead').DataTable({
        //    scrollY: 300,
        //    scrollCollapse: true,
        //    paging: false,
        //    scrollX: true,
        //    searching: true, // Enable searching
        //});

        var ContractorMappingList = @Html.Raw(Json.Encode(ViewBag.GetContractorMappingList));
        debugger;
        if (ContractorMappingList != null) {
            var table = document.getElementById("tblContractorNamebody");
            var rowCount = table.rows.length;
            for (i = 0; i < rowCount; i++) {
                var TableDepartmentId = Number(table.rows[i].cells[1].innerHTML);
                var UpdatedepartmentId = Number(ContractorMappingList[i][1].Value);
                var CheckboxValue = Number(ContractorMappingList[i][0].Value);
                var chk = document.querySelectorAll('.chk');
                if (TableDepartmentId === UpdatedepartmentId && CheckboxValue === 1) {
                    var achk = chk[i];
                    achk.checked = true;
                }
            }
        }


    });//Ready Funcation


    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );
    $('#SaveContractorMapping').validate({
        rules: {
            CmpId: {
                required: true,
            },
            //BranchId: {
            //    required: true,
            //},
        },
        messages: {
            CmpId: {
                required: "Company name  is required"
            },
            //KPICategoryBranchId: {
            //    BranchId: "Business unit is required"
            //},
        },
    });

    var form = $("#SaveContractorMapping");
    form.validate();

    function GetContractorMapping() {
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        var BranchId = $("#ddlBranchId").val();
        if(BranchId=="")
        {
            $("#ErrorBranchID").html("Select business unit");return false;
        }else{$("#ErrorBranchID").html("");}
        $(".Userloaderbg").css("display", "flex");
        $("#SaveContractorMapping").submit();
    }






    $("#btnSubmit").click(function () {
        debugger;

        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        if(BranchId=="")
        {
            $("#ErrorBranchID").html("Select business unit");return false;
        }else{$("#ErrorBranchID").html("");}
        var Record = [];
        $(':checkbox:checked').each(function (i) {
            debugger;
            var data1 = {};
            data1.ContractorId = $(this).val();
            Record.push(data1);
        });
        debugger;
        if (Record == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one contractor",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            async: true,
            type: "POST",
            url: '@Url.Action("SaveUpdate", "ESS_ContractorAttendance_ContractorMapping")',
            data: JSON.stringify({ BranchId: BranchId, CmpId: CmpId, Record: Record }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var Getdata = JSON.parse(response);
                var Message1 = Getdata.Message;
                var Icon1 = Getdata.Icon;
                if (Message1 != null) {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {

                            window.location.href = '@Url.Action("ESS_ContractorAttendance_ContractorMapping", "ESS_ContractorAttendance_ContractorMapping")';
                        } else if (
                            /* Read more about handling dismissals below */
                            result.dismiss === Swal.DismissReason.cancel
                        ) {

                        }
                    })
                }
            }
        });
    });
</script>
