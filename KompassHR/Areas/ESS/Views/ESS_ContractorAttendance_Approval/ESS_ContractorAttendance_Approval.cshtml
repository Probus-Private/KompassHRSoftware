<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Contractor Attendance Approval Request
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ContractorAttendance_Menu", "ESS_ContractorAttendance_Menu",  new { id = 27,ScreenId=333, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Contractor Attendance Approval Request - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        A "Contractor Attendance Approval Request" is a form or notification used to request the review and approval of a contractor's recorded attendance by the relevant authority.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="tblOutDoorList" style="width: 100%;">
                                    <thead>
                                        <tr class="trheading text-center">
                                            <th hidden>DocId</th>
                                            <th hidden>DocID_Encrypted</th>
                                            <th>
                                                ALL <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" />
                                            </th>
                                            <th class="text-nowrap text-center fixed-side">View</th>
                                            <th class="text-nowrap text-center">Employee Name</th>
                                            <th class="text-nowrap text-center">Origin</th>
                                            <th class="text-nowrap text-center">Type</th>
                                            <th class="text-nowrap text-center">Request date</th>
                                            <th class="text-nowrap text-center">Request Time</th>
                                            <th class="text-nowrap text-center">Pending Since</th>
                                            <th class="text-nowrap text-center">Reason</th>
                                            <th class="text-nowrap text-center">Total Duration</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tbodyApproveReject">
                                        @foreach (var d in ViewBag.WorkerForApprovalList)
                                        {
                                            <tr>
                                                <td hidden>@d.DocID</td>
                                                <td hidden>@d.DocID_Encrypted</td>
                                                <td style="width:10px">
                                                    <span class="d-flex justify-content-center">
                                                        <input type="checkbox" class="form-check-input" data-checked="email-checkbox" value="@d.DocID_Encrypted" id="tblCheckbox">
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <a id="btnUpdate" onclick="ViewForApprover('@d.DocID_Encrypted','@d.Origin')" style="cursor: pointer;">
                                                        <i class="fa-solid fa-eye text-warning fa-lg"></i>
                                                    </a>
                                                </td>
                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                <td class="text-center">@d.Origin</td>
                                                <td class="text-nowrap">@d.Type</td>
                                                <td class="text-nowrap">@d.RequestDate</td>
                                                <td class="text-nowrap">@d.RequestTime</td>
                                                <td class="text-center">@d.PendingScience</td>
                                                <td class="text-nowrap">@d.Reason</td>
                                                <td class="text-center">@d.TotalDuration</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="LastShortLeaveBx">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" class="btn btn-primary btn-sm" id="btnAllApprove" onclick="AllApproveReject('Approved')">
                                                <i class="fa-solid fa-floppy-disk"></i> Approve
                                            </button>

                                            @*<button type="button" class="btn btn-success " id="btnAllApprove" onclick="AllApproveReject('Rejected')">
                                                    <i class="fa-solid fa-floppy-disk"></i> Reject
                                                </button>*@
                                            <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" type="button" class="btn btn-success btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>

                                            <a href="/ESS/ESS_ContractorAttendance_Approval/ESS_ContractorAttendance_ApprovedRejectedList">
                                                <button class="btn btn-danger btn-sm" type="submit" id="btnManualUpload">
                                                    Approved Rejected List
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>

    </div>
</div>

<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Reject</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                       aria-hidden="true">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success " id="btnAllApprove" onclick="AllApproveReject('Rejected')">
                    <i class="fa-solid fa-floppy-disk"></i> Submit
                </button>

                @*<button type="button" onclick="Approved()" id="btnReject" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk"> </i> Submit
                    </button>*@

                <button type="button" id="btnCancel" class="btn btn-danger btnpress btnClear" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->

<script>
    function ViewForApprover(DocID_Encrypted, Origin) {
        debugger
        if (Origin == 'OD') {
            var url = '@Url.Action("ESS_ContractorAtten_ViewForOutdoorRequestApprover", "ESS_ContractorAttendance_Approval")?DocId_Encrypted=' + DocID_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'PM') {
            var url = '@Url.Action("ESS_ContractorAtten_ViewForPunchMissingRequestApprover", "ESS_ContractorAttendance_Approval")?DocId_Encrypted=' + DocID_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'PG') {
            var url = '@Url.Action("ESS_ContractorAtten_ViewForPersonalGetpassRequestApprover", "ESS_ContractorAttendance_Approval")?DocId_Encrypted=' + DocID_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'WFH') {
            var url = '@Url.Action("ESS_ContractorAtten_ViewForWorkFromHomeRequestApprover", "ESS_ContractorAttendance_Approval")?DocId_Encrypted=' + DocID_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'SL') {
            var url = '@Url.Action("ESS_ContractorAtten_ViewForShortLeaveRequestApprover", "ESS_ContractorAttendance_Approval")?DocId_Encrypted=' + DocID_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
        if (Origin == 'SC') {
            var url = '@Url.Action("ESS_ContractorAtten_ViewForShiftChangeRequestApprover", "ESS_ContractorAttendance_Approval")?DocId_Encrypted=' + DocID_Encrypted + '&Origin=' + Origin;
            window.location.href = url;
        }
    }
    var Resource = "";
    var ResourceEncrypted = "";
    function OpenModule() {
        debugger;
        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            debugger;
            var currentRow = $(this).closest("tr");
            data.DocID = currentRow[0].cells[0].innerText;
            data.DocID_Encrypted = currentRow.find("td:eq(1)").html();
            data.Origin = currentRow.find("td:eq(5)").html();
            data.Status = Status;
            data.RejectRemark = RejectRemark;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            //$("#myModalFinal").modal('hide');
            //document.getElementById("txtApproveRejectRemark").value = "";
            Swal.fire({
                icon: "error",
                text: "Select at least one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $("#myModalFinal").modal('show');
    }


    function Approved(ResourceId, ResourceId_Encrypted)
    {
        debugger
        var DocId = "";
        var Encrypted = "";
        var Status = "";
        if (ResourceId_Encrypted != undefined) {
            DocId = ResourceId;
            Encrypted = ResourceId_Encrypted;
            Status = "Approved";
        }
        else {
            DocId = Resource;
            Encrypted = ResourceEncrypted;
            Status = "Rejected";
        }
        var Remark = "";
        if (Status == "Rejected") {
            Remark = $("#txtApproveRejectRemark").val();
        }

        $.ajax({
            url: "@Url.Action("ForApprovalCandidate", "ESS_Recruitment_Menu")",
            method: "get",
            data: { DocId: DocId, Encrypted: Encrypted, Status: Status, Remark: Remark },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                            $(".Userloaderbg").css("display", "none");
                            $("#myModalFinal").modal('hide');
                            $("#txtApproveRejectRemark").val("");
                            location.reload();
                        }
                    }
                }
                else {
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon == "success") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                                $(".Userloaderbg").css("display", "none");
                                $("#myModalFinal").modal('hide');
                                $("#txtApproveRejectRemark").val("");
                                location.reload();
                            }
                        }
                    }
                }
            }
        });
    }
</script>

<script>
    function AllApproveReject(Status) {
        debugger;
        var RejectRemark = document.getElementById("txtApproveRejectRemark").value;
        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            debugger;
            var currentRow = $(this).closest("tr");
            data.DocID = currentRow[0].cells[0].innerText;
            data.DocID_Encrypted = currentRow.find("td:eq(1)").html();
            data.Origin = currentRow.find("td:eq(5)").html();
            data.Status = Status;
            data.RejectRemark = RejectRemark;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            $("#myModalFinal").modal('hide');
            document.getElementById("txtApproveRejectRemark").value = "";
            Swal.fire({
                icon: "error",
                text: "Select at least one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display", "flex");

        $.ajax({
            type: "POST",
            url: "@Url.Action("MultipleApproveRejectRequest", "ESS_ContractorAttendance_Approval")",
            //url: "MultipleApproveRejectRequest",
            data: JSON.stringify({ ObjRecordList: RecordList }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("ESS_ContractorAttendance_Approval", "ESS_ContractorAttendance_Approval")';
                        window.location.href = url;
                    });
                }
            }
        });
    }

    //Select All Checkboxes
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>