
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";


    //string TicketStatus = ViewBag.GetTicketRaiseList as string;

    //string OpenStatus = TicketStatus == "Open" ? "active" : "";
    //string InProcessStatus = TicketStatus == "In Process" ? "active" : "";
    //string CloseStatus = TicketStatus == "Close" ? "active" : "";

    //Open Count

    var ticketList = ViewBag.GetTicketRaiseList as IEnumerable<dynamic>;
    int TotalOpenTickets = 0;

    if (ticketList != null && ticketList.Any())
    {
        TotalOpenTickets = ticketList.First().TotalOpenTickets ?? 0;
    }

    //In Process Count

    var InProcessList = ViewBag.GetInProcessTicketRaiseList as IEnumerable<dynamic>;
    int TotalInProcessTickets = 0;

    if (InProcessList != null && InProcessList.Any())
    {

        TotalInProcessTickets = InProcessList.First().TotalInProcessTickets ?? 0;
    }

    //Close Count

    var CloseList = ViewBag.GetCloseTicketRaiseList as IEnumerable<dynamic>;
    int TotalCloseTickets = 0;

    if (CloseList != null && CloseList.Any())
    {

        TotalCloseTickets = CloseList.First().TotalCloseTickets ?? 0;
    }

    string TicketStatus = "Open"; // or however you determine active tab
    string OpenStatus = TicketStatus == "Open" ? "active" : "";
    string InProcessStatus = TicketStatus == "In Process" ? "active" : "";
    string CloseStatus = TicketStatus == "Close" ? "active" : "";


}

<style>
    .Tooltip {
