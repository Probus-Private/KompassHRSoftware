                                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                            </a>
                                                                        }
                                                                        else
                                                                        {
                                                                            <a title="Ticket is closed. You can't delete it."
                                                                               style="cursor:not-allowed; opacity:0.4; pointer-events:none;">
                                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                            </a>
                                                                        }
                                                                    </td>

                                                                    <td>@d.DocNo</td>
                                                                    <td>@d.DocDate</td>
                                                                    <td>@d.TicketCategoryName</td>
                                                                    <td>@d.TicketRaiseTitle</td>
                                                                    <td>@d.Description</td>

                                                                    @if (d.AttachFile != "No")
                                                                    {
                                                                        <td class="text-center">
                                                                            <a href="@Url.Action("DownloadAttachment","ESS_Ticket_TicketRaise", new { DownloadAttachment = @d.AttachFile })"><i class="fa fa-download"></i></a>
                                                                        </td>
                                                                    }

                                                                    else
                                                                    {
                                                                        <td>

                                                                            <div style="display:flex; justify-content:center; align-items:center;">
                                                                                <i class="fa fa-times" style="color:red;"></i>
                                                                            </div>

                                                                        </td>
                                                                    }

                                                                    <td>@d.Priority</td>
                                                                    <td>@d.TicketStatus</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>

                                                </div>
                                            </div>
                                        </div>
                                    </div>

                            
