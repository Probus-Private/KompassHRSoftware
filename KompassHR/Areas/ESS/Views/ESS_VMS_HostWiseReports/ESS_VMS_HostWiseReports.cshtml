<script>

    $(document).ready(function () {
        $("#ddlCompanyName").select2();
        $("#txtBusinessUnit").select2();
        $("#ddlEmployeeName").select2();
        $('title').html("Host Wise Reports");
        var CheckEmptyToDate = document.getElementById('txtToDate').value;
        if (CheckEmptyToDate == "") {
            document.getElementById('txtFromDate').value = SetTodaysDate;
            document.getElementById('txtToDate').value = SetTodaysDate;
        }
        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#txtBusinessUnit").empty();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_VMS_HostWiseReports")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#txtBusinessUnit").find("option").remove();
                        $("#txtBusinessUnit").append("<option value=''> All </option>");
                        $.each(data, function (i, p) {
                            $("#txtBusinessUnit").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#txtBusinessUnit").on("change", function () {
            var CmpId = $("#ddlCompanyName").val();
            var UnitBranchId = $("#txtBusinessUnit").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetUnit", "ESS_VMS_HostWiseReports")',
                data: { UnitBranchId: UnitBranchId, CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlEmployeeName").find("option").remove();
                        $("#ddlEmployeeName").append("<option value=''> All </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });

    });//ready function

    function downloadExcelFile() {
        debugger;
        //$(".Userloaderbg").css("display", "flex");
        //var CmpId = $("#ddlCompanyName").val();
        //var BranchId = $("#txtBusinessUnit").val();
        //var EmployeeId = $("#ddlEmployeeName").val();
        //var FromDate = $("#txtFromDate").val();
        //var ToDate = $("#txtToDate").val();
        //var url = '/ESS_VMS_HostWiseReports/DownloadExcelFile?BranchId=' + encodeURIComponent(BranchId) + '&FromDate=' + encodeURIComponent(FromDate) + '&CmpId=' + encodeURIComponent(CmpId) + '&ToDate=' + encodeURIComponent(ToDate) + '&EmployeeId=' + encodeURIComponent(EmployeeId);

        $(".Userloaderbg").css("display", "flex");
        var CmpId = encodeURIComponent($("#ddlCompanyName").val());
        var BranchId = encodeURIComponent($("#txtBusinessUnit").val());
        var DepartmentId = encodeURIComponent($("#ddlDepartmentName").val());
        var FromDate = encodeURIComponent($("#txtFromDate").val());
        var ToDate = encodeURIComponent($("#txtToDate").val());
        var url = `@Url.Action("DownloadExcelFile", "ESS_VMS_HostWiseReports")?BranchId=${BranchId}&CmpId=${CmpId}&DepartmentId=${DepartmentId}&FromDate=${FromDate}&ToDate=${ToDate}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function (data) {
                debugger;
                if (data.size == 0) {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertDateFormat(FromDate);
                var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'HostWiseReports(' + formattedDate + ' - ' + ToformattedDate + ').xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function (xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }

