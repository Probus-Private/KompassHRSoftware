                                            <div class="col-md-8">
                                                @Html.DropDownList("CompanyName", new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCompanyName" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownList("BusinessUnit", new SelectList(ViewBag.GetBusinessUnit, "Id", "Name"), "All", new { @class = "form-select", type = "text", name = "BusinessUnit", id = "txtBusinessUnit" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
