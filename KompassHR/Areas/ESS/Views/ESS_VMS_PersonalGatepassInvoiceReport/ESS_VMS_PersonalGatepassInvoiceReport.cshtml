@model KompassHR.Areas.ESS.Models.ESS_VMS.Visitor_Tra_Master.VisitorMasterInOutList
@{
    ViewBag.Title = "ESS_VMS_PersonalGatepassInvoiceReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Gatepass Invoice Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_VMS_Reports", "ESS_VMS_Reports",  new { id = 10,ScreenId=189, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="row">
                <div class="col-md-12">
                    <div class="panel panel-inverse" data-sortable-id="index-1">
                        <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                            <h4 class="panel-title">Gatepass Invoice Report </h4>
                            <div class="panel-heading-btn">
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                            </div>
                        </div>
                        <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                            <p class="pb-0">
                                This is the list of visitors, including those who have left.
                            </p>
                        </div>
                        <div class="panel-body">
                            <form role="form" action='@Url.Action("ESS_VMS_PersonalGatepassInvoiceReport", "ESS_VMS_PersonalGatepassInvoiceReport", new { area = "ESS" })' id="PersonalGatepassInvoiceReport">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                In Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.InDateTime, new { @class = "form-control", type = "date", id = "dateInDateTime", Name = "InDateTime" })
                                                @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtdateInDateTime", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Out Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.GateOutTime, new { @class = "form-control", type = "date", id = "dateGateOutTime", Name = "GateOutTime" })
                                                @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtdateGateOutTime", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div>
                                            <button type="button" id="btnshow" class="btn btn-primary btn-sm  mb-10px">
                                                <i class="fa-solid fa-eye"></i> &nbsp; Show
                                            </button>
                                            @*<a href="/ESS/ESS_VMS_VisitorEntry/ESS_VMS_VisitorEntry">
                                                    <button type="button" class="btn btn-success btnpress  mb-10px" style="margin-left:10px">
                                                        &nbsp;Back To Visitor Entry
                                                    </button>
                                                </a>*@
                                        </div>
                                    </div>

                                </div>
                            </form>
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine">
                                        <thead>
                                            <tr class="trheading">
                                                <th class="text-nowrap text-center">Print</th>
                                                <th class="text-nowrap text-center">Doc No</th>
                                                <th class="text-nowrap text-center">Appointment Date</th>
                                                <th class="text-nowrap text-center">In Time</th>
                                                <th class="text-nowrap text-center">Leaving Time</th>
                                                <th class="text-nowrap text-center">Visitor Name</th>
                                                <th class="text-nowrap text-center">MobileNo</th>
                                                <th class="text-nowrap text-center">Host Name</th>
                                                <th class="text-nowrap text-center">Department Name</th>
                                                <th class="text-nowrap text-center">Host Out Time</th>
                                                <th class="text-nowrap text-center">Badge No</th>
                                                <th class="text-nowrap text-center">Additional</th>
                                                <th class="text-nowrap text-center">Visitor InBy</th>
                                                <th class="text-nowrap text-center">Visitor OutBy</th>

                                            </tr>
                                        </thead>
                                        <tbody id="tblVisitorInOutList">
                                            @foreach (var d in ViewBag.VisitorList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button type="button" onclick="PrintInvoice('@d.VisitorId_Encrypted')"
                                                                class="btn  btnpress ListBtn" style="background-color:#fff;">
                                                            <i class="fa-solid fa-print"></i>
                                                        </button>
                                                    </td>
                                                    <td>@d.DocNo</td>
                                                    <td>@d.DocDate</td>
                                                    <td>@d.InDateTime</td>
                                                    <td>@d.GateOutTime</td>
                                                    <td>@d.VisitorName</td>
                                                    <td>@d.MobileNo</td>
                                                    <td>@d.HostName</td>
                                                    <td>@d.DepartmentName</td>
                                                    <td>@d.HostOutTime</td>
                                                    <td>@d.Batchno</td>
                                                    <td>@d.Additional</td>
                                                    <td>@d.VisitorInBy</td>
                                                    <td>@d.VisitorOutBy</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <!-- END table-responsive -->
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        var CheckEmptyDate = document.getElementById('dateInDateTime').value;
        if (CheckEmptyDate == "") {
            document.getElementById('dateInDateTime').value = SetTodaysDate;
            document.getElementById('dateGateOutTime').value = SetTodaysDate;

        }
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });

</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );
    $('#ListInOutVisitorList').validate({
        rules: {
            InDateTime: {
                required: true,
            },
            GateOutTime: {
                required: true,
            },
        },
        messages: {
            InDateTime: {
                required: "In date is required",
            },
            GateOutTime: {
                required: "Out date is required",
            },
        },
    });



    var form = $("#PersonalGatepassInvoiceReport");
    form.validate();
    $("#btnshow").click(function () {
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
            $("#dateInDateTime").removeClass('error');
            $("#dateGateOutTime").removeClass('error');
        }
        $(".Userloaderbg").css("display", "flex");
        $("#PersonalGatepassInvoiceReport").submit();
    });

    $("#dateInDateTime").change(function () {
        debugger;
        var StartDate = document.getElementById('dateInDateTime').value;
        var EndDate = document.getElementById('dateGateOutTime').value;
        var eDate = new Date(EndDate);
        var sDate = new Date(StartDate);
        if (StartDate != '' && EndDate != '' && sDate > eDate) {
            $("#ErrortxtdateInDateTime").html("From date should not be less than to date.");
        }
        else {
            $("#ErrortxtdateInDateTime").html("");
            $("#ErrortxtdateGateOutTime").html("");
        }
    });

    $("#dateGateOutTime").change(function () {
        debugger;
        var StartDate = document.getElementById('dateInDateTime').value;
        var EndDate = document.getElementById('dateGateOutTime').value;
        var eDate = new Date(EndDate);
        var sDate = new Date(StartDate);
        if (StartDate != '' && EndDate != '' && sDate > eDate) {
            $("#ErrortxtdateGateOutTime").html("To date should not be greater than from date.");
        }
        else {
            $("#ErrortxtdateGateOutTime").html("");
            $("#ErrortxtdateInDateTime").html("");
        }
    });

    function PrintInvoice(VisitorId_Encrypted ) {
        var url = '@Url.Action("VisitorPassInvoiceReport", "ESS_VMS_PersonalGatepassInvoiceReport")?VisitorId_Encrypted=' + VisitorId_Encrypted;
        window.location.href = url;
    }
</script>