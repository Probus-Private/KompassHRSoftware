@model KompassHR.Areas.ESS.Models.ESS_FineAndDamage.Payroll_Damage
@{
    ViewBag.Title = "ESS_FineAndDamage_Damage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->  
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="/ESS/ESS_WorkForce_Menu/ESS_WorkForce_Menu/?id=29">Fine & Penalty Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Damage Deduction  </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Damage Deduction - <b>@ViewBag.AddUpdateTitle</b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>               
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="/ESS/ESS_FineAndDamage_Damage/SaveUpdate" id="SaveDamage" method="post">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.                                               
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNo", type = "text", id = "txtDocNo", autocomplete = "Off", @readonly = "readonly", Value = @TempData["DocNo"], Style = "background-color: #eee;" })
                                                @Html.HiddenFor(model => model.DamageID_Encrypted, new { id = "DamageID_Encrypted" })
                                                @Html.HiddenFor(model => model.DamageID)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date                                             
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", type = "date", id = "dateDocDate", autocomplete = "Off", Name = "DocDate" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.DamageEmployeeID, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "--Select--", new { id = "ddlDamageEmployeeID", @class = "form-select", autocomplete = "off", name = "DamageEmployeeID" })

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Damage Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DamageName, new { @class = "form-control", type = "text", id = "txtDamageName", autocomplete = "Off", Name = "DamageName", @style = "text-align:Left" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Damage Amount
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DamageAmount, new { @class = "form-control", type = "number", onkeypress = " return numbervalidate(event)", id = "txtDamageAmount", autocomplete = "Off", Name = "DamageAmount", @style = "text-align:right" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Deduction Month
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DeductionInMonth, new { @class = "form-control", type = "date", id = "dateDeductionInMonth", autocomplete = "Off", Name = "DeductionInMonth" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Description
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.DamageDescription, new { @class = "form-control", type = "text", id = "txtDamageDescription", autocomplete = "Off", Name = "DamageDescription", @style = "text-align:Left" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">
                                                    Last Record :
                                                    <span>@ViewBag.LastRecored</span>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnDamageGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveDamage").validate({
        rules: {
            DocDate: {
                required: true,
            },
            DamageEmployeeID: {
                required: true,

            },
            DamageName: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
            DeductionInMonth: {
                required: true,
            },
            DamageAmount: {
                required: true,
                regex: /^[0-9]+$/,
            },

        },
        messages: {
            DocDate: {
                required: "Doc date is required",
            },
            DamageEmployeeID: {
                required: "Employee name is required",
            },
            DamageName: {
                required: "Damage name  is required",
            },
            DeductionInMonth: {
                required: "Deduction month is required",
            },
            DamageAmount: {
                required: "Damage amount is required",
                regex: "Enter olny alphabet.",
            },

        }
    });

    var form = $("#SaveDamage");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#dateDocDate").removeClass('error');
            $("#dateDeductionInMonth").removeClass('error');
            return false;
        }
        var DamageEmployeeID = $("#ddlDamageEmployeeID").val();
        var DeductionInMonth = $("#dateDeductionInMonth").val();
        var DamageID_Encrypted = $("#DamageID_Encrypted").val();

        $.ajax({
            url: "IsDamageExists",
            method:"Get",
            data: { DamageEmployeeID: DamageEmployeeID, DeductionInMonth: DeductionInMonth, DamageID_Encrypted: DamageID_Encrypted },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveDamage").submit();

                }
            }
        });

    });

    var date = new Date();
    var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
    $("#dateDocDate").val(dateString);
</script>

<script>
    $(document).ready(function () {
       debugger;
       $("#ddlDamageEmployeeID").select2();

     $("#btnDamageGetList").click(function () {
         debugger;
         var url = '@Url.Action("GetList", "ESS_FineAndDamage_Damage")';
         window.location.href = url;
     });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }

     var Doc = @Html.Raw(Json.Encode(TempData["DocDate"]));
     var DDate = @Html.Raw(Json.Encode(TempData["DeductionInMonth"]));
        if(Doc =="" ||DDate == "" || DDate == null || Doc ==null    )
     {

     }
     else
     {
         var DocDate =  convertDate(Doc);
         var DeducationMonth = convertDate(DDate);
         $("#dateDocDate").val(DocDate);
         $("#dateDeductionInMonth").val(DeducationMonth);

     }

     $("#formReset").click(function () {
         $("#SaveDamage")[0].reset()
     });
     var date = new Date();
     var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
     $("#dateDocDate").val(dateString);

 });//Ready Funcation
</script>

<script>
    function millisecTodate(milliDate) {
        var date = new Date(milliDate);
        var mnth = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var hours = date.getHours();
        var minutes = date.getMinutes();
        hours = hours < 10 ? '0'+hours : hours;
        minutes = minutes < 10 ? '0'+minutes : minutes;
        var ddmmyyyy = [date.getFullYear(), mnth,day].join("-");
        return ddmmyyyy;
    }

    function convertDate(data) {
        var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
        var date = millisecTodate(getdate);
        return date;
    }
</script>

<script>
    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>

