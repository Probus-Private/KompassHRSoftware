        debugger
        // Get the first input value
        let firstValue = document.querySelector('.rnt').value;

        // Get all inputs and apply the first value to all
        document.querySelectorAll('.rnt').forEach(input => {
            input.value = firstValue;
        });
        updateSum();
    }

    function updateSum() {
        debugger
        let sum = 0;
        document.querySelectorAll('.rnt').forEach(input => {
