<div id="content" class="app-content">

    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                House Rent Allowance
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Tax_InvestmentMenu", "ESS_Tax_InvestmentMenu", new {id = 9, ScreenId=176, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">  House Rent Allowance - <b>@ViewBag.AddUpdateTitle </b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add here house rent allowance.
                    </p>
                </div>
                <div class="panel-body" style="overflow: auto !important;">
                    <form role="form" action="@Url.Action("SaveUpdate", "ESS_Tax_Investment_HouseRental", new { area = "ESS" })" id="FormSaveChapterVI_A" method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="empbx">
                                    <span>
                                        <h5> <i class="fa-solid fa-calendar"></i> &nbsp;  Financial Year - @Session["TaxYear"]  </h5>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="row">
                            <div class="col-md-6">
                                <div class="empbx">
                                    @if (TempData["SubmitValid"] != null)
                                    {
                                        <span>
                                            <h5> <i class="fa-solid fa-lock-open"></i> &nbsp; Declaration Window - <span class="text-success">Open</span> </h5>
                                        </span>
                                    }
                                    else
                                    {
                                        <span>
                                            <h5> <i class="fa-solid fa-lock"></i>  &nbsp;  Declaration Window - <span class="text-danger">Close</span>  </h5>
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <hr />
                        <!-- BEGIN table-responsive -->
                        <table id="tblHouseRent" class="table table-striped table-bordered align-middle TablePageHRA">
                            <thead>
                                <tr>
                                    <th class="" colspan="7">
                                        <h5>House Rent Allowance</h5>
                                    </th>
                                </tr>
                                <tr style="background-color: rgba(233, 236, 239, 1) !important;">
                                    <th class="text-nowrap text-center">Month </th>
                                    <th class="text-nowrap text-center">Rent Amount <button type="button" onclick="applyAmtToAll()"><i class="fas fa-copy"></i></button></th>
                                    <th class="text-nowrap text-center">Metro / Non-Metro <button type="button" onclick="applyCityTypeToAll()"><i class="fas fa-copy"></i> </button></th>
                                    <th class="text-nowrap text-center">City Name <button type="button" onclick="applyCityToAll()"><i class="fas fa-copy"></i></button></th>
                                    <th class="text-nowrap text-center">Address <button type="button" onclick="applyAddressToAll()"><i class="fas fa-copy"></i></button></th>
                                    <th class="text-nowrap text-center">Landlord Name <button type="button" onclick="applyNameToAll()"><i class="fas fa-copy"></i></button></th>
                                    <th class="text-nowrap text-center">Landlord PAN <button type="button" onclick="applyPANToAll()"><i class="fas fa-copy"></i></button></th>
                                </tr>
                            </thead>
                            <tbody class="white-background">
                                <tr>
                                    <td><b>April</b></td>
                                    <td>
                                        @Html.TextBoxFor(model => model.HRA_Apr_CurrentAmt, new { @class = "form-control rnt", id = "HRA_Apr_CurrentAmt", autocomplete = "Off", name = "HRA_Apr_CurrentAmt", type = "number", @style = "text-align:right", onclick = "setSource(this)" })
                                    </td>
                                    <td>

                                        @Html.DropDownListFor(model => model.HRA_Apr_Metro, new SelectList(new List<object>() {
                                                    new {text="Non-Metro",value="Non-Metro"},
                                                    new {text="Metro",value="Metro"},
                                                }, "text", "value"), "--Select--", new { @class = "form-control metroNonmetro", @id = "HRA_Apr_Metro" })
                                        @Html.ValidationMessageFor(model => model.HRA_Apr_Metro, "", new { @class = "help-block", @id = "ErrorAprMetro", @style = "color:red" })
                                    </td>

                                    <td>
                                        <div hidden>
                                            @Html.TextBoxFor(model => model.InvestmentDeclarationEmployeeId, new { @class = "form-control", id = "InvestmentDeclarationEmployeeId", autocomplete = "Off", name = "InvestmentDeclarationEmployeeId" })
                                            @Html.TextBoxFor(model => model.InvestmentDeclaration_Encrypted, new { @class = "form-control", id = "InvestmentDeclaration_Encrypted", autocomplete = "Off", name = "InvestmentDeclaration_Encrypted" })
                                            @Html.TextBoxFor(model => model.InvestmentDeclarationFyearId, new { @class = "form-control", id = "InvestmentDeclarationFyearId", autocomplete = "Off", name = "InvestmentDeclarationFyearId" })
                                            @Html.TextBoxFor(model => model.InvestmentDeclarationEmployeeName, new { @class = "form-control", id = "InvestmentDeclarationEmployeeName", autocomplete = "Off", name = "InvestmentDeclarationEmployeeName" })
                                        </div>
