        var HRA_Nov_PanNo = $("#HRA_Nov_PanNo").val();
        var HRA_Dec_PanNo = $("#HRA_Dec_PanNo").val();
        var HRA_Jan_PanNo = $("#HRA_Jan_PanNo").val();
        var HRA_Feb_PanNo = $("#HRA_Feb_PanNo").val();
        var HRA_Mar_PanNo = $("#HRA_Mar_PanNo").val();

        if (Panlimit <= TotalAmount)
        {
            //April Panlimit
            if(RentAmount==null || RentAmount>0)
            {
                if(HRA_Apr_PanNo=="")
                {$('#ErrorAprPanNo').html("Value is required");return false}
                else{
                    $('#ErrorAprPanNo').html("");
                }
            }


            //May  Panlimit
            if(MayCurrentAmt==null || MayCurrentAmt>0)
            {
                if(May_PanNo=="")
                {$('#ErrorMayPanNo').html("Value is required");return false}
                else{ $('#ErrorMayPanNo').html("");}
            }

            //JUne Pan Limit
            if(HRA_Jun_CurrentAmt==null ||HRA_Jun_CurrentAmt>0)
            {
                if(HRA_Jun_PanNo=="")
                {$('#ErrorJunPanNo').html("Value is required");return false}
                else{ $('#ErrorJunPanNo').html("");}
            }


            //july Pan limit
            if(HRA_Jul_CurrentAmt==null || HRA_Jul_CurrentAmt>0)
            {
                if(HRA_Jul_PanNo=="")
                {$('#ErrorJulPanNo').html("Value is required");return false}
                else{ $('#ErrorJulPanNo').html("");}
            }


            //Aug  Panlimit
