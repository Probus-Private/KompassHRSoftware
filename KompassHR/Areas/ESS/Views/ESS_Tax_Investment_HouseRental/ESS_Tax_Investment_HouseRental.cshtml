        function validateMonthData(currentAmtSelector, metroSelector, cityNameSelector, addressSelector, landlordNameSelector, errorMetroSelector, errorCitySelector, errorAddressSelector, errorLandlordSelector) {
            var currentAmt = $(currentAmtSelector).val();
            var metro = $(metroSelector).val();
            var cityName = $(cityNameSelector).val();
            var address = $(addressSelector).val();
            var landlordName = $(landlordNameSelector).val();

            if (currentAmt > 0) {
                if (metro == "") {
                    $(errorMetroSelector).html("Value is required");
                    $(metroSelector).focus();
                    return false;
                } else {
                    $(errorMetroSelector).html("");
                }

                if (cityName == "") {
                    $(errorCitySelector).html("Value is required");
                    $(cityNameSelector).focus();
                    return false;
                } else {
                    $(errorCitySelector).html("");
                }

                if (address == "") {
                    $(errorAddressSelector).html("Value is required");
                    $(addressSelector).focus();
                    return false;
                } else {
                    $(errorAddressSelector).html("");
                }

                if (landlordName == "") {
                    $(errorLandlordSelector).html("Value is required");
                    $(landlordNameSelector).focus();
                    return false;
                } else {
                    $(errorLandlordSelector).html("");
                }
            } else {
                $(errorMetroSelector).html("");
                $(errorCitySelector).html("");
                $(errorAddressSelector).html("");
                $(errorLandlordSelector).html("");
            }
            return true;
        }

        // Validate each month using the same function
        if (!validateMonthData('#HRA_Apr_CurrentAmt', '#HRA_Apr_Metro', '#txtCityName', '#txtAddress', '#txtLandlordName', '#ErrorAprMetro', '#ErrorAprCityName', '#ErrorAprAddress', '#ErrorAprLandlordName')) {
            return false;
        }

        if (!validateMonthData('#HRA_May_CurrentAmt', '#HRA_May_Metro', '#HRA_May_CityName', '#HRA_May_Address', '#HRA_May_LandlordName', '#ErrorMayMetro', '#ErrorMayCityName', '#ErrorMayAddress', '#ErrorMayLandlordName')) {
            return false;
        }

        // Repeat the validation function for other months...

        //---------------------------------------------------------------


        //Pan Limit Validation
        debugger;
        var Panlimit = @Html.Raw(Json.Encode(TempData["HRA_PanLimit"]));

        var TotalAmount = Number($('#HRA_Total').val());
        var HRA_Apr_PanNo = $("#HRA_Apr_PanNo").val();
        var May_PanNo = $("#HRA_May_PanNo").val();
        var HRA_Jun_PanNo = $("#HRA_Jun_PanNo").val();
        var HRA_Jul_PanNo = $("#HRA_Jul_PanNo").val();
        var HRA_Aug_PanNo = $("#HRA_Aug_PanNo").val();
        var HRA_Sep_PanNo = $("#HRA_Sep_PanNo").val();
