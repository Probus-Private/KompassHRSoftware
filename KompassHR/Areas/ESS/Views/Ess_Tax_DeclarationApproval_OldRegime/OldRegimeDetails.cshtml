    function CalculateSum() {
        debugger;
        var sum=0;
        var value =Number ($("#US80C_EmployeesNationalPensionScheme80CCD1_CurrentAmt").val());
        var value1 =Number ($("#US80C_PensionPlanfromInsuranceCompaniesMutualFunds_CurrentAmt").val());
        var value2 =Number ($("#US80C_HousingLoanPrincipalRepayment_CurrentAmt").val());
        var value3 =Number ($("#US80C_LifeInsurancePremium_CurrentAmt").val());
        var value4 =Number ($("#US80C_NationalSavingCertificate_CurrentAmt").val());
        var value5 =Number ($("#US80C_NationalSavingCertificateAccruedInterest_CurrentAmt").val());
        var value6 =Number ($("#US80C_PublicProvidentFund_CurrentAmt").val());
        var value7 =Number ($("#US80C_UnitLinkedInsurancePlan_CurrentAmt").val());
        var value8 =Number ($("#US80C_ELSSTaxSavingMutualFund_CurrentAmt").val());
        var value9 =Number ($("#US80C_Tuitionfeesfor2children_CurrentAmt").val());
        var value10 =Number ($("#US80C_TaxSavingSharesNABARDandOtherBonds_CurrentAmt").val());
        var value11 =Number ($("#US80C_TaxsavingFixDepositsTenure5yearsormore_CurrentAmt").val());
        var value12 =Number ($("#US80C_HousingStampDutyRegistration_CurrentAmt").val());
        var value13 =Number ($("#US80C_PostOfficeTimeDepositScheme_CurrentAmt").val());
        var value14 =Number ($("#US80C_SeniorCitizenSavingScheme_CurrentAmt").val());
        var value15 =Number ($("#US80C_SukanyaSamriddhiScheme_CurrentAmt").val());
        var value16 =Number ($("#US80C_80CCC_CurrentAmt").val());
        var value17 =Number ($("#US80C_SuperannuationFundContribution_CurrentAmt").val());

        sum = value + value1 + value2 + value3 + value4 + value5 + value6 + value7 + value8 + value9 + value10 + value11
         + value12 + value13 + value14 + value15 + value16 + value17;

        //var sum;
        $("#sumEligiblededuction").val(sum);

        var CheckLimit = $("#sumEligiblededuction").val();

        if(CheckLimit>Limit)
        {
            $('#US80C_Total_EligibleDeduction').val(Limit);
        }
        else
        {
            $('#US80C_Total_EligibleDeduction').val(sum);
        }
    }

