<script>
    //btn Addinto Rows
    //use for add regex function
    //    jQuery.validator.addMethod(
    //  "regex",
    //   function(value, element, regexp) {
    //       if (regexp.constructor != RegExp)
    //           regexp = new RegExp(regexp);
    //       else if (regexp.global)
    //           regexp.lastIndex = 0;
    //       return this.optional(element) || regexp.test(value);
    //   },"erreur expression reguliere"
    //);
    $('#SavePreviousEmployerDetails').validate({
        rules: {
            PreviousEmployerName: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
            PreviousEmployerAddress: {
                required: true,
            },
            PreviousEmployerGrossSalary: {
                required: true,
            },
        },
        messages: {
            PreviousEmployerName: {
                required: "Please enter previous employer name",
                regex: "Only alphabet allowed"
            },
            PreviousEmployerAddress: {
                required: "Please enter previous employer address",
            },
            PreviousEmployerGrossSalary: {
                required: "Insert gross salary",
            },
        },
    });

    var form = $("#SavePreviousEmployerDetails");
    form.validate();
    $("#btnAddPreviousEmployer").click(function (e) {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }

        var GrossSal = $("#txtPreviousEmployerGrossSalary").val();
        if (GrossSal == 0 || GrossSal == "" || isNaN(GrossSal)) {
            $("#GrossSalError").html("Greater Than 0");
            return false;
        } else {
            $("#GrossSalError").html("");
        }

        var PreviousEmployerName = $('#txtPreviousEmployerName').val();
        var PreviousEmployerAddress = $('#txtPreviousEmployerAddress').val();
        var PreviousEmployerGrossSalary = $('#txtPreviousEmployerGrossSalary').val();
        var PreviousEmployerProfessionalTax = $('#txtPreviousEmployerProfessionalTax').val();
        var PreviousEmployer80C = $('#txtPreviousEmployer80C').val();
        var PreviousEmployerTaxDeductedAtSource = $('#txtPreviousEmployerTaxDeductedAtSource').val();
        var PreviousEmployerNPSEmployeeContribution80CCD1B = $('#txtPreviousEmployerNPSEmployeeContribution80CCD1B').val();
        var PreviousEmployerNPSEmployerContribution80CCD2 = $('#txtPreviousEmployerNPSEmployerContribution80CCD2').val();
        var PreviousEmployerSalaryMonth = $('#txtPreviousEmployerSalaryMonth').val();
        var PreviousEmployerJoiningDate = $('#txtPreviousEmployerJoiningDate').val();
        var PreviousEmployerLeavingDate = $('#txtPreviousEmployerLeavingDate').val();

        const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                        "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

        const formatDate = (dateStr) => {
            const date = new Date(dateStr);
            if (isNaN(date)) return '';
            return `${date.getDate().toString().padStart(2, '0')}/${months[date.getMonth()]}/${date.getFullYear()}`;
        }

        const formatMonthYear = (dateStr) => {
            const date = new Date(dateStr);
            if (isNaN(date)) return '';
            return `${months[date.getMonth()]}/${date.getFullYear()}`;
        }

        const formattedSalaryMonth = formatMonthYear(PreviousEmployerSalaryMonth);
        const formattedJoiningDate = formatDate(PreviousEmployerJoiningDate);
        const formattedLeavingDate = formatDate(PreviousEmployerLeavingDate);

        // 🔍 Check for duplicate dates
        let isDuplicate = false;
        $('#tblPreviousEmployerDetails tr').each(function () {
            const tds = $(this).find('td');
            if (tds.length === 0) return;

            const existingSalaryMonth = tds.eq(3).text().trim();
            const existingJoiningDate = tds.eq(10).text().trim();
            const existingLeavingDate = tds.eq(11).text().trim();

            if (
                existingSalaryMonth === formattedSalaryMonth
            ) {
                isDuplicate = true;
                return false; // Exit .each loop
            }

            if (
               existingJoiningDate === formattedJoiningDate
           ) {
                isDuplicate = true;
                return false; // Exit .each loop
            }

            if (
               existingLeavingDate === formattedLeavingDate
           ) {
                isDuplicate = true;
                return false; // Exit .each loop
            }
        });

        if (isDuplicate) {
            Swal.fire({
                icon: 'warning',
                title: 'Duplicate Entry',
                text: 'A record with the same Salary Month, Joining Date, and Leaving Date already exists.',
            });
            return false;
        }

        // ✅ Add new row
        const table = document.getElementById("tblPreviousEmployerDetails");
        const rowCount = table.rows.length;
        const row = table.insertRow(rowCount);

        row.insertCell(0).innerHTML = `<center><i class="fa-regular fa-trash-can fa-xl" onClick="SomeDeleteRowFunction(this,'')" id="btnDelete" style="color:#ff5b57"></i></center>`;
        row.insertCell(1).innerHTML = PreviousEmployerName;
