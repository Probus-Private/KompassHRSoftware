<script>
    function OpenModule() {
        debugger;
        var RecordList = new Array();

        var data = {};
        var currentRow = $(this).closest("tr");

        data.InvestmentDeclarationId = currentRow.find("td:eq(1)").html();
        data.EmployeeId = currentRow.find("td:eq(2)").html();
        data.InvestmentDeclarationFyearId = currentRow.find("td:eq(3)").html();

        RecordList.push(data);


        $("#myModalFinal").modal('show');
    }

    function AllApproveReject(Status) {
        debugger;
        var RejectRemark = document.getElementById("txtApproveRejectRemark").value;

        if (Status == "Rejected" && (RejectRemark == null || RejectRemark=="")) {
            $("#ErrorApproveRejectRemark").html("Please enter Reject Remark");
            return false;
        }
        var RecordList = new Array();
        var data = {};


        data.InvestmentDeclarationId = $("#InvestmentDeclarationId").val();
        data.EmployeeId = $("#InvestmentDeclarationEmployeeId").val();
        data.InvestmentDeclarationFyearId = $("#InvestmentDeclarationFyearId").val();
        data.Status = Status;
        data.RejectRemark = RejectRemark;
        RecordList.push(data);

        $.ajax({
            type: "POST",
            url: "@Url.Action("ApproveReject", "Ess_Tax_DeclarationApproval_OldRegime")",
            data: JSON.stringify({ ObjRecordList: RecordList }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
