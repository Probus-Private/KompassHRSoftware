        function calculateDeduction() {
            debugger;
            var selfCrntAmt = Number($("#ChapterVIA_Medical80D_Self_CurrentAmt").val()) || 0;
            var parentsCrntAmt = Number($("#ChapterVIA_Medical80D_Parents_CurrentAmt").val()) || 0;
            var healthCheckupAmt = Number($("#ChapterVIA_Medical80D_HealthCheckup_CurrentAmt").val()) || 0;
            var selfHealthCheckupAmt = Number($("#ChapterVIA_Medical80D_Self_HealthCheckup_CurrentAmt").val()) || 0;

            var selfCrntAmtLimit = Number($("#ChapterVIA_Medical80D_Self_CurrentAmtlbl").val()) || 0;
            var parentsCrntAmtLimit = Number($("#ChapterVIA_Medical80D_Parents_CurrentAmtlbl").val()) || 0;
            var healthCheckupLimit = Number($("#80D_BothAbove60_DeductionUnder80D_HealthCheckuplbl").val()) || 0;
            var selfHealthCheckupLimit = Number($("#ChapterVIA_Medical80D_Self_HealthCheckup_LimitAmtlbl").val()) || 0;

            // Total Calculation


            // Self Deduction Calculation
            var selfTotal = selfCrntAmt + selfHealthCheckupAmt;
            var selfEligibleAmt = Math.min(selfTotal, selfCrntAmtLimit);
            $("#ChapterVIA_Medical80D_Self_EligibleDeductionAmtlbl").val(selfEligibleAmt);
            $("#ChapterVIA_Medical80D_Self_EligibleDeductionAmtlblShow").val(selfEligibleAmt);

            // Parents Deduction Calculation
            var parentsTotal = parentsCrntAmt + healthCheckupAmt;
            var parentsEligibleAmt = Math.min(parentsTotal, parentsCrntAmtLimit);
            $("#ChapterVIA_Medical80D_Parents_EligibleDeductionAmtlbl").val(parentsEligibleAmt);
            $("#ChapterVIA_Medical80D_Parents_EligibleDeductionAmtlblShow").val(parentsEligibleAmt);

            var Parents_EligibleDeductionAmtlblShow=Number($("#ChapterVIA_Medical80D_Parents_EligibleDeductionAmtlblShow").val());
            var Self_EligibleDeductionAmtlblShow= Number($("#ChapterVIA_Medical80D_Self_EligibleDeductionAmtlblShow").val());

            var total = Self_EligibleDeductionAmtlblShow + Parents_EligibleDeductionAmtlblShow ;
            $("#Totallbl").val(total);


            // Health Checkup Deduction Calculation
            var healthCheckupEligibleAmt = Math.min(healthCheckupAmt, healthCheckupLimit);
            $("#80D_BothAbove60_DeductionUnder80D_EligibleDeductionAmtlbl").val(healthCheckupEligibleAmt);

            // Self Health Checkup Deduction Calculation
            var selfHealthCheckupEligibleAmt = Math.min(selfHealthCheckupAmt, selfHealthCheckupLimit);
            $("#ChapterVIA_Medical80D_Self_HealthCheckup_EligibleDeductionAmt").val(selfHealthCheckupEligibleAmt);
        }

        // Attach keyup event to all relevant input fields
        $("#ChapterVIA_Medical80D_Self_CurrentAmt, #ChapterVIA_Medical80D_Parents_CurrentAmt, #ChapterVIA_Medical80D_HealthCheckup_CurrentAmt, #ChapterVIA_Medical80D_Self_HealthCheckup_CurrentAmt")
            .on("keyup", function () {
                calculateDeduction();
            });

    });
</script>

