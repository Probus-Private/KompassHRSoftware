
@{
    ViewBag.Title = "Ess_Tax_DeclarationApproval_OldRegime";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
      /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Old Regime
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Ess_Tax_DeclarationApproval_Menu", "Ess_Tax_DeclarationApproval_Menu", new {id = 9, ScreenId= 524, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Old Regime </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Old Regime Employees.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Ess_Tax_DeclarationApproval_OldRegime", "Ess_Tax_DeclarationApproval_OldRegime", new { area = "ESS" })' id="InvestmentFYear" method="post" data-parsley-validate="true">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Financial Year<span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownList("TaxFyearId", new SelectList(ViewBag.GetTaxFyear, "Id", "Name"), "--Select--", new { id = "TaxFyearId", @class = "form-select", autocomplete = "off", name = "TaxFyearId" })
                                                <span id="ErrorTaxFyearId" class="Error" style="color:red;"></span>
                                            </div>
                                            <div class="col-md-3">
                                                <button type="submit" class="btn btn-primary btn-sm" id="btnSubmit">
                                                    Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3"></div>

                                </div>
                            </form>
                            <hr />
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage3">
                                        <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr class="text-center">
                                                <th hidden></th>
                                                <th class="text-nowrap" hidden>InvestmentDeclarationId	</th>
                                                <th class="text-nowrap" hidden>EmployeeId</th>
                                                <th class="text-nowrap" hidden>InvestmentDeclarationFyearId</th>
                                                <th class="text-nowrap">
                                                    <input type="checkbox" id="select-allchk">  All
                                                </th>
                                                <th class="text-nowrap">Details</th>
                                                <th class="text-nowrap">Company Name</th>
                                                <th class="text-nowrap">Business Unit</th>
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Employee No</th>
                                                <th class="text-nowrap">Joining Date</th>
                                                <th class="text-nowrap">Gender</th>
                                                <th class="text-nowrap">PAN</th>
                                                <th class="text-nowrap">Aadhar No</th>
                                                <th class="text-nowrap">PAN and Aadhar Link</th>
                                                <th class="text-nowrap">Departmernt</th>
                                                <th class="text-nowrap">Designation</th>
                                                <th class="text-nowrap">Grade</th>
                                                <th class="text-nowrap">Total Rent</th>
                                                <th class="text-nowrap">U/S 80C</th>
                                                <th class="text-nowrap">Chapter-VI A</th>
                                                <th class="text-nowrap">Self Occupied House Loan</th>
                                                <th class="text-nowrap">Let Out House</th>
                                                <th class="text-nowrap">Other Income</th>
                                                <th class="text-nowrap">Previous Employer</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbodyApproveReject">
                                            @foreach (var item in ViewBag.OldRegimeList)
                                            {
                                                <tr>
                                                    <td hidden></td>
                                                    <td hidden>@item.InvestmentDeclarationId</td>
                                                    <td hidden>@item.EmployeeId</td>
                                                    <td hidden>@item.InvestmentDeclarationFyearId</td>
                                                    <td class="text-center"><input type="checkbox" class="row-checkbox1"></td>
                                                    <td class="text-center">
                                                        <a onclick="OldRegimeDetails(@item.InvestmentDeclarationId,@item.EmployeeId,@item.InvestmentDeclarationFyearId)" id="UpdateBtn"
                                                           style="cursor:pointer;">
                                                            <i class="fa-solid fa-eye fa-lg text-dark"></i>
                                                        </a>
                                                    </td>
                                                    <td>@item.CompanyName</td>
                                                    <td>@item.BusinessUnit</td>
                                                    <td>@item.EmployeeName</td>
                                                    <td>@item.EmployeeNo</td>
                                                    <td>@item.JoiningDate</td>
                                                    <td>@item.Gender</td>
                                                    <td>@item.PAN</td>
                                                    <td>@item.AadharNo</td>
                                                    <td>@item.PANandAadharLink</td>
                                                    <td>@item.Department</td>
                                                    <td>@item.Designation</td>
                                                    <td>@item.Grade</td>
                                                    <td>@item.TotalRent</td>
                                                    <td>@item.US80C</td>
                                                    <td>@item.ChapterVIA</td>
                                                    <td>@item.SelfOccupiedHouseLoan</td>
                                                    <td>@item.LetOutHouse</td>
                                                    <td>@item.OtherIncome</td>
                                                    <td>@item.PreviousEmployer</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <br />

                            <div class="row">
                                <div class="col-md-12">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnApprove" class="btn btn-primary btn-sm" onclick="AllApproveReject('Approved')">
                                                <i class="fa-solid fa-floppy-disk"></i> Approve
                                            </button>
                                            <button href="#modal-dialogForHoldReject1" onclick="OpenModule()" type="button" class="btn btn-danger btn-sm" id="btnmodal-dialog1" value="Rejected">
                                                Reject
                                            </button>
                                            <a href="@Url.Action("GetList", "Ess_Tax_DeclarationApproval_OldRegime", new { area = "ESS" })">
                                                <button type="button" class="btn btn-success btn-sm" id="btnGetOldReqimeApprovalList">
                                                    <i class="fa-solid fa-share-from-square"></i> Approved List
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>




<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"> Remark For Reject</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                       aria-hidden="true">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <textarea id="txtApproveRejectRemark" class="form-control" rows="4"></textarea>
                                            <span id="ErrorApproveRejectRemark" class="Error" style="color:red;"></span>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success " id="btnAllReject" onclick="AllApproveReject('Rejected')">
                    <i class="fa-solid fa-floppy-disk"></i> Reject
                </button>

                <button type="button" id="btnCancel" class="btn btn-danger btnpress btnClear" data-bs-dismiss="modal">
                    <i class="fa-solid fa-share-from-square"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->

<script>
    //Select All Checkbox Functionality
    $(document).ready(function () {
        $(document).ready(function () {
            debugger
            document.getElementById("select-allchk").addEventListener("change", function () {
                debugger
                let checkboxes = document.querySelectorAll(".row-checkbox1");
                checkboxes.forEach(checkbox => checkbox.checked = this.checked);
            });
        });
    });
</script>

<script>

    function OldRegimeDetails(InvestmentDeclarationId, EmployeeId, InvestmentDeclarationFyearId) {
        debugger
        var url = '@Url.Action("OldRegimeDetails", "Ess_Tax_DeclarationApproval_OldRegime")' + '?InvestmentDeclarationId=' + InvestmentDeclarationId + '&EmployeeId=' + EmployeeId + '&InvestmentDeclarationFyearId=' + InvestmentDeclarationFyearId;
        window.location.href = url;
    }

</script>

<script>
    function OpenModule() {
        debugger;
        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");

            data.InvestmentDeclarationId = currentRow.find("td:eq(1)").html();
            data.EmployeeId = currentRow.find("td:eq(2)").html();
            data.InvestmentDeclarationFyearId = currentRow.find("td:eq(3)").html();

            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $("#myModalFinal").modal('show');
    }


    function AllApproveReject(Status) {
        debugger;
        var RejectRemark = document.getElementById("txtApproveRejectRemark").value;

        if (Status == "Rejected" && (RejectRemark == null || RejectRemark == "")) {
            $("#ErrorApproveRejectRemark").html("Please enter Reject Remark");
            return false;
        }

        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");

            data.InvestmentDeclarationId = currentRow.find("td:eq(1)").html();
            data.EmployeeId = currentRow.find("td:eq(2)").html();
            data.InvestmentDeclarationFyearId = currentRow.find("td:eq(3)").html();
            data.Status = Status;
            data.RejectRemark = RejectRemark;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            $("#myModalFinal").modal('hide');
            document.getElementById("txtApproveRejectRemark").value = "";
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }


        $.ajax({
            type: "POST",
            url: "@Url.Action("ApproveReject", "Ess_Tax_DeclarationApproval_OldRegime")",
            data: JSON.stringify({ ObjRecordList: RecordList }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                if (response == "true") {
                    Swal.fire({
                        icon: "success",
                        text: "Record Save Successfully",
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    })
                    .then((result) => {
                        if (result.isConfirmed) {
                            debugger
                            let selectedFYear = $("#TaxFyearId").val();
                            window.location.href = '@Url.Action("Ess_Tax_DeclarationApproval_OldRegime", "Ess_Tax_DeclarationApproval_OldRegime")' + "?TaxFyearId=" + selectedFYear;

                        } else if (
                            result.dismiss === Swal.DismissReason.cancel
                        ) {

                        }
                    })
                }
            }
        });
    }


</script>

<script>
    $(document).ready(function () {
        $(document).ready(function () {
            $('#btnSubmit').on('click', function (event) {
                debugger
                var TaxFyearId = $("#TaxFyearId").val();
                if (TaxFyearId == null || TaxFyearId == "") {
                    $("#ErrorTaxFyearId").html("Please select financial year");
                    return false;
                }
                else {
                    $("#ErrorTaxFyearId").html("");
                    return true;
                }
            });
        });
    });
</script>