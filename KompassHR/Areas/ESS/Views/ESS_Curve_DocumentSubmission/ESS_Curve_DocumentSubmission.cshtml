@model KompassHR.Areas.ESS.Models.ESS_Conference.Curve_DocumentSubmission
@{
    ViewBag.Title = "ESS_Curve_DocumentSubmission";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>
<style>
    .note-editable {
        border: groove;
        font-size: 16px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }
    /*.card-row-title {
        color: #1d76c6;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }*/

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Document Submission
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Curve_Menu", "ESS_Curve_Menu", new {id = 20, ScreenId=210, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Document Submission - <Span>@ViewBag.AddUpdateTitle</Span></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Here’s a form for document compulsory submission.
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Curve_DocumentSubmission", new { area = "ESS" })' id="SaveDocumentSubmission" method="post" enctype="multipart/form-data">
                                <div class="row">
                                    @Html.HiddenFor(model => model.DocAssignmentMasterId, new { @class = "form-control", id = "DocAssignmentMasterId" })
                                    @Html.HiddenFor(model => model.DocAssignmentDetailsId, new { @class = "form-control", id = "DocAssignmentDetailsId" })
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            Upload File <span class="important">*</span>
                                        </label>
                                        <div class="col-md-10">
                                            <input class="form-control" type="file" onchange="ResetFile()" name="DocumentPath" id="DocumentPath" accept=".jpg,.jpeg,.png,.pdf" />
                                            @Html.ValidationMessageFor(model => model.DocumentPath, null, new { @class = "help-block", @id = "ErrorDocumentPath", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            Remark
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.Remark, new { @class = "form-control", type = "text", name = "Remark", id = "txtRemark", autocomplete = "Off" })
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnsubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "ESS_Curve_DocumentSubmission", new { area = "ESS" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnTrainingAgency">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <h5>Description</h5>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="row mb-15px">
                                        <div class="summernote" style="background-color: rgba(0,0,0,0.03);">
                                            @Html.Raw(Model.Description)
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            <i class="fa fa-clipboard"></i> Instruction
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="row mb-15px">
                                        <div class="summernote" style="background-color: rgba(0,0,0,0.03);">
                                            @Html.Raw(Model.Instruction)
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {debugger
        $('title').html("Document Submission");
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveDocumentSubmission').validate({
        rules: {
            DocumentPath: {
                required: true,
            },
        },
        DocumentPath: {
            TrainingAgencyName: {
                required:"Please Upload File.",
            },
        },
    });

    var form = $("#SaveDocumentSubmission");
    form.validate();
    $("#btnsubmit").click(function () {
        debugger;

        form.valid();
        if(form.valid()==false)
        {
            $("#txtEstablishedDate").removeClass("error");
            return false;
        }
        else
        {
            $("#SaveDocumentSubmission").submit();
        }
    });

</script>

<script>
    function ResetFile()
    {
        let allowedExtension = ['image/jpeg', 'image/jpg', 'image/png','application/pdf'];
        let type = document.getElementById('DocumentPath').files[0].type;

        if(allowedExtension.indexOf(type)>-1)
        {
        }else{
            Swal.fire({
                icon: "error",
                text: "File type should be jpeg/jpg/png/pdf",
            })
            document.getElementById("fileUploadFile").value = null;
        }

        $("#lblFileName").text('');
    }
</script>



