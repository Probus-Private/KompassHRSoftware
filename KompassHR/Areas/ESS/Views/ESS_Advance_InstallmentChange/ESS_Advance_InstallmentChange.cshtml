@model KompassHR.Areas.ESS.Models.ESS_LoanAndAdvance.Payroll_AdvanceInstallment

@{
    ViewBag.Title = "ESS_Advance_InstallmentChange";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 80px; /* Set the width for the first column */
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Installment Change
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_LoanAndAdvance_SubMenu", "ESS_LoanAndAdvance_SubMenu", new {id = 6, ScreenId=496, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Installment Change - @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Fill in below form for installment change here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Advance_InstallmentChange", new { area = "ESS" })' id="SaveAdvanceInstallmentChange" method="post">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.AdvanceInstallmentEmployeeId, new SelectList(ViewBag.GetEmployee, "Id", "Name"), "--Select--", new { id = "ddlAdvanceInstallmentEmployeeId", @class = "form-select", autocomplete = "off", name = "AdvanceInstallmentEmployeeId" })
                                                @Html.HiddenFor(model => model.AdvanceInstallmentID_Encrypted, new { id = "AdvanceInstallmentID_Encrypted" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                Advance
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.AdvanceId, new SelectList(ViewBag.GetEmployeeAdvanceList, "Id", "Name"), "--Select--", new { id = "ddlAdvanceId", @class = "form-select", autocomplete = "off", name = "AdvanceId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                From Month /Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.FromMonthYear, new { @class = "form-control", type = "month", id = "txtFromMonthYear", autocomplete = "Off", Name = "FromMonthYear" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                To Month /Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.ToMonthYear, new { @class = "form-control", type = "month", id = "txtToMonthYear", autocomplete = "Off", Name = "ToMonthYear" })
                                                <span id="monthError" class="text-danger" style="display:none;">To Month/Year cannot be less than From Month/Year</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                Amount
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.AdvanceInstallmentAmount, new { @class = "form-control", type = "number", onkeypress = " return numbervalidate(event)", id = "txtAdvanceInstallmentAmount", autocomplete = "Off", Name = "AdvanceInstallmentAmount" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                Remark
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.Remark, new { @class = "form-control", type = "text", id = "txtRemark", autocomplete = "Off", Name = "Remark" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "ESS_Advance_InstallmentChange", new { area = "ESS" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnAdvanceGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlAdvanceInstallmentEmployeeId").select2();
        $("#ddlAdvanceId").select2();

        var FromDate = @Html.Raw(Json.Encode(TempData["FromMonthYear"]));
        var ToDate = @Html.Raw(Json.Encode(TempData["ToMonthYear"]));
        $("#txtFromMonthYear").val(FromDate);
        $("#txtToMonthYear").val(ToDate);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.toggle('animate__headShake', true);
                    setTimeout(() => popup.classList.toggle('animate__headShake', false), 500);
                    return false;
                }
            }).then(() => location.reload());
        }


        $("#ddlAdvanceInstallmentEmployeeId").on("change", function () {
            $("#ddlAdvanceId").find("option").remove();
            var EmployeeId = $("#ddlAdvanceInstallmentEmployeeId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeAdvance", "ESS_Advance_InstallmentChange")',
                data: { EmployeeId: EmployeeId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlAdvanceId").append("<option value=''>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlAdvanceId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })
    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveAdvanceInstallmentChange").validate({
        rules: {
            AdvanceInstallmentEmployeeId: {
                required: true,
            },
            AdvanceId: {
                required: true,
            },
            FromMonthYear: {
                required: true,
            },
            ToMonthYear: {
                required: true,
            },
            AdvanceInstallmentAmount: {
                required: true,
            },
        },
        messages: {
            AdvanceInstallmentEmployeeId: {
                required: "Employee name is required",
            },
            AdvanceId: {
                required: "Advance is required",
            },
            FromMonthYear: {
                required: "From Month year  is required",
            },
            ToMonthYear: {
                required: "To Month year  is required",
            },
            AdvanceInstallmentAmount: {
                required: "Amount is required",
            },
        }
    });

    var form = $("#SaveAdvanceInstallmentChange");
    form.validate();

    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#dateDocDate").removeClass('error');
            return false;
        }

        var AdvanceInstallmentID_Encrypted=$("#AdvanceInstallmentID_Encrypted").val();
        var AdvanceId=$("#ddlAdvanceId").val();
        var AdvanceInstallmentEmployeeId=$("#ddlAdvanceInstallmentEmployeeId").val();
        var FromMonthYear=$("#txtFromMonthYear").val();
        var ToMonthYear=$("#txtToMonthYear").val();
        var AdvanceInstallmentAmount=$("#txtAdvanceInstallmentAmount").val();

        $(".Userloaderbg").css("display", "flex");

        $.ajax({
            url: '@Url.Action("Ispayroll_AdvanceInstallmentExists", "ESS_Advance_InstallmentChange")',
            method:"Get",
            data:{
                AdvanceInstallmentID_Encrypted:AdvanceInstallmentID_Encrypted,
                AdvanceInstallmentEmployeeId:AdvanceInstallmentEmployeeId,
                AdvanceId:AdvanceId,
                FromMonthYear:FromMonthYear,
                ToMonthYear:ToMonthYear,
                AdvanceInstallmentAmount:AdvanceInstallmentAmount
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveAdvanceInstallmentChange").submit();
                }
            }
        });

    });
</script>

<script>
    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const fromMonth = document.getElementById("txtFromMonthYear");
    const toMonth = document.getElementById("txtToMonthYear");
    const errorSpan = document.getElementById("monthError");

    // Check if all elements exist
    if (!fromMonth || !toMonth || !errorSpan) {
        console.error("One or more elements not found:", {
            fromMonth: !!fromMonth,
            toMonth: !!toMonth,
            errorSpan: !!errorSpan
        });
        return;
    }

    function validateMonthRange() {
        // Clear previous validation
        errorSpan.style.display = "none";
        fromMonth.setCustomValidity("");

        if (!fromMonth.value || !toMonth.value) {
            return;
        }

        const from = new Date(fromMonth.value + "-01");
        const to = new Date(toMonth.value + "-01");

        if (to < from) {
            errorSpan.style.display = "inline";
            fromMonth.setCustomValidity("To Month/Year cannot be less than From Month/Year");
        }
    }

    // Add event listeners
    fromMonth.addEventListener("change", validateMonthRange);
    toMonth.addEventListener("change", validateMonthRange);

   
});
</script>