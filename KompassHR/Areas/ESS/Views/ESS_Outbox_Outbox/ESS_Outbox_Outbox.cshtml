                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>

            <div class="modal-footer">
                <button type="button" id="btnCancel" class="btn btn-primary btn-sm" data-bs-dismiss="modal">
                    <i class="fa-solid fa-floppy-disk"> </i> Ok
