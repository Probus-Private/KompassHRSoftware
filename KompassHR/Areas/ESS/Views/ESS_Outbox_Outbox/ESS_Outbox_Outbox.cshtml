<script>

    $(document).ready(function () {

    });

</script>

<script>
    function NotificationFunction(Origin, DocID) {
        $.ajax({
            type: "Get",
            url: "GetContactDetails",
            data: { Origin: Origin, DocID: DocID },
            dataType: "text",
            success: function (data) {
                //debugger;
                //console.log(data);
                ////alert(JSON.stringify(data[0]));
                //var datas = JSON.parse(data);
                //var Getdata = datas.data[0];
                //var ManagerName1 = Getdata[2].Value;
                //var ReportingmanagerMail1 = Getdata[9].Value
                //var ManagerName2 = Getdata[3].Value;
                //var EmailId = Getdata[10].Value
                //var HR = Getdata[4].Value;
                //var email = Getdata[11].Value;
                //$('#lblManager').html(ManagerName1);
                //$('#lblEmailIdName').html(ReportingmanagerMail1);
                //$('#lblManagerName2').html(ManagerName2);
                //$('#lblEmailId').html(EmailId);
                //$('#lblHR').html(HR);
                //$('#lblHREmailId').html(email);
                //$('#NotificationModalPopUp').modal('show');
                debugger;
                var datas = JSON.parse(data);
                if (datas.data.length != 0)
                {
                    var Getdata = datas.data[0];
                    $('#lblManager1Name').html(Getdata[0].Value);
                    $('#lblManager1EmailId').html(Getdata[1].Value);
                    $('#lblManager1Mobile').html(Getdata[2].Value);

                    $('#lblManager2Name').html(Getdata[3].Value);
                    $('#lblManager2EmailId').html(Getdata[4].Value);
                    $('#lblManager2Mobile').html(Getdata[5].Value);

                    $('#lblHRName').html(Getdata[6].Value);
                    $('#lblHREmailId').html(Getdata[7].Value);
                    $('#lblHRMobile').html(Getdata[8].Value);

                    if (Getdata[9] == undefined)
                    {
                        $('#DivAccount').hide();
                    }
                    else
                    {
                        $('#DivAccount').show();
                        $('#lblAcName').html(Getdata[9].Value);
                        $('#lblAcEmailId').html(Getdata[10].Value);
                        $('#lblAcMobile').html(Getdata[11].Value);
                    }
                    
                    $('#NotificationModalPopUp').modal('show');
                }
            }
        });
    }
    //CapthaVerification code added in CapthaVerification.js file.
    $(".Close").click(function () {
        $("#mainCaptcha").val("");
        $("#txtInput").val("");
        $("#success").html("");
        $("#error").html("");
    });
</script>
