                                                        <i class="fa-solid fa-user"></i>
                                                        @Html.Label("HR", new { @class = "control-label", id = "lblHRName" })
                                                    </div>
                                                    <div class="teamEmail">
                                                        <i class="fa fa-envelope"></i>
                                                        @Html.Label("HREmailId", new { @class = "control-label", id = "lblHREmailId" })
                                                    </div>
                                                    <div class="teamMob">
                                                        <i class="fa fa-phone"></i>
                                                        @Html.Label("HRMobileNo", new { @class = "control-label", id = "lblHRMobile" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12" id="DivAccount">
                                        <div class="teambx">
                                            <div class="teamheading">Account</div>
                                            <div class="teambody">
                                                <div class="teamcontactBx">
                                                    <div class="teamname">
                                                        <i class="fa-solid fa-user"></i>
                                                        @Html.Label("AC", new { @class = "control-label", id = "lblAcName" })
                                                    </div>
                                                    <div class="teamEmail">
                                                        <i class="fa fa-envelope"></i>
                                                        @Html.Label("ACEmailId", new { @class = "control-label", id = "lblAcEmailId" })
                                                    </div>
                                                    <div class="teamMob">
                                                        <i class="fa fa-phone"></i>
                                                        @Html.Label("ACMobileNo", new { @class = "control-label", id = "lblAcMobile" })
