
@{
    ViewBag.Title = "ESS_Outbox_Outbox";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<script src="~/assets/js/CaptchaVerification.js"></script>
<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }

    /*TeamBX Css*/
    .teambx {
        border: 1px solid gray;
        padding: 10px;
        position: relative;
        display: flex;
        align-items: center;
        margin: 10px 5px;
        border-radius:10px;
    }

        .teambx .teamheading {
            position: absolute;
            right: 0px;
            bottom: 5px;
            padding: 5px 15px;
            width: fit-content;
            border-radius: 20px 0px 0px 20px;
            background: #000;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 900;
        }

        .teambx .teamname {
            font-size: 16px;
            font-weight: 800;
            border-bottom: 1px solid lightgray;
            margin-bottom: 8px;
           
        }

    .teamname i {
        margin-right: 0 10px !important;
    }

    .teamcontactBx {
        font-size: 14px;
        text-align: left;
        font-weight: 600;
    }

        .teamcontactBx i {
            margin: 0 5px;
        }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/ESS/ESS_Requisition_Menu/ESS_Requisition_Menu">Requisition Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Outbox </h1>
    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Pending List For Approval</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        
                          
                    </div>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine">
                                <thead>
                                    <tr class="trheading">
                                        <th hidden>Delete</th>
                                        <th hidden> Notification</th>
                                        <th class="text-nowrap text-center">Notification</th>
                                        <th class="text-nowrap text-center">Doc Type</th>
                                        <th class="text-nowrap text-center">Pending Science</th>
                                        <th class="text-nowrap text-center">Doc No.</th>
                                        <th class="text-nowrap text-center">Doc Date</th>
                                        <th class="text-nowrap text-center">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.GetOutboxList)
                                    {
                                    <tr>
                                        <td hidden>@d.DocID</td>
                                        <td hidden>@d.Origin</td>
                                        <td class="text-nowrap">
                                            &nbsp;
                                            <button type="button" id="btnGetNotification" onclick="NotificationFunction('@d.Origin','@d.DocID')"
                                                    class="btn  btnpress ListBtn" style="background-color:#fff;">
                                                <i class="fa fa-phone"></i>
                                            </button> &nbsp;&nbsp;
                                            <button type="button" id="btnSendNotification" onclick="SendNotification('@d.id')"
                                                    class="btn  btnpress ListBtn" style="background-color:#fff;">
                                                <i class="fa-solid fa-paper-plane text-dark"></i>
                                            </button>
                                            @* @d.id*@
                                        </td>
                                        <td class="text-nowrap text-center">@d.ReqType</td>
                                        <td class="text-nowrap text-center">@d.PendingScience</td>
                                        <td class="text-nowrap text-center">@d.DocNo</td>
                                        <td class="text-nowrap text-center">@d.DocDate</td>
                                        <td class="text-nowrap text-center">@d.ReqDescription</td>
                                    </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <br />
                        <h6>Total Count : @TempData["TotalCount"]</h6>

                    </div>
                    <!-- END table-responsive -->
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Rejected List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        
                          
                    </div>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine">
                                <thead>
                                    <tr class="trheading">
                                        <th class="fixed-side text-center">Notification</th>
                                        <th hidden>Delete</th>
                                        <th hidden> Notification</th>
                                        <th class="text-nowrap text-center">Doc Type</th>
                                        <th class="text-start text-nowrap">Pending Science</th>
                                        <th class="text-start text-nowrap">Doc No.</th>
                                        <th class="text-nowrap text-center">Doc Date</th>
                                        <th class="text-nowrap text-center">Description</th>
                                        <th class="text-nowrap text-center">Rejected By</th>
                                        <th class="text-nowrap text-center">Rejected Date</th>
                                        <th class="text-nowrap text-center">Remark</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.GetOutboxRejectList)
                                    {
                                        <tr>

                                            <td class="text-nowrap">
                                                &nbsp;
                                                <button type="button" id="btnGetNotification" onclick="NotificationFunction('@d.Origin','@d.DocID')"
                                                        class="btn  btnpress ListBtn" style="background-color:#fff;">
                                                    <i class="fa fa-phone"></i>
                                                </button> &nbsp;&nbsp;
                                                <button type="button" id="btnSendNotification" onclick="SendNotification('@d.id')"
                                                        class="btn  btnpress ListBtn" style="background-color:#fff;">
                                                    <i class="fa-solid fa-paper-plane text-dark"></i>
                                                </button>
                                                @* @d.id*@
                                            </td>
                                            <td hidden>@d.DocID</td>
                                            <td hidden>@d.Origin</td>
                                            <td class="text-nowrap text-center">@d.ReqType</td>
                                            <td class="text-nowrap text-center">@d.PendingScience</td>
                                            <td class="text-nowrap text-center">@d.DocNo</td>
                                            <td class="text-nowrap text-center">@d.DocDate</td>
                                            <td class="text-nowrap">@d.ReqDescription</td>
                                            <td class="text-nowrap">@d.Approverejectby</td>
                                            <td class="text-nowrap">@d.ApproveRejectDate</td>
                                            <td class="text-nowrap">@d.ApproveRejectremark</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <br />
                        <h6>Total Count : @TempData["RejectTotalCount"]</h6>

                    </div>
                    <!-- END table-responsive -->
                </div>
            </div>
        </div>
    </div>
</div>
<!-- #Start NotificationModalPopUp modal-dialog -->
