                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.Time,
                                                new { @class = "form-control", type = "time", id = "txttime" ,
                                                    value = Model.Time.HasValue ? Model.Time.Value.ToString(@"hh\:mm") : ""})
                                            </div>

                                        </div>
                                    </div>

                                    <!-- Hourly Fields -->
                                    <div class="col-md-6" id="HourlyFields" style="display:none;">
                                        <div class="row">
                                            <!-- Hours -->
                                            <label class="form-label col-form-label col-md-4">
                                                Hour
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Hours, new SelectList(Enumerable.Range(1, 12)), "Select", new { @class = "form-control", id = "txtHours" })
                                             </div>
                                            </div>
                                        </div>

                                    <!-- Daily Fields -->
                                    <div class="col-md-6" id="DailyFields" style="display:none;">
                                        <div class="row">
                                            <!-- Daily Time -->
                                            <label class="form-label col-form-label col-md-4">
                                                Daily Time
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DailyTime,
                                                new { @class = "form-control", type = "time", id = "txtDailyTime" })
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Weekly Fields -->
                                    @*<div class="col-md-6" id="WeeklyFields" style="display:none;">
                                        <div class="row">
                                          
                                            <label class="form-label col-form-label col-md-2">
                                                Days
                                            </label>

                                            <div class="col-md-10">
                                                @foreach (var day in new[]
                                                 {
                                                 "Monday","Tuesday","Wednesday",
                                                 "Thursday","Friday","Saturday","Sunday"
                                                 })
                                                {
                                                    <label class="me-3">
                                                        <input type="checkbox" name="WeeklyDays" value="@day" />
                                                        @day
                                                    </label>
                                                }
                                            </div>
                                        </div>
                                    </div>*@

                                    <div class="col-md-6" id="WeeklyFields" style="display:none;">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Days
                                            </label>

                                            <div class="col-md-8">
                                                @{
                                                    var selectedDays = Model.WeeklyDays ?? new List<string>();
                                                }

                                                @foreach (var day in new[]
                                                    {
                                                        "Monday","Tuesday","Wednesday",
                                                         "Thursday","Friday","Saturday","Sunday"
                                                         })
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               name="WeeklyDays"
                                                               value="@day"
                                                               id="day_@day" 
                                                               @(selectedDays.Contains(day) ? "checked" : "")
                                                               />
