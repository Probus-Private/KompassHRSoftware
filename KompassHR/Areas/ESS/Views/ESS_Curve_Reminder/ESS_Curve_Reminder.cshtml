@model KompassHR.Areas.ESS.Models.ESS_Conference.Curve_Reminder

@{
    ViewBag.Title = "ESS_Curve_Reminder";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .select2.select2-container {
        width: 100% !important;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Reminder
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GetList", "ESS_Curve_Reminder", new {id = 20, ScreenId=836, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <!-- END breadcrumb -->


    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Reminder - <b>@ViewBag.AddUpdateTitle</b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Fill in below form for Reminder here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Curve_Reminder", new { area = "ESS" })' id="FormReminder" method="post" enctype="multipart/form-data">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => Model.DocNo, new { @class = "form-control mb-5px", @id = "txtDocNo", @readonly = "readonly", Value = @ViewBag.DocNo, Style = "background-color: #eee;" })
                                                @*@Html.Hidden("model.ReminderID_Encrypted", "", new { id = "hdnReminderID_Encrypted" })
                                                @Html.Hidden("ReminderID")*@
                                                @Html.HiddenFor(model => model.ReminderID_Encrypted, new { @class = "form-control", id = "ReminderID_Encrypted" })


                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Due Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DueDate, new { @class = "form-control", id = "txtDueDate", name = "DocDate", autocomplete = "Off", type = "date", @readonly = "readonly", Style = "background-color: #eee;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Reminder List
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.ReminderList, new { @class = "form-control", id = "txtReminderList", name = "ReminderList", autocomplete = "Off", type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Alert Before Days
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.AlertBeforeDays, new SelectList(Enumerable.Range(1, 30)), "Select", new { @class = "form-control", id = "txtAlertBeforeDays" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Attachment
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <input type="file" class="form-control" id="Attachment" name="Attachment" accept=".pdf">
                                                </div>
                                            </div>
                                            <small class="text-muted" style="margin-left: 367px;">Accepted formats: PDF(Max 5MB)</small>
                                            @if (Model != null && !string.IsNullOrEmpty(Model.Attachment))
                                            {
                                                <a href="@Url.Action("DownloadAttachment", "ESS_Curve_Reminder", new { DownloadAttachment = Model.Attachment })"
                                                   class="btn btn-sm btn-link">
                                                    <i class="fas fa-download"></i><label class="form-label col-form-label col-md-12" id="fileUploadFile-lbltext">@TempData["Attachment"]</label>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                End Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", id = "txtEndDate", name = "EndDate", autocomplete = "Off", type = "date", value = Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Status <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Status,
                                                  new List<SelectListItem>
                                                  {
                                                new SelectListItem { Text = "Private", Value = "1" },
                                                new SelectListItem { Text = "Public", Value = "2" }

                                                 },
                                               "Select", new { @class = "form-control", name = "Status", id = "ddlStatus" })
                                            </div>
                                        </div>
                                    </div>

                                </div>



                                <div class="row mb-15px">
                                    <!-- Frequency -->
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Frequency <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Frequency,
                                                  new List<SelectListItem>
                                                {
                                               new SelectListItem { Text = "One Time", Value = "OneTime" },
                                               new SelectListItem { Text = "Hourly", Value = "Hourly" },
                                               new SelectListItem { Text = "Daily", Value = "Daily" },
                                               new SelectListItem { Text = "Weekly", Value = "Weekly" },
                                               new SelectListItem { Text = "Monthly", Value = "Monthly" },
                                               new SelectListItem { Text = "Quarterly", Value = "Quarterly" },
                                               new SelectListItem { Text = "Yearly", Value = "Yearly" }
                                                 },
                                               "Select", new { @class = "form-select", name= "Frequency", id = "ddlFrequency" })
                                            </div>
                                        </div>
                                    </div>

                                    <!-- One Time Fields -->
                                     <div class="col-md-6" id="oneTimeFields" style="display:none;">
                                        <div class="row">
                                            <!-- Date -->
                                            <label class="form-label col-form-label col-md-2">
                                                Date
                                            </label>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(model => model.OneTimeDate,
                                                 new { @class = "form-control", type = "date", id = "txtDate", value = Model.OneTimeDate.HasValue ? Model.OneTimeDate.Value.ToString("yyyy-MM-dd") : "" })
                                                @Html.ValidationMessageFor(model => model.OneTimeDate, "", new { @class = "text-danger", id = "OneTimeDateError" })

                                             </div>

                                            <!-- Time -->
                                            <label class="form-label col-form-label col-md-2">
                                                Time
