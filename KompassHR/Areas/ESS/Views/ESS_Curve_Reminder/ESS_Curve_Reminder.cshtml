<script>
    $(document).ready(function () {
        debugger
        var EndDate = @Html.Raw(Json.Encode(TempData["EndDate"]));
        if (EndDate) {
            document.getElementById('txtEndDate').value = EndDate;
        }

        var OneTimeDate = @Html.Raw(Json.Encode(TempData["OneTimeDate"]));
        if (OneTimeDate) {
            document.getElementById('txtDate').value = OneTimeDate;
        }
        var Time = @Html.Raw(Json.Encode(TempData["Time"]));
        if (Time) {
            document.getElementById('txttime').value = Time;
        }



        var MonthDate = @Html.Raw(Json.Encode(TempData["MonthDate"]));
        if (MonthDate) {
            document.getElementById('txtMonthDate').value = MonthDate;
        }

        var QuarterlyDate = @Html.Raw(Json.Encode(TempData["QuarterlyDate"]));
        if (QuarterlyDate) {
            document.getElementById('txtQuarterlyDate').value = QuarterlyDate;
        }

        var YearlyDate = @Html.Raw(Json.Encode(TempData["YearlyDate"]));
        if (YearlyDate) {
            document.getElementById('txtYearlyDate').value = YearlyDate;
        }

        @*var DueDate = @Html.Raw(Json.Encode(TempData["DueDate"]));*@
        //document.getElementById('txtDueDate').value = DueDate;
        var today = new Date().toISOString().split('T')[0];
        $("#txtDueDate").val(today);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false // Disable outside clicks
            }).then(() => {
                window.location.reload();
            });
        }

    });
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function (value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   }, "erreur expression reguliere"
);

    $("#FormReminder").validate({
        rules: {
            DueDate: {
                required: true,
            },
            ReminderList: {
                required: true,
            },
            AlertBeforeDays: {
                required: true,
            },
            Frequency:{
                required:true,
            },
            Status:{
                required:true,
            },
            EndDate:{
                required:true,
            },
        },
        messages: {
            DueDate: {
                required: "DueDate is required",
            },
            ReminderList: {
                required: "Reminder List is required",
            },
            AlertBeforeDays: {
                required: "Alert Before Days is required",
            },
            Frequency:{
                required:"Frequency is required",
            },
            Status:{
                required:"status is required",
            },
            EndDate:{
                required:"End Date is required"
            },
        }
    });

    var form = $("#FormReminder");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
        }
        form.submit();
    });

