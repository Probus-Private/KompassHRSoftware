                                    <!-- Monthly Fields -->
                                    <div class="col-md-6" id="MonthlyFields" style="display:none;">
                                        <div class="row">
                                            <!-- Daily Time -->
                                            <label class="form-label col-form-label col-md-4">
                                                Start Date
                                            </label>
                                           
                                             <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MonthDate,
                                                new { @class = "form-control", type = "date", id = "txtMonthDate", value = Model.MonthDate.HasValue ? Model.MonthDate.Value.ToString("yyyy-MM-dd") : "" })
                                                @Html.ValidationMessageFor(model => model.MonthDate, "", new { @class = "text-danger", id = "monthDateError"})

                                            </div>
                                        </div>
                                    </div>

                                    <!-- Quarterly Fields -->
                                    <div class="col-md-6" id="QuarterlyFields" style="display:none;">
                                        <div class="row">
                                            <!-- Quarterly Date -->
                                            <label class="form-label col-form-label col-md-4">
                                                Start Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.QuarterlyDate,
                                                new { @class = "form-control", type = "date", id = "txtQuarterlyDate", value = Model.QuarterlyDate.HasValue ? Model.QuarterlyDate.Value.ToString("yyyy-MM-dd") : "" })
                                                @Html.ValidationMessageFor(model => model.QuarterlyDate, "", new { @class = "text-danger", id = "QuarterlyDateError" })

                                            </div>

                                        </div>
                                    </div>

                                    <!-- Yearly Fields -->
                                    <div class="col-md-6" id="YearlyFields" style="display:none;">
                                        <div class="row">
                                            <!-- Yearly Date -->
                                            <label class="form-label col-form-label col-md-4">
                                                Start Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.YearlyDate,
                                                new { @class = "form-control", type = "date", id = "txtYearlyDate", value = Model.YearlyDate.HasValue ? Model.YearlyDate.Value.ToString("yyyy-MM-dd") : "" })
                                                @Html.ValidationMessageFor(model => model.YearlyDate, "", new { @class = "text-danger", id = "YearlyDateError" })


                                             </div>
                                        </div>
                                    </div>

                                    </div>

                           

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                            </label>
                                            <div class="col-md-8 ">
                                                @Html.CheckBoxFor(model => model.IsActive)
                                                &nbsp;
                                                <label class="form-label">
                                                    Is Active
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    </div>


                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">

                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                                            </button>

                                                            <a href="@Url.Action("GetList", "ESS_Curve_Reminder", new { area = "ESS" })">
                                                                <button type="button" class="btn btn-danger btn-sm" id="btnTrainingAgency">
                                                                    <i class="fa-solid fa-share-from-square"></i> List
                                                                </button>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    function toggleFrequencyFields(frequency) 
    {
        $("#oneTimeFields,#HourlyFields,#DailyFields,#WeeklyFields,#MonthlyFields,#QuarterlyFields,#YearlyFields").hide();

        switch (frequency) {
            case "OneTime":
                $("#oneTimeFields").show();
                break;
            case "Hourly":
                $("#HourlyFields").show();
                break;
            case "Daily":
                $("#DailyFields").show();
                break;
            case "Weekly":
                $("#WeeklyFields").show();
                break;
            case "Monthly":
                $("#MonthlyFields").show();
                break;
            case "Quarterly":
                $("#QuarterlyFields").show();
                break;
            case "Yearly":
                $("#YearlyFields").show();
                break;
        }
    }

    $(document).ready(function () {
        toggleFrequencyFields($("#ddlFrequency").val());
        $("#ddlFrequency").change(function () {
            toggleFrequencyFields($(this).val());
        });
    });


    
    $("#txtMonthDate").change(function () {
        var monthDateVal = $(this).val();
        var endDateVal = $("#txtEndDate").val();
        var errorSpan = $("#monthDateError");

        if (monthDateVal && endDateVal) {
            var monthDate = new Date(monthDateVal);
            var endDate = new Date(endDateVal);

            if (monthDate > endDate) {
                errorSpan.text("Monthly date cannot be greater than End Date!");
                $(this).val(""); 
            }
        }
    });

    $("#txtDate").change(function () {
        debugger
        var OneTimeDateVal = $(this).val();
        var endDateVal = $("#txtEndDate").val();
        var errorSpan = $("#OneTimeDateError");

        if (OneTimeDateVal && endDateVal) {
            var OneTimeDate = new Date(OneTimeDateVal);
            var endDate = new Date(endDateVal);

            if (OneTimeDate > endDate) {
                errorSpan.text("One Time Date cannot be greater than End Date!");
                $(this).val(""); 
            }
        }
    });

    $("#txtQuarterlyDate").change(function () {
        var QuarterlyDateVal = $(this).val();
        var endDateVal = $("#txtEndDate").val();
        var errorSpan = $("#QuarterlyDateError");

        if (QuarterlyDateVal && endDateVal) {
            var QuarterlyDate = new Date(QuarterlyDateVal);
            var endDate = new Date(endDateVal);

            if (QuarterlyDate > endDate) {
                errorSpan.text("Quarterly Date cannot be greater than End Date!");
                $(this).val(""); 
            }
        }
    });



    $("#txtYearlyDate").change(function () {
        var YearlyDateVal = $(this).val();
        var endDateVal = $("#txtEndDate").val();
        var errorSpan = $("#YearlyDateError");

        if (YearlyDateVal && endDateVal) {
            var YearlyDate = new Date(YearlyDateVal);
            var endDate = new Date(endDateVal);

            if (YearlyDate > endDate) {
                errorSpan.text("Yearly date cannot be greater than End Date!");
                $(this).val(""); 
            }
        }
    });


</script>

