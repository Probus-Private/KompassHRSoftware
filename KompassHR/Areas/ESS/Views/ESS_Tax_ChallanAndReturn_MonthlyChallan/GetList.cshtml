                                                <th class="text-nowrap">Employee Name</th>                                               
                                            </tr>
                                        </thead>
                                        <tbody id="tblBodyEmployeeSalary"></tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">

                <button type="button" id="btnSubmit" onclick="funSave()"
                        class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk"></i> Submit
                </button>
               
                <button type="button" class="btn btn-primary btnpress btn-sm CloseModelHistory" id="CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true">
                    <i class="btn btn-danger btn-sm"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->





<script>
    function ShowList(ChallanId,ChallanNo) {
       debugger
    $.ajax({
        type: "GET",
        url: '@Url.Action("GetChallanDetails", "ESS_Tax_ChallanAndReturn_MonthlyChallan")',
        data: { ChallanId: ChallanId },
        contentType: "application/json; charset=utf-8",
        dataType: "text",
        success: function (response) {
            debugger;
            const data = JSON.parse(response);
            const modal = $('#myEmployeeSalary');
            const tableBody = $('#tblBodyEmployeeSalary');

            // Clear table body (except headers)
            if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
            }

            if (data && data.length > 0) {
                modal.modal('show');

                data.forEach(item => {
                    const row = $('<tr>');

                    const getCellValue = (key) => {
                        const cell = item.find(e => e.Key === key);
                        return cell ? cell.Value : '';
                    };

                    row.append(`<td><center><input type="checkbox" class="form-check-input"/></center></td>`);
                    row.append(`<td>${ChallanId}</td>`);
                    row.append(`<td>${ChallanNo}</td>`);
                    row.append(`<td>${getCellValue("BranchId")}</td>`);
                    row.append(`<td>${getCellValue("EmployeeId")}</td>`);
                    row.append(`<td>${getCellValue("BranchName")}</td>`);
                    row.append(`<td>${getCellValue("EmployeeNo")}</td>`);
                    row.append(`<td>${getCellValue("EmployeeName")}</td>`); 
                    

                    tableBody.append(row);
                });
            } else {
                modal.modal('hide');
            }
        }
    });
}




    function funSave() {
        debugger;
       

                $("#SelectAll").prop("checked", false);
                var Deductee = [];
                $('#tblBodyEmployeeSalary :checkbox:checked').each(function () {
                    var row = $(this).closest('tr'); // Get the closest row
                    var data = {
                        IncomeTax_Challan_ChallanId: row.find('td').eq(1).text(), // Hidden column
                        EmployeeID: row.find('td').eq(2).text(), // Hidden column
                        ChallanDeducteeBranchId: row.find('td').eq(3).text(),
                    };

                    
                    Deductee.push(data);
                });
                
                $("#myEmployeeSalary").modal('hide');
                $(".Userloaderbg").css("display", "flex");
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("SaveChallanDeductee", "ESS_Tax_ChallanAndReturn_MonthlyChallan")',
                    data: JSON.stringify({ Deductee: Deductee }),
                    contentType: "application/json; charset=utf-8",
                    dataType: "text",
                    success: function (response) {
                        debugger;
                        var data = JSON.parse(response);
                        var Message1 = data.Message;
                        var Icon1 = data.Icon;
                        var Month1 = data.Month;
                        if (data != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("GetList", "ESS_Tax_ChallanAndReturn_MonthlyChallan")';
                                    } else if (
                                        /* Read more about handling dismissals below */
                                        result.dismiss === Swal.DismissReason.cancel
                                    ) {

                                    }
                                })
                            }
                        }
                    }
                });

           

    }

  


    
</script>

<script>
    $(document).ready(function () {
        $('#myEmployeeSalary').on('shown.bs.modal', function () {
            var table = $('.TabledataBulkClass').DataTable();

            if ($.fn.DataTable.isDataTable('.TabledataBulkClass')) {
                table.destroy();
            }

            $('.TabledataBulkClass').DataTable({
                scrollY: 300,
                scrollCollapse: true,
                paging: false,
                scrollX: true,
                searching: true,
                autoWidth: false,
            });
        });
    });
</script>