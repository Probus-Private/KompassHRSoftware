<script>
    $(document).ready(function(){
        debugger
        $("#TAN").select2();
        $("#ChallanFyearId").select2();
        $("#MinorHeadOfChallan").select2();
       
        
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#DocDate").val(dateString);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });


    $('#ChallanFyearId, #Quarter').change(function () {
        debugger
        updateFinancialYearRange();
    });

    function updateFinancialYearRange() {
        debugger;
        var selectedFYear = $('#ChallanFyearId').find(":selected").text(); // e.g., "2023-2024"
        var selectedQuarter = $('#Quarter').val(); // e.g., "Quarter1"

        if (selectedFYear && selectedFYear.includes("-") && selectedQuarter && selectedQuarter !== "--Select--") {
            var years = selectedFYear.split("-");
            var startYear = years[0].trim();
            var endYear = years[1].trim();

            var quarterMonths = {
                "Quarter1": { start: "04", end: "06", year: startYear },
                "Quarter2": { start: "07", end: "09", year: startYear },
                "Quarter3": { start: "10", end: "12", year: startYear },
                "Quarter4": { start: "01", end: "03", year: endYear }
            };

            var q = quarterMonths[selectedQuarter];

            var minDate = q.year + "-" + q.start;
            var maxDate = q.year + "-" + q.end;

            $('#QuarterMonth').attr('min', minDate);
            $('#QuarterMonth').attr('max', maxDate);

            var currentVal = $('#QuarterMonth').val();
            if (currentVal < minDate || currentVal > maxDate) {
                $('#QuarterMonth').val('');
            }

        } else {
            $('#QuarterMonth').removeAttr('min max');
        }
    }
</script>






