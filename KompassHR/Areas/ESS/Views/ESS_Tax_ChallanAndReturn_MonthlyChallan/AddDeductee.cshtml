<script>


    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }








   function funSave() {
    debugger;
    $("#SelectAll").prop("checked", false);
    var TaxDepositedAmount = parseFloat(@Html.Raw(Json.Encode(ViewBag.ChallanDetails.TotalTaxDepositedAmount))) || 0;
    var Deductee = [];
    let totalDeducteeTDS = 0;

    //console.log("TaxDepositedAmount:", TaxDepositedAmount);

    var challanId = $("#IncomeTax_Challan_ChallanId").val();
    if (!challanId || isNaN(challanId)) {
        Swal.fire({
            icon: 'error',
            text: 'Invalid or missing Challan ID.',
        });
        return false;
    }
    challanId = parseInt(challanId);

    $('#fixed-header tbody input[type="checkbox"].form-check-input').each(function () {
        
        var row = $(this).closest('tr');
        var isChecked = $(this).is(':checked');
        var totalTdsAmtText = row.find('td').eq(14).text().trim();
        var totalTdsAmt = parseFloat(totalTdsAmtText) || 0;
        var employeeId = row.find('td.employee-id').text().trim();
        var challanDeducteeIdEncrypted = row.find('td').data('challan-deductee-id') || null;

        //console.log(`Row: EmployeeID=${employeeId}, TotalTDSAmount=${totalTdsAmt}, IsChecked=${isChecked}, ChallanDeducteeID_Encrypted=${challanDeducteeIdEncrypted}`);

        //if (!employeeId || isNaN(employeeId)) {
        //    return;
        //}

        if (isChecked) {
            totalDeducteeTDS += totalTdsAmt;
        }

        var data = {
            IncomeTax_Challan_ChallanId: challanId,
            SrNoInChallanAsPerRunningSerialNo: $("#SrNoInChallanAsPerRunningSerialNo").val(),
            ChallanDeducteeBranchId: row.find('td').eq(2).text().trim(),
            EmployeeID: row.find('td').eq(3).text().trim(),
            //ChallanDeducteeBranchId: parseInt(row.find('td').eq(1).text().trim()) || 0,
            EmployeeReferenceNumberProvidedByEmployer: row.find('td').eq(8).text().trim(),
            PANOfTheEmployee: row.find('td').eq(9).text().trim(),
            AmountPaidCredited: row.find('td').eq(10).text().trim(),
            TDSAmount: row.find('td').eq(11).text().trim(),
            SurchargeAmount: row.find('td').eq(12).text().trim(),
            EducationCessAmount: row.find('td').eq(13).text().trim(),
            TotalTDSAmount: row.find('td').eq(14).text().trim(),
            //TotalTDSAmount: totalTdsAmt.toString(),
            IsActive: isChecked,
            ChallanDeducteeID_Encrypted: challanDeducteeIdEncrypted,
            Mode: ""
        };

        Deductee.push(data);
    });
    debugger;
    //console.log("totalDeducteeTDS:", totalDeducteeTDS);
    //console.log("Deductee Array:", Deductee);

    if (Math.abs(totalDeducteeTDS - TaxDepositedAmount) > 0.01) {
        $("#errorTaxDepositedAmount").html(`Tax Deposited Amount (${TaxDepositedAmount}) and total of Deductees' TDS (${totalDeducteeTDS}) do not match!`);
        const errorElement = document.getElementById("errorTaxDepositedAmount");
        const yOffset = -100;
        const y = errorElement.getBoundingClientRect().top + window.pageYOffset + yOffset;
        window.scrollTo({ top: y, behavior: "smooth" });
        return false;
    }

    $(".Userloaderbg").css("display", "flex");
    $.ajax({
        type: "POST",
        url: '@Url.Action("SaveChallanDeductee", "ESS_Tax_ChallanAndReturn_MonthlyChallan")',
        data: JSON.stringify({ Deductee: Deductee }),
        contentType: "application/json; charset=utf-8",
        dataType: "text",
        success: function (response) {
            $(".Userloaderbg").css("display", "none");
            var data = JSON.parse(response);
            var Message1 = data.Message;
            var Icon1 = data.Icon;
            var Month1 = data.Month;
            if (data != null && Message1 != null) {
                Swal.fire({
                    icon: Icon1,
                    text: Message1,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup();
                        popup.classList.remove('swal2-show');
                        setTimeout(() => popup.classList.add('animate__animated', 'animate__headShake'));
                        setTimeout(() => popup.classList.remove('animate__animated', 'animate__headShake'), 500);
                        return false;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("GetList", "ESS_Tax_ChallanAndReturn_MonthlyChallan")';
                    }
                });
            }
        },
        error: function (xhr, status, error) {
            $(".Userloaderbg").css("display", "none");
            Swal.fire({
                icon: 'error',
                text: 'An error occurred while saving the data: ' + error,
            });
        }
    });
}

</script>

<script>
    function Delete(ChallanDeducteeID_Encrypted) {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_Tax_ChallanAndReturn_MonthlyChallan")?ChallanDeducteeID_Encrypted=' + ChallanDeducteeID_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

<script>
    $('#btnCalculateTotal').on('click', function () {
        // Initialize totals
        let totalPaid = 0, totalTDS = 0, totalSurcharge = 0, totalCess = 0, totalTotal = 0;

        // Loop through only checked rows in tbody of #fixed-header
        $('#fixed-header tbody input[type="checkbox"].form-check-input:checked').each(function () {
            const row = $(this).closest('tr');

            totalPaid += parseFloat(row.find('td').eq(10).text().trim()) || 0;
            totalTDS += parseFloat(row.find('td').eq(11).text().trim()) || 0;
            totalSurcharge += parseFloat(row.find('td').eq(12).text().trim()) || 0;
            totalCess += parseFloat(row.find('td').eq(13).text().trim()) || 0;
            totalTotal += parseFloat(row.find('td').eq(14).text().trim()) || 0;
        });

        // ✅ Update the fixed footer table, not #fixed-header
        $('#fixed-footer-clone .total-paid').text(totalPaid);
        $('#fixed-footer-clone .total-tds').text(totalTDS);
        $('#fixed-footer-clone .total-surcharge').text(totalSurcharge);
        $('#fixed-footer-clone .total-cess').text(totalCess);
        $('#fixed-footer-clone .total-total').text(totalTotal);
    });

</script>