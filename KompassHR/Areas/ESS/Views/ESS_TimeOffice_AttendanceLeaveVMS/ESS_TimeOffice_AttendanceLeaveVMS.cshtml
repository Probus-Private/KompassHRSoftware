                    </div>
                    <div class="leave-box">
                        <i class="fa-solid fa-pen-to-square"></i>
                        <h3>COFF Requistion</h3>
                    </div>
                    <div class="leave-box">
                        <i class="fa-regular fa-circle-right"></i>
                        <h3>More</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-10px">
        <div class="col-lg-12 col-md-12 ui-sortable">
            <!-- BEGIN panel -->

            <div class="vms-container">
                <h2><strong>VMS</strong></h2>
                <div class="vms-boxes">
                    <div class="vms-box">
                        <i class="fa-solid fa-calendar-check"></i>
