                <!-- END col-12 -->
            </div>
        </div>
    </div>

    <div class="row mt-10px">
        <div class="col-lg-12 col-md-12 ui-sortable">
            <!-- BEGIN panel -->

            <div class="attendance-container">
                <h2><strong>Attendance</strong></h2>
                <div class="attendance-boxes">
                    <div class="attendance-box">
