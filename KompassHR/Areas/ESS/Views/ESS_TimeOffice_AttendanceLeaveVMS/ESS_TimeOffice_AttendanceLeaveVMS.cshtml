
@{
    ViewBag.Title = "ESS_TimeOffice_AttendanceLeaveVMS";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<style>
    .attendance-container, .leave-container, .vms-container {
        padding: 20px;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.3);
    }

        .attendance-container h2, .leave-container h2, .vms-container h2 {
            margin-bottom: 10px;
            color: #333;
        }

    .attendance-boxes, .leave-boxes, .vms-boxes {
        display: flex;
        flex-wrap: nowrap;
        gap: 20px;
        justify-content: flex-start;
    }

    .attendance-box, .leave-box, .vms-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px;
        text-align: left;
        border-radius: 8px;
        transition: transform 0.3s ease;
    }

        .attendance-box:hover, .leave-box:hover, .vms-box:hover {
            transform: translateY(-5px);
        }

        .attendance-box i, .leave-box i, .vms-box i {
            font-size: 2em;
            margin-bottom: 10px;
            color: #007bff;
        }

        .attendance-box h3, .leave-box h3, .vms-box h3 {
            text-align: center;
            margin: 0;
            font-size: 1.1em;
            color: #555;
        }

    @@media screen and (max-width: 500px) {
        .attendance-box, .leave-box, .vms-box {
            padding: 10px;
        }

            .attendance-box h3, .leave-box h3, .vms-box h3 {
                font-size: 0.8em;
            }

            .attendance-box i, .leave-box i, .vms-box i {
                font-size: 1.5em;
            }

        .attendance-container h2, .leave-container h2, .vms-container h2 {
            font-size: 0.9em;
        }

        .sliderCard{
            margin-top:40px;
        }
    }

    .swiper {
        width: 100%;
/*        height: 100%;*/
    }

    .swiper-slide {
        width:100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }
</style>


<div id="content" class="app-content bg-white">
    
    <div class="row sliderCard">
        <div class="col-md-12 ui-sortable ">
            <div class="panel panel-inverse" style="margin-bottom:0px !important;" data-sortable-id="index-1">
                
                <!-- END panel-heading -->
                <div class="panel-body" style="padding:0px;">
                    <div class="swiper mySwiper">
                        <div class="swiper-wrapper">
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-blue" style="margin:0px; width:100% !important;" >
