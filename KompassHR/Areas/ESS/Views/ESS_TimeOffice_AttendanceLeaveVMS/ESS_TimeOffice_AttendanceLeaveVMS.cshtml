                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Shift Change</div>
                                        <div class="stats-number">
                                            <a href="/ESS/ESS_TimeOffice_ShiftChange/GetList" id="anchorApprovals" style="color:white;" onclick="Showdata('RECR03','Approvals pending with me')">2</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 40.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-teal" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-globe fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">OutDoor</div>
                                        <div class="stats-number">
                                            <a href="/ESS/ESS_TimeOffice_OutDoor/ESS_TimeOffice_GetApproveRejectList" id="anchorApprovals" style="color:white;" onclick="Showdata('RECR03','Approvals pending with me')">0</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 40.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-purple" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-archive fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Personal Gatepass</div>
                                        <div class="stats-number">
                                            <a href="/ESS/ESS_TimeOffice_PersonalGatePass/ESS_TimeOffice_GetApproveRejectPersOnalGatepassList" id="AchorRequsitions" onclick="Showdata('RECR01','Open raised by me')" style="color:white;">0</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 76.3%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me </div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-dark" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-comment-alt fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Work From Home</div>
                                        <div class="stats-number"><a href="/ESS/ESS_TimeOffice_WHF/ESS_TimeOffice_WHF_ApprovalandrejectList" id="AchorCandidate" onclick="Showdata('CandidatesPendingForAction','Candidates Pending for actions')" style="color:white;"> 0 </a></div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 54.9%;"></div>
                                        </div>
                                        <div class="stats-desc"> Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-orange" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-file-alt fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Punch Missing</div>
                                        <div class="stats-number">
                                            <a href="/ESS/ESS_TimeOffice_PunchMissing/ESS_TimeOffice_GetPunchMissingApprovalpendingList" id="AnchorInterview" onclick="Showdata('RECR07','Interviews pending with me')" style="color:white;">2</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 23.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-pink" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-exclamation-triangle fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Approval</div>
                                        <div class="stats-number">
                                            <a href="/ESS/ESS_TimeOffice_Approval/ESS_TimeOffice_Approval" id="AnchorDatabaseCandidates" onclick="Showdata('DatabaseCandidates','Database Candidates')" style="color:white;">8</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 10.5%;"></div>
                                        </div>
