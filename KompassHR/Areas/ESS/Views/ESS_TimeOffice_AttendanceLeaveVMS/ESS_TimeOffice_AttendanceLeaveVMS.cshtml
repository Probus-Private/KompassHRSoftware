                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="row mt-10px">
        <div class="col-lg-12 col-md-12 ui-sortable">
            <!-- BEGIN panel -->

            <div class="leave-container">
                <h2><strong>Leave</strong></h2>
                <div class="leave-boxes">
                    <div class="leave-box">
                        <i class="fa-solid fa-calendar"></i>
