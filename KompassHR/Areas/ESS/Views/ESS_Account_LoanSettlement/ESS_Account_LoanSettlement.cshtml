@{
    ViewBag.Title = "Loan Settlement";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var loan = ViewBag.GetLoanList != null && ((IEnumerable<dynamic>)ViewBag.GetLoanList).Any()
                ? ((IEnumerable<dynamic>)ViewBag.GetLoanList).FirstOrDefault()
                : null;
    var loanCalculations = ViewBag.Calculations != null && ((IEnumerable<dynamic>)ViewBag.Calculations).Any()
                ? ((IEnumerable<dynamic>)ViewBag.Calculations).FirstOrDefault()
                : null;
}

<style>
  /* ================= Tooltip ================= */
.Tooltip {
    position: relative;
    display: inline-block;
}

.Tooltip button {
    width: 35px;
}

.Tooltip .Tooltip-text {
    display: none;
    position: absolute;
    top: 40px;
    right: -18px;
    z-index: 10;
    min-width: 45px;
    max-width: fit-content;
    padding: 5px 8px;
    border-radius: 6px;
    background-color: #000;
    color: #fff;
    font-size: 12px;
    text-align: center;
}

.Tooltip:hover .Tooltip-text {
    display: flex;
    justify-content: center;
}

.Tooltip .Tooltip-text::after {
    content: "";
    position: absolute;
    top: -10px;
    right: 20px;
    border-width: 6px;
    border-style: solid;
    border-color: transparent transparent #000 transparent;
}

/* ================= Buttons ================= */
.ListBtn {
    font-size: 10px !important;
    padding: 5px 8px !important;
    border: 1px solid lightgray !important;
    border-radius: 4px;
    background-color: #f8f9fa;
    transition: all 0.2s ease-in-out;
}

.ListBtn:hover {
    background-color: #e9ecef;
}

/* ================= Tables ================= */
tr td {
    padding: 4px !important;
    font-weight: 600;
}

.table-striped > tbody > tr:nth-of-type(odd) > * {
    --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
}

.table-scroll table {
    width: 100%;
    margin: auto;
    border-collapse: separate;
    border-spacing: 0;
}

.table-scroll th, 
.table-scroll td {
    padding: 5px 10px;
    border: 1px solid lightgray;
    background: #fff;
    white-space: nowrap;
    vertical-align: top;
}

.table-scroll th {
    background-color: rgba(233, 236, 239, 1) !important;
    font-weight: 700;
}

/* ================= Scrollbar ================= */
.table-wrap {
    width: 100%;
    overflow: auto;
}

.table-wrap::-webkit-scrollbar {
    width: 6px;
    height: 10px;
}

.table-wrap::-webkit-scrollbar-track {
    background-color: #f5f5f5;
    border-radius: 10px;
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
}

.table-wrap::-webkit-scrollbar-thumb {
    background-color: #777;
    border-radius: 10px;
}

/* ================= Validation ================= */
label.error {
    display: block;
    margin-top: 3px;
    color: red;
    font-size: 12px;
    font-weight: 500;
}

.error {
    text-align: left;
    height: auto;
    color: red;
}

/* ================= Sticky Columns (Optional) ================= */
/* 
.div1 td:nth-child(1),
.fixed-side {
    position: sticky;
    left: 0;
    background: #fff;
    z-index: 2;
}

.div1 td:nth-child(2),
.fixed-side1 {
    position: sticky;
    left: 63px;
    background: #fff;
    z-index: 2;
}
*/

</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Loan Settlement
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Account_Menu", "ESS_Account_Menu", new {id = 33, ScreenId= 637, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Loan Settlement</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        View list of request loan here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="card-body">
                                <div class="card shadow-sm border mb-4">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fas fa-file-invoice-dollar me-2 text-primary"></i> Loan Information</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row gy-3">
                                            <div class="col-md-4 mb-3">
                                                <span >Loan Amount</span>
                                                <div class="fw-bold">₹ @(loan?.LoanAmount ?? 0) </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >Interest %</span>
                                                <div class="fw-bold"> @(loan?.LoanInterest ?? 0)  %</div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >Interest Amount</span>
                                                <div class="fw-bold">₹  @(loan?.InterestAmount ?? 0) </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >Total Loan Amount</span>
                                                <div class="fw-bold">₹ @(loan?.TotalLoanAmount ?? 0) </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >No of Installments</span>
                                                <div class="fw-bold"> @(loan?.NoOfInstallment ?? 0) </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span>Monthly Deduction</span>
                                                <div class="fw-bold text-danger">₹  @(loan?.MonthlyDeductionAmount ?? 0) </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >Deduction Start Date</span>
                                                <div class="fw-bold">@(loan?.FormattedDeductionStartDate ?? 0)  </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >Guarantor</span>
                                                <div class="fw-bold">@(loan?.GuarantorName1_Name ?? 0)  </div>
                                            </div>
                                            <div class="col-md-4 mb-3">
                                                <span >Reason</span>
                                                <div class="fw-bold">@(loan?.Reason ?? 0) </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card shadow-sm border">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0"><i class="fas fa-clipboard-check me-2 text-success"></i> Settlement Form</h5>
                                    </div>
                                    <div class="card-body">
                                        @using (Html.BeginForm("ESS_Account_LoanSettlement", "ESS", FormMethod.Post, new { @class = "row g-3" }))
                                        {
                                            <div class="col-12">
                                                <div class="row g-3 mb-4 p-3 bg-light rounded">
                                                    <div class="col-md-4 mb-3">
                                                        <div class="d-flex flex-column">
                                                            <span class="text-muted small">Total Loan</span>
                                                            <span class="fw-bold fs-5 text-primary">₹ @(loanCalculations?.TotalLoanAmount ?? 0) </span>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4 mb-3">
                                                        <div class="d-flex flex-column">
                                                            <span class="text-muted small">Paid Amount</span>
                                                            <span class="fw-bold fs-5 text-success">₹ @(loanCalculations?.TotalPaidAmount ?? 0)  </span>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4 mb-3">
                                                        <div class="d-flex flex-column">
                                                            <span class="text-muted small">Balance Amount</span>
                                                            <span class="fw-bold fs-5 text-warning">₹ @(loanCalculations?.RemainingBalance ?? 0) </span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">Principal Outstanding</label>
                                                @Html.TextBox("PrincipalOutstanding","",new { @class = "form-control", @readonly = "readonly", id = "PrincipalOutstanding", Value = loanCalculations?.RemainingPrincipal ?? 0 })
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">Interest Outstanding</label>
                                                @Html.TextBox("InterestOutstanding", "",new { @class = "form-control", id = "InterestOutstanding", Value=loanCalculations?.RemainingInterest ?? 0})
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Foreclosure %</label>
                                                <input class="form-control" id="ForeclosureCharges" placeholder="Enter %" />
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Foreclosure Amount</label>
                                                <input type="text" class="form-control" id="ForeclosureAmount" readonly />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">Total Settlement Amount</label>
                                                @Html.TextBox("TotalSettlementAmount", "",new { @class = "form-control fw-bold text-primary", @readonly = "readonly", id = "TotalSettlementAmount" })
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">Settlement Date</label>
                                                @*@Html.TextBox("SettledDate", "", new { @class = "form-control fw-bold text-primary", @readonly = "readonly", id = "SettledDate" })*@
                                                @Html.TextBox("SettledDate", DateTime.Today.ToString("yyyy-MM-dd"), new { id = "txtSettledDate", @class = "form-control", type = "date" })

                                                <input type="hidden" id="LastPaidMonth" value="@ViewBag.LastPaidMonth" />

                                                   </div>

                                            <div class="col-12 mt-2">
                                                <div id="calculationBox" class="alert alert-secondary fw-bold" style="display:none;">
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <label class="form-label fw-bold">Remarks</label>
                                                @Html.TextArea("Remarks", "", new { @class = "form-control", rows = "3", placeholder = "Write remarks (optional)",id="Remarks" })
                                            </div>
                                            <div class="col-12 text-end mt-3">
                                                <button type="button" class="btn btn-success px-4" id="btnSubmit">
                                                    <i class="fa fa-check-circle me-1"></i> Submit Settlement
                                                </button>
                                                <a href="@Url.Action("GetList","ESS_Account_CreateLoan")" class="btn btn-outline-secondary px-4 ms-2">
                                                    <i class="fa fa-arrow-left me-1"></i> Back
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $(document).ready(function () {

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });


    $(document).on("input", "#ForeclosureCharges", function () {
        debugger
    let percent = parseFloat($(this).val()) || 0;
    let principal = parseFloat($("#PrincipalOutstanding").val()) || 0;

    let foreclosureAmt = (percent / 100) * principal;

    $("#ForeclosureAmount").val(foreclosureAmt.toFixed(2));

    calculateSettlement();
});
    function calculateSettlement() {
        debugger
        let principal = parseFloat($("#PrincipalOutstanding").val()) || 0;
        let interest = parseFloat($("#InterestOutstanding").val()) || 0;
        let foreclosurePercent = parseFloat($("#ForeclosureCharges").val()) || 0;

        let foreclosureAmount = (foreclosurePercent / 100) * principal;
        let total = principal + interest + foreclosureAmount;

        // update total field
        $("#TotalSettlementAmount").val(total.toFixed(2));

        // show calculation
        let calcText = `${principal.toFixed(2)} + ${interest.toFixed(2)} + ${foreclosureAmount.toFixed(2)} = <span class="text-primary">${total.toFixed(2)}</span>`;
        $("#calculationBox").html(calcText).show();
    }

    $("#txtSettledDate").on("change", function () {
        debugger
        var lastPaidMonth = $("#LastPaidMonth").val(); // yyyy-MM
        var selectedDate = $(this).val();              // yyyy-MM-dd

        if (!selectedDate || !lastPaidMonth) return;

        // Convert selected date to yyyy-MM
        var selectedMonth = selectedDate.substring(0, 7);

        // 🔒 CORE RULE
        if (selectedMonth < lastPaidMonth) {
            Swal.fire({
                icon: "warning",
                text: "Settlement date must be on or after " + lastPaidMonth
            });

            $(this).val("");
        }
    });


    $(document).ready(function () {
        debugger
        $("#ForeclosureCharges, #InterestOutstanding").on("input", function () {
            debugger
            calculateSettlement();
        });
        calculateSettlement();
    });


    $("#btnSubmit").click(function () {
        debugger
        var LoanId = @(loanCalculations != null ? loanCalculations.LoanId : 0);
        var SettledDate=$("#txtSettledDate").val();
        var Remarks=$("#Remarks").val();
        var PrincipalOutstanding=$("#PrincipalOutstanding").val();
        var InterestOutstanding=$("#InterestOutstanding").val();
        var ForeclosurePercentage=$("#ForeclosureCharges").val();
        var Foreclosure_Amount=$("#ForeclosureAmount").val();
        var TotalSettlementAmount=$("#TotalSettlementAmount").val();

    $.ajax({
        url: '@Url.Action("ESS_Account_LoanSettlement", "ESS_Account_LoanSettlement")',
        type: "POST",
        data: { LoanId: LoanId,SettledDate:SettledDate,Remarks:Remarks,PrincipalOutstanding:PrincipalOutstanding,InterestOutstanding:InterestOutstanding,ForeclosurePercentage:ForeclosurePercentage,Foreclosure_Amount:Foreclosure_Amount,TotalSettlementAmount:TotalSettlementAmount},
        success: function (response) {
            if (response.Message) {
                Swal.fire({
                    icon: response.Icon,
                    text: response.Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup();
                        popup.classList.remove('swal2-show');
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake');
                        });
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake');
                        }, 500);
                        return false;
                    }
                });
                var url='@Url.Action("GetList", "ESS_Account_CreateLoan", new { area = "ESS" })';
                window.location.href = url;
            }
        },
        error: function () {
            Swal.fire({
                icon: "error",
                text: "Something went wrong while settling loan."
            });
        }
    });
});

</script>

