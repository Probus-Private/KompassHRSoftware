    function AllApproveReject() {
        debugger;
        
       
        var hasError =true;
        var RecordList = new Array();
        $("#tblOTApprovalBody").find(':checkbox:checked').each(function (i) {
            var data = {};
            debugger;
            var currentRow = $(this).closest("tr");
            data.EmployeeID =currentRow.find("td:eq(1)").html();
            data.InOutID =currentRow.find("td:eq(16)").html();
            var ObjActualOTHrs= ActualOTHrs = currentRow.find('#txtActualOTHrs').val();
            currentRow.find('#ErrortxtActualOTHrs').css('display', 'flex');
            var CheckError = currentRow.find("#ErrortxtActualOTHrs").html();
            if(CheckError!="")
            {
                currentRow.find('#txtActualOTHrs').css('color', 'red').focus();
                hasError = false;
                return false;
            }
            else
            {
                currentRow.find('#txtActualOTHrs').css('color', ''); // Reset color
            }
            var timeParts = ObjActualOTHrs.split(':');
            var hours = parseInt(timeParts[0]);
            var minutes = parseInt(timeParts[1]);
            // Converting hours into minutes and adding the minutes
            data.ActualOTHrs  = hours * 60 + minutes;
            data.Remark = currentRow.find('#txtRemark').val();
            RecordList.push(data);
        });
        if (RecordList.length == 0) {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }

        if(hasError==false)
        {
            return false;
        }

        
        
        $(".Userloaderbg").css("display", "flex");
        var GetDate=$("#FromDate").val();
        $.ajax({
            type: "POST",
            url: '@Url.Action("MultipleApproveRejectRequest", "ESS_TimeOffice_OTApproval")',
            //url: "MultipleApproveRejectRequest",
            data: JSON.stringify({ RecordList: RecordList,GetDate:GetDate }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
