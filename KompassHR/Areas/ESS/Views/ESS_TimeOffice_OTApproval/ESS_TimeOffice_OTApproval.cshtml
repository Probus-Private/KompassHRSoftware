<script>
    function validateTimeInput(input) {
        debugger;
        var regex = /^([01][0-9]|2[0-3]):[0-5][0-9]$/; // Regular expression for HH:MM format
        if (!regex.test(input.value)) 
        {
            var time = input.value;
            var timeStr = time.toString(); // Convert to string
            var hours = timeStr.slice(0, -2); // Get the first part for hours
            var minutes = timeStr.slice(-2); // Get the last two digits for minutes
            var formattedTime = hours + ':' + minutes; // Combine with colon
            input.value=formattedTime;
        }
        
       
        if (!regex.test(input.value)) {
            var Message = "Please enter time in HH:MM";
            var Icon = "error";
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500000)
                            return false
                        }
                    });
                }
            }
            input.value = ""; // Clear the input field if the format is incorrect
        }
    }


    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

