<script>
    $(document).ready(function () {
        debugger
        $('#ddlEmployee').select2();

        var DocDate = @Html.Raw(Json.Encode(TempData["DocDate"]));
        var Deadline = @Html.Raw(Json.Encode(TempData["Deadline"]));
        var NextMeetDate = @Html.Raw(Json.Encode(TempData["NextMeetDate"]));

        var StartTimeRaw = @Html.Raw(Json.Encode(TempData["StartTime"])); 
        var EndTimeRaw = @Html.Raw(Json.Encode(TempData["EndTime"]));     
        var NextMeetTimeRaw = @Html.Raw(Json.Encode(TempData["NextMeetTime"])); 

        $("#txtDocDate").val(DocDate);
        $("#txtDeadline").val(Deadline);
        $("#txtNextMeetDate").val(NextMeetDate);

        function convertTimeFormat(timeStr) {
            if (!timeStr) return "00:00"; // fallback
            return timeStr.replace(".", ":");
        }

        // Set the input values in proper format
        $("#txtStartTime").val(convertTimeFormat(StartTimeRaw));
        $("#txtEndTime").val(convertTimeFormat(EndTimeRaw));
        $("#txtNextMeetTime").val(convertTimeFormat(NextMeetTimeRaw));

        if (DocDate) {
            $("#txtDocDate").val(DocDate);
        } else {
            var today = new Date();
            var dd = String(today.getDate()).padStart(2, '0');
            var mm = String(today.getMonth() + 1).padStart(2, '0');
            var yyyy = today.getFullYear();
            var currentDate = yyyy + '-' + mm + '-' + dd;
            $("#txtDocDate").val(currentDate);
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#formReset").click(function () {
            $("#SaveMOM")[0].reset();
        });

    });
</script>

<script>
    $(document).on("click", ".btnDelete", function () {
        debugger
    const row = $(this).closest("tr");

    Swal.fire({
        title: 'Are you sure?',
        text: "This will remove the row!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Yes, delete it!',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            row.fadeOut(300, function () {
                $(this).remove();
                Swal.fire('Deleted!', 'Row removed successfully.', 'success');
            });
        }
    });
});
</script>

<script>
     function Delete(MOMDetailsId)
     {
             debugger;
             const DeleteButtons = Swal.mixin({
                 customClass: {
                     cancelButton: ' btnpress',
                     confirmButton: ' btnpress'
                 },
                 buttonsStyling: true
             })
             DeleteButtons.fire({
                 title: 'Are you sure?',
                 text: "You won't be able to revert this!",
                 icon: 'warning',
                 confirmButtonColor: '#d33',
                 cancelButtonColor: '#3085d6',
                 showCancelButton: true,
                 confirmButtonText: 'Yes, delete it!',
                 cancelButtonText: 'No, cancel!',
                 reverseButtons: false,
                 allowOutsideClick: () => {
                     const popup = Swal.getPopup()
                     popup.classList.remove('swal2-show')
                     setTimeout(() => {
                         popup.classList.add('animate__animated', 'animate__headShake')
                     })
                     setTimeout(() => {
                         popup.classList.remove('animate__animated', 'animate__headShake')
                     }, 500)
                     return false
                 }

             }).then((result) => {
                 if (result.isConfirmed) {
                     window.location.href = '@Url.Action("Delete", "ESS_TMS_MOM")?MOMDetailsId=' + MOMDetailsId;

                 } else if (
                     result.dismiss === Swal.DismissReason.cancel
                 ) {

                 }
             })
         }
    

</script>

<script>
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveMOM').validate({

        rules: {
            DocId: {
                required: true,
            },
            DocDate:{
                required: true,
            },

          
        },
        messages: {
              DocId: {
                  required: "DocId is required",

              },
              DocDate:{
                  required: "Doc Date is required",
              },
           
        },
    });

    var form = $("#SaveMOM");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#txtDocDate").removeClass('error');
            return false;
        }
        var DocNo = $("#txtDocNo").val();
        //var BranchId = $("#ddlBranchId").val();

        var MOMId_Encrypted = $("#txtMOMId_Encrypted").val();
        var MOMId=$("#txtMOMId").val();


        $.ajax({
            url:"IsMOMExists",
            method:"get",
            data: {
                DocNo:DocNo,
                MOMId_Encrypted:MOMId_Encrypted,
                MOMId:MOMId
            },
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    localStorage.removeItem("MOMTableData");
                    $("#SaveMOM").submit();
                }
            }
        });
    });
</script>

