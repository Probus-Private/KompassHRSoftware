    function saveTableToLocalStorage() {
        debugger
        var tableData = [];
        $("#tblBodyEmployees tr").each(function() {
            var row = $(this);
            var rowData = {
                ActionItem: row.find("input[name*='ActionItem']").val(),
                Priority: row.find("input[name*='Priority']").val(),
                Employee: row.find("input[name*='Employee']").val(),
                EmployeeText: row.find("td").eq(3).text(),
                Deadline: row.find("input[name*='Deadline']").val()
            };
            tableData.push(rowData);
        });
        localStorage.setItem("MOMTableData", JSON.stringify(tableData));
    }
    $(document).on("click", ".btnDelete", function() {
        $(this).closest("tr").remove();
        saveTableToLocalStorage(); 
    });


</script>

