                            <div class="table-responsive">
                                <table class="table">
                                    <tbody>
                                        <tr>
                                            <th>Employee Name</th>
                                            <td>@Item.employeename</td>
                                            <th>Doc. Date</th>
                                            <td>@Item.DocDate</td>
                                        </tr>
                                        <tr>
