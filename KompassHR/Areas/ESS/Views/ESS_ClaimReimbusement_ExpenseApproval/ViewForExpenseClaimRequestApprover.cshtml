                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ClaimReimbusement_ExpenseApproval", "ESS_ClaimReimbusement_ExpenseApproval", new {id = 8, ScreenId=705, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="invoice">
        <div class="invoice-company d-flex justify-content-between align-items-center">
            <span class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-road fa-lg"></i> Expense Claim Request For
            </span>
            <input type="hidden" id="hdnEncryptedId" value="@(Item.GeneralClaimId_Encrypted ?? string.Empty)" />
            <input type="hidden" id="hdnClaimId" value="@(Item.GeneralClaimId ?? string.Empty)" />
            <input type="hidden" id="hdnClaimType" value="@(Item.Type ?? string.Empty)" />
