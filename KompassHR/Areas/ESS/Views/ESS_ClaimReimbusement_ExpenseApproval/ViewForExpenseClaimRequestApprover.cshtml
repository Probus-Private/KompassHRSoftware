                                        <td>@item.ApprovedDate</td>
                                        <td>@item.Time</td>
                                        <td>@item.EmployeeName</td>
                                        <td>@item.Role</td>
                                        <td>@item.Remark</td>
                                        <td>@item.GeneralClaimAmount</td>
                                        <td class="text-success">@item.Status</td>
                                    </tr>
                                }
                                
                                
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Right Side: Expense Summary & Previous Expenses -->
