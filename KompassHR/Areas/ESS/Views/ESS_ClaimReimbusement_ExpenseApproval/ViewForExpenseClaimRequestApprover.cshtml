<script>
    document.addEventListener("DOMContentLoaded", function () {
        debugger
        window.ViewFile = function (filePath) {
            debugger
            if (!filePath || filePath.trim() === "") return;

            // === CLEAN FILE NAME EXTRACTION (Robust) ===
            let fullPath = filePath.trim();

            // Get everything after the last \ or /
            let fileNameWithExt = fullPath.split("\\").pop().split("/").pop();

            // Remove any query parameters if accidentally included (e.g., from bad URL)
            fileNameWithExt = fileNameWithExt.split("?")[0];

            // Final clean filename (e.g., "receipt.jpg")
            let fileName = fileNameWithExt.trim();

            // Get extension safely (lowercase)
            let ext = "";
            if (fileName.includes(".")) {
                ext = fileName.split(".").pop().toLowerCase();
            }

            // Build the correct URL for viewing
            const fileUrl = "/ESS_ClaimReimbusement_ExpenseApproval/OpenAttachment?filePath=" + encodeURIComponent(fullPath);

            // Update modal title — now shows ONLY the clean file name
            document.getElementById("modalFileTitle").innerHTML = `<i class="fas fa-file-alt me-2"></i> ${fileName}`;

            // Hide all sections
            document.getElementById("imageContainer").classList.add("d-none");
            document.getElementById("pdfContainer").classList.add("d-none");
            document.getElementById("modalOther").classList.add("d-none");

            // Clear old content
            document.getElementById("modalImage").src = "";
            document.getElementById("modalIframe").src = "";

            // Show correct viewer based on extension
            if (["jpg", "jpeg", "png", "gif", "bmp", "webp", "svg"].includes(ext)) {
                document.getElementById("modalImage").src = fileUrl;
                document.getElementById("imageContainer").classList.remove("d-none");
            }
            else if (ext === "pdf") {
                document.getElementById("modalIframe").src = fileUrl;
                document.getElementById("pdfContainer").classList.remove("d-none");
            }
            else {
                document.getElementById("modalOpenLink").href = fileUrl;
                document.getElementById("modalOther").classList.remove("d-none");
            }

            // Show modal
            const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('fileViewerModal'));
            modal.show();
        };
    });
</script>

<script>
    function DownloadFile(attachmentPath) {
        var correctedPath = attachmentPath.replace(/\//g, '\\');
        var url = '@Url.Action("DownloadAttachment", "ESS_ClaimReimbusement_ExpenseApproval")';

        $.ajax({
            url: url,
            type: 'POST',
            data: { DownloadAttachment: correctedPath },
            success: function (response) {
                debugger;
                if (response.Success) {
                    var fileName = response.FileName;
                    var fileData = atob(response.FileData);  // Decode the base64 string
                    var byteArray = new Uint8Array(fileData.length);
                    for (var i = 0; i < fileData.length; i++) {
                        byteArray[i] = fileData.charCodeAt(i);
                    }

                    var blob = new Blob([byteArray], { type: response.ContentType });
                    var downloadUrl = window.URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = downloadUrl;
                    a.download = fileName;
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                    window.URL.revokeObjectURL(downloadUrl);
                }
                else {
                    Swal.fire({
                        icon: response.Icon || 'error',
                        text: response.Message || 'An error occurred.',
                        allowOutsideClick: false
                    });
                }
            },
            error: function (xhr, status, error) {
                Swal.fire({
                    icon: 'error',
                    text: 'An unexpected error occurred.',
                    allowOutsideClick: false
                });
            }
        });
    }



</script>

<script>
    function printDiv() {

        //Get the HTML of div
        var divElements = document.getElementById('card').innerHTML;
        //Get the HTML of whole page
        var oldPage = document.body.innerHTML;
        //Reset the page's HTML with div's HTML only
        document.body.innerHTML =
          "<html><head></head><body>    " +
        divElements + "    </body>";
        //Print Page
        window.print();
        //Restore orignal HTML
        document.body.innerHTML = oldPage;
    }

    function OpenModule() {
        debugger;
        $("#myModalFinal").modal('show');
    }


    function Approved(Approver)
    {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes,submit!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                if(Approver=="Approved")
                {
                    var ApproveAmount=Number($("#txtClaimApproveAmount").val());
                    if(ApproveAmount=="")
                    {
                        $("#ErrortxtClaimApproveAmount").html("Please enter claim approve amount");
                        return false;
                    }
                    else{
                        $("#ErrortxtClaimApproveAmount").html("");
                    }
                    var TotalAmount = Number($("#txtTotalAmount").html());
                    debugger
                    if(TotalAmount < ApproveAmount)
                    {
                        $("#ErrortxtClaimApproveAmount").html("Approve amount should be less than total amount");
                        return false;
                    }
                    else{
                        $("#ErrortxtClaimApproveAmount").html("");
                    }
                }

                var DocId=$("#hdnClaimId").val();
                var Encrypted=$("#hdnEncryptedId").val();
                var Origin=$("#hdnClaimType").val();

                var Status="";
                var Remark="";
                if(Approver=="Rejected")
                {
                    Remark = $("#txtApproveRejectRemark").val();
                    Status="Rejected";
                }
                else {
                    Remark = $("#txtClaimApprovalRemark").val();
                    Status="Approved";
                }
                $(".Userloaderbg").css("display", "flex");

                $.ajax({
                url: "@Url.Action("ApproveClaimRequest", "ESS_ClaimReimbusement_ExpenseApproval")",
                method:"get",
                data:{DocId:DocId,Encrypted:Encrypted,Status:Status,Remark:Remark,ApproveAmount:ApproveAmount,Origin:Origin},
                success:function(response){
                    debugger;
                    $(".Userloaderbg").css("display", "none");
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon=="error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });

                                $("#myModalFinal").modal('hide');
                                $("#txtApproveRejectRemark").val("")
                                .then((result) => {
                                    debugger
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("ESS_ClaimReimbusement_ExpenseApproval", "ESS_ClaimReimbusement_ExpenseApproval")';
                                    } else if (
                                        /* Read more about handling dismissals below */
                                        result.dismiss === Swal.DismissReason.cancel
                                    ) {

                                    }
                                })
                            }
                        }
                    }
                    else{
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon=="success") {
                            if (Message1 != null) {
                                if (Message1 != null) {
                                    Swal.fire({
                                        icon: Icon1,
                                        text: Message1,
                                        allowOutsideClick: () => {
                                            const popup = Swal.getPopup()
                                            popup.classList.remove('swal2-show')
                                            setTimeout(() => {
                                                popup.classList.add('animate__animated', 'animate__headShake')
                                            })
                                            setTimeout(() => {
                                                popup.classList.remove('animate__animated', 'animate__headShake')
                                            }, 500)
                                            return false
                                        }
                                    })
                                    .then((result) => {
                                        if (result.isConfirmed) {
                                            window.location.href = '@Url.Action("ESS_ClaimReimbusement_ExpenseApproval", "ESS_ClaimReimbusement_ExpenseApproval")';
                                        } else if (
                                            /* Read more about handling dismissals below */
                                            result.dismiss === Swal.DismissReason.cancel
                                        ) {

                                        }
                                    })

                                    $("#myModalFinal").modal('hide');
                                    $("#txtApproveRejectRemark").val("");
                                }
                            }
                        }
                    }
                }
            });
        } else if (
        /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
           ) {

            }
    })
    }
</script>