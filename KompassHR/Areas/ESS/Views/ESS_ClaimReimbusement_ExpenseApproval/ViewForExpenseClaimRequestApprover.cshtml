                                            <td>@Item.FromDate</td>
                                            <th>To Date</th>
                                            <td>@Item.ToDate</td>
                                        </tr>
                                        <tr>
                                            <th>Expense Category Name</th>
                                            <td>@Item.ExpenseCategoryName</td>
                                            <th>Description</th>
                                            <td>@Item.GeneralClaimDescription</td>
                                        </tr>
                                        <tr>
