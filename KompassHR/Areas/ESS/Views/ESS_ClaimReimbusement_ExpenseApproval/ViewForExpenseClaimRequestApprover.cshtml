                            </div>
                            <div class="invoice-to">
                                <address>
                                    <i class="fa-solid fa-building"></i>&nbsp;<b>Category Name:</b> @Item.ExpenseCategoryName<br />
                                    <i class="fa-solid fa-desktop"></i>&nbsp;<b>Description:</b> @Item.GeneralClaimDescription
                                </address>
                            </div>
                        </div>

                        <!-- Claim Table -->
