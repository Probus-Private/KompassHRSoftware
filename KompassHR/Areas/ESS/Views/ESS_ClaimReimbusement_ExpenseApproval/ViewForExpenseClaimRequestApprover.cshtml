                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <hr />
                        </div>
                    </div>
                </div>

                <!-- Approval History -->
                <div class="card" style="padding: 20px; box-shadow: 0 0 10px rgba(0,0,0,0.05); border-radius: 10px;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="fa fa-history text-primary me-2"></i>
                        <h4 class="m-0">Approval History</h4>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="bg-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Name of Approver</th>
                                    <th>Role</th>
                                    <th>Comment</th>
