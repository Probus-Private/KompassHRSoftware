                var $moduleDropdown = $("#txtModuleID");
                $moduleDropdown.empty();

                if (data && data.length > 0) {
                    $moduleDropdown.append("<option value=''>--Select--</option>");
                    $.each(data, function (i, module) {
                        $moduleDropdown.append(
                            $("<option>").val(module.Id).text(module.Name)
                        );
                    });
                } else {
                    $moduleDropdown.append("<option>--Select--</option>");
                }
            },
            error: function () {
                console.error("Failed to fetch modules.");
                $("#txtModuleID").empty().append("<option>Error loading modules</option>");
            }
        });
    }



</script>*@
