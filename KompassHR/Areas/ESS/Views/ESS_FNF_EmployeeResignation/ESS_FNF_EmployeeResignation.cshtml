                            $("#ddlFNFBranchID").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        })

        $("#ddlFNFBranchID").on("change", function () {
            debugger
            $("#ddlFnfEmployee").find("option").remove();
            var BranchId = $("#ddlFNFBranchID").val();
