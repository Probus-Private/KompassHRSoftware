                            $("#ddlNoticePeriodValue").append("<option value='" + p.Name +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        //$('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });*@
        var ResignationDate = @Html.Raw(Json.Encode(TempData["ResignationDate"]));
        $("#ResignationDate").val(ResignationDate);

        var RelievingDate = @Html.Raw(Json.Encode(TempData["RelievingDate"]));
