$("#ddlFnfEmployee").on("change", function () {
    var EmployeeId = $("#ddlFnfEmployee").val();

    $.ajax({
        type: 'GET',
        dataType: 'JSON',
        url: '@Url.Action("GetNoticePeriodDays", "ESS_FNF_EmployeeResignation")',
        data: { EmployeeId: EmployeeId },
        success: function (data) {debugger

            if (data && data.info && data.info.length > 0) {

                var arr = data.info;
                var obj = {};

                // convert key/value list → object
                arr.forEach(function (item) {
                    obj[item.Key] = item.Value;
                });

                // bind Notice Period Type
                $("#ddlNoticePeriodType").val(obj.NoticePeriodType);
                $("#ddlNoticePeriodType").trigger("change", [obj.DayMonth]);
                debugger
               
                // Joining Date formatting
                if (obj.JoiningDate) {
                    var dateObj = new Date(obj.JoiningDate);
                    var yyyy = dateObj.getFullYear();
                    var MM = ("0" + (dateObj.getMonth() + 1)).slice(-2);
                    var dd = ("0" + dateObj.getDate()).slice(-2);

                    $("#txtDOJ").val(yyyy + "-" + MM + "-" + dd);
                }
                if (obj.ConfirmationDate) {
                    var dateObj = new Date(obj.ConfirmationDate);
                    var yyyy = dateObj.getFullYear();
                    var MM = ("0" + (dateObj.getMonth() + 1)).slice(-2);
                    var dd = ("0" + dateObj.getDate()).slice(-2);

                    $("#txtConfirmationDate").val(yyyy + "-" + MM + "-" + dd);
                }
                $("#txtIsConfirmation").val(obj.IsConfirmation);
                
            }
            else {
                $("#txtNoticePeriodDays").val("");
                $("#ddlNoticePeriodValue").val("");
                $("#ddlNoticePeriodType").val("");
                $("#divNoticePeriodValue").hide();
            }
        }
    });
});

    });

</script>
<script>
    $(document).ready(function () {
        $("#formReset").click(function () {
            $("#SaveEmployeeResignation")[0].reset();
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


    });// Ready end

    $("#btnEmployeeResignation").click(function () {
        debugger;
        var url = '@Url.Action("GetList", "ESS_FNF_EmployeeResignation")';
        window.location.href = url;
    });



    $("#ResignationDate, #ddlNoticePeriodType, #ddlNoticePeriodValue").on("change", function () {debugger

        var resignationDate = $("#ResignationDate").val();
        var noticeType = $("#ddlNoticePeriodType").val();
        var noticeValue = parseInt($("#ddlNoticePeriodValue").val());

        if (!resignationDate || isNaN(noticeValue)) return;

        var relDate = new Date(resignationDate);

        // --- MONTH TYPE ---
        if (noticeType === "Month") {

            let year = relDate.getFullYear();
            let month = relDate.getMonth() + noticeValue; // Add months
            let day = relDate.getDate();

            // Create target month date
            let temp = new Date(year, month, day);

            // If month overflowed (day does not exist)
            if (temp.getMonth() !== (month % 12)) {
                // Last day of previous month
                temp = new Date(year, month + 1, 0);
            }

            // Subtract 1 day
            temp.setDate(temp.getDate() - 1);

            relDate = temp;
        }

        // --- DAYS TYPE ---
        if (noticeType === "Days") {
            relDate.setDate(relDate.getDate() + noticeValue);
        }

        // Format date: yyyy-MM-dd
        var yyyy = relDate.getFullYear();
        var MM = ("0" + (relDate.getMonth() + 1)).slice(-2);
        var dd = ("0" + relDate.getDate()).slice(-2);

        var finalDate = `${yyyy}-${MM}-${dd}`;

        $("#RelievingDate").val(finalDate);
        $("#LastWorkingDate").val(finalDate);
        $("#txtNoticePeriodEndDate").val(finalDate);
    });


    function validateDates() {debugger
        var resignationDate = new Date($("#ResignationDate").val());
        var noticeEndDate = new Date($("#txtNoticePeriodEndDate").val());
        var relievingDate = new Date($("#RelievingDate").val());
        var lastWorkingDate = new Date($("#LastWorkingDate").val());

        // Clear previous errors
        $(".date-error").remove();

        let isValid = true;

        // Validate Relieving Date
        if (relievingDate < resignationDate) {debugger
            $("#RelievingDate").after("<span class='date-error text-danger'>Relieving Date cannot be earlier than Resignation Date.</span>");
            isValid = false;
        }
        if (relievingDate > noticeEndDate) {
            $("#RelievingDate").after("<span class='date-error text-danger'>Relieving Date cannot be after Notice Period End Date.</span>");
            isValid = false;
        }

        // Validate Last Working Date
        if (lastWorkingDate < resignationDate) { debugger
            $("#LastWorkingDate").after("<span class='date-error text-danger'>Last Working Date cannot be earlier than Resignation Date.</span>");
            isValid = false;
        }
        if (lastWorkingDate > noticeEndDate) { debugger
            $("#LastWorkingDate").after("<span class='date-error text-danger'>Last Working Date cannot be after Notice Period End Date.</span>");
            isValid = false;
        }

        return isValid;
    }

    // Trigger validation when user selects dates
    $("#RelievingDate, #LastWorkingDate, #ResignationDate, #txtNoticePeriodEndDate").on("change", function () {
        validateDates();
    });
</script>


