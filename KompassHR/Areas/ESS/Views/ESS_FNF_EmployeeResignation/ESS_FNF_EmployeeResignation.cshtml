            }


            $("#ddlNoticePeriodValue").find("option").remove();
            var NoticePeriodType = $("#ddlNoticePeriodType").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
