<script>
    $(document).ready(function () {
        debugger;
        $("#ddlFnfEmployee").select2();
        $("#ddlFnfReason").select2();
        $("#ddlFNFBranchID").select2();
        $("#ddlCmpID").select2();

        @*var GetVal = @Html.Raw(Json.Encode(TempData["NoticePeriodMonthDays"]));
        debugger
        $("#ddlNoticePeriodValue").val(GetVal);*@
        var getddlPType = $("#ddlNoticePeriodType").val();
        if (getddlPType === "ByPolicy")
        {
            $("#divNoticePeriodValue").hide();
        }
        if (getddlPType === "Month" || getddlPType === "Days")
        {
            $("#divNoticePeriodValue").show();
        }
        else
        {
            $("#divNoticePeriodValue").hide();
        }

        $("#ddlNoticePeriodType").on("change", function (e, selectedValue) {

            var val = $(this).val();

            $("#ddlNoticePeriodValue").empty();

            if (val === "ByPolicy") {
                $("#divNoticePeriodValue").hide();
                return;
            }

            $("#divNoticePeriodValue").show();

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                url: '@Url.Action("GetNoticePeriodMonthDays", "ESS_FNF_EmployeeResignation")',
                data: { NoticePeriodType: val },
                success: function (data) {

                    $("#ddlNoticePeriodValue").append("<option value=''>--Select--</option>");

                    $.each(data.NoticePeriodMonthDays, function (i, p) {
                        $("#ddlNoticePeriodValue").append("<option value='" + p.Name + "'>" + p.Name + "</option>");
                    });

                    // 🔥 Only run if employee-change triggered this
                    if (selectedValue) {

                        selectedValue = $.trim(selectedValue.toString());

                        // Try selecting by value
                        $("#ddlNoticePeriodValue").val(selectedValue);

                        // If not selected, try matching by text
                        if ($("#ddlNoticePeriodValue").val() !== selectedValue) {
                            $("#ddlNoticePeriodValue option").filter(function () {
                                return $.trim($(this).text()) === selectedValue;
                            }).prop("selected", true);
                        }

                        // Select2 refresh if used
                        $("#ddlNoticePeriodValue").trigger("change");
                    }
                }
            });
        });

        @*$("#ddlNoticePeriodType").on("change", function (e, selectedValue) {
            var val = $(this).val();
            if (val === "ByPolicy")
            {
                $("#divNoticePeriodValue").hide();
                $("#ddlNoticePeriodValue").find("option").remove();
                return false;
            }
            if (val === "Month" || val === "Days")
            {
