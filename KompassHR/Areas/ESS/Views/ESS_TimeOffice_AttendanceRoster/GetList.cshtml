@model KompassHR.Areas.ESS.Models.ESS_TimeOffice.AttenRoster

@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 40px; /* Set the width for the first column */
    }

    th:nth-child(2), td:nth-child(2) {
        width: 40px; /* Set the width for the first column */
    }

    .tblAddData td:nth-child(7) {
        display: none;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 10px !important;
        background-color: #F5F5F5;
    }
    /* Horizontal scrollbar */
    .dataTables_scrollBody::-webkit-scrollbar {
        height: 10px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Attendance Roster
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new {id = 5, ScreenId=150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Attendance Roster- List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of attendance roster created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action="@Url.Action("GetList", "ESS_TimeOffice_AttendanceRoster")" id="SaveAttendanceRoster">
                        <div class="row">
                            <div class="col-md-2">
                                <a href="@Url.Action("ESS_TimeOffice_AttendanceRoster", "ESS_TimeOffice_AttendanceRoster", new { area = "ESS" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                            </div>
                            <div class="col-md-10">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-2">
                                        Month/Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-3">
                                        @Html.TextBoxFor(model => model.RosterMonthYear, new { id = "txtMonth", @class = "form-control", name = "Month", type = "month" })
                                    </div>
                                    <div class="col-md-6">
                                        <button type="button" id="btnshow" onclick="showList()" class="btn btn-success btn-sm  mb-10px">
                                            <i class="fa-solid fa-eye"></i> &nbsp; Show
                                        </button>
                                        <a id="btnexport" onclick="downloadExcelFile()" class="btn btn-primary btn-sm  mb-10px">
                                            <i class="fa-solid fa-download fa-lg"></i> &nbsp;Export to Excel
                                        </a>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </form>

                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                   style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th class="text-nowrap">Update </th>
                                        <th class="text-nowrap">Delete </th>
                                        <th class="text-nowrap">Company Name </th>
                                        <th class="text-nowrap">Business Unit</th>
                                        <th class="text-nowrap">Month Year</th>
                                        <th class="text-nowrap">Employee</th>
                                        <th class="text-nowrap">From Date</th>
                                        <th class="text-nowrap">To Date</th>
                                        <th class="text-nowrap">Shift</th>
                                        <th class="text-nowrap">Is WeekOff</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.GetAttenRosterList)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <a onclick="UpdateAttenRoster('@d.RosterID_Encrypted')" id="UpdateBtn" style="cursor:pointer">
                                                    <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <a onclick="DeleteAttenRoster('@d.RosterID')" id="DeleteBtn" style="cursor:pointer">
                                                    <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                </a>
                                            </td>
                                            <td>@d.CompanyName</td>
                                            <td>@d.BranchName</td>
                                            <td>@d.RosterMonthYear.ToString("MMM/yyyy")</td>
                                            <td>@d.EmployeeName</td>
                                            <td>@d.FromDate.ToString("dd/MMM/yyyy")</td>
                                            <td>@d.ToDate.ToString("dd/MMM/yyyy")</td>
                                            <td>@d.ShiftName</td>
                                            <td>@(d.Is_WO ? "Yes" : "No")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- END panel -->
</div>

