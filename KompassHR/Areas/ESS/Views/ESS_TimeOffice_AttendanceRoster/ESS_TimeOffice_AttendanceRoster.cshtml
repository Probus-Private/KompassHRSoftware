        var RosterMonth = $("#txtRosterMonth").val();

        $.ajax({
            url: '@Url.Action("SaveUpdate", "ESS_TimeOffice_AttendanceRoster")',
            method: "POST",
            data: {
                RosterCmpID: RosterCmpID,
                RosterBranchID: RosterBranchID,
                RosterMonth: RosterMonth,
                EmployeeList: EmployeeList,
                AttedanceRosterList: AttedanceRosterList
            },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (Message1 != null && Icon1 != null) {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup();
                            popup.classList.remove('swal2-show');
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake');
                            });
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake');
                            }, 500);
                        }
                    }).then(function () {
                        window.location.href = '@Url.Action("ESS_TimeOffice_AttendanceRoster", "ESS_TimeOffice_AttendanceRoster")';
                    });
                }
            }
        });
    });

    // Select/Deselect all checkboxes
    $(document).on('change', '#AllCheckBox', function () {
        var table = $('#tblEmployees').DataTable();
        var isChecked = $(this).is(':checked');
        table.rows({ search: 'applied' }).nodes().each(function (row) {
            $(row).find('.rowCheckbox').prop('checked', isChecked);
