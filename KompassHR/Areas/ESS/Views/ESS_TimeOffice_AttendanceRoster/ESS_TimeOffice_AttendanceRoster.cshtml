<script>
    $(document).ready(function () {
        // Initialize select2 for dropdowns
        $("#ddlCompanyName").select2();
        $("#ddlRosterBranchID").select2();
        $("#ddlManagerName").select2();
        $("#ddlShiftId").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null && Icon != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.remove('swal2-show');
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake');
                    });
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake');
                    }, 500);
                }
            }).then(function () {
                window.location.reload();
            });
        }

        // Company Name change event
        $("#ddlCompanyName").on("change", function () {
            Validate(['RosterCmpID']);
            var RosterCmpID = $(this).val();
            $("#ddlRosterBranchID").find("option").remove();
            $("#ddlManagerName").find("option").remove();

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_TimeOffice_AttendanceRoster", new { area = "ESS" })',
                data: { RosterCmpID: RosterCmpID },
                success: function (data) {
                    // Populate Business Unit dropdown
                    var Branch = data.Branch || [];
                    if (Branch.length > 0) {
                        $("#ddlRosterBranchID").append("<option value=''>--Select--</option>");
                        $.each(Branch, function (i, p) {
                            $("#ddlRosterBranchID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    // Populate Manager Name dropdown
                    var ManagerName = data.ManagerName || [];
                    if (ManagerName.length > 0) {
                        $("#ddlManagerName").append("<option value='0'>--Select--</option>");
                        $.each(ManagerName, function (i, p) {
                            $("#ddlManagerName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                },
                error: function () {
                    alert("Error loading business units or managers.");
                }
            });
        });

        // Business Unit change event
        $("#ddlRosterBranchID").on("change", function () {debugger
            Validate(['RosterBranchID']);
            var RosterCmpID = $("#ddlCompanyName").val();
            var RosterBranchID = $(this).val();
            OnBranchChange(RosterCmpID, RosterBranchID, '');
        });
    });

    // Handle month change to set initial dates
    document.addEventListener("DOMContentLoaded", function () {
        const monthInput = document.getElementById("txtRosterMonth");
        const fromDateInput = document.getElementById("txtFromDate");
        const toDateInput = document.getElementById("txtToDate");

        monthInput.addEventListener("change", function () {
            const selectedMonth = this.value; // Format: yyyy-mm
            console.log("Month changed to:", selectedMonth);

            if (selectedMonth) {
                const parts = selectedMonth.split("-");
                const year = parseInt(parts[0]);
                const month = parseInt(parts[1]);
                const firstDay = new Date(year, month - 1, 1);
                const lastDay = new Date(year, month, 0);

                const formatDate = (date) => {
                    const yyyy = date.getFullYear();
                    const mm = ("0" + (date.getMonth() + 1)).slice(-2);
                    const dd = ("0" + date.getDate()).slice(-2);
                    return `${yyyy}-${mm}-${dd}`;
                };

                // Set min/max for date inputs
                const minDate = formatDate(firstDay);
                const maxDate = formatDate(lastDay);
                [fromDateInput, toDateInput].forEach(input => {
                    if (input) {
                        input.setAttribute("min", minDate);
                        input.setAttribute("max", maxDate);
                        input.value = "";
                    }
                });

                // Set FromDate to 1st of month
                fromDateInput.value = minDate;

                // Set ToDate to first Saturday
                let firstSaturday = new Date(firstDay);
                while (firstSaturday.getDay() !== 6) { // 6 is Saturday
                    firstSaturday.setDate(firstSaturday.getDate() + 1);
                }
                toDateInput.value = formatDate(firstSaturday);
            }
        });
    });

    // Form validation
    jQuery.validator.addMethod(
    "regex",
    function (value, element, regexp) {
        if (regexp.constructor != RegExp)
            regexp = new RegExp(regexp);
        else if (regexp.global)
            regexp.lastIndex = 0;
        return this.optional(element) || regexp.test(value);
    }, "erreur expression reguliere"
    );

    $('#SaveAttendanceRoster').validate({
        rules: {
            FromDate: { required: true },
            ToDate: { required: true },
            ShiftId: { required: true },
            RosterMonth: { required: true }
        },
        messages: {
            FromDate: { required: "From Date is Required" },
            ToDate: { required: "To Date is Required" },
            ShiftId: { required: "Shift is Required" },
            RosterMonth: { required: "Month/Year is Required" }
        }
    });

    var form = $("#SaveAttendanceRoster");
    form.validate();

    function  OnBranchChange(RosterCmpID,RosterBranchID,Task) {debugger
        if(Task == 'ShiftDropdownOnly')
        {
            //   $("#ddlShiftId").empty().append("<option value=''>--Select--</option>");
            $.ajax({
                type: 'GET',
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployee", "ESS_TimeOffice_AttendanceRoster", new { area = "ESS" })',
                data: { RosterBranchID: RosterBranchID, RosterCmpID: RosterCmpID },
                success: function (response) {
                    debugger;
                    // Populate Shift dropdown
                    var shiftData = response.Shift || [];
                    console.log("Shift Data:", shiftData);
                    if (shiftData.length > 0) {
                        $.each(shiftData, function (i, p) {
                            $("#ddlShiftId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                },
                error: function (xhr, status, error) {
                    debugger;
                    console.error("AJAX Error:", status, error, xhr.responseText);
                    alert("Error loading managers and shifts: " + error);
                }
            });
        }
        else{
            debugger
            $("#ddlManagerName").empty().append("<option value='0'>--Select--</option>");
            $("#ddlShiftId").empty().append("<option value=''>--Select--</option>");

            $.ajax({
                type: 'GET',
                dataType: 'json',
