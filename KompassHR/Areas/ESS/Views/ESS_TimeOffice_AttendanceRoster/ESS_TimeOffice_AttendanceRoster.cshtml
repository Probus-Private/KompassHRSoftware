    function ShowEmployee() {
        var RosterCmpID = $("#ddlCompanyName").val();
        var RosterBranchID = $("#ddlRosterBranchID").val();
        var RosterManagerID = $("#ddlManagerName").val();

        var controlFields = ['RosterCmpID', 'RosterBranchID'];
        var isFormValid = Validate(controlFields);

        if (isFormValid) {
            $(".Userloaderbg").css("display", "flex");
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeList", "ESS_TimeOffice_AttendanceRoster", new { area = "ESS" })',
                data: {
                    RosterCmpID: RosterCmpID,
                    RosterBranchID: RosterBranchID,
                    RosterManagerID: RosterManagerID
                },
                success: function (data) {
                    if ($.fn.DataTable.isDataTable('#tblEmployees')) {
                        $('#tblEmployees').DataTable().destroy();
                    }
                    $(".Userloaderbg").css("display", "none");
                    debugger
                    var tbody = $('#tblBodyEmployees');
                    tbody.empty();
                    if (data && data.length > 0) {
                        $.each(data, function (i, d) {
                            var row = `<tr>
                        <td class="text-nowrap text-center"><input type="checkbox" class="rowCheckbox" /></td>
                                    <td hidden>${d.EmployeeId}</td>
                                    <td>${d.CompanyName}</td>
                                    <td>${d.BranchName}</td>
                                    <td>${d.EmployeeName}</td>
                        </tr>`;
                            tbody.append(row);
                        });
                    }
                    $('#tblEmployees').DataTable({
                        paging: true
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Error loading employees:", error);
                }
            });
        }
    }

    function Validate(Control) {
        let Isvalid = true;
        for (let i = 0; i < Control.length; i++) {
            if (Control[i] == 'RosterCmpID') {
                if ($("#ddlCompanyName").val() == 0 || $("#ddlCompanyName").val() == '') {
                    $("#ErrorRosterCmpID").html("Company is required");
                    Isvalid = false;
                } else {
                    $("#ErrorRosterCmpID").html("");
                }
            }
            if (Control[i] == 'RosterBranchID') {
                if ($("#ddlRosterBranchID").val() == 0 || $("#ddlRosterBranchID").val() == '') {
                    $("#ErrorRosterBranchID").html("Branch is required");
                    Isvalid = false;
                } else {
                    $("#ErrorRosterBranchID").html("");
                }
            }
            if (Control[i] == 'RosterEmployeeID') {
                if ($("#ddlManagerName").val() == 0 || $("#ddlManagerName").val() == '') {
                    $("#ErrorRosterManagerID").html("Employee is required");
                    Isvalid = false;
                } else {
                    $("#ErrorRosterManagerID").html("");
                }
            }
        }
        return Isvalid;
    }

    // Add button click handler
    $("#btnAdd").click(function (e) {debugger
        e.preventDefault(); // Prevent default form behavior

        // Validate form
        if (!form.valid()) {
            console.log("Form validation failed");
            return false;
        }
        debugger
        // Get form input values
        var FromDate = document.getElementById("txtFromDate").value;
        var ToDate = document.getElementById("txtToDate").value;
        var WeekOff = document.getElementById("chkIs_WO").checked ? 1 : 0;
        var ShiftId = document.getElementById("ddlShiftId").value;
        var ShiftName = $("#ddlShiftId option:selected").text().trim();

        console.log("Input values:", { FromDate, ToDate, WeekOff, ShiftId, ShiftName });

        // Validate inputs manually
        var error = document.getElementById("lblerror") || document.createElement("span");
        error.id = "lblerror";
        error.style.color = "red";
        error.style.display = "none";
        if (!FromDate || !ToDate || !ShiftId || ShiftName === "--Select--") {
            error.innerHTML = "Please fill all required fields (From Date, To Date, Shift).";
            error.style.display = "block";
            if (!document.getElementById("lblerror")) {
                $("#btnAdd").after(error);
            }
            console.log("Manual validation failed: Missing required fields");
            return;
        } else {
            error.style.display = "none";
        }
        debugger
        // Week-off validation: max 2 days difference when Is_WO is checked
        if (WeekOff) {
            var fromDateObj = new Date(FromDate);
            var toDateObj = new Date(ToDate);
            var dayDiff = (toDateObj - fromDateObj) / (1000 * 60 * 60 * 24); // Difference in days
            if (dayDiff > 1) { // Allow 0 (same day) or 1 (e.g., Sat-Sun)
                error.innerHTML = "Week-off duration cannot exceed 2 days.";
                error.style.display = "block";
                if (!document.getElementById("lblerror")) {
                    $("#tblAttendance").after(error);
                }
                return;
            }
        }

        // Format dates to dd/MMM/yyyy for display
        var formattedFromDate = FromDate ? new Date(FromDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).replace(/ /g, '-') : '';
        var formattedToDate = ToDate ? new Date(ToDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).replace(/ /g, '-') : '';
        var formattedWeekOff = WeekOff ? "Yes" : "No";

        debugger
        // Check for duplicates
        var tableBody = document.getElementById("tblAttendanceRoster");
        var rows = tableBody.getElementsByTagName("tr");
        var isDuplicate = false;
        for (var i = 0; i < rows.length; i++) {
            var rowFromDate = rows[i].cells[2].textContent.trim();
            var rowToDate = rows[i].cells[3].textContent.trim();
            //var rowShiftName = rows[i].cells[4].textContent.trim();
            if (rowFromDate === formattedFromDate && rowToDate === formattedToDate) {
                isDuplicate = true;
                break;
            }
        }

        var duplicateError = document.getElementById("lblErrorDuplicate") || document.createElement("span");
        duplicateError.id = "lblErrorDuplicate";
        duplicateError.style.color = "red";
        duplicateError.style.display = "none";
        if (isDuplicate) {
            duplicateError.innerHTML = "Attendance already exit for this Date and Shift. ";
            duplicateError.style.display = "block";
            if (!document.getElementById("lblErrorDuplicate")) {
                $("#tblAttendance").after(duplicateError);
            }
            return;
        } else {
            duplicateError.style.display = "none";
        }
        debugger
        // Add new row
        try {
            var newRow = tableBody.insertRow();
            newRow.insertCell(0).innerHTML = '<center><a href="javascript:void(0);" type="button" onclick="deleteRow(this)" style="cursor:pointer;"><i class="fa-solid fa-trash-alt text-danger fa-lg"></i></a></center>';
            let shiftCell = newRow.insertCell(1);
            shiftCell.textContent = ShiftId;
            shiftCell.classList.add("hidden-cell");
            newRow.insertCell(2).textContent = formattedFromDate;
            newRow.insertCell(3).textContent = formattedToDate;
            newRow.insertCell(4).textContent = ShiftName;
            newRow.insertCell(5).textContent = formattedWeekOff;
        } catch (err) {
            return;
        }
        debugger
        // Set next FromDate and ToDate
        var rosterMonth = document.getElementById("txtRosterMonth").value;
        if (rosterMonth) {
            var parts = rosterMonth.split("-");
            var year = parseInt(parts[0]);
            var month = parseInt(parts[1]);
            var lastDay = new Date(year, month, 0); // Last day of month
            var maxDate = lastDay.toISOString().split('T')[0]; // YYYY-MM-DD

            const formatDate = (date) => {
                const yyyy = date.getFullYear();
                const mm = ("0" + (date.getMonth() + 1)).slice(-2);
                const dd = ("0" + date.getDate()).slice(-2);
                return `${yyyy}-${mm}-${dd}`;
            };

            // Get updated rows after adding the new row
            var updatedRows = tableBody.getElementsByTagName("tr");
            if (updatedRows.length > 0) {
                // Get last row's ToDate
                var lastRowToDate = updatedRows[updatedRows.length - 1].cells[3].textContent.trim();
                var toDateObj = new Date(lastRowToDate.split('-').reverse().join('-')); // Parse dd-MMM-yyyy
                if (!isNaN(toDateObj)) {
                    // Next FromDate: day after last ToDate
                    var nextFromDate = new Date(toDateObj);
                    nextFromDate.setDate(toDateObj.getDate() + 1);

                    // Next ToDate: next Saturday
                    var nextToDate = new Date(nextFromDate);
                    while (nextToDate.getDay() !== 6 && nextToDate <= lastDay) { // 6 is Saturday
                        nextToDate.setDate(nextToDate.getDate() + 1);
                    }

                    // Ensure dates are within the month
                    if (nextFromDate.getMonth() + 1 === month && nextToDate.getMonth() + 1 === month && nextToDate <= lastDay) {
                        document.getElementById("txtFromDate").value = formatDate(nextFromDate);
                        document.getElementById("txtToDate").value = formatDate(nextToDate);
                    } else {
                        document.getElementById("txtFromDate").value = "";
                        document.getElementById("txtToDate").value = "";
                    }
                } else {
                }
            } else {
                // First row: set defaults
                var firstDay = new Date(year, month - 1, 1);
                var firstSaturday = new Date(firstDay);
                while (firstSaturday.getDay() !== 6) {
                    firstSaturday.setDate(firstSaturday.getDate() + 1);
                }
                document.getElementById("txtFromDate").value = formatDate(firstDay);
                document.getElementById("txtToDate").value = formatDate(firstSaturday);
            }
        } else {
            document.getElementById("txtFromDate").value = "";
            document.getElementById("txtToDate").value = "";
        }
        debugger
        document.getElementById("chkIs_WO").checked = false;
        var RosterCmpID = $("#ddlCompanyName").val();
        var RosterBranchID = $("#ddlRosterBranchID").val();
        var Task="ShiftDropdownOnly";
        OnBranchChange(RosterCmpID,RosterBranchID,Task);
    });

    // Delete row function
    function deleteRow(element) {
        var row = element.closest("tr");
        row.remove();
        // Reinitialize DataTable after deletion
        if ($.fn.DataTable && $.fn.DataTable.isDataTable("#tblAttendance")) {
            $("#tblAttendance").DataTable().destroy();
        }
        $("#tblAttendance").DataTable({
            destroy: true,
            drawCallback: function () {
                console.log("DataTable redrawn");
            }
        });
    }

