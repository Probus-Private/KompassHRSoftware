<script>
    $(document).ready(function () {
        var hasError = true;
        $(document).on('change', '#txtCOff', function() {
            debugger;
            var currentRow=$(this).closest("tr");
            var ChangeCOff = currentRow.find('#txtCOff').val();
            var OldCoff = $('#hdnspnCOff').data('noofcoffdays');
            if(ChangeCOff > OldCoff)
            {
                currentRow.find('#txtCOff').css('color', 'red');
                currentRow.find('#ErrortxtCOff').css('display', 'flex');
                currentRow.find('#ErrortxtCOff').html("Invalid Coff");
                hasError = false;
            }
            else {
                currentRow.find('#txtCOff').css('color', 'black');
                currentRow.find('#ErrortxtCOff').css('display', 'none');
                currentRow.find('#ErrortxtCOff').html("");
            }
        });

        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlDepartmentId").select2();
        $("#ddlSubDepartmentId").select2();
        $("#ddlDesignationId").select2();
        $("#ddlLineId").select2();
        $("#ddlGradeId").select2();
        $("#ddlContractorId").select2();
        $("#ddlSubUnitId").select2();

        var CheckEmptyDate = document.getElementById('FromDate').value;
        if(CheckEmptyDate =="")
        {
            document.getElementById('ToDate').value = SetTodaysDate;
        }
        var today = new Date();
        today.setDate(today.getDate() - 30);
        var formattedDate = today.toISOString().split('T')[0];
        document.getElementById('FromDate').value = formattedDate;
        //COffApproval();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
        var GetPendingDate = @Html.Raw(Json.Encode(TempData["GetDate"]));
        if(GetPendingDate==null || GetPendingDate=="")
        {

        }
        else
        {
            var GetPendingDate1 =  convertDate(GetPendingDate);
            $("#FromDate").val(GetPendingDate1);
            $("#ToDate").val(GetPendingDate1);
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_TimeOffice_OTApproval")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });


        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlLineId").find("option").remove();
            $("#ddlEmployeeID").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var UnitBranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetUnit", "ESS_TimeOffice_OTApproval")',
                data: { CmpId: CmpId, UnitBranchId: UnitBranchId },
                success: function (data) {
                    debugger;
                    if (data == false) {
                        $("#ddlLineId").find("option").remove();

                        $("#ddlLineId").append("<option value=''>All </option>");
                        $("#ddlSubUnitId").find("option").remove();
                        $("#ddlSubUnitId").append("<option value=''>All </option>");
                    }
                    else {

                        var LineMaster = data.List_LineMaster;
                        var GetUnitName = data.GetUnitName;

                        debugger;
                        if (LineMaster != null) {
                            $("#ddlLineId").append("<option value=''>All </option>");
                            $.each(LineMaster, function (i, p) {
                                $("#ddlLineId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                        if (GetUnitName != null) {
                            // $("#ddlSubUnitId").append("<option value=''>All </option>");
                            $.each(GetUnitName, function (i, p) {
                                $("#ddlSubUnitId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                    }
                }
            })
        });

        $("#ddlDepartmentId").on("change", function () {
            debugger;
            $("#ddlSubDepartmentId").find("option").remove();
            var DepartmentId = $("#ddlDepartmentId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetSubDepartment", "ESS_TimeOffice_COffApproval")',
                data: { DepartmentId: DepartmentId },
                success: function (data) {
                    debugger;
