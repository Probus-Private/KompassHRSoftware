@model KompassHR.Areas.ESS.Models.ESS_TimeOffice.AttendanceLock
@{
    ViewBag.Title = "ESS_TimeOffice_AttendanceLock";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 100px; /* Set the width for the first column */
    }

    th:nth-child(2), td:nth-child(2) {
        width: 100px; /* Set the width for the first column */
    }

    th:nth-child(3), td:nth-child(3) {
        width: 100px; /* Set the width for the first column */
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Attendance Lock
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new {id = 5, ScreenId=150, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Attendance Lock<b></b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Attendance Lock.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("ESS_TimeOffice_AttendanceLock", "ESS_TimeOffice_AttendanceLock", new { area = "ESS" })' id="formAttendanceLock" method="post">
                                @*<div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <abel class="form-label col-form-label col-md-4">
                                                    Company Name
                                                </abel>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"),"--Select--" ,new { @class = "form-select", name = "CompanyName", id = "ddlCompanyName" })
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                                <div class="row mb-15px">
                                                    <label class="form-label col-form-label col-md-4">
                                                        Business Unit
                                                    </label>
                                                    <div class="col-md-8">
                                                        @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBusinessUnit, "Id", "Name"), new { @class = "form-select", type = "text", name = "BusinessUnit", id = "ddlBranchId" })
                                                    </div>
                                                </div>
                                            </div>
                                    </div>*@
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Month Year
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "Month", name = "FromDate", id = "txtMonthYear", required = "required" })
                                                @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-8">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="ShowBussinessUnit()">
                                                    Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr />
                                <div class="row">
                                    <div class="col-lg-12 overflow-auto">

                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblEmployees" style="width:100%;">
                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                <tr class="text-center">
                                                    <th hidden>CmpId</th>
                                                    <th hidden>BranchIdId</th>
                                                    <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsMenuCheckBox" value="value" onchange="checkAll(this)"> All</label></th>
                                                    <th class="text-nowrap text-center"> Company</th>
                                                    <th class="text-nowrap text-center"> Business Unit</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblBodyEmployees">
                                                @foreach (var d in ViewBag.Employees)
                                                {
                                                    <tr>
                                                        <td class="text-nowrap text-center" hidden>@d.CmpId</td>
                                                        <td class="text-nowrap text-center" hidden>@d.Id</td>
                                                        <td class="text-nowrap text-center">
                                                            <input type="checkbox" @d.CheckBox>
                                                        </td>
                                                        <td class="text-nowrap">@d.CompanyName</td>
                                                        <td class="text-nowrap">@d.Name</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("ESS_TimeOffice_Menu", "ESS_TimeOffice_Menu", new { id = 5, area = "ESS" })">
                                                        <button type="button" class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i> Back
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlCompanyName").select2();
        $("#ddlBranchId").select2();
        $("#ddlEmployeeName").select2();
        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;

        var CheckEmptyDate = document.getElementById('txtMonthYear').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtMonthYear').value = defaultMonth;
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }


        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#tblEmployeeWise tbody tr").detach();
            $("#tblEmployeeLog  tbody tr").detach();

            $("#ddlBranchId").find("option").remove();
            $("#ddlEmployeeName").find("option").remove();

            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_TimeOffice_AttendanceLock")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;

                    var Branch = data.Branch;
                    if (Branch != null) {
                        //$("#ddlBranchId").append("<option value=''>All </option>");
                        $.each(Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    var EmployeeName = data.EmployeeName;
                    if (EmployeeName != null) {
                        $("#ddlEmployeeName").append("<option value=''>--All-- </option>");
                        $.each(EmployeeName, function (i, p) {
                            $("#ddlEmployeeName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlBranchId").on("change", function () {
            $("#tblEmployeeWise tbody tr").detach();
            $("#tblEmployeeLog  tbody tr").detach();
            var CmpId = $("#ddlCompanyName").val();
            var UnitBranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetUnit", "ESS_TimeOffice_AttendanceLock")',
                data: { UnitBranchId: UnitBranchId, CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlEmployeeName").find("option").remove();
                        $("#ddlEmployeeName").append("<option value=''> --All-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            });
        });

    });

</script>

<script>
    jQuery.validator.addMethod(
     "regex",
         function(value, element, regexp) {
             if (regexp.constructor != RegExp)
                 regexp = new RegExp(regexp);
             else if (regexp.global)
                 regexp.lastIndex = 0;
             return this.optional(element) || regexp.test(value);
         },"erreur expression reguliere"
      );

    $('#formAttendanceLock').validate({
        rules: {
            CmpId:{
                required: true,
            },
        },
        messages: {
            CmpId:{
                required: "Company name is required",
            },
        },
    });
    var form = $("#formAttendanceLock");
    form.validate();
    function ShowBussinessUnit()
    {
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        $("#formAttendanceLock").submit();
    }

    function ShowEmployee() {
        var CmpId = $("#ddlCompanyName").val();
        var BranchId = $("#ddlBranchId").val();
        $.ajax({
            type: "Get",
            url: '@Url.Action("GetEmployees", "ESS_TimeOffice_AttendanceLock")',
            data: { CmpId: CmpId, BranchId: BranchId },
            dataType: "JSON",
            success: function (data) {
                debugger;
                var tableLogContent = '';
                for (var i = 0; i < data.data.length; i++) {
                    tableLogContent += '<tr>';
                    tableLogContent += '<td hidden>' + data.data[i][0].Value + '</td>';
                    tableLogContent += "<td><input type='checkbox'></td>";
                    tableLogContent += '<td>' + data.data[i][1].Value + '</td>';
                }
                $('#tblEmployees tbody').append(tableLogContent);
            }
        });

    }

    $("#btnSubmit").click(function () {
        debugger;
        var MonthYear = $("#txtMonthYear").val();
        var AttendanceLock = [];
        debugger;
        $("#tblBodyEmployees").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");
            data.CmpId =currentRow[0].cells[0].innerText;
            data.BranchId = currentRow[0].cells[1].innerText;
            AttendanceLock.push(data);
        });

        //if (AttendanceLock == "") {
        //    debugger;
        //    Swal.fire({
        //        icon: "error",
        //        text: "Select atleast one record",
        //        allowOutsideClick: () => {
        //            const popup = Swal.getPopup()
        //            popup.classList.remove('swal2-show')
        //            return false;
        //            setTimeout(() => {
        //                popup.classList.add('animate__animated', 'animate__headShake')
        //            })
        //            setTimeout(() => {
        //                popup.classList.remove('animate__animated', 'animate__headShake')
        //            }, 500)
        //            window.location.reload();
        //            return false
        //        }
        //    });
        //    return false;
        //}
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpdate", "ESS_TimeOffice_AttendanceLock")',
            data: JSON.stringify({ AttendanceLock: AttendanceLock,MonthYear:MonthYear}),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '@Url.Action("ESS_TimeOffice_AttendanceLock", "ESS_TimeOffice_AttendanceLock")';

                            } else if (
                                result.dismiss === Swal.DismissReason.cancel
                            ) {

                            }
                        })
                    }
                }
            }
        });
    });

    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>
