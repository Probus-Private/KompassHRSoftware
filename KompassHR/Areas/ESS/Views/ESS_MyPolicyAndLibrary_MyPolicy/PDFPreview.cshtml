@{
    ViewBag.Title = "PDFPreview";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    #as {
        height: 500px;
        width: 700px;
    }
</style>
<script src="https://mozilla.github.io/pdf.js/build/pdf.js"></script>

<section class="content-header">
    <h1>
        HR Policy
    </h1>
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard"  ,new { area = "Dashboard" })">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("ESS_MyPolicyAndLibrary_MyPolicy", "ESS_MyPolicyAndLibrary_MyPolicy", new { id = 1,  area = "ESS" })">Policy & Library Menu</a></li>
    </ol>
</section>
<section class="content">
    <div class="row">
        <div class="col-xs-12">
            <div class="box box-info">

                <div class="box-body">
                    <div id="app">
                        @*<embed src="#toolbar=0&navpanes=0&scrollbar=0" width="100%" height="600px" id="ViewPDF" />*@
                        @*<embed src="" width="100%" height="600px" id="ViewPDF" />*@
                        <embed src="@Url.Action("PDFPreview", "ESS_MyPolicyAndLibrary_MyPolicy")" width="100%" height="600px" id="ViewPDF" />

                        @* <embed src="~/assets/images/Test.pdf"/>*@
                        @*style="pointer-events: none;"*@
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(document).ready(function () {

       
        debugger;
        var GetPDFSrc = @(Html.Raw(Json.Encode(TempData["GetFileName"])));
        debugger;
        if(GetPDFSrc!="")
        {
            var GetPDFSrcNew = convertPath(GetPDFSrc);

            document.getElementById("ViewPDF").src = ""+GetPDFSrcNew+"#toolbar=0&navpanes=0&scrollbar=0";
            //document.getElementById("ViewPDF").src = "/assets/other/7.Attendance Policy.pdf#toolbar=0&navpanes=0&scrollbar=0";
        }

        function convertPath(path) {
            return path.replace(/\\/g, '/'); // Convert backslashes to forward slashes
        }



    });
</script>
