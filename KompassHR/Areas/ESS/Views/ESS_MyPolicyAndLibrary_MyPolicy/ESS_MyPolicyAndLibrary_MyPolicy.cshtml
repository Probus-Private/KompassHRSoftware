                                                    <a href="#" onclick="PolicyName('@d.DocumentPath.Replace("\\", "/")', '@d.PolicyLibraryId')" id="ViewPDF" embed src="">View Policy</a>
                                                   <embed src="" id="ViewPDF" />
                                                </div>
                                            </div>

                                        }
                                    </div>
                                </div>
                            </div>
                        </div>*@

              @{
                  var groupedPolicies = ((IEnumerable<dynamic>)ViewBag.GetEmployeeNamePolicy)
                                        .GroupBy(x => x.GroupName);
            }

            <div class="panel-body py-4" style="background: #f5f8ff;" id="PolicyLibrary">
                @foreach (var group in groupedPolicies)
                {
                    var firstPolicy = group.FirstOrDefault(); // take first policy for header concat

                    <div class="mb-4">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle policy-table">
                                <thead>
                                    <tr class="group-header">
                                        <th colspan="3">
                                            <i class="fa-solid fa-layer-group"></i>
                                            @group.Key - @firstPolicy.PolicyName
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in group)
                                    {
                                        <tr>
                                            <td class="text-center action-col">
                                                @{
                                                    string filePath = d.DocumentPath?.ToLower() ?? "";

                                                    bool isPdf = filePath.StartsWith("data:application/pdf") || filePath.EndsWith(".pdf");
                                                    bool isExcel = filePath.EndsWith(".xls") || filePath.EndsWith(".xlsx") || filePath.EndsWith(".csv");
                                                    bool isImage = filePath.EndsWith(".jpg") || filePath.EndsWith(".jpeg") ||
                                                                   filePath.EndsWith(".png") || filePath.EndsWith(".gif") ||
                                                                   filePath.EndsWith(".bmp") || filePath.StartsWith("data:image/");

                                                    bool isWord = filePath.EndsWith(".doc") || filePath.EndsWith(".docx") ||
                                                                  filePath.StartsWith("data:application/msword") ||
                                                                  filePath.StartsWith("data:application/vnd.openxmlformats-officedocument.wordprocessingml.document");
                                                }

                                                @if (isPdf)
                                                {
                                                    <a href="javascript:void(0);" onclick="showPDF('@d.DocumentPreview')" class="w-sm-200px">
                                                        <i class="fa fa-file-pdf text-danger fa-2x"></i>
                                                    </a>

                                                }
                                                else if (isWord)
                                                {
                                                    <a href="javascript:void(0);" onclick="showWord('@d.DocumentPreview')" class="w-sm-200px">
                                                        <i class="fa fa-file-word text-primary fa-2x"></i>
                                                    </a>
                                                }
                                                else if (isImage)
                                                {
                                                    <a href="javascript:void(0);" onclick="showImage('@d.DocumentPreview')" class="w-sm-200px">
                                                        <img class="mw-100 rounded" src="@d.DocumentPreview" alt="@d.DocumentPreview" />
                                                    </a>
                                                }
                                                else if (isImage)
                                                {
                                                    <a href="javascript:void(0);" onclick="showImage('@d.DocumentPreview')" class="w-sm-200px">
                                                        <img class="mw-100 rounded" src="@d.DocumentPreview" alt="@d.DocumentPreview" />
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a href="@d.FilePath" target="_blank" class="w-sm-200px d-block text-center border rounded p-3 bg-light">
                                                        <i class="fa fa-file text-secondary fa-2x"></i>
                                                        <div class="small text-muted mt-1">Other File</div>
                                                    </a>
                                                }

                                                @*<a href="#" onclick="PolicyName('@d.DocumentPath.Replace("\\", "/")', '@d.PolicyLibraryId')" class="btn btn-sm btn-outline-primary">
                                                    <i class="fa-solid fa-eye"></i>
                                                </a>*@
                                            </td>
                                            <td class="text">@d.Remark</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <style>
                .policy-table {
                    background: #fff;
                    border-radius: 10px;
                    overflow: hidden;
                    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
                }

                    .policy-table .group-header th {
                        background: #e9f2ff;
                        color: #0d6efd;
                        font-weight: 600;
                        font-size: 16px;
                        border-bottom: 2px solid #cfe2ff;
                        padding: 10px 12px;
                    }

                    .policy-table tr:hover {
                        background: #f8fbff;
                        transition: background 0.2s ease;
                    }

                    .policy-table td {
                        vertical-align: middle;
                        padding: 10px 12px;
                    }

                    .policy-table .action-col {
                        width: 50px;
                    }
            </style>


                </div>
            </div>
        </div>
    </div>
</body>
</html>

