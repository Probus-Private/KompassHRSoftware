<script>
    function showPDF(base64Data) {
        if (!base64Data) {
            Swal.fire({
                text: 'file not found!.',
                icon: 'info',
                allowOutsideClick: false
            });
            return false;
        }
        // Directly use base64 string
        const iframe = `<iframe src="${base64Data}#toolbar=0&navpanes=0&scrollbar=0"
                             width="100%" height="600px" style="border:none;"></iframe>`;

        $('#modalContent1').html(iframe);
        new bootstrap.Modal(document.getElementById('mediaModal')).show();
    }

    // It is not possible to preview this file, so it will be downloaded directly.
    function showWord(base64Data) {
        if (!base64Data) {
            Swal.fire({
                text: 'file not found!.',
                icon: 'info',
                allowOutsideClick: false
            });
            return false;
        }
        // Directly use base64 string
        const iframe = `<iframe src="${base64Data}#toolbar=0&navpanes=0&scrollbar=0"
                             width="100%" height="600px" style="border:none;"></iframe>`;

        $('#modalContent1').html(iframe);
        //new bootstrap.Modal(document.getElementById('mediaModal')).show();
    }

    function showImage(base64Data) {
        if (!base64Data) {
            Swal.fire({
                text: 'Image not found!.',
                icon: 'info',
                allowOutsideClick: false
            });
            return false;
        }
        const img = `<img src="${base64Data}" class="img-fluid rounded" />`;
        $('#modalContent1').html(img);
        new bootstrap.Modal(document.getElementById('mediaModal')).show();
    }


    function showExcel(base64Data) {
        if (!base64Data) {
            Swal.fire({
                text: 'Excel file not found!.',
                icon: 'info',
                allowOutsideClick: false
            });
            return false;
        }

        $.ajax({
            url: '@Url.Action("PreviewExcel", "ESS_MyPolicyAndLibrary_MyPolicy", new { area = "ESS" })',
            type: 'POST',
            data: { base64File: base64Data },
            success: function (res) {
                if (res.success) {
                    const iframe = `<iframe src="https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(res.url)}"
                                         width="100%" height="600px" style="border:none;"></iframe>`;
                    $('#modalContent1').html(iframe);
                    new bootstrap.Modal(document.getElementById('mediaModal')).show();
                } else {
                    Swal.fire({ icon: "error", text: res.message });
                }
            },
            error: function () {
                Swal.fire({ icon: "error", text: "Error while previewing file." });
            }
        });
    }



</script>