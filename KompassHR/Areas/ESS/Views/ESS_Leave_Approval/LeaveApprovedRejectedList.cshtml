<script>
    $(document).ready(function () {
        $('title').html("Leave Cancel Approval Request List");

        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('txtMonth').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtMonth').value = defaultMonth;
        }
    })
</script>


<script>
    function showList() {
        $("#ShowApproval").submit();
    }

      function ViewForApprover(DocId_Encrypted, Type) {
        debugger
        if (Type == 'Leave') {
            var url = '@Url.Action("ViewForLeaveRequestApprover", "ESS_Leave_Approval")?DocId_Encrypted=' + DocId_Encrypted + '&Type=' + Type;
            window.location.href = url;
        }
        if (Type == 'Coff') {
            var url = '@Url.Action("ViewForCOFFRequestApprover", "ESS_Leave_Approval")?DocId_Encrypted=' + DocId_Encrypted + '&Type=' + Type;
            window.location.href = url;
        }
    }
    var Resource = "";
    var ResourceEncrypted = "";
    function OpenModule(ResourceId, ResourceId_Encrypted) {
        debugger;
        Resource = ResourceId;
        ResourceEncrypted = ResourceId_Encrypted;
        $("#myModalFinal").modal('show');
    }


    function Approved(ResourceId, ResourceId_Encrypted) {
        debugger
        var DocId = "";
        var Encrypted = "";
        var Status = "";
        if (ResourceId_Encrypted != undefined) {
            DocId = ResourceId;
            Encrypted = ResourceId_Encrypted;
            Status = "Approved";
        }
        else {
            DocId = Resource;
            Encrypted = ResourceEncrypted;
            Status = "Rejected";
        }
        var Remark = "";
        if (Status == "Rejected") {
            Remark = $("#txtApproveRejectRemark").val();
        }

        $.ajax({
            url: "@Url.Action("ForApprovalCandidate", "ESS_Recruitment_Menu")",
            method: "get",
            data: { DocId: DocId, Encrypted: Encrypted, Status: Status, Remark: Remark },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });

                            $("#myModalFinal").modal('hide');
                            $("#txtApproveRejectRemark").val("");
                            location.reload();
                        }
                    }
                }
                else {
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon == "success") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                                $("#myModalFinal").modal('hide');
                                $("#txtApproveRejectRemark").val("");
                                location.reload();
                            }
                        }
                    }
                }
            }
        });
    }
</script>


<script>
    function AllApproveReject(Status) {
        debugger;
        var RecordList = new Array();
        $("#tbodyApproveReject").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");

            data.DocID = currentRow.find("td:eq(0)").html();
            data.DocId_Encrypted = currentRow.find("td:eq(1)").html();
            data.Origin = "Leave";
            data.Status = Status;
            RecordList.push(data);
        });

        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: "MultipleApproveRejectRequest",
            data: JSON.stringify({ ObjRecordList: RecordList }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("ESS_Leave_Approval", "ESS_Leave_Approval")';
                        window.location.href = url;
                    });
                }

                @*var url = '@Url.Action("Inbox", "Inbox")';
                window.location.href = url;*@
            }
        });
    }

    //Select All Checkboxes
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>

