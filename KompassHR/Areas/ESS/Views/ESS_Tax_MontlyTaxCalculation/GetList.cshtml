                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

    function showList() {
        $("#SaveMonthlyTaxDetails").submit();
    }
</script>










<script>
    function TaxDetails(TaxCal_MonthYear, TaxCal_FyearID,TaxCal_CmpID) {
        debugger
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetTaxDetails", "ESS_Tax_MontlyTaxCalculation")',
            data: { TaxCal_MonthYear, TaxCal_FyearID ,TaxCal_CmpID},
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                const data = JSON.parse(response);
                const modal = $('#modalTaxDetails');
                const tableBody = $('#tblBodyTaxDetails');

                // Clear table body (except headers)
                if ($.fn.DataTable.isDataTable('#tblTaxdetailsHead')) {
                    $('#tblTaxdetailsHead').DataTable().clear().destroy();
                }

                if (data && data.length > 0) {
                    modal.modal('show');

                    data.forEach(item => {
                        const row = $('<tr>');

                        const getCellValue = (key) => {
                            const cell = item.find(e => e.Key === key);
                            return cell ? cell.Value : '';
                        };

                        row.append(`<td><center><input type="checkbox" class="form-check-input"/></center></td>`);
                        row.append(`<td>${getCellValue("TaxCal_Id")}</td>`);
                        row.append(`<td>${getCellValue("TaxCal_EmployeeID")}</td>`);
                        row.append(`<td>${getCellValue("TaxCal_MonthYear")}</td>`);
                        row.append(`<td>${getCellValue("ShortName")}</td>`);
                        row.append(`<td>${getCellValue("BranchName")}</td>`);
                        row.append(`<td>${getCellValue("EmployeeName")}</td>`);
                        row.append(`<td>${getCellValue("EmployeeNo")}</td>`);
                        row.append(`<td>${getCellValue("TaxCal_Net_Tax_Payable")}</td>`);

                        tableBody.append(row);
                    });
                } else {
                    modal.modal('hide');
                }
            }
        });
    }



    function funSave() {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger
                $("#SelectAll").prop("checked", false);
                var ObjDelete = [];
                var MonthlyTaxMonthYear=$("#MonthlyTaxMonthYear").val();
                // Iterate through checked checkboxes in the table body only
                $('#tblBodyTaxDetails :checkbox:checked').each(function () {

                    var row = $(this).closest('tr'); // Get the closest row
                    var data = {
                        TaxCal_Id: row.find('td').eq(1).text(), 
                        TaxCal_EmployeeID:row.find('td').eq(2).text(), 
                        TaxCal_MonthYear:row.find('td').eq(3).text(), 
                        // Hidden column
                    };

                    // Push the data object to the array
                    ObjDelete.push(data);
                });
                $("#modalTaxDetails").modal('hide');
                $(".Userloaderbg").css("display", "flex");
                $.ajax({

                    url: '@Url.Action("DeleteMonthlyTaxDetails", "ESS_Tax_MontlyTaxCalculation")',
                    type: "POST",
                    data: JSON.stringify({ ObjDelete: ObjDelete,MonthlyTaxMonthYear: MonthlyTaxMonthYear }),
                    contentType: "application/json; charset=utf-8",
                    dataType: "text",
                    success: function (response) {
                        debugger;
                        var data = JSON.parse(response);
                        var Message1 = data.Message;
                        var Icon1 = data.Icon;
                        var Month1 = data.Month;
                        if (data != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("GetList", "ESS_Tax_MontlyTaxCalculation")';
                                    } else if (
                                        /* Read more about handling dismissals below */
                                        result.dismiss === Swal.DismissReason.cancel
                                    ) {

                                    }
                                })
                            }
                        }
                    }
                });

            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }



    function downloadExcelFile(TaxCal_MonthYear, TaxCal_FyearID,TaxCal_CmpID) {
        debugger
        $(".Userloaderbg").css("display", "flex");
        var MonthlyTaxMonthYear= $("#MonthlyTaxMonthYear").val();
        var MonthYear = encodeURIComponent(TaxCal_MonthYear);
        var FyearID = encodeURIComponent(TaxCal_FyearID);
        var CmpId=encodeURIComponent(TaxCal_CmpID);
        var url = `@Url.Action("DownloadExcelFile", "ESS_Tax_MontlyTaxCalculation")?MonthYear=${MonthYear}&FyearID=${FyearID}&CmpId=${CmpId}`;
        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }

                var formattedDate = convertMonthYearFormat(TaxCal_MonthYear);
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'MonthlyTaxCalculation('+formattedDate+').xlsx';
                anchorElement.click();
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }
</script>