                                    </label>
                                    <div class="col-md-4">
                                        @Html.TextBoxFor(model => model.MonthlyTaxMonthYear, new { id = "MonthlyTaxMonthYear", type = "month", @class = "form-select", autocomplete = "off", name = "MonthlyTaxMonthYear" })


                                        @*@Html.DropDownListFor(model => model.TaxFyearId, new SelectList(ViewBag.GetTaxFyear, "Id", "Name"), "--Select--", new { id = "TaxFyearId", @class = "form-select", autocomplete = "off", name = "TaxFyearId" })*@
