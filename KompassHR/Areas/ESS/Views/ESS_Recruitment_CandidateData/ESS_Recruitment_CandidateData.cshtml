@model KompassHR.Areas.ESS.Models.ESS_Recruitment.Recruitment_Resume
@{
    ViewBag.Title = "ESS_Recruitment_CandidateData";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<style>
    .card-row-title {
        color: blue;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }


    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }



    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }


    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }


    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .Error {
        color: red;
    }

    select[readonly].select2-hidden-accessible + .select2-container .select2-selection {
        background: #eee;
        box-shadow: none;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Candidate Data
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_Recruitment_Menu", "ESS_Recruitment_Menu", new {id = 1, ScreenId=126, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>

                </li>

            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Candidate Data - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>

                    </div>
                </div>

                <div class="card-body p-4 bg-light row g-4 mb-4">
                    <!-- From Section -->
                    <div class="col-md-4 col-sm-12">
                        <div class="card h-100 border-0 shadow-sm" style="border-radius: 8px; transition: transform 0.2s;">
                            <div class="card-body">
                                <h6 class="text-muted mb-3" style="font-family: 'Roboto', sans-serif; font-size: 0.9rem;">
                                    <i class="fa-solid fa-arrow-left text-secondary me-2"></i><b>From</b>
                                </h6>
                                <address class="fs-6" style="line-height: 1.8; color: #333;">
                                    <i class="fa-solid fa-user me-2 text-info"></i>
                                    <strong>@ViewBag.ResourceApprovalList.EmployeeName</strong><br>
                                    <i class="fa-solid fa-building me-2 text-warning"></i>
                                    <b>Department:</b> @ViewBag.ResourceApprovalList.EmpDepartmentName<br>
                                    <i class="fa-regular fa-handshake me-2 text-success"></i>
                                    <b>Designation:</b> @ViewBag.ResourceApprovalList.EmpDesignationName<br>
                                    <i class="fa-solid fa-phone-volume me-2 text-danger"></i>
                                    <b>Phone:</b> +91-@ViewBag.ResourceApprovalList.companymobileno<br>
                                    <i class="fa-solid fa-envelope me-2 text-primary"></i>
                                    <b>Email:</b> @ViewBag.ResourceApprovalList.CompanyMailID<br>
                                    <i class="fa-solid fa-file-invoice me-2 text-primary"></i>
                                    <b>Requisition No:</b> @ViewBag.ResourceApprovalList.ResourceId


                                </address>
                            </div>
                        </div>
                    </div>

                    <!-- For Section -->
                    <div class="col-md-4 col-sm-12">
                        <div class="card h-100 border-0 shadow-sm" style="border-radius: 8px; transition: transform 0.2s;">
                            <div class="card-body">
                                <h6 class="text-muted mb-3" style="font-family: 'Roboto', sans-serif; font-size: 0.9rem;">
                                    <i class="fa-solid fa-arrow-right text-secondary me-2"></i><b>For</b>
                                </h6>
                                <address class="fs-6" style="line-height: 1.8; color: #333;">
                                    <i class="fa-solid fa-building me-2 text-warning"></i>
                                    <b>Department:</b> @ViewBag.ResourceApprovalList.DepartmentName<br>
                                    <i class="fa-solid fa-desktop me-2 text-primary"></i>
                                    <b>Job Title:</b> @ViewBag.ResourceApprovalList.DesignationName<br>
                                    <i class="fa-solid fa-briefcase me-2 text-success"></i>
                                    <b>No. of Positions:</b> @ViewBag.ResourceApprovalList.TotalPositions<br />
                                    <i class="fa-solid fa-file-contract me-2 text-danger"></i>
                                    <b>Legal Bond:</b> @ViewBag.ResourceApprovalList.LegalBond -
                                    @ViewBag.ResourceApprovalList.LegalBondDuration Months
                                </address>
                            </div>
                        </div>
                    </div>

                    <!-- Dates Section -->
                    <div class="col-md-4 col-sm-12">
                        <div class="card h-100 border-0 shadow-sm" style="border-radius: 8px; transition: transform 0.2s;">
                            <div class="card-body">
                                <h6 class="text-muted mb-3" style="font-family: 'Roboto', sans-serif; font-size: 0.9rem;">
                                    <i class="fa-solid fa-calendar-days text-secondary me-2"></i><b>Dates</b>
                                </h6>
                                <div class="fs-6" style="line-height: 1.8; color: #333;">
                                    <i class="fa-solid fa-calendar-plus me-2 text-success"></i>
                                    <b>Opening Date:</b> @ViewBag.ResourceApprovalList.DocDate<br>
                                    <i class="fa-solid fa-calendar-xmark me-2 text-danger"></i>
                                    <b>Closing Date:</b> @ViewBag.ResourceApprovalList.ClosingDate
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Recruitment_CandidateData", new { area = "ESS" })' id="SaveCandidateData" method="post" enctype="multipart/form-data">
                                @*<form action="/ESS/ESS_Recruitment_CandidateData/SaveUpdate" id="SaveCandidateData" method="post" enctype="multipart/form-data">*@
                                @*<div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Requisition No.
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", id = "DocNo", type = "text", autocomplete = "Off", Value = @ViewBag.ResourceApprovalList.ResourceId, @readonly = "readonly", Style = "background-color: #eee;" })

                                                </div>
                                            </div>
                                        </div>

                                    </div>*@
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", id = "DocNo", type = "text", autocomplete = "Off", Value = @ViewBag.DocNo.DocNo, @readonly = "readonly", Style = "background-color: #eee;" })
                                                @Html.HiddenFor(model => model.ResumeId_Encrypted, new { id = "ResumeId_Encrypted" })
                                                @Html.HiddenFor(model => model.ResumeId)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", id = "txtDocDate", type = "date", name = "DocDate", autocomplete = "Off", @readonly = "readonly", Style = "background-color: #e9ecef;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Candidate Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Salutation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Salutation, new List<SelectListItem>{
                                                new SelectListItem {Text ="Mr.", Value="Mr."},
                                                new SelectListItem {Text ="Ms.", Value="Ms."},
                                                 new SelectListItem {Text ="Mrs.", Value="Mrs."},
                                              }, "--Select--", new { @class = "form-select", name = "Salutation", @id = "txtSalutationName" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-4">
                                                Candidate Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CandidateName, new { @class = "form-control", id = "txtCandidateName", type = "text", name = "CandidateName", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Mobile No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", id = "txtMobileNo", type = "text", name = "MobileNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">

                                            <label class="form-label col-form-label col-md-4">
                                                Alternate Mobile No

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.AlternateMobileNo, new { @class = "form-control", id = "txtAlternateMobileNo", type = "text", name = "AlternateMobileNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>

                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Email Id
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EmailId, new { @class = "form-control", id = "txtEmailId", type = "text", name = "EmailId", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Gender
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Gender, new List<SelectListItem>{
                                                                          new SelectListItem {Text ="Male", Value="Male"},
                                                                          new SelectListItem {Text ="Female", Value="Female"},
                                                                           new SelectListItem {Text ="Any", Value="Any"},
                                                                        }, "--Select--", new { @class = "form-select", id = "txtGender", type = "text", name = "Gender", autocomplete = "Off" })
                                                <span style="color:green;">Preferred Gender :@ViewBag.ResourceApprovalList.PreferredGender</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Date Of Birth
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DOB, new { @class = "form-control", id = "txtDOB", type = "date", name = "DOB", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Age

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Age, new { @class = "form-control", id = "txtAge", type = "number", name = "Age", autocomplete = "Off", onkeypress = "return event.charCode >=48", @readonly = "readonly", style = "background-color:#eee;" })
                                                <span id="ErrortxtAge" class="Error">
                                                </span>
                                                <span style="color:green;">Preferred Age :@ViewBag.ResourceApprovalList.MinAge-@ViewBag.ResourceApprovalList.MaxAge</span>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current City
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CurrentCity, new { @class = "form-control", id = "txtCurrentCity", type = "text", name = "CurrentCity", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Marital Status
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.MaritalStatus,
                                               new List<SelectListItem>{new SelectListItem {Text ="Unmarried", Value="Unmarried"},
                                                                        new SelectListItem {Text ="Married ", Value="Married "},
                                                                           new SelectListItem {Text ="Widow", Value="Widow"},
                                                                        }, "--Select--", new { @class = "form-select", id = "txtMaritalStatus", type = "text", name = "MaritalStatus", autocomplete = "Off" })
                                                <span style="color:green;">Preferred Marital Status :@ViewBag.ResourceApprovalList.PreferredMaritalStatus</span>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Highest Qualification <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.HighestQualification, new SelectList(ViewBag.GetQualificationName, "Id", "Name"), "--Select--", new { id = "txtHighestQualification", @class = "form-select", autocomplete = "off", name = "HighestQualification" })
                                                <span style="color:green;">Preferred Qualification :@ViewBag.ResourceApprovalList.Qualification</span>

                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Specific Qualification <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.QualificationRemark, new { @class = "form-control", id = "txtQualificationRemark", type = "text", name = "QualificationRemark", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Nationality

                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.Nationality, new SelectList(ViewBag.GetNationalityName, "Name", "Name"), new { id = "txtNationality", @class = "form-select", autocomplete = "off", name = "Nationality" })
                                                @*@Html.TextBoxFor(model => model.Nationality, new { @class = "form-control", id = "txtNationality", type = "text", name = "Nationality", autocomplete = "Off" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Family Info

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.FamilyDetails, new { @class = "form-control", id = "txtFamilyDetails", type = "text", name = "FamilyDetails", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <hr class="mt-0">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Candidate Experince
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Candidate Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CandidateType,
                                                   new List<SelectListItem>{new SelectListItem {Text ="Fresher", Value="Fresher"},
                                                   new SelectListItem {Text ="Intern", Value="Intern"},
                                                   new SelectListItem {Text ="Experience", Value="Experience"},
                                                  }, "--Select--", new { @class = "form-select", id = "txtCandidateType", type = "text", name = "CandidateType", autocomplete = "Off" })
                                                <span style="color:green;">Preferred Candidate Type :@ViewBag.ResourceApprovalList.CandidateType</span>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Currently Working
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CurrentlyWorking,
                                                new List<SelectListItem>{new SelectListItem {Text ="Yes ", Value="true"},
                                                   new SelectListItem {Text ="No", Value="false"},
                                                  }, "--Select--", new { @class = "form-select", id = "txtCurrentlyWorking", type = "text", name = "CurrentlyWorking", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.CurrentlyWorking, "", new { @class = "help-block", @id = "ErrorCurrentlyWorking", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LastCompanyName, new { @class = "form-control", id = "txtLastCompanyName", type = "text", name = "LastCompanyName", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.LastCompanyName, "", new { @class = "help-block", @id = "ErrorLastCompanyName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Total Experience<span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.TotalExperience, new { @class = "form-control", id = "txtTotalExperience", type = "text", name = "TotalExperience", autocomplete = "Off", Maxlength = 2, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.TotalExperience, "", new { @class = "help-block", @id = "ErrorTotalExperience", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Relevant Experience<span class="important">*</span>
                                            </label>
