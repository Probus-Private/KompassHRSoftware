<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<script>

    $(document).ready(function () {
        debugger;
        $("#DivResumeReferEmployeeId").hide();
        $("#DivResumeJobPortal").hide();
        var LeaglBond = @Html.Raw(Json.Encode(TempData["LeaglBoand"]));
        var HoldingOffer = @Html.Raw(Json.Encode(TempData["HoldingAnyOffer"]));
        var ResumeSource = @Html.Raw(Json.Encode(TempData["ResumeSource"]));
        if(ResumeSource!=null)
        {
            $("#txtResumeSource").val(ResumeSource).select2();
        }

        if(HoldingOffer=="No")
        {
            $("#txtOfferRemark").attr("disabled", "disabled");
        }
        else{
            $("#txtOfferRemark").removeAttr("disabled");
        }
        if(LeaglBond=="No")
        {
            $("#txtBondMonth").attr("disabled", "disabled");
        }
        else{
            $("#txtBondMonth").removeAttr("disabled");
        }
        var GetCandidateType = $("#txtCandidateType").val();
        debugger;
        if(GetCandidateType=="Experience")
        {
            $("#txtBondMonth").removeAttr("disabled");
            $("#txtCurrentlyWorking").removeAttr("disabled");
            $("#txtLastCompanyName").removeAttr("disabled");
            $("#txtTotalExperience").removeAttr("disabled");
            $("#txtRelevantExperience").removeAttr("disabled");
            $("#txtLastDesignation").removeAttr("disabled");
            $("#txtSutableForDesignation").removeAttr("disabled");

            $("#txtOfferRemark").removeAttr("disabled");
        }
        if(GetCandidateType=="Intern")
        {
            $("#txtLastDesignation").attr("disabled", "disabled");

            $("#txtServingNoticePeriod").attr("disabled", "disabled");
            $("#txtNoticePeriodDays").attr("disabled", "disabled");
        }
        if(GetCandidateType=="Fresher")
        {
            $("#txtCurrentlyWorking").attr("disabled", "disabled");
            $("#txtLastCompanyName").attr("disabled", "disabled");
            $("#txtTotalExperience").attr("disabled", "disabled");
            $("#txtRelevantExperience").attr("disabled", "disabled");
            $("#txtServingNoticePeriod").attr("disabled", "disabled");
            $("#txtNoticePeriodDays").attr("disabled", "disabled");
            $("#txtLastDesignation").attr("disabled", "disabled");

        }

        $("#txtSutableForDesignation").select2();
        $("#txtHrSelection").select2();
        $("#txtHrRanking").select2();
        $("#txtResumeSource").select2();
        $("#txtHighestQualification").select2();
        $("#txtResumeReferEmployeeId").select2();
        $(".LastWorkingDay").hide();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }


        $('#txtSalutationName').on('change', function () {
            var salutation = $(this).val();
            var gender = '';

            if (salutation === "Mr.") {
                gender = "Male";
            } else if (salutation === "Ms." || salutation === "Mrs.") {
                gender = "Female";
            } else {
                gender = "";
            }

            // Set gender
            $('#txtGender').val(gender).trigger('change');

            // Make dropdown readonly (disable mouse/keyboard interaction)
            if (gender !== "") {
                $('#txtGender').css({
                    'pointer-events': 'none',       // prevent click
                    'background-color': '#f9f9f9',  // visually readonly
                    'cursor': 'not-allowed'
                });
            } else {
                // Re-enable if salutation is cleared
                $('#txtGender').css({
                    'pointer-events': 'auto',
                    'background-color': '',
                    'cursor': ''
                });
            }
        });

        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000)).toISOString().split("T")[0];
