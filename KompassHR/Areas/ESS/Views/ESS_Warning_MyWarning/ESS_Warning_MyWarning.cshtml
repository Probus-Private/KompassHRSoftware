@*@model KompassHR.Areas.ESS.Models.ESS_Warning.Warning_Employee*@
@{
    ViewBag.Title = "ESS_Warning_MyWarning";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int count = 1;
}

<style>
    

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>My Warning</title>
</head>
<body>
    <div id="content" class="app-content">
        <!-- BEGIN breadcrumb -->
        <ol class="breadcrumb float-xl-end">
            <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active"><a href="/ESS/ESS_WorkForce_Menu/ESS_WorkForce_Menu/?id=29">Warning Menu </a></li>

        </ol>
        <!-- END breadcrumb -->
        <!-- BEGIN page-header -->
        <h1 class="page-header">My Warning</h1>
        <!-- END page-header -->
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">My Warning</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                               data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            View performance assessment and ratings here!
                        </p>
                        @Html.Hidden("WarningEmpID_Encrypted", new { id = "WarningEmpID_Encrypted" })
                    </div>

                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle" id="data-table-combine" style="width: 100%;">
                                            <thead>
                                                <tr>
                                                    <th class="text-nowrap">Sr.No</th>
                                                    <th class="text-nowrap text-center">Action</th>
                                                    <th class="text-nowrap">Doc No</th>
                                                    <th class="text-nowrap">Doc Date</th>
                                                    <th class="text-nowrap">Employee Name</th>
                                                    <th class="text-nowrap">Warning Type </th>
                                                    <th class="text-nowrap">Description</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblMyWarnings">
                                                @foreach (var d in ViewBag.GetMyWarning)
                                                {
                                                    <tr>                                                      
                                                        <td hidden>@d.WarningEmpID_Encrypted</td>
                                                        <td>@count </td>
                                                        <td class="text-nowrap">
                                                            @if (d.Status == "Accept")
                                                            {
                                                                <button type="button" disabled class="btn btn-success btn-sm btnpress" onclick="ApproveReject('@d.WarningEmpID_Encrypted','Accept')">
                                                                    Accept
                                                                </button>
                                                            }
                                                            else if (d.Status == "NotAccept")
                                                            {
                                                                <button type="button" disabled class="btn btn-danger ListBtn btnpress" onclick="OpenModal('@d.WarningEmpID_Encrypted','NotAccept')">
                                                                    Not Accept
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button" class="btn btn-success btn-sm btnpress" onclick="ApproveReject('@d.WarningEmpID_Encrypted','Accept')">
                                                                    Accept
                                                                </button>
                                                                <button type="button" class="btn btn-danger ListBtn btnpress" onclick="OpenModal('@d.WarningEmpID_Encrypted','NotAccept')">
                                                                    Not Accept
                                                                </button>
                                                            }
                                                        </td>
                                                        <td class="text-nowrap">@d.DocNo</td>
                                                        <td class="text-nowrap">@d.DocDate</td>
                                                        <td class="text-nowrap">@d.EmployeeName</td>
                                                        <td class="text-nowrap">@d.WarningType</td>
                                                        <td class="text-nowrap">@d.Description</td>
                                                    </tr>
                                                    count++;
                                                }
                                               
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- END panel -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- #Start Appprove Reject Modal -dialog -->
    <div class="modal fade" id="myModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header bg-black text-white">
                    <h4 class="modal-title">Warning Remark For Not Accept</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal"
                           aria-hidden="true">
                            <i class="fa fa-xmark"></i>
                        </a>
                    </div>
                </div>
                <div class="modal-body">
                    <!-- BEGIN panel -->
                    <div class="modal-body-content">
                        <div class="row">
                            <div class="col-md-12">
                                <form>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="row mb-15px">
                                                <textarea id="txtRejectRemark" class="form-control" rows="4"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
                <div class="modal-footer">                   
                        <button type="button" onclick="ApproveReject()" id="btnReject" class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-floppy-disk"> </i> Submit
                        </button>
                        <button type="button" id="btnCancel" class="btn btn-danger btnpress btnClear" data-bs-dismiss="modal">
                            <i class="fa-solid fa-share-from-square"></i> Cancel
                        </button>                   
                </div>
            </div>
        </div>
    </div>
    <!-- #End modal-dialog -->
</body>
</html>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>

    function UpdateTeamReview(EmployeeReviewId_Encrypted) {
        var url = '@Url.Action("ESS_EmployeeReview_TeamReview", "ESS_EmployeeReview_TeamReview")?EmployeeReviewId_Encrypted=' + EmployeeReviewId_Encrypted;
        window.location.href = url;
    }



    function DeleteTeamReview(EmployeeReviewId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "ESS_EmployeeReview_TeamReview")?EmployeeReviewId_Encrypted=' + EmployeeReviewId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }


    var  RejctWarningEmpIDEncrypted ="";
    var  RejecttestStatus ="";
    function OpenModal(WarningEmpID_Encrypted1,Status1){
        debugger;

        RejctWarningEmpIDEncrypted = WarningEmpID_Encrypted1;
        RejecttestStatus = Status1;
        $("#myModal").modal('show');
    }

    function ApproveReject(WarningEmpID_Encrypted,Status) {
        debugger;
        var Remark="";
        if (RejecttestStatus == "NotAccept") {
            WarningEmpID_Encrypted  = RejctWarningEmpIDEncrypted;
            Status =RejecttestStatus;
            Remark = $("#txtRejectRemark").val();
        }
        $.ajax({
            url:"IsApprovedOrRejectedCheck",
            method:"get",
            data:{WarningEmpID_Encrypted:WarningEmpID_Encrypted,Remark:Remark,Status:Status},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    $("#myModal").modal('hide');
                                    $("#txtRejectRemark").val("");
                                    window.location.href = '@Url.Action("ESS_Warning_MyWarning", "ESS_Warning_MyWarning")';
                                } else if (
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })
                        }
                    }
                }
                else{
                    if (Message1 != null) {
                        if (Icon1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    $("#myModal").modal('hide');
                                    $("#txtRejectRemark").val("");
                                    window.location.href = '@Url.Action("ESS_Warning_MyWarning", "ESS_Warning_MyWarning")';

                                } else if (
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })
                        }
                    }
                }               
            }
        });

    }
</script>



