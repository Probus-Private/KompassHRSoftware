@model KompassHR.Areas.ESS.Models.ESS_ManpowerAllocation.KPI_CriticalStage
@{
    ViewBag.Title = "ESS_ManpowerAllocation_CriticalStage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>


<style>
    .Col-md-2 {
        margin: 10px 0;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .tblAddData td:nth-child(2) {
        display: none;
    }

    .tblAddData td:nth-child(3) {
        display: none;
    }

    .tblAddData td:nth-child(4) {
        display: none;
    }
</style>
<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("ESS_ManpowerAllocation_Menu", "ESS_ManpowerAllocation_Menu", new { id = 35, area = "ESS" })">Manpower Menu</a></li>
    </ol>
    <h1 class="page-header"> Critical Stage </h1>
    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Critical Stage </h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row">
                            <div class="col-md-12">
                                <form role="form" action='@Url.Action("ESS_ManpowerAllocation_CriticalStage", "ESS_ManpowerAllocation_CriticalStage", new { area = "ESS" })' id="SaveCriticalStage" method="post">
                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Company Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCmpId", type = "text", name = "CmpId" })

                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Business Unit
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.KPICriticalStageBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtKPICriticalStageBranchId", type = "text", name = "KPICriticalStageBranchId" })
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    From date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.CriticalStageFromDate, new { @class = "form-control", id = "txtCriticalStageFromDate", type = "date", name = "CriticalStageFromDate" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    To Date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.CriticalStageToDate, new { @class = "form-control", id = "txtCriticalStageToDate", type = "date", name = "CriticalStageToDate" })
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Grade
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CriticalStageGradeId, new SelectList(ViewBag.GetGradeList, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCriticalStageGradeId", type = "text", name = "CriticalStageGradeId" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Department Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CriticalStageDepartmentId, new SelectList(ViewBag.GetDepatmentList, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCriticalStageDepartmentId", type = "text", name = "CriticalStageDepartmentId" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <div class="row mb-15px">
                                                <div class="col-md-4">
                                                    <button type="button" class="btn btn-primary btn-sm" id="btnShow" onclick="LoadEmployee()">
                                                        @*<i class="fa-solid fa-share-from-square"></i>*@ Show
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Category Name

                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CriticalStageCategoryId, new SelectList(ViewBag.GetCriticalCategoryList, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCriticalStageCategoryId", type = "text", name = "CriticalStageCategoryId" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <div class="row mb-15px">
                                                <div class="col-md-4">
                                                    <button type="button" class="btn btn-primary btn-sm" id="btnApply">
                                                        @*<i class="fa-solid fa-share-from-square"></i>*@Apply
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="table-scroll div1">
                                            <div class="table-wrap">
                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage tblAddData" id="tblCriticalStage" style="width: 100%;">
                                                    <thead>
                                                        <tr class="trheading">
                                                            <th class="text-nowrap text-center">Select</th>
                                                            <th hidden class="text-nowrap text-center">Employee Id</th>
                                                            <th hidden class="text-nowrap text-center">ShiftGroupId</th>
                                                            <th hidden class="text-nowrap text-center">ShiftRuleId</th>
                                                            <th class="text-nowrap text-center">Employee Card No </th>
                                                            <th class="text-nowrap text-center">Employee Name </th>
                                                            <th class="text-nowrap text-center">Designation Name</th>
                                                            <th class="text-nowrap text-center">Contractor Name</th>
                                                            <th class="text-nowrap text-center">Line Name</th>
                                                            <th class="text-nowrap text-center">Shift Group Name</th>
                                                            <th class="text-nowrap text-center">Shift Rule Name</th>
                                                            @*<th class="text-nowrap text-center">Employee SubDepartment Name</th>*@
                                                            <th class="text-nowrap text-center">Joining Date</th>
                                                            <th class="text-nowrap text-center">Critical Stage Category</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblGetCriticalStage">
                                                        @foreach (var d in ViewBag.GetEmployeeList)
                                                        {
                                                            <tr>
                                                                <td class="text-center">
                                                                    <input type="checkbox" class="form-check-input" data-checked="email-checkbox" />
                                                                </td>
                                                                <td class="text-nowrap">@d.EmployeeId</td>
                                                                <td class="text-nowrap">@d.ShiftGroupId</td>
                                                                <td class="text-nowrap">@d.ShiftRuleId</td>
                                                                <td class="text-nowrap">@d.EmployeeCardNo</td>
                                                                <td class="text-nowrap">@d.EmployeeName</td>
                                                                @*<td class="text-nowrap">@d.DepartmentName</td>*@
                                                                <td class="text-nowrap">@d.DesignationName</td>
                                                                <td class="text-nowrap">@d.BusinessArea</td>
                                                                <td class="text-nowrap">@d.LineName</td>
                                                                <td class="text-nowrap">@d.ShiftGroupSName</td>
                                                                <td class="text-nowrap">@d.ShiftRuleSName</td>
                                                                @*<td class="text-nowrap">@d.EmployeeSubDepartmentName</td>*@
                                                                <td class="text-nowrap">@d.joininggdate</td>
                                                                <td>
                                                                    <input type="text" class="form-control TotalCriticalStageCategory" id="TbltextCriticalStageCategory" style="width:230px" disabled="disabled" />
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">

                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit"
                                                                    class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                                            </button>
                                                            <a href="@Url.Action("GetList", "ESS_ManpowerAllocation_CriticalStage", new { area = "ESS" })">
                                                                <button type="button" id="btnGetList"
                                                                        class="btn btn-danger btn-sm">
                                                                    <i class="fa-solid fa-share-from-square"></i>
                                                                    List
                                                                </button>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger;
        $("#txtKPICriticalStageBranchId").select2();
        $("#txtCmpId").select2();
        $("#txtCriticalStageGradeId").select2();
        $("#txtCriticalStageDepartmentId").select2();
        $("#txtCriticalStageCategoryId").select2();
        $("#txtCmpId").on("change", function () {
            debugger;
            $("#txtKPICriticalStageBranchId").find("option").remove();
            var CmpId = $("#txtCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_ManpowerAllocation_CriticalStage")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#txtKPICriticalStageBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#txtKPICriticalStageBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

