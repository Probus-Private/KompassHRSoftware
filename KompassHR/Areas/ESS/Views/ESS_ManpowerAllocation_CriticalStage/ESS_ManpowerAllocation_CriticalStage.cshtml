        }*@

    })



    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveCriticalStage').validate({
        rules: {
            CmpID: {
                required: true,
            },
            KPICriticalStageBranchId: {
                required: true,
            },
            CriticalStageFromDate: {
                required: true,
            },
            CriticalStageToDate: {
                required: true,
            },
            CriticalStageGradeId: {
                required: true,
            },
            CriticalStageDepartmentId: {
                required: true,
            },


        },
        messages: {
            CmpID: {
                required: "Company name is required",
            },
            KPICriticalStageBranchId: {
                required: "Business unit is required",
            },
            CriticalStageFromDate: {
                required: "From date is required",
            },
            CriticalStageToDate: {
                required: "To date is required",
            },
            CriticalStageGradeId: {
                required: "Grade is required",
            },
            CriticalStageDepartmentId: {
                required: "Department name is required",
            },


        },
    });

    var form = $("#SaveCriticalStage");
    form.validate();
    function LoadEmployee() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#txtCriticalStageFromDate").removeClass("error");
            $("#txtCriticalStageToDate").removeClass("error");
            return false;
        }
        $("#SaveCriticalStage").submit();
    }
    $("#btnApply").click(function () {
        var CategoryName = $('#txtCriticalStageCategoryId option:selected').html()
        $(".TotalCriticalStageCategory").val(CategoryName);
    })
</script>

<script>
    $("#btnSubmit").click(function () {
        debugger;
        var CmpId = $("#txtCmpId").val();
        var KPICriticalStageBranchId = $("#txtKPICriticalStageBranchId").val();
        var CriticalStageFromDate = $("#txtCriticalStageFromDate").val();
        var CriticalStageToDate = $("#txtCriticalStageToDate").val();
        var CriticalStageGradeId = $("#txtCriticalStageGradeId").val();
        var CriticalStageDepartmentId = $("#txtCriticalStageDepartmentId").val();
        var CriticalStageCategoryId = $("#txtCriticalStageCategoryId").val();

        var TaskKPI = new Array();
        $(':checkbox:checked').each(function (i) {
            debugger;
            var data1 = {};
            var currentRow = $(this).closest("tr");
            data1.CriticalStageEmployeeId = currentRow[i].children[1].innerHTML;
            data1.CriticalStageShiftGroupId = currentRow[i].children[2].innerHTML;
            data1.CriticalStageShiftRuleId = currentRow[i].children[3].innerHTML;
            TaskKPI.push(data1);

        });

        if (TaskKPI.length == 0) {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        else {
            $.ajax({
                type: "POST",
                url: '@Url.Action("GetBusinessUnit", "ESS_ManpowerAllocation_CriticalStage")',
                data: JSON.stringify({ TaskKPI: TaskKPI, CmpId: CmpId, KPICriticalStageBranchId: KPICriticalStageBranchId, CriticalStageFromDate: CriticalStageFromDate, CriticalStageToDate: CriticalStageToDate, CriticalStageGradeId: CriticalStageGradeId, CriticalStageDepartmentId: CriticalStageDepartmentId, CriticalStageCategoryId: CriticalStageCategoryId }),
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    var DATA = JSON.parse(response);
                    var Message1 = DATA.Message;
                    var Icon1 = DATA.Icon;
                    if (Icon1 == "success") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                })
                               .then(function () {
                                   window.location.reload();
                                   $("#txtCmpId").val("").select2();
                                   $("#txtKPICriticalStageBranchId").val("");
                                   $("#txtCriticalStageFromDate").val("");
                                   $("#txtCriticalStageToDate").val("");
                                   $("#txtCriticalStageGradeId").val("");
                                   $("#txtCriticalStageDepartmentId").val("");

                               });
                            }
                        }
                    }
                }
            });
        }

        //var table = document.getElementById("tblGetCriticalStage");
        //var rowCount = table.rows.length;
        //var TaskKPI =[];
        //debugger;
        //var data1 = {};
        //for (i = 0; i <= rowCount-1; i++) {
        //    debugger;
        //    var data1 = {};
        //    data1.CriticalStageEmployeeId = table.rows[i].cells[1].textContent;
        //    data1.CriticalStageShiftGroupId = table.rows[i].cells[2].textContent;
        //    data1.CriticalStageShiftRuleId = table.rows[i].cells[3].textContent;
        //    TaskKPI.push(data1);
        //}


    });
</script>
