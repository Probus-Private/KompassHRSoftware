@model KompassHR.Areas.ESS.Models.ESS_ManpowerAllocation.KPI_CriticalStage
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

</style>

<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/ESS/ESS_ManpowerAllocation_Menu/ESS_ManpowerAllocation_Menu">Manpower Allocation Menu</a></li>
    </ol>
    <h1 class="page-header"> Critical Stage List </h1>



    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Critical Stage List </h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row">
                            <div class="col-md-12">
                               
                                        <a href="/ESS/ESS_ManpowerAllocation_CriticalStage/ESS_ManpowerAllocation_CriticalStage">
                                            <button type="button" class="btn btn-success btnpress  mb-10px">
                                                <i class="fa-solid fa-plus"></i> &nbsp; Add New
                                            </button>
                                        </a>
                               
                                        <form role="form" action="/ESS/ESS_ManpowerAllocation_CriticalStage/GetList" id="SaveCriticalStage" method="post">
                                            <div class="row">
                                                <div class="col-md-5">
                                                    <div class="row mb-15px">
                                                        <label class="form-label col-form-label col-md-4">
                                                            Company Name
                                                            <span class="important">*</span>
                                                        </label>
                                                        <div class="col-md-8">
                                                            @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCmpId", type = "text", name = "CmpId" })

                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-5">
                                                    <div class="row mb-15px">
                                                        <label class="form-label col-form-label col-md-4">
                                                            Business Unit
                                                            <span class="important">*</span>
                                                        </label>
                                                        <div class="col-md-8">
                                                            @Html.DropDownListFor(model => model.KPICriticalStageBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtKPICriticalStageBranchId", type = "text", name = "KPICriticalStageBranchId" })
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>

                                            <div class="row">
                                                <div class="col-md-5">
                                                    <div class="row mb-15px">
                                                        <label class="form-label col-form-label col-md-4">
                                                            Department Name
                                                            <span class="important">*</span>
                                                        </label>
                                                        <div class="col-md-8">
                                                            @Html.DropDownListFor(model => model.CriticalStageDepartmentId, new SelectList(ViewBag.GetDepatmentList, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCriticalStageDepartmentId", type = "text", name = "CriticalStageDepartmentId" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-5">
                                                    <div class="row mb-15px">
                                                        <label class="form-label col-form-label col-md-4">
                                                            Month
                                                            <span class="important">*</span>
                                                        </label>
                                                        <div class="col-md-8">
                                                            @Html.TextBoxFor(model => model.CriticalStageFromDate, new { @class = "form-control", id = "txtCriticalStageFromDate", type = "month", name = "CriticalStageFromDate" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-2">
                                                    <div class="row mb-15px">
                                                        <div class="col-md-4">
                                                            <button type="submit" class="btn btn-success btnpress" id="btnShow" onclick="LoadEmployee()">
                                                                @*<i class="fa-solid fa-share-from-square"></i>*@ Show
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row">
                                                <div class="table-scroll div1">
                                                    <div class="table-wrap">
                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage2" id="tblCriticalStage" style="width: 100%;">
                                                            <thead>
                                                                <tr class="trheading">
                                                                    <th class="text-nowrap text-center">Delete</th>
                                                                    <th class="text-nowrap text-center">Employee Name </th>
                                                                    <th class="text-nowrap text-center">Company Name </th>
                                                                    <th class="text-nowrap text-center">Branch Name</th>
                                                                    <th class="text-nowrap text-center">Department Name</th>
                                                                    <th class="text-nowrap text-center">Grade Name</th>
                                                                    <th class="text-nowrap text-center">Critical Category Name</th>
                                                                    <th class="text-nowrap text-center">Shift Group Name</th>
                                                                    <th class="text-nowrap text-center">Shift Rule Name</th>

                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblGetCriticalStage">
                                                                @foreach (var d in ViewBag.CriticalStageList)
                                                                {
                                                                    <tr>
                                                                        <td class="text-center">
                                                                            <button type="button" id="btnDelete" onclick="DeleteCriticalStage('@d.KPICriticalStageId_Encrypted')"
                                                                                    class="btn btn-danger ListBtn btnpress">
                                                                                <i class="fa-solid fa-trash-alt"></i>
                                                                            </button>
                                                                        </td>
                                                                        <td class="text-nowrap">@d.EmployeeName</td>
                                                                        <td class="text-nowrap">@d.CompanyName</td>
                                                                        <td class="text-nowrap">@d.BranchName</td>
                                                                        <td class="text-nowrap">@d.DepartmentName</td>
                                                                        <td class="text-nowrap">@d.GradeName</td>
                                                                        <td class="text-nowrap">@d.CriticalStageName</td>
                                                                        <td class="text-nowrap">@d.ShiftGroupSName</td>
                                                                        <td class="text-nowrap">@d.ShiftRuleName</td>


                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger;
        $("#txtKPICriticalStageBranchId").select2();
        $("#txtCmpId").select2();       
        $("#txtCriticalStageDepartmentId").select2();
      
        $("#txtCmpId").on("change", function () {
            debugger;
            $("#txtKPICriticalStageBranchId").find("option").remove();
            var CmpId = $("#txtCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#txtKPICriticalStageBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#txtKPICriticalStageBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    })



    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveCriticalStage').validate({
        rules: {
            CmpID: {
                required: true,
            },
            KPICriticalStageBranchId: {
                required: true,
            },
            CriticalStageFromDate: {
                required: true,
            },           
            CriticalStageDepartmentId: {
                required: true,
            },


        },
        messages: {
            CmpID: {
                required: "Company name is required",
            },
            KPICriticalStageBranchId: {
                required: "Business unit is required",
            },
            CriticalStageFromDate: {
                required: "From date is required",
            },
           
            CriticalStageDepartmentId: {
                required: "Department name is required",
            },


        },
    });

    var form = $("#SaveCriticalStage");
    form.validate();
    function LoadEmployee() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#txtCriticalStageFromDate").removeClass("error");      
            return false;
        }
        $("#SaveCriticalStage").submit();
    }   
</script>



<script>
    function DeleteCriticalStage(KPICriticalStageId_Encrypted) {
            const DeleteButtons = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            DeleteButtons.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Delete", "ESS_ManpowerAllocation_CriticalStage")?KPICriticalStageId_Encrypted=' + KPICriticalStageId_Encrypted;
                } else if (
                    /* Read more about handling dismissals below */
                    result.dismiss === Swal.DismissReason.cancel
                ) {

                }
            })
        }


</script>

