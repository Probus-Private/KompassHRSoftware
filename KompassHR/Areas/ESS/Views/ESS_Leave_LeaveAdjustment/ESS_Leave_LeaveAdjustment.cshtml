@model KompassHR.Areas.ESS.Models.ESS_Leave.Leave_Adjustment

@{
    ViewBag.Title = "ESS_Leave_LeaveAdjustment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .tblAddData td:nth-child(9) {
        display: none;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Adjustment
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Leave_Menu", "ESS_Leave_Menu", new {id = 4, ScreenId=145, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave Adjustment - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Refers to the process of modifying or updating an employee's leave balance for various reasons. Here's how leave balance adjustments typically work.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_Leave_LeaveAdjustment", new { area = "ESS" })' id="SaveLeaveAdjustment" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.ComapnyName, "Id", "Name"), "--Select--", new { @id = "ddlCompanyName", name = "CmpID", @class = "form-select", autocomplete = "off" })
                                                @Html.HiddenFor(model => model.LeaveAdjustmentId_Encrypted)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveAdjustmenBranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @id = "txtBranchId", name = "LeaveOpeningBalanceBranchID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveAdjustmentEmployeeId, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { @id = "ddlEmployeeName", name = "LeaveOpeningBalanceEmployeeId", @class = "form-select", autocomplete = "off", onChange = "ChangeConpany()" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Leave Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveAdjustmentSettingId, new SelectList(ViewBag.LeaveTypeName, "Id", "Name"), "--Select--", new { id = "ddlLeaveType", name = "LeaveTypeId", @class = "form-control", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Leave Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveAdjustmentYearId, new SelectList(ViewBag.GetLeaveYear, "Id", "Name"), "--Select--", new { id = "LeaveMasterLeaveYearId", name = "LeaveMasterLeaveYearId", @class = "form-control", autocomplete = "off" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                No Of Leave
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.NoOfLeave, new { id = "txtNoOfLeave", name = "NoOfLeave", @class = "form-control", type = "text", autocomplete = "off", onchange = "validateInput(this)", Maxlength = 5 })
                                                @Html.ValidationMessageFor(model => model.NoOfLeave, "", new { @class = "help-block", @id = "ErrorNoOfLeave", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Remark
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextAreaFor(model => model.AdjustmentRemark, new { id = "OpeningAdjCarryCredit_Remark", name = "OpeningAdjCarryCredit_Remark", @class = "form-control", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm" onclick="GetAllEmployeeInformation()">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>

    </div>
</div>

<script>
    $("#btnGetList").click(function () {
        window.location.href= '@Url.Action("GetList", "ESS_Leave_LeaveAdjustment", new { Area = "ESS" })';
    });


    $(document).ready(function () {
        $("#ddlCompanyName").select2();
        $("#ddlEmployeeName").select2();
        $("#txtBranchId").select2();
        $("#LeaveTypeId").select2();
        $("#ddlLeaveType").select2();
        $("#LeaveMasterLeaveYearId").select2();


        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "ESS_Leave_LeaveAdjustment")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data.data !=null) {
                        $("#txtBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data.data, function(i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });

                        //$("#LeaveMasterLeaveYearId").append("<option value=0>--Select-- </option>");
                        $.each(data.data1, function(i, p) {
                            $("#LeaveMasterLeaveYearId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });



        $("#txtBranchId").change(function () {
            debugger;
            $("#ddlEmployeeName").find("option").remove();
            var BranchId = $("#txtBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "ESS_Leave_LeaveAdjustment")',
                data: { BranchId: BranchId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlEmployeeName").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });

        $("#ddlEmployeeName").change(function () {
            debugger;
            $("#ddlLeaveType").find("option").remove();
            //var EmployeeId = Number($("#ddlEmployeeName").val());
            var CmpID = Number($("#ddlCompanyName").val());

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetLeaveType", "ESS_Leave_LeaveAdjustment")',
                data: { CmpID: CmpID },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlLeaveType").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlLeaveType").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });

    });//Ready Funcation

    function validateInput(input) {
        var textbox = document.getElementById('txtNoOfLeave');
        var textboxValue = textbox.value.trim(); // Trim whitespace from the input
        // Updated pattern to allow for 0.5, 1, 1.5, 2, 2.5, etc.
        //var pattern = /^(0\.5|[1-9]\d*(\.(0|5))?)$/;
        var pattern = /^-?\d+(\.\d+)?$/; // allow -20 also
        if (pattern.test(textboxValue)) {
            $("#ErrorNoOfLeave").html("");
        } else {
            textbox.value = ''; // Clear textbox value
            $("#ErrorNoOfLeave").html("0.5 is Constant");
        }
    }



    jQuery.validator.addMethod(
    "regex",
          function (value, element, regexp) {
              if (regexp.constructor != RegExp)
                  regexp = new RegExp(regexp);
              else if (regexp.global)
                  regexp.lastIndex = 0;
              return this.optional(element) || regexp.test(value);
          }, "erreur expression reguliere"
  );

    $("#SaveLeaveAdjustment").validate({
        rules: {
            CmpID: {
                required: true,
            },
            LeaveAdjustmenBranchId: {
                required: true,
            },
            LeaveAdjustmentEmployeeId: {
                required: true,
            },
            LeaveAdjustmentSettingId: {
                required: true,
            },
            LeaveAdjustmentYearId: {
                required: true,
            },
            NoOfLeave: {
                required: true,
            },
        },
        messages: {
            CmpID: {
                required: "Company Name is required"
            },
            LeaveAdjustmenBranchId: {
                required: "Business Unit is required",
            },
            LeaveAdjustmentEmployeeId: {
                required: "Employee Name  is required",
            },
            LeaveAdjustmentSettingId: {
                required: "Leave type is required",
            },

            LeaveAdjustmentYearId: {
                required: "Leave year is required",
            },

            NoOfLeave: {
                required: "Leave is required",
            },

        },
    });

    var form = $("#SaveLeaveAdjustment");
    form.validate();
    function GetAllEmployeeInformation() {
        debugger;
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        $("#SaveLeaveAdjustment").submit();
    }

</script>