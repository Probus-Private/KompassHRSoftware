
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<html>

<body>
    <div id="content" class="app-content">
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
                <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                    Advance Claim
                </h1>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ESS_ClaimReimbusement_Menu", "ESS_ClaimReimbusement_Menu", new {id = 8, ScreenId=172, area = "ESS" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                        </a>
                    </li>
                </ol>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">

                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Advance Claim - Approved List</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            This is the approved list of Advance claim.
                        </p>
                    </div>
                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="@Url.Action("ESS_ClaimReimbusement_ClaimAdvance", "ESS_ClaimReimbusement_ClaimAdvance", new { area = "ESS" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage" id="tblClaim_Travel" style="width: 100%;">
                                            <thead>
                                                <tr class="trheading">                                                    
                                                    <th class="fixed-side">Delete</th>
                                                    <th class="fixed-side1">Details</th>
                                                    <th class="text-nowrap">Auto/Manually</th>
                                                    <th class="text-nowrap text-center">Doc No</th>
                                                    <th class="text-nowrap text-center">Doc Date</th>                                                                                                                                                                                            
                                                    <th class="text-nowrap text-center">Approve Reject By</th>
                                                    <th class="text-nowrap text-center">Approve Reject Date</th>
                                                    <th class="text-nowrap text-center">Approve Reject Remark</th>
                                                    <th class="text-nowrap text-center">Created By</th>
                                                    <th class="text-nowrap text-center">Created Date</th>
                                                    <th class="text-nowrap text-center">Modified By</th>
                                                    <th class="text-nowrap text-center">Modified Date</th>
                                                    <th class="text-nowrap text-center">Machine Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetClaim_Advance)
                                                {
                                                    <tr>
                                                        
                                                        <td class="text-center fixed-side1">
                                                            <a onclick="DeleteTravelClaim('@d.AdvanceClaimId_Encrypted','@d.Status')" id="btnDelete" style="cursor:pointer">
                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                            </a>
                                                        </td>
                                                        <td class="text-center" style="width: 80px;">
                                                            <a onclick="View('@d.AdvanceClaimId')" id="btnView" style="cursor:pointer;">
                                                                <i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>
                                                            </a>
                                                        </td>
                                                        <td class="text-nowrap">
                                                            <i class="fa-solid fa-circle-info text-success fa-lg" style="cursor: pointer;" onclick="ApproveStatus(@d.TravelClaimId)"></i> &nbsp;
                                                            @d.ApprovedDay
                                                        </td>
                                                        <td class="text-nowrap">@d.AutoApproval</td>
                                                        <td class="text-nowrap" style="text-align:right">@d.DocNo</td>
                                                        <td class="text-nowrap">@d.DocDate</td>                                                      
                                                        <td class="text-nowrap">@d.ApprovedByName</td>
                                                        <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                        <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                        <td class="text-nowrap">@d.CreatedBy</td>
                                                        <td class="text-nowrap">@d.CreatedDate</td>
                                                        <td class="text-nowrap">@d.ModifiedBy</td>
                                                        <td class="text-nowrap">@d.ModifiedDate</td>
                                                        <td class="text-nowrap">@d.MachineName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- END panel -->
                    </div>
                </div>
            </div>
        </div>
    </div>


</body>
</html>

<!-- #Start modal-dialog -->
<div class="modal fade" id="AdvanceClaimListModel" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title" id="ClaimListTitle"></h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body" style="height: 500px; overflow-y: auto;">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div class="table-scroll">
                                                <div class="table-wrap">
                                                    <table class="table table-bordered table-hover mb-0 table-wrap align-middle" id="tblEmployeeLog">
                                                        <thead>
                                                            <tr>
                                                                <th class="text-nowrap text-center">S.N</th>
                                                                <th class="text-nowrap text-left">From Date</th>
                                                                <th class="text-nowrap text-left">To Date</th>
                                                                <th class="text-nowrap text-left">From Location</th>
                                                                <th class="text-nowrap text-left">To Location</th>
                                                                <th class="text-nowrap text-left">Purpose</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="tbodyAdvanceClaimDetailsList"></tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>


<script>
    function View(AdvanceClaimId) {
        debugger;
        var url = '@Url.Action("ShowAdvanceClaimDetails", "ESS_ClaimReimbusement_ClaimAdvance")';
        $.getJSON(url, {
            AdvanceClaimId: AdvanceClaimId            
        }, function (data) {
            debugger;
            const jsonData = JSON.parse(data);
            $('#AdvanceClaimListModel').modal('show');
            $('#ClaimListTitle').text('Advance Claim Details List'); // Set the modal title
            $("#tbodyAdvanceClaimDetailsList").empty();
            $.each(jsonData, function (index, item) {
                debugger;
                var row = `<tr>
                                <td class="text-center">${item.SN}</td>
                                <td class ="text-left">${item.FromDate}</td>
                                <td class ="text-left">${item.ToDate}</td>
                                <td class ="text-left">${item.FromLocation}</td>
                                <td class ="text-left">${item.ToLocation}</td>
                                <td class ="text-left"></td>
                           </tr>`;
                $("#tbodyAdvanceClaimDetailsList").append(row);
            });
        });
    }
</script>