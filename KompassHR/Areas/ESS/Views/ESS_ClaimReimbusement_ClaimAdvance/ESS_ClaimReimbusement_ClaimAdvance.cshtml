</style>



<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Advance Claim
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new {area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_ClaimReimbusement_Menu", "ESS_ClaimReimbusement_Menu", new { id = 8, ScreenId =172, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Settings">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Advance Claim </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>

                <div class="panel-body">
                    <form role="form" action='@Url.Action("GetInOutData", "ESS_UpdateLineManpowerDesignationMapping", new { area = "ESS" })' id="SaveLetter" method="post" data-parsley-validate="">
                        
                        <div class="row">
                            <div class="col-md-12">
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered TablePageRemovePagination" id="fixed-header" style="width: 100%;">
                                            <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                <tr class="text-center">                                                 
                                                    <th>From Location</th>
                                                    <th>To Location</th>
                                                    <th>From Date</th>
                                                    <th>To Date</th>
                                                    <th>Reason</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody id="claimBody">
                                                <tr>                                                    
                                                    <td><input type="text" name="FromLocation" class="form-control FromLocation" /></td>
                                                    <td><input type="text" name="ToLocation" class="form-control ToLocation" /></td>
                                                    <td><input type="date" name="FromDate" class="form-control FromDate" /></td>
                                                    <td><input type="date" name="ToDate" class="form-control ToDate" /></td>
                                                    <td><input type="text" name="Reason" class="form-control Reason" /></td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-success addRow">+</button>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <br />
                        <div class="row">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                </button>

                                                <a href="@Url.Action("GetList", "ESS_ClaimReimbusement_ClaimAdvance", new { area = "ESS" })">
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnDesignationGetList">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    

    $(document).on("click", ".addRow", function () {
        var row = `<tr>
        
        <td><input type="text" name="FromLocation" class ="form-control FromLocation"/></td>
        <td><input type="text" name="ToLocation" class ="form-control ToLocation"/></td>
        <td><input type="date" name="FromDate" class ="form-control FromDate"/></td>
        <td><input type="date" name="ToDate" class ="form-control ToDate"/></td>
        <td><input type="text" name="Reason" class ="form-control Reason"/></td>

        <td class="text-center">
            <button type="button" class="btn btn-danger removeRow">-</button>
        </td>
    </tr>`;
        $("#claimBody").append(row);
    });

    $(document).on("click", ".removeRow", function () {
        $(this).closest("tr").remove();
    });
</script>


<script>
    $("#btnSubmit").click(function (e) {
        debugger
        var ClaimData = [];

        $("#claimBody tr").each(function () {

            var obj = {};
            debugger
            obj.FromLocation = $(this).find(".FromLocation").val();
            obj.ToLocation = $(this).find(".ToLocation").val();
            obj.FromDate = $(this).find(".FromDate").val();
            obj.ToDate = $(this).find(".ToDate").val();
            obj.AdvancePurposeId = 1; //$(this).find(".Reason").val();

            ClaimData.push(obj);
        });

    
        if (ClaimData.length == 0) {
            var Message = "Add atleast one record";
            var Icon = "error";
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)

                            return false
                        }
                    })
                    return false;
                }
            }
        }

        $.ajax({
            url: '@Url.Action("SaveUpdate", "ESS_ClaimReimbusement_ClaimAdvance")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(ClaimData),
            success: function (response) {
                debugger;
                // var data = JSON.parse(response);
                var data = response;
                var Message = data.Message;
                var Icon = data.Icon;
                if (data != null) {

                    $(".Userloaderbg").css("display", "none");
                    if (Message != null) {
                        Swal.fire({
                            icon: Icon,
                            text: Message,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '@Url.Action("ESS_ClaimReimbusement_ClaimAdvance", "ESS_ClaimReimbusement_ClaimAdvance")';
                            } else if (
                                result.dismiss === Swal.DismissReason.cancel
                            ) {

                            }
                        })
                    }
                }

            }
        });

    });
</script>