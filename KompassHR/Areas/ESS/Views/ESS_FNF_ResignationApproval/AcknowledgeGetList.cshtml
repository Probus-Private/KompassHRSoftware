<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
              Resignation Approval
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Acknowledged Employee -List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Acknowledged Employee.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                          
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="TablePage"
                                           style="width: 100%;">
                                        <thead class="text-center">
                                            <tr>
                                               
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Employee No</th>
                                                <th class="text-nowrap">Department</th>
                                                <th class="text-nowrap">Designation</th>
                                                <th class="text-nowrap">Grade</th>
                                                <th class="text-nowrap">Date of Joining</th>
                                                <th class="text-nowrap">Resignation No</th>
                                                <th class="text-nowrap">Resignation Date</th>
                                                <th class="text-nowrap">Last Working Date</th>
                                                <th class="text-nowrap">Notice Period</th>
                                                <th class="text-nowrap">End Notice Period Date</th>
                                                <th class="text-nowrap">Reason</th>
                                                <th class="text-nowrap">Is Immediate Relieve</th>
                                                <th class="text-nowrap">Is Notice Period Purchase</th>
                                                <th class="text-nowrap">Resigned Employee Remark</th>
                                                <th class="text-nowrap">Acknowledgement By </th>
                                                <th class="text-nowrap">Acknowledgement Date </th>
                                                <th class="text-nowrap">Acknowledgement Remark </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetFNFAcknowledgementCompleteList)
                                            {
                                                <tr>
                                                    
                                                    <td>@d.EmployeeName</td>
                                                    <td class="text-center">@d.EmployeeNo</td>
                                                    <td>@d.Department</td>
                                                    <td>@d.Designation</td>
                                                    <td>@d.Grade</td>
                                                    <td class="text-center">@d.DOJ</td>
                                                    <td class="text-center">@d.ResignationNo</td>
                                                    <td class="text-center">@d.ResignationDate</td>
                                                    <td class="text-center">@d.LastWorkingDate</td>
                                                    <td class="text-center">@d.NoticePeriod</td>
                                                    <td class="text-center">@d.NoticePeriodEndDate</td>
                                                    <td class="text-center">@d.Reason</td>
                                                    <td class="text-nowrap">@d.IsImmediatelyRelieve</td>
                                                    <td class="text-nowrap">@d.IsNoticePeriodPurchase</td>
                                                    <td class="text-start text-center">
                                                        @if (!string.IsNullOrEmpty(d.Remark))
                                                        {
                                                            <input type="hidden" id="hiddenDescription_@d.ResignId" value="@d.Remark" />
                                                                        <i class="fa-solid fa-receipt fa-lg" onclick="ResignedEmpRemark(encodeURIComponent(document.getElementById('hiddenDescription_@d.ResignId').value))" style="cursor:pointer; color: #ff5b57;"></i>

                                                        }
                                                    </td>
                                                    <td class="text-nowrap">@d.AcknowledgeBy</td>
                                                    <td class="text-nowrap">@d.AcknowledgedDate</td>
                                                    <td class="text-start text-center">
                                                        @if (!string.IsNullOrEmpty(d.AcknowledgementRemark))
                                                        {
                                                            <input type="hidden" id="hiddenDescription_@d.FnfAcknowledgementId" value="@d.AcknowledgementRemark" />
                                                            <i class="fa-solid fa-receipt fa-lg" onclick="AcknowledgedRemark(encodeURIComponent(document.getElementById('hiddenDescription_@d.FnfAcknowledgementId').value))" style="cursor:pointer; color: #ff5b57;"></i>

                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>

                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="LastShortLeaveBx">
                            <div class="row">
                                <div class="col-md-12 text-end">
                                    <div class="BtnBx">
                                        <div>
                                            <a href="@Url.Action("ESS_FNF_ResignationApproval", "ESS_FNF_ResignationApproval", new { area = "ESS" })">
                                                <button type="button" class="btn btn-danger btn-sm" id="btnTrainingAgency">
                                                    <i class="fa-solid bi-file-arrow-down"></i> Back
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>
<!-- #Start modal-dialog -->
<div class="modal fade" id="modal_basic3" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Remark</h4>
                <div class="panel-heading-btn">

                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div id="txtRemark"></div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" id="btnCancel" class="btn btn-success btnpress" onclick="dismissModal('modal_basic3')">
                    <i class="fa-solid fa-floppy-disk"> </i> Ok
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->
<script>
    function ResignedEmpRemark(encodedHtml) {
        debugger
        $('#txtRemark').html('');
        const Remark = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtRemark').html(Remark);
            //$('#txtRemark').summernote('pasteHTML', WorkOnTask);
        });
    }

    function AcknowledgedRemark(encodedHtml)
    {debugger;
        $('#txtRemark').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtRemark').html(AssignDesc);
            //$('#txtRemark').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#' + modalId).modal('hide');
    }
</script>
<script>
    $(document).ready(function () {
        $('title').html("Employee Resignation");
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>


