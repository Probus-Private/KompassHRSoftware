                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
        <div class="row mb-20px">
            <div class="LastShortLeaveBx">
                <div class="row">
                    <div class="col-md-12">
                        <div class="BtnBx">
                            <div>
                                <a href="@Url.Action("AcknowledgeGetList", "ESS_FNF_ResignationApproval", new { id = 7, ScreenId = 171, area = "ESS" })">
                                    <button type="button" id="btnGetList"
                                            class="btn btn-success btn-sm">
                                        <i class="fa-solid fa-share-from-square"></i>
