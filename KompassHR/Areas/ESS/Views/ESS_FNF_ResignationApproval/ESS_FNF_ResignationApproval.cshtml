                    .nav-tabs .nav-link.active {
                        background-color: #eee !important; /* Background for selected tab */
                        color: #000000 !important; /* Text color for selected tab */
                        font-weight: bold;
                        border-color: #ddd #ddd #fff;
                    }
                </style>

                @{
                    var headerColor = Session["HeaderColor"] != null ? Session["HeaderColor"].ToString() : "#49b6d6";
                    var headerTextColor = Session["HeaderTextColor"] != null ? Session["HeaderTextColor"].ToString() : "#ffffff";
                }
                <div class="row">
                    <div class="col-md-12">
                        <!-- BEGIN tabs -->

                        <ul class="nav nav-tabs nav-tabs-inverse nav-justified"
