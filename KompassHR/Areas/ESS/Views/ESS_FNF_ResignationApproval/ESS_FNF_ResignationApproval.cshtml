                                                                    <i class="fas fa-handshake action-icon icon-acknowledge" onclick="Acknowledge('@d.EmployeeId','@d.ResignId')"></i>
                                                                </td>
                                                                <td hidden>@d.EmployeeId</td>
                                                                <td>@d.EmployeeName</td>
                                                                <td class="text-center">@d.EmployeeNo</td>
                                                                <td>@d.Department</td>
                                                                <td>@d.Designation</td>
                                                                <td>@d.Grade</td>
                                                                <td class="text-center">@d.DOJ</td>
                                                                <td class="text-center">@d.ResignationNo</td>
                                                                <td class="text-center">@d.ResignationDate</td>
                                                                <td class="text-center">@d.LastWorkingDate</td>
                                                                <td class="text-center">@d.NoticePeriod</td>
                                                                <td class="text-center">@d.NoticePeriodEndDate</td>
                                                                <td class="text-center">@d.Reason</td>
                                                                <td class="text-nowrap">@d.IsImmediatelyRelieve</td>
                                                                <td class="text-nowrap">@d.IsNoticePeriodPurchase</td>
                                                                <td class="text-start text-center">
                                                                    @if (!string.IsNullOrEmpty(d.Remark))
                                                                    {
                                                                        <input type="hidden" id="hiddenDescription_@d.ResignId" value="@d.Remark" />
                                                                        <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.ResignId').value))" style="cursor:pointer; color: #ff5b57;"></i>

                                                                    }
                                                                </td>
                                                                <td class="text-center">
                                                                    @if (@d.AttachedFileName != "")
                                                                    {
                                                                        <a href="@Url.Action("DownloadAttachment", "ESS_FNF_ResignationApproval", new { DownloadAttachment = @d.AttachedFileName })"><i class="fa fa-download"></i></a>
                                                                    }
                                                                    else
                                                                    {
                                                                        <i class="fa-solid fa-xmark" style="color: red;"></i>
                                                                    }
                                                                </td>

                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>

                                            </div>
                                        </div>
                                    </div>
                                </div>

                            }
                                <div class="tab-pane fade show @activeTabApproval" id="tabResignedEmployee">
                                    <div class="h-400px p-3" data-scrollbar="true">
                                        <div class="table-scroll">
                                            <div class="table-wrap">
                                                <table class="table table-bordered align-middle TablePage2" id="tbl1" style="width: 100%;">
                                                    <thead class="text-center">
                                                        <tr>
                                                            <th class="text-nowrap">Action</th>
                                                            <th class="text-nowrap" hidden>Feedback</th>
                                                            <th class="text-nowrap" hidden>Employee Id</th>
                                                            <th class="text-nowrap">Employee Name</th>
                                                            <th class="text-nowrap">Employee No</th>
                                                            <th class="text-nowrap">Department</th>
                                                            <th class="text-nowrap">Designation</th>
                                                            <th class="text-nowrap">Grade</th>
                                                            <th class="text-nowrap">Date of Joining</th>
                                                            <th class="text-nowrap">Resignation No</th>
                                                            <th class="text-nowrap">Resignation Date</th>
                                                            <th class="text-nowrap">Last Working Date</th>
                                                            <th class="text-nowrap">Relieving Date</th>
                                                            <th class="text-nowrap">Notice Period</th>
                                                            <th class="text-nowrap">Notice Period end Date</th>
                                                            <th class="text-nowrap">Reason</th>
                                                            <th class="text-nowrap">Is Immediate Relieve</th>
                                                            <th class="text-nowrap">Is Notice Period Purchase</th>
                                                            <th class="text-nowrap">Resigned Employee Remark</th>
                                                            <th class="text-nowrap">Attachment</th>
                                                            <th class="text-nowrap">Approval Remark</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var d in ViewBag.GetFNFApprovalPendingList)
                                                        {
                                                            <tr>
                                                                <!-- View Action -->
                                                                <td class="text-center">
                                                                    <i class="fas fa-eye action-icon icon-view" onclick="ViewForApprover('@d.ResignId','@d.NoticePeriod','@d.NoticePeriodEndDate')"></i>
                                                                </td>
                                                                <td class="text-center" hidden>
                                                                    <i class="fas fa-comment-dots action-icon icon-feedback" onclick="FeedbackQuestion('@d.FnfId_Encrypted','@d.EmployeeId')"></i>
                                                                </td>
                                                                <td hidden>@d.EmployeeId</td>
                                                                <td class="text-center">@d.EmployeeName</td>
                                                                <td class="text-center">@d.EmployeeNo</td>
                                                                <td class="text-center">@d.Department</td>
                                                                <td class="text-center">@d.Designation</td>
                                                                <td class="text-center">@d.Grade</td>
                                                                <td class="text-center">@d.DOJ</td>
                                                                <td class="text-center">@d.ResignationNo</td>
                                                                <td class="text-center">@d.ResignationDate</td>
                                                                <td class="text-center">@d.LastWorkingDate</td>
                                                                <td class="text-center">@d.RelievingDate</td>
                                                                <td class="text-center">@d.NoticePeriod</td>
                                                                <td class="text-center">@d.NoticePeriodEndDate</td>
                                                                <td class="text-center">@d.Reason</td>
                                                                <td class="text-nowrap">@d.IsImmediatelyRelieve</td>
                                                                <td class="text-nowrap">@d.IsNoticePeriodPurchase</td>
                                                                <td class="text-start text-center">
                                                                    @if (!string.IsNullOrEmpty(d.Remark))
                                                                    {
                                                                        <input type="hidden" id="hiddenDescription_@d.ResignId" value="@d.Remark" />
                                                                        <i class="fa-solid fa-receipt fa-lg" onclick="AssignTaskDesc(encodeURIComponent(document.getElementById('hiddenDescription_@d.ResignId').value))" style="cursor:pointer; color: #ff5b57;"></i>

                                                                    }
                                                                </td>
                                                                <td class="text-center">
                                                                    @if (@d.AttachedFileName != "")
                                                                    {
                                                                        <a href="@Url.Action("DownloadAttachment","ESS_FNF_ResignationApproval", new { DownloadAttachment = @d.AttachedFileName })"><i class="fa fa-download"></i></a>
                                                                    }
                                                                    else
                                                                    {
                                                                        <i class="fa-solid fa-xmark" style="color: red;"></i>
