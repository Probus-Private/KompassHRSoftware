</div>
<!-- Button to trigger modal -->
<button id="btnSelectDateTime" class="btn btn-primary">Select Date and Time</button>

<!-- Modal for Date and Time Selection -->
<div class="modal fade" id="dateTimeModal" tabindex="-1" aria-labelledby="dateTimeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title"></h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="datePicker" class="form-label"><b>Select Date:</b></label><span class="important">*</span>
                    <input type="date" id="datePicker" class="form-control" />
                    <span id="dateError" class="text-danger d-none">Please select a valid date.</span>
                </div>
                <div class="mb-3">
                    <label for="timePicker" class="form-label"><b>Select Time:</b></label><span class="important">*</span>
                    <input type="time" id="timePicker" class="form-control" />
                    <span id="timeError" class="text-danger d-none">Please select a valid time.</span>
                </div>
                <div class="mb-3">
                    <label for="Remark" class="form-label"><b>Remark:</b></label>
                    <textarea id="txtAcknowledgeRemark" class="form-control" rows="4"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="saveDateTime">Save</button>
            </div>
