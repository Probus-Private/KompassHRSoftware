<script>
    function ViewForApprover(ResignId, NoticePeriod, NoticePeriodEndDate) {
        debugger
        var formattedDate = new Date(NoticePeriodEndDate).toISOString().split("T")[0];
        var baseUrl = '@Url.Action("ViewForRequestApprover", "ESS_FNF_ResignationApproval")';
        var url = baseUrl
                + '?ResignId=' + encodeURIComponent(ResignId)
                + '&NoticePeriod=' + encodeURIComponent(NoticePeriod)
                + '&NoticePeriodEndDate=' + encodeURIComponent(formattedDate);
        window.location.href = url;
    }

    function FeedbackQuestion(FnfId_Encrypted, EmployeeId) {
        debugger
        var url = '@Url.Action("ESS_FNF_ExitFeedbackManager", "ESS_FNF_ResignationApproval")?FnfId_Encrypted=' + FnfId_Encrypted + '&EmployeeId=' + EmployeeId;
        window.location.href = url;
    }

    function Acknowledge(EmployeeId, ResignId) {
        debugger;
        // Store the EmployeeId in a data attribute on the modal
        $('#dateTimeModal').data('employeeId', EmployeeId);
        $('#dateTimeModal').data('resignId', ResignId);
        $('#dateTimeModal').modal('show');
    }

    $('#saveDateTime').click(function () {
        debugger
        var EmployeeId = $('#dateTimeModal').data('employeeId');
        var ResignId = $('#dateTimeModal').data('resignId');
        var Date = $('#datePicker').val();
        var Time = $('#timePicker').val();
        var Remark = $('#txtAcknowledgeRemark').val();

        // Reset previous errors
        $('#dateError').addClass('d-none');
        $('#timeError').addClass('d-none');

        // Validate Date and Time
        var isValid = true;
        if (!Date) {
            $('#dateError').removeClass('d-none');
            isValid = false;
        }
        if (!Time) {
            $('#timeError').removeClass('d-none');
            isValid = false;
        }
        if (!isValid) return; // Stop if validation fails

        $.getJSON('@Url.Action("SheduleAcknowledge", "ESS_FNF_ResignationApproval")',
        {
            EmployeeId: EmployeeId,
            ResignId: ResignId,
            Date: Date,
            Time: Time,
            Remark: Remark
        },
        function (response) {
            var Message1 = response.Message;
            var Icon1 = response.Icon;

            if (Message1) {
                Swal.fire({
                    icon: Icon1,
                    text: Message1,
                    allowOutsideClick: false,
                    showConfirmButton: true,
                    showCancelButton: false
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#dateTimeModal').modal('hide');
                        window.location.href = '@Url.Action("ESS_FNF_ResignationApproval", "ESS_FNF_ResignationApproval")';
                    }
                });
            }
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.error("Error:", textStatus, errorThrown);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while processing your request'
            });
        });
    });
</script>
