                                                    }, "Value", "Text"),
                                                    new { id = "ddlServiceBond", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.ServiceBondRemark, new { @class = "form-control", id = "txtServiceBondRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row" id="InvestigationRequired" style="display: none;">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Investigation Required</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.InvestigationRequired,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlInvestigationRequired", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.InvestigationRequiredRemark, new { @class = "form-control", id = "txtInvestigationRequiredRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Voluntary Remark </span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.IsVoluntary,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlVoluntary", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <sapn>Remark:</sapn>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.VoluntaryRemark, new { @class = "form-control", id = "txtVoluntaryRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <sapn>Pending Task/Projects</sapn>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.TaskPending,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlTaskPending", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <sapn>Remark:</sapn>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.TaskPendingRemark, new { @class = "form-control", id = "txtTaskPendingRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <sapn>KPI PMS Pending</sapn>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.KPIPending,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlKPIPending", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
