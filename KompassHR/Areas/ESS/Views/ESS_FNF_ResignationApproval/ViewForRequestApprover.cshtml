                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.KPIPendingRemark, new { @class = "form-control", id = "txtKPIPendingRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            <sapn>Employer Next Company</sapn>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextAreaFor(model => model.EmployerNextCompany, new { @class = "form-control", id = "txtEmployerNextCompany", autocomplete = "Off", rows = "1" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <sapn>Approve/Reject Remark</sapn>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.ApproveRejectRemark, new { @class = "form-control", id = "txtApproveRejectRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="row">
                <div class="LastShortLeaveBx">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="BtnBx">
                                <div class="action-buttons-right">
                                    <button type="button" onclick="Approved('Approved')" class="btn btn-success btn-sm" id="btnmodal-dialog" value="Approved"><i class="fa-solid fa-check-double"></i>Approve</button>
                                    <button type="button" class="btn btn-warning btn-sm" onclick="Approved('Rejected')" id="btnmodal-dialog1" value="Rejected">Reject</button>
                                    <a href="@Url.Action("ESS_FNF_ResignationApproval", "ESS_FNF_ResignationApproval", new { area = "ESS" })">
                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetResignationList"><i class="fa-solid fa-share-from-square"></i> List </button>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Access Buttons -->
            <div class="quick-access-buttons mt-4 d-flex flex-wrap gap-2" hidden>
                <button type="button" class="btn btn-info" hidden>
                    <i class="fas fa-history me-2"></i>Increment History
                </button>
                <button type="button" class="btn btn-info" hidden>
                    <i class="fas fa-list-alt me-2"></i>Leave Summary
                </button>
                <button type="button" class="btn btn-info" hidden>
                    <i class="fas fa-chart-line me-2"></i>PMS
                </button>
                <button type="button" class="btn btn-info" hidden>
                    <i class="fas fa-calendar-alt me-2"></i>Attendance
                </button>
                <button type="button" class="btn btn-info" hidden>
                    <i class="fas fa-building me-2"></i>Dept Status
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    
    function Approved(Approver) {
        debugger;

        var ApprovalquestionAnswers = {
            FnfId: $("#hdnFnfId").val(),
            LastWorkingDate: $("#dateLastWorkingDate").val(),
            FnfEmployeeId: $("#hdnFnfEmployeeId").val(),
            IsReasonCorrect: $("#ddlIsReasonCorrect").val(),
            IsReasonCorrectRemark: $("#txtIsReasonCorrectRemark").val(),
            IsCriticalResource: $("#ddlCriticalResource").val(),
            IsCriticalResourceRemark: $("#txtIsCriticalResourceRemark").val(),
            IsHireagain: $("#ddlHireagain").val(),
            IsHireagainRemark: $("#txtIsHireagainRemark").val(),
            IsImmediateRelease: $("#ddlImmediateRelease").val(),
            IsImmediateReleaseRemark: $("#txtImmediateReleaseRemark").val(),
            ServiceBond: $("#ddlServiceBond").val(),
            ServiceBondRemark: $("#txtServiceBondRemark").val(),
            InvestigationRequired: $("#ddlInvestigationRequired").val(),
            InvestigationRequiredRemark: $("#txtInvestigationRequiredRemark").val(),
            IsVoluntary: $("#ddlVoluntary").val(),
            VoluntaryRemark: $("#txtVoluntaryRemark").val(),
            TaskPending: $("#ddlTaskPending").val(),
            TaskPendingRemark: $("#txtTaskPendingRemark").val(),
            KPIPending: $("#ddlKPIPending").val(),
            KPIPendingRemark: $("#txtKPIPendingRemark").val(),
            EmployerNextCompany: $("#txtEmployerNextCompany").val(),
            ApproveRejectRemark: $("#txtApproveRejectRemark").val()
        };

        var FnfID = $("#FnfId").val();
        var FNFEncrypted = $("#FnfId_Encrypted").val();
        var Status = "";
        var Remark = "";
        if (Approver == "Rejected") {
            Remark = $("#txtApproveRejectRemark").val();
            Status = "Rejected";
        }
        else {
            Status = "Approved";
            Remark = $("#txtApproveRejectRemark").val();
        }
        $.ajax({
            url: "@Url.Action("ForApprovalCandidate", "ESS_FNF_ResignationApproval")",
            method: "Post",
            data: {ApprovalquestionAnswers:ApprovalquestionAnswers, FnfID: FnfID, FNFEncrypted: FNFEncrypted, Status: Status, Remark: Remark },
            success: function (response) {
                debugger;

                var Message1 = response.Message;
                var Icon1 = response.Icon;

                if (Message1) {debugger

                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup();
                            popup.classList.remove('swal2-show');
                            setTimeout(() => popup.classList.add('animate__animated', 'animate__headShake'));
                            setTimeout(() => popup.classList.remove('animate__animated', 'animate__headShake'), 500);
                            return false;
                        }
                    }).then((result) => {

                        $("#txtApproveRejectRemark").val("");

                        if (result.isConfirmed) {debugger
                            $("#myModalFinal").modal('hide');
                            window.location.href = '@Url.Action("ESS_FNF_ResignationApproval", "ESS_FNF_ResignationApproval")';
                        }
                    });
                }

                // Hide modal for success case
                if (Icon1 !== "error") {
                    $("#myModalFinal").modal('hide');
                    $("#txtApproveRejectRemark").val("");
                }
            }
        });
    }

    $("#dateLastWorkingDate").on("change", function () {debugger
        let lastWorking = new Date($(this).val());
        let resignation = new Date($("#hdnResignationDate").val());
        let noticeEnd = new Date($("#hdnNoticePeriodEndDate").val());

        $("#errLastWorkingDate").text("");

        // Stop if empty
        if (!$(this).val()) return;

        lastWorking.setHours(0,0,0,0);
        resignation.setHours(0,0,0,0);
        noticeEnd.setHours(0,0,0,0);

        // Validation 1: Last working > notice period end
        if (lastWorking > noticeEnd) {
            $("#errLastWorkingDate").text(
                "Relieving date cannot be greater than notice period end date."
            );
            return;
        }

        // Validation 2: Last working < resignation date
        if (lastWorking < resignation) {
            $("#errLastWorkingDate").text(
                "Relieving date cannot be less than resignation date."
            );
            return;
        }
    });


</script>


