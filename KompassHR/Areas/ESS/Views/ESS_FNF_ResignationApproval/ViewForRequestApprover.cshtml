@model KompassHR.Areas.ESS.Models.ESS_FNF.FNF_EmployeeResignation
@{
    ViewBag.Title = "ViewForRequestApprover";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    .note-toolbar {
        display: none;
    }

    .note-editable {
        height: 100% !important;
        [contenteditable="false"];
    }

    .table, tr, td, th, .invoice, .smallFrom {
        border: none;
        font-size: 13px;
        font-family: Arial;
    }
</style>
<style>
    .card {
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .card-header {
        padding: 0.5rem;
    }

    .section-title {
        font-size: 1.1rem;
        color: #495057;
        border-bottom: 1px dashed #dee2e6;
        padding-bottom: 0.5rem;
        margin-bottom: 1rem;
    }

    .employee-detail-section, .resignation-detail-section {
        background: #f8f9fa;
        padding: 1.25rem;
        border-radius: 0.5rem;
        height: 100%;
    }

    .question-group {
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 0.375rem;
    }

    .quick-access-buttons .btn {
        flex: 1 0 auto;
        min-width: 180px;
    }

    @@media (max-width: 768px) {
        .action-buttons-right {
            margin-top: 1rem;
        }

        .quick-access-buttons .btn {
            min-width: 100%;
            margin-bottom: 0.5rem;
        }
    }
</style>



<!-- Add these styles in your custom CSS or within a <style> tag in your HTML -->
<style>
    .mb-15px {
        margin-bottom: 0px !important;
    }

    .invoice-header {
        background-color: #f9f9f9;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .invoice .invoice-header {
        margin: 0 -0px;
    }

    .invoice .invoice-from {
        padding: 5px;
        flex: 1;
    }

    .invoice .invoice-to {
        padding: 5px;
        flex: 1;
    }

    .invoice-from, .invoice-to {
        padding: 1px;
    }

    .smallFrom {
        font-size: 0.9em;
        color: #6c757d;
    }

    address {
        font-style: normal;
        line-height: 1.5;
    }

    .invoice-header i {
        color: #007bff;
    }

    .invoice-header b {
        color: #343a40;
    }

    @@media (max-width: 768px) {
        .invoice-header {
            padding: 20px;
        }
    }

    .custom-font {
        font-family: 'Arial', serif;
        font-size: 14px; /* Optional: Adjust font size */
        color: #333; /* Optional: Adjust text color */
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Resignation Approval
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_FNF_Menu", "ESS_FNF_Menu",  new { id = 7,ScreenId=168, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="invoice">
        <!-- BEGIN invoice-company -->
        @Html.HiddenFor(model => model.FnfId_Encrypted, new { id = "FnfId_Encrypted" })
        @Html.HiddenFor(model => model.FnfId, new { id = "FnfId" })
        @*<div class="invoice-company">
                <span class="float-end hidden-print">
                    <button type="button" class="btn  btn-primary" onclick="printDiv();" id="search"><i class="ace-icon fa fa-print align-top bigger-125"></i>&nbsp; Print</button>
                    <button type="button" onclick="Approved('Approved')" class="btn btn-success" id="btnmodal-dialog" value="Approved"><i class="fa-solid fa-check-double"></i>Approve</button>
                    <button href="#modal-dialogForHoldReject1" type="button" onclick="OpenModule()" class="btn btn-danger" id="btnmodal-dialog1" value="Rejected">Reject</button>
                </span>
                Request Approval
            </div>*@
        <!-- END invoice-company -->
        <form class="form">
            <div class="card border-0">
                <!-- Employee Information Card -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0"><i class="fas fa-user-tie me-2"></i>Employee Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="employee-detail-section">
                                    <ul class="list-unstyled">
                                        <li class="mb-2"><i class="fas fa-user-tie text-muted me-2"></i><strong>Name:</strong> @ViewBag.GetData.EmployeeName</li>
                                        <li class="mb-2"><i class="fas fa-building text-muted me-2"></i><strong>Department:</strong> @ViewBag.GetData.DepartmentName</li>
                                        <li class="mb-2"><i class="fas fa-briefcase text-muted me-2"></i><strong>Designation:</strong> @ViewBag.GetData.DesignationName</li>
                                        <li class="mb-2"><i class="fas fa-briefcase text-muted me-2"></i><strong>Grade:</strong> @ViewBag.GetData.GradeName</li>
                                        <li class="mb-2"><i class="fas fa-calendar-day text-muted me-2"></i><strong>Date Of Joining:</strong> @ViewBag.GetData.DOJ - (@ViewBag.GetData.WorkDuration )</li>
                                        <li class="mb-2"><i class="fas fa-clock text-muted me-2"></i><strong>Notice Period:</strong> @ViewBag.GetNoticePeriod</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="resignation-detail-section">
                                    <ul class="list-unstyled">
                                        <li class="mb-2"><i class="fas fa-calendar-check text-muted me-2"></i><strong>Reason:</strong> @ViewBag.GetData.ReasonName</li>

                                        <li class="mb-2"><i class="fas fa-calendar-day text-muted me-2"></i><strong>Resignation Date:</strong> @ViewBag.GetData.ResignationDate</li>
                                        <li class="mb-2"><i class="fas fa-calendar-day text-muted me-2"></i><strong>Last Working Proposed Date:</strong> @ViewBag.GetData.LastWorkingDate</li>
                                        <li class="mb-2"><i class="fas fa-calendar-day text-muted me-2"></i><strong>Notice Period End Date:</strong> @ViewBag.GetData.NoticePeriodEndDate</li>
                                        <li class="mb-2"><i class="fas fa-briefcase text-muted me-2"></i><strong>Is Employee Want to Permit Immediate Relieving: </strong> @ViewBag.GetData.IsImmediatelyRelieve</li>
                                        <li class="mb-2"><i class="fas fa-briefcase text-muted me-2"></i><strong>Is There an Option to Buy Out the Notice Period: </strong> @ViewBag.GetData.IsNoticePeriodPurchase</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Exit Process Form -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-door-open me-2"></i>Employee Exit Process</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-group row align-items-center">
                                    <label class="col-md-4 col-form-label">
                                        <i class="fas fa-calendar-alt me-2"></i>Relieving  Date
                                    </label>
                                    <div class="col-md-6">
                                        @Html.TextBoxFor(model => model.LastWorkingDate, new { @class = "form-control", name = "LastWorkingDate", type = "date", id = "dateLastWorkingDate" })
                                        <span id="errLastWorkingDate" style="color:red"></span>
                                        @Html.HiddenFor(model => model.ResignationDate, new { @class = "form-control", id = "hdnResignationDate" })
                                        @Html.HiddenFor(model => model.NoticePeriodEndDate, new { @class = "form-control", id = "hdnNoticePeriodEndDate" })
                                        @Html.HiddenFor(model => model.FnfEmployeeId, new { @class = "form-control", id = "hdnFnfEmployeeId" })
                                        @Html.HiddenFor(model => model.FnfId, new { @class = "form-control", id = "hdnFnfId" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr>
                        <!-- Exit Questionnaire -->
                        <div class="exit-questionnaire">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Is Resignation Reason Correct?</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.IsReasonCorrect,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlIsReasonCorrect", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6" id="remarkRow">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.IsReasonCorrectRemark, new { @class = "form-control", id = "txtIsReasonCorrectRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Is the employee a critical (valuable) resource for the company?</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.IsCriticalResource,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlCriticalResource", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6" id="remarkRow1">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.IsCriticalResourceRemark, new { @class = "form-control", id = "txtIsCriticalResourceRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Whether to Hire again or Not ?</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.IsHireagain,
                                                        new SelectList(new List<SelectListItem>
                                                        {
                                                            new SelectListItem { Text = "Yes", Value = "true" },
                                                            new SelectListItem { Text = "No", Value = "false" }
                                                        }, "Value", "Text"),
                                                        new { id = "ddlHireagain", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6" id="remarkRowHire">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.IsHireagainRemark, new { @class = "form-control", id = "txtIsHireagainRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Is Immediate Release?</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.IsImmediateRelease,
                                                    new SelectList(new List<SelectListItem>
                                                    {
                                                        new SelectListItem { Text = "Yes", Value = "true" },
                                                        new SelectListItem { Text = "No", Value = "false" }
                                                    }, "Value", "Text"),
                                                    new { id = "ddlImmediateRelease", @class = "form-select" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-2">
                                            <span class="custom-font">Remark:</span>
                                        </label>
                                        <div class="col-md-10">
                                            @Html.TextAreaFor(model => model.IsImmediateReleaseRemark, new { @class = "form-control", id = "txtIsImmediateReleaseRemark", autocomplete = "Off", rows = "2" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-9">
                                            <i class="fa-brands fa-quora"></i> .
                                            <span class="custom-font">Service Agreement Bond Active</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.ServiceBond,
                                                    new SelectList(new List<SelectListItem>
