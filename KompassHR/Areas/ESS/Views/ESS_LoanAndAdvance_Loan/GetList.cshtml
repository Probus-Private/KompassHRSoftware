
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 63px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 63px;
    }*/
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new { id = 6, area = "Module" })">Payroll Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Loan  </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Loan - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>


                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        View list of request loan here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <a href="@Url.Action("ESS_LoanAndAdvance_Loan", "ESS_LoanAndAdvance_Loan", new { area = "ESS" })" class="btn btn-primary btn-sm mb-10px">
                                <i class="fa-solid fa-plus"></i> &nbsp; Add
                            </a>

                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle TablePage" id="fixed-header"  style="width: 100%;">
                                                <thead>
                                                    <tr>
                                                        @*<th class="fixed-side">Update</th>
                                                        <th class="fixed-side1">Delete</th>*@
                                                        <th class="fixed-side">Cancel</th>
                                                        <th class="fixed-side1">Status</th>
                                                        <th class="text-nowrap">Auto/Manually</th>
                                                        <th class="text-nowrap">Doc No</th>
                                                        <th class="text-nowrap">Doc Date </th>
                                                        <th class="text-nowrap">Employee Name </th>
                                                        <th class="text-nowrap">Loan Amount </th>
                                                        <th class="text-nowrap">No of Installment</th>
                                                        <th class="text-nowrap">Required Date </th>
                                                        <th class="text-nowrap">Deducation Month </th>
                                                        <th class="text-nowrap">Reason </th>
                                                        <th class="text-nowrap">Guarantor Name 1</th>
                                                        <th class="text-nowrap">Guarantor Name 2</th>
                                                        <th class="text-nowrap">CreatedBy</th>
                                                        <th class="text-nowrap">CreatedDate</th>
                                                        <th class="text-nowrap">ModifiedBy</th>
                                                        <th class="text-nowrap">ModifiedDate</th>
                                                        <th class="text-nowrap">MachineName</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var d in ViewBag.GetLoanList)
                                            {
                                                    <tr>
                                                        @*<td class="text-center">
                                                            <button type="button" onclick="UpdateLoan('@d.LoanID_Encrypted')" id="UpdateBtn"
                                                                    class="btn btn-success btnpress ListBtn">
                                                                <i class="fa-solid fa-pencil-alt"></i>
                                                            </button>
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="button" onclick="DeleteLoan('@d.LoanID_Encrypted')" id="DeleteBtn"
                                                                    class="btn btn-danger ListBtn btnpress">
                                                                <i class="fa-solid fa-trash-alt"></i>
                                                            </button>
                                                        </td>*@
                                                        <td>@d.ApprovedDay</td>
                                                        <td>@d.DocNo</td>
                                                        <td>@d.DocDate</td>
                                                        <td>@d.EmployeeName</td>
                                                        <td style="text-align:right">@d.LoanAmount</td>
                                                        <td style="text-align:right">@d.NoOfInstallment</td>
                                                        <td>@d.RequiredDate</td>
                                                        <td>@d.DeducationMonth</td>
                                                        <td>@d.GuarantorName1</td>
                                                        <td>@d.GuarantorName2</td>
                                                        <td>@d.Reason</td>
                                                        <td>@d.CreatedBy</td>
                                                        <td>@d.CreatedDate</td>
                                                        <td>@d.GuarantorName1</td>
                                                        <td>@d.GuarantorName2</td>
                                                        <td>@d.ModifiedBy</td>
                                                        <td>@d.ModifiedDate</td>
                                                        <td>@d.MachineName </td>
                                                    </tr>
                                            }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>

    <script>
        $(document).ready(function () {
            var Message = @Html.Raw(Json.Encode(TempData["Message"]));
            var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
            debugger;
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)

                            return false
                        }
                    });
                }
            }
        });//ready function

    </script>


    <script>

        function UpdateLoan(LoanID_Encrypted) {
            var url = '@Url.Action("ESS_LoanAndAdvance_Loan", "ESS_LoanAndAdvance_Loan")?LoanID_Encrypted=' + LoanID_Encrypted;
            window.location.href = url;
        }
      
    </script>


