</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "ESS" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new { id = 6, area = "Module" })">Payroll Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Loan </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Loan - <b>@ViewBag.AddUpdateTitle</b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Fill in below form for request loan here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "ESS_LoanAndAdvance_Loan", new { area = "ESS" })' id="SaveLoan" method="post">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNo", type = "text", id = "txtDocNo", autocomplete = "Off", @readonly = "readonly", Value = @ViewBag.DocNo.DocNo, Style = "background-color: #eee;" })
                                                @Html.HiddenFor(model => model.LoanID_Encrypted, new { id = "LoanID_Encrypted" })
                                                @Html.HiddenFor(model => model.LoanID)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", type = "date", id = "dateDocDate", autocomplete = "Off", Name = "DocDate" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.LoanEmployeeID, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "--Select--", new { id = "ddlLoanEmployeeID", @class = "form-select", autocomplete = "off", name = "LoanEmployeeID" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Loan Amount
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LoanAmount, new { @class = "form-control", type = "number", onkeypress = " return numbervalidate(event)", id = "txtLoanAmount", autocomplete = "Off", Name = "LoanAmount", @style = "text-align:right" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                No of Installment
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.NoOfInstallment, new { @class = "form-control", type = "number", onkeypress = "return event.charCode >=48", id = "txtNoOfInstallment", autocomplete = "Off", Name = "NoOfInstallment", @style = "text-align:right" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Required Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.RequiredDate, new { @class = "form-control", type = "date", id = "dateRequiredDate", autocomplete = "Off", Name = "RequiredDate" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Deducation Month
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DeducationMonth, new { @class = "form-control", type = "date", id = "dateDeducationMonth", autocomplete = "Off", Name = "DeducationMonth" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Guarantor  Name 1
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.GuarantorName1, new SelectList(ViewBag.GetGuarantorName, "Id", "Name"), "--Select--", new { id = "ddlGuarantorName1", @class = "form-select", autocomplete = "off", name = "GuarantorName2" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Guarantor  Name 2
                                            </label>
                                            <div class="col-md-10">
                                                @Html.DropDownListFor(model => model.GuarantorName2, new SelectList(ViewBag.GetGuarantorName, "Id", "Name"), "--Select--", new { id = "ddlGuarantorName2", @class = "form-select", autocomplete = "off", name = "GuarantorName2" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Reason
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.Reason, new { @class = "form-control", type = "text", id = "txtReason", autocomplete = "Off", Name = "Reason" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            @*<div class="col-md-4 d-flex">
                                                    <div class="title d-flex align-items-center">
                                                        Last Record :
                                                        <span>@ViewBag.LastRecored</span>
                                                    </div>
                                                </div>*@
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnLoanGetList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Loan - Pending List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <!--BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine">
                                <thead>
                                    <tr class="trheading">
                                        <th class="fixed-side">Delete</th>
                                        <th class="fixed-side1">Notification</th>
                                        <th class="text-nowrap text-center">Doc No</th>
                                        <th class="text-nowrap text-center">Doc Date</th>
                                        <th class="text-nowrap text-center">Employee Name</th>
                                        <th class="text-nowrap text-center">Loan Amount</th>
                                        <th class="text-nowrap text-center">No of Installment</th>
                                        <th class="text-nowrap text-center">Required Date</th>
                                        <th class="text-nowrap text-center">Deducation Month </th>
                                        <th class="text-nowrap text-center">Guarantor Name 1</th>
                                        <th class="text-nowrap text-center">Guarantor Name 2</th>
                                        <th class="text-nowrap text-center">Reason </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.Loan)
                                    {
                                        <tr>
                                            <td class="text-center fixed-side1">
                                                <button type="button" onclick="DeleteLoan('@d.LoanID_Encrypted')" id="btnDelete"
                                                        class="btn btn-danger ListBtn btnpress">
                                                    <i class="fa-solid fa-trash-alt"></i>
                                                </button>
                                            </td>
                                            <td class="text-nowrap">
                                                <button type="button" id="btnSendNofication" class="btn btnpress ListBtn" onclick="NotificationFunction('@d.EmployeeId','@d.LoanID_Encrypted ')" style="background-color:#fff;">
                                                    <i class="fa fa-phone"></i>
                                                </button>&nbsp;&nbsp;
                                                <button type="button" id="btnSendNotification" class="btn  btnpress ListBtn" style="background-color:#fff;" onclick="SendNotification('@d.EmployeeId')">
                                                    <i class="fa-solid fa-paper-plane text-dark"></i>
                                                </button>
                                                @d.PendingDay
                                            </td>
                                            <td>@d.DocNo</td>
                                            <td>@d.DocDate</td>
                                            <td>@d.EmployeeName</td>
                                            <td style="text-align:right">@d.LoanAmount</td>
                                            <td style="text-align:right">@d.NoOfInstallment</td>
                                            <td>@d.RequiredDate</td>
                                            <td>@d.DeducationMonth</td>
                                            <td>@d.GuarantorName1</td>
                                            <td>@d.GuarantorName2</td>
                                            <td>@d.Reason</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>


                    <!-- END table-responsive -->
                </div>
            </div>
        </div>
    </div>
</div>
