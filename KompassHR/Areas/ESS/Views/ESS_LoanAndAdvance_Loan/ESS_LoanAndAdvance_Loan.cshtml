@model KompassHR.Areas.ESS.Models.ESS_LoanAndAdvance.Payroll_Loan
@{
    ViewBag.Title = "ESS_LoanAndAdvance_Loan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

