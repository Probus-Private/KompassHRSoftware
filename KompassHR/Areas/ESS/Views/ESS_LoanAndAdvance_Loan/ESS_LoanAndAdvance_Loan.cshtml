<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);

    $("#SaveLoan").validate({
        rules: {
            DocDate: {
                required: true,
            },
            LoanEmployeeID: {
                required: true,

            },
            BranchID: {
                required: true,
            },
            LoanAmount: {
                required: true,
            },
            NoOfInstallment: {
                required: true,
            },
            RequiredDate: {
                required: true,
            },
            DeducationMonth: {
                required: true,
            },
            Reason: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
        },
        messages: {
            DocDate: {
                required: "Doc date is required",
            },
            LoanEmployeeID: {
                required: "Employee name is required",
            },
            BranchID: {
                required: "Business unit  is required",
            },
            LoanAmount: {
                required: "Loan amount is required",
            },
            NoOfInstallment: {
                required: "No of installment is required",
            },
            RequiredDate: {
                required: "Required date is required",
            },
            DeducationMonth: {
                required: "Deducation month  is required",
            },
            Reason: {
                required: "Reason is required",
                regex: "Enter olny alphabate.",
            },
        }
    });

    var form = $("#SaveLoan");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            $("#dateDeducationMonth").removeClass('error');
            $("#dateRequiredDate").removeClass('error');
            $("#dateDocDate").removeClass('error');
            return false;
        }

        var LoanEmployeeID=$("#ddlLoanEmployeeID").val();
        //var DeducationMonth=$("#dateDeducationMonth").val();
        var LoanIDEncrypted=$("#LoanID_Encrypted").val();

        $.ajax({
            url: '@Url.Action("IsLoanExists", "ESS_LoanAndAdvance_Loan")',
            method:"Get",
            data:{LoanEmployeeID:LoanEmployeeID,LoanIDEncrypted:LoanIDEncrypted},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveLoan").submit();

                }
            }
        });

    });



    function NotificationFunction(EmployeeId,LoanID_Encrypted) {
        debugger;
        //alert(LoanEmployeeID,LoanID_Encrypted);
        $.ajax({
            type: "Get",
            url: '@Url.Action("GetContactDetails", "ESS_LoanAndAdvance_Loan")',
            data: {EmployeeId:EmployeeId , LoanID_Encrypted: LoanID_Encrypted},
            dataType: "text",
            success: function (data) {
                debugger;
                var datas = JSON.parse(data);
                var Getdata = datas.data[0];

                $('#lblManager1Name').html(Getdata[0].Value);
                $('#lblManager1EmailId').html(Getdata[1].Value);
                $('#lblManager1Mobile').html(Getdata[2].Value);

                $('#lblManager2Name').html(Getdata[3].Value);
                $('#lblManager2EmailId').html(Getdata[4].Value);
                $('#lblManager2Mobile').html(Getdata[5].Value);

                $('#lblHRName').html(Getdata[6].Value);
                $('#lblHREmailId').html(Getdata[7].Value);
                $('#lblHRMobile').html(Getdata[8].Value);
                $('#NotificationModalPopUp').modal('show');
            }
        });
    }
</script>

<script>
