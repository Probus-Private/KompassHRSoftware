@model KompassHR.Areas.ESS.Models.ESS_PMS.PMS_GoalCreation

@{
    ViewBag.Title = "ESS_PMS_GoalCreation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>
<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Goal Creation
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_TMS_Menu", "ESS_TMS_Menu",  new { id = 12,ScreenId=194, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Goal Creation  - @ViewBag.AddUpdateTitle </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("SaveUpdate", "ESS_TMS_TaskAssign", new { area = "ESS" })" id="SaveTaskAssign" method="post" enctype="multipart/form-data">
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                               Goal Type
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.GoalTypeId, new SelectList(ViewBag.GoalTypeList, "GoalTypeID", "GoalType"), "--Select--", new { id = "ddlGoalTypeId", @class = "form-select", autocomplete = "off", name = "GoalTypeId" })
                                                @Html.HiddenFor(model => model.GoalCreationIDEncrypted)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                               Department
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.DepartmentId, new SelectList(ViewBag.DepartmentList, "DepartmentId", "DepartmentName"), "--Select--", new { id = "ddlDepartmentId", @class = "form-select", autocomplete = "off", name = "DepartmentId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-2">
                                                Goal Title
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.GoalTitle, new { @class = "form-control", name = "GoalTitle", id = "txtGoalTitle", autocomplete = "Off"})
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Description
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @*@Html.TextAreaFor(model => model.Description, new { id = "txtDescription", name = "Description", style = "border: 1px solid #000;", @class = "summernote", type = "text" })*@
                                                @Html.TextAreaFor(model => model.Description, new { @class = "summernote", style = "border: 2px solid #000; padding: 10px;", id = "Description",name= "Description", @placeholder = "Description....", autocomplete = "Off", contenteditable = "true" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Goal Type
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.GoalTypeId, new SelectList(ViewBag.GoalTypeList, "GoalTypeID", "GoalType"), "--Select--", new { id = "txtGoalTypeId", name = "GoalTypeId", @class = "form-select" })


                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Department
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.DepartmentId, new SelectList(ViewBag.DepartmentList, "DepartmentId", "DepartmentName"), "--Select--", new { id = "txtDepartmentId", name = "DepartmentId", @class = "form-select" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Alignment
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.Alignment, new SelectList(ViewBag.AlignmentList, "GoalCreationID", "GoalTitle"), "--Select--", new { id = "txtAlignment", name = "Alignment", @class = "form-select" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="row">
                                    <label class="form-label col-form-label col-md-4">
                                        Success Matrix
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.SuccessMatrix, new List<SelectListItem>{
                                                new SelectListItem {Text ="Specific", Value="Specific"},
                                                 new SelectListItem {Text ="Measurable", Value="Measurable"},
                                                 new SelectListItem {Text ="Achievable", Value="Achievable"},
                                                 new SelectListItem {Text ="Relevant", Value="Relevant"},
                                                 new SelectListItem {Text ="Time Bound", Value="Time Bound"},
                                              }, "--Select--", new { @class = "form-select", name = "SuccessMatrix", @id = "txtSuccessMatrix" })                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Weightage
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.Weightage, new { id = "txtWeightage", name = "Weightage", @class = "form-control"})
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="row">
                                    <label class="form-label col-form-label col-md-4">
                                        Visibility
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.Visibility, new List<SelectListItem>{
                                                new SelectListItem {Text ="Private", Value="Private"},
                                                 new SelectListItem {Text ="Public", Value="Public"}
                                              }, "--Select--", new { @class = "form-select", name = "Visibility", @id = "txtVisibility" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Start Date
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.StartDate, new { id = "txtStartDate", name = "StartDate", @class = "form-control" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="row">
                                    <label class="form-label col-form-label col-md-4">
                                        End Date
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.EndDate, new { id = "txtEndDate", name = "EndDate", @class = "form-control" })


                                    </div>
                                </div>
                            </div>
                        </div>


                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="SubmitBtn" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" id="btnGetList" class="btn btn-danger btn-sm">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>

