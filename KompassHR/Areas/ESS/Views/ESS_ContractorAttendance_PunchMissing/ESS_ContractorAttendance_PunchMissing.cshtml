                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">Time<span class="important">*</span></label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PunchMissingLogTime, new { @class = "form-control", @id = "PunchMissingLogTime", Type = "time", name = "PunchMissingLogTime" })
                                            </div>
                                            <div hidden>
                                                @Html.TextBox("AllowBeforeStartShift", "", new { @class = "form-control", @id = "AllowBeforeStartShift", Type = "text" })
                                                @Html.TextBox("AllowAfterEndShift", "", new { @class = "form-control", @id = "AllowAfterEndShift", Type = "text" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4"> Reason<span class="important">*</span></label>
                                            <div class="col-md-8">
                                                <div class="col-md-12">
                                                    @Html.TextAreaFor(model => model.Reason, new { @class = "form-control", @id = "AdditionNotify", Type = "text" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <br>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-4 d-flex">
                                                <div class="title d-flex align-items-center">
                                                    @*Last Record :
                                <span>@ViewBag.LastRecored</span>*@
                                                    <span></span>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" id="btnGetList" onclick="location.href='@Url.Action("ESS_ContractorAttendance_GetList", "ESS_ContractorAttendance_PunchMissing")'">
                                                            <i class="fa-solid fa-share-from-square"></i> List
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
        @*<div class="col-md-4">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Attendance Log </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
