                                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>

                                                    <a href="@Url.Action("ESS_TimeOffice_AttendanceRegularization_SubMenu", "ESS_TimeOffice_AttendanceRegularization_SubMenu", new { id=5 , ScreenId=363 , area = "ESS" })">
                                                        <button type="button" class="btn btn-danger">
                                                            <i class="fa-solid fa-share-from-square"></i> Back
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- Start panel -->
<div class="row">
    <div class="col-lg-12">
        <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false" data-bs-scroll=true>
            <div class="offcanvas-header" style="border-bottom: 1px solid #d3d3d38a;">
                <h6 class="offcanvas-title text-center" id="EmpName1"
                    style="width: 100%;">
                    <span id="EmpName"></span>
                </h6>
                <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-5">
                                From date
                                <span class="important">*</span>
                            </label>
                            <div class="col-md-7">
                                @Html.TextBox("LogFromDate", null, new { @class = "form-control", id = "LogFromDate", type = "date" })
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-5">
                                To date
                                <span class="important">*</span>
                            </label>
                            <div class="col-md-7">
                                @Html.TextBox("LogToDate", null, new { @class = "form-control", id = "LogToDate", type = "date" })
                            </div>
                            <span class="Error" id="ErrorLogFromToDate" style="display:none"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="row mb-15px">
                            <label class="form-label col-form-label col-md-5">

                            </label>
                            <div class="col-md-7">
                                <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployeeLog()">
                                    <i class="fa-solid fa-spinner"></i>&nbsp; Load Log
                                </button>
                            </div>
                            <span class="Error" id="ErrorLogFromToDate" style="display:none"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-12 overflow-auto">

                        <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblEmployeeLog" style="width:100%;">
                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                <tr class="text-center">
                                    <th class="text-nowrap text-center">Log Date</th>
                                    <th class="text-nowrap text-center">In-Out</th>
                                    <th class="text-nowrap text-center" hidden></th>
                                    <th class="text-nowrap text-center">In</th>
                                    <th class="text-nowrap text-center">Out</th>
                                </tr>
                            </thead>
                            <tbody>
                                @*@foreach (var d in ViewBag.EmployeeLog)
                                    {
                                        <tr onclick="tblEmployeeLogRowColor(this)">
                                            <td class="text-nowrap text-center">@d.LoDate</td>
                                            <td class="text-nowrap text-center">@d.Direction</td>
                                            <td hidden>TimeSend 24Hr</td>
                                            <td><i class="fa-regular fa-circle-up"></i></td>
                                            <td><i class="fa-regular fa-circle-up"></i></td>
                                        </tr>
                                    }*@
                            </tbody>
                        </table>

                    </div>
                </div>
                <br />
            </div>
        </div>
    </div>
</div>
<!-- END panel -->

<script>
    $(document).ready(function () {
        $("#ddlCompanyName").select2();
        $("#ddlBranchId").select2();

        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#ddlBranchId").empty();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlBranchId").find("option").remove();
                        //$("#ddlBranchId").append("<option value=''> --Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
        $(document).on('change', '#txtInTime, #txtOutTime', function () {
            debugger;
            var currentRow = $(this).closest("tr");
            var GetDate = currentRow.find("td").eq(3).find("input").val();
            var GetInTimes = currentRow.find("td").eq(4).find("input").val();
            var GetOutTimes = currentRow.find("td").eq(5).find("input").val();

            var GetInDate = GetInTimes.substring(0, 10);
            var GetOutDate = GetOutTimes.substring(0, 10);
            var GetInTime = GetInTimes.substring(11);
            var GetOutTime = GetOutTimes.substring(11);

            //if (GetInTimes == "") {
            //    row.find('#ErrortxtInTime').css('display', 'flex');
            //    row.find('#ErrortxtInTime').html("Invalid In Time");
            //    hasError = true; return false;
            //}
            //else {
            //    $("#ErrortxtInTime").html("");
            //    hasError = false;
            //}

            //if (tblRowData.InOut_OutTime == "") {
            //    row.find('#ErrortxtOutTime').css('display', 'flex');
            //    row.find('#ErrortxtOutTime').html("Invalid Out Time");
            //    hasError = true; return false;
            //}
            //else {
            //    $("#ErrortxtOutTime").html("");
            //    hasError = false;
            //}

            //For Date Check
            if (GetInDate === GetOutDate) // IF SAME DATE
            {
                //FOR CHECK TIME SHOULD NOT GRETER
                if (GetInTime > GetOutTime) {
                    //currentRow.find('#txtInTime').css('color', 'red');
                    currentRow.find('#ErrortxtOutTime').css('display', 'flex');
                    currentRow.find('#ErrortxtOutTime').html("Not Less Than In Time");
                    return false; hasError = true;
                }
                else {
                    //currentRow.find('#txtInTime').css('color', 'black');
                    currentRow.find('#ErrortxtOutTime').css('display', 'none');
                    currentRow.find('#ErrortxtOutTime').html("");
                    hasError = "";
                }
            }
            else if (GetInDate != GetOutDate)// IF DIFFRENT DATE
            {
                var fromDate = new Date(GetInDate);
                var toDate = new Date(GetOutDate);
                // COMPARE THE DATES
                if (fromDate > toDate) {
                    //currentRow.find('#txtInTime').css('color', 'red');
                    currentRow.find('#ErrortxtOutTime').css('display', 'flex');
                    currentRow.find('#ErrortxtOutTime').html("Not Less Than In Date");
                    var hasError = true; return false;
                }
                else {
                    //currentRow.find('#txtInTime').css('color', 'black');
                    currentRow.find('#ErrortxtOutTime').css('display', 'none');
                    currentRow.find('#ErrortxtOutTime').html("");
                    var hasError = false;
                }
            }
        });


        $('#tblEmployeeLog').DataTable({
            scrollY: 300,
            scrollCollapse: false,
            paging: false,
            scrollX: false,
            ordering: false, // Disable sorting
            searching: false, // Enable searching
            "bInfo": false
        });

        //FINAL SUBMIT
        $("#btnSubmit").click(function () {
            debugger;
            var hasError = "";
            var CmpId = $('select#ddlCompanyName option:selected').val();
            var BranchId = $('select#ddlBranchId option:selected').val();
            var tbldata = [];
            $("#tblMultipleEmployeeLog tbody tr").each(function (index) {
                //var rowNumber = index + 1;
                var row = $(this).closest("tr");
                var tblRowData = {};
                tblRowData.InOut_EmployeeNo = row.find("td").eq(2).find("input").val();
                tblRowData.InOut_AttendanceDate = row.find("td").eq(3).find("input").val();
                tblRowData.InOut_InTime = row.find("td").eq(4).find("input").val();
                tblRowData.InOut_OutTime = row.find("td").eq(5).find("input").val();
                tblRowData.InOut_inoutnote = row.find("td").eq(6).find("input").val();


                var cells = row.find("td");
                var employeeNo = row.find("td").eq(2).find("input").val(); // First cell (Employee No.)
                var date = row.find("td").eq(3).find("input").val();       // Second cell (Date)
                //var rowIdentifier = employeeNo + "-" + date;
                //const seen = new Set();
                //if (seen.has(rowIdentifier)) {
                //    row.find('#txtEmployeeNo').css('color', 'black').focus();
                //    row.find("#ErrortxtEmployeeNo").css('display', 'flex');
                //    row.find("#ErrortxtEmployeeNo").html("Duplicate record not allow");
                //    hasError = true;
                //    return false;
                //} else {
                //    seen.add(rowIdentifier);
                //    hasError = false;
                //}

                if (tblRowData.InOut_EmployeeNo == "")
                {
                    row.find('#txtEmployeeNo').css('color', 'black').focus();
                    row.find("#ErrortxtEmployeeNo").css('display', 'flex');
                    row.find("#ErrortxtEmployeeNo").html("Employee No. Required");
                    hasError = true;
                    return false;
                }
                else
                {
                    row.find("#ErrortxtEmployeeNo").css('display', 'none');
                    row.find("#ErrortxtEmployeeNo").html("");
                    hasError = false;
                }

                if (tblRowData.InOut_AttendanceDate == "") {
                    row.find('#txtDate').css('color', 'black').focus();
                    row.find("#ErrortxtDate").css('display', 'flex');
                    row.find("#ErrortxtDate").html("Date Is Required");
                    hasError = true;
                    return false;
                }
                else {
                    row.find("#ErrortxtDate").css('display', 'none');
                    row.find("#ErrortxtDate").html("");
                    hasError = false;
                }

                var CheckInTimeError = row.find("#ErrortxtInTime").html();
                if (CheckInTimeError != "") {
                    row.find('#txtInTime').css('color', 'black').focus();
                    hasError = true;
                    return false;
                }
                else {
                    row.find('#txtInTime').css('color', 'black'); // Reset color
                    hasError = false;
                }

                var CheckOutTimeError = row.find("#ErrortxtOutTime").html();
                if (CheckOutTimeError != "") {
                    row.find('#txtOutTime').css('color', 'black').focus();
                    hasError = true;
                    return false;
                }
                else {
                    row.find('#txtOutTime').css('color', 'black'); // Reset color
                    hasError = false;
                }
                //var CheckOutTimeError = row.find("#ErrortxtOutTime").html();
                //if (CheckOutTimeError != "") {
                //    row.find('#txtOutTime').css('color', 'black').focus();
                //    hasError = true;
                //    return false;
                //}
                //else {
                //    row.find('#txtOutTime').css('color', 'black'); // Reset color
                //    hasError = false;
                //}
                tbldata.push(tblRowData);
            });
            console.log(tbldata);
            if (hasError == true) {
                return false;
            }
            //CHECK TABLE IS EMPTY
            if (tbldata.length == 0) {
                hasError = true;
                Swal.fire({
                    icon: "error",
                    text: "No Record In A Table",
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function () {
                    $(".Userloaderbg").css("display", "none");
                    return false;
                });
            }

