                                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblMultipleEmployeeLog" style="width: 100%;">
                                                <thead class="table-active horizontal-scroll tblheadEmployeeLog" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="trheading">
                                                        <th class="text-start text-center">Action</th>
