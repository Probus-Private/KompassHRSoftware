                                                        <th class="text-start text-center">Employee No.</th>
                                                        <th class="text-start text-center">Date</th>
                                                        <th class="text-start text-center">In-Time</th>
                                                        <th class="text-start text-center">Out-Time</th>
                                                        <th class="text-start text-center" style="width: 300px;">Remark</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @*@foreach (var d in ViewBag.EmployeeLog)
                                                        {
                                                            <tr onclick="tblEmployeeLogRowColor(this)">
                                                                <td class="text-nowrap text-center">@d.LoDate</td>
                                                                <td class="text-nowrap text-center">@d.Direction</td>
                                                                <td hidden>TimeSend 24Hr</td>
                                                                <td><i class="fa-regular fa-circle-up"></i></td>
                                                                <td><i class="fa-regular fa-circle-up"></i></td>
                                                            </tr>
                                                        }*@
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <br />
