    function convertTo24HourFormat(time12h) {
        var splitTime = time12h.split(' ');
        var time = splitTime[0];
        var period = splitTime[1];

        var splitHoursMinutes = time.split(':');
        var hours = splitHoursMinutes[0];
        var minutes = splitHoursMinutes[1];

        if (period === 'PM') {
            hours = parseInt(hours, 10) + 12;
            if (hours === 24) {
                hours = 12; // Special case: 12 PM should be converted to 12:00, not 24:00
            }
        } else {
            if (hours === '12') {
                hours = '00'; // Special case: 12 AM should be converted to 00:00
            }
        }
        return hours + ':' + minutes;
    }

