@model KompassHR.Areas.ESS.Models.ESS_TimeOffice.EmployeeWiseAttendance
@{
    ViewBag.Title = "ESS_TimeOffice_EmployeeWiseAttendance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /*select Row CSS Start*/
    body table.dataTable tbody tr.selected td {
        background: #fff7cc !important;
        color: black !important;
        font-weight: 600;
    }

    table.dataTable.table-hover > tbody > tr.selected:hover > * {
        box-shadow: inset 0 0 0 9999px #D0D3D4 !important;
    }

    /*Table Row Hover   rgba(0, 0, 0, 0.075);*/
    table.dataTable.table-hover > tbody > tr:hover > * {
        box-shadow: inset 0 0 0 9999px #D0D3D4 !important;
    }
    /*Table select Row BackGround Color */
    table.dataTable > tbody > tr.selected > * {
        box-shadow: inset 0 0 0 9999px #D0D3D4 !important;
        color: white;
    }

    /*.table{
           --bs-table-active-bg: #9bc2ce !important;
       }*/
    /*tr:nth-child(even) {
             --bs-table-accent-bg: #D0D3D4   !important;
             }*/
    /*select Row CSS End*/
    .dataTables_scrollBody::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
        margin-top: 0px;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .dataTables_scrollBody::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
        height: 10px;
    }

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
        border-collapse: collapse;
        background-color: #eee;
    }

    .fixed-side {
        position: sticky;
        left: 0;
        background-color: #eee;
        border-collapse: collapse;
    }
    
    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .fa-share-from-square {
        transform: rotate(180deg);
    }

    #tblEmployeeWise input[type="text"] {
        height: 25px; /* Adjust the height as needed */
    }

    #tblEmployeeWise input[type="datetime-local"] {
        height: 25px; /* Adjust the height as needed */
    }


    #tblEmployeeWise td:nth-child(3) {
        display: none;
    }


    .divEmployeeLog {
        height: 250px; /* Adjust height as needed */
        overflow-y: auto;
    }

    .tblheadEmployeeLog {
        position: sticky;
        top: 0;
        border-color: black;
    }

    .dataTables_wrapper .dataTables_scroll table.dataTable th, .dataTables_wrapper .dataTables_scroll tr.even td,
    .dataTables_wrapper .dataTables_scroll table.dataTable th, .dataTables_wrapper .dataTables_scroll tr.odd td {
        border-color: black !important;
        background-color: white !important;
    }

    #ShiftIconColor {
        color: #f39c12;
    }

    .table-responsive {
    height: 120px;
}
</style>

<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/ESS/ESS_TimeOffice_AttendanceRegularization_SubMenu/ESS_TimeOffice_AttendanceRegularization_SubMenu">Attendance Menu</a></li>
    </ol>
    <h1 class="page-header"> Employee Wise Attendance Regularization</h1>
    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Employee Wise Attendance Regularization </h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row">
                            <div class="col-md-12">
                                <form role="form" action="/ESS/ESS_TimeOffice_EmployeeWiseAttendance/ESS_TimeOffice_EmployeeWiseAttendance" id="SaveEmployeeWiseAttendance" method="post">
                                    @*<div class="row">
                                        <div class="col-md-6">
                                        <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                        Company Name
                                        <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CompanyName", id = "ddlCmpId" })
                                        </div>
                                        </div>
                                        </div>
                                        <div class="col-md-6">
                                        <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                        Business Unit
                                        <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                        </div>
                                        </div>
                                        </div>
                                        </div>*@

                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-5">
                                                    From date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-7">
                                                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", id = "txtFromDate", type = "date", name = "FromDate"})
                                                    <span class="Error" id="ErrortxtFromDate"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-5">
                                                    To Date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-7">
                                                    @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", id = "txtToDate", type = "date", name = "ToDate" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    Employee Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-7">
                                                    @Html.DropDownListFor(model => model.EmployeeID, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "EmployeeID", id = "ddlEmployeeID" })
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployee()" style="margin-left:-10px;">
                                                        <i class="fa-solid fa-spinner fa-lg"></i>&nbsp;Load
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                                <hr class="mt-2px">

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="row mb-15px">
                                            <div class="col-md-12">
                                                @Html.TextBox("ApplyDate", null, new { @class = "form-control", id = "ApplyTime", type = "datetime-local", name = "FromDate" })
                                                <span class="Error" id="ErrorApplyTime"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <div class="col-md-8">
                                                @Html.DropDownList("Status", new SelectList(new List<object>() {
                                                new {text="In",value="In"},
                                                new {text="Out",value="Out"},
                                                }, "text", "value"), "Select Punch Type", new { @class = "form-select", @id = "ddlApplyInOut", name = "ApplyInOut" })
                                                <span class="Error" id="ErrorddlApplyInOut"></span>
                                            </div>
                                            <div class="col-md-4">
                                                <button type="button" onclick="funSetInOutPunch(this)" class="btn btn-info" style="margin-left:-13px;margin-right:-10px">
                                                    <i class="fa-solid fa-pencil"></i> Adjust Punch
                                                </button>
                                                @*<input type="button" class="btn btn-primary btn-sm" onclick="funSetInOutPunch(this)" value="Adjust Punch" />*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-15px">
                                            <div class="col-md-8">
                                                @Html.DropDownList("Status", new SelectList(new List<object>() {
                                                new {text="P",value="P"},
                                                new {text="AB",value="AB"},
                                                 new {text="WO",value="WO"},
                                                 new {text="PH",value="PH"},
                                                 new {text="OD",value="OD"},
                                                 new {text="WFH",value="WFH"},
                                                 new {text="CO",value="CO"},
                                                 new {text="SL",value="SL"},
                                                 new {text="CL",value="CL"},
                                                 new {text="PL",value="PL"},
                                                 new {text="EL",value="EL"},
                                                 new {text="LWP",value="LWP"},
                                                }, "text", "value"), "Select Status", new { @class = "form-select", @id = "ddlStatus", name = "ApplyInOut" })
                                                <span class="Error" id="ErrorddlStatus"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-info" onclick="funSetStatus(this)" id="btnApplyStatus" style="margin-left: -15px;margin-right: -25px;">
                                                    <i class="fa-solid fa-pencil"></i> Set
                                                </button>
                                                @*<input type="button" class="btn btn-danger btn-sm" value="Set" onclick="funSetStatus(this)" id="btnApplyStatus" />*@
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" data-bs-toggle="offcanvas" class="btn btn-warning btnpress" href="#offcanvasExample" id="btnActionList" onclick="funSetDate(this)" style="width:110px; margin-left: 5px;">
                                                    <i class="fa-solid fa-eye fa-lg blink"></i> &nbsp; Show Log
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered table-hover mb-0 " id="tblEmployeeWise" style="width: 100%;">
                                                <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="trheading">
                                                        <th class="fixed-side" style="border: 1px solid black !important; z-index:3"> Action</th>
                                                        <th class="text-nowrap text-center"> Date</th>
                                                        <th class="text-nowrap text-center" hidden>Day</th>
                                                        <th class="text-nowrap text-center">In Time</th>
                                                        <th class="text-nowrap text-center">Out Time</th>
                                                        <th class="text-nowrap text-center">Status</th>
                                                        <th class="text-nowrap text-center">Shift</th>
                                                        <th class="text-nowrap text-center">Total <br />Duration</th>
                                                        <th class="text-nowrap text-center">Over <br />Time</th>
                                                        @*<th class="text-nowrap text-center">Late <br />Mark</th>*@
                                                        <th class="text-nowrap text-center">Late <br /> Coming</th>
                                                        @*<th class="text-nowrap text-center">Early Coming</th>*@
                                                        <th class="text-nowrap text-center">Early<br /> Going</th>
                                                        <th class="text-nowrap text-center">No Of <br />COFF</th>
                                                        <th class="text-nowrap text-center" style="width:200px;">Remark</th>

                                                    </tr>
                                                </thead>
                                                <tbody id="tbodyEmployeeWise">
                                                    @if (ViewBag.AttendanceList != null)
                                                    {
                                                        foreach (var d in ViewBag.AttendanceList)
                                                        {
                                                            string formattedInTime = "";
                                                            string formattedOutTime = "";
                                                            <tr>

                                                                @if (@d.InTime != null || @d.OutTime != null)
                                                                {
                                                                    if (@d.InTime != null)
                                                                    {
                                                                        formattedInTime = @d.InTime.ToString("yyyy-MM-ddTHH:mm");
                                                                    }
                                                                    else
                                                                    {
                                                                        formattedInTime = "2999-01-01T00:00";
                                                                    }
                                                                    if (@d.OutTime != null)
                                                                    {
                                                                        formattedOutTime = @d.OutTime.ToString("yyyy-MM-ddTHH:mm");
                                                                    }
                                                                    else
                                                                    {
                                                                        formattedOutTime = "2999-01-01T00:00";
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    formattedInTime = "2999-01-01T00:00";
                                                                    formattedOutTime = "2999-01-01T00:00";
                                                                }
                                                                <td class="text-nowrap text-center fixed-side" style="background-color:#eee !important">
                                                                    @*<button type="button" onclick="deleteRow(this)" id="btnDelete" class="btn btn-danger btn-sm">  </button>*@
                                                                    <i class="fa-regular fa-trash-can fa-xl" onclick="deleteRow(this)" id="btnDelete" style="color:#ff5b57"></i>
                                                                </td>
                                                                @if (@d.attenDate != null)
                                                                {
                                                                    <td class="text-nowrap" id="AttenDate" style="background-color:white !important"><span>@d.attenDate.ToString("dd-MM-yyyy")</span><span style="font-size: 10px;">&nbsp;&nbsp;(@d.Day)</span></td>
                                                                    <td class="text-nowrap">@d.Day</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap" id="AttenDate" style="background-color:white !important"></td>
                                                                    <td class="text-nowrap"></td>
                                                                }

                                                                @if (formattedInTime == "2999-01-01T00:00")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control InTime" id="txtInTime" value="" name="timeInput" onclick="getRowNumber(this)" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    DateTime myDate = @d.InTime.AddDays(1);
                                                                    string InTimeMax = myDate.ToString("yyyy-MM-ddTHH:mm");

                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control InTime" id="txtInTime" min="@d.InTime.ToString("yyyy-MM-ddTHH:mm")" max="@InTimeMax" value="@d.InTime.ToString("yyyy-MM-ddTHH:mm")" name="timeInput" onclick="getRowNumber(this)" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }
                                                                @if (formattedOutTime == "2999-01-01T00:00")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control OutTime" id="txtOutTime" value="" onclick="getRowNumber(this)" name="timeInput" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    DateTime myDate = @d.InTime.AddDays(1);
                                                                    string OutTimeMax = myDate.ToString("yyyy-MM-ddTHH:mm");
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="datetime-local" class="form-control OutTime" min="@d.OutTime.ToString("yyyy-MM-ddTHH:mm")" max="@OutTimeMax" id="txtOutTime" value="@d.OutTime.ToString("yyyy-MM-ddTHH:mm")" onclick="getRowNumber(this)" name="timeInput" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }

                                                                @if (@d.Status == "AB")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="text" class="form-control" id="txtInOutStatus" onclick="getRowNumber(this)" name="timeInput" value="@d.Status" style="width:60px;text-align: center; background-color:#ff5b57" readonly>
                                                                    </td>
                                                                }
                                                                else if (@d.Status == "WO")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="text" class="form-control" id="txtInOutStatus" onclick="getRowNumber(this)" name="timeInput" value="@d.Status" style="width:60px;text-align: center; background-color:orange" readonly>
                                                                    </td>
                                                                }
                                                                else if (@d.Status != "AB" && @d.Status != "WO")
                                                                {
                                                                    <td class="text-nowrap" style="background-color:white !important">
                                                                        <input type="text" class="form-control" id="txtInOutStatus" onclick="getRowNumber(this)" name="timeInput" value="@d.Status" style="width:60px;text-align: center;" readonly>
                                                                    </td>
                                                                }

                                                                <td class="text-nowrap" style="background-color:white !important">
                                                                    <input type="text" class="form-control" id="txtShift" onclick="getRowNumber(this)" name="timeInput" value="@d.Shift" style="width:60px;text-align: center;" readonly>
                                                                </td>
                                                                <td class="text-nowrap text-center" style="background-color:white !important">@d.TotalDuration</td>
                                                                <td class="text-nowrap text-center" style="background-color:white !important">@d.OverTime</td>

                                                                @* <td class="text-nowrap">@d.InOutLateBy</td>*@
                                                                <td class="text-nowrap text-center" style="background-color:white !important">@d.LateComing</td>
                                                                <td class="text-nowrap text-center" style="background-color:white !important">@d.EarlyGoing</td>
                                                                <td class="text-nowrap text-center" style="background-color:white !important">@d.NoOffCOFF</td>
                                                                <td class="text-nowrap text-center" style="background-color:white !important"><input type="text" id="txtRemark" class="form-control" style="width:200px;" /></td>
                                                            </tr>
                                                        }
                                                    }
                                                    @if (ViewBag.AttendanceListNew != null)
                                                    {

                                                        foreach (var d in ViewBag.AttendanceListNew)
                                                        {
                                                            @*<script>
                                                                    var GetDay = @d.EM_WO_CurrentDay;
                                                                    var Day = GetDay.slice(0, 3);
                                                                </script>*@
                                                            <tr>
                                                                <td class="text-nowrap text-center" style="background-color:#eee !important">
                                                                    <i class="fa-regular fa-trash-can fa-xl" onclick="deleteRow(this)" id="btnDelete" style="color:#ff5b57"></i>
                                                                </td>
                                                                <td class="text-nowrap" id="AttenDate" style="background-color:white !important">
                                                                   
                                                                    <span>@d.InOut_AttendanceDate.ToString("dd-MM-yyyy")</span>
                                                                    @if (@d.EM_WO_CurrentDay != null)
                                                                    {
                                                                        <span style="font-size: 10px;">&nbsp;&nbsp;(@d.EM_WO_CurrentDay.Substring(0, 3))</span>
                                                                    }
                                                                </td>

                                                                @if (@d.EM_WO_CurrentDay != null)
                                                                {
                                                                    <td class="text-nowrap">@d.EM_WO_CurrentDay</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap"></td>
                                                                }

                                                                @if (@d.InOut_InTime == null)
                                                                {
                                                                    <td class="text-nowrap">
                                                                        <input type="datetime-local" class="form-control InTime" id="txtInTime" value="" name="timeInput" onclick="getRowNumber(this)" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    DateTime GetInTimeDate = @d.InOut_InTime;
                                                                    DateTime myDate = GetInTimeDate.AddDays(1);
                                                                    string InTimeMax = myDate.ToString("yyyy-MM-ddTHH:mm");

                                                                    <td class="text-nowrap">
                                                                        <input type="datetime-local" class="form-control InTime" min="@d.InTime" max="@InTimeMax" id="txtInTime" value="@d.InOut_InTime.ToString("yyyy-MM-ddTHH:mm")" name="timeInput" onclick="getRowNumber(this)" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }
                                                                @if (@d.InOut_OutTime == null)
                                                                {
                                                                    <td class="text-nowrap">
                                                                        <input type="datetime-local" class="form-control OutTime" id="txtOutTime" value="" onclick="getRowNumber(this)" name="timeInput" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    DateTime GetOutTimeDate = @d.InOut_OutTime;
                                                                    DateTime myDate = GetOutTimeDate.AddDays(1);
                                                                    string OutTimeMax = myDate.ToString("yyyy-MM-ddTHH:mm");
                                                                    <td class="text-nowrap">
                                                                        <input type="datetime-local" class="form-control OutTime" min="@d.InOut_OutTime" max="@OutTimeMax" id="txtOutTime" value="@d.InOut_OutTime.ToString("yyyy-MM-ddTHH:mm")" onclick="getRowNumber(this)" name="timeInput" onchange="validateTimeInput(this)" style="width:170px">
                                                                    </td>
                                                                }

