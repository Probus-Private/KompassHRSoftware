@model KompassHR.Areas.ESS.Models.ESS_TimeOffice.Leave_ShortLeave
@{
    ViewBag.Title = "ShortLeaveList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }
</style>



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>ShortLeaveList</title>
</head>
<body>
    <div id="content" class="app-content">
        <!-- BEGIN breadcrumb -->
        <ol class="breadcrumb float-xl-end">
            <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active"><a href="/ESS/ESS_TimeOffice_Menu/ESS_TimeOffice_Menu/?id=5"> Time Office Menu</a></li>
        </ol>
        <!-- END breadcrumb -->
        <!-- BEGIN page-header -->
        <h1 class="page-header"> ShortLeave Approve List </h1>
        <!-- END page-header -->
        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title"> Short Leave Approve List</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                               data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            
                              
                        </div>
                    </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            
                            
                        </p>
                    </div>
                    <div class="panel-body" data-scrollbar="true">
                        <div class="row">
                            <div class="col-md-12">
                                <a href="/Requisition/ShortLeave/ShortLeave">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="data-table-combine"
                                               style="width: 100%;">
                                            <thead>
                                                <tr class="trheading">
                                                    <th class="fixed-side">Cancel</th>
                                                    <th class="fixed-side1">Status</th>
                                                    <th class="text-nowrap text-center">Auto/Manually</th>
                                                    <th class="text-nowrap text-center">Doc No </th>
                                                    <th class="text-nowrap text-center">Doc Date </th>
                                                    <th class="text-nowrap text-center">Req Date</th>
                                                    <th class="text-nowrap text-center">Employee Name</th>
                                                    <th class="text-nowrap text-center">Employee No</th>
                                                    <th class="text-nowrap text-center">Shift</th>
                                                    <th class="text-nowrap text-center">Direction</th>
                                                    <th class="text-nowrap text-center">For Time</th>
                                                    <th class="text-nowrap text-center">Reason</th>
                                                    <th class="text-nowrap text-center">Approve/Rejected by</th>
                                                    <th class="text-nowrap text-center">Approve/Rejected Date</th>
                                                    <th class="text-nowrap text-center">Rejected Reason</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.ShortLeaveList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <button type="button" onclick="CancelFunction('@d.ShortLeaveID_Encrypted')" id="btnDelete"
                                                                    class="btn btn-danger ListBtn btnpress">
                                                                <i class="fa-solid fa-xmark"></i>
                                                            </button>
                                                        </td>
                                                        <td class="text-nowrap">@d.ApprovedDay</td>
                                                        <td class="text-nowrap">@d.ApprovedAutoManually</td>
                                                        <td class="text-nowrap">@d.DocNo</td>
                                                        <td class="text-nowrap">@d.DocDate</td>
                                                        <td class="text-nowrap">@d.ReqDate</td>
                                                        <td class="text-nowrap">@d.EmployeeName</td>
                                                        <td class="text-nowrap">@d.EmployeeNo</td>
                                                        <td class="text-nowrap">@d.ShiftName</td>
                                                        <td class="text-nowrap">@d.Direction</td>
                                                        <td class="text-nowrap">@d.ForTime</td>
                                                        <td class="text-nowrap">@d.Reason</td>
                                                        <td class="text-nowrap">@d.Manager1</td>
                                                        <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                        <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                    </tr>
                                                }

                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- END panel -->
                    </div>
                </div>
            </div>
</body>
</html>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>

    @*function UpdateCompanyProfile(CompanyId) {
        alert(CompanyId)
        var url = '@Url.Action("CompanyProfile", "CompanyProfile")?CompanyId=' + CompanyId;
        window.location.href = url;
    }*@

    function DeleteCompanyProfile(ShortLeaveID_Encrypted) {
             const DeleteButtons = Swal.mixin({
                 customClass: {
                     cancelButton: ' btnpress',
                     confirmButton: ' btnpress'
                 },
                 buttonsStyling: true
             })
             DeleteButtons.fire({
                 title: 'Are you sure?',
                 text: "You won't be able to revert this!",
                 icon: 'warning',
                 confirmButtonColor: '#d33',
                 cancelButtonColor: '#3085d6',
                 showCancelButton: true,
                 confirmButtonText: 'Yes, delete it!',
                 cancelButtonText: 'No, cancel!',
                 reverseButtons: false,

                 allowOutsideClick: () => {
                     const popup = Swal.getPopup()
                     popup.classList.remove('swal2-show')
                     setTimeout(() => {
                         popup.classList.add('animate__animated', 'animate__headShake')
                     })
                     setTimeout(() => {
                         popup.classList.remove('animate__animated', 'animate__headShake')
                     }, 500)
                     return false
                 }

             }).then((result) => {
                 if (result.isConfirmed) {
                     window.location.href = '@Url.Action("Delete", "ShortLeave")?ShortLeaveID_Encrypted=' + ShortLeaveID_Encrypted;
                     //window.location.href = url;
                     DeleteButtons.fire(
                         'Deleted!',
                         'Your file has been deleted.',
                         'success'
                     )
                 } else if (
                     /* Read more about handling dismissals below */
                     result.dismiss === Swal.DismissReason.cancel
                 ) {

                 }
             })
    }
</script>



<div class="modal" id="modal_basic2" tabindex="-1" role="dialog" aria-labelledby="defModalHead" aria-hidden="true" style="display: none ;margin-top:50px">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Cancel</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
            </div>
            <div class="modal-body">
                <div class="form-group row mb-3">
                    <label class="col-lg-4 col-form-label form-label" for="Remark">Remark:</label>
                    <div class="col-lg-8">
                        @Html.TextAreaFor(model => model.ApproveRejectRemark, new { @class = "input-sm form-control", id = "txtRejectRemark", placeholder = "Enter Remark" })

                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <input type="submit" class="Ok btn btn-success" data-dismiss="modal" id="btnReject" value="Cancel" />
            </div>
        </div>
    </div>
</div>


<script>
    function CancelFunction(OutDoorCompanyId) {
        $('#modal_basic2').modal('show');
    }
</script>


