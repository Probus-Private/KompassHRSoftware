@{
    ViewBag.Title = "Final Reviewer Evaluation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-title {
    font-size: 22px;
    font-weight: 700;
    color: #1e293b;
}

.page-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}

.page-actions img {
    width: 24px;
    height: auto;
    cursor: pointer;
}












    body {
        background: #f4f6fa;
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden;
    }

    /* ===== PAGE CONTAINER ===== */
    .review-wrapper {
        max-width: 1400px;
        margin: 20px auto;
        padding: 22px;
        background: #ffffff;
        border: 1px solid #d1d5db;
        border-radius: 10px;
    }

    /* ===== PAGE HEADER ===== */
    .page-header {
        padding-bottom: 16px;
        margin-bottom: 20px;
        border-bottom: 2px solid #e5e7eb;
    }

        .page-header h1 {
            font-size: 22px;
            font-weight: 700;
            color: #1e3a8a;
            margin: 0;
        }

        .page-header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 4px;
        }

    /* ===== CARD SECTION ===== */
    .card-section {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 24px;
    }

    /* ===== SECTION HEADER ===== */
    .section-title {
        font-size: 15px;
        font-weight: 700;
        color: #1e3a8a;
        margin-bottom: 12px;
        padding: 8px 12px;
        background: #eef2ff;
        border-left: 4px solid #1e3a8a;
    }

    /* ===== EMPLOYEE INFO TABLE ===== */
    .info-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        background: #f9fafb;
        border-radius: 6px;
        overflow: hidden;
    }

        .info-table td {
            padding: 10px 12px;
            border: 1px solid #d1d5db;
            background: #ffffff;
        }

            .info-table td.label {
                background: #f1f5f9;
                font-weight: 600;
                width: 15%;
                color: #1f2937;
            }

    /* ===== KRA CALCULATION TABLE ===== */
    .calc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .calc-table th {
            background: #e5e7eb;
            padding: 10px;
            border: 1px solid #c7cdd4;
            text-align: center;
            font-weight: 600;
            white-space: nowrap;
        }

        .calc-table td {
            padding: 10px;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            text-align: center;
        }

            .calc-table td.left {
                text-align: left;
                background: #ffffff;
            }

            .calc-table td.actual {
                font-weight: 700;
                color: #1e40af;
                background: #eef2ff;
            }

            .calc-table td.weightage {
                background: #fef3c7;
                font-weight: 700;
            }

            .calc-table td.total {
                background: #e5e7eb;
                font-weight: 700;
            }

        .calc-table tbody tr:hover td {
            background: #f1f5f9;
        }

        .calc-table tfoot td {
            background: #f3f4f6;
            font-weight: 700;
            border-top: 2px solid #9ca3af;
        }

            .calc-table tfoot td.label {
                text-align: center;
                background: #e5e7eb;
            }

            .calc-table tfoot td.final {
                background: #dcfce7;
                color: #065f46;
                font-size: 14px;
            }

    /* ===== FINAL SCORE ===== */
    .final-score {
        margin-top: 20px;
        padding: 16px;
        background: #ecfdf5;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        text-align: center;
        font-weight: 700;
        font-size: 18px;
        color: #047857;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .muted {
        font-size: 12px;
        color: #6b7280;
        font-weight: normal;
    }
</style>

<div id="content" class="app-content">
    <div class="review-wrapper">
        <div class="row mb-3">
            <div class="col-md-12 d-flex justify-content-between align-items-center">

                <!-- PAGE TITLE -->
                <h1 class="page-title mb-0">
                    KRA Evaluation
                </h1>

                <!-- HOME & BACK -->
                <div class="page-actions">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })"
                       title="Home">
                        <img src="~/assets/MenuImages/Home.png" alt="Home">
                    </a>

                    <a href="@Url.Action("ESS_PMS_Menu", "ESS_PMS_Menu",
                    new { id = 11, ScreenId = 594, area = "ESS" })"
                       title="Back">
                        <img src="~/assets/MenuImages/Back.png" alt="Back">
                    </a>
                </div>

            </div>
        </div>

        <div class="card-section">
            <div class="section-title">Employee Information</div>
            <table class="info-table">
                <tr>
                    <td class="label">Employee Name</td>
                    <td>Dheerendra Kumar Joshi</td>
                    <td class="label">Department</td>
                    <td>Administrative</td>
                    <td class="label">Designation</td>
                    <td>Business Analyst</td>
                </tr>
                <tr>
                    <td class="label">Grade</td>
                    <td>A</td>
                    <td class="label">PMS Year</td>
                    <td>2024</td>
                </tr>
            </table>
        </div>

        <!-- KRA CALCULATION -->
        <div class="card-section">
            <div class="section-title">Objective / KRA Calculation</div>
            <table class="calc-table">
                <thead>
                    <tr>
                        <th>Objective</th>
                        <th>KRA</th>
                        <th>Unit</th>
                        <th>Target Type</th>
                        <th>Standard</th>
                        <th>Target</th>
                        <th>Actual</th>
                        <th>50 % between<br />Standard & Target</th>
                        <th>Rating</th>
                        <th>Weightage</th>
                        <th>Weightage × Rating</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var d in ViewBag.KraList)
                    {
                        <tr class="kra-row">
                            <td class="left">@d.Objective</td>
                            <td class="left">@d.KRA</td>
                            <td>@d.UOM</td>
                            <td>@d.TargetType</td>
                            <td><input type="number" class="form-control standard" value="@(d.Standard ?? 0)" /></td>
                            <td class="target" data-target="@d.EffectiveTarget">
                                @d.EffectiveTarget
                            </td>
                            <td class="actual" data-actual="@d.ActualValue">
                                @d.ActualValue
                            </td>
                            <td class="mid" data-mid="@d.MidValue">@d.MidValue</td>
                            <td class="rating">0</td>
                            <td class="weightage" data-weightage="@d.Weightage">
                                @d.Weightage
                            </td>
                            <td class="total">0</td>
                        </tr>
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <td colspan="9" class="label">Total</td>
                        <td id="totalWeightage" class="weightage">0</td>
                        <td id="totalScore" class="total">0</td>
                    </tr>
                    <tr>
                        <td colspan="10" class="label">Average Rating</td>
                        <td id="avgRating" class="final">0</td>
                    </tr>
                </tfoot>

            </table>
        </div>

        <!-- FINAL SCORE -->
        <div class="final-score">
            Final Appraisal(KRA) Rating : <b><span id="FinalRatingScore"></span></b>
            <div class="muted">Calculated as per yearly appraisal policy</div>
        </div>

    </div>
</div>

<script>
    function getExcelRating(standard, target, actual) {

        const mid = standard + ((target - standard) / 2);
        let rating = 0;
        if (standard < target) {
            if (actual <= standard) {
                rating = 1;
            }
            else if (actual > standard && actual < mid) {
                rating = 2;
            }
            else if (actual >= mid && actual < target) {
                rating = 3;
            }
            else {
                rating = 4;
            }
        }
        else {

            if (actual >= standard) {
                rating = 1;
            }
            else if (actual < standard && actual > mid) {
                rating = 2;
            }
            else if (actual <= mid && actual > target) {
                rating = 3;
            }
            else {
                rating = 4;
            }
        }

        return { rating, mid };
    }

    function calculateAll() {

        var totalWeightage = 0;
        var totalScore = 0;

        document.querySelectorAll(".kra-row").forEach(function (row) {

            var standard = parseFloat(row.querySelector(".standard").value) || 0;
            var target = parseFloat(row.querySelector(".target").dataset.target) || 0;
            var actual = parseFloat(row.querySelector(".actual").dataset.actual) || 0;
            var weightage = parseFloat(row.querySelector(".weightage").dataset.weightage) || 0;

            var result = getExcelRating(standard, target, actual);
            var rating = result.rating;
            var mid = result.mid;

            var score = rating * weightage;

            row.querySelector(".mid").innerText = mid.toFixed(2);
            row.querySelector(".rating").innerText = rating;
            row.querySelector(".total").innerText = score.toFixed(2);

            totalWeightage += weightage;
            totalScore += score;
        });

        document.getElementById("totalWeightage").innerText = totalWeightage.toFixed(2);
        document.getElementById("totalScore").innerText = totalScore.toFixed(2);

        document.getElementById("avgRating").innerText =
            totalWeightage > 0
                ? (totalScore / totalWeightage).toFixed(2)
                : "0.00";

        var FinalRating = document.getElementById("avgRating").innerText;
        document.getElementById("FinalRatingScore").innerText = FinalRating;

    }
    document.addEventListener("input", e => {
        if (e.target.classList.contains("standard")) {
            calculateAll();
        }
    });

    document.addEventListener("DOMContentLoaded", calculateAll);


document.addEventListener("input", function (e) {
    if (e.target.classList.contains("standard")) {
        calculateAll();
    }
});

document.addEventListener("DOMContentLoaded", function () {
    calculateAll();
});
</script>







