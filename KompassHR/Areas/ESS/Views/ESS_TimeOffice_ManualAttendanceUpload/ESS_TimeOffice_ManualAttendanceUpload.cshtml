    //THIS CODE IS USE FOR INPUT TYPE NUMBER NOT ALLOW MAX 10 DIGIT
    $(document).on('input', '.txtNumber', function() {
        if (this.value.length > 10) {
            this.value = this.value.slice(0, 10);
        }
    });

    //THIS CODE IS USE FOR REMOVE ROW IN A TABLE
    function removeRow(button) {
        var row = button.parentNode.parentNode;
        row.parentNode.removeChild(row);
        updateSrNo();
    }

    function updateSrNo() {
        var table = document.getElementById("tblManualUploadItems");
        var rows = table.getElementsByTagName("tr");
        for (var i = 1; i < rows.length; i++) { // Assuming the first row is the header
            rows[i].cells[1].innerText = i; // Update SrNo, assuming it's in the first cell
        }
    }
</script>
