<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });//Ready Funcation
</script>

<script>
    $("#btnfileupload").click(function(){
        debugger;
        var fileInput = document.getElementById('txtAttachFile');
        if (fileInput.files.length === 0) {
            Swal.fire({
                icon:  "error",
                text: "Please import excel file",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        $('#tblManualUploadItems').not(function(){return!!$(this).has('th').length;}).remove();
        $("#SaveManualUpload").submit();
    })

    $("#btnSave").click(function () {
        //function ManualUploadSave() {
        debugger;
        var hasError = true;
        var table = document.getElementById("tblManualUploadItems");
        var rowCount = table.rows.length;
        if (rowCount <= 1)
        {
            $("#ErrorFile").html("Please import file first");
            return false;
        }
        else
        {
            $("#ErrorFile").html("");
        }
        var ObjManualAttendance = [];
        $("#tblManualUploadItems tbody tr").each(function (index) {

            var row = $(this);
            var varEmployeeNo = row.find("td").eq(2).find("input").val();
            //data1.EmployeeCardNo = row.find("td").eq(3).find("input").val();
            var varInTime = row.find("td").eq(3).find("input").val();
            var varOutTime = row.find("td").eq(4).find("input").val();

            var SrNo = index+1;

            if(varEmployeeNo=="")
            {
                Swal.fire({
                    text: 'Please Enter EmployeeNo In Sr.no. '+SrNo+'',
                    icon: 'error',
                });
                hasError = false;
                return false;
            }
            //else if(data1.EmployeeCardNo=="")
            //{
            //    Swal.fire({
            //        text: 'Please Enter EmployeeCardNo In Sr.no. '+SrNo+'',
            //        icon: 'error',
            //    });
            //    return false;
            //}
            else if(varInTime=="" && varOutTime=="")
            {
                Swal.fire({
                    text: 'Please Enter Date-InTime Or OutTime In Sr.no. '+SrNo+'',
                    icon: 'error',
                });
                hasError = false;
                return false;
            }
            //else if(varOutTime=="")
            //{
            //    Swal.fire({
            //        text: 'Please Enter Date-OutTime In Sr.no. '+SrNo+'',
            //        icon: 'error',
            //    });
            //    hasError = false;
            //    return false;
            //}
            const IN_fromDate = new Date(varInTime);
            const IN_year = IN_fromDate.getFullYear();
            const IN_month = IN_fromDate.getMonth() + 1; // getMonth() returns 0-11, so we add 1
            const IN_date = IN_fromDate.getDate();
            var InDateTime = IN_year +"-"+ IN_month +"-" +IN_date

            // IN Time
            const IN_hours = IN_fromDate.getHours();
            const IN_minutes = IN_fromDate.getMinutes();

            const OUT_fromDate = new Date(varOutTime);
            const OUT_year = OUT_fromDate.getFullYear();
            const OUT_month = OUT_fromDate.getMonth() + 1; // getMonth() returns 0-11, so we add 1
            const OUT_date = OUT_fromDate.getDate();

            var OUTDateTime = OUT_year +"-"+ OUT_month +"-" +OUT_date
            // OUT Time
            const OUT_hours = OUT_fromDate.getHours();
            const OUT_minutes = OUT_fromDate.getMinutes();

            const inDate = new Date(InDateTime);
            const outDate = new Date(OUTDateTime);

            // Compare the Date objects
            if (InDateTime == OUTDateTime)
            {
                var myDateInTime = new Date(varInTime);
                var nineAMInTime = new Date(myDateInTime);
                nineAMInTime.setHours(5, 0, 0, 0);

                var myDateOutTime = new Date(varOutTime);
                var nineAMOutTime = new Date(myDateOutTime);
                nineAMOutTime.setHours(5, 0, 0, 0);

                if (myDateInTime < nineAMInTime) {
                    Swal.fire({
                        icon: "error",
                        text: "In-time should not be less than 5:00 AM in sr.no: "+SrNo+"",
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    hasError = false;
                    return false;
                }
                if (myDateOutTime < nineAMOutTime) {
                    Swal.fire({
                        icon: "error",
                        text: "Out-time should not be less than 5:00 AM in sr.no: "+SrNo+"",
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    hasError = false;
                    return false;
                }
            }
            if (outDate < inDate) {

                Swal.fire({
                    icon: "error",
                    text: "OutDateTime should not be less than InDateTime in sr.no: "+SrNo+"",
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
                hasError = false;
                return false;
            }

            if (outDate > inDate) {
                var myDateTime = new Date(varOutTime);
                var nineAM = new Date(myDateTime);
                nineAM.setHours(9, 0, 0, 0);
                if (myDateTime > nineAM) {
                    Swal.fire({
                        icon: "error",
                        text: "Out time should not be greter than 9:00 AM in sr.no: "+SrNo+"",
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    }).then(function () {
                        hasError = false;
                        return false;
                    });
                    hasError = false;
                    return false;
                }
            }

            var data1 = {};
            data1.EmployeeNo = row.find("td").eq(2).find("input").val();
            //data1.EmployeeCardNo = row.find("td").eq(3).find("input").val();
            data1.InTime = row.find("td").eq(3).find("input").val();
            data1.OutTime = row.find("td").eq(4).find("input").val();
            ObjManualAttendance.push(data1);
        });
        var jsonData = JSON.stringify(ObjManualAttendance);
        if(hasError == false)
        {
            return false;
            $(".Userloaderbg").css("display","none");
        }
        $(".Userloaderbg").css("display","flex");
        $.ajax({
            url: '@Url.Action("SaveUpdate", "ESS_TimeOffice_ManualAttendanceUpload")',
            method: "POST",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            //data: JSON.stringify({ TestOBJAttenINOUT: ObjManualAttendance}),
            data: jsonData,
            success: function (response) {
                debugger;
                $(".Userloaderbg").css("display","none");
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (Icon1 !=null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '@Url.Action("ESS_TimeOffice_ManualAttendanceUpload", "ESS_TimeOffice_ManualAttendanceUpload")';
                            }
                        });
                    }
                }
            }
        });
    });
</script>

