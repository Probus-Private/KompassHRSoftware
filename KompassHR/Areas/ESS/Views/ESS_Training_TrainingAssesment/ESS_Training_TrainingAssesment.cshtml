                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />
                    <div class="card shadow-sm rounded">
                        <div class="card-header text-center bg-light">
                            <h4 class="card-title">Employee Information</h4>
                        </div>
                        <div class="card-body p-1">
                            <div class="row">
                                <div class="col-12 col-md-6 mb-0">
                                    <div class="invoice-from">
                                        @* <small class="text-muted d-block">From : </small>*@
                                        <address class="custom-font">
                                            <i class="fa-solid fa-user"></i>&nbsp;&nbsp;<b>Employee Name:</b> @Session["EmployeeName"] - @Session["EmployeeNo"] <br />
                                            <i class="fa-solid fa-briefcase"></i>&nbsp;&nbsp;<b>Designation:</b> @Session["DepartmentName"] / @Session["DesignationName"] <br />
                                            <i class="fa-solid fa-calendar"></i>&nbsp;&nbsp;<b>JoiningDate:</b> @Session["JoiningDate"] <br />
                                        </address>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <style>
                        body {
                            font-family: Arial, sans-serif;
                            margin: 0;
                            padding: 0;
                            background-color: #f9f9f9;
                        }

                        .container {
                            max-width: 96%;
                            margin: 20px auto;
                            background: #ffffff;
                            padding: 20px;
                            border-radius: 8px;
                            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                        }

                        h3 {
                            font-size: 1.25rem;
                            color: #333;
                        }

                        .form-group {
                            margin-bottom: 20px;
                        }

                        label {
                            display: flex;
                            align-items: center;
                            padding: 3px;
                            border: 1px solid #ccc;
                            border-radius: 8px;
                            cursor: pointer;
                            transition: background-color 0.2s ease;
                        }

                            label:hover {
                                background-color: #f1f1f1;
                            }

                        input[type="radio"],
                        input[type="checkbox"] {
                            margin-right: 10px;
                        }

                        textarea {
                            width: 100%;
                            min-height: 100px;
                            resize: vertical;
                            padding: 10px;
                            border: 1px solid #ccc;
                            border-radius: 4px;
                        }

                        .btn:hover {
                            background-color: #0056b3;
                        }

                        .success-message {
                            position: fixed;
                            bottom: 20px;
                            right: 20px;
                            background-color: #28a745;
                            color: #fff;
                            padding: 10px 20px;
                            border-radius: 4px;
                            display: flex;
                            align-items: center;
                        }

                        .hidden {
                            display: none;
                        }
                    </style>
                    @if (ViewBag.GetQuestionList != null)
                    {
                        foreach (var d in ViewBag.GetQuestionList)
                        {
                            <input type="text" value="@d.OptionType" hidden id="txtQuestionType" />
                            <input type="text" value="@d.QustionID" hidden id="txtQustionID" />
                            <div class="container">
                                <form id="feedbackForm">
                                    <div class="form-group">
                                        <h3><span class="bold-question" style="color: #5496cf"><i class="fa-brands fa-quora"></i>. @d.Question</span></h3>
                                        <div>
                                            @foreach (var e in ViewBag.GetOptionsList)
                                            {
                                                double MasterQustionID = Convert.ToDouble(d.QustionID);
                                                double DetailQustionID = Convert.ToDouble(e.QustionID);
                                                double OptionId = Convert.ToDouble(e.OptionId);
                                                if (MasterQustionID == DetailQustionID)
                                                {
                                                    if (d.OptionType == 1)
                                                    {
                                                        <div class="col-md-12 option-container">
                                                            <input type="text" value="@e.MasterID" hidden id="txtMasterID" />
                                                            <label class="option-label">
                                                                @if (e.IsSelected == "True")
                                                                {
                                                                    <input type="radio" name="RadioOption_@e.QustionID" value="@e.OptionId" id="RadioOption_@e.OptionId" class="option-input" checked />}
                                                                else
                                                                {
                                                                    <input type="radio" name="RadioOption_@e.QustionID" value="@e.OptionId" id="RadioOption_@e.OptionId" class="option-input" />}
                                                                @e.OptionName
                                                                <input type="text" value="@e.OptionId" hidden id="txtOptionId" />
                                                            </label>
                                                        </div>    }
                                                    if (d.OptionType == 2)
                                                    {
                                                        <div class="col-md-12 option-container">
                                                            <input type="text" value="@e.MasterID" hidden id="txtMasterID" />
                                                            <label class="option-label">
                                                                @if (e.IsSelected == "True")
                                                                {
                                                                    <input type="checkbox" name="CheckboxOption_@e.QustionID" value="@e.OptionId" id="CheckboxOption_@e.OptionId" class="option-input" checked />}
                                                                else
                                                                {
                                                                    <input type="checkbox" name="CheckboxOption_@e.QustionID" value="@e.OptionId" id="CheckboxOption_@e.OptionId" class="option-input" />}
                                                                @e.OptionName
                                                            </label>
                                                        </div>    }
                                                    if (d.OptionType == 3)
                                                    {
                                                        <div class="col-md-12 text-area-container">
                                                            <input type="text" value="@e.MasterID" hidden id="txtMasterID" />
                                                            @if (e.InputRemark != "")
                                                            {
                                                                <textarea id="InputText_@e.OptionId" name="InputText_@e.QustionID" class="text-area" rows="4">@e.InputRemark</textarea><br />}
                                                            else
                                                            {
                                                                <textarea id="InputText_@e.OptionId" name="InputText_@e.QustionID" class="text-area" rows="4"></textarea><br />}
                                                        </div>
                                                    }
                                                }
                                            }

                                            <div class="row">
                                                <div class="col-md-10">
                                                    @if (d.OptionType == 3)
                                                    {
                                                        <label class="form-label col-form-label col-md-6" id="lblerror_@d.QustionID" style="display: none; color: red;">Kindly Enter Text.</label>
                                                    }
                                                    @if (d.OptionType == 2)
                                                    {
                                                        <label class="form-label col-form-label co6" id="lblerror_@d.QustionID" style="display: none; color: red;">Kindly Choose at least One/Multiple Option.</label>
                                                    }
                                                    else
                                                    {
                                                        <label class="form-label col-form-label col-md-6" id="lblerror_@d.QustionID" style="display: none; color: red;">Kindly Choose at least One Option.</label>}
                                                </div>                                     <div class="col-md-2">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit" onclick="funSubmit(@d.QustionID,@d.OptionType)" class="btn btn-primary btn-sm" style="padding: 3px 6px;">
                                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                            @Html.HiddenFor(model => model.Training_AssesmentQuestionId, new { id = "txtTraining_AssesmentQuestionId", Value = d.Training_AssesmentQuestionId })
                            @Html.HiddenFor(model => model.Training_AssesmentQuestionId_Encrypted, new { id = "txtTraining_AssesmentQuestionId_Encrypted" })
                        }
                    }

                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>



<script>
    $(document).ready(function () {
        $("#formReset").click(function () {
            $("#TrainingAssesment")[0].reset();
        });

        $("#ddlTrainingCalenderID").select2();
        $("#ddlTrainingLangaugeID").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#btnShow").click(function () {
            let isValid = true;

            let trainingCalenderId = $('#ddlTrainingCalenderID').val();
            let trainingLangaugeId = $('#ddlTrainingLangaugeID').val();

            let calenderError = $('#ddlTrainingCalenderID-error');
            let languageError = $('#ddlTrainingLangaugeID-error');

            // Training Calendar validation
            if (!trainingCalenderId || trainingCalenderId === "" || trainingCalenderId === "0") {
                calenderError.text("Please select a training calendar.");
                calenderError.show();
                isValid = false;
            } else {
                calenderError.hide();
            }

            // Language validation
            if (!trainingLangaugeId || trainingLangaugeId === "" || trainingLangaugeId === "0") {
                languageError.text("Please select a language.");
                languageError.show();
                isValid = false;
            } else {
                languageError.hide();
            }

            // Redirect if valid
            if (isValid) {
                window.location.href = '@Url.Action("ESS_Training_TrainingAssesment", "ESS_Training_TrainingAssesment")'
                    + '?TrainingCalenderId=' + trainingCalenderId + '&TrainingLangaugeId=' + trainingLangaugeId;
            }
        });
    });
</script>

