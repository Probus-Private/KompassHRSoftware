                                    @Html.HiddenFor(model => model.Training_AssesmentQuestionId, new { @class = "form-control", id = "Training_AssesmentQuestionId" })
                                    @Html.HiddenFor(model => model.Training_AssesmentQuestionId_Encrypted, new { @class = "form-control", id = "TrainingPlan_MasterId_Encrypted" })
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row mb-10px">
                                <h6>
                                    Language
                                    <span class="important">*</span>
                                </h6>
                                <div class="col-md-6">
                                    @Html.DropDownListFor(model => model.TrainingLangaugeId, new SelectList(ViewBag.TrainingAssesmentLangauge, "Id", "Name"), "--Select--", new { id = "ddlTrainingLangaugeID", name = "TrainingLangaugeID", @class = "form-select", autocomplete = "off" })
                                    <span id="ddlTrainingLangaugeID-error" class="text-danger" style="display:none;"></span>
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn btn-primary btn-sm" id="btnShow">
                                        Show
