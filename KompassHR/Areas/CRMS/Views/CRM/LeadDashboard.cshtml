<style>
            .cardbX {
                color: #fff;
                height: fit-content;
                padding: 20px;
                background: rgb(4,34,100);
                border-radius: 10px;
                backdrop-filter: blur(5px);
                -webkit-backdrop-filter: blur(5px);
                border: 3px solid rgba(255, 255, 255, 1);
                overflow: auto;
            }

                .cardbX:hover {
                    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
                    border: 3px solid skyblue;
                    transition: all 0.5s;
                    overflow: auto;
                }

                .cardbX .cardbX-body .MainHeading {
                    text-align: center;
                    font-size: 20px;
                    color: skyblue;
                    letter-spacing: 1px;
                    overflow: auto;
                }

            a {
                text-decoration: none;
                overflow: auto;
            }

            .display-6 {
                font-size: 20px;
                font-weight: 500;
                overflow: auto;
            }

            .cardbX .cardbX-body {
                display: flex;
                justify-content: center;
                align-items: center;
                flex-direction: column;
                overflow: auto;
            }

            img.box-icon {
                width: 100px;
                margin-bottom: 10px;
                overflow: auto;
            }

                img.box-icon:hover {
                    transform: scale(1.1);
                    overflow: auto;
                }

            .highcharts-credits {
                display: none;
                overflow: auto;
            }

            .highcharts-background {
                overflow: auto;
                overflow-y: scroll;
            }

            .data-selector {
                width: auto; /* Limit width for larger screens */
                border: none; /* Remove border */
                margin: 0 auto; /* Center align */
                font-weight: bold; /* Remove default styles */
                background: none; /* Optional: Set background to transparent */
                padding: 8px; /* Add some padding for a better touch target */
                display: block; /* Ensures it behaves like a block element */
                font-size: 12px;
                outline: none;
            }

            /* Centering the select element in its container */
            .highcharts-figure {
                text-align: center;
                flex: 1; /* Ensures the pie charts take up equal space */
                min-width: 300px; /* Center the content */
            }

            .data-selector .option {
                background: #1b76a3bf;
                color: white;
            }

            .highcharts-figure #container, .highcharts-figure #container1 {
                width: 100%;
                height: 300px; /* Adjust the height as necessary */
            }

            .chart-container {
                display: flex; /* Use flexbox to align the charts side by side */
                justify-content: space-between; /* Optional: space between the two charts */
                gap: 20px; /* Optional: adds space between the charts */
                flex-wrap: wrap; /* Allow the charts to wrap on smaller screens */
            }

            @@media (max-width: 320px) {
                .highcharts-button-symbol {
                    width: 12px;
                    height: 12px;
                }

                /* Add space between buttons and edges of the screen */
                .highcharts-button {
                    margin: 0 10px; /* Adds space on both sides of the button */
                }
            }
        </style>

<style>
