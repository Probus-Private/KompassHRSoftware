<script>
    $(document).ready(function () {
        debugger
        let chartInstance;
        function loadChartData(filterType) {
            var d1 = $("#single-date").val();
            $.ajax({
                url: '@Url.Action("GetAnalyticsData", "CRM")',
                type: 'GET',
                data: { filterType: filterType, d1: d1 },
                success: function (response) {
                    if (response.success) {
                        const labels = filterType === "Weekly"
                        ? response.labels.map(label => `Day ${label}`)
                        : response.labels;

                        renderChart(labels, response.leadCounts, response.opportunityCounts, response.accountCounts);
                    } else {
                        console.error(response.message || response.error);
                        alert("Failed to load analytics data.");
                    }
                },
                error: function () {
                    alert("Server error while loading chart data.");
                }
            });
        }

        function renderChart(labels, leadData, opportunityData, accountData) {
            const ctx = document.getElementById('analyticsChart').getContext('2d');

            if (chartInstance) {
                chartInstance.destroy();
            }

            // ✅ Calculate totals
            const totalLeads = leadData.reduce((sum, val) => sum + val, 0);
            const totalOpportunities = opportunityData.reduce((sum, val) => sum + val, 0);
            const totalAccounts = accountData.reduce((sum, val) => sum + val, 0);

            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                    {
                        label: `Lead (Total: ${totalLeads})`,
                        data: leadData,
                        borderColor: 'rgba(54, 162, 235, 1)',
                        backgroundColor: 'rgba(54, 162, 235, 0.2)',
                        fill: true,
                        tension: 0.3
                    },
                    {
                        label: `Opportunity (Total: ${totalOpportunities})`,
                        data: opportunityData,
                        borderColor: 'rgba(255, 206, 86, 1)',
                        backgroundColor: 'rgba(255, 206, 86, 0.2)',
                        fill: true,
                        tension: 0.3
                    },
                    {
                        label: `Account (Total: ${totalAccounts})`, // ✅ new dataset
                        data: accountData,
                        borderColor: 'rgba(75, 192, 192, 1)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        fill: true,
                        tension: 0.3
                    }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top'
                        },
                        title: {
                            display: true,
                            text: 'Lead vs Opportunity vs Account' // ✅ updated title
                        }
                    }
                }
            });
        }

        // Load default chart on page load
        loadChartData($('#filterType').val());

        // Reload on dropdown change
        $('#filterType').on('change', function () {
            loadChartData($(this).val());
        });
    });
</script>

