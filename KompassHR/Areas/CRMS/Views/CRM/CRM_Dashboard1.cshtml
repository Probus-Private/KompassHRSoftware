@model KompassHR.Areas.CRMS.Models.ACCMAIN
@using System.Drawing;

@{
    ViewBag.Title = "CRM_Dashboard1";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    body{
        background-color:#e4e7e8;
    }

</style>

@*<script src="~/assets/plugins/d3/d3.js"></script>
  <script src="~/assets/plugins/d3/d3.min.js"></script>*@

@{
    string mmValue = "";
    if (ViewBag.mm != null)
    {
        // Parse the "MM-yyyy" format into DateTime
        DateTime parsedDate = DateTime.ParseExact(ViewBag.mm, "MM-yyyy", null);
        // Convert to "September 2024" format
        mmValue = parsedDate.ToString("MMMM yyyy");
    }
}

<style>
    #nv-stacked-area-chart1 svg:nth-of-type(2) {
        display: none;
    }
</style>

<style>
    #ESSDashboard .menu-submenu {
        box-sizing: border-box;
        display: block;
    }

        #ESSDashboard .menu-submenu .Dashboard1 {
            font-size: 14px;
            color: #fff !important;
        }
</style>

<style>
    /* Make the chart container responsive */
    #visitors1-line-chart {
        width: 100%; /* Full width of the parent container */
        height: auto; /* Adjust height automatically */
    }

    /* Hide specific buttons (stream expand, etc.) on smaller screens */
    @@media (max-width: 768px) {
        .nvd3-svg .nv-legend {
            display: none; /* Hide legend or expand buttons on smaller screens */
        }
    }
</style>

<div id="content" class="app-content">
