<script>
    var List = @Html.Raw(Json.Encode(ViewBag.Data));
    debugger
    function parseDate(dateString) {
        const timestamp = dateString.replace('/Date(', '').replace(')/', '');
        return parseInt(timestamp, 10);
    }

    function handleStackedAreaChart(filterType) {
        "use strict";

        var stackedAreaChartData = [
            { 'key': 'OpportunityCount', 'color': 'red', 'values': [] },
            { 'key': 'AccountCount', 'color': 'orange', 'values': [] },
            { 'key': 'LeadCount', 'color': 'black', 'values': [] }
        ];

        // Totals
        var totalOpportunities = 0;
        var totalAccounts = 0;
        var totalLeads = 0;

        List.forEach(function (entry) {
            debugger
            var leadCount = parseInt(entry.find(item => item.Key === 'LeadCount').Value);
            var opportunityCount = parseInt(entry.find(item => item.Key === 'OpportunityCount').Value);
            var accountCount = parseInt(entry.find(item => item.Key === 'AccountCount').Value);
            var dateValue = entry.find(item => item.Key === 'date').Value;
            var timestamp = parseDate(dateValue);

            // Apply filtering logic
            var includeThis = true;

            if (filterType === 'monthly') {
                var date = new Date(timestamp);
                var currentDate = new Date();
                if (date.getFullYear() !== currentDate.getFullYear() || date.getMonth() !== currentDate.getMonth()) {
                    includeThis = false;
                }
            }

            if (includeThis) {
                debugger
                stackedAreaChartData[0].values.push([timestamp, opportunityCount]);
                stackedAreaChartData[1].values.push([timestamp, accountCount]);
                stackedAreaChartData[2].values.push([timestamp, leadCount]);

                // Update totals
                totalOpportunities += opportunityCount;
                totalAccounts += accountCount;
                totalLeads += leadCount;
            }
        });

        // Update the counts in the labels
        $('#opportunityCount').text(totalOpportunities);
        $('#accountCount').text(totalAccounts);
        $('#leadCount').text(totalLeads);

        // Sort values by date
        stackedAreaChartData.forEach(function (series) {
            debugger
            series.values.sort(function (a, b) {
                return a[0] - b[0];
            });
        });

        // Clear previous chart
        d3.select('#nv-stacked-area-chart1').selectAll("*").remove();

        nv.addGraph(function () {
            var stackedAreaChart = nv.models.stackedAreaChart()
                .useInteractiveGuideline(true)
                .x(function (d) { return d[0]; })
                .y(function (d) { return d[1]; })
                .controlLabels({ stacked: 'Stacked' })
                .showControls(false)
                .duration(300);

            stackedAreaChart.xAxis.tickFormat(function (d) {
                return d3.time.format('%b %d')(new Date(d));
            });

            d3.select('#nv-stacked-area-chart1')
                .append('svg')
                .datum(stackedAreaChartData)
                .transition().duration(1000)
                .call(stackedAreaChart)
                .each('start', function () {
                    setTimeout(function () {
                        d3.selectAll('#nv-stacked-area-chart1 *').each(function () {
                            if (this.__transition__)
                                this.__transition__.duration = 1;
                        });
                    }, 0);
                });

            nv.utils.windowResize(stackedAreaChart.update);
            return stackedAreaChart;
        });
    }


    $(document).ready(function () {
        // Initial render as 'monthly'
        handleStackedAreaChart('monthly');

        // Change filter event
        $('#filterType').on('change', function () {
            var selectedFilter = $(this).val();
            handleStackedAreaChart(selectedFilter);
        });
    });
</script>



