@model KompassHR.Areas.CRMS.Models.ACCSITES
@{
    ViewBag.Title = "AccountDetailsEdit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="content" class="app-content">



    <!-- BEGIN page-header -->
    <div class="d-flex flex-wrap mb-1">
    
    </div>
    <!-- END page-header -->

    <div class="panel panel-inverse">
        <!-- BEGIN panel-heading -->
        <div class="panel-heading">
            <h4 class="panel-title">Site List</h4>
          
        </div>
        <!-- END panel-heading -->
        <!-- BEGIN panel-body -->

        <div class="panel-body">
            <div class="row">
                <div class="col-12 overflow-auto">
                    <table id="" class="table table-striped table-bordered align-middle TablePage mt-1 mb-1">
                        <thead>
                            <tr>
                                <th hidden></th>
                                <th class="width-45"></th>
                                <th class="text-nowrap">Site Name</th>
                                <th class="text-nowrap">Site Code</th>
                                <th class="text-nowrap">Site Start Date</th>
                                <th class="text-nowrap">Site Close Date</th>
                                <th class="text-nowrap">Site Status</th>

                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in ViewBag.ACCSites)
                            {
                                <tr>
                                    <td class="width-45">
                                        <span class="d-flex justify-content-evenly">
                                            <a href="#" onclick="location.href='@Url.Action("AccountDetailsEditList", "CRM",new {EncryptedId = @item.Encrypted_Id ,Fid = @item.Fid ,area="CRM"})'" title="Update Shift"> <i class="fa fa-pencil fa-lg"></i></a>
                                            @*<a href="#" onclick="DeleteMAS_EMPRSGN('@item.Fid')" title="delete"> <i class="fa fa-trash fa-lg text-danger"></i></a>*@
                                        </span>
                                    </td>
                                    <td hidden>@item.Fid</td>
                                    <td>@item.SiteName</td>
                                    <td>@item.SiteCode</td>
                                    <td>@item.SiteOpenDate</td>
                                    <td>@item.SiteCloseDate</td>
                                    <td>@item.SiteStatus</td>

                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>



        </div>
        <!-- END panel-body -->
    </div>


    <div class="modal fade" id="modal-dialog">
        <div class="modal-dialog">
            <div class="modal-content">
            
                <div class="modal-body">
                 
                </div>
                <div class="modal-footer">
                    <a href="javascript:;" class="btn btn-white" data-bs-dismiss="modal">Close</a>
                    <a href="#" id="Print" class="btn btn-success">Show</a>
                </div>
            </div>
        </div>
    </div>
    <div id="footer" class="app-footer m-0">
        &copy;
        <script>document.write(new Date().getFullYear())</script> Probus Software. All Right Reserved
    </div>

</div>


