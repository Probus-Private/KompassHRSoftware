                <!-- BEGIN panel-body -->
                <div class="panel-body">
                    @{
                        var alertClasses = new[] { "alert-primary", "alert-success", "alert-warning", "alert-gray-500", "alert-info" };
                        int index = 0;
                    }

                    <div data-scrollbar="true" data-height="230px" style="height: 230px;">
                        @if (ViewBag.Opportunity != null)
                        {
                            foreach (var item in ViewBag.Opportunity)
                            {

                                var firstLetter = string.IsNullOrEmpty(item.CompanyName) ? "?" : item.CompanyName.ToString().Substring(0, 1).ToUpper();
                                var alertClass = alertClasses[index % alertClasses.Length]; // Rotate colors

                                <div class="note @alertClass mb-2 d-flex align-items-center">
                                    <div class="note-icon me-2">
                                        <div style="width: 39px; height: 38px; background-color: #c5f2ec; color: black; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: initial;">
                                            @firstLetter
                                        </div>
                                    </div>

                                    <div class="note-content">
                                        <h4><b>@item.CompanyName</b></h4>
                                        <p>
                                            <strong>Lead:</strong> @item.LeadName<br />
                                            <strong>Stage:</strong> @item.Stage
                                        </p>
                                    </div>
                                </div>

                                index++; // Only increment when a company is shown
                            }

                        }
                        else
                        {
                            <div class="note alert-secondary">
                                <div class="note-content">
                                    <p>No opportunities found.</p>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
