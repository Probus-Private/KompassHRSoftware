@model KompassHR.Areas.CRMS.Models.ACCMAIN

@{
    ViewBag.Title = "OpportunityDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #e4e7e8;
    }
</style>

<style>
    #nv-stacked-area-chart1 svg:nth-of-type(2) {
        display: none;
    }
</style>

<style>
    p {
        margin-top: -8px;
        margin-bottom: 0.9375rem;
    }

    .note .note-content {
        padding: 5px;
        flex: 1;
        margin-bottom: -18px;
    }

    .note .note-icon {
        width: 72px;
        font-size: 29px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .alert-primary {
        background-color: #b3d7ff;
        color: #00254d;
        height: 86px;
    }

    .alert-warning {
        background-color: #ffdfb3;
        color: #4d2d00;
    }

