                            @foreach (var item in ViewBag.OpportunityCountAll)
                            {
                                <div class="widget-chart-info-progress">
                                    <b>@item.Stage</b>
                                    <span class="float-end">@item.counts</span>
                                </div>
                                <br />
                            }
                        </div>
                        <hr />         
                    </div>
                </div>
                <!-- END widget-content -->
            </div>

            <!-- END col-4 -->
        </div>
        <!-- END row -->
    </div>

   </div>
    <script src="~/assets/js/demo/chart-d3.demo.js"></script>

    @*new chart*@
    <script>
    var handleStackedAreaChart = function () {
        "use strict";
        debugger
        var List = @Html.Raw(Json.Encode(ViewBag.Data));
        //var LeadList = @Html.Raw(Json.Encode(ViewBag.LeadgraphData));

        function parseDate(dateString) {
            const timestamp = dateString.replace('/Date(', '').replace(')/', '');
            return parseInt(timestamp, 10); // Return the timestamp as an integer
        }

        var stackedAreaChartData = [
          {
              'key': 'OpportunityCount',
              'color': 'red',
              'values': []
              }
        ];

        List.forEach(function(entry) {
            var opportunityCount = entry.find(item => item.Key === 'OpportunityCount').Value;
            var date = entry.find(item => item.Key === 'date').Value;
            var timestamp = parseDate(date);
            stackedAreaChartData[0].values.push([timestamp, opportunityCount]);  // For OpportunityCount
        });

        stackedAreaChartData.forEach(function(series) {
            series.values.sort(function(a, b) {
                return a[0] - b[0]; // Sort by the timestamp (first element of the array)
            });
        });

        nv.addGraph(function () {
            var stackedAreaChart = nv.models.stackedAreaChart()
                .useInteractiveGuideline(true)
                .x(function (d) { return d[0] })
                .y(function (d) { return d[1] })
                .controlLabels({ stacked: 'Stacked' })
                .showControls(false)
                .duration(300);

            stackedAreaChart.xAxis.tickFormat(function (d) {
                return d3.time.format('%b %d')(new Date(d));
            });
            //stackedAreaChart.yAxis.tickFormat(d3.format(',.4f'));

            d3.select('#nv-stacked-area-chart1')
              .append('svg')
              .datum(stackedAreaChartData)
              .transition().duration(1000)
              .call(stackedAreaChart)
              .each('start', function () {
                  setTimeout(function () {
                      d3.selectAll('#nv-stacked-area-chart1 *').each(function () {
                          if (this.__transition__)
                              this.__transition__.duration = 1;
                      })
                  }, 0)
              });

            nv.utils.windowResize(stackedAreaChart.update);
            return stackedAreaChart;
        });
    };

    $(document).ready(function () {
        debugger
        handleStackedAreaChart();
    });
    </script>

