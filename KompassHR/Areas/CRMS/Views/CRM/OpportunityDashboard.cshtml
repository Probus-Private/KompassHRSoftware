        // Get the selected date value from the input
        const selectedDate = document.getElementById("single-date").value;
        if (selectedDate) {
            const dateParts = selectedDate.split("-");
            const year = dateParts[0];  // Year part (e.g., "2024")
            const month = dateParts[1]; // Month part (e.g., "10")
            console.log("Month:", month); // e.g., "10"
            console.log("Year:", year);   // e.g., "2024"
            var formattedDate = `${month}-${year}`;
            $("#SENDDATA").submit();
        }
    }
    </script>

