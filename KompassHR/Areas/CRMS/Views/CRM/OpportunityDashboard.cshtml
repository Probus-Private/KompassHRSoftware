                <!-- END widget-header -->
                <!-- BEGIN widget-content -->
                <div class="row m-0">
                    <div class="col widget-chart-content">
                        <div id="nv-stacked-area-chart1" style="height: 108%"></div>
                    </div>

                    <div class="col-lg-4 p-3">
