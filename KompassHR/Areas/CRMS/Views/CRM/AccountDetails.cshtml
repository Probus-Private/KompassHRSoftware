            let value = $(this).val().replace(/,/g, '');

            // Format the number with commas
            if (!isNaN(value) && value !== '') {
                $(this).val(formatNumber(value));
            }
        });

        $('#txtMonthlyContractValue').on('input', function() {
            debugger
            // Remove any existing commas for formatting
            let value = $(this).val().replace(/,/g, '');

            // Format the number with commas
            if (!isNaN(value) && value !== '') {
                $(this).val(formatNumber(value));
            }
        });

        $('#txtTotalContractValue').on('input', function() {
            debugger
            // Remove any existing commas for formatting
            let value = $(this).val().replace(/,/g, '');

            // Format the number with commas
            if (!isNaN(value) && value !== '') {
                $(this).val(formatNumber(value));
            }
        });

        $('#txtAnnualContractValue').on('input', function() {
            debugger
            // Remove any existing commas for formatting
            let value = $(this).val().replace(/,/g, '');

            // Format the number with commas
            if (!isNaN(value) && value !== '') {
                $(this).val(formatNumber(value));
            }
        });

    });

    function formatNumber(num) {
        // Convert to a number and format with commas
        return num.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }

    function calculateContractValues() {
        debugger
        var tenure = parseFloat(document.getElementById("txtContractTenure").value);
        var totalValue = parseFloat(document.getElementById("txtTotalContractValue").value.replace(/,/g, ''));

        if (!isNaN(tenure) && !isNaN(totalValue) && tenure > 0) {
            var monthlyValue = totalValue / tenure;

            if(tenure < 12)
            {
                var annualValue = totalValue ;
            }
            else{
                var annualValue = monthlyValue * 12;
            }


            document.getElementById("txtMonthlyContractValue").value = formatNumber1(monthlyValue.toFixed(2));
            document.getElementById("txtAnnualContractValue").value = formatNumber1(annualValue.toFixed(2));
        } else {
            document.getElementById("txtMonthlyContractValue").value = "";
            document.getElementById("txtAnnualContractValue").value = "";
        }
    }

    function calculateAVCINCTAX(){
        debugger
        var tax = parseFloat(document.getElementById("txtTaxPercentage").value);
        var ACV = parseFloat(document.getElementById("txtAnnualContractValue").value.replace(/,/g, ''));

        if (!isNaN(tax) && !isNaN(ACV) && tax > 0) {
            var AVCINCTAX = ACV + (ACV * (tax / 100));

            document.getElementById("txtACVAmountIncludingTax").value = formatNumber1(AVCINCTAX.toFixed(2));
            $("#txtACVAmountIncludingTax").attr('readonly', true);
        } else {
            document.getElementById("txtACVAmountIncludingTax").value = "";
        }
    }

    function calculateMangment(){
        debugger
        var MangPer = parseFloat(document.getElementById("txtManagementFeeInPercent").value);
        var ACV = parseFloat(document.getElementById("txtACVAmountIncludingTax").value.replace(/,/g, ''));

        if (!isNaN(MangPer) && !isNaN(ACV) && MangPer > 0) {
            var AVCINCTAX = (ACV * (MangPer / 100));

            document.getElementById("txtManagementFee").value = formatNumber1(AVCINCTAX.toFixed(2));
            $("#txtManagementFee").attr('readonly', true);
        } else {
            document.getElementById("txtManagementFee").value = "";
        }
    }



    function formatNumber1(num) {
        // Convert to a number and format with commas
        return parseFloat(num).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }


</script>

<script>

    var rawAllEncryptedIds = @Html.Raw(Json.Encode(ViewBag.AllEncryptedIds));
    var allEncryptedIds = rawAllEncryptedIds.map(item => item.find(x => x.Key === 'Encrypted_Id').Value);

    var currentEncryptedId = "@ViewBag.EncryptedId";
    var currentIndex = allEncryptedIds.indexOf(currentEncryptedId);

    // Determine previous and next record IDs
    var previousId = (currentIndex > 0) ? allEncryptedIds[currentIndex - 1] : null;
    var nextId = (currentIndex < allEncryptedIds.length - 1) ? allEncryptedIds[currentIndex + 1] : null;

    // Handle previous button click
    $('#prevBtn').click(function() {
        if (previousId) {
            window.location.href = '@Url.Action("AccountDetails")' + '?EncryptedId=' + previousId;
        }
    });

    // Handle next button click
    $('#nextBtn').click(function() {
        if (nextId) {
            window.location.href = '@Url.Action("AccountDetails")' + '?EncryptedId=' + nextId;
        }
    });

    // Disable buttons if no previous or next ID
    if (!previousId) {
        $('#prevBtn').addClass('disabled');
    }
    if (!nextId) {
        $('#nextBtn').addClass('disabled');
    }

