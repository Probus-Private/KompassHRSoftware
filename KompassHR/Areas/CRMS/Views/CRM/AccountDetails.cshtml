        }

        if (NextFollowUpDate != ""){
            $('#txtNextFollowUpDate').attr('min', formattedDate1);
        }

    });
    })
    function convertDate(dateString) {
        debugger
        // Try to parse the input date string
        const parsedDate = new Date(dateString);
        debugger
        // Check if the parsed date is valid
        if (!isNaN(parsedDate)) {
            debugger
            // Return an object with the ISO date string
            return {
                isoDate: parsedDate.toISOString().split('T')[0] // ISO format: YYYY-MM-DD
            };
        } else {
            // Return null if the date is invalid
            return null;
        }
    }

