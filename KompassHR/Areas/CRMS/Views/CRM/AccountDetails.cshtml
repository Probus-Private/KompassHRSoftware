                confirmButtonText: `Yes`,
                denyButtonText: `No`,
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Are you sure?',
                        showCancelButton: true,
                        confirmButtonText: 'Yes',
                        cancelButtonText: 'No'
                    }).then((secondResult) => {
                        if (secondResult.isConfirmed) {
                            document.getElementById("UpdateLeadStage").submit();
                        } else {
                            // Reset to the initial value if the user cancels
                            $("#txtStage").val(Stageddl);
                        }
                    });
                } else {
                    // Reset to the initial value if the user cancels
                    $("#txtStage").val(Stageddl);
                }
            });
        } else {
            Swal.fire({
                title: 'Are you sure?',
                showCancelButton: true,
                confirmButtonText: 'Yes',
                cancelButtonText: 'No'
            }).then((secondResult) => {
                if (secondResult.isConfirmed) {
                    document.getElementById("UpdateLeadStage").submit();
                } else {
                    // Reset to the initial value if the user cancels
                    $("#txtStage").val(Stageddl);
                }
            });
        }
    }
</script>

