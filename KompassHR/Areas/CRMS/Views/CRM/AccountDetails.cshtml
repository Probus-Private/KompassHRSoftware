<script>

    document.getElementById('txtMobileNo').addEventListener('input', function (e) {
        debugger
        var value = e.target.value;
        if ((value.match(/\+/g) || []).length > 1) {
            // Remove all '+' signs and then add one at the start
            e.target.value = value.replace(/\+/g, '').replace(/^\d/, '+' + '$&');
        } else {
            // Replace any non-digit characters except for the first '+' (if present)
            e.target.value = value.replace(/[^\d+]/g, '');
        }
    });

    $("#txtRateRevision").change(function(){
        debugger
        var RateRevision = $("#txtRateRevision").val();

        if (RateRevision == "false"){
            $("#txtDurationInMonths").prop('disabled',true)
            $("#txtDurationInMonths").val(null);
        }else{
            $("#txtDurationInMonths").prop('disabled',false)
        }
    })
</script>

<script>
