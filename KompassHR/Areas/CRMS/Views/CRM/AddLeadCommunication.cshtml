<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .hidden-column {
        display: none;
    }
</style>

<div id="content" class="app-content">
    <div class="row">
        @*<div class="col-12">
            <button type="button" class="btn btn-danger d-lg-block m-b-15" onclick="location.href='@Url.Action("Lead_Dashboard", "CRM")'" style="float:right;"><i class="fa fa-arrow-left"></i>&nbsp;Back</button>
        </div>*@
        <ol style="list-style: none; padding: 0; margin: 0; ">
            <li style="float:right; margin-right: 15px;">
                <a href="@Url.Action("Lead_Dashboard", "CRM",  new { id = 45,ScreenId=803, area = "CRMS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
    </div>
    <br />
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Add Lead Communication -</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="panel-body">
                    <form role="form" action="/CRMS/CRM/SaveLeadCommunication" id="SaveLeadCommunication" method="post" data-parsley-validate="">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="email">Company Name:<span class="text-danger">*</span></label>
                                @Html.DropDownList("ACCMAIN_Fid", new SelectList(ViewBag.CompanyList, "Fid", "CompanyName"), "Select", new { @class = "form-control form-select", name = "ACCMAIN_Fid", Id = "txtACCMAIN_Fid" })
                                @Html.Hidden("isredirect", "", new { @class = "form-control", name = "isredirect", Value = true })
                                @Html.Hidden("BUCode", "", new { @class = "form-control", name = "BUCode", id = "BUCode" })
                                @Html.Hidden("ACCCommunication_EncryptedId", "", new { id = "ACCCommunication_EncryptedId" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Communication Type:<span class="text-danger">*</span></label>
                                @Html.DropDownList("CommunicationType", new SelectList(new List<Object>
                                        {
                                        new { value = "Phone Call" , text = "Phone Call" },
                                        new { value = "Email"  , text = "Email"  },
                                        new { value = "Virtual Meeting" , text = "Virtual Meeting" },
                                        new { value = "In-Person Meeting" , text = "In-Person Meeting" },
                                        new { value = "Other" , text = "Other" },},
                                        "value", "text"), "Select", new { @class = "form-control", name = "CommunicationType", id = "txtCommunicationType", autocomplete = "Off" })

                            </div>
                           
                            <div class="col-md-6 mb-3" id="CommunicationDateEdit" style="display: none;">
                                <label class="mb-2" for="email">Date:</label>
                                @Html.TextBox("CommunicationDate", "", new { @class = "form-control", name = "CommunicationDate", id = "txtCommunicationDateEdit", autocomplete = "off", type = "date" })
                            </div>
                            <div class="col-md-6 mb-3" id="CommunicationDateCreate">
                                <label class="mb-2" for="email">Date:</label>
                                @Html.TextBox("CommunicationDate", today, new
                           {
                               @class = "form-control",
                               name = "CommunicationDate",
                               id = "txtCommunicationDateCreate",
                               autocomplete = "off",
                               type = "date"@*, min = ViewBag.TodayDate*@ })
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Contact Person:<span class="text-danger">*</span></label>
                                @Html.DropDownList("ACCCONTACT_Fid", new SelectList(ViewBag.ContactPersonList, "Fid", "ContactPerson"), "Select", new { @class = "form-control", name = "ACCCONTACT_Fid", Id = "txtACCCONTACT_Fid1" })
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Follow Up Status:<span class="text-danger">*</span></label>
                                @Html.DropDownList("FollowUpStatus", new SelectList(new List<Object>
                                        {
                                        new { value = "Open" , text = "Open" },
                                        new { value = "In Process"  , text = "In Process"  },
                                        new { value = "Hold" , text = "Hold" },
                                        new { value = "Closed" , text = "Closed"},},
                                        "value", "text"), "Select", new { @class = "form-control", name = "FollowUpStatus", id = "txtFollowUpStatus", autocomplete = "Off" })
                            </div>

                        </div>
                        @*<div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="mb-2" for="email">Description * :</label>
                                @Html.TextArea("Description", "", new { @class = "form-control summernote", name = "Description", id = "txtDescription1", autocomplete = "Off" })
                            </div>
                        </div>*@

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="mb-2" for="email">Description:</label>
                                @Html.TextArea("Description", "", new { @class = "summernote", name = "Description", style = "border: 1px solid #000;", id = "txtDescription1", autocomplete = "Off", @placeholder = "Description....", contenteditable = "true" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Next follow up date:</label>
                                @Html.TextBox("NextFollowUpDate", "", new { @class = "form-control", name = "NextFollowUpDate", id = "txtNextFollowUpDate", type = "date", autocomplete = "Off" })
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="email">Follow Up Remark :</label>
                                @Html.TextBox("FollowUpRemark", "", new { @class = "form-control", name = "FollowUpRemark", id = "txtFollowUpRemark", autocomplete = "Off" })
                            </div>
                        </div>
                        <div class="row" align="center">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="CommunicationSubmit"
                                                        class="btn btn-primary">
                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <br />
                    <div class="row">
                        <div class="col-12 overflow-auto">

                            <table id="tableCriteria4" class="table table-striped table-bordered align-middle table-responsive">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>Contact Person</th>
                                        <th>Communication Type</th>
                                        <th>Communication Date</th>
                                        <th hidden>Description</th>
                                        <th hidden>Follow Up Status</th>
                                        <th>Next Follow Up Date</th>
                                        <th hidden>ACCCOMM_EncryptedId</th>
                                        <th hidden>ContactFid</th>
                                        <th>Follow Up Remark</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>



                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $("#tableCriteria4").on('click', '.btnselect', function () {
        debugger;
        var table = document.getElementById("tableCriteria4");
        var rowCount = table.rows.length;
        var currentRow = $(this).closest("tr");

        var CommunicationType = currentRow.find("td:eq(2)").text();
        var CommunicationDate = currentRow.find("td:eq(3)").text();
        var ContactPerson = currentRow.find("td:eq(8)").text();
        var NextFollowUpDate = currentRow.find("td:eq(6)").text();
        var Description = currentRow.find("td:eq(4)").html();
        var EncryptedId = currentRow.find("td:eq(7)").text();
        var FollowUpStatus = currentRow.find("td:eq(5)").text();
        var FollowUpRemark = currentRow.find("td:eq(9)").text();

        $('#txtCommunicationType').val(CommunicationType).trigger('change');
        var formattedDate = formatDate(CommunicationDate);
        $('#txtCommunicationDateEdit').val(formattedDate);

        $('#txtACCCONTACT_Fid1').val(ContactPerson).trigger('change');
        $('#txtFollowUpStatus').val(FollowUpStatus).trigger('change');
        //$('#txtDescription1').summernote('code', Description);
        $('#txtDescription1').val(Description);
        var formattedDate1 = formatDate(NextFollowUpDate);
        $('#txtNextFollowUpDate').val(formattedDate1);

        $('#ACCCommunication_EncryptedId').val(EncryptedId);
        $('#txtFollowUpRemark').val(FollowUpRemark);

        if (EncryptedId) {
            $("#CommunicationDateCreate").hide();
            $("#CommunicationDateEdit").show();
        } else {
            $("#CommunicationDateCreate").show();
            $("#CommunicationDateEdit").hide();
        }

        if (NextFollowUpDate != "") {
            $('#txtNextFollowUpDate').attr('min', formattedDate1);
        }

    });



    function formatDate(dateStr) {
        debugger
        var date = new Date(dateStr);
        var year = date.getFullYear();
        var month = ('0' + (date.getMonth() + 1)).slice(-2);
        var day = ('0' + date.getDate()).slice(-2);
        return year + '-' + month + '-' + day;
    }

    $(document).ready(function () {
        debugger

        $('#txtACCMAIN_Fid').change(function () {
            debugger
            var txtACCMAIN_Fid = $(this).val();
            $('#txtACCCONTACT_Fid1').empty();

            if (txtACCMAIN_Fid !== "") {
                $.ajax({
                    url: "@Url.Action("GetConPerson", "CRM")",
                    method: "get",
                    data: { txtACCMAIN_Fid: txtACCMAIN_Fid },
                    success: function (response) {
                        debugger;
                        $('#BUCode').val(response.BuCode.BUCode);
                        $('#txtACCCONTACT_Fid1').append('<option value="">' + '--Select--' + '</option>');
                        $.each(response.EmployeeList, function (index, emp) {
                            $('#txtACCCONTACT_Fid1').append($('<option/>', {
                                value: emp.Fid,
                                text: emp.ContactPerson,
                            }));
                        });

                        $("#tableCriteria4").find('tr:not(:first)').remove();
                        var Obj = response.ACCCommList;
                        var table = document.getElementById("tableCriteria4");

                        $.each(Obj, function (Key, item) {
                            var rowCount = table.rows.length;
                            var row = table.insertRow(rowCount);
                            var count = $('#tableCriteria4 tr').length;
                            console.log(count);
                            var valueObj = {};
                            $.each(item, function (index, element) {
                                valueObj[element.Key] = element.Value;
                            });
                            row.insertCell(0).innerHTML = `<center><a href="#" title="edit"><i class="fa fa-pen-to-square btnselect"></i></a></center>`;
                            row.insertCell(1).innerHTML = (valueObj.ContactPerson || '');
                            row.insertCell(2).innerHTML = (valueObj.CommunicationType || '');
                            debugger
                            var d3 = convertDate(valueObj.CommunicationDate);
                            let dt2 = new Date(d3);
                            var dd = String(dt2.getDate()).padStart(2, '0');
                            var mm = String(dt2.getMonth() + 1).padStart(2, '0');
                            var yyyy = dt2.getFullYear();
                            dt2 = yyyy + '-' + mm + '-' + dd;
                            row.insertCell(3).innerHTML = dt2 || '';
                            row.insertCell(4).innerHTML = (valueObj.Description || '');
                            row.insertCell(5).innerHTML = (valueObj.FollowUpStatus || '');

                            if (valueObj.NextFollowUpDate == null) {
                                row.insertCell(6).innerHTML = '';
                            } else {
                                var d4 = convertDate(valueObj.NextFollowUpDate);
                                let dt3 = new Date(d4);
                                var dd = String(dt3.getDate()).padStart(2, '0');
                                var mm = String(dt3.getMonth() + 1).padStart(2, '0');
                                var yyyy = dt3.getFullYear();
                                dt3 = yyyy + '-' + mm + '-' + dd;
                                row.insertCell(6).innerHTML = dt3 || '';
                            }
                            row.insertCell(7).innerHTML = (valueObj.Encrypted_Id || '');
                            row.insertCell(8).innerHTML = (valueObj.ConFid || '');
                            row.insertCell(9).innerHTML = (valueObj.FollowUpRemark || '');

                            row.cells[7].classList.add("hidden-column");
                            row.cells[8].classList.add("hidden-column");
                            row.cells[4].classList.add("hidden-column");
                            row.cells[5].classList.add("hidden-column");
                        });

                        var today = new Date().toISOString().split('T')[0];;

                        $("#txtACCCONTACT_Fid1").val(null);
                        $("#txtCommunicationType").val(null).trigger('change');
                        $("#txtCommunicationDateCreate").val(today);
                        $("#txtCommunicationDateEdit").val("");
                        $("#txtFollowUpStatus").val(null).trigger('change');
                        $("#txtMAS_COUNTRY_Fid").val(null);
                       // $('#txtDescription1').summernote('code', '');
                        $("#txtDescription1").val(null);
                        $("#txtNextFollowUpDate").val(null);
                        $("#txtFollowUpRemark").val(null);
                        $("#CommunicationDateCreate").show();
                        $("#CommunicationDateEdit").hide();
                        $("#ACCCommunication_EncryptedId").val(null);
                        $('#txtNextFollowUpDate').removeAttr('min');
                        Count();
                    },
                    error: function (xhr, status, error) {
                        debugger

                        if (xhr.status == 500) {
                            Swal.fire({
                                icon: "error",
                                text: xhr.statusText,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false;
                                }
                            });
                        }
                        else {
                            window.location.href = '/Home/Logout';
                        }
                    }
                })
            }
        });

            //$('#txtDescription1').summernote({
            //    height: 300,               
            //    minHeight: null,           
            //    maxHeight: null,             
            //    focus: true,
            //    callbacks: {
            //        onInit: function () {
            //            $('.note-editable').attr('contenteditable', true); 
            //        }
            //    }
            //})
    })
</script>

<script>
    $("#SaveLeadCommunication").validate({
        rules: {
            ACCMAIN_Fid: {
                required: true
            },
            CommunicationType: {
                required: true
            },
            CommunicationDate: {
                required: true
            },
            ACCCONTACT_Fid: {
                required: true
            },
            FollowUpStatus: {
                required: true
            },
            Description: {
                required: true
            }
          
        },
        messages: {
            ACCMAIN_Fid: {
                required: "Company Name is required"
            },
            CommunicationType: {
                required: "Communication Type is required"
            },
            CommunicationDate: {
                required: "Communication Date is required"
            },
            ACCCONTACT_Fid: {
                required: "Contact Person is required"
            },
            FollowUpStatus: {
                required: "FollowUp Status is required"
            },
            Description: {
                required: "Description is required"
            }
         
        }
    });
    var formCommunication=$("#SaveLeadCommunication");

    $("#CommunicationSubmit").click(function () {
        debugger
        if (formCommunication.valid()) {
            debugger

            var Encrypted_Id = $("#ACCCommunication_EncryptedId").val();
            var ACCMAIN_Fid = $("#txtACCMAIN_Fid").val();
            var CommunicationType = $("#txtCommunicationType").val();

            var con = $("#txtCommunicationDateEdit").val();
            if (con == "") {
                var CommunicationDate = $("#txtCommunicationDateCreate").val();
            } else {
                var CommunicationDate = $("#txtCommunicationDateEdit").val();
            }

            var FollowUpStatus = $("#txtFollowUpStatus").val();
            var Description = $("#txtDescription1").val();
           // var Description = $('#txtDescription1').summernote('code'); 
            var NextFollowUpDate = $("#txtNextFollowUpDate").val();
            var FollowUpRemark = $("#txtFollowUpRemark").val();
            var ACCCONTACT_Fid = $("#txtACCCONTACT_Fid1").val();

            $.ajax({
                //url: "SaveLeadCommunication",
                url: '@Url.Action("SaveLeadCommunication", "CRM", new { area = "CRMS" })',
                method: "post",
                data: {
                    ACCCOMM: {
                        Encrypted_Id: $("#ACCCommunication_EncryptedId").val(),
                        ACCMAIN_Fid: $("#txtACCMAIN_Fid").val(),
                        CommunicationType: $("#txtCommunicationType").val(),
                        CommunicationDate: $("#txtCommunicationDateEdit").val() || $("#txtCommunicationDateCreate").val(),
                        FollowUpStatus: $("#txtFollowUpStatus").val(),

                      //  Description: $('#txtDescription1').summernote('code'),
                        NextFollowUpDate: $("#txtNextFollowUpDate").val(),
                        FollowUpRemark: $("#txtFollowUpRemark").val(),
                        ACCCONTACT_Fid: $("#txtACCCONTACT_Fid1").val(),
                        BUCode: $("#BUCode").val()
                    },
                    Acc_EncryptedId: $("#ACCCommunication_EncryptedId").val()
                },

              //data: { Encrypted_Id: Encrypted_Id, ACCMAIN_Fid: ACCMAIN_Fid, CommunicationType: CommunicationType, CommunicationDate: CommunicationDate, FollowUpStatus: FollowUpStatus, Description: Description, NextFollowUpDate: NextFollowUpDate, FollowUpRemark: FollowUpRemark, ACCCONTACT_Fid: ACCCONTACT_Fid },
                success: function (response) {
                    debugger
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (Icon1 == "success" || Icon1 == "error") {
                        if (Message1 != null && Icon1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup();
                                    popup.classList.remove('swal2-show');
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake');
                                    });
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake');
                                    }, 500);
                                }
                            }).then(() => {
                                window.location.href = '@Url.Action("Lead_Dashboard", "CRM")';
                            });
                        }
                    }
                }
            });
        }

        else
        {
            return false;
        }

    });


    function convertDate(dateString) {
        const parsedDate = new Date(dateString);
        if (!isNaN(parsedDate)) {
            return {
                isoDate: parsedDate.toISOString().split('T')[0] 
            };
        } else {
            return null;
        }
    }

</script>

<script>
    $(".summernote").summernote({
        placeholder: '',
        height: "300"
    });
</script>
