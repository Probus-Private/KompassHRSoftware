
@{
    ViewBag.Title = "ProposalReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div id="content" class="app-content">
    <div class="row">
        <ol style="list-style: none; padding: 0; margin: 0; ">
            <li style="float:right; margin-right: 15px;">
                <a href="@Url.Action("ViewListList", "CRM",  new {modules="Opportunity",area = "CRMS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
    </div> 
    <div class="panel panel-inverse" id="MAS_ReportNameList">
        <!-- BEGIN panel-heading -->
        <div class="panel-heading">
            <h4 class="panel-title">
                Proposal Details
            </h4>
            <div class="panel-heading-btn">
                <a href="@Url.Action("ProposalReport", "CRM", new { area = "CRMS" })" class="btn btn-xs btn-icon btn-default">
                    <i class="fa fa-home fa-lg"></i>
                </a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
            </div>
        </div>

        <!-- END panel-heading -->
        <!-- BEGIN panel-body -->
        <div class="panel-body" id="LEAType">

            <div class="row">
                <div class="col-12 overflow-auto">

                    <table id="data-table-combine15" class="table table-striped table-bordered align-middle">
                        <thead>
                            <tr>

                                <th class="text-nowrap ">CompanyName</th>
                                <th class="text-nowrap">Proposal No.</th>
                                <th class="text-nowrap ">Revision No.</th>
                                <th class="text-nowrap ">ProposalSubmissionDate</th>
                                <th class="text-nowrap ">ExpectedClosingDate</th>
                                <th class="text-nowrap ">RevisedProposalDate</th>
                                <th class="text-nowrap ">TypeOfContract</th>
                                <th class="text-nowrap ">ManpowerCount</th>
                                <th class="text-nowrap ">Currency</th>
                                <th class="text-nowrap ">ContractTenure</th>
                                <th class="text-nowrap ">TotalContractValue</th>
                                <th class="text-nowrap ">MonthlyContractValue</th>
                                <th class="text-nowrap ">AnnualContractValue</th>
                                <th class="text-nowrap ">TaxApplicable</th>
                                <th class="text-nowrap ">TaxPercentage</th>
                                <th class="text-nowrap ">ACVInclusiveOfTax</th>
                                <th class="text-nowrap ">ManagementFeePer</th>
                                <th class="text-nowrap ">ManagementFeeValue</th>

                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in ViewBag.ProposalDetails)
                            {
                                <tr>
                                    <td>@(item.CompanyName ?? "NA")</td>
                                    <td>@(item.ProposalNo ?? "NA")</td>
                                    <td>@(item.RevisionNo ?? "NA")</td>
                                    <td>@(item.ProposalSubmissionDate != null ? item.ProposalSubmissionDate.ToString("dd-MM-yyyy") : "NA")</td>
                                    <td>@(item.ExpectedClosingDate != null ? item.ExpectedClosingDate.ToString("dd-MM-yyyy") : "NA")</td>
                                    <td>@(item.RevisedProposalDate != null ? item.RevisedProposalDate.ToString("dd-MM-yyyy") : "NA")</td>
                                    <td>@(item.TypeOfContract ?? "NA")</td>
                                    <td>@(item.ManpowerCount ?? "NA")</td>
                                    <td>@(item.Currency ?? "NA")</td>
                                    <td>@(item.ContractTenure ?? "NA")</td>
                                    <td>@(item.TotalContractValue ?? "NA")</td>
                                    <td>@(item.MonthlyContractValue ?? "NA")</td>
                                    <td>@(item.AnnualContractValue ?? "NA")</td>
                                    <td>@(item.TaxApplicable == true ? "Yes" : item.TaxApplicable == false ? "No" : "NA")</td>
                                    <td>@(item.TaxPercentage ?? "NA")</td>
                                    <td>@(item.ACVInclusiveOfTax ?? "NA")</td>
                                    <td>@(item.ManagementFeePer ?? "NA")</td>
                                    <td>@(item.ManagementFeeValue ?? "NA")</td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>



