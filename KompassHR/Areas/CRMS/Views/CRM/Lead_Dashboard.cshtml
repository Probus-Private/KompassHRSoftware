

@*@using OceanFM.Models.helper;*@

@{
    ViewBag.Title = "Lead_Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@if (Convert.ToBoolean(Session["IsMobile"]) != false)
{
    <style>
        .MobileHidden {
            display: none !important;
        }

        .app-header-fixed {
            padding-top: 20px !important;
        }

        .mailbox-sidebar-header.d-flex.justify-content-center {
            justify-content: end !important;
        }
    </style>
}

<style>
    .mailbox-content-body1 {
        /*margin-bottom:10px;*/
        height: 500px; /* Adjust the height as needed */
        /*overflow-y: auto;*/ /* Enables vertical scrolling */
    }
</style>

<style>
    .searchbtn {
        display: flex;
        position: relative;
    }

        .searchbtn input {
            width: 170px;
        }

        .searchbtn button {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            border: none;
            background: 0 0;
            border-radius: 0 30px 30px 0;
            display: flex;
            align-items: center;
        }

    #ESSDashboard .menu-submenu {
        box-sizing: border-box;
        display: block;
    }

        #ESSDashboard .menu-submenu .Lead {
            font-size: 14px;
            color: #fff !important;
        }

    .page-num.active {
        background-color: #007bff;
        color: white;
    }

    .page-num {
        margin: 0 2px;
        cursor: pointer;
    }

    .btn-group button {
        margin: 0 2px;
    }

        .btn-group button :hover {
            cursor: pointer;
        }
</style>


<div id="content" class="app-content p-0">

    <div class="row">
        <ol style="list-style: none; padding: 0; margin: 0; ">
            <li style="float:right; margin-right: 15px;">
                <a href="@Url.Action("CRM_SalesForce_Menu", "CRM_SalesForce_Menu", new { id = 45,ScreenId=801, area = "CRMS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
    </div>
    <br />

    <!-- BEGIN mailbox -->
    <div class="mailbox">
        <!-- BEGIN mailbox-sidebar -->
        <div class="mailbox-sidebar">
            <div class="mailbox-sidebar-header d-flex justify-content-center">
                <a href="#emailNav" data-bs-toggle="collapse" class="btn btn-dark btn-sm me-auto d-block d-lg-none MobileHidden">
                    <i class="fa fa-cog"></i>
                </a>
                <a href="@Url.Action("CRM_LeadForm", "CRM", new { area = "CRMS" })" class="btn btn-dark ps-40px pe-40px btn-sm">
                    Add New Lead
                </a>
            </div>
            <div class="mailbox-sidebar-content collapse d-lg-block" id="emailNav">
                <!-- BEGIN scrollbar -->
                <div data-scrollbar="true" data-height="100%" data-skip-mobile="true">
                    <div class="nav-title"><b>Quick Menu</b></div>
                    <ul class="nav nav-inbox">
                        <li><a href="@Url.Action("AddLeadContact", "CRM", new { area = "CRMS" })"><i class="fa fa-square-phone fa-lg fa-fw me-2"></i> Contact</a></li>
                        <li><a href="@Url.Action("AddLeadLocation", "CRM", new { area = "CRMS" })"><i class="fa fa-location-dot fa-lg fa-fw me-2"></i>Location</a></li>
                        <li><a href="@Url.Action("AddLeadCommunication", "CRM", new { area = "CRMS" })"><i class="fa fa-comments fa-lg fa-fw me-2"></i>Communication</a></li>
                        <li><a href="@Url.Action("AddLeadActivity", "CRM", new { area = "CRMS" })"><i class="fa fa-list-check fa-lg fa-fw me-2"></i>Activities</a></li>

                    </ul>
              
                </div>
                <!-- END scrollbar -->
            </div>
        </div>
        <!-- END mailbox-sidebar -->
        <!-- BEGIN mailbox-content -->
        <div class="mailbox-content">
            <div class="mailbox-content-header">
                <!-- BEGIN btn-toolbar -->
                <div class="btn-toolbar align-items-center">
                 
                    <div class="dropdown me-2">
                        <button id="sortBtn" class="btn btn-white btn-sm" data-bs-toggle="dropdown">
                            View All <span class="caret ms-3px"></span>
                        </button>
                        <div class="dropdown-menu">
                            <a href="javascript:;" class="dropdown-item" onclick="Stage('All')"><i class="fa fa-circle fs-9px fa-fw me-2"></i> All</a>
                            <a href="javascript:;" class="dropdown-item" onclick="Stage('Identification')"><i class="fa fa-circle fs-9px fa-fw me-2 text-blue"></i> Identification</a>
                            <a href="javascript:;" class="dropdown-item" onclick="Stage('Qualification')"><i class="fa fa-circle fs-9px fa-fw me-2 text-warning"></i> Qualification</a>
                        </div>
                    </div>
                    <div class="button me-2">
                        <button class="btn btn-white btn-sm" onclick="location.href='@Url.Action("LeadTransfer", "CRM", new { area = "CRMS" })'">
                            Lead Transfer
                        </button>
                    </div>
                    <div class="button me-2">
                        <button class="btn btn-white btn-sm" onclick="location.href='@Url.Action("ViewListList", "CRM", new {modules="Lead", area = "CRMS" })'">
                            Reports
                        </button>
                    </div>

                    <div class="form-group searchbtn">
                        <input type="text" id="searchInput" class="form-control" placeholder="Enter keyword">
                        <button type="button" id="searchButton" class="btn btn-search"><i class="fa fa-search"></i></button>
                    </div>
                    <div class="w-100 d-sm-none d-block mb-2 hide" data-email-action="divider"></div>
                    <!-- BEGIN btn-group -->
                   
                    <!-- END btn-group -->
                </div>
                <!-- END btn-toolbar -->
            </div>
            <div class="mailbox-content-body">
                <div @*id="lead-list-container" data-height="100%" data-skip-mobile="true"*@ class="mailbox-content-body1" data-scrollbar="true">

                    <ul id="mailbox-list" class="list-group list-group-lg no-radius list-email"></ul>
                 
                    <!-- END list-email -->
                </div>
            </div>
            <div id="pagination" class="mailbox-content-footer d-flex align-items-center">

            </div>
        </div>
        <!-- END mailbox-content -->
    </div>
    <!-- END mailbox -->
</div>


<script>
    $(document).ready(function () {
        $("#ESSDashboard").addClass("expand");;
    });

</script>

<script>
    $(document).ready(function () {
        debugger
        var allData = @Html.Raw(Json.Encode(ViewBag.List)); // Get all the data passed from the controller
        var currentPage = 1;
        var pageSize = 10;
        var totalPages = Math.ceil(allData.length / pageSize);

        window.Stage = function(e) {

            if (e == "Qualification") {
                $('#sortBtn').text(e + ' ').append('<span class="caret ms-3px"></span>');
             
            }
            if (e == "Identification") {
                $('#sortBtn').text(e + ' ').append('<span class="caret ms-3px"></span>');
            
            }
            else if (e == "All") {
                $('#sortBtn').text('View All' + ' ').append('<span class="caret ms-3px"></span>');
            }
            renderList(allData,1);
        }

        function renderList(data, page) {


            debugger
            var filteredData = data.filter(function (item) {

                var searchTerm = $('#searchInput').val().toLowerCase();
                return item.LeadName.toLowerCase().includes(searchTerm) ||
                       item.CompanyName.toLowerCase().includes(searchTerm) ||
                       item.Summary.toLowerCase().includes(searchTerm);
            });
    debugger
    if ($('#sortBtn').text().includes("Qualification")) {
        filteredData = filteredData.filter(item => item.Stage === "Qualification");
    } else if ($('#sortBtn').text().includes("Identification")) {
        filteredData = filteredData.filter(item => item.Stage === "Identification");
    } else {
        filteredData = filteredData; 
    }

            var paginatedData = filteredData.slice((page - 1) * pageSize, page * pageSize);
            var listHtml = '';
            paginatedData.forEach(function (item) {

                listHtml += `

                        <li class="list-group-item unread ${item.Stage}" data-leadname="${item.LeadName}" data-companyname="${item.CompanyName}">
                            <div class="email-checkbox">
                                <div class="form-check">
                                    <label class="form-check-label" for="emailCheckbox1"></label>
                                </div>
                            </div>
                            <a href="/CRMS/CRM/Lead_Details?EncryptedId=${item.Encrypted_Id}" class="email-user bg-blue">
                                <span class="text-white">L</span>
                            </a>
                            <div class="email-info">
                                <a href="/CRMS/CRM/Lead_Details?EncryptedId=${item.Encrypted_Id}">
                                    <span class="email-sender">${item.LeadName}</span>
                                    <span class="email-title">${item.CompanyName}</span>

                                    <span class="email-time" style="justify-content:flex-start; margin-left: 10px;">
                                        ${Array(item.CompanyRating).fill('<i class="fas fa-star text-warning"></i>').join('')}
                                    </span>

                                </a>
                            </div>
                        </li>

                `;
            });
          
            $('#mailbox-list').html(listHtml); 
            renderPagination(filteredData.length, page);
        }

        function renderPagination(totalItems, currentPage) {
            debugger

            var paginationHtml = `
        <div class="text-dark fw-bold">${totalItems} results</div>
        <div class="btn-group ms-auto">
    `;

            // "First" and "Prev" buttons
            if (currentPage > 1) {
                paginationHtml += `<button class="btn btn-white btn-sm" id="firstPage">First</button>`;
                paginationHtml += `<button class="btn btn-white btn-sm" id="prevPage">Prev</button>`;
            }

            // Page number range (show 5 before and 5 after the current page)
            var startPage = Math.max(1, currentPage - 2);
            var endPage = Math.min(Math.ceil(totalItems / pageSize), currentPage + 2);
            endPage = totalItems <= pageSize ? startPage : endPage;
            totalPages = endPage === 1 ? 1 : Math.ceil(allData.length / pageSize);
            // Display page numbers
            for (var i = startPage; i <= endPage; i++) {
                paginationHtml += `
            <button class="btn btn-white btn-sm page-num ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>
        `;
            }

            // "Next" and "Last" buttons
            if (currentPage < totalPages) {
                paginationHtml += `<button class="btn btn-white btn-sm" id="nextPage">Next</button>`;
                paginationHtml += `<button class="btn btn-white btn-sm" id="lastPage">Last</button>`;
            }

            paginationHtml += `</div>`;
            $('#pagination').html(paginationHtml); // Insert pagination controls into the page
        }

        $('#searchInput').on('keyup', function () {
            renderList(allData, 1); // Re-render the list whenever the search term changes
        });

        // Event listener for the search button
        $('#searchButton').on('click', function () {
            renderList(allData, 1); // Trigger the search and render list
        });
        // Event listener for "First" page
        $(document).on('click', '#firstPage', function () {
            currentPage = 1; // Set the page to the first page
            renderList(allData, currentPage); // Re-render the list
        });

        // Event listener for "Prev" button
        $(document).on('click', '#prevPage', function () {
            if (currentPage > 1) {
                currentPage--;
                renderList(allData, currentPage); // Re-render the list when the previous page is clicked
            }
        });

        // Event listener for pagination page numbers
        $(document).on('click', '.page-num', function () {
            var page = $(this).data('page');
            currentPage = page; // Set the current page to the clicked page
            renderList(allData, currentPage); // Re-render the list when a page number is clicked
        });

        // Event listener for "Next" button
        $(document).on('click', '#nextPage', function () {
            var totalPages = Math.ceil(allData.filter(item =>
                item.LeadName.toLowerCase().includes($('#searchInput').val().toLowerCase()) ||
                item.CompanyName.toLowerCase().includes($('#searchInput').val().toLowerCase()) ||
                item.Summary.toLowerCase().includes($('#searchInput').val().toLowerCase())
            ).length / pageSize);

            if (currentPage < totalPages) {
                currentPage++;
                renderList(allData, currentPage); // Re-render the list when the next page is clicked
            }
        });

        // Event listener for "Last" page
        $(document).on('click', '#lastPage', function () {
            currentPage = totalPages; // Set the page to the last page
            renderList(allData, currentPage); // Re-render the list
        });


        renderList(allData, currentPage);
    });
</script>

<script>

    $(document).ready(function () {
        debugger
          
        });
</script>