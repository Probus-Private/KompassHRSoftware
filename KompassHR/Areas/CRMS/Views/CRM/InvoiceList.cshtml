
@{
    ViewBag.Title = "InvoiceList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
   
    </ol>

    <div class="d-flex flex-wrap">
        <button type="button" class="btn btn-primary me-1 mb-1" onclick="location.href='@Url.Action("AddNewInvoice","CRM")'"><i class="fa fa-plus fa-sm" title="Add New" style="font-size:x-small"></i> Add New</button>
    </div>

    <div class="panel panel-inverse" id="ShiftGroupId">
        <!-- BEGIN panel-heading -->
        <div class="panel-heading">
            <h4 class="panel-title">
                Invoice
            </h4>
            <div class="panel-heading-btn">
                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
            </div>
        </div>
        <!-- END panel-heading -->
        <!-- BEGIN panel-body -->
        <div class="panel-body" id="LEAType">
            <div class="row">
                <div class="col-12 overflow-auto">

                    <table id="data-table-combine15" class="table table-striped table-bordered align-middle">
                        <thead>
                            <tr>
                                <th class="width-45">  </th>
                                <th class="text-nowrap">Site Name</th>
                                <th class="text-nowrap">Month</th>
                                <th class="text-nowrap">Invoice Number</th>
                                <th class="text-nowrap">Invoice Total Amount</th>
                                <th class="text-nowrap">Invoice Paid Amount</th>
                                <th class="text-nowrap">Invoice Balance Amount</th>
                                <th class="text-nowrap">Invoice Copy</th>
                                <th class="text-nowrap">Supporting Document</th>
                                @*<th class="text-nowrap">Last Working Date</th>
                                    <th class="text-nowrap">Status</th>*@
                            </tr>
                        </thead>
                        @foreach (var item in ViewBag.InvoiceList)
                        {
                            <tr>
                                <td class="width-45">
                                    <span class="d-flex justify-content-evenly">
                                        <a href="#" onclick="location.href='@Url.Action("AddNewInvoice", "CRM",new {id = @item.Encrypted_Id ,area="CRM"})'" title="View"
                                           class="@(item.IsAcknowledged ? "disabled" : "")">
                                            <i class="fa fa-pencil fa-lg"></i>
                                        </a>
                                    </span>
                                </td>
                                <td>@item.SiteName</td>
                                <td>@item.BillMonth.ToString("MMM-yyyy")</td>
                                <td>@item.InvoiceNumber</td>
                                <td>@(Convert.ToDouble(item.InvoiceBasicAmount) + Convert.ToDouble(item.InvoiceTaxAmount))</td>
                                <td>@item.InvoicePaidAmount</td>
                                <td>@((Convert.ToDouble(item.InvoiceBasicAmount) + Convert.ToDouble(item.InvoiceTaxAmount)) - Convert.ToDouble(item.InvoicePaidAmount))</td>
                                <td>
                                    @if (item.InvoiceCopy != null)
                                    {
                                        <a href="#" onclick="window.open('@Url.Action("GetViewFile", "CRM",new { FilePath = @item.InvoiceCopy,area="CRMS"})', '_blank')" title="View"> <i class="fa fa-eye"></i></a>
                                    }
                                    else
                                    {

                                    }
                                </td>
                                <td>
                                    @if (item.SupportingDocument != null)
                                    {
                                        <a href="#" onclick="window.open('@Url.Action("GetViewFile", "CRM",new { FilePath = @item.SupportingDocument,area="CRMS"})', '_blank')" title="View"> <i class="fa fa-eye"></i></a>
                                    }
                                    else
                                    {

                                    }
                                </td>
                                @*<td>@item.LastWorkingDate</td>
                                    <td>@item.Status</td>*@
                            </tr>
                        }
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>
<script>

    $(document).ready(function () {
        debugger

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                    }
                });
            }
        }
    });

</script>

