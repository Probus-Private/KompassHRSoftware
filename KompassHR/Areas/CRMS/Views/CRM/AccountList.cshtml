</div>



<script>
    $(document).ready(function () {
        debugger
        var allData = @Html.Raw(Json.Encode(ViewBag.List)); // Get all the data passed from the controller
        var currentPage = 1;
        var pageSize = 10;
        var totalPages = Math.ceil(allData.length / pageSize);

        function renderList(data, page) {


            debugger
            var filteredData = data.filter(function (item) {

                var searchTerm = $('#searchInput').val().toLowerCase();
                return item.LeadName.toLowerCase().includes(searchTerm) ||
                       item.CompanyName.toLowerCase().includes(searchTerm) ||
                       item.Summary.toLowerCase().includes(searchTerm);
            });
            debugger


            var paginatedData = filteredData.slice((page - 1) * pageSize, page * pageSize);

            var listHtml = '';
            paginatedData.forEach(function (item) {

                listHtml += `
                    <ul class="list-group list-group-lg no-radius list-email">
                        <li class="list-group-item unread ${item.Stage}" data-leadname="${item.LeadName}" data-companyname="${item.CompanyName}">
                            <div class="email-checkbox">
                                <div class="form-check">
                                    <label class="form-check-label" for="emailCheckbox1"></label>
                                </div>
                            </div>
                            <a href="/CRMS/CRM/AccountDetails?EncryptedId=${item.Encrypted_Id}" class="email-user bg-blue">
                                <span class="text-white">L</span>
                            </a>
                            <div class="email-info">
                                <a href="/CRMS/CRM/AccountDetails?EncryptedId=${item.Encrypted_Id}">
                                    <span class="email-sender">${item.LeadName}</span>
                                    <span class="email-title">${item.CompanyName}</span>

                                    <span class="email-time" style="justify-content:flex-start; margin-left: 10px;">
                                        ${Array(item.CompanyRating).fill('<i class="fas fa-star text-warning"></i>').join('')}
                                    </span>
                                </a>
                            </div>
                        </li>
                    </ul>
                `;
            });
            $('#mailbox-list').html(listHtml); // Insert the list into the page
            renderPagination(filteredData.length, page);
        }

        // Function to render the pagination controls


        function renderPagination(totalItems, currentPage) {
            debugger

            var paginationHtml = `
        <div class="text-dark fw-bold">${totalItems} results</div>
        <div class="btn-group ms-auto">
    `;

            // "First" and "Prev" buttons
            if (currentPage > 1) {
                paginationHtml += `<button class="btn btn-white btn-sm" id="firstPage">First</button>`;
                paginationHtml += `<button class="btn btn-white btn-sm" id="prevPage">Prev</button>`;
            }

            var startPage = Math.max(1, currentPage - 2);
            var endPage = Math.min(Math.ceil(totalItems / pageSize), currentPage + 2);
            endPage = totalItems <= pageSize ? startPage : endPage;
            totalPages = endPage === 1 ? 1 : Math.ceil(allData.length / pageSize);
            // Display page numbers
            for (var i = startPage; i <= endPage; i++) {
                paginationHtml += `
            <button class="btn btn-white btn-sm page-num ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>
        `;
            }

            // "Next" and "Last" buttons
            if (currentPage < totalPages) {
                paginationHtml += `<button class="btn btn-white btn-sm" id="nextPage">Next</button>`;
                paginationHtml += `<button class="btn btn-white btn-sm" id="lastPage">Last</button>`;
            }

            paginationHtml += `</div>`;
            $('#pagination').html(paginationHtml); // Insert pagination controls into the page
        }

        $('#searchInput').on('keyup', function () {
            renderList(allData, 1); // Re-render the list whenever the search term changes
        });

        $('#searchButton').on('click', function () {
            renderList(allData, 1); // Trigger the search and render list
        });

        $(document).on('click', '#firstPage', function () {
            currentPage = 1; // Set the page to the first page
            renderList(allData, currentPage); // Re-render the list
        });

        // Event listener for "Prev" button
        $(document).on('click', '#prevPage', function () {
            if (currentPage > 1) {
                currentPage--;
                renderList(allData, currentPage); // Re-render the list when the previous page is clicked
            }
        });

        // Event listener for pagination page numbers
        $(document).on('click', '.page-num', function () {
            var page = $(this).data('page');
            currentPage = page; // Set the current page to the clicked page
            renderList(allData, currentPage); // Re-render the list when a page number is clicked
        });

        // Event listener for "Next" button
        $(document).on('click', '#nextPage', function () {
            var totalPages = Math.ceil(allData.filter(item =>
                item.LeadName.toLowerCase().includes($('#searchInput').val().toLowerCase()) ||
                item.CompanyName.toLowerCase().includes($('#searchInput').val().toLowerCase()) ||
                item.Summary.toLowerCase().includes($('#searchInput').val().toLowerCase())
            ).length / pageSize);

            if (currentPage < totalPages) {
                currentPage++;
                renderList(allData, currentPage); // Re-render the list when the next page is clicked
            }
        });

        // Event listener for "Last" page
        $(document).on('click', '#lastPage', function () {
            currentPage = totalPages; // Set the page to the last page
            renderList(allData, currentPage); // Re-render the list
        });


        renderList(allData, currentPage);
    });
</script>


