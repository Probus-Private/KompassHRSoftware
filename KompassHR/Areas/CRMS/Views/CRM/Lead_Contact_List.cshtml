
@{
    ViewBag.Title = "Lead_Contact_List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="content" class="app-content">

    <!-- BEGIN page-header -->
    @*<div class="d-flex flex-wrap">
        <button type="button" class="btn btn-danger me-1 mb-1" onclick="window.location.href='@Url.Action("ViewListList", "CRM",new {modules="Lead", area ="CRMS"})'">
            <i class="fa fa-arrow-left fa-sm" title="Back" style="font-size: x-small;"></i> Back
        </button>
    </div>*@  <!-- END page-header -->
    <div class="row">
        <ol style="list-style: none; padding: 0; margin: 0; ">
            <li style="float:right; margin-right: 15px;">
                <a href="@Url.Action("ViewListList", "CRM",  new {modules="Lead",area = "CRMS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
    </div>

    <div class="panel panel-inverse" id="MAS_ReportNameList">
        <!-- BEGIN panel-heading -->
        <div class="panel-heading">
            <h4 class="panel-title">
                Lead Contact
            </h4>
            <div class="panel-heading-btn">
                <a href="@Url.Action("Lead_Dashboard", "CRM", new { area = "CRMS" })" class="btn btn-xs btn-icon btn-default">
                    <i class="fa fa-home fa-lg"></i>
                </a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
            </div>
        </div>

        <!-- END panel-heading -->
        <!-- BEGIN panel-body -->
        <div class="panel-body" id="LEAType">

            <form action="/CRMS/CRM/Lead_Contact_List" id="Search" method="get" data-parsley-validate="true">
                <div class="form-group row">
                    <div class="col-md-3 mb-3">
                        <label class="mb-2"> Lead Name @*<span class="text-danger">*</span>*@</label>
                        @Html.DropDownList("Contact", new SelectList(ViewBag.LeadContactList, "LeadName", "LeadName"), "--Select--", new { @class = "form-control form-select", id = "LeadContactList" })
                    </div>
        
                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-sm btn-primary me-1 mb-1" name="action" value="search">
                            <i class="fa fa-search" title="Search" style="font-size: x-small;"></i> Search
                        </button>
                        <button type="button" class="btn btn-sm btn-danger me-1 mb-1" onclick="location.href='@Url.Action("Lead_Contact_List", "CRM",new {area="CRM"})'">
                            <i class="fa fa-reply" title="Reset" style="font-size: x-small;"></i> Reset
                        </button>
                    </div>
                </div>
            </form>

            <div class="row">
                <div class="col-12 overflow-auto">

                    <table id="data-table-combine15" class="table table-striped table-bordered align-middle">
                        <thead>
                            <tr>

                                <th class="text-nowrap ">Lead Name</th>
                                <th class="text-nowrap">Email</th>
                                <th class="text-nowrap ">Contact No</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in ViewBag.Lead_Contact_ListList)
                            {
                                <tr>
                                    <td>@item.LeadName</td>
                                    <td>@item.EmailId</td>
                                    <td>@item.MobileNo</td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

