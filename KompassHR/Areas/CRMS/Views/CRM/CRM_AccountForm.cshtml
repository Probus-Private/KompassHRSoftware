<script>

    $("#txtCompanyName").on("change", function () {
        debugger
        $("#txtBUCode").empty();

        var CmpId = $("#txtCompanyName").val();

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetBusinessUnit", "CRM")',
            data: { CmpId: CmpId },
            success: function (data) {

                if (data && data.Branch) {
                    $("#txtBUCode").append("<option value=''>Select</option>");
                    $.each(data.Branch, function (i, p) {
                        $("#txtBUCode").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    });
                }

            }
        });
    });

    function Details() {
        debugger;
        var CompanyName = $("#txtCompanyName").val();
        $.ajax({
            url: "CompanyDetails",
            method: "get",
            data: { DetailsId: CompanyName },
            success: function(response) {
                debugger;
                try {
                    if (typeof response === "string") {
                        response = JSON.parse(response);
                    }

                    const fieldMap = {
                        'LeadName': '#ModalLeadName',
                        'CompanyName': '#ModalCompanyName',
                        'EmployeeName': '#ModalSalesPerson'
                    };

                    $('#companyModal').modal('show');

                    response.forEach(function(item) {
                        if (fieldMap[item.Key]) {
                            $(fieldMap[item.Key]).text(item.Value);
                        }
                    });
                } catch (e) {
                    console.error('Parsing error:', e);
                    alert('There was an error retrieving the company details. Please try again later.');
                }
            },
            error: function(xhr, status, error) {
                console.error('AJAX request failed:', status, error);
