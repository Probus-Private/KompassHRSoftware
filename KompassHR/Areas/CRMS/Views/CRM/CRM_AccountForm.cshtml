        text-align: left;
        height: 35px;
    }

    input[type="radio"] {
        display: none;
    }

    .star {
        font-size: 2em;
        color: gray;
        cursor: pointer;
    }

    input[type="radio"]:checked + .star {
        color: gold;
    }

        input[type="radio"]:checked + .star ~ .star {
            color: gray;
        }

    .btn-attractive {
        background-color: #673ab7;
        color: white;
        padding: 10px 20px;
        font-size: 16px;
        border-radius: 5px;
        transition: background-color 0.3s, transform 0.3s;
    }

        .btn-attractive:hover {
            background-color: #441a91;
            transform: scale(1.05);
            color: white;
        }

        .btn-attractive:focus, .btn-attractive:active {
            outline: none;
            box-shadow: 0 0 10px rgba(0, 123, 255, 0.5);
        }

    .note-editable {
        border: 1px solid lightgray;
    }

