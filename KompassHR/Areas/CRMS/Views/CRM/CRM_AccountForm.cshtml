<script>

    $(document).ready(function () {
        const $stars = $('.star');
        const $radios = $('input[type="radio"]');

        // Function to update star colors based on the selected rating
        function updateStars(rating) {
            $stars.each(function (index) {
                $(this).css('color', index < rating ? 'gold' : 'gray');
            });
        }

        // On click, update radio buttons and star colors
        $stars.each(function (index) {
            $(this).on('click', function () {
                const rating = index + 1;
                $radios.each(function (idx) {
                    this.checked = idx < rating;
                });
                updateStars(rating);
            });

            // On mouse over, temporarily highlight stars
            $(this).on('mouseover', function () {
                const rating = index + 1;
                updateStars(rating);
            });

            // On mouse out, reset to the current checked rating
            $(this).on('mouseout', function () {
                const $checkedRadio = $('input[type="radio"]:checked');
                const rating = $checkedRadio.length ? parseInt($checkedRadio.val()) : 0;
                updateStars(rating);
            });
        });

        // Initialize star colors based on the initially checked radio button
        const $checkedRadio = $('input[type="radio"]:checked');
        const initialRating = $checkedRadio.length ? parseInt($checkedRadio.val()) : 0;
        updateStars(initialRating);
    });


</script>

<script>

    $(document).ready(function () {
        debugger
        var companyList;


        function getCompanyList() {
            return new Promise(function(resolve, reject) {
                $.ajax({
                    url: "GetCompanyList",
                    method: "get",
                    success: function (response) {
                        debugger
                        resolve(response.CompanyNameList); // Resolve with the company list
                    },
                    error: function(xhr, status, error) {
                        debugger
                        reject(error); // Reject on error
                    }
                });
            });
        }

        // Call the function and use .then() to process the result
        getCompanyList().then(function(companyListJson) {
            debugger
            companyList = companyListJson.map(function(item) {
                debugger
                return {
                    label: item[1].Value,
                    value: item[1].Value,
                    detailsUrl: item[0].Value
                };
            });

            //console.log(companyList);  // Now you can access companyList here
        }).catch(function(error) {
            console.error("Error fetching company list:", error);
        });

        $('#TenderApplicable').change(function() {
            debugger;
            var PoliceVerificationStatus = $('#TenderApplicable').val();

            if (PoliceVerificationStatus === "False") {
                $(".pol").hide();

            } else {
                $(".pol").show();
            }
        });

        $('#TenderApplicable').change();

        $("#txtCompanyName").autocomplete({

            source: function(request, response) {
                debugger
                var term = request.term ? request.term.toLowerCase() : ""; // Ensure term is defined
                var filteredList = companyList.filter(function(item) {
                    return item.label && item.label.toLowerCase().includes(term); // Check item.label for null
                });


                if (filteredList.length === 0) {
                    filteredList.push({
                        label: "Add \"" + request.term + "\" to list",
                        value: request.term,
                        isCustom: true
                    });
                }

                response(filteredList);
            },
            select: function(event, ui) {
                $("#txtCompanyName").val(ui.item.value);

                if (!ui.item.isCustom) {
                    $("#Detailsss").show();
                    $("#txtCompanyName").blur();
                    $("#txtCompanyName").data("selected", true);
                } else {
                    event.preventDefault();
                    $("#Detailsss").hide();
                }

                return false;
            }
        }).autocomplete("instance")._renderItem = function(ul, item) {
            debugger
            var $item = $("<li>")
                .append("<div>" + item.label +
                        (item.isCustom ? "" : "" ) +
                        "</div>")
                .appendTo(ul);
            debugger
            if (!item.isCustom) {
                $item.find(".details-link").on("click", function() {
                    var DetailsId = $(this).val();
                    $.ajax({
                        url: "CompanyDetails",
                        method: "get",
                        data: { DetailsId: DetailsId },
                        success: function(response) {
                            const fieldMap = {
                                'LeadName': '#ModalLeadName',
                                'CompanyName': '#ModalCompanyName',
                                'EmployeeName': '#ModalSalesPerson'
                            };
                            $('#companyModal').modal('show');
                            response.forEach(function(item) {
                                if (fieldMap[item.Key]) {
                                    $(fieldMap[item.Key]).text(item.Value);
                                }
                            });
                        },
                        error: function(xhr, status, error) {
                            console.error('AJAX request failed:', status, error);
                        }
                    });
                });
            }

            return $item;
        };

        $("#txtCompanyName").on("focus", function() {
            if ($(this).data("selected")) {
                $(this).val("");
                $(this).data("selected", false);
                $(this).autocomplete("search", "");
                $("#Detailsss").hide();
            }
        });
    });



</script>


