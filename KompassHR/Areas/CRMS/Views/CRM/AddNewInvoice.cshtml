                           })
                            </div>



                            <div class="col-md-4 mb-3">
                                <label class="mb-2"> Invoice Date <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(model => model.InvoiceDate, "{0:yyyy-MM-dd}", new { @class = "form-control", Type = "Date", id = "InvoiceDate", required = "required" })
                                @*@Html.TextBoxFor(model => model.Forthemonthof, "{0:yyyy-MM}", new { @class = "form-control", Type = "month", id = "Forthemonthof", required = "required" @*, value = Model.Forthemonthof.ToString("MMM,yyyy"), @readonly = @isReadOnly})*@
                                @Html.ValidationMessageFor(model => model.InvoiceDate, "", new { @class = "help-block", id = "ErrorInvoiceDate", @style = "color:red" })

                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="mb-2"> Due Date <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(model => model.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", Type = "date", id = "DueDate", required = "required" })
                                @*@Html.TextBoxFor(model => model.Forthemonthof, "{0:yyyy-MM}", new { @class = "form-control", Type = "month", id = "Forthemonthof", required = "required" @*, value = Model.Forthemonthof.ToString("MMM,yyyy"), @readonly = @isReadOnly})*@
                                @Html.ValidationMessageFor(model => model.DueDate, "", new { @class = "help-block", id = "ErrorDueDate", @style = "color:red" })

