                                @Html.ValidationMessageFor(model => model.BillMonth, "", new { @class = "help-block", id = "ErrorBillMonth", @style = "color:red" })
                                @Html.HiddenFor(Model => Model.Encrypted_Id, new { @id = "Encrypted_Id" })

                            </div>
                        </div>

                        <div class="form-group row">
