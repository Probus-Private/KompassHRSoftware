                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="mb-2">Invoice Tax Percentage (%) <span class="text-danger">*</span></label>
                                    @Html.TextBoxFor(model => model.InvoiceTaxPercentagestring, new
