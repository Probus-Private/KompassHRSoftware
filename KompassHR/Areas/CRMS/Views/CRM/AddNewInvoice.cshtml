                                            @*<a href="#" onclick="window.open('@Url.Action("GetViewFile", "CRM", new {FilePath=ViewBag.Invoice})', '_blank');"><i class="fa fa-eye"></i>View File</a>*@

                                        }
                                    </div>
                                </div>



                                <div class="col-md-6 mb-3">
                                    <label class="mb-2">Supporting Document<span class="text-danger"></span></label>
                                    <input class="form-control" type="file" name="SupportingDocumentFile" id="SupportingDocumentFile"
                                           data-file-link="@ViewBag.SupDoc" />
                                    <div id="file-link-container-SupportingDocument" style="display: @(ViewBag.SupDoc != "" ? "block" : "none")">
