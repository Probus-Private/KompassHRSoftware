    $("#SaveInvoice").validate({
        rules: {
            BillMonth: {
                required: true
            },
            InvoiceNumber: {
                required: true
            },
            InvoiceDate: {
                required: true
            },
            DueDate: {
                required: true
            },
            InvoiceBasicAmountstring : {
                required: true
            },
            InvoiceTaxPercentagestring: {
                required: true
            },
            InvoiceTaxAmountstring : {
                required: true
            },
            //InvoicePaidAmountstring : {
            //    required: true
            //},
            //InvoiceBalanceAmountstring : {
            //    required: true
            //}
        },
        messages: {
            BillMonth: {
                required: "Month of Invoice is required"
            },
            InvoiceNumber: {
                required: "InvoiceNumber  is required"
            },
            InvoiceDate: {
                required: "Invoice Date  is required"
            },
            DueDate: {
                required: "Due Date  is required"
            },
            InvoiceBasicAmountstring : {
                required: "Invoice Basic Amount  is required"
            },
            InvoiceTaxPercentagestring: {
                required: "Invoice Percentage is required"
            },
            InvoiceTaxAmountstring : {
                required: "Invoice Tax Amount  is required"
            },
          //  InvoicePaidAmountstring : {
            //    required: "Invoice Paid Amount  is required"
            //},
            //InvoiceBalanceAmountstring : {
            //    required: "Invoice Balance Amount  is required"
            //}
        }
    });

    $(document).ready(function(){
        calculateTotal();
    });

    function isNumberKey(evt, element) {
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        // Allow backspace, delete, arrow keys
        if (charCode == 8 || charCode == 37 || charCode == 39) {
            return true;
        }
        // Prevent dot (.)
        if (charCode == 46) {
            return false;
        }
        // Allow only numbers and limit the length to 9 characters
        if (charCode >= 48 && charCode <= 57) {
            if (element.value.length >= 9) {
                return false;
            }
            return true;
        }
        return false;
    }

    function calculateTotal() {
        debugger
        var basicAmount = parseFloat(document.getElementById('InvoiceBasicAmount').value) || 0;
        var taxAmount = parseFloat(document.getElementById('InvoiceTaxAmount').value) || 0;
        var totalAmount = basicAmount + taxAmount;

        document.getElementById('InvoiceTaxAmount').value = totalAmount.toFixed(2); // Display with 2 decimal places
    }



    var form = $('#SaveInvoice');
    form.validate();


    $('#btnSubmit').click(function () {
        debugger
        if (form.valid()) {

            var Encrypted_Id = $("#Encrypted_Id").val();
            var BillMonth = $("#BillMonth").val();
            //var EmailId = $("#EmailId").val();
            form.submit();

        }
        else {
            return false;
        }
    });
</script>


<script>

    const MAX_FILE_SIZE = 5 * 1024 * 1024;

    document.querySelectorAll('input[type="file"]').forEach(input => {
        let replacingFile = false; // Flag to track if user confirmed replacement

        input.addEventListener('click', function (event) {
            debugger
            const existingFile = input.getAttribute('data-file-link');
            const file = event.target.files[0];
            if (file) {
                replacingFile = true;
            }
            if (existingFile && !replacingFile) {
                event.preventDefault();

                Swal.fire({
                    title: 'File Already Uploaded',
                    text: 'You have already uploaded a file. Do you want to replace it?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, replace it!',
                    cancelButtonText: 'No, keep the existing file'
                }).then((result) => {
                    if (result.isConfirmed) {
                        replacingFile = true; // Set the flag to true
                        input.click(); // Open the file explorer
                    } else {
                        // Clear the file input if user decides not to replace
                        input.value = '';
                    }
                });
            }
            else {
                replacingFile = false;
                return;
            }
        });

        // Listen for the change event to handle file selection
        input.addEventListener('change', function (event) {
            replacingFile = true;
            const file = event.target.files[0];
            if (file) {
                // Check file size
                if (file.size > MAX_FILE_SIZE) {
                    Swal.fire({
                        title: 'File Size Exceeded',
                        text: 'The file size must be less than 5 MB.',
                        icon: 'error'
                    });
                    input.value = ''; // Clear the input if the file is too large
                } else {
                    if (replacingFile) {
                        const fileLinkContainerId = `file-link-container-${input.name === 'InvoiceCopyFile' ? 'InvoiceCopy' : 'SupportingDocument'}`;
                        // Hide the view file link
                        document.getElementById(fileLinkContainerId).style.display = 'none';
                        replacingFile = false; // Reset the flag after handling the change
                    }
                }
            }
        });
    });
</script>

<script>
    function calculateTaxFromPercentage() {
        const basicAmount = parseFloat(document.getElementById("InvoiceBasicAmount").value) || 0;
        const percentage = parseFloat(document.getElementById("InvoiceTaxPercentage").value) || 0;

        const calculatedTax = (basicAmount * percentage) / 100;

        // Show calculated tax
        document.getElementById("PercentageResult").value = calculatedTax.toFixed(2);

        // Now calculate total using updated tax
        calculateTotalFromAll();
    }

    function calculateTotalFromAll() {
        const basicAmount = parseFloat(document.getElementById("InvoiceBasicAmount").value) || 0;
        const calculatedTax = parseFloat(document.getElementById("PercentageResult").value) || 0;
        const total = basicAmount + calculatedTax;

        document.getElementById("InvoiceTaxAmount").value = total.toFixed(2);
    }
</script>

<script>
    function loadInvoiceDetails() {
        debugger
        var siteId = $('#ACCSITES_Fid').val();
        var month = $('#BillMonth').val();

        if (siteId && month) {
            $.ajax({
                url: '/CRMS/CRM/GetInvoiceDetails', // <-- Change to your actual controller & action
                type: 'GET',
                data: { siteId: siteId, month: month },
                success: function (data) {
                    debugger
                    if (data.success) {
                        $('#InvoiceBasicAmount').val(data.basicAmount);
                        $('#InvoiceTaxPercentage').val(data.taxPercentage);
                        calculateTaxFromPercentage(); // Optional
                    } else {
                        $('#InvoiceBasicAmount').val('');
                        $('#InvoiceTaxPercentage').val('');
                        $('#PercentageResult').val('');
                        $('#InvoiceTaxAmount').val('');
                        alert("No invoice data found.");
                    }
                },
                error: function () {
                    alert("Error loading invoice data.");
                }
            });
        }
    }
</script>
