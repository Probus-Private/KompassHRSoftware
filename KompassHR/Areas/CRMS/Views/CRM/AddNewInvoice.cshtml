        htmlAttributes.Add("readonly", "readonly");
    }


    var htmlAttributesSite = new Dictionary<string, object>
    {
        { "class", "form-control form-select" },
        { "id", "ACCSITES_Fid" },
        { "required","required" }
    };
    if (Model.Encrypted_Id != null)
    {
        htmlAttributesSite.Add("disabled", "disabled");
    }
}


