@model KompassHR.Areas.CRMS.Models.ACCSITELOCT

@{
    ViewBag.Title = "SiteLocListCreationForm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input[type="radio"] {
        display: none;
    }
</style>

<style>
    #map {
        height: 300px;
        width: 100%;
    }
</style>


<script>
    var map;
    var marker;

    function initMap() {
        // Read from input or use fallback
        var lat = parseFloat(document.getElementById('txtLatitue').value) || 18.51205454734215;
        var lng = parseFloat(document.getElementById('txtLongitude').value) || 73.85506912689212;

        var initialPosition = { lat: lat, lng: lng };

        map = new google.maps.Map(document.getElementById('map'), {
            center: initialPosition,
            zoom: 13
        });

        marker = new google.maps.Marker({
            position: initialPosition,
            map: map
        });

        // When the map is clicked
        map.addListener('click', function(event) {
            var clickedLat = event.latLng.lat();
            var clickedLng = event.latLng.lng();

            document.getElementById('txtLatitue').value = clickedLat;
            document.getElementById('txtLongitude').value = clickedLng;

            updateMarkerAndMap(clickedLat, clickedLng);
        });

        // When lat/lng inputs change manually
        document.getElementById('txtLatitue').addEventListener('change', moveToInputLocation);
        document.getElementById('txtLongitude').addEventListener('change', moveToInputLocation);
    }

    function moveToInputLocation() {
        var lat = parseFloat(document.getElementById('txtLatitue').value);
        var lng = parseFloat(document.getElementById('txtLongitude').value);

        if (!isNaN(lat) && !isNaN(lng)) {
            updateMarkerAndMap(lat, lng);
        }
    }

    function updateMarkerAndMap(lat, lng) {
        debugger
        var position = { lat: lat, lng: lng };
        marker.setPosition(position);
        map.setCenter(position);
        map.setZoom(15); // zoom to location
    }
</script>


<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyA3r4hH526z1plXeKvsOcOzA0xsS8Npies&sensor=false_KEY&callback=initMap" async defer></script>

<div id="content" class="app-content">
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="d-flex flex-wrap">
                @*@{ var EncryptedId = ViewBag.EncryptedId as string; }*@
                @*<button type="button" class="btn btn-danger d-lg-block m-l-15 me-1 mb-1" onclick="location.href='@Url.Action("AccountDetails", "CRM", new { EncryptedId = Convert.ToString(Session["EnIdSL"]) })'"><i class="fa fa-arrow-left fa-sm" title="Back" style="font-size:x-small"></i> Back</button>*@
                
                <button type="button"
                        onclick="location.href='@Url.Action("AccountDetails", "CRM", new { EncryptedId = Convert.ToString(Session["EnIdSL"]) })'"
                        style="background: none; border: none; padding: 0; cursor: pointer;">
                    <img src="~/assets/MenuImages/Back.png"
                         alt="Back"
                         style="width: 28px; height: auto;">
                </button>

             </div>
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">Site Location Creation Form</h4>
                </div>
                <div class="panel-body">
                    <form role="form" action="/CRMS/CRM/SiteLocListCreationForm" id="SaveSiteLocListCreationForm" method="post" data-parsley-validate="">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Site Name* :</label>
                                @Html.DropDownListFor(model => model.ACCSITES_Fid, new SelectList(ViewBag.SiteList, "Fid", "SiteName"), "--Select--", new { @class = "form-control", name = "ACCSITES_Fid", id = "ACCSITES_Fid", autocomplete = "off" })
                                @Html.Hidden("Encrypted_Id", new { id = "Encrypted_Id" })
                                @Html.Hidden("Ids", "", new { @class = "form-control", name = "Ids", id = "Ids", autocomplete = "off" })

                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Location Name* :</label>
                                @Html.TextBoxFor(model => model.LocationName, new { @class = "form-control", name = "LocationName", id = "LocationName", autocomplete = "off" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Address* :</label>
                                @Html.TextBoxFor(model => model.Address, new { @class = "form-control", name = "Address", id = "Address", autocomplete = "off" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div id="map"></div>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="mb-2" for="txtLatitue">Latitude* :</label>
                                @Html.TextBoxFor(model => model.GPSLattitude, new { @class = "form-control", name = "txtLatitue", id = "txtLatitue", autocomplete = "off" })
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="mb-2" for="txtLongitude">Longitude* :</label>
                                @Html.TextBoxFor(model => model.GPSLongitude, new { @class = "form-control", name = "txtLongitude", id = "txtLongitude", autocomplete = "off" })
                            </div>

                        </div>
                        <div class="form-group row">
                            <div class="col-md-12">
                                <center>
                                    <label class="mb-2">
                                        <input type="button" id="btnSubmit" class="btn btn-success btnpress" value="Save" />
                                    </label>
                                </center>
                            </div>
                        </div>
                        <br />

                    </form>

                    <div class="row mt-4">
                        <table id="SiteLoclist" class="table table-striped table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>Edit</th>
                                    <th hidden>Encrypted_Id</th>
                                    <th hidden>SiteId</th>
                                    <th>Site Name</th>
                                    <th>Location Name</th>
                                    <th>Address</th>
                                    <th>Latitude</th>
                                    <th>Longitude</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.SitedetailsList)
                                {
                                    <tr>
                                        <td>
                                            <a id="editSiteName1" class="editSiteName" title="Edit">
                                                <i class="bi bi-pencil-square" style="margin-left: 8px; color: #007bff;"></i>
                                            </a>
                                        </td>

                                        <td hidden>@item.Encrypted_Id</td>
                                        <td hidden>@item.ACCSITES_Fid</td>

                                        <td>@item.SiteName</td>
                                        <td>@item.LocationName</td>
                                        <td>@item.Address</td>
                                        <td>@item.GPSLattitude</td>
                                        <td>@item.GPSLongitude</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
  
    $("#Encrypted_Id").val("");
    $(document).on("click", ".editSiteName", function () {
        const row = $(this).closest("tr");
        const encryptedId = row.find("td:eq(1)").text().trim();
        const accsitesFid = row.find("td:eq(2)").text().trim();
        const siteName = row.find("td:eq(3)").text().trim();
        const locationName = row.find("td:eq(4)").text().trim();
        const address = row.find("td:eq(5)").text().trim();
        const latitude = row.find("td:eq(6)").text().trim();
        const longitude = row.find("td:eq(7)").text().trim();

        // Set values in the form fields
        $("#Ids").val(encryptedId);
        $("#Encrypted_Id").val(encryptedId);
        $("#ACCSITES_Fid").val(accsitesFid);
        $("#LocationName").val(locationName);
        $("#Address").val(address);
        $("#txtLatitue").val(latitude);
        $("#txtLongitude").val(longitude);

        $("#ACCSITES_Fid").focus();
        $("#ACCSITES_Fid").change();
    });

</script>
<script>
    $("#SaveSiteLocListCreationForm").validate({
        rules: {
            LocationName: { required: true },
            ACCSITES_Fid: { required: true },
            Address: { required: true },
            txtLongitude: { required: true },
            txtLatitue: { required: true },
        },
        messages: {
            LocationName: { required: "Location Name is required" },
            ACCSITES_Fid: { required: "Site Name is required" },
            Address: { required: "Site Name is required" },
            txtLongitude: { required: "Site Name is required" },
            txtLatitue: { required: "Site Name is required" }
        }
    });

        var form1 = $("#SaveSiteLocListCreationForm");

        $("#btnSubmit").click(function () {
            debugger
            if (form1.valid()) {
                var Encrypted_Id = $("#Ids").val();
                var LocationName = $("#LocationName").val();
                var ACCSITES_Fid = $("#ACCSITES_Fid").val();
                $.ajax({
                    url: "/CRMS/CRM/IsSiteLocExist",
                    method: "get",
                    data: { Encrypted_Id: Encrypted_Id, LocationName: LocationName, ACCSITES_Fid: ACCSITES_Fid },
                    success: function (response) {
                        debugger
                        var Message1 = response.Message;
                        var Icon1 = response.Icon;
                        if (response.Icon == "error") {
                            if (Message1 != null && Icon1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup();
                                        popup.classList.remove('swal2-show');
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake');
                                        });
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake');
                                        }, 500);
                                    }
                                });
                            }
                        } else {
                            $("#SaveSiteLocListCreationForm").submit();
                        }
                    }
                });
            } else {
                return false;
            }
        });

</script>


