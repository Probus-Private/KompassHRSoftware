    var formLocation = $("#SaveLeadLocation");
    $("#LocationSubmit").click(function () {
        debugger
        if (formLocation.valid()) {
            debugger
            var Encrypted_Id = $("#ACCLOCATION_EncryptedId").val();
            var ACCMAIN_Fid = $("#txtACCMAIN_Fid").val();
            var LocationName = $("#txtLocationName").val();
            var Area = $("#txtArea").val();
            var Address = $("#txtAddress").val();
            var MAS_COUNTRY_Fid = $("#txtMAS_COUNTRY_Fid").val();
            var MAS_STATE_Fid = $("#txtMAS_STATE_Fid").val();
            var City = $("#txtCity").val();
            var IsHeadOffice = $("#txtIsHeadOffice").is(':checked');
            var BUCode = $("#BUCode").val();
            var Pincode = $("#txtPincode").val();
            $.ajax({
                url: "SaveLeadLocation",
                method: "post",
                data: { Encrypted_Id: Encrypted_Id, ACCMAIN_Fid: ACCMAIN_Fid, LocationName: LocationName, Area: Area, Address: Address, MAS_COUNTRY_Fid1: MAS_COUNTRY_Fid, MAS_STATE_Fid1: MAS_STATE_Fid, City: City, IsHeadOffice: IsHeadOffice, BUCode: BUCode, Pincode: Pincode },
                success: function (response) {
                    debugger
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (Icon1 == "success") {
                        if (Message1 != null && Icon1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup();
                                    popup.classList.remove('swal2-show');
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake');
                                    });
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake');
                                    }, 500);
                                }
                            }).then(() => {
                                // Redirect to the desired action method after showing the success message
                                window.location.href = '@Url.Action("Lead_Dashboard", "CRM")';
                            });
                        }
                    } else {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup();
                                popup.classList.remove('swal2-show');
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake');
                                });
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake');
                                }, 500);
                            }
                        });
                    }
                    $("#ACCLOCATION_EncryptedId").val(null);
                    $("#txtLocationName").val(null);
                    $("#txtPincode").val(null);
                    $("#txtArea").val(null);
                    $("#txtAddress").val(null);
                    $("#txtMAS_COUNTRY_Fid").val(null);
                    $("#txtMAS_STATE_Fid").val(null);
                    $("#txtCity").val(null);
                    $("#txtIsHeadOffice").prop("checked", false);
                    $("#txtACCMAIN_Fid").val(null);

                }
            });
        }
        else {
            return false;
        }
    });

     $("#txtArea").change(function () {
        debugger
        var txtAddress = $(this).val();
        var pincode = $("#txtPincode").val();

        if (txtAddress !== "") {
            $.ajax({
                url: "@Url.Action("GetCSC2", "CRM")",
                method: "get",
                data: { txtAddress: txtAddress, pincode: pincode },
                success: function (response) {
                    debugger;
                    $("#txtMAS_COUNTRY_Fid").val(response.CSCList[0].Country);
                    $("#txtMAS_STATE_Fid").val(response.CSCList[0].StateName);
                    $("#txtCity").val(response.CSCList[0].OfficeName);
                }
            })
        }
    })

      $("#txtPincode").change(function () {
        debugger
        var txtPincode = $(this).val();
        $('#txtArea').empty();

        if (txtPincode !== "") {
            $.ajax({
                url: "@Url.Action("GetStates", "CRM")",
                method: "get",
            data: { txtPincode: txtPincode },
            success: function (response) {
                debugger;
                $('#txtArea').append('<option value="">' + '--Select--' + '</option>');
                $.each(response.AreaList, function (index, emp) {
                    $('#txtArea').append($('<option/>', {
                        value: emp.OfficeName,
                        text: emp.OfficeName,
                    }));
                });
            }
        })
        }
    })


</script>


