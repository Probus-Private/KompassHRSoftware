
@{
    ViewBag.Title = "AddLeadLocation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .hidden-column {
        display: none !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row">
        @*<div class="col-12">
            <button type="button" class="btn btn-danger d-lg-block m-b-15" onclick="location.href='@Url.Action("Lead_Dashboard", "CRM")'" style="float:right;"><i class="fa fa-arrow-left"></i>&nbsp;Back</button>
        </div>*@
        <ol style="list-style: none; padding: 0; margin: 0; ">
            <li style="float:right; margin-right: 15px;">
                <a href="@Url.Action("Lead_Dashboard", "CRM",  new { id = 45,ScreenId=803, area = "CRMS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
    </div>
    <br />
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Add Lead Location -</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="panel-body">
                    <form role="form" action="/CRMS/CRM/SaveLeadLocation" id="SaveLeadLocation" method="post" data-parsley-validate="">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="email">Company Name:<span class="text-danger">*</span></label>
                                @Html.DropDownList("ACCMAIN_Fid", new SelectList(ViewBag.CompanyList, "Fid", "CompanyName"), "Select", new { @class = "form-control form-select", name = "ACCMAIN_Fid", Id = "txtACCMAIN_Fid" })
                                @Html.Hidden("isredirect", "", new { @class = "form-control", name = "isredirect", Value = true })
                                @Html.Hidden("ACCLOCATION_EncryptedId", "", new { id = "ACCLOCATION_EncryptedId" })

                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Location Name:<span class="text-danger">*</span></label>
                                @Html.TextBox("LocationName", "", new { @class = "form-control", name = "LocationName", id = "txtLocationName", autocomplete = "Off" })

                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Pincode:<span class="text-danger">*</span></label>
                                @Html.TextBox("Pincode", "", new { @class = "form-control", name = "Pincode", id = "txtPincode", autocomplete = "Off", type = "number" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="mb-2" for="fullname">Area:<span class="text-danger">*</span></label>
                                @Html.DropDownList("Area", new SelectList(Enumerable.Empty<SelectListItem>(), "Value", "Text"), "--Select--", new { @class = "form-control", id = "txtArea", autocomplete = "off" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="mb-2" for="email">Country :</label>
                                @Html.TextBox("CountryId", "", new { @class = "form-control", name = "MAS_COUNTRY_Fid", Id = "txtMAS_COUNTRY_Fid", @readonly = "readonly" })
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="mb-2" for="fullname">State :</label>
                                @Html.TextBox("StateId", "", new { @class = "form-control", name = "MAS_STATE_Fid", Id = "txtMAS_STATE_Fid", @readonly = "readonly" })
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="mb-2" for="email">City :</label>
                                @Html.TextBox("City", "", new { @class = "form-control", name = "City", id = "txtCity", autocomplete = "Off", @readonly = "readonly" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 d-flex justify-content-center align-items-center mb-3">
                                <div>
                                    <label class="mb-2 mt-4" for="fullname">IsHeadOffice:</label>
                                    @Html.CheckBox("IsHeadOffice", new { @class = "", name = "IsHeadOffice", id = "txtIsHeadOffice", autocomplete = "Off" })
                                </div>
                            </div>
                        </div>

                        <br />
                        <div class="row" align="center">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" id="LocationSubmit"
                                                        class="btn btn-primary">
                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <br />
                    <div class="row">
                        <div class="col-12 overflow-auto">
                            <table id="tableCriteria255" class="table table-striped table-bordered align-middle table-responsive">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>Location Name</th>
                                        <th>Area</th>
                                        <th>Address</th>
                                        <th>City</th>
                                        <th>State</th>
                                        <th>Country</th>
                                        <th>Pincode</th>
                                        <th>Is Head Office</th>
                                        <th hidden>StateId</th>
                                        <th hidden>CountryId</th>
                                        <th hidden>Location_EncryptedId</th>

                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


