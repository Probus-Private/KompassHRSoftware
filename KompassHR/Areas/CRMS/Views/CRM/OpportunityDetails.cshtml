<script>
    function formatDate(dateStr) {
        debugger
        var date = new Date(dateStr);
        var year = date.getFullYear();
        var month = ('0' + (date.getMonth() + 1)).slice(-2);
        var day = ('0' + date.getDate()).slice(-2);
        return year + '-' + month + '-' + day;
    }
    function millisecTodate(millidate) {
        var date = new Date(millidate);
        var month = ("0" + (date.getMonth() + 1)).slice(-2);
        var day = ("0" + date.getDate()).slice(-2);
        var ddmmyyyy1 = [day, month, date.getFullYear()].join("/");
        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
            "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        var fmonth = monthNames[date.getMonth()];
        var ddmmyyyy = [day, fmonth, date.getFullYear()].join("/");
        var yyyymmdd = [date.getFullYear(), month, day].join("-");
        return { formattedDate: ddmmyyyy, isoDate: yyyymmdd };
    }

    function convertDate(data) {
        if (data != null) {
            var getdate = parseInt(data.replace("/Date(", "").replace(")/", ""));
            var date = millisecTodate(getdate);
            return date;
        }
    }


    function handleStageChange() {debugger
        var stageDropdown = document.getElementById("txtStage");
        var Encrypted_Id = $("#Encrypted_Id").val();
        var selectedStage = stageDropdown.value;

        if (selectedStage == "Won") {debugger
            Swal.fire({
                title: 'Are you sure you want to transfer to the Account?',
                showDenyButton: true,
                confirmButtonText: `Yes`,
                denyButtonText: `No`,
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Are you sure?',
                        showCancelButton: true,
                        confirmButtonText: 'Yes',
                        cancelButtonText: 'No'
                    }).then((secondResult) => {
                        if (secondResult.isConfirmed) {
                            submitOpportunityStageChange(Encrypted_Id, selectedStage);
                        } else {
                            // Reset to the initial value if the user cancels
                            $("#txtStage").val(Stageddl);
                        }
                    });
                } else {
                    // Reset to the initial value if the user cancels
                    $("#txtStage").val(Stageddl);
                }
            });
        } else {
            Swal.fire({
                title: 'Are you sure?',
                showCancelButton: true,
                confirmButtonText: 'Yes',
                cancelButtonText: 'No'
            }).then((secondResult) => {
                if (secondResult.isConfirmed) {
                    submitOpportunityStageChange(Encrypted_Id, selectedStage);
                } else {
                    // Reset to the initial value if the user cancels
                    $("#txtStage").val(Stageddl);
                }
            });
        }
    }

    function submitOpportunityStageChange(Encrypted_Id, selectedStage) {
        $.ajax({
            url: '/CRMS/CRM/UpdateOpportunityStage',
            type: 'POST',
            data: {
                Encrypted_Id: Encrypted_Id,
                Stage: selectedStage
            },
            success: function(response) {
                if (response.success) {
                    window.location.href = response.redirectUrl;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: response.message
                    });
                    $("#txtStage").val(Stageddl);
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred while processing your request.'
                });
                $("#txtStage").val(Stageddl);
            }
        });
    }

</script>

