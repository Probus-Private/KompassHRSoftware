                                            @Html.Hidden("Encrypted_Id", "", new { id = "Encrypted_Id", Value = @ViewBag.EncryptedId })
                                        </div>
                                        @if (ViewBag.StagesRecords != null)
                                        {
                                            <div class="col-md-6 mb-3">
                                                @foreach (var item in ViewBag.StagesRecords)
                                                {
                                                    <div class="col-md-6 mb-3">
