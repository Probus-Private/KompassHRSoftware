    function calculateContractValues() {
        debugger
        var tenure = parseFloat(document.getElementById("txtContractTenure").value);
        var totalValue = parseFloat(document.getElementById("txtTotalContractValue").value.replace(/,/g, ''));

        if (!isNaN(tenure) && !isNaN(totalValue) && tenure > 0) {
            var monthlyValue = totalValue / tenure;

            if(tenure < 12){
                var annualValue = totalValue;
            }else{
                var annualValue = monthlyValue * 12;
            }


            document.getElementById("txtMonthlyContractValue").value = formatNumber1(monthlyValue.toFixed(2));
            document.getElementById("txtAnnualContractValue").value = formatNumber1(annualValue.toFixed(2));
        } else {
            document.getElementById("txtMonthlyContractValue").value = "";
            document.getElementById("txtAnnualContractValue").value = "";
        }
    }

    function calculateAVCINCTAX(){
        debugger
        var tax = parseFloat(document.getElementById("txtTaxPercentage").value);
        var ACV = parseFloat(document.getElementById("txtAnnualContractValue").value.replace(/,/g, ''));

        if (!isNaN(tax) && !isNaN(ACV) && tax > 0) {
            var AVCINCTAX = ACV + (ACV * (tax / 100));

            document.getElementById("txtACVInclusiveOfTax").value = formatNumber1(AVCINCTAX.toFixed(2));
            $("#txtACVInclusiveOfTax").attr('readonly', true);
        } else {
            document.getElementById("txtACVInclusiveOfTax").value = "";
        }
    }

    function calculateMangment(){
        debugger
        var MangPer = parseFloat(document.getElementById("txtManagementFeePer").value);
        var ACV = parseFloat(document.getElementById("txtACVInclusiveOfTax").value.replace(/,/g, ''));

        if (!isNaN(MangPer) && !isNaN(ACV) && MangPer > 0) {
            var AVCINCTAX =(ACV * (MangPer / 100));

            document.getElementById("txtManagementFeeValue").value = formatNumber1(AVCINCTAX.toFixed(2));
            $("#txtManagementFeeValue").attr('readonly', true);
        } else {
            document.getElementById("txtManagementFeeValue").value = "";
        }
    }



    function formatNumber1(num) {
        // Convert to a number and format with commas
        return parseFloat(num).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }



</script>

