
@{
    ViewBag.Title = "DailyPresentEmployeeList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="content" class="app-content">


    <div class="d-flex flex-wrap">
        @*<button type="button" class="btn btn-danger d-lg-block m-l-15 me-1 mb-1" onclick="location.href='@Url.Action("CRM_Dashboard1", "CRM",new { area = "CRMS"})'"><i class="fa fa-arrow-left fa-sm" title="Add New" style="font-size:x-small"></i> Back</button>*@
        <ol style="list-style: none; padding: 0; margin: 0; ">
            <li style="float:right; margin-right: 15px;">
                <a href="@Url.Action("CRM_Dashboard1", "CRM",  new {area = "CRMS" })">
                    <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                </a>
            </li>
        </ol>
     </div>
    <div class="panel panel-inverse" id="ShiftRuleId">
        <!-- BEGIN panel-heading -->
        <div class="panel-heading">
            <h4 class="panel-title">
                Today,s Present Employee List
            </h4>
            <div class="panel-heading-btn">

                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
            </div>
        </div>

        <!-- END panel-heading -->
        <!-- BEGIN panel-body -->
        <div class="panel-body" id="LEAType">

            <div class="row">
                <!-- BEGIN col-12 -->

            </div>

            <div class="row">
                <div class="col-12 overflow-auto">

                    <table id="data-table-combine15" class="table table-striped table-bordered align-middle">
                        <thead>
                            <tr>
                                <th class="text-nowrap">Employee ID</th>
                                <th class="text-nowrap">Employee Name</th>
                                @*<th class="text-nowrap">Employee Location</th>*@
                                <th class="text-nowrap">Date</th>
                                <th class="text-nowrap">In-Location</th>
                                @*<th class="text-nowrap">Out-Location</th>*@

                            </tr>
                        </thead>

                        <tbody>
                            @if (ViewBag.PresentEmployeeList != null)
                            {
                                foreach (var item in ViewBag.PresentEmployeeList)
                                {
                                    <tr>
                                        <td>@item.EmployeeId</td>
                                        <td>@item.EmployeeName</td>
                                        @*<td>@item.LocationName</td>*@
                                        <td>@Convert.ToDateTime(item.CheckInOutDateTime).ToString("dd/MM/yyyy")</td>
                                        <td class="text-center align-middle">
                                            @if (item.GPSLAttitude != null && item.GPSLongitude != null)
                                            {
                                                <a href="javascript:void(0);" onclick="showMap(@item.InLat, @item.InLong)" title="Show Map">
                                                    <i class="fa fa-map-marker-alt" cursor pointer;"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <span title="Location not available">
                                                    <i class="fa fa-map-marker-alt" style="color: #ccc; cursor: not-allowed;"></i>
                                                </span>
                                            }
                                        </td>
                                        @*<td class="text-center align-middle">
                                            @if (item.OutLat != null && item.OutLong != null)
                                            {
                                                <a href="javascript:void(0);" onclick="showMap(@item.OutLat, @item.OutLong)" title="Show Map">
                                                    <i class="fa fa-map-marker-alt" cursor pointer;"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <span title="Location not available">
                                                    <i class="fa fa-map-marker-alt" style="color: #ccc; cursor: not-allowed;"></i>
                                                </span>
                                            }
                                        </td>*@
                                    </tr>

                                }
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>



</div>

<style>
    #mapModal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.5);
        z-index: 9999;
    }

        #mapModal .modal-content {
            position: relative;
            width: 80vw;
            height: 80vh;
            margin: 5vh auto;
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-sizing: border-box;
        }


    #map {
        width: 100%;
        height: 100%;
    }
</style>

<div id="mapModal" onclick="outsideClickClose(event)">
    <div class="modal-content">
        <span class="close-btn" onclick="closeMapModal(event)">&times;</span>
        <div id="map"></div>
    </div>
</div>

<script>
function closeMapModal(e) {
    if(e) e.stopPropagation();
    document.getElementById('mapModal').style.display = 'none';
}
function outsideClickClose(event) {
    if(event.target === document.getElementById('mapModal')) {
        closeMapModal();
    }
}
</script>

<script>
let map; // Keep a reference to the map

function showMap(lat, lng) {
    document.getElementById('mapModal').style.display = 'block';
    setTimeout(() => {
        if (map) {
            map.remove();
        }
        map = L.map('map').setView([lat, lng], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
        }).addTo(map);
        L.marker([lat, lng]).addTo(map);
    }, 100); // Delay to ensure modal is visible
}


</script>

