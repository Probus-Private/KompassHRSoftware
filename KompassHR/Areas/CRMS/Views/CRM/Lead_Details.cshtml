    });

    // Handle next button click
    $('#nextBtn').click(function() {
        if (nextId) {
            window.location.href = '@Url.Action("Lead_Details")' + '?EncryptedId=' + nextId;
        }
    });

    // Disable buttons if no previous or next ID
    if (!previousId) {
        $('#prevBtn').addClass('disabled');
