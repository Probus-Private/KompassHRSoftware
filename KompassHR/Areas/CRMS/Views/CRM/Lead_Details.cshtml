    $('#txtEmailId').on('keyup', function (e) {
        debugger


        var currentValue = $(this).val();
        var domainSuffix = @Html.Raw(Json.Encode(ViewBag.AccMainDetails.CompanyEmail));

        if (domainSuffix) {
            var domainParts = domainSuffix.split('@@');
            domainSuffix = domainParts[1];  // Set it to an empty string if null or empty
        } else {
            domainSuffix = "";
        }
        if(e.key == "Backspace"){


                var atPosition = currentValue.indexOf('@@');

                // If there is an '@@' and there is something after it
                if (atPosition !== -1 && currentValue.slice(atPosition + 1) !== "") {
                    // Remove everything after '@@' but leave '@@' intact
                    $(this).val(currentValue.slice(0, atPosition + 1));
                }

        }
        // Check if '@@' exists in the input value
        else if (currentValue.includes('@@')) {
            var parts = currentValue.split('@@');

            // If '@@' is followed by an empty value (i.e., the user is typing after '@@')
            if (parts.length === 2 && parts[1] === "") {
                // Don't add the domain suffix if there's no domain yet
                $(this).val(parts[0] + '@@' + domainSuffix);
            }
        }




    });




</script>

