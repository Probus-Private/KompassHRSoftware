            <div class="mailbox-content-body">
                <div data-height="100%" data-skip-mobile="true">
                    <div class="p-3">
                        <h3 class="mb-3">@ViewBag.AccMainDetails.LeadName &nbsp;<a href='@Url.Action("CRM_LeadForm", "CRM", new { Encrypted_Id = @ViewBag.EncryptedId })' title="edit"><i class="fa fa-pen-to-square" style="font-size:medium;"></i></a></h3>

                        <div class="d-flex mb-3">
                            @if (ViewBag.CompanyLogo != null)
                            {
                                if (File.Exists(ViewBag.CompanyLogo))
                                {
                                    try
                                    {
                                        using (Image image = Image.FromFile(ViewBag.CompanyLogo))  // Load the image
                                        {
                                            using (MemoryStream m = new MemoryStream())  // Convert image to stream
                                            {
                                                image.Save(m, image.RawFormat);
                                                byte[] imageBytes = m.ToArray();  // Convert stream to byte array

                                                // Convert byte[] to Base64 String
                                                string base64String = Convert.ToBase64String(imageBytes);
                                                string mimeType = "image/jpg";  // Change this based on the actual image type (e.g., "image/jpeg" for jpg images)

                                                // Update FinalPath to include the mime type and Base64 string
                                                var FinalPath = "data:" + mimeType + ";base64," + base64String;

                                                <img class="rounded-pill" width="48" alt="" src="@FinalPath" />
                                            }
                                        }
                                    }
                                    catch (Exception ex)
                                    {
                                        // Fallback to default image if there's an error
                                        <img class="rounded-pill" width="48" alt="" src="~/assets/img/user/user-13.jpg" />

                                        @*<span class="widget-img widget-img-xs rounded bg-dark me-2 w-40px" style="background-image: url(~/assets/img/flag/us.jpg)"></span>*@
                                    }
                                }
                                else
                                {
                                    <a href="javascript:;">
                                        <img class="rounded-pill" width="48" alt="" src="~/assets/img/user/user-13.jpg" />
                                    </a>
                                }
                            }
                            else
                            {
                                <a href="javascript:;">
                                    <img class="rounded-pill" width="48" alt="" src="~/assets/img/user/user-13.jpg" />
                                </a>
                            }
                            <div class="ps-3">
                                <div class="email-from text-dark fs-14px mb-3px fw-bold">
                                    @ViewBag.AccMainDetails.CompanyName
                                </div>
                                <div class="email-stage text-muted fs-12px mb-3px">
                                    <i class="fa fa-tasks fa-fw"></i> Your lead is currently at the <strong>@ViewBag.AccMainDetails.Stage</strong> stage, progressing towards a successful conversion.
                                </div>
                                <div class="mb-3px"><i class="fa fa-phone fa-fw"></i> @ViewBag.AccMainDetails.CompanyContactNumber</div>
                                <div class="email-to">
                                    <i class="fa fa-paper-plane fa-fw"></i> @ViewBag.AccMainDetails.CompanyEmail
                                </div>
                                <div class="email-to">
                                    <b><span id="locCount"> You Have Created <span id="LocationCount2"></span> Locations</span></b>
                                </div>
                            </div>
                        </div>



                        <hr class="bg-gray-500" />
