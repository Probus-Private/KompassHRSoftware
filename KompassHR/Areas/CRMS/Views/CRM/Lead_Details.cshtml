<script>

    function formatDate1(dateString) {
        if (!dateString || !dateString.startsWith('/Date(') || !dateString.endsWith(')/')) return '';
        var timestamp = parseInt(dateString.replace(/\/Date\((\d+)\)\//, '$1'), 10);
        if (isNaN(timestamp)) return '';
        var date = new Date(timestamp);

        var day = ("0" + date.getDate()).slice(-2);
        var monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        var month = monthNames[date.getMonth()];
        var year = date.getFullYear();

        return day + "/" + month + "/" + year;
    }

    debugger
    var rawAllEncryptedIds = @Html.Raw(Json.Encode(ViewBag.AllEncryptedIds));
    var allEncryptedIds = rawAllEncryptedIds.map(item => item.find(x => x.Key === 'Encrypted_Id').Value);

    var currentEncryptedId = "@ViewBag.EncryptedId";
    var currentIndex = allEncryptedIds.indexOf(currentEncryptedId);

    // Determine previous and next record IDs
    var previousId = (currentIndex > 0) ? allEncryptedIds[currentIndex - 1] : null;
    var nextId = (currentIndex < allEncryptedIds.length - 1) ? allEncryptedIds[currentIndex + 1] : null;

    // Handle previous button click
    $('#prevBtn').click(function() {
        if (previousId) {
            window.location.href = '@Url.Action("Lead_Details")' + '?EncryptedId=' + previousId;
