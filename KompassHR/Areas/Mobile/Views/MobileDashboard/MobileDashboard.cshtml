
@{
    ViewBag.Title = "MobileDashboard";
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
<style>
    body {
        font-family: roboto;
        background-color: #ffffff;
    }

    .app-header-fixed {
        padding-top: 0;
    }

    .app-content {
        padding: 2px 20px;
    }

    .quickLinks-container {
        padding: 5px;
        background: #fff;
        /*        border-radius: 10px;*/
        /*        box-shadow: 0 1px 2px rgba(0,0,0,0.1);*/
    }

        .quickLinks-container h3 {
            /*            margin-bottom: 0px;*/
            color: #333;
            font-size: 0.7rem;
            text-align: center;
        }

    .quickLinks-box {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: center;
        padding: 15px 5px;
        text-align: left;
        transition: transform 0.3s ease;
        border-radius: 7px;
        /*        box-shadow: 0 1px 2px rgba(0,0,0,0.1);*/
        border: 1px solid #D9D9D9;
    }

        .quickLinks-box:hover {
            transform: translateY(-5px);
        }

        .quickLinks-box i {
            font-size: 1.3rem;
            margin-bottom: 10px;
            color: #007bff;
        }

        .quickLinks-box h3 {
            text-align: center;
            margin: 0;
            font-size: 0.9rem;
            color: #555;
            font-weight: 500;
        }

    .quickLinks-boxes a {
        padding: 5px;
    }

    .gradientLine-Div {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin: 10px 0px;
    }

    .gradientLine1 {
        width: 50%;
        height: 1px;
        background: linear-gradient(to left, #000000, #66666600);
    }

    .gradientLine2 {
        width: 50%;
        height: 1px;
        background: linear-gradient(to right, #000000, #66666600);
    }

    @@media screen and (max-width: 500px) {

        .quickLinks-boxes {
            justify-content: space-evenly;
        }

        .quickLinks-box h3 {
            font-size: 0.5rem;
        }

        .quickLinks-box img {
            width: 50%;
            /*            margin-top: 5px;*/
        }

        .quickLinks-container h2 {
            font-size: 0.9rem;
        }

        .sliderCard {
            margin-top: 10px;
        }
    }

    @@media screen and (max-width: 365px) {
        .quickLinks-box {
            padding: 15px 3px;
        }

        .quickLinks-boxes a {
            padding: 3px;
        }
    }

    @@media screen and (max-width: 350px) {
        .quickLinks-box {
            padding: 15px 2px;
        }

        .quickLinks-boxes a {
            padding: 2px;
        }
    }

    .vms-container {
        /*        margin-bottom: 50px;*/
    }

    .swiper {
        width: 100%;
        /*        height: 100%;*/
    }

    .swiper-slide {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }
</style>


<div id="content" class="app-content bg-white">

    <div class="row sliderCard">
        <div class="col-md-12 ui-sortable ">
            <div class="panel panel-inverse" style="margin-bottom:0px !important;" data-sortable-id="index-1">

                <!-- END panel-heading -->
                <div class="panel-body" style="padding:0px;">
                    <div class="swiper mySwiper">
                        <div class="swiper-wrapper">
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-blue" style="margin:0px; width:100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-dollar-sign fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Shift Change</div>
                                        <div class="stats-number">
                                            <a href="@Url.Action("GetList", "ESS_TimeOffice_ShiftChange", new { area = "ESS" })" id="anchorApprovals" style="color:white;" onclick="Showdata('RECR03','Approvals pending with me')">2</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 40.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-teal" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-globe fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">OutDoor</div>
                                        <div class="stats-number">
                                            <a href="@Url.Action("ESS_TimeOffice_GetApproveRejectList", "ESS_TimeOffice_OutDoor", new { area = "ESS" })" id="anchorApprovals" style="color:white;" onclick="Showdata('RECR03','Approvals pending with me')">0</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 40.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-purple" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-archive fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Personal Gatepass</div>
                                        <div class="stats-number">
                                            <a href="@Url.Action("ESS_TimeOffice_GetApproveRejectPersOnalGatepassList", "ESS_TimeOffice_PersonalGatePass", new { area = "ESS" })" id="AchorRequsitions" onclick="Showdata('RECR01','Open raised by me')" style="color:white;">0</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 76.3%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me </div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-dark" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-comment-alt fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Work From Home</div>
                                        <div class="stats-number">
                                        <a href="@Url.Action("ESS_TimeOffice_WHF_ApprovalandrejectList", "ESS_TimeOffice_WHF", new { area = "ESS" })" id="AchorCandidate" onclick="Showdata('CandidatesPendingForAction','Candidates Pending for actions')" style="color:white;"> 0 </a></div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 54.9%;"></div>
                                        </div>
                                        <div class="stats-desc"> Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-orange" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-file-alt fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Punch Missing</div>
                                        <div class="stats-number">
                                            <a href="@Url.Action("ESS_TimeOffice_GetPunchMissingApprovalpendingList", "ESS_TimeOffice_PunchMissing", new { area = "ESS" })" id="AnchorInterview" onclick="Showdata('RECR07','Interviews pending with me')" style="color:white;">2</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 23.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Open raised by me</div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="widget widget-stats bg-pink" style="margin: 0px; width: 100% !important;">
                                    <div class="stats-icon stats-icon-lg"><i class="fa fa-exclamation-triangle fa-fw"></i></div>
                                    <div class="stats-content" style="height:120px;">
                                        <div class="stats-title">Approval</div>
                                        <div class="stats-number">
                                            <a href="@Url.Action("ESS_TimeOffice_Approval", "ESS_TimeOffice_Approval", new { area = "ESS" })" id="AnchorDatabaseCandidates" onclick="Showdata('DatabaseCandidates','Database Candidates')" style="color:white;">8</a>
                                        </div>
                                        <div class="stats-progress progress">
                                            <div class="progress-bar" style="width: 10.5%;"></div>
                                        </div>
                                        <div class="stats-desc">Pending Request</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END widget-list -->
                <!-- END col-12 -->
            </div>
        </div>
    </div>

    <div class="row mt-10px">
        <div class="col-lg-12 col-md-12 ui-sortable">
            <!-- BEGIN panel -->

            <div class="quickLinks-container">
                <div class="gradientLine-Div">
                    <div class="gradientLine1"> </div>
                    <div><strong>Explore</strong></div>
                    <div class="gradientLine2"> </div>
                </div>
                <div class="quickLinks-boxes row">
                    <a href="@Url.Action("GetList", "ESS_TimeOffice_Leave", new { id = 4, ScreenId=146, area = "ESS" })"
                        class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-solid fa-building-circle-arrow-right"></i>*@
                            <h3>Leave</h3>
                            <img src="~/assets/img/Icons/1.png" alt="Leave" width="30%" />
                        </div>
                    </a>
                    <a href="@Url.Action("GetList", "ESS_Leave_COFFRequistion", new { id = 4, ScreenId=293, area = "ESS" })"
                        class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-solid fa-right-from-bracket"></i>*@
                            <h3>COFF</h3>
                            <img src="~/assets/img/Icons/2.png" alt="COFF" width="30%" />
                        </div>
                    </a>
                    <a href="@Url.Action("ESS_TimeOffice_GetApproveRejectList", "ESS_TimeOffice_OutDoor", new { id = 5, ScreenId= 152, area = "ESS" })"
                       class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-solid fa-fingerprint"></i>*@
                            <h3>Outdoor</h3>
                            <img src="~/assets/img/Icons/3.png" alt="Outdoor" width="30%" />
                        </div>
                    </a>
                    <a href="@Url.Action("ESS_TimeOffice_GetPunchMissingApprovalpendingList", "ESS_TimeOffice_PunchMissing", new { id = 5, ScreenId=155, area = "ESS" })"
                        class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-solid fa-house-laptop"></i>*@
                            <h3>Punch Missing</h3>
                            <img src="~/assets/img/Icons/4.png" alt="Punch Missing" width="30%" />
                        </div>
                    </a>
                    <a href="@Url.Action("ESS_TimeOffice_WHF_ApprovalandrejectList", "ESS_TimeOffice_WHF", new { id = 5, ScreenId=154, area = "ESS" })"
                        class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-solid fa-right-left"></i>*@
                            <h3>Work From Home</h3>
                            <img src="~/assets/img/Icons/5.png" alt="Work From Home" width="30%" />
                        </div>
                    </a>
                    <a href="@Url.Action("MobileDashboard", "MobileDashboard", new { id = 4, ScreenId=293, area = "Mobile" })"
                       class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-regular fa-circle-right"></i>*@
                            <h3>Salary Slips</h3>
                            <img src="~/assets/img/Icons/6.png" alt="Salary Slips" width="30%" />
                        </div>
                    </a>
                    <a href="#" class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-solid fa-right-left"></i>*@
                            <h3>Holidays</h3>
                            <img src="~/assets/img/Icons/7.png" alt="Holidays" width="30%" />
                        </div>
                    </a>
                    <a href="/Mobile/MobileDashboard/ShowMoreDashboard" class="col-md-2 col-3" style="text-decoration:none !important;">
                        <div class="quickLinks-box">
                            @*<i class="fa-regular fa-circle-right"></i>*@
                            <h3>See More</h3>
                            <img src="~/assets/img/Icons/8.png" alt="See More" width="30%" />
                        </div>
                    </a>
                </div>
            </div>

        </div>
    </div>
    @*<hr />*@
</div>


<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<!-- Initialize Swiper -->
<script>
    var swiper = new Swiper(".mySwiper", {
        spaceBetween: 30,
        centeredSlides: true,
        autoplay: {
            delay: 2500,
            disableOnInteraction: false,
        },
        pagination: {
            el: ".swiper-pagination",
            clickable: true,
        },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
    });
</script>
