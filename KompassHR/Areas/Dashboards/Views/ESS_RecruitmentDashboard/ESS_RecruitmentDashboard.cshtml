<style>
    body {
        font-family: "Roboto", sans-serif;
        font-size: 14px;
        line-height: 1.5;
        background-color: #F8F9FA;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .page-wrapper {
        -webkit-transition: all 0.5s ease;
        -ms-transition: all 0.5s ease;
        transition: all 0.5s ease;
        margin: 0 0 0 252px;
