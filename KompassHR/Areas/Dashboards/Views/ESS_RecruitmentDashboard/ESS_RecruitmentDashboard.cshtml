@using Newtonsoft.Json

@{
    ViewBag.Title = "ESS_RecruitmentDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var genderData = ViewBag.GenderWise != null ? JsonConvert.SerializeObject(ViewBag.GenderWise) : "[]";
    var openVsWipData = ViewBag.OpenVsWIP != null ? JsonConvert.SerializeObject(ViewBag.OpenVsWIP) : "[]";
    var deptWiseData = ViewBag.DeptWise != null ? JsonConvert.SerializeObject(ViewBag.DeptWise) : "[]";
    var positionTypeData = ViewBag.PositionType != null ? JsonConvert.SerializeObject(ViewBag.PositionType) : "[]";
    IEnumerable<dynamic> companyList = ViewBag.CompanySummary;
    dynamic companySummary = null;

    if (companyList != null && companyList.Any())
    {
        companySummary = companyList.First();
    }
    var monthAbbrs = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedMonthNames.Take(12).ToArray();
    var deptMonthlyData = ViewBag.DeptMonthlyData as IEnumerable<dynamic>;
}

