<script>
    document.addEventListener("DOMContentLoaded", function () {

        var totalApplications = @Html.Raw(ViewBag.TotalApplications ?? 0);
        var filledPositions = @Html.Raw(ViewBag.FilledPositions ?? 0);

        var percent = 0;

        if (totalApplications > 0) {
            percent = (filledPositions / totalApplications) * 100;
        }

        var totalSegments = 14;
        var filledSegments = Math.round((percent / 100) * totalSegments);

        var data = [];

        for (var i = 0; i < totalSegments; i++) {

            if (i < filledSegments) {
                data.push({ y: 1, color: '#f46228' });
            } else {
                data.push({ y: 1, color: '#e5e7eb' });
            }
        }

        Highcharts.chart('recruitmentOverviewChart', {

            chart: {
                type: 'pie',
                backgroundColor: 'transparent',
                margin: [0,0,0,0]
            },

            title: {
                text:
                '<span style="font-size:26px;font-weight:bold;color:#1e293b">'
                + totalApplications +
                '</span><br><span style="font-size:12px;color:#6c757d">Total Applications</span>',
                align: 'center',
                verticalAlign: 'middle',
                y: 45
            },

            tooltip: { enabled:false },

            plotOptions: {
                pie: {
                    startAngle: -90,
                    endAngle: 90,
                    center: ['50%','85%'],
                    size: '150%',
                    innerSize: '75%',
                    borderWidth: 6,
                    borderColor: '#ffffff',
                    dataLabels:{ enabled:false }
                }
            },

            series: [{
                name: 'Applications',
                data: data
            }],

            credits: { enabled:false }

        });

    });

    document.addEventListener("DOMContentLoaded", function () {
        debugger
