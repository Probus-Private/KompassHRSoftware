            <div class="container-fluid px-3 px-md-4 mb-3">

                <!-- Row 4 Stage Performance Header -->
                <div class=" mb-3 mt-2">
                    <h4 class="fw-bold m-0" style="color: #1e293b;">Stage Performance</h4>
                </div>

                <!-- Row 4 Stage Performance Cards -->
                <div class="row g-4 mb-3">
                    <div class="col-12 col-md-4 col-xl" style="min-width: 200px;">
                        <div class="card stage-card mb-0">
                            <div class="stage-icon-tr bg-orange"><i class="ti ti-folder"></i></div>
                            <h6>Applied</h6>
                            <h2 class="fw-bold">@ViewBag.Applied</h2>
                            <p><span>Overall Progress</span> <span>100%</span></p>
                            <div class="progress-thin">
                                <div class="bar bg-orange" style="width:100%"></div>             
                                           </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl" style="min-width: 200px;">
                        <div class="card stage-card mb-0">
                            <div class="stage-icon-tr bg-teal"><i class="ti ti-hourglass"></i></div>
                            <h6>Shortlisted</h6>
                            <h2 class="fw-bold">@ViewBag.Shortlisted</h2>
                            <p><span>Conversion rate</span> <span>@ViewBag.ShortlistedPercent%</span></p>
                            <div class="progress-thin">
                                <div class="bar bg-teal" style="width:@ViewBag.ShortlistedPercent%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-xl" style="min-width: 200px;">
                        <div class="card stage-card mb-0">
                            <div class="stage-icon-tr bg-dark"><i class="ti ti-calendar-event"></i></div>
                            <h6>Interviewed</h6>
                            <h2 class="fw-bold">@ViewBag.Interviewed</h2>
                            <p><span>Conversion rate</span> <span>@ViewBag.InterviewedPercent%</span></p>
                            <div class="progress-thin">
                                <div class="bar bg-dark" style="width:@ViewBag.InterviewedPercent%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-xl" style="min-width: 200px;">
                        <div class="card stage-card mb-0">
                            <div class="stage-icon-tr bg-blue"><i class="ti ti-file-text"></i></div>
                            <h6>Offered</h6>
                            <h2 class="fw-bold">@ViewBag.Offered</h2>
                            <p><span>Conversion rate</span> <span>@ViewBag.OfferedPercent%</span></p>
                            <div class="progress-thin">
                                <div class="bar bg-blue" style="width:@ViewBag.OfferedPercent%"></div>
                            </div>
                        </div>
                    </div>
                    
                </div>

                <!-- Row 1 -->
                <div class="row g-4 mb-2">
                    <div class="col-lg-8">
                        <div class="card w-100" style="height:520px; overflow-y:auto;">
                            <div class="card-header-flex">
                                <h3 class="card-title">Candidates Hiring Analysis</h3>

                            </div>
                            <div class="table-responsive">
                                <table class="table table-borderless align-middle w-100">
                                    <thead>
                                        <tr>
                                            <th style="width: 28%">Department</th>
                                            <th class="text-center">Applicants</th>
                                            <th class="text-center">Shortlisted</th>
                                            <th class="text-center">Interviewed</th>
                                            <th class="text-center">Offered</th>
                                        </tr>
                                    </thead>
                                    <tbody>

                                        @foreach (var item in ViewBag.HiringAnalysis)
                                        {
                                            <tr>

                                                <td>
                                                    <strong class="text-dark">@item.DepartmentName</strong><br>
                                                    <small>@item.DesignationName</small>
                                                </td>

                                                <td class="text-center">
                                                    <span class="pill-solid orange">@item.Applicants</span>
                                                </td>

                                                <td class="text-center">
                                                    <span class="pill-solid teal">@item.Shortlisted</span>
                                                </td>

                                                <td class="text-center">
                                                    <span class="pill-solid dark">@item.Interviewed</span>
                                                </td>

                                                <td class="text-center">
                                                    <span class="pill-solid blue">@item.Offered</span>
                                                </td>

                                            </tr>
                                        }

                                    </tbody>                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 d-flex flex-column">
                        <div class="card mb-3 flex-grow-1" style="height: auto;">
                            <div class="card-header-flex">
                                <h3 class="card-title">Recruitment Overview</h3>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <div>
                                    <p class="text-muted mb-1" style="font-size: 13px;">Offer Acceptance</p>
                                    <h4 class="fw-bold fs-3" style="color: #1e293b;">@ViewBag.OfferAcceptance%</h4>
                                </div>
                                <div class="text-end">
                                    <p class="text-muted mb-1" style="font-size: 13px;">Overall Hire Rate</p>
