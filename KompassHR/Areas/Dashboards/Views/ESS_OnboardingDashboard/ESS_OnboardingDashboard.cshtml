      // Highcharts Initialization Script for Onboarding Dashboard
      document.addEventListener('DOMContentLoaded', function () {

        if (typeof Highcharts !== 'undefined') {

          Highcharts.setOptions({
            colors: ['#28a745', '#ffc107', '#dc3545', '#17a2b8', '#F26522', '#1D2A3A'],

            chart: {
              backgroundColor: '#ffffff',
              style: {
                fontFamily: 'Roboto, sans-serif',
                color: '#111827'
              }
            },

            title: {
              style: {
                color: '#111827',
                fontWeight: '600'
              }
            },

            subtitle: {
              style: {
                color: '#111827'
              }
            },

            xAxis: {
              labels: { style: { color: '#111827' } },
              title: { style: { color: '#111827' } },
              gridLineDashStyle: 'Dash',
              gridLineColor: 'rgba(0,0,0,0.1)'
            },

            yAxis: {
              labels: { style: { color: '#111827' } },
              title: { style: { color: '#111827' } },
              gridLineDashStyle: 'Dash',
              gridLineColor: 'rgba(0,0,0,0.1)'
            },

            legend: {
              itemStyle: { color: '#111827' },
              itemHoverStyle: { color: '#000000' }
            },

            tooltip: {
              backgroundColor: '#ffffff',
              style: { color: '#111827' }
            },

            credits: { enabled: false }

          });

          /* =================================================
          1️⃣ Offer Status Distribution (Pie Chart)
          ================================================= */

          Highcharts.chart('offerStatusChart', {
            chart: { type: 'pie' },

            title: {
              text: 'Offer Status Distribution'
            },

            plotOptions: {
              pie: {
                allowPointSelect: true,
                cursor: 'pointer',
                dataLabels: {
                  enabled: true,
                  format: '<b>{point.name}</b>: {point.percentage:.1f} %',
                  style: {
                    color: '#111827',
                    textOutline: 'none'
                  }
                }
              }
            },

            series: [{
              name: 'Offers',
              colorByPoint: true,
              data: [
                { name: 'Accepted', y: 70, color: '#28a745' },
                { name: 'Pending', y: 20, color: '#ffc107' },
                { name: 'Rejected', y: 10, color: '#dc3545' }
              ]
            }]

          });

          /* =================================================
          2️⃣ Hiring Trend Chart (Area Spline)
          ================================================= */

          Highcharts.chart('hiringTrendChart', {
            chart: { type: 'areaspline' },

            title: {
              text: 'Hiring Trend'
            },

            xAxis: {
              categories: [
                'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'
              ]
            },

            yAxis: {
              title: {
                text: 'Number of Hires'
              }
            },

            tooltip: {
              crosshairs: true,
              shared: true
            },

            series: [{
              name: 'Hires',
              data: [5, 8, 12, 10, 15, 22, 18, 25, 20, 30, 28, 35],
              color: '#F26522',
              fillColor: {
                linearGradient: { x1: 0, y1: 0, x2: 0, y2: 1 },
                stops: [
                  [0, Highcharts.color('#F26522').setOpacity(0.3).get('rgba')],
                  [1, Highcharts.color('#F26522').setOpacity(0).get('rgba')]
                ]
              }
            }]
          });

        }
      });
</script> 
