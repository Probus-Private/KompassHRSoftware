    .onboarding-dashboard .border-secondary {
        border-color: #6c757d !important;
    }

    /* Tables */
    .onboarding-dashboard .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .onboarding-dashboard .custom-table {
        width: 100%;
