<style>
    /* ==========================================
                      VMS DASHBOARD INTERNAL STYLES
                      (Self-contained CSS for the dashboard content)
                      ========================================== */


    .vms-dashboard .avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        border-radius: 50%;
        object-fit: cover;
    }

    .vms-dashboard .avatar-sm {
        width: 32px;
        height: 32px;
        font-size: 13px;
    }

    .vms-dashboard .avatar-md {
        width: 48px;
        height: 48px;
        font-size: 20px;
    }

    /* Transparent Backgrounds & Text Colors */
    .vms-dashboard .bg-primary-transparent {
        background-color: rgba(242, 101, 34, 0.1) !important;
        color: #F26522 !important;
    }

    .vms-dashboard .bg-success-transparent {
        background-color: rgba(40, 167, 69, 0.1) !important;
        color: #28a745 !important;
    }

    .vms-dashboard .bg-info-transparent {
        background-color: rgba(23, 162, 184, 0.1) !important;
        color: #17a2b8 !important;
    }

    .vms-dashboard .bg-warning-transparent {
        background-color: rgba(255, 193, 7, 0.1) !important;
        color: #ffc107 !important;
    }

    .vms-dashboard .bg-danger-transparent {
        background-color: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
    }

    .vms-dashboard .bg-secondary-transparent {
        background-color: rgba(108, 117, 125, 0.1) !important;
        color: #6c757d !important;
    }

    .vms-dashboard .text-primary {
        color: #F26522 !important;
    }

    .vms-dashboard .text-success {
        color: #28a745 !important;
    }

    .vms-dashboard .text-info {
        color: #17a2b8 !important;
    }

    .vms-dashboard .text-warning {
        color: #ffc107 !important;
    }

    .vms-dashboard .text-danger {
        color: #dc3545 !important;
    }

    .vms-dashboard .text-secondary {
        color: #6c757d !important;
    }

    .vms-dashboard .border-primary {
        border-color: #F26522 !important;
    }

    .vms-dashboard .border-success {
        border-color: #28a745 !important;
    }

    .vms-dashboard .border-info {
        border-color: #17a2b8 !important;
    }

    .vms-dashboard .border-warning {
        border-color: #ffc107 !important;
    }

    .vms-dashboard .border-danger {
        border-color: #dc3545 !important;
    }

    .vms-dashboard .border-secondary {
        border-color: #6c757d !important;
    }

    /* Tables */
    .vms-dashboard .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .vms-dashboard .custom-table {
        width: 100%;
        margin-bottom: 1rem;
        color: #212529;
    }

        .vms-dashboard .custom-table th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 1px solid #dee2e6;
            font-size: 13px;
            white-space: nowrap;
            padding: 0.75rem;
            vertical-align: bottom;
        }

        .vms-dashboard .custom-table td {
            vertical-align: middle;
            font-size: 14px;
            border-bottom: 1px solid #f1f1f1;
            padding: 0.75rem;
        }

    .vms-dashboard .table-hover tbody tr:hover {
        background-color: #fcfcfc;
    }

    /* Badges */
    .vms-dashboard .badge {
        font-weight: 500;
        padding: 0.35em 0.65em;
        font-size: 0.75em;
        border-radius: 4px;
        display: inline-block;
        line-height: 1;
        text-align: center;
        white-space: nowrap;
    }

    /* Utilities */
    .vms-dashboard .fs-12 {
        font-size: 12px !important;
    }

    .vms-dashboard .fs-13 {
        font-size: 13px !important;
    }

    .vms-dashboard .fs-14 {
        font-size: 14px !important;
    }

    .vms-dashboard .fs-18 {
        font-size: 18px !important;
    }

    .vms-dashboard .fs-20 {
        font-size: 20px !important;
    }

    .vms-dashboard .fs-22 {
        font-size: 22px !important;
    }

    .vms-dashboard .progress-sm {
        height: 6px;
        border-radius: 4px;
        overflow: hidden;
        background-color: #e9ecef;
    }

    .vms-dashboard .progress-bar {
        display: flex;
        flex-direction: column;
        justify-content: center;
        overflow: hidden;
        color: #fff;
        text-align: center;
        white-space: nowrap;
        transition: width 0.6s ease;
    }

    .vms-dashboard .border-opacity-25 {
        border-color: rgba(0, 0, 0, 0.1) !important;
    }

    .vms-dashboard .border-4 {
        border-left-width: 4px !important;
    }
</style>


