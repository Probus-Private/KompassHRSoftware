        <div class="kpi-row">

            <div class="kpi-col">
                <div class="md-card kpi-box">
                    <div class="kpi-icon" style="background-color: var(--md-primary);">
                        <i class="fa-solid fa-users-viewfinder"></i>
                    </div>
                    <div class="kpi-content">
                        <div class="kpi-value">@ViewBag.Completed</div>
                        <div class="kpi-label">Emp Evaluated</div>
                    </div>
                </div>
            </div>

            <div class="kpi-col">
                <div class="md-card kpi-box">
                    <div class="kpi-icon" style="background-color: var(--md-warning);">
                        <i class="fa-solid fa-user-clock"></i>
                    </div>
                    <div class="kpi-content">
                        <div class="kpi-value">@ViewBag.NotCompleted</div>
                        <div class="kpi-label">Not Evaluated</div>
                    </div>
                </div>
            </div>

            <div class="kpi-col">
                <div class="md-card kpi-box">
                    <div class="kpi-icon" style="background-color: var(--md-success);">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <div class="kpi-content">
                        <div class="kpi-value">@ViewBag.AvgFinalRating</div>
                        <div class="kpi-label">Avg Final Rating</div>
                    </div>
                </div>
            </div>

            <div class="kpi-col">
                <div class="md-card kpi-box">
                    <div class="kpi-icon" style="background-color: var(--md-info);">
                        <i class="fa-solid fa-bullseye"></i>
                    </div>
                    <div class="kpi-content">
                        <div class="kpi-value">@ViewBag.AvgKraRating</div>
                        <div class="kpi-label">Avg KRA Rating</div>
                    </div>
                </div>
            </div>

            <div class="kpi-col">
                <div class="md-card kpi-box">
                    <div class="kpi-icon" style="background-color: var(--md-accent);">
                        <i class="fa-solid fa-brain"></i>
                    </div>
                    <div class="kpi-content">
                        <div class="kpi-value">@ViewBag.AvgCompetency</div>
                        <div class="kpi-label">Avg Competency</div>
                    </div>
                </div>
            </div>

        </div>


        <!-- 2. Hierarchical Objectives -->
        <div class="md-card" style="padding-bottom:8px;">
            <div class="md-card-title">Company Objectives Alignment</div>

            <div class="accordion md-accordion" id="objectivesAccordion">

                @foreach (var obj in ViewBag.CompanyObjectives)
                {
                    <div class="accordion-item">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed loadTeam"
                                    type="button"
                                    data-id="@obj.Id"
                                    data-origin="Team"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapse_@obj.Id">

                                <span style="flex-grow:1;">
                                    @obj.Name
                                </span>

                                <div class="obj-progress-wrap" onclick="event.stopPropagation();">

                                    <div class="obj-progress">
                                        <div class="progress-bar"
                                             style="width:@obj.ProgressPercentage%; background-color: var(--md-success); height:100%; border-radius:3px;">
                                        </div>
                                    </div>

                                    <span style="font-weight:700;">
                                        @obj.ProgressPercentage%
                                    </span>

                                </div>

                            </button>

                        </h2>

                        <div id="collapse_@obj.Id"
                             class="accordion-collapse collapse"
                             data-bs-parent="#objectivesAccordion">

                            <div class="accordion-body p-0">

                                <table class="md-table">

                                    <thead>
                                        <tr>
                                            <th style="padding-left:24px;">Team Name</th>
                                            <th>Progress</th>
                                            <th>Members</th>
                                        </tr>
                                    </thead>

                                    <tbody id="teamContainer_@obj.Id"></tbody>

                                </table>

                            </div>

                        </div>

                    </div>
                }

            </div>
        </div>



        <div class="row">
            <!-- 3. Goal Status Pie Chart -->
            <div class="col-lg-6 mb-4">
                <div class="md-card h-100 mb-0">
                    <div class="md-card-title">Overall Goal Status</div>
                    <div class="row align-items-center">
                        <div class="col-md-6 mb-3 mb-md-0" style="position:relative; height: 230px;">
                            <canvas id="goalStatusPie"></canvas>
                        </div>
                        <div class="col-md-6">
                            <ul id="goalStatusList" class="list-group list-group-flush" style="font-size: 14px;"></ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. Department Performance Heatmap -->
            <div class="col-lg-6 mb-4">
                <div class="md-card h-100 mb-0">
                    <div class="md-card-title">Department Performance Heatmap</div>

                    <div class="table-responsive" style="max-height:300px; overflow-y:auto;">

                        <table class="table md-table" style="min-width:600px; margin-bottom:0;">
                            <thead style="position:sticky; top:0; background:#fff; z-index:2;">
                                <tr>
                                    <th>Department</th>
                                    <th class="text-center">Goal Completion</th>
                                    <th class="text-center">KRA Avg</th>
                                    <th class="text-center">Competency Avg</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in ViewBag.DeptHeatmap)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.DepartmentName</td>

                                        <td>
                                            <div class="heatmap-cell @(Convert.ToDecimal(item.GoalCompletion) >= 20 ? "hm-high" : Convert.ToDecimal(item.GoalCompletion) >= 60 ? "hm-med" : "hm-low")">
                                                @item.GoalCompletion%
                                            </div>
                                        </td>

                                        <td>
                                            <div class="heatmap-cell @(Convert.ToDecimal(item.KRARating) >= 4 ? "hm-high" : Convert.ToDecimal(item.KRARating) >= 3 ? "hm-med" : "hm-low")">
                                                @item.KRARating
                                            </div>
                                        </td>

                                        <td>
                                            <div class="heatmap-cell @(Convert.ToDecimal(item.CompetencyRating) >= 4 ? "hm-high" : Convert.ToDecimal(item.CompetencyRating) >= 3 ? "hm-med" : "hm-low")">
                                                @item.CompetencyRating
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>

                    </div>
                </div>
            </div>        </div>

        <!-- 5. Full Bar Chart -->
        <div class="md-card">
            <div class="md-card-title">Goal Status by Department</div>
            <div style="height: 300px; position:relative;">
                <canvas id="goalStatusDeptBar"></canvas>
            </div>
        </div>

        <!-- 6. Employee Lists -->
        <div class="row">
            <!-- Top Performers -->
            <div class="col-lg-6 mb-4">
                <div class="md-card h-100 mb-0">
                    <div class="md-card-title">Top Performers <i class="fa-solid fa-trophy text-warning"></i></div>
                    <ul class="list-unstyled p-0 m-0">
                        @*<li class="d-flex align-items-start p-3 mb-2 rounded border border-success border-opacity-25 bg-success bg-opacity-10">
                            <img src="../assets/img/avatar-02.jpg" alt="User" class="rounded-circle shadow-sm me-3"
                                 style="width: 42px; height: 42px; object-fit: cover;"
                                 onerror="this.src='https://ui-avatars.com/api/?name=Alice+Wonder&background=e8f5e9&color=2e7d32'">
                            <div class="flex-grow-1">
                                <div class="fw-semibold text-dark mb-0 fs-6">Alice Wonder</div>
                                <div class="text-secondary small mb-1">HR & Admin</div>
                            </div>
                            <div class="text-end">
                                <div style="color: #ff9800; font-size: 11px; margin-bottom: 2px;">
                                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                                </div>
                                <div class="badge rounded-pill bg-success text-white py-1 px-2 fw-bold">4.9 / 5.0</div>
                            </div>
                        </li>*@
                        @foreach (var item in ViewBag.HighPerformers)
                        {
                            <li class="d-flex align-items-start p-3 mb-2 rounded border border-success border-opacity-25 bg-success bg-opacity-10">
                                <img src="https://ui-avatars.com/api/?name=@item.EmployeeName&background=e8f5e9&color=2e7d32"
                                     class="rounded-circle shadow-sm me-3"
                                     style="width:42px;height:42px;object-fit:cover;">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold text-dark fs-6">@item.EmployeeName</div>
                                    <div class="text-secondary small">@item.DepartmentName</div>
                                </div>
                                <div class="text-end">
                                    <div class="badge rounded-pill bg-success text-white py-1 px-2 fw-bold">
                                        @item.PerformanceScore %
                                    </div>
                                </div>
                            </li>
                        }
                       
                    </ul>
                </div>
            </div>

            <!-- Low Performers -->
            <div class="col-lg-6 mb-4">
                <div class="md-card h-100 mb-0">
                    <div class="md-card-title">
                        Low Performers <i class="fa-solid fa-arrow-trend-down text-danger"></i>
                    </div>
                    <ul class="list-unstyled p-0 m-0">
                        @foreach (var item in ViewBag.LowPerformers)
                        {
                            <li class="d-flex align-items-start p-3 mb-2 rounded border border-danger border-opacity-25 bg-danger bg-opacity-10">

