                                     class="rounded-circle shadow-sm me-3"
                                     style="width:42px;height:42px;object-fit:cover;">

                                <div class="flex-grow-1">
                                    <div class="fw-semibold text-dark fs-6">@item.EmployeeName</div>
                                    <div class="text-secondary small">@item.DepartmentName</div>
                                </div>

                                <div class="badge rounded-pill bg-danger text-white py-1 px-2 fw-bold">
                                    @item.PerformanceScore %
                                </div>

                            </li>
                        }
                        @*<li class="d-flex align-items-start p-3 mb-2 rounded border border-danger border-opacity-25 bg-danger bg-opacity-10">
                            <img src="../assets/img/avatar-05.jpg" alt="User" class="rounded-circle shadow-sm me-3"
                                 style="width: 42px; height: 42px; object-fit: cover;"
                                 onerror="this.src='https://ui-avatars.com/api/?name=Dave+Smith&background=ffebee&color=c62828'">
                            <div class="flex-grow-1">
                                <div class="fw-semibold text-dark mb-0 fs-6">Dave Smith</div>
                                <div class="text-secondary small mb-1">Sales</div>
                                <ul class="improvement-list">
                                    <li>Improvement Needs: Client Relations</li>
                                </ul>
                            </div>
                            <div class="badge rounded-pill bg-danger text-white py-1 px-2 fw-bold">2.1 / 5.0</div>
                        </li>
                        <li class="d-flex align-items-start p-3 mb-2 rounded border border-danger border-opacity-25 bg-danger bg-opacity-10">
                            <img src="../assets/img/avatar-06.jpg" alt="User" class="rounded-circle shadow-sm me-3"
                                 style="width: 42px; height: 42px; object-fit: cover;"
                                 onerror="this.src='https://ui-avatars.com/api/?name=Eve+Adams&background=ffebee&color=c62828'">
                            <div class="flex-grow-1">
                                <div class="fw-semibold text-dark mb-0 fs-6">Eve Adams</div>
                                <div class="text-secondary small mb-1">Sales</div>
                                <ul class="improvement-list">
                                    <li>Improvement Needs: Pipeline Management</li>
                                </ul>
                            </div>
                            <div class="badge rounded-pill bg-danger text-white py-1 px-2 fw-bold">2.3 / 5.0</div>
                        </li>
                        <li class="d-flex align-items-start p-3 mb-0 rounded border border-danger border-opacity-25 bg-danger bg-opacity-10">
                            <img src="../assets/img/avatar-07.jpg" alt="User" class="rounded-circle shadow-sm me-3"
                                 style="width: 42px; height: 42px; object-fit: cover;"
                                 onerror="this.src='https://ui-avatars.com/api/?name=Frank+Castle&background=ffebee&color=c62828'">
                            <div class="flex-grow-1">
                                <div class="fw-semibold text-dark mb-0 fs-6">Frank Castle</div>
                                <div class="text-secondary small mb-1">Engineering</div>
