                                </ul>
                            </div>
                            <div class="badge rounded-pill bg-danger text-white py-1 px-2 fw-bold">2.5 / 5.0</div>
                        </li>*@
                    </ul>
                </div>
            </div>
        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

    var rawData = @Html.Raw(Json.Encode(ViewBag.GoalStatus));

    var goalData = [];

    rawData.forEach(function (rowArr) {

        let item = {};

        rowArr.forEach(function (x) {
            item[x.Key] = x.Value;
        });

        goalData.push(item);
    });

    var labels = goalData.map(x => x.GoalStatus);
    var values = goalData.map(x => x.Percentage);

    var pieCtx = document.getElementById('goalStatusPie');

    if (pieCtx) {
        new Chart(pieCtx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: [
                        '#9e9e9e',
                        '#ff9800',
                        '#3f51b5',
                        '#f44336',
                        '#4caf50'
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    }

    var colorMap = {
        "Not Started": "#9e9e9e",
        "At Risk": "#ff9800",
        "On Track": "#3f51b5",
        "In Trouble": "#f44336",
        "Completed": "#4caf50"
    };

    var listHtml = "";

    goalData.forEach(function (item) {

        listHtml += `
    <li class="list-group-item d-flex justify-content-between align-items-center"
        style="border-bottom:1px solid var(--md-border); padding:12px 0; background:transparent;">

        <div>
            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;
            background-color:${colorMap[item.GoalStatus]};margin-right:8px;"></span>
            ${item.GoalStatus}
        </div>

        <span style="font-weight:600;">${item.Percentage}%</span>

    </li>`;
    });

    document.getElementById("goalStatusList").innerHTML = listHtml;
    var rawDeptData = @Html.Raw(Json.Encode(ViewBag.DeptGoalStatus));

    var deptData = [];

    rawDeptData.forEach(function (rowArr) {

        let item = {};

        rowArr.forEach(function (x) {
            item[x.Key] = x.Value;
        });

        deptData.push(item);
    });

    var deptLabels = deptData.map(x => x.DepartmentName);
    var completedData = deptData.map(x => x.Completed);
    var inProgressData = deptData.map(x => x.InProgress);
    var pendingData = deptData.map(x => x.Pending);           
    var barCtx = document.getElementById('goalStatusDeptBar');

    if (barCtx) {

        new Chart(barCtx, {

            type: 'bar',

            data: {

                labels: deptLabels,

                datasets: [

                    {
                        label: 'Completed',
                        data: completedData,
                        backgroundColor: '#10B981'
                    },

                    {
                        label: 'In Progress',
                        data: inProgressData,
                        backgroundColor: '#6366F1'
                    },

                    {
                        label: 'Pending',
                        data: pendingData,
                        backgroundColor: '#CBD5E1'
                    }

                ]
            },

            options: {

                responsive: true,
                maintainAspectRatio: false,

                plugins: {
                    legend: {
                        position: 'top'
                    }
                },

                scales: {
                    x: {
                        stacked: true,
                        grid: { display: false }
                    },
                    y: {
                        stacked: true,
                        beginAtZero: true
                    }
                }

            }

        });

    }        });


$(document).on("click", ".loadTeam", function () {
    debugger
    var parentId = $(this).data("id");
    var origin = $(this).data("origin");

    var container = "#teamContainer_" + parentId;

    if ($(container).html().trim() != "") return;

    $.ajax({
        url: '@Url.Action("GetObjectiveChildren","ESS_PMSDashboard")',
        type: "GET",
        data: {
            origin: origin,
            parentId: parentId
        },

        success: function (data) {

            var html = "";

            data.forEach(function (rowArr) {

                let item = {};

                rowArr.forEach(function (x) {
                    item[x.Key] = x.Value;
                });

                html += `
        <tr>

            <td style="padding-left:24px;font-weight:500;">
                ${item.Name}
            </td>

            <td>
                <div class="d-flex align-items-center">

                    <div class="obj-progress w-50 me-2">
                        <div class="progress-bar"
                             style="width:${item.ProgressPercentage}%;">
                        </div>
                    </div>

                    <span>${item.ProgressPercentage}%</span>

                </div>
            </td>

            <td>
                <span class="badge bg-light text-dark border">
                    ${item.ChildCount}
                </span>
            </td>

        </tr>
        `;
            });

            $(container).html(html);
        }
    });

});
        function getHeatClass(value) {

            if (value >= 85) return "hm-high";
            if (value >= 60) return "hm-med";
            return "hm-low";
        }
</script>

