<!-- #modal-dialog -->
<div class="modal fade" id="Job-Application" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Job Application</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger" data-bs-dismiss="modal"
                       aria-hidden="true">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->

                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <form action="/Dashboards/CurrentOpening/SaveUpdate" id="FormCurrentOpening" method="post" enctype="multipart/form-data">

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Candidate Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.CandidateName, new { @class = "form-control", name = "CandidateName", type = "text", id = "txtCandidateName", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Gender
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownListFor(model => model.Gender, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Male", Value = "Male"},
                                                    new SelectListItem { Text = "Female", Value = "Female"},
                                                    new SelectListItem { Text ="Other",Value="Other"}
                                                }, "--Select--", new { id = "ddlGender", @class = "form-select", autocomplete = "off", name = "Gender" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Email
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.EmailId, new { @class = "form-control", name = "EmailId", type = "text", id = "txtEmailId", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Mobile No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.MobileNo, new { @class = "form-control", name = "MobileNo", type = "text",maxlength="10", onkeypress = "return event.charCode >=48", inputmode="numeric", id = "txtMobileNo", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Experience
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.TotalExperience, new { @class = "form-control", name = "TotalExperience", type = "number", onkeypress = "return event.charCode >=48", id = "txtTotalExperience", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                CTC
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.CTC, new { @class = "form-control", name = "CTC", type = "number", onkeypress = " return numbervalidate(event)", id = "txtCTC", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current City
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.CurrentCity, new { @class = "form-control", name = "CurrentCity", type = "text", id = "txtCurrentCity", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Current Working
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownListFor(model => model.CurrentWorking, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Yes", Value = "Permannent"},
                                                    new SelectListItem { Text = "No", Value = "Temparary"},
                                                }, "--Select--", new { id = "ddlCurrentWorking", @class = "form-select", autocomplete = "off", name = "CurrentWorking" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Resume
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                <input type="file" name="Image" value="" class="form-control" id="fileupload" />

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                CAPCHA
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">

                                    <button type="submit" id="SubmitBtn" class="btn btn-primary btn-sm">
                                        <i class="fa-solid fa-floppy-disk"> </i> Submit
                                    </button>
                                    <a href="javascript:;" class="btn btn-white" data-bs-dismiss="modal">Close</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

