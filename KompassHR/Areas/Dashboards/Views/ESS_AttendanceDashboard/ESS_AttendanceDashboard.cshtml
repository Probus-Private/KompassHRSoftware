<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highcharts/12.4.0/css/highcharts.css" />


<!-- Feather Icon JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/feather-icons/4.29.2/feather.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.35.0/tabler-icons.min.css" integrity="sha512-gzw5zNP2TRq+DKyAqZfDclaTG4dOrGJrwob2Fc8xwcJPDPVij0HowLIMZ8c1NefFM0OZZYUUUNoPfcoI5jqudw==" crossorigin="anonymous" referrerpolicy="no-referrer" />


<style>
    body {
        font-family: "Roboto", sans-serif;
        font-size: 14px;
        line-height: 1.5;
        background-color: #F8F9FA;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .page-wrapper {
        -webkit-transition: all 0.5s ease;
        -ms-transition: all 0.5s ease;
        transition: all 0.5s ease;
        margin: 0 0 0 252px;
        padding: 50px 0 0;
        position: relative;
        left: 0;
        -webkit-transition: all 0.2s ease;
        -ms-transition: all 0.2s ease;
        transition: all 0.2s ease;
    }

        .page-wrapper .content {
            padding: 24px;
            padding-bottom: 0;
            min-height: calc(100vh - 105px);
        }
</style>

<style>
    .day-active-item {
        background: #F8F9FA;
        border: 1px solid #ededed;
        padding: 4px;
        border-radius: 100px;
    }

        .day-active-item button.active {
            background: #212529;
            color: #FFF;
        }

    .attendance-db {
        background-color: #f8f9fa;
        color: #212529;
    }

        .attendance-db .btn .btn-icon {
            width: 1.5rem;
            height: 1.5rem;
        }


        .attendance-db h1,
        .attendance-db h2,
        .attendance-db h3,
        .attendance-db h4,
        .attendance-db h5,
        .attendance-db h6 {
            color: #1e293b;
            font-weight: 700;
        }

        /* Unify Card Styles */
        .attendance-db .card,
        .attendance-db .overview-card,
        .attendance-db .custom-card,
        .attendance-db .attendance-trends-card,
        .attendance-db .attendance-status-card {
            background-color: #ffffff;
            border: 1px solid #eef0f3;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        }

        /* Fix Image/Avatar Sizes uniformly */
        .attendance-db .avatar-group {
            display: flex;
            align-items: center;
        }

            .attendance-db .avatar-group img,
            .attendance-db .avatar-group .avatar-more {
                width: 35px;
                height: 35px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid #fff;
                margin-left: -10px;
                z-index: 1;
            }

                .attendance-db .avatar-group img:first-child {
                    margin-left: 0;
                }

            .attendance-db .avatar-group .avatar-more {
                background-color: #f3f4f6;
                color: #1d2a3a;
                display: flex;
                justify-content: center;
                align-items: center;
                font-size: 12px;
                font-weight: 600;
            }

        .attendance-db .late-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px dashed #eef0f3;
        }

            .attendance-db .late-item:last-child {
                border-bottom: none;
            }

        .attendance-db .emp-info {
            display: flex;
            align-items: center;
            gap: 12px;
            width: 45%;
        }

            .attendance-db .emp-info img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

        .attendance-db .check-time {
            width: 25%;
            font-size: 13px;
            color: #6b7280;
        }

        .attendance-db .late-bars {
            display: flex;
            gap: 4px;
            width: 30%;
            justify-content: flex-end;
        }

            .attendance-db .late-bars span {
                width: 4px;
                height: 16px;
                border-radius: 2px;
                background-color: #fceceb;
            }

                .attendance-db .late-bars span.active {
                    background-color: #f26522;
                }

    .avatar i {
        font-size: 20px;
    }
    .btn-outline {
    
        border:1px solid;
    }
</style>

    <!-- Page Wrapper -->
<div id="content" class="app-content">
