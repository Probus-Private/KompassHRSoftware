
@{
    ViewBag.Title = "ESS_AttendanceDashboard";
    Layout = "~/Views/Shared/_LayoutPageSmartHR.cshtml";
}

<!-- Highcharts -->
<script src="https://cdn.jsdelivr.net/npm/highcharts@12.5.0/highcharts.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highcharts/12.4.0/css/highcharts.css" />

<script>
    $(document).ready(function () {

        $('.nav-link').removeClass('active');
        $('.tab-pane').removeClass('show active');

        $('#Menu-tab').addClass('active');
        $('#Menu-tab-pane').addClass('show active');

        $('#DashboardMenulink').addClass('active');
    });
</script>

<style>
    .day-active-item {
        background: #F8F9FA;
        border: 1px solid #ededed;
        padding: 4px;
        border-radius: 100px;
    }

        .day-active-item button.active {
            background: #212529;
            color: #FFF;
        }



    /* Fix Image/Avatar Sizes uniformly */
    .attendance-db .avatar-group {
        display: flex;
        align-items: center;
    }

        .attendance-db .avatar-group img,
        .attendance-db .avatar-group .avatar-more {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #fff;
            margin-left: -10px;
            z-index: 1;
        }

            .attendance-db .avatar-group img:first-child {
                margin-left: 0;
            }

        .attendance-db .avatar-group .avatar-more {
            background-color: #f3f4f6;
            color: #1d2a3a;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 12px;
            font-weight: 600;
        }

    .attendance-db .late-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px dashed #eef0f3;
    }

        .attendance-db .late-item:last-child {
            border-bottom: none;
        }

    .attendance-db .emp-info {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 45%;
    }

        .attendance-db .emp-info img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }

    .attendance-db .check-time {
        width: 25%;
        font-size: 13px;
        color: #6b7280;
    }

    .attendance-db .late-bars {
        display: flex;
        gap: 4px;
        width: 30%;
        justify-content: flex-end;
    }

        .attendance-db .late-bars span {
            width: 4px;
            height: 16px;
            border-radius: 2px;
            background-color: #fceceb;
        }

            .attendance-db .late-bars span.active {
                background-color: #f26522;
            }

    .avatar i {
        font-size: 20px;
    }

    .btn-outline {
        border: 1px solid;
    }
</style>


