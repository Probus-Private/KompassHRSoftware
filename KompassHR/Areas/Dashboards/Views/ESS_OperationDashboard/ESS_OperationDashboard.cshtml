<style>
    /* ==========================================
                     OPERATION DASHBOARD INTERNAL STYLES
                     ========================================== */
    .operation-dashboard .card {
        border-radius: 10px;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        margin-bottom: 24px;
        background-color: #fff;
        display: flex;
        flex-direction: column;
        word-wrap: break-word;
        height: 100%;
    }

    .operation-dashboard .card-header {
        background-color: transparent;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid rgba(0, 0, 0, .05);
    }

    .operation-dashboard .card-title {
        font-weight: 600;
        font-size: 16px;
        color: #1D2A3A;
    }

    .operation-dashboard .card-body {
        flex: 1 1 auto;
        padding: 1.25rem;
    }

    .operation-dashboard .avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        border-radius: 50%;
        object-fit: cover;
    }

    .operation-dashboard .avatar-sm {
        width: 32px;
        height: 32px;
        font-size: 13px;
    }

    .operation-dashboard .avatar-md {
        width: 48px;
        height: 48px;
        font-size: 20px;
    }

    /* Transparent Backgrounds & Text Colors */
    .operation-dashboard .bg-primary-transparent {
        background-color: rgba(242, 101, 34, 0.1) !important;
        color: #F26522 !important;
    }

    .operation-dashboard .bg-success-transparent {
        background-color: rgba(40, 167, 69, 0.1) !important;
        color: #28a745 !important;
    }

    .operation-dashboard .bg-info-transparent {
        background-color: rgba(23, 162, 184, 0.1) !important;
        color: #17a2b8 !important;
    }

    .operation-dashboard .bg-warning-transparent {
        background-color: rgba(255, 193, 7, 0.1) !important;
        color: #ffc107 !important;
    }

    .operation-dashboard .bg-danger-transparent {
        background-color: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
    }

    .operation-dashboard .bg-secondary-transparent {
        background-color: rgba(108, 117, 125, 0.1) !important;
        color: #6c757d !important;
    }

    .operation-dashboard .bg-purple-transparent {
        background-color: rgba(111, 66, 193, 0.1) !important;
        color: #6f42c1 !important;
    }

    .operation-dashboard .bg-teal-transparent {
        background-color: rgba(32, 201, 151, 0.1) !important;
        color: #20c997 !important;
    }

    .operation-dashboard .text-primary {
        color: #F26522 !important;
    }

    .operation-dashboard .text-success {
        color: #28a745 !important;
    }

    .operation-dashboard .text-info {
        color: #17a2b8 !important;
    }

    .operation-dashboard .text-warning {
        color: #ffc107 !important;
    }

    .operation-dashboard .text-danger {
        color: #dc3545 !important;
    }

    .operation-dashboard .text-secondary {
        color: #6c757d !important;
    }

    .operation-dashboard .border-primary {
        border-color: #F26522 !important;
    }

    .operation-dashboard .border-success {
        border-color: #28a745 !important;
    }

    .operation-dashboard .border-info {
        border-color: #17a2b8 !important;
    }

    .operation-dashboard .border-warning {
        border-color: #ffc107 !important;
    }

    .operation-dashboard .border-danger {
        border-color: #dc3545 !important;
    }

    .operation-dashboard .border-secondary {
        border-color: #6c757d !important;
    }

    /* Tables */
    .operation-dashboard .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .operation-dashboard .custom-table {
        width: 100%;
        margin-bottom: 1rem;
        color: #212529;
    }

        .operation-dashboard .custom-table th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 1px solid #dee2e6;
            font-size: 13px;
            white-space: nowrap;
            padding: 0.75rem;
            vertical-align: bottom;
        }

        .operation-dashboard .custom-table td {
            vertical-align: middle;
            font-size: 14px;
            border-bottom: 1px solid #f1f1f1;
            padding: 0.75rem;
        }

    .operation-dashboard .table-hover tbody tr:hover {
        background-color: #fcfcfc;
    }

    /* Badges */
    .operation-dashboard .badge {
        font-weight: 500;
        padding: 0.35em 0.65em;
        font-size: 0.75em;
        border-radius: 4px;
        display: inline-block;
        line-height: 1;
        text-align: center;
        white-space: nowrap;
    }

    /* Utilities */
    .operation-dashboard .fs-12 {
        font-size: 12px !important;
    }

    .operation-dashboard .fs-13 {
        font-size: 13px !important;
    }

    .operation-dashboard .fs-14 {
        font-size: 14px !important;
    }

    .operation-dashboard .fs-18 {
        font-size: 18px !important;
    }

    .operation-dashboard .fs-20 {
        font-size: 20px !important;
    }

    .operation-dashboard .fs-22 {
        font-size: 22px !important;
    }

    .operation-dashboard .border-opacity-25 {
        border-color: rgba(0, 0, 0, 0.1) !important;
    }

    .operation-dashboard .border-4 {
        border-left-width: 4px !important;
    }

    /* Feed */
    .activity-feed {
        list-style: none;
        padding: 0;
        margin: 0;
        position: relative;
    }

        .activity-feed::before {
            content: "";
            position: absolute;
            left: 15px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e9ecef;
        }

        .activity-feed li {
            position: relative;
            padding-left: 45px;
            margin-bottom: 20px;
        }

            .activity-feed li:last-child {
                margin-bottom: 0;
            }

    .activity-feed-icon {
        position: absolute;
        left: 0;
        top: 0;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        z-index: 1;
        border: 2px solid #fff;
    }
</style>





