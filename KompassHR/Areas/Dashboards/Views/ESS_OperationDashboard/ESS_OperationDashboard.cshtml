                    // Highcharts Initialization Script for Operations Dashboard
                    document.addEventListener('DOMContentLoaded', function () {
                        if (typeof Highcharts !== 'undefined') {
                            Highcharts.setOptions({
                                colors: ['#28a745', '#ffc107', '#dc3545', '#17a2b8', '#F26522', '#1D2A3A', '#6f42c1', '#20c997'],
                                chart: { style: { fontFamily: 'Roboto, sans-serif' } },
                                title: { text: null },
                                credits: { enabled: false }
                            });

                            // 1. Attendance Status Chart (Donut)
                            Highcharts.chart('attendanceStatusChart', {
                                chart: { type: 'pie' },
                                tooltip: { pointFormat: '{series.name}: <b>{point.y}</b> ({point.percentage:.1f}%)' },
                                plotOptions: {
                                    pie: {
                                        innerSize: '60%', allowPointSelect: true, cursor: 'pointer',
                                        dataLabels: { enabled: true, format: '<b>{point.name}</b>' }
                                    }
                                },
                                series: [{
                                    name: 'Employees',
                                    colorByPoint: true,
                                    data: [
                                        { name: 'Present', y: 412, color: '#28a745' },
                                        { name: 'On Leave', y: 15, color: '#ffc107' },
                                        { name: 'Absent', y: 8, color: '#dc3545' },
                                        { name: 'WFH', y: 15, color: '#17a2b8' }
                                    ]
                                }]
                            });

                            // 2. Leave Type Distribution (Pie)
                            Highcharts.chart('leaveTypeDistributionChart', {
                                chart: { type: 'pie' },
                                tooltip: { pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>' },
                                plotOptions: {
                                    pie: {
                                        allowPointSelect: true, cursor: 'pointer',
                                        dataLabels: { enabled: true, format: '<b>{point.name}</b>: {point.y}' }
                                    }
                                },
                                series: [{
                                    name: 'Leaves',
                                    colorByPoint: true,
                                    data: [
                                        { name: 'Casual Leave', y: 6, color: '#F26522' },
                                        { name: 'Sick Leave', y: 5, color: '#dc3545' },
                                        { name: 'Earned Leave', y: 3, color: '#28a745' },
                                        { name: 'Unpaid Leave', y: 1, color: '#6c757d' }
                                    ]
                                }]
                            });

                            // 3. Department Employee Chart (Bar Chart)
                            Highcharts.chart('departmentEmployeeChart', {
                                chart: { type: 'bar' },
                                xAxis: { categories: ['Development', 'QA', 'Support', 'Design', 'HR'], title: { text: null } },
                                yAxis: { min: 0, title: { text: 'Employees', align: 'high' } },
                                tooltip: { valueSuffix: ' employees' },
                                plotOptions: { bar: { dataLabels: { enabled: true } } },
                                series: [{ name: 'Headcount', data: [25, 12, 10, 6, 4], color: '#1D2A3A' }]
                            });

                            // 4. Ticket Status Chart (Column Chart)
                            Highcharts.chart('ticketStatusChart', {
                                chart: { type: 'column' },
                                xAxis: { categories: ['IT Support', 'HR Requests', 'Facilities', 'System Access'] },
                                yAxis: { min: 0, title: { text: 'Ticket Count' } },
                                tooltip: { shared: true },
