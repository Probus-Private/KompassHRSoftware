                                    { name: 'Open', data: [15, 8, 5, 6], color: '#ffc107' },
                                    { name: 'Resolved', data: [40, 20, 10, 9], color: '#28a745' }
                                ]
                            });

                            // 5. Hiring / Joining Trend Chart (Line Chart over months)
                            Highcharts.chart('hiringJoiningTrendChart', {
                                chart: { type: 'spline' },
                                xAxis: { categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'] },
