
@{
    ViewBag.Title = "ESS_Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f5f5f5;
    }

    .container {
        display: grid;
        grid-template-columns: repeat(4, 1fr); /* Default: 3 columns */
        gap: 20px;
        padding: 40px;
        max-width: 1200px;
        margin: auto;
    }

    .card {
        background-color: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        text-align: center;
        transition: transform 0.2s;
        cursor: pointer;
        text-decoration: none !important;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            width: 100%;
            height: 140px;
            /*object-fit: cover;*/
        }

        .card h3 {
            margin: 0;
            padding: 12px;
            font-weight: 500;
            color: #333;
            font-size: 16px;
        }

    /* Responsive for mobile */
    @@media (max-width: 768px) {
        .container {
            grid-template-columns: 1fr; /* Show only 1 column on mobile */
        }
    }
</style>

<!-- ================== Icon Css ================== -->
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<link href="~/assets/MyCSS/MenuImages.css" rel="stylesheet" />
<link href="~/Content/Site.css" rel="stylesheet" />
