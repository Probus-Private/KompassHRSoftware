
@{
    ViewBag.Title = "ESS_Dashboard";
    Layout = "~/Views/Shared/_LayoutPageSmartHR.cshtml";
}

<script>
 $(document).ready(function () {
  
        $('.nav-link').removeClass('active');
        $('.tab-pane').removeClass('show active');


        $('#Menu-tab').addClass('active');
        $('#Menu-tab-pane').addClass('show active');

        $('#DashboardMenulink').addClass('active');
    });
</script>

<style>
        .container {
            display: grid;
            grid-template-columns: repeat(4, 1fr); /* Default: 3 columns */
            gap: 20px;
            padding: 40px;
            max-width: 1200px;
            margin: auto;
        }
        .card {
        display: block;
        border-radius: 12px;
        background: #fff;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    /* Image styling */
    .card img {
                   width: 100%;
                height: 140px;
                object-fit: cover;
        transition: transform 0.3s ease;
    }

    /* Title */
    .card h3 {
        margin: 15px 8px;
        font-size: 14px;
        color: #333; font-weight:500;
        transition: color 0.3s ease;
    }

    /* Hover effect */
    .card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 12px 25px rgba(0, 0, 0, 0.2);
           background: linear-gradient(135deg, #fff9f8, #fff6ee);
    }
    /* Image zoom on hover */
    .card:hover img {
        transform: scale(1.1);
    }

    /* Text color change */
    .card:hover h3 {
        color: var(--primary-color);
    }

        /* Responsive for mobile */
        @@media (max-width: 768px) {
            .container {
                grid-template-columns: 1fr; /* Show only 1 column on mobile */
            }
        }
</style>

<div id="content" class="content">
    <!-- Breadcrumb -->
    <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
        <div class="my-auto mb-2">
            <h2 class="mb-1 fs-18">All Dashboard Menu</h2>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="index.html"><i class="ti ti-smart-home"></i></a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })" class="fs-14"> Dashboard </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">All Dashboard</li>
                </ol>
            </nav>
        </div>
    </div>
    <!-- /Breadcrumb -->

    <div class="row">

        @foreach (var item in ViewBag.GetUserMenuList)
            {<div class="col-xl-3 col-lg-4 col-md-4">
            <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" class="card">
                <img src="~/assets/MenuImages/@item.Icon" alt="@item.ScreenDisplayMenuName" />
                <h3 class="text-center">@item.ScreenDisplayMenuName</h3>
            </a>
        </div>
        }
    </div>
</div>