<style>
    /* ==========================================
                     LEAVE DASHBOARD INTERNAL STYLES
                     ========================================== */


    .leave-dashboard .avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        border-radius: 50%;
        object-fit: cover;
    }

    .leave-dashboard .avatar-sm {
        width: 32px;
        height: 32px;
        font-size: 13px;
    }

    .leave-dashboard .avatar-md {
        width: 48px;
        height: 48px;
        font-size: 20px;
    }

    /* Transparent Backgrounds & Text Colors */
    .leave-dashboard .bg-primary-transparent {
        background-color: rgba(242, 101, 34, 0.1) !important;
        color: #F26522 !important;
    }

    .leave-dashboard .bg-success-transparent {
        background-color: rgba(40, 167, 69, 0.1) !important;
        color: #28a745 !important;
    }

    .leave-dashboard .bg-info-transparent {
        background-color: rgba(23, 162, 184, 0.1) !important;
        color: #17a2b8 !important;
    }

    .leave-dashboard .bg-warning-transparent {
        background-color: rgba(255, 193, 7, 0.1) !important;
        color: #ffc107 !important;
    }

    .leave-dashboard .bg-danger-transparent {
        background-color: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
    }

    .leave-dashboard .bg-secondary-transparent {
        background-color: rgba(108, 117, 125, 0.1) !important;
        color: #6c757d !important;
    }

    .leave-dashboard .text-primary {
        color: #F26522 !important;
    }

    .leave-dashboard .text-success {
        color: #28a745 !important;
    }

    .leave-dashboard .text-info {
        color: #17a2b8 !important;
    }

    .leave-dashboard .text-warning {
        color: #ffc107 !important;
    }

    .leave-dashboard .text-danger {
        color: #dc3545 !important;
    }

    .leave-dashboard .border-warning {
        border-color: #ffc107 !important;
    }

    .leave-dashboard .border-danger {
        border-color: #dc3545 !important;
    }

    .leave-dashboard .border-info {
        border-color: #17a2b8 !important;
    }

    /* Tables */
    .leave-dashboard .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .leave-dashboard .custom-table {
        width: 100%;
        margin-bottom: 1rem;
        color: #212529;
    }

        .leave-dashboard .custom-table th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 1px solid #dee2e6;
            font-size: 13px;
            white-space: nowrap;
            padding: 0.75rem;
            vertical-align: bottom;
        }

        .leave-dashboard .custom-table td {
            vertical-align: middle;
            font-size: 14px;
            border-bottom: 1px solid #f1f1f1;
            padding: 0.75rem;
        }

    .leave-dashboard .table-hover tbody tr:hover {
        background-color: #fcfcfc;
    }

    /* Badges */
    .leave-dashboard .badge {
        font-weight: 500;
        padding: 0.35em 0.65em;
        font-size: 0.75em;
        border-radius: 4px;
        display: inline-block;
        line-height: 1;
        text-align: center;
        white-space: nowrap;
    }

    /* Utilities */
    .leave-dashboard .fs-12 {
        font-size: 12px !important;
    }

    .leave-dashboard .fs-13 {
        font-size: 13px !important;
    }

    .leave-dashboard .fs-14 {
        font-size: 14px !important;
    }

    .leave-dashboard .fs-20 {
        font-size: 20px !important;
    }

    .leave-dashboard .fs-22 {
        font-size: 22px !important;
    }

