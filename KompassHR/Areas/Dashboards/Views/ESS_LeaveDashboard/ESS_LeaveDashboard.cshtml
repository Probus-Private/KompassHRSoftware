        border-color: rgba(0, 0, 0, 0.1) !important;
    }

    .leave-dashboard .border-4 {
        border-left-width: 4px !important;
    }

    .action-icons .btn:hover i {
        color: #fff !important;
    }

    .action-icons .approve {
        color: #28a745;
    }

    .action-icons .reject {
        color: #dc3545;
    }

    .action-icons .view {
        color: #17a2b8;
    }
