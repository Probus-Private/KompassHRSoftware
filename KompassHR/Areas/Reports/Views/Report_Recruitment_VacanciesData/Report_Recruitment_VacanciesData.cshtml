                                                @*@Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", id = "txtToDate", type = "date", name = "ToDate" })*@
                                                @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", id = "txtToDate", type = "month", name = "ToDate" })

                                             </div>

                                        </div>
                                    </div>
                                </div>
