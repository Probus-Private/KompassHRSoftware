                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlDepartmentId").select2();
        $("#ddlDesignationId").select2();
        var FD = document.getElementById("txtFromDate").value;
        var TD = document.getElementById("txtToDate").value;
        $('title').html("Vacancies Data");
        var CheckEmptyDate = document.getElementById('txtFromDate').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtFromDate').value = SetTodaysDate;
            document.getElementById('txtToDate').value = SetTodaysDate;
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

     $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Report_Attendance_RptMenu")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data == false) {
                        $("#ddlBranchId").find("option").remove();
                        $("#ddlBranchId").append("<option value=''>All </option>");
                    }
                    else {
                        if (data != null) {
                            $("#ddlBranchId").append("<option value=''>All </option>");
                            $.each(Branch, function (i, p) {
                                $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }

                    }
                }
            })
        });
    });// Ready Function End
</script>

<script>
    function downloadExcelFile() {
        $(".Userloaderbg").css("display", "flex");
        var DepartmentId = encodeURIComponent($("#ddlDepartmentId").val());
        var DesignationId = encodeURIComponent($("#ddlDesignationId").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        var CmpId = encodeURIComponent($("#ddlCmpId").val());
     //   var FromDate = encodeURIComponent($("#txtFromDate").val());
     //   var ToDate=encodeURIComponent($("#txtToDate").val());

        var startMonth = $("#txtFromDate").val();  
        var endMonth = $("#txtToDate").val();     

        if (!startMonth || !endMonth) {
            Swal.fire({ icon: 'error', text: 'Please select both Start and End Month.' });
            $(".Userloaderbg").hide();
            return false;
        }

        // Convert to yyyy-MM-dd
        function toYYYYMMDD(day, ym) {
            if (!ym || ym.indexOf("-") === -1) return "";
            const parts = ym.split("-");
            if (parts.length !== 2) return "";

            const year = parts[0];
            const month = parts[1];

            return `${year}-${month}-${day}`;
        }

        function lastDayOfMonth(ym) {
            if (!ym || ym.indexOf("-") === -1) return 0;

            const parts = ym.split("-");
            if (parts.length !== 2) return 0;

            const year = parseInt(parts[0]);
            const month = parseInt(parts[1]);

            return new Date(year, month, 0).getDate();
        }

        let FromDate, ToDate;

        if (startMonth === endMonth) {
            let last = lastDayOfMonth(startMonth);
            FromDate = toYYYYMMDD("01", startMonth);
            ToDate = toYYYYMMDD(last, startMonth);
        } else {
            let lastEndMonth = lastDayOfMonth(endMonth);
            FromDate = toYYYYMMDD("01", startMonth);
            ToDate = toYYYYMMDD(lastEndMonth, endMonth);
        }

        FromDate = encodeURIComponent(FromDate);
        ToDate = encodeURIComponent(ToDate);




        var url = `@Url.Action("DownloadExcelFile", "Report_Recruitment_VacanciesData")?BranchId=${BranchId}&CmpId=${CmpId}&DesignationId=${DesignationId}&FromDate=${FromDate}&ToDate=${ToDate}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'VacanciesDataReport.xlsx';
                anchorElement.click();
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }
</script>

