<script>
function downloadExcelFile() {
    $(".Userloaderbg").css("display", "flex");

    var CmpId = encodeURIComponent($("#ddlCmpId").val());
    var FinantialYear = encodeURIComponent($("#ddlFinantialYear").val());
    var IncomeTaxType = encodeURIComponent($("#ddlIncomeTaxType").val());
   
    var url = `@Url.Action("DownloadExcelFile", "Reports_IncomeTax_Data")?FinantialYear=${FinantialYear}&IncomeTaxType=${IncomeTaxType}&CmpId=${CmpId}`;

    $.ajax({
        url: url,
        method: 'GET',
        xhrFields: { responseType: 'blob' },
        success: function (data, status, xhr) {

            $(".Userloaderbg").css("display", "none");

            // Check file name
            var disposition = xhr.getResponseHeader("Content-Disposition");
            if (disposition && disposition.indexOf("FileNotFound.txt") !== -1) {
                Swal.fire({ icon: 'error', text: 'Record Not Found' });
                return;
            }

            // Download normally
            var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
            var downloadUrl = URL.createObjectURL(blob);

            var a = document.createElement('a');
            a.href = downloadUrl;
            a.download = 'IncomeTaxDataReport.xlsx';
            a.click();

            URL.revokeObjectURL(downloadUrl);
        },
        error: function (xhr, status, error) {
            console.error('Error downloading file:', error);
            $(".Userloaderbg").css("display", "none");
        }
    });
}
</script>