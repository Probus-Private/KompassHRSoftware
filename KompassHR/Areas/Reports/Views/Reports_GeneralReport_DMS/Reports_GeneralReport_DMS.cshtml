<!-- #modal-dialog -->
<div class="modal fade" id="ReviewEmployeeName" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Document List</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->

                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage hd" id="tblDocument" style="width: 100%;">
                                        <thead>
                                            <tr>                                                  
                                                <th class="text-nowrap text-center">Sr.No</th>                          
                                                <th class="text-nowrap text-center">Employee Name</th>
                                                <th class="text-nowrap text-center">Doc Origin Name</th>                                                  
                                                <th class="text-nowrap text-center" hidden>Total File Size</th>
                                                <th class="text-nowrap text-center">File Size</th>
                                                <th class="text-nowrap text-center">Preview</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblDocumentDetails"></tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="3"> <h3 class="text-center">Total</h3></td>
                                                <td>
                                                    <input type="text" class="form-control" id="txtTotalCount" style="text-align:right" />
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                            </div>
                        </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="EmployeeWiseName" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Documents List</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModels">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->

                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="fixed-header" style="width: 100%;">
                                        <thead>
                                            <tr>
                                                <th class="text-nowrap text-center">Sr.No</th>
                                                <th class="text-nowrap text-center">Employee Name</th>
                                                <th class="text-nowrap text-center">Doc Origin Name</th>
                                                <th class="text-nowrap text-center">Download</th>
                                                <th class="text-nowrap text-center">File Size</th>
                                              
                                            </tr>
                                        </thead>
                                        <tbody id="tblEmployeeWiseDetails"></tbody>
                                        
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>


<script>
    function DMSOriginName(DocOrigin) {
        $.ajax({
            url: "DMSRecordPreview",
            method: "get",
            data: { DocOrigin: DocOrigin },
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                var datas = JSON.parse(data);
               
                if (datas != null) {
                    var totalkb =0;
                    for (var i = 0; i <= datas.length - 1; i++) {
                        var table = document.getElementById("tblDocumentDetails");
                        var rowCount = table.rows.length;
                        var row = table.insertRow(rowCount);
                        var count = $('#tblDocumentDetails tr').length;
                        var Setdata = datas[i];
                        var SrNo = (i + 1);
                        row.insertCell(0).innerHTML = '<center>' + SrNo + '</center>';
                        row.insertCell(1).innerHTML = "" + Setdata[1].Value + "";
                        row.insertCell(2).innerHTML = "" + Setdata[2].Value + "";
                        row.insertCell(3).innerHTML = '<center>' + Setdata[3].Value + '<center>';
                        row.insertCell(4).innerHTML = '<center>' + Setdata[4].Value + '<center>';
                        var Id = Setdata[0].Value;
                        var Origin = Setdata[2].Value;
                        
                        //row.insertCell(4).innerHTML = '<center><a type="button" id="btnDelete" class="btn btn-success ListBtn btnpress" href="/Reports/Reports_GeneralReport_DMS/DownloadFile?AnnouncementFile=' + Setdata[4].Value + '"download><i class="fa-solid fa-download"></i></a></center>';
                         //row.insertCell(4).innerHTML = '<center><a href="#ReviewEmployeeName" data-bs-toggle="modal"><button type="button" id="btnDelete" class="btn btn-success ListBtn btnpress" href="/Reports/Reports_GeneralReport_DMS/DMSEmployeeWise?EmployeeUserID,Announcement=' + Setdata[0].Value + '' + Setdata[2].Value + '"download><i class="fa-solid fa-expand"></i></button></a></center>';
                        row.insertCell(5).innerHTML = '<center><a href="#EmployeeWiseName" data-bs-toggle="modal"><button type="button" id="btnOpenPopUp" class="btn btn-success ListBtn btnpress" onclick="DMSEmployeeWise(\'' + Id + '\',\'' + Origin + '\')"><i class="fa-solid fa-expand"></i></button></a></center>';
                       // var sum = 0;
                        var Total = Number($('#txtTotalCount').val());
                        //var SetDatas =(Setdata[3].Value);                       
                        var sum = Total + Setdata[3].Value;
                        totalkb += sum;
                        //$('#txtTotalCount').val(sum.toFixed(2));
                    }
                    $('#txtTotalCount').val(totalkb +' '+'Kb');
                };
            }

        });

    }
    $("#CloseModel").click(function () {
        $('#tblDocumentDetails tr').not(function () { return !!$(this).has('th').length; }).remove();
        $("#txtTotalCount").val('');
    })

    function DMSEmployeeWise(Id, Origin) {
        debugger;
        
        $.ajax({
            url: "DMSEmployeeWises",
            method: "get",
            data: { Id: Id, Origin: Origin },
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                var datas = JSON.parse(data);
                if (datas != null) {
                    for (var i = 0; i <= datas.length - 1; i++) {
                        var table = document.getElementById("tblEmployeeWiseDetails");
                        var rowCount = table.rows.length;
                        var row = table.insertRow(rowCount);
                        var count = $('#tblEmployeeWiseDetails tr').length;
                        var Setdata = datas[i];
                        var SrNo = (i + 1);
                        row.insertCell(0).innerHTML = '<center>' + SrNo + '</center>';
                        row.insertCell(1).innerHTML = "" + Setdata[1].Value + "";
                        row.insertCell(2).innerHTML = "" + Setdata[5].Value + "";
                        row.insertCell(3).innerHTML = '<center><a type="button" id="btnDelete" class="btn btn-success ListBtn btnpress" href="/Reports/Reports_GeneralReport_DMS/DownloadFile?AnnouncementFile=' + Setdata[6].Value + '"download><i class="fa-solid fa-download"></i></a></center>';                     
                        row.insertCell(4).innerHTML = '<center>' + Setdata[7].Value + '<center>';                      

                    }
                }
            }

        });

    }

    $("#CloseModels").click(function () {
        $('#tblEmployeeWiseDetails tr').not(function () { return !!$(this).has('th').length; }).remove();
        $('#tblDocumentDetails tr').not(function () { return !!$(this).has('th').length; }).remove();
        $("#txtTotalCount").val('');
    })

   
</script>





