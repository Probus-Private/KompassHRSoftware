
@{
    ViewBag.Title = "Reports_Onboarding_DocumentSize";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .fixed-header-wrapper {
        max-height: 400px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .fixed-header-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
    }

    .fixed-header-wrapper th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f1f1f1;
        box-shadow: inset 0 -1px 0 lightgray;
    }


    .table-scroll {
        table-layout: fixed;
        width: 100%;
    }

    .tbody-scroll .table-scroll {
        border-top: none;
    }

    .table-scroll th,
    .table-scroll td {
        width: 25%;
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: middle;
    }

        .table-scroll th:nth-child(2),
        .table-scroll td:nth-child(2),
        /*.table-scroll th:nth-child(3),
        .table-scroll td:nth-child(3)*/
         {
            /*text-align: center;*/
            text-align: left;
            white-space: nowrap;
        }

    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .custom-group {
        display: flex;
        align-items: center;
    }

        .custom-group .file-input {
            flex: 0 1 200px;
        }

        .custom-group .submit-btn {
            flex: 0 1 120px;
            white-space: nowrap;
        }

    .file-input {
        flex: 0 1 200px;
    }

    .submit-btn {
        flex: 0 1 120px;
    }
    .total-row td {
    font-weight: 700 !important;
    background-color: #f2f2f2;
}

</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Documents Size
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports_Onboarding_Menu", "Reports_Onboarding_Menu", new {id = 41, ScreenId=275, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Documents - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                       Documents size
                    </p>
                </div>

                <div class="panel-body">
                    <div class="row">
                        <!-- BEGIN table-responsive -->

                        <form role="form" action='@Url.Action("Reports_Onboarding_DocumentSize", "Reports_Onboarding_DocumentSize", new { area = "Reports" })' id="" method="post">

                            <input type="hidden" name="selectedFieldsJson" id="selectedFields" />

                            <div class="table-scroll div1">
                                <div class="fixed-header-wrapper">
                                    <div class="table-wrap" style="height: 350px; overflow-y: auto;">

                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="EmployeeExportTable">
                                            <thead>
                                                <tr class="trheading text-center">
                                                    @*<th class="text-nowrap text-center">Origin</th>
                                                    <th class="text-nowrap text-center">Folders</th>*@
                                                    <th class="text-nowrap text-center">Documents</th>
                                                    <th class="text-nowrap text-center">size(MB)</th>
                                                </tr>
                                            </thead>

                                            <tbody class="table-scroll">

                                                @if (ViewBag.GetDetailsList != null)
                                                {
                                                    foreach (var item in ViewBag.GetDetailsList)
                                                    {
                                                        <tr>
                                                            @*<td class="text-left">@item.DocOrigin</td>
                                                            <td class="text-left">@item.FolderName</td>*@
                                                            <td class="text-left">@item.DisplayName</td>
                                                            <td class="text-center">@item.FolderSizeMB</td>
                                                        </tr>
                                                    }

                                                      <!-- Total row -->
                                                    <tr class="total-row">
                                                        @*<td colspan="2" class="text-end">Total Size (MB)</td>*@
                                                        <td class="text-end">Total Size (MB)</td>
                                                        <td class="text-center">@ViewBag.totalFolderSize</td>
                                                    </tr>
                                                    <tr class="total-row">
                                                        <td class="text-end">Total Size (GB)</td>
                                                        <td class="text-center">@ViewBag.TotalFolderSizeGB</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

