@model KompassHR.Areas.ESS.Models.ESS_Tax.IncomeTax_Fyear

@{
    ViewBag.Title = "Reports_TaxSheet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<link href="~/assets/plugins/summernote/dist/summernote-lite.css" rel="stylesheet" />
<script src="~/assets/plugins/summernote/dist/summernote-lite.min.js"></script>



<style>
    .table-wrapper .connected-table {
        width: 100%;
        border: 1px solid black;
        border-collapse: collapse;
        margin: 0;
        border-spacing: 0;
    }

        .table-wrapper .connected-table + .connected-table {
            border-top: none; /* Remove double border between tables */
        }

    /* Optional: fix browser rendering flicker on load */
    .table-wrapper {
        display: block;
        overflow: hidden;
        border: 1px solid black; /* outer border for the block */
    }
</style>











<style>
    /* This will apply ONLY to rows in .tblSalaryDetails */
    .tblSalaryDetails .highlight-row td,
    .tblSalaryDetails .highlight-row th {
        font-weight: bold !important;
        background-color: lightgray !important;
    }

    /* This keeps .tblSalaryDetailsSub normal — your current style */
    .tblSalaryDetailsSub td {
        font-weight: normal !important;
    }



    tbody td {
        font-weight: bold;
    }



    .table1 td {
        font-weight: normal !important;
    }

    .table3 td {
        font-weight: normal;
    }


    .table4 td {
        font-weight: normal;
    }

    .full-width-box {
        border: 1px solid #ccc;
        padding: 10px;
        background-color: #f9f9f9;
        border-radius: 8px;
        width: 100%;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
        margin-bottom: 20px;
    }

    .select2.select2-container {
        width: 100% !important;
    }

    .amt {
        text-align: right;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 24px; font-family: roboto; transform: translateY(4px); margin: 0 auto; display: block; text-align: center;">
                Tax Sheet
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Report_MyAtttendance_RptMenu", "Report_MyAtttendance_RptMenu", new {id = 23, ScreenId= 376, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <hr />




    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-body combined-table-border table-container">

                    <form role="form" action='@Url.Action("Reports_TaxSheet", "Reports_TaxSheet", new { area = "Reports" })' id="SaveTaxComputation" method="post" data-parsley-validate="">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Financial Year<span class="important">*</span>
                                    </label>
                                    <div class="col-md-6">
                                        @Html.DropDownListFor(model => model.TaxFyearId, new SelectList(ViewBag.GetTaxFyear, "Id", "Name"), "--Select--", new { id = "ddlTaxFyearId", @class = "form-select", autocomplete = "off", name = "TaxFyearId" })
                                        @Html.ValidationMessageFor(model => model.TaxFyearId, "", new { @class = "help-block", id = "ErrorTaxFyearId", style = "color:red" })
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary btn-sm IncomeTax" id="btnSubmit">
                                            Show  <i class="fa-solid fa-arrow-right-long"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="table-wrap table-wrapper">
                                    <table class="table table-bordered table1 connected-table" style="width: 100%;">
                                        <tbody>
                                            <tr style="background-color: deepskyblue !important; color: white; border-bottom: 2px solid black;">
                                                <th class="text-start" colspan="14">
                                                    <center><h3><b>@ViewBag.PersonalDetails.CompanyName</b></h3></center>
                                                </th>
                                            </tr>
                                            <tr>
                                                <th>Employee Name</th>
                                                <td>@ViewBag.PersonalDetails.EmployeeName</td>
                                                <th>PAN</th>
                                                <td>@ViewBag.PersonalDetails.PAN</td>
                                            </tr>
                                            <tr>
                                                <th>Employee No</th>
                                                <td>@ViewBag.PersonalDetails.EmployeeNo</td>
                                                <th>Adhaar</th>
                                                <td>@ViewBag.PersonalDetails.Aadhar</td>
                                            </tr>
                                            <tr>
                                                <th>Bussiness Unit</th>
                                                <td>@ViewBag.PersonalDetails.BranchName</td>
                                                <th>DOB</th>
                                                <td>@ViewBag.PersonalDetails.DOB</td>
                                            </tr>
                                            <tr>
                                                <th>Department</th>
                                                <td>@ViewBag.PersonalDetails.Department</td>
                                                <th>DOJ</th>
                                                <td>@ViewBag.PersonalDetails.DOJ</td>
                                            </tr>
                                            <tr>
                                                <th>Designation</th>
                                                <td>@ViewBag.PersonalDetails.Designation</td>
                                                <th>Mobile No</th>
                                                <td>@ViewBag.PersonalDetails.MobileNo</td>
                                            </tr>
                                            <tr>
                                                <th>Grade</th>
                                                <td>@ViewBag.PersonalDetails.Grade</td>
                                                <th>Email Id</th>
                                                <td>@ViewBag.PersonalDetails.EmailId</td>
                                            </tr>
                                            <tr>
                                                <th>Gender</th>
                                                <td>@ViewBag.PersonalDetails.Gender</td>
                                                <th></th>
                                                <td></td>
                                            </tr>
                                        </tbody>
                                    </table>



                                    <table class="table table-bordered align-middle tblSalaryDetails table2 connected-table" id="fixed-header" style="width: 100%;">
                                        <thead style="width: 100%;">
                                            <tr>
                                                <th class="text-start" colspan="14">
                                                    <center><h3><b>Salary Details</b></h3></center>
                                                </th>
                                            </tr>
                                            <tr class="text-center">
                                                <th class="text-nowrap" style="width:20%">Head</th>
                                                <th class="text-nowrap">April</th>
                                                <th class="text-nowrap">May</th>
                                                <th class="text-nowrap">June</th>
                                                <th class="text-nowrap">July</th>
                                                <th class="text-nowrap">August</th>
                                                <th class="text-nowrap">September</th>
                                                <th class="text-nowrap">October</th>
                                                <th class="text-nowrap">November</th>
                                                <th class="text-nowrap">December</th>
                                                <th class="text-nowrap">January</th>
                                                <th class="text-nowrap">February</th>
                                                <th class="text-nowrap">March</th>
                                                <th class="text-nowrap">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in ViewBag.AttendanceDetails)
                                            {
                                                <tr>
                                                    <td>@item.HeadName</td>
                                                    <td class="amt">@item.Apr_Month</td>
                                                    <td class="amt">@item.May_Month</td>
                                                    <td class="amt">@item.Jun_Month</td>
                                                    <td class="amt">@item.Jul_Month</td>
                                                    <td class="amt">@item.Aug_Month</td>
                                                    <td class="amt">@item.Sep_Month</td>
                                                    <td class="amt">@item.Oct_Month</td>
                                                    <td class="amt">@item.Nov_Month</td>
                                                    <td class="amt">@item.Dec_Month</td>
                                                    <td class="amt">@item.Jan_Month</td>
                                                    <td class="amt">@item.Feb_Month</td>
                                                    <td class="amt">@item.Mar_Month</td>
                                                    <td class="amt">@item.Total</td>
                                                </tr>
                                            }


                                        </tbody>
                                        <tbody class="tblSalaryDetailsSub">
                                            @foreach (var item in ViewBag.SalaryDetails)
                                            {
                                                <tr>
                                                    <td>@item.HeadName</td>
                                                    <td class="amt">@item.Apr_Month</td>
                                                    <td class="amt">@item.May_Month</td>
                                                    <td class="amt">@item.Jun_Month</td>
                                                    <td class="amt">@item.Jul_Month</td>
                                                    <td class="amt">@item.Aug_Month</td>
                                                    <td class="amt">@item.Sep_Month</td>
                                                    <td class="amt">@item.Oct_Month</td>
                                                    <td class="amt">@item.Nov_Month</td>
                                                    <td class="amt">@item.Dec_Month</td>
                                                    <td class="amt">@item.Jan_Month</td>
                                                    <td class="amt">@item.Feb_Month</td>
                                                    <td class="amt">@item.Mar_Month</td>
                                                    <td class="amt">@item.Total</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>


                                    <table class="table table-bordered align-middle tblTaxSheet table3 connected-table">
                                        <thead>
                                            <tr style="background-color: deepskyblue !important;">
                                                <th class="text-start" colspan="2">
                                                    <center><h2><b>Tax Sheet</b></h2></center>
                                                    <center><h3><b>Financial Year:  @ViewBag.PersonalDetails.FinancialYear </b></h3></center>
                                                    <center><h4><b>(@ViewBag.PersonalDetails.RegimeType)</b></h4></center>
                                                </th>
                                            </tr>
                                            <tr>
                                                <th>Particulars</th>
                                                
                                                <th><center> Amount</center></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>A. Gross Income from Salaries and Allowances</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>
                                            </tr>

                                            <tr>
                                                <td>(1) Current Employer(Company)</td>                                                
                                                <td></td>
                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>a. Salary</span>
                                                    <span></span>
                                                </td>
                                                <td class="amt">@ViewBag.TaxDetails.TaxCal_GrossSalary</td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>b. Bonus</span>
                                                    <span></span>
                                                </td>
                                                <td class="amt">@ViewBag.TaxDetails.TaxCal_Bonus</td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>c. Leave Encashment</span>
                                                    <span></span>
                                                </td>
                                                <td class="amt">@ViewBag.TaxDetails.TaxCal_LeaveEncashment</td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>d. Other Than Salary</span>
                                                    <span></span>
                                                </td>
                                                <td class="amt">@ViewBag.TaxDetails.TaxCal_OtherThanSalary</td>
                                            </tr>


                                            <tr>
                                                <td>(2) Previous Employer(Company)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_PreviousGrossSalary) ?? "")</td>
                                            </tr>

                                            <tr>
                                                <td><strong>Total Gross Income from Salaries and Allowances</strong></td>
                                                
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_TotalGrossSalary) ?? "")</strong></td>

                                            </tr>

                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>B.Deduction under section 16</strong></td>
                                                  <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>

                                            </tr>
                                            <tr>
                                                <td>Standard Deduction for Salaried</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_StandardDeduction) ?? "")</td>

                                            </tr>
                                            <tr>
                                                <td>Professional Tax</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_ProfessionTax) ?? "")</td>


                                            </tr>
                                            <tr>
                                                <td><strong>Total Deduction under section 16</strong></td>
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_TotalDeductionUS16) ?? "")</strong></td>

                                            </tr>


                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>C.Exemptions under section 10 & 17</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>
                                            </tr>
                                            <tr>
                                                <td>(1) HRA Exemption     (Least of the following three)10(13A)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_HRA_Exemption) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Resident of Non-Metro</td>
                                                <td class="amt"></td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>a. Basic Salary (Basic+DA)</span>
                                                    <span></span>
                                                </td>
                                                <td style="border-bottom:solid white;"></td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>b. Rent Paid</span>
                                                    <span></span>
                                                </td>
                                                <td class="amt"></td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px; display: flex; justify-content: space-between;">
                                                    <span>c. HRA received</span>
                                                    <span></span>
                                                </td>
                                                <td style="border-top:solid white;"></td>

                                            </tr>



                                            <tr>
                                                <td>(2) Retirement Leave Encashment U/S 10(10AA)</td>
                                               
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_RetirementLeaveEncashment) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(3) Sodexo Meal Coupon</td>
                                                
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_SodexoMealCoupon) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(4) Children Education Allowance (Rs. 100 pm per child {Max 2})</td>
                                                
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_ChildrenEducationAllowanceExemption) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(5) ChildrenHostel(Rs. 100 pm per child {Max 2})</td>
                                                
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_ChildrenEducationHostel) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(6) Leave Travel Allowance-to the extent allowed10(5)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_LTAExemption) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(7) Gratuity Payment 10(10)-to the extent allowed</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_GratuityPayment) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(8) Uniform Allowance</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_UniformExpenses) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(9) Other Tax free Allowances and reimbursements</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_OtherexEmption) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>(10) Transport Allowance-to the extent allowed10(5)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_TransportExemption) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td> <strong>Total Exemptions under section 10 & 17</strong></td>
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_Total_ExemptionsUnderSection) ?? "")</strong></td>

                                            </tr>

                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"> <strong>D. Gross Salary after Section 10 & 17 exemptions</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Gross Salary after Section 10 & 17 exemptions(D=A-B-C)</strong></td>
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_GrossSalaryAfterSection10and17Exemptions) ?? "")</strong></td>

                                            </tr>
                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"> <strong>E. Perquisites</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>
                                            </tr>


                                            <tr>
                                                <td>Cars/Other automotive</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite1) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Sweeper, gardener, watchman or personal attendant</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite2) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Gas, electricity, water</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite3) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Interest free or concessional loans</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite4) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Holiday expenses</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite5) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Free or concessional travel</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite6) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Free meals</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite7) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Free education</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite8) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Gifts, vouchers, etc.</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite9) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Credit card expenses</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite10) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Club expenses</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite11) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Use of movable assets by employees</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite12) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Transfer of assets to employees</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite13) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Value of any other benefit / amenity / service / privilege</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite14) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Stock options ( non-qualified options)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite15) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td>Other benefits or amenities</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_Perquisite16) ?? "")</td>

                                            </tr>



                                            <tr>
                                                <td><strong>Total Perquisites</strong></td>
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_Total_Perquisites) ?? "")</strong></td>

                                            </tr>

                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>F. Income chargeable under head 'Salaries'</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>

                                            </tr>

                                            <tr>
                                                <td><strong>Income chargeable under head 'Salaries'(F= D + E)</strong></td>
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_Total_IncomeChargeableUnderHeadSalaries) ?? "")</strong></td>

                                            </tr>

                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>G. Income from Other Sources</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>

                                            </tr>

                                            <tr>
                                                <td><strong>1. Interest income from the following sources:</strong></td>
                                                <td class="amt"></td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px;">a. Bank (Savings A/C)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_OtherIncome1) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px;">b. Bank (F.D/ Recurring)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_OtherIncome2) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px;">c. N.S.C( Accrued/Received)</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_OtherIncome3) ?? "")</td>

                                            </tr>

                                            

                                          

                                            <tr>
                                                <td><strong>2. Income from House Properties [Let out/Self occupied) (</strong></td>
                                                <td class="amt"></td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px;">Income from Let Out House Property</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_IncomefromLetOutHouseProperty) ?? "")</td>

                                            </tr>

                                            <tr>
                                                <td style="padding-left: 20px;">Interest On Self Occupied Housing Loan</td>
                                                <td class="amt">@((ViewBag.TaxDetails?.TaxCal_InterestOnSelfOccupiedHousingLoan) ?? "")</td>

                                            </tr>



                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>H. Gross Total Income</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>

                                            </tr>

                                            <tr>
                                                <td><strong>Gross Total Income(H=F + G)</strong></td>
                                                <td class="amt"><strong>@((ViewBag.TaxDetails?.TaxCal_GrossTotalIncome) ?? "")</strong></td>

                                            </tr>

                                            <tr>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"><strong>I. Less: Deduction</strong></td>
                                                <td style="border:none" class="text-start bg-blue text-white p-2 mb-0"></td>

