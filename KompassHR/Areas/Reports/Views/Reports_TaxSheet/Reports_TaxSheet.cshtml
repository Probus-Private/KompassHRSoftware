<script>
    document.addEventListener("DOMContentLoaded", function () {
        let total = @Html.Raw(Json.Encode(ViewBag.TaxDetails.TaxCal_Net_Tax_Payable));
        
        document.getElementById("tds-total").textContent = total.toFixed(2);


        let totalPaid = 0;
        document.querySelectorAll("table.tblTDSDetails tbody tr").forEach(row => {
            const cells = row.querySelectorAll("td");

            // Only consider rows with at least 3 cells
            if (cells.length >= 3) {
                const status = cells[1].textContent.trim().toLowerCase(); // Remark2 (Paid/Unpaid)
                const amountText = cells[2].textContent.trim(); // Amount

                if (status === "paid") {
                    const amount = parseFloat(amountText.replace(/[^0-9.-]+/g, '')) || 0;
                    totalPaid += amount;
                }
            }
        });
        document.getElementById("tds-total-paid").textContent = totalPaid.toFixed(2);


        let totalUnPaid = 0;
        document.querySelectorAll("table.tblTDSDetails tbody tr").forEach(row => {
            const cells = row.querySelectorAll("td");

            if (cells.length >= 3) {
                const status = cells[1].textContent.trim().toLowerCase();
                const amountText = cells[2].textContent.trim();

                if (status === "unpaid") {
                    const amount = parseFloat(amountText.replace(/[^0-9.-]+/g, '')) || 0;
                    totalUnPaid += amount;
                }
            }
        });
        document.getElementById("tds-total-unpaid").textContent = totalUnPaid.toFixed(2);


        let balance = 0;
        document.getElementById("tds-total-balance").textContent = (total - totalPaid).toFixed(2);
    });
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const table = document.querySelector("table.tblSalaryDetails");
        if (!table) return;

        const rows = table.querySelectorAll("tbody tr");

        rows.forEach(row => {
            const firstCell = row.querySelector("td, th"); // <- updated here
            if (firstCell) {
                const cellText = firstCell.textContent.trim().toLowerCase();
                if (cellText === "gross" || cellText === "netpay") {
                    row.classList.add("highlight-row");
                }
            }
        });
    });
</script>