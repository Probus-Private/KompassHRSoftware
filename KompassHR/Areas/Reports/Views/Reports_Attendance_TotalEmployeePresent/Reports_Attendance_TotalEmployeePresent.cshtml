    function downloadExcelFile() {
        debugger;
        $(".Userloaderbg").css("display", "flex");
        //var CmpId = $("#ddlCmpId").val();
        //var BranchId = $("#ddlBranchId").val();
        //var DepartmentId = $("#ddlDepartmentId").val();
        //var SubDepartmentId = $("#ddlSubDepartmentId").val();
        //var DesignationId = $("#ddlDesignationId").val();
        //var GradeId = $("#ddlGradeId").val();
        //var LineId = $("#ddlLineId").val();
        //var SubUnitId = $("#ddlSubUnit").val();
        //var EmployeeID = $("#ddlEmployeeID").val();
        //var FromDate = $("#txtFromDate").val();
        //var ToDate=$("#txtToDate").val();

        var DepartmentId = encodeURIComponent($("#ddlDepartmentId").val());
        var SubDepartmentId = encodeURIComponent($("#ddlSubDepartmentId").val());
        var DesignationId = encodeURIComponent($("#ddlDesignationId").val());
        var GradeId = encodeURIComponent($("#ddlGradeId").val());
        var LineId = encodeURIComponent($("#ddlLineId").val());
        var SubUnitId = encodeURIComponent($("#ddlSubUnit").val());
        var EmployeeID = encodeURIComponent($("#ddlEmployeeID").val());
        var FromDate = encodeURIComponent($("#txtFromDate").val());
        var branchId = encodeURIComponent($("#ddlBranchId").val());
        var CmpID = encodeURIComponent($("#ddlCmpId").val());
        var ToDate=encodeURIComponent($("#txtToDate").val());
        var ContractorId=encodeURIComponent($("#ddlContractorId").val());
        var url = `@Url.Action("DownloadExcelFile", "Reports_Attendance_TotalEmployeePresent")?BranchId=${branchId}&CmpID=${CmpID}&DepartmentId=${DepartmentId}&SubDepartmentId=${SubDepartmentId}&DesignationId=${DesignationId}&GradeId=${GradeId}&LineId=${LineId}&SubUnitId=${SubUnitId}&EmployeeID=${EmployeeID}&FromDate=${FromDate}&ToDate=${ToDate}&ContractorId=${ContractorId}`;

        // Create a full URL with query parameters
        //var url = '/Reports_Attendance_TotalEmployeePresent/DownloadExcelFile?BranchId=' + encodeURIComponent(BranchId) + '&FromDate=' + encodeURIComponent(FromDate) +'&CmpId='+ encodeURIComponent(CmpId) +'&DepartmentId='+encodeURIComponent(DepartmentId)+'&SubDepartmentId='+encodeURIComponent(SubDepartmentId)+'&DesignationId='+encodeURIComponent(DesignationId)+'&GradeId='+encodeURIComponent(GradeId)+'&LineId='+encodeURIComponent(LineId)+'&SubUnitId='+encodeURIComponent(SubUnitId)+'&EmployeeID='+encodeURIComponent(EmployeeID)+'&ToDate='+encodeURIComponent(ToDate);
        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertDateFormat(FromDate);
                var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'TotalEmployeePresentReport('+formattedDate +' - '+ ToformattedDate+').xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }

