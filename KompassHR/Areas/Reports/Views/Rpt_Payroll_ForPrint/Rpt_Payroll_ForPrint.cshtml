<script>
    $("#btlPrintInvoice").on("click", function () {
        debugger;
        $(".Userloaderbg").css("display", "flex");
        var BranchId = Number(encodeURIComponent($("#ddlBranchId").val()));
        var MonthYear = encodeURIComponent($("#GetMonth").val());
        var CmpId = Number(encodeURIComponent($("#ddlCmpId").val()));
        var SalarySheetId = Number(encodeURIComponent($("#ddlSalarySheet").val()));
        var url = '@Url.Action("GetWagesSheetInvoice", "Module_Payroll_PayrollProcess", new { area = "Module" })'
                  + '?BranchId=' + BranchId
                  + '&MonthYear=' + MonthYear
                  + '&SalaryCmpId=' + CmpId
                  + '&SalarySheetId=' + SalarySheetId;
        window.location.href = url;
    });
    
    @*function GetInvoice(SalaryBranchId, SalaryMonthYear, SalaryCmpId) {
        var BranchId = encodeURIComponent(SalaryBranchId);
        var MonthYear = encodeURIComponent(SalaryMonthYear);
        var CmpId = encodeURIComponent(SalaryCmpId);

        var url = '@Url.Action("GetWagesSheetInvoice", "Module_Payroll_PayrollProcess", new { area = "Module" })'
                  + '?BranchId=' + BranchId
