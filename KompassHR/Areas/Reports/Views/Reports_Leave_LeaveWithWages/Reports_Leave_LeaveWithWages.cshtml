                                                                    <td class="text-nowrap text-center">@d.NoOfDaysOfMaternityLeaveWith</td>
                                                                }


                                                                @if (d.NoOfDaysLeaveWithWagesEnjoyed == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.NoOfDaysLeaveWithWagesEnjoyed</td>
                                                                }


                                                                @if (d.NoOfLeaveWithoutPay == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.NoOfLeaveWithoutPay</td>
                                                                }
                                                                @if (d.NoOfWeekOffandPublicHolidayWithWagesEnjoyed == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.NoOfWeekOffandPublicHolidayWithWagesEnjoyed</td>
                                                                }


                                                                @if (d.NoTotal == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.NoTotal</td>
                                                                }
                                                                <td class="text-nowrap text-center">@d.BalanceOfLeaveWithWagesFromPrecedingYear</td>
                                                                <td class="text-nowrap text-center">@d.LeaveWithWagesEarnedDuringThisYear</td>

                                                                @*@if (d.BalanceOfLeaveWithWagesFromPrecedingYear==null)
                                                                    {
                                                                        <td class="text-nowrap text-center">0</td>
                                                                    }
                                                                    else
                                                                    {
                                                                        <td class="text-nowrap text-center">@d.BalanceOfLeaveWithWagesFromPrecedingYear</td>
                                                                    }*@

                                                                @*@if (d.LeaveWithWagesEarnedDuringThisYear==null)
                                                                    {
                                                                        <td class="text-nowrap text-center">0</td>
                                                                    }
                                                                    else
                                                                    {
                                                                        <td class="text-nowrap text-center">@d.LeaveWithWagesEarnedDuringThisYear</td>
                                                                    }*@

                                                                @if (d.EarnedLeaveTotal == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.EarnedLeaveTotal</td>
                                                                }

                                                                @if (d.WhetherLeaveWithWagesRefused == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.WhetherLeaveWithWagesRefused</td>
                                                                }

                                                                @if (d.WhetherLeaveWithWagesNotDesiredDuringTheNextCalendarYear == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.WhetherLeaveWithWagesNotDesiredDuringTheNextCalendarYear</td>
                                                                }

                                                                @if (d.LeaveWithWagesEnjoyedFromTo == null)
                                                                {
                                                                    <td class="text-nowrap text-center">-</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.LeaveWithWagesEnjoyedFromTo</td>
                                                                }

                                                                @if (d.BalanceToCredit == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.BalanceToCredit</td>
                                                                }

                                                                @if (d.NormalRateOfWages == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.NormalRateOfWages</td>
                                                                }

                                                                @if (d.CashEquivalentorAccruingThroughConcessionalSaleofFoodgrainsorOtherArticles == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.CashEquivalentorAccruingThroughConcessionalSaleofFoodgrainsorOtherArticles</td>
                                                                }

                                                                @if (d.RateOfWagesForLeaveWagesPeriod == null)
                                                                {
                                                                    <td class="text-nowrap text-center">0</td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.RateOfWagesForLeaveWagesPeriod</td>
                                                                }


                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        <br />
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function printDiv() {
        var divElements = document.getElementById('divPrint').innerHTML;
        var headerElements = document.getElementById('DIVheader').innerHTML;
        var printWindow = window.open('', '', 'height=842,width=595'); // A4 Portrait

        printWindow.document.write('<html><head><title>Print</title>');
        printWindow.document.write('<style>');

        // Reset styles
        printWindow.document.write('* { box-sizing: border-box; }');
        printWindow.document.write('body, html { margin: 0; padding: 0; font-size: 9pt; width: 100%; }');

        // A4 dimensions
        printWindow.document.write('@@page { size: A4 landscape; margin: 10mm; }');
        printWindow.document.write('body { width: 100%; height: 100%; }');

        // Table styles
        printWindow.document.write('#tbl { width: 100%; border: 2px solid black; border-collapse: collapse; table-layout: fixed; }');
        printWindow.document.write('#tbl th, #tbl td { border: 1px solid black; padding: 4px; word-wrap: break-word; vertical-align: middle; font-size: 9pt; }');
        printWindow.document.write('th, td:nth-last-child(-n+2) { width: 7%; }');

        // Header text
        printWindow.document.write('h2 { text-align: center; font-size: 1.2em; margin: 0 0 15px 0; }');

        // Text alignment classes
        printWindow.document.write('.text-nowrap { white-space: nowrap; }');
        printWindow.document.write('.text-left { text-align: left; }');
        printWindow.document.write('.text-center { text-align: center; }');

        // Vertical header
        printWindow.document.write('.vertical-header {');
        printWindow.document.write('writing-mode: vertical-rl;');
        printWindow.document.write('transform: rotate(180deg);');
        printWindow.document.write('text-align: center;');
        printWindow.document.write('padding: 10px;');
        printWindow.document.write('width: 50px !important;');
        printWindow.document.write('height: 100px !important;');
        printWindow.document.write('}');

        printWindow.document.write('</style></head><body>');
        printWindow.document.write('<h2>' + headerElements + '</h2>');
        printWindow.document.write('<div id="divPrint">' + divElements + '</div>');
        printWindow.document.write('</body></html>');

        printWindow.document.close();

        printWindow.onload = function () {
            printWindow.focus();
            printWindow.print();
            printWindow.close();
        };
    }



</script>

<script>
    $(document).ready(function () {
        $("#ddlCmpId").select2();
        $("#ddlEmployeeId").select2();
        $("#txtBranchId").select2();
        $("#GetMonth").select2();
        var today = new Date();
