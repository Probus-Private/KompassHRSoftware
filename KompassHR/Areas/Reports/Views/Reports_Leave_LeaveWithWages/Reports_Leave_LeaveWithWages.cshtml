                                            @Html.DropDownListFor(model => model.EmployeeId, new SelectList(ViewBag.EmployeeName, "Id", "Name"), "--Select--", new { @id = "ddlEmployeeId", name = "LeaveOpeningBalanceEmployeeId", @class = "form-select" })

