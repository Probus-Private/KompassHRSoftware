                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" onclick="funEmployeeWiseReport()" class="btn btn-sm btn-success btn-sm"> Show</button>
                                                    @*<button type="button" onclick="funEmployeeWiseReport()" class="btn btn-sm btn-success">Show</button>*@
