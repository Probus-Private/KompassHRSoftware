                                                                    }

                                                                }
                                                                else
                                                                {
                                                                    <td class="text-nowrap text-center">@d.MonthYear</td>
                                                                }
                                                                <td class="text-nowrap text-center">@d.NoOfDaysWorkPerformed</td>
