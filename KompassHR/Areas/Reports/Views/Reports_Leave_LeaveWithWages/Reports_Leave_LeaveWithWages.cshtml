                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="invoice">
                                <div class="invoice-company mb-3"></div>
                                <form class="form">
                                    <div class="row" id="DIVheader">
                                        <div class="col-md-12 text-center">
                                            <h3><b>Leave With Wages Register Form No 20</b></h3>
                                        </div>
                                    </div>
                                    <div class="invoice-content" id="divPrint">
                                        <div class="row">
                                            <div class="col-md-12" style="overflow-x:auto">
                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tbl">
                                                    <thead>
                                                        @if (ViewBag.GetEmployeeDetails.ToString() != "")
                                                        {

                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="8">Company Name : <b>@ViewBag.GetEmployeeDetails[0].CompanyName</b></th>
                                                                <th class="text-left" colspan="6">Business Unit : <b>@ViewBag.GetEmployeeDetails[0].BranchName</b></th>
                                                                <th class="text-left" colspan="4">Dischared Worker </th>
                                                            </tr>
                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="8">Employee Name : @ViewBag.GetEmployeeDetails[0].EmployeeName</th>
                                                                <th class="text-left" colspan="6">Father Name :</th>
                                                                <th class="text-left" colspan="4">Date : @ViewBag.GetEmployeeDetails[0].LeavingDate</th>
                                                            </tr>
                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="8">Employee No : @ViewBag.GetEmployeeDetails[0].EmployeeNo</th>
                                                                <th class="text-left" colspan="6">Normal Rate of Wages :</th>
                                                                <th class="text-left" colspan="4"></th>
                                                            </tr>
                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="8">Department : @ViewBag.GetEmployeeDetails[0].DepartmentName</th>
                                                                <th class="text-left" colspan="6">Page No. Old / New : </th>
                                                                <th class="text-left" colspan="4"></th>
                                                            </tr>
                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="8">Section : @ViewBag.GetEmployeeDetails[0].ContractorName</th>
                                                                <th class="text-left" colspan="6">Serial No. From Adult / Children's Worker register :</th>
                                                                <th class="text-left" colspan="4">Date & amount of payment made in lieu of leave with wages etc.</th>
                                                            </tr>
                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="8">Designation : @ViewBag.GetEmployeeDetails[0].DesignationName</th>
                                                                <th class="text-left" colspan="6">Date of entry into service : @ViewBag.GetEmployeeDetails[0].JoiningDate</th>
                                                                <th class="text-left" colspan="4">Remarks</th>
                                                            </tr>
                                                            <tr class="trheading">
                                                                <th class="text-left" colspan="18">Address : @ViewBag.GetEmployeeDetails[0].Address</th>

                                                            </tr>
                                                        }
                                                        <tr class="trheading">
                                                            <th rowspan="2" style="width:6%; border-color:black !important;" class="text-center vertical-header">Year & Month</th>
                                                            <th class="text-center" style="width:3%; border-color:black !important;" colspan="7">No. of days eligible during the calendar year</th>
                                                            <th class="text-center" style="width:3%; border-color:black !important;" colspan="3">Leave with wages to credit</th>
                                                            <th rowspan="2" style="width:5%;border-color:black !important;" class="text-center vertical-header">Whether leave with wages refused</th>
                                                            <th rowspan="2" style="width:5%;border-color:black !important;" class="text-center vertical-header">Whether leave with wages not desired during the next calendar year</th>
                                                            <th class="text-center" style="width:3%" colspan="1">Leave with wages enjoyed</th>
                                                            <th rowspan="2" style="width:5%;border-color:black !important;" class="text-center">Balance to Credit</th>
                                                            <th rowspan="2" style="width:5%;border-color:black !important;" class="text-center vertical-header">Normal Rate of Wages</th>
