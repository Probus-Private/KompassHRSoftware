<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Contractor Wise Rate Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports_ManpowerAllocation_Menu", "Reports_ManpowerAllocation_Menu",  new {id =35, ScreenId=288, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading">
                        <h4 class="panel-title">Contractor Wise Rate Report </h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                        </p>
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="col-md-12">
                                <form role="form" action='@Url.Action("Reports_ManpowerAllocation_ContractorWiseRate", "Reports_ManpowerAllocation_ContractorWiseRate", new { area = "Reports" })' id="SaveContractorWiseRate" method="post" enctype="multipart/form-data">

                                    <div class="row">
                                        <div class="col-md-6 mb-2">
                                            <div class="row mb-12px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Company
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "-- Select --", new { @class = "form-select", type = "text", name = "CmpId", id = "ddlCmpId", onchange = "OnCompanyChange()" })
                                                    <span id="ErrorddlCmpId" style="color:red"></span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6 mb-2">
                                            <div class="row mb-12px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Buisness Unit
                                                    <span class="important">*</span>
                                                </label>

                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BUName, "Id", "Name"), "-- Select --", new { @class = "form-select", type = "text", name = "CmpId", id = "ddlBranchId", onchange = "OnBUChange()" })
                                                    <span id="ErrorddlBranchId" style="color:red"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Contractor
                                                    <span class="important">*</span>
                                                </label>

                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.ContractorId, new SelectList(ViewBag.ContractorName, "Id", "Name"), "-- Select --", new { @class = "form-select", type = "text", name = "ContractorId", id = "ddlContractorId" })
                                                    <span id="ErrorddlContractorId" style="color:red"></span>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    From Month/Year <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.FromMonth, new { @class = "form-control", name = "FromMonth", type = "month", id = "txtFromMonth" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    To Month/Year <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.ToMonth, new { @class = "form-control", name = "ToMonth", type = "month", id = "txtToMonth" })
                                                    <span id="monthError" style="color:red; display:none;">To Month must be greter From Month.</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>


                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-10">
                                                </div>
                                                <div class="col-md-2">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                                <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                            </button>

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>

<script>
    $(document).ready(function () {
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlContractorId").select2();

        // Get current date and set default values
        var today = new Date();
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // getMonth() returns 0-11

        // Format as YYYY-MM (HTML5 month input format)
        var defaultMonthYear = yyyy + '-' + mm;

        // Set default values if empty
        if (!$('#txtFromMonth').val()) {
            $('#txtFromMonth').val(defaultMonthYear);
        }
        if (!$('#txtToMonth').val()) {
            $('#txtToMonth').val(defaultMonthYear);
        }

        // Add date validation
        $('#txtFromMonth, #txtToMonth').change(function() {
            validateMonthRange();
        });

        function validateMonthRange() {
            const fromVal = $('#txtFromMonth').val();
            const toVal = $('#txtToMonth').val();

            if (fromVal && toVal) {
                if (toVal < fromVal) {
                    $('#monthError').show();
                } else {
                    $('#monthError').hide();
                }
            }
        }
     
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#formReset").click(function () {
            $("#SaveContractorWiseRate")[0].reset();
        });
       
    });
</script>

<script>
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );

    $('#SaveContractorWiseRate').validate({
        rules: {
            CmpId: {
                required: true,
            },
            ContractorId:{
                required: true,
            },
            BranchId: {
                required: true,
            },
            FromMonth: {
                required: true,
            },
            ToMonth: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Company Name is required",

            },
            ContractorId:{
                required: "Contractor  is required",
            },
            BranchId: {
                required: "Business Unit name is required",
            },
            FromMonth: {
                required: "From Month is required",
            },
            ToMonth: {
                required: "To Month is required",
            },
        },
    });

    var form = $("#SaveContractorWiseRate");
    form.validate();

</script>

<script>
    function OnCompanyChange() {
        debugger
        var CmpId = document.getElementById("ddlCmpId").value;

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetBusinessUnit", "Reports_ManpowerAllocation_ContractorWiseRate")',
            data: { CmpId: CmpId},
            success: function (data) {
                debugger;
                if (data.Branch !=null) {
                    //$("#ddlBranchId").append("<option value=''>All</option>");
                    $.each(data.Branch, function(i, p) {
                        $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                    });
                }
                else {
                    $('#ddlBranchId').html(" ");
                }
            }
           
        });
    }

    function OnBUChange() {
        debugger
        var CmpId= document.getElementById("ddlCmpId").value;
        var BranchId = document.getElementById("ddlBranchId").value;

        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetContractor", "Reports_ManpowerAllocation_ContractorWiseRate")',
            data: { BranchId: BranchId,CmpId:CmpId},
            success: function (data) {
                var $ContractorDropdown = $("#ddlContractorId");
                $ContractorDropdown.empty();

                if (data && data.length > 0) {
                    $ContractorDropdown.append("<option value=''>--Select--</option>");
                    $.each(data, function (i, module) {
                        $ContractorDropdown.append(
                            $("<option>").val(module.Id).text(module.Name)
                        );
                    });
                } else {
                    $ContractorDropdown.append("<option>--Select--</option>");
                }
            },
            error: function () {
                console.error("Failed to fetch modules.");
                $("#ddlContractorId").empty().append("<option>Error loading modules</option>");
            }
        });
    }
  
    var form = $("#SaveContractorWiseRate");
    form.validate();

    function downloadExcelFile() {
        debugger;
        var isValid = true;

        //if (CmpId === "" || CmpId === "0") {
        //    $("#ErrorddlCmpId").text("Company is required");
        //    isValid = false;
        //} else {
        //    $("#ErrorddlCmpId").text("");
        //}

        //if (BranchId === "" || BranchId === "0") {
        //    $("#ErrorddlBranchId").text("Business Unit is required");
        //    isValid = false;
        //} else {
        //    $("#ErrorddlBranchId").text("");
        //}

        //if (ContractorId === "" || ContractorId === "0") {
        //    $("#ErrorddlContractorId").text("Contractor is required");
        //    isValid = false;
        //} else {
        //    $("#ErrorddlContractorId").text("");
        //}

        //if (!isValid) {
        //    return false;
        //}

        form.valid();
        if(form.valid()==false)
        {
            $("#txtFromMonth").removeClass('error');
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var ContractorId=$("#ddlContractorId").val();
        var FromMonth = $("#txtFromMonth").val();
        var ToMonth = $("#txtToMonth").val();
        var url = `@Url.Action("DownloadExcelFile", "Reports_ManpowerAllocation_ContractorWiseRate")?CmpId=${CmpId}&BranchId=${BranchId}&ContractorId=${ContractorId}&FromMonth=${FromMonth}&ToMonth=${ToMonth}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }

                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'ContractorWiseRate.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }

</script>
