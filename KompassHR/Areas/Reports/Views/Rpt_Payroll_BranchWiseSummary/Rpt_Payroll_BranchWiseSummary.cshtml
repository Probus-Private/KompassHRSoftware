@model KompassHR.Areas.Reports.Models.BranchWiseSummary
@{
    ViewBag.Title = "Rpt_Payroll_BranchWiseSummary";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Business Unit Wise Summary
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Report_Payroll_RptMenu", "Report_Payroll_RptMenu", new {id = 6, ScreenId=455, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Business Unit Wise Summary</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Export report business unit wise summary.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" href="@Url.Action("Rpt_Attendance_WorkDuration", "Rpt_Attendance_WorkDuration" , new { area = "Reports" })" id="formAttendance_WorkDuration" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCmpId" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Business Unit
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "All", new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            From Month/Year
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.FromMonth, new { @class = "form-control", name = "FromMonth", type = "month", id = "GetFromMonth", @onchange = "validateDates()", @required = "The From Date Field Is Required" })
                                            <span id="errorMessage" style="color: red; display: none;">Error: From Month cannot be greater than To Month.</span>
                                            <span id="errorMessage3" style="color: red; display: none;">Error: From Month is Required.</span>

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            To Month/Year
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.ToMonth, new { @class = "form-control", name = "ToMonth", type = "month", id = "GetToMonth", @onchange = "validateDates()", @required = "The To Date Field Is Required" })
                                            @Html.ValidationMessageFor(model => model.ToMonth, "", new { @class = "help-block", @id = "ErrorToMonth", @style = "color:red" })
                                            <span id="errorMessage1" style="color: red; display: none;">Error: Cannot Be More Then 12 Monthss .</span>
                                            <span id="errorMessage2" style="color: red; display: none;">Error: To Month is Required.</span>

                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">

                            </div>

                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-10">
                                        </div>
                                        <div class="col-md-2">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                        <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                    </button>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        $('title').html("Payroll Branch Wise Summary");

        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        var today = new Date();
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('GetFromMonth').value;
        if (CheckEmptyDate == "") {
            document.getElementById('GetFromMonth').value = defaultMonth;
            document.getElementById('GetToMonth').value = defaultMonth;
        }


        var Title = @Html.Raw(Json.Encode(TempData["Title"]));
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            $(".Userloaderbg").css("display","none");
            if (Message != null) {
                var Text = "Your Download File Path Is "+Title+"";
                Swal.fire({
                    title: Message,
                    icon: Icon,
                    text: Text,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }


        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetMonthlyBusinessUnit", "Rpt_Payroll_BranchWiseSummary")',
                data: { CmpId: CmpId},
                success: function (data) {
                    debugger;
                    if (data.Branch !=null) {
                        $("#ddlBranchId").append("<option value=''>All</option>");
                        $.each(data.Branch, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
    });
</script>
<script>
    function downloadExcelFile() {
        debugger;
        errorMessage3.style.display = "none";
        errorMessage2.style.display = "none";
        var FromMonth = encodeURIComponent($("#GetFromMonth").val());
        var ToMonth = encodeURIComponent($("#GetToMonth").val());
        if (FromMonth=="")
        {
            errorMessage3.style.display = "inline";
        }
        if (ToMonth=="")
        {
            errorMessage2.style.display = "inline";
        }
        if(FromMonth!="" && ToMonth!=""){
            $(".Userloaderbg").css("display", "flex");
            var CmpId = encodeURIComponent($("#ddlCmpId").val());
            var branchId = encodeURIComponent($("#ddlBranchId").val());
            var FromMonth = encodeURIComponent($("#GetFromMonth").val());
            var ToMonth = encodeURIComponent($("#GetToMonth").val());
            var  ContractorId= encodeURIComponent($("#ddlContractorId").val());
            var  Title= "Salary Net Pay";
            var url = `@Url.Action("DownloadExcelFile", "Rpt_Payroll_BranchWiseSummary")?BranchId=${branchId}&FromMonth=${FromMonth}&ToMonth=${ToMonth}&CmpId=${CmpId}&Title=${Title}`;

            $.ajax({
                url: url,
                method: 'GET',
                xhrFields: {
                    responseType: 'blob' // Set the response type to blob
                },
                success: function(data) {
                    debugger;
                    $(".Userloaderbg").css("display", "none");
                    if(data.size==0)
                    {
                        Swal.fire({
                            icon: 'error',
                            text: 'Record Not Found',
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });
                        $(".Userloaderbg").css("display", "none");
                        return false;
                    }
                    var formattedDate = convertMonthYearFormat(FromMonth);
                    // Create a Blob from the response data
                    var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                    // Create a temporary anchor element to initiate the download
                    var anchorElement = document.createElement('a');
                    var url = window.URL.createObjectURL(blob);
                    anchorElement.href = url;
                    anchorElement.download = 'BusinessUnitWiseSummary('+formattedDate+').xlsx';
                    anchorElement.click();
                    // Clean up
                    window.URL.revokeObjectURL(url);
                },
                error: function(xhr, status, error) {
                    console.error('Error downloading file:', error);
                }
            });
        }

    }
</script>
<script>
        // JavaScript function to validate the date range
        function validateDates() {
            const fromDateInput = document.getElementById("GetFromMonth");
            const toDateInput = document.getElementById("GetToMonth");
            const errorMessage = document.getElementById("errorMessage");

            // Get the values of the input fields
            const fromDate = new Date(fromDateInput.value);
            const toDate = new Date(toDateInput.value);

            // Check if From Date is greater than To Date
            if (fromDate && toDate && fromDate > toDate) {
                // Show the error message
                errorMessage.style.display = "inline";
            }
            else {
                // Hide the error message if the date range is valid
                errorMessage.style.display = "none";
            }
            const maxToDate = new Date(fromDate);
            maxToDate.setMonth(fromDate.getMonth() + 11); // Add 12 months
            //const diffMonths = (toDate.getFullYear() - fromDate.getFullYear()) * 12 + toDate.getMonth() - fromDate.getMonth();
            // Check if To Date is more than 12 months after From Date
            if (toDate > maxToDate) {
                errorMessage1.style.display = "inline"; // Show error if To Date is more than 12 months after From Date
            } else {
                errorMessage1.style.display = "none"; // Hide error if the date range is valid
            }
        }
</script>

