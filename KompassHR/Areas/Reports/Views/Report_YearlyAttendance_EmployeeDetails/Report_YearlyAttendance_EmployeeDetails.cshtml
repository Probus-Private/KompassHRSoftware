@model KompassHR.Areas.Reports.Models.DailyAttendanceReportFilter
@{
    ViewBag.Title = "Report_YearlyAttendance_EmployeeDetails";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Yearly Attendance Details
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Report_YearlyAttendace_RptSubMenu", "Report_YearlyAttendace_RptSubMenu", new {id = 5, ScreenId=479, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Yearly Attendance Details</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" action="/Reports/Report_YearlyAttendance_EmployeeDetails/Report_YearlyAttendance_EmployeeDetails" id="formAYearlyAttendance_EmployeeDetails" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCmpId" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Business Unit
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Contractor Name
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.ContractorId, new SelectList(ViewBag.GetContractor, "Id", "Name"), "All", new { @class = "form-select", name = "ContractorId", id = "ddlContractorId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                           From Month/Year
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", name = "FromMonth", type = "month", id = "GetFromMonth" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                           To Month/Year
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", name = "ToMonth", type = "month", id = "GetToMonth" })
                                            <span id="ErrorFromDate" style="color:red;"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-10">
                                        </div>
                                        <div class="col-md-2">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                        <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                    </button>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('title').html("Yearly Attendance Report");

        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlContractorId").select2();
        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('GetFromMonth').value;
        if (CheckEmptyDate == "") {
            document.getElementById('GetFromMonth').value = defaultMonth;
            document.getElementById('GetToMonth').value = defaultMonth;
        }

        var Title = @Html.Raw(Json.Encode(TempData["Title"]));
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            $(".Userloaderbg").css("display","none");
            if (Message != null) {
                var Text = "Your Download File Path Is "+Title+"";
                Swal.fire({
                    title: Message,
                    icon: Icon,
                    text: Text,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }


        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            $("#ddlContractorId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var GetMonthYear = $("#GetFromMonth").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetMonthlyBusinessUnit", "Report_Attendance_RptMenu")',
                data: { CmpId: CmpId,GetMonthYear:GetMonthYear },
                success: function (data) {
                    debugger;
                    if (data.Branch !=null) {
                        $.each(data.Branch, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    if (data.GetContractorDropdown != null) {
                        $("#ddlContractorId").append("<option value=''>All </option>");
                        $.each(data.GetContractorDropdown, function (i, p) {
                            $("#ddlContractorId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlContractorId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var UnitBranchId = $("#ddlBranchId").val();
            var GetFromDate = $("#GetFromMonth").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetUnit", "Report_Attendance_RptMenu")',
                data: {CmpId:CmpId, UnitBranchId: UnitBranchId,GetFromDate:GetFromDate },
                success: function (data) {
                    debugger;
                    if (data == false) {
                        $("#ddlContractorId").find("option").remove();
                        $("#ddlContractorId").append("<option value=''>All </option>");
                    }
                    else {
                        var GetContractorDropdown = data.GetContractorDropdown;
                        if (GetContractorDropdown != null) {
                            $("#ddlContractorId").append("<option value=''>All </option>");
                            $.each(GetContractorDropdown, function (i, p) {
                                $("#ddlContractorId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                    }
                }
            })
        });

        $("#GetFromMonth, #GetToMonth").on("change", function () {
            // Clear previous error
            $("#ErrorFromDate").html("");

            var fromVal = document.getElementById("GetFromMonth").value;  // e.g. "2024-09"
            var toVal   = document.getElementById("GetToMonth").value;    // e.g. "2025-09"

            if (!fromVal || !toVal) {
                $("#ErrorFromDate").html("Both From and To must be selected.");
                return false;
            }

            // Parse year & month
            // The Date constructor “new Date("YYYY-MM")” gives first of that month in UTC (or locale) — enough for our comparisons.
            var fromDateObj = new Date(fromVal + "-01");  // add a day so JS can parse
            var toDateObj   = new Date(toVal + "-01");

            // Basic order check
            if (fromDateObj > toDateObj) {
                $("#ErrorFromDate").html("The From month must not be later than To month.");
                return false;
            }

            // Compute the maximum allowed “to” month = from + 12 months (i.e. one year ahead)
            var maxTo = new Date(fromDateObj);
            maxTo.setFullYear(maxTo.getFullYear() + 1);
            // Optionally subtract one month if you want “within 12 months inclusive” logic
            // e.g. if from = 2024‑09, maxTo = 2025‑09
            // (With setFullYear +1, you'll land in same month next year)

            if (toDateObj > maxTo) {
                $("#ErrorFromDate").html("The span should not exceed 12 months.");
                return false;
            }

            // If all validations pass, clear error
            $("#ErrorFromDate").html("");
            return true;
        });


    });
</script>

<script>


    function downloadExcelFile() {
        debugger;
      
        //var CmpId = $("#ddlCmpId").val();
        //var BranchId = $("#ddlBranchId").val();
        //var FromDate = $("#GetMonth").val();

        var branchId = encodeURIComponent($("#ddlBranchId").val());
        var fromDate = encodeURIComponent($("#GetFromMonth").val());
        var ToDate = encodeURIComponent($("#GetToMonth").val());
        var  ContractorId= encodeURIComponent($("#ddlContractorId").val());
        var fromDateObj = new Date(fromDate);
        var toDateObj = new Date(ToDate);

        //// Calculate time difference
        //var timeDifference = toDateObj.getTime() - fromDateObj.getTime();
        //var daysDifference = timeDifference / (1000 * 60 * 60 * 24) + 1;

        //// Validation: FromDate should not be greater than ToDate
        //if (fromDateObj > toDateObj) {
        //    $("#ErrorFromDate").html("Both dates should be within the year.");
        //    return false;
        //}

        //// Validation: Date difference should not exceed 31 days
        //if (daysDifference > 31) {
        //    $("#ErrorFromDate").html("The date range should not exceed 31 days.");
        //    return false;
        //}

        //// Validation: Both dates should belong to the same year
        //if (fromDateObj.getFullYear() !== toDateObj.getFullYear()) {
        //    $("#ErrorFromDate").html("Both dates should be within the year.");
        //    return false;
        //}

        // Clear the error message if validation passes
        $("#ErrorFromDate").html("");
        $(".Userloaderbg").css("display", "flex");

        var url = `@Url.Action("DownloadExcelFile", "Report_YearlyAttendance_EmployeeDetails")?BranchId=${branchId}&FromDate=${fromDate}&ContractorId=${ContractorId}&ToDate=${ToDate}`;
        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertMonthYearFormat(fromDate);
                var formattedToDate = convertMonthYearFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'YealyAttendanceEmployeeDetails('+formattedDate+' - '+formattedToDate+').xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }
</script>