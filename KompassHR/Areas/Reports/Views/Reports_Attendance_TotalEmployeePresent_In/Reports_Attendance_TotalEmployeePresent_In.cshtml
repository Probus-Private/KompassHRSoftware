        var ContractorId=encodeURIComponent($("#ddlContractorId").val());
        //var ToDate=encodeURIComponent($("#txtToDate").val());
        var url = `@Url.Action("Print", "Reports_Attendance_TotalEmployeePresent_In")?BranchId=${branchId}&CmpID=${CmpID}&DepartmentId=${DepartmentId}&SubDepartmentId=${SubDepartmentId}&DesignationId=${DesignationId}&GradeId=${GradeId}&LineId=${LineId}&SubUnitId=${SubUnitId}&EmployeeID=${EmployeeID}&FromDate=${FromDate}&ContractorId=${ContractorId}`;


        $.ajax({
            url: url,
            method: "GET",
            success: function (html) {
                $(".Userloaderbg").css("display", "none");

                // If empty file returned
                if (html.length === 0) {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found'
                    });
                    return;
                }
                //var rawMonth = document.getElementById('GetMonth').value;
                //if (rawMonth) {
                //    var dateObj = new Date(rawMonth + "-01");
                //  //  var formatted = dateObj.toLocaleString('default', { month: 'short', year: 'numeric' }); // "Jun 2025"
                //    $('title').html("Total Employee Present IN Report - (" + formatted + ")");
                //} else {

                //}
                $('title').html("Total Employee Present IN Report");
                var printFrame = document.createElement('iframe');
                printFrame.style.position = 'absolute';
                printFrame.style.left = '-9999px';
                document.body.appendChild(printFrame);

                var frameDoc = printFrame.contentWindow || printFrame.contentDocument;
                if (frameDoc.document) frameDoc = frameDoc.document;

                frameDoc.open();
                frameDoc.write(`<html><head><title>Print</title></head><body>${html}</body></html>`);
                frameDoc.close();

                printFrame.contentWindow.focus();
                printFrame.contentWindow.print();

                document.body.removeChild(printFrame);
            }
        });
    }
</script>