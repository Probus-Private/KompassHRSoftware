<script>
    function printDiv() {
        // Clone the div content to avoid modifying the original
        var divPrintClone = document.getElementById('divPrint').cloneNode(true);

        // Select the specific table (tbl) within the cloned content
        var table = divPrintClone.querySelector('table#tbl');
        if (!table) {
            console.error('Table with ID "tbl" not found in divPrint');
            return;
        }

        // Iterate over all rows in the table
        var rows = table.querySelectorAll('tr');
        rows.forEach(function (row) {
            // Hide the last three cells (Contractor Name, Created Date, Origin)
            var cells = row.querySelectorAll('td, th');
            if (cells.length >= 3) {
                cells[cells.length - 1].style.display = 'none'; // Origin
                cells[cells.length - 2].style.display = 'none'; // Created Date
                cells[cells.length - 3].style.display = 'none'; // Contractor Name
            }
        });

        // Prepare the print window
        var printWindow = window.open('', '', 'height=600,width=800');
        printWindow.document.write('<html><head><title>Print</title>');
        printWindow.document.write('<style>');
        // Set up A4 page size and portrait layout
        printWindow.document.write(
            '<style>' +
            '@@page {' +
                'size: A4 portrait; /* A4 size in portrait orientation */' +
                'margin: 20mm; /* Standard margin for A4 */' +
            '}' +
            'body {' +
                'font-family: Arial, sans-serif;' +
                'font-size: 12px;' +
                'margin: 0;' +
                'padding: 0;' +
            '}' +
            'table, th, td {' +
                'border: 1px solid black;' +
                'border-collapse: collapse;' +
            '}' +
            'th, td {' +
                'padding: 8px;' +
                'text-align: center;' +
            '}' +
            '#tblSummry td, #tblSummry th {' + // Specific alignment for tblSummry
                'text-align: left;' +
            '}' +
            '.text-nowrap {' +
                'white-space: nowrap;' +
            '}' +
            '.text-left {' +
                'text-align: left;' +
            '}' +
            '.text-center {' +
                'text-align: center;' +
            '}' +
            '</style>'
        );

        printWindow.document.write('</style></head><body>');

        // Write the modified cloned content into the print window
        printWindow.document.write(divPrintClone.innerHTML);
        printWindow.document.write('</body></html>');

        // Finalize and trigger the print
        printWindow.document.close();
        printWindow.print();
    }

