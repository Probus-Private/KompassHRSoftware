    .fixed-side {
        position: sticky !important;
        left: 0px !important;
        z-index: 1;
        min-width: 270px;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
