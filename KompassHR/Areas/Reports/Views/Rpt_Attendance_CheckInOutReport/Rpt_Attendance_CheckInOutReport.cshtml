                                                                     style="width:100%; height:100%; object-fit:cover;"
                                                                     onerror="this.src='@Url.Content("~/assets/img/user/Male.png")'" />                                                           }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                        <hr />

                                        if (punches != null)
