                                                                }
                                                    
                                                                else
                                                                {
                                                                    <img src="/Rpt_Attendance_CheckInOutReport/ViewSelfie?filePath=@firstItem.SelfiePath&Id=@firstItem.CheckInOutEmployeeId"
                                                                         style="width:100%; height:100%; object-fit:cover;"
                                                                         onerror="this.src='@Url.Content("~/assets/img/user/Male.png")'" />
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>


