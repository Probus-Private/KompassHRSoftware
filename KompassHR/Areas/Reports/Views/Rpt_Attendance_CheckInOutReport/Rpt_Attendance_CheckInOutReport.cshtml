@model KompassHR.Areas.Reports.Models.DailyAttendanceReportFilter

@{
    ViewBag.Title = "Rpt_Attendance_CheckInOutReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .font-bold {
        font-weight: 700 !important;
    }
</style>

<style type="text/css">
    @@media print {

        @@page {
            margin-top: -40px;
            margin-right: 0px;
            margin-left: 0px;
        }

        body {
            visibility: hidden;
        }

        .hidden-print {
            display: none;
        }

        .invoice {
            width: 100%;
            visibility: visible;
            position: absolute;
            top: 0px;
            left: 0;
            padding: 0px !important;
        }

        .invoice-company {
            font-size: 12px !important;
        }

        .invoice-content .invoice-details .heading {
            font-weight: 800;
            font-size: 10px !important;
        }

        .invoice-content .invoice-details .value {
            font-size: 10px !important;
        }

        .col-33 {
            width: 25%;
        }

        .col-40 {
            width: 35% !important;
        }

        .col-66 {
            width: 50%;
        }

        .col-44 {
            width: 20%;
        }

        .col-99 {
            width: 50%;
        }

        .col-55, .col-77 {
            width: 50%;
        }


        .invoice .invoice-footer {
            padding-top: 0;
            border-top: 1px solid black;
        }

        .invoice-Numbers {
            padding: 5px 0;
            margin-bottom: 0;
        }

        /*.ImgBox {
            margin-top: 5px;
            width: 60px;
        }*/

        .invoiceMargin {
            padding-bottom: 10px !important;
            margin-bottom: 10px !important;
            border-bottom: 1px solid #000000;
        }

        .invoice-Numbers {
            border-top: 1px solid black;
            border-bottom: 1px solid black;
        }



        /*.Instrunction {
            font-size: 10px;
        }*/
    }
</style>

