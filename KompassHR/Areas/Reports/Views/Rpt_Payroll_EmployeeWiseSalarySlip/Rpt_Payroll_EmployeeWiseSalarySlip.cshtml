@model KompassHR.Areas.Reports.Models.EmployeeWiseSalarySlip
@{
    ViewBag.Title = "Rpt_Payroll_EmployeeWiseSalarySlip";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 70px; /* Set the width for the first column */
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Employee Wise Salary Slip
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Report_Payroll_RptMenu", "Report_Payroll_RptMenu", new {id = 6, ScreenId=455, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">   Employee Wise Salary Slip</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" href="@Url.Action("Rpt_Payroll_EmployeeWiseSalarySlip", "Rpt_Payroll_EmployeeWiseSalarySlip" , new { area = "Reports" })" id="formEmployeeWiseSalarySlip" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            From Date
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", name = "FromDate", id = "txtFromDate", type = "month" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            To Date
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", type = "month", name = "ToDate", id = "txtToDate" })
                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Employee No
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.EmployeeNo, new { @class = "form-control", name = "EmployeeNo", type = "text", id = "EmployeeNo",Maxlength=10,autocomplete="Off" })
                                            <span id="errorMessage1" style="color: red; display: none;">Error: Month is Required.</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <div class="col-md-4">
                                            <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="ShowData()">
                                                Show
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                        <hr />
                        @if (ViewBag.GetUS80CEmployee != null)
                        {
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="empbx">
                                        <span>
                                            <h5><b>Employee Name :</b> @ViewBag.GetUS80CEmployee.EmployeeName -  @ViewBag.GetUS80CEmployee.EmployeeNo </h5>
                                        </span>
                                        <span>
                                            <h6> <b>Department :</b>  @ViewBag.GetUS80CEmployee.DepartmentName </h6>
                                        </span>
                                        <span>
                                            <h6> <b>Grade :</b> @ViewBag.GetUS80CEmployee.GradeName</h6>
                                        </span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="empbx">
                                        <span>
                                            <h6> <b>Business Unit :</b>  @ViewBag.GetUS80CEmployee.BranchName </h6>
                                        </span>
                                        <span>
                                            <h6> <b>Designation :</b>   @ViewBag.GetUS80CEmployee.DesignationName</h6>
                                        </span>
                                        <span>
                                            <h6> <b>Joining Date :</b> @ViewBag.GetUS80CEmployee.JoiningDate</h6>
                                        </span>
                                    </div>
                                </div>
                                <hr />
                            </div>
                        }
                       
                        <div class="row">
                            <div class="col-md-12">
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle tblAddData TablePage2" id="fixed-header" style="width: 100%;">
                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                <tr class="text-center">
                                                    <th class="text-center"> <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /> &nbsp; All</th>
                                                    <th hidden class="text-center">Salary Id</th>
                                                    <th class="text-center"> Month Year</th>
                                                    <th class="text-center">Business Unit</th>
                                                    <th class="text-center">Gross Earning</th>
                                                    <th class="text-center">Deduction</th>
                                                    <th class="text-center">Net Pay</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblEmployeeListEarning">
                                                @if (ViewBag.GetPaySlipList != null)
                                                {
                                                    foreach (var item in ViewBag.GetPaySlipList)
                                                    {
                                                        <tr>
                                                            <td class="text-center">
                                                                <input type="checkbox" class="form-check-input" />
                                                                @*<i class="fa-solid fa-eye fa-xl" style="color: #f59c1a; cursor: pointer;" onclick="ViewPaySlip(@item.SalaryID)" id="btnViewPaySlip"></i>
                                                                    &nbsp; | &nbsp;<i class="fas fa-file-pdf fa-xl" style="color: red; cursor: pointer;" onclick="ViewPaySlip(@item.SalaryID, 'PDF')"></i>
                                                                    <i class="fas fa-envelope fa-xl" style="color: #007bff; cursor: pointer;" onclick="ViewPaySlip(@item.SalaryID, 'Mail')"></i>*@

                                                            </td>
                                                            <td hidden>@item.SalaryID</td>
                                                            <td>@item.SalaryMonthYear</td>
                                                            <td>@item.BusinessUnit</td>
                                                            <td>@item.SalaryTotalGross</td>
                                                            <td>@item.SalaryTotalDeduction</td>
                                                            <td>@item.SalaryNetPay</td>
                                                        </tr>
                                                    }
                                                }

                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="BtnBx">
                                    <div>
                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm" onclick="SendMail()">
                                            <i class="fa-solid fa-paper-plane"></i> Send Mail
                                        </button>
                                        <button type="button" class="btn btn-danger btn-sm" id="" onclick="Print()">
                                            <i class="fa-solid fa-print"></i> Print
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var today = new Date();
        var yyyy = today.getFullYear();

        var fromMonth = '01';
        var fromDefaultDate = yyyy + '-' + fromMonth;
        var toMonth = '12';
        var toDefaultDate = yyyy + '-' + toMonth;

        var fromDateValue = document.getElementById('txtFromDate').value;
        var toDateValue = document.getElementById('txtToDate').value;

        if (fromDateValue.trim() === "") {
            document.getElementById('txtFromDate').value = fromDefaultDate;
        }

        if (toDateValue.trim() === "") {
            document.getElementById('txtToDate').value = toDefaultDate;
        }

    });






    $('#formEmployeeWiseSalarySlip').validate({
        rules: {
            FromDate: {
                required: true,
            },
            ToDate: {
                required: true,
            },

            EmployeeNo: {
                required: true,
            },
        },
        messages: {
            FromDate: {
                required: "From date is required",
            },
            ToDate: {
                required: "To Date is required",
            },
            EmployeeNo: {
                required: "Employee No is required",
            },
        },
    });
    var form = $("#formEmployeeWiseSalarySlip");
    form.validate();
    function ShowData() {
        form.valid();
        if (form.valid() == false) {
            $("#txtFromDate").removeClass("error");
            $("#txtToDate").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#formEmployeeWiseSalarySlip").submit();
    }

    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>