            Month: {
                required: true,
            },
        },
        messages: {
            //CmpId: {
            //    required: "Company name is required",
            //},
            //BranchId: {
            //    required: "Business unit is required",
            //},
            //EmployeeId: {
            //    required: "Employee is required",
            //},
            Month: {
                required: "Month is required",
            },
        },
    });

    var form = $("#formMyAttendance");
    form.validate();
    function funEmployeeWiseReport() {
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#formMyAttendance").submit();
    }
</script>