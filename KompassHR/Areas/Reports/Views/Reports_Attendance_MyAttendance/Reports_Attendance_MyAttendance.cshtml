</div>

<script>
    function printDiv() {
        var divElements = document.getElementById('divPrint').innerHTML;
        var printWindow = window.open('', '', 'height=600,width=800');

        printWindow.document.write('<html><head><title>Print</title>');
        printWindow.document.write('<style>');
        printWindow.document.write('table, th, td { border: 1px solid black; border-collapse: collapse; }');
        printWindow.document.write('th, td { padding: 8px;}');
        printWindow.document.write('.text-nowrap { white-space: nowrap; }');
        printWindow.document.write('.text-left { text-align: left; }');
        //printWindow.document.write('.text-center { text-align: center; }');
        printWindow.document.write('</style></head><body>');
        printWindow.document.write(divElements);
        printWindow.document.write('</body></html>');

        printWindow.document.close();
        printWindow.print();
    }


</script>

<script>

    $(document).ready(function () {
        //$("#ddlCmpId").select2();
        //$("#ddlEmployeeId").select2();
        //$("#txtBranchId").select2();
        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month

        var CheckEmptyDate = document.getElementById('GetMonth').value;
        if(CheckEmptyDate =="")
        {
            document.getElementById('GetMonth').value = defaultMonth;
        }


        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Rpt_EmployeeWise_Attendance")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        //$("#txtBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data.Branch, function(i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#txtBranchId").change(function () {
            debugger;
            $("#ddlEmployeeId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var BranchId = $("#txtBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "Rpt_EmployeeWise_Attendance")',
                data: { BranchId: BranchId , CmpId:CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlEmployeeId").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });
    });//Ready Funcation
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formMyAttendance').validate({
        rules: {
            //CmpId: {
            //    required: true,
            //},
            //BranchId: {
            //    required: true,
            //},
            //EmployeeId: {
            //    required: true,
