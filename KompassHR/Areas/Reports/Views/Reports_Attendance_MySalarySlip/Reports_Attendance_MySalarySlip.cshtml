<script>
    function ViewPaySlip(SalaryID, format,EmpId) {
        debugger
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            url: '@Url.Action("GetPaySlipDetails", "Reports_Attendance_MySalarySlip")',
            data: { SalaryID: SalaryID },
            success: function (response) {
                debugger;
                const json = response.GetPersonal[0];
                const transformed = {
                    GetPersonal: Object.fromEntries(
                        json.map(item =>[item.Key, item.Value])
                    )
                };
                $(".Userloaderbg").css("display", "none");
                var GetData = transformed.GetPersonal;

                //$("#EmpId").html(GetData.EmployeeId);
                $("#EmpName").html(GetData.EmployeeName);
                $("#EmpNo").html(GetData.EmployeeNo);
                $("#EmpDepartment").html(GetData.Department);
                $("#EmpDesignation").html(GetData.Designation);
                $("#EmpGrade").html(GetData.Grade);
                $("#EmpDOJ").html(GetData.JoiningDate);
                $("#EmpBankName").html(GetData.BankName);
                $("#EmpBankAccountNo").html(GetData.AccountNo);
                $("#EmpIFSCCode").html(GetData.IFSCCode);
                $("#EmpPFNo").html(GetData.PFNo);
                $("#EmpUANNo").html(GetData.UAN);
                $("#EmpESICNo").html(GetData.ESIC);
                $("#EmpLINNo").html(GetData.LIN);
                $("#EmpAadhaarNo").html(GetData.AadhaarNo);
                $("#EmpPANNo").html(GetData.PAN);

                $("#spnCompanyName").html(GetData.CompanyName);
                $("#spnBranchName").html(GetData.BranchName);
                $("#spnNetPay").html(GetData.NetPay);

                $("#spnMonth").html(GetData.SalaryMonthYear);
                $("#spnAddress").html(GetData.BranchAddress);

                $("#lblMonthDays").html(GetData.SalaryMonthDays);
                $("#lblPaidDays").html(GetData.SalaryPayableDays);

                $("#spnStandardAmt").html(GetData.TotalStandardGross);
                $("#spnEarningAmt").html(GetData.TotalGross);
                $("#spnDeductionAmt").html(GetData.TotalDeduction);

                //BIND ATTENDANCE DETAILS
                var GetAttendanceData = response.GetAttendance;
                let html = "";
                let columnCount = 0; // Track the number of columns in a row

                GetAttendanceData.forEach((item) => {
                    if (columnCount === 0) {
                        html += "<tr>";
                    }
                    html += `<td class="attend-type"><b> ${item.AttenType} :</b></td><td>${item.Total}</td>`;
                    columnCount += 2; // Increment column count (2 columns per item)
                    // Close the current row after 4 columns (2 pairs of Head and DeductionAmt)
                    if (columnCount === 14) {
                        html += "</tr>";
                        columnCount = 0; // Reset column count for the next row
                    }
                });
                // Only add the last row if it contains exactly 4 columns
                if (columnCount !== 0) {
                    html += "</tr>";
                }
                document.getElementById("tblAttendanceInfo").innerHTML = html;

                var GetEarningData = response.GetEarning;
                var GetDeductionData = response.GetDeduction;

                var tableBody = $('#tblCombined tbody');
                tableBody.empty(); // Clear existing rows

                // Iterate over the longer array to ensure all data is displayed
                var maxLength = Math.max(GetEarningData.length, GetDeductionData.length);

                for (var i = 0; i < maxLength; i++) {
                    var earning = GetEarningData[i] || {}; // Default to empty object if out of bounds
                    var deduction = GetDeductionData[i] || {}; // Default to empty object if out of bounds

                    var row = $('<tr>');
                    row.append('<td style="text-align: left;">' + (earning.Head || '') + '</td>');
                    row.append('<td style="text-align: right;">' + (earning.StandardAmt || '') + '</td>');
                    row.append('<td style="text-align: right;">' + (earning.EarningAmt || '') + '</td>');
                    row.append('<td hidden>' + (earning.ArreasAmt || '') + '</td>');
                    row.append('<td style="text-align: left;">' + (deduction.Head || '') + '</td>');
                    row.append('<td style="text-align: right;">' + (deduction.DeductionAmt || '') + '</td>');

                    tableBody.append(row);
                }
                if (format == 'PDF') {
                    generatePDF();
                    return false;
                }
                else if (format == 'Mail') {
                    generateAndSendPDF(EmpId);
                    return false;
                }
                else {
                    $('#PayslipMDL').modal('show');
                }
            }
        })
    }

