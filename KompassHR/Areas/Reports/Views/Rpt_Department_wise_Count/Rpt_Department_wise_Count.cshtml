@model KompassHR.Areas.Reports.Models.EmployeeWiseReportFilter
@{
    ViewBag.Title = "Rpt_Department_wise_Count";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }



    .table-wrap {
        max-height: 300px; /* Set max height for the whole table container */
        overflow: auto; /* Enable both horizontal and vertical scrolling */
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 8px;
        border: 1px solid #ddd;
        text-align: left;
    }

    th {
        position: sticky;
        top: 0;
        background-color: #f2f2f2;
    }

    .table-body-scroll {
        max-height: 200px; /* Set max height for the body to enable vertical scrolling */
        overflow-y: auto; /* Enable vertical scrolling */
    }
</style>



<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Reports/Report_Attendance_RptMenu/Report_Attendance_RptMenu">Report Menu</a></li>
    </ol>
    <h1 class="page-header"> Department Wise Report </h1>
    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Department Wise Report</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row justify-content-center">
                            @*<hr class="mt-15px">*@
                            <div class="row justify-content-center">
                                <form role="form" action="/Reports/Rpt_Department_wise_Count/Rpt_Department_wise_Count" id="formDepartmentWiseReport" method="post">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Company Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyName, "Id", "Name"), new { @id = "ddlCompanyName", name = "CmpID", @class = "form-select", autocomplete = "off" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Bunieness Unit
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--All--", new { @id = "txtBranchId", name = "LeaveOpeningBalanceBranchID", @class = "form-select", autocomplete = "off" })
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Date
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", name = "FromDate", type = "date", id = "FromDate" })
                                                </div>
                                            </div>
                                        </div>
                                        @*<div class="col-md-5">
                                                <div class="row mb-15px">
                                                    <label class="form-label col-form-label col-md-4">
                                                        To Date
                                                    </label>
                                                    <div class="col-md-8">
                                                        @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", name = "ToDate", type = "date", id = "ToDate" })
                                                    </div>
                                                </div>
                                            </div>*@
                                        <div class="col-md-2">
                                            <div class="row mb-15px">
                                                <div class="col-md-8">
                                                    <button type="button" onclick="DeptWiseReport()" class="btn btn-sm btn-success">Show</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <hr class="mt-15px">
                        <div class="row">
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="tbl" style="width: 100%;">
                                        <thead>
                                            <tr class="trheading">
                                                @*<th class="text-nowrap text-center">Branch ID</th>*@
                                                @*<th class="text-nowrap text-center">Branch Name</th>*@
                                                @*<th class="text-nowrap text-center">Department ID</th>*@
                                                <th class="text-nowrap text-center"> Department Name</th>
                                                <th class="text-nowrap text-center">Total Employee </th>
                                                <th class="text-nowrap text-center">Total Leave</th>
                                                <th class="text-nowrap text-center">Total OutDoor</th>
                                                <th class="text-nowrap text-center">Total Present</th>
                                                <th class="text-nowrap text-center">Total Absent</th>
                                                <th class="text-nowrap text-center">Total WFH</th>
                                                <th class="text-nowrap text-center">TotalWO</th>
                                                @*<th class="text-nowrap text-center">Unit ID</th>*@
                                                <th class="text-nowrap text-center">Unit Name</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblDeptWiseReport" class="table-body-scroll">
                                            @foreach (var d in ViewBag.DepartmentWiseReport)
                                            {
                                                <tr>
                                                    @*<td class="text-nowrap">@d.BranchID</td>*@
                                                    @*<td class="text-nowrap">@d.BranchName</td>*@
                                                    @*<td class="text-nowrap">@d.DepartmentID</td>*@
                                                    <td class="text-nowrap">@d.DepartmentName</td>
                                                    <td class="text-nowrap">@d.TotalEmployee</td>
                                                    <td class="text-nowrap">@d.TotalLeave</td>
                                                    <td class="text-nowrap">@d.TotalOutDoor</td>
                                                    <td class="text-nowrap">@d.TotalPresent</td>
                                                    <td class="text-nowrap">@d.TotalAbsent</td>
                                                    <td class="text-nowrap">@d.TotalWFH</td>
                                                    <td class="text-nowrap">@d.TotalWO</td>
                                                    @*<td class="text-nowrap">@d.UnitID</td>*@
                                                    <td class="text-nowrap">@d.UnitName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $('#tbl').DataTable({
    lengthMenu: [20, 40, 60],
    fixedHeader: {
      header: true,
      headerOffset: $('#header').height()
    },
    responsive: true
  });
</script>
<script>

    $(document).ready(function () {
       var a = "01-04-2024 To 30-04-2024"
        $('title').html("Department Wise Report ("+(a)+")");
        $("#ddlCompanyName").select2();
        $("#txtBranchId").select2();
        document.getElementById('FromDate').value = SetTodaysDate;

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Rpt_Department_wise_Count")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        //$("#txtBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#txtBranchId").find("option").remove();
        var CmpId = $("#ddlCompanyName").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: '@Url.Action("GetBusinessUnit", "Rpt_Department_wise_Count")',
            data: { CmpId: CmpId },
            success: function (data) {
                debugger;
                if (data !=null) {
                    //$("#txtBranchId").append("<option value=0>--Select-- </option>");
                    $.each(data, function(i, p) {
                        $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                    });
                }
                else {
                    $('#ErrorESSPassword').html(" ");
                }
            }
        })
        var CmpId = $("#ddlCompanyName").val();
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: '@Url.Action("GetBusinessUnit", "Rpt_Department_wise_Count")',
            data: { CmpId: CmpId },
            success: function (data) {
                debugger;
                $("#txtBranchId").find("option").remove();
                if (data !=null) {
                   // $("#txtBranchId").append("<option value=0>--All-- </option>");
                    $.each(data, function(i, p) {
                        $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                    });
                }
                else {
                    $('#ErrorESSPassword').html(" ");
                }
            }
        })

        $("#txtBranchId").change(function () {
            debugger;
            $("#ddlEmployeeName").find("option").remove();
            var BranchId = $("#txtBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetEmployeeName',
                data: { BranchId: BranchId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlEmployeeName").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });
    });//Ready Funcation
</script>
<script>
    
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formDepartmentWiseReport').validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            FromDate: {
                required: true,
            },
            //ToDate: {
            //    required: true,
            //},
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            BranchId: {
                required: "Business unit is required",
            },
            FromDate: {
                required: "From date is required",
            },
            //ToDate: {
            //    required: "To date is required",
            //},
        },
    });

    var form = $("#formDepartmentWiseReport");
    form.validate();
    function DeptWiseReport() {
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#formDepartmentWiseReport").submit();
    }
</script>