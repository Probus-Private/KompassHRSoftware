<script>
    $(document).ready(function () {
        $('title').html("Contractor Wise Monthly Head Count Report");
        var CheckEmptyDate = document.getElementById('txtFromDate').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtFromDate').value = SetTodaysDate;
            document.getElementById('txtToDate').value = SetTodaysDate;
        }

        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Reports_Attendance_ContractorWiseMonthlyHeadCount")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        $("#ddlBranchId").append("<option value=0>All </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        var ShowData = @Html.Raw(Json.Encode(TempData["ShowData"]));
        if(ShowData!=true)
        {

            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Reports_Attendance_ContractorWiseMonthlyHeadCount")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        // $("#ddlBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        }

        $("#txtFromDate, #txtToDate").on("change", function () {
            debugger;
            var input = document.getElementById("txtFromDate").value;
            var input1 = document.getElementById("txtToDate").value;
            //define two date object variables with dates inside it
            fromDateObj = new Date(input);
            toDateObj = new Date(input1);
            //calculate time difference
            var time_difference = toDateObj.getTime() - fromDateObj.getTime();
            //calculate days difference by dividing total milliseconds in a day
            var days_differences = time_difference / (1000 * 60 * 60 * 24);
            var days_difference = days_differences + 1;
            // Check if toDate is greater than fromDate
            var from = $("#txtFromDate").val();
            var to = $("#txtToDate").val();
            if (Date.parse(from) > Date.parse(to)) {

                $("#ErrortxtFromDate").html("From date should not be greater than todate");
                return false;
            }
            else {
                $("#ErrortxtFromDate").html("");
            }
            if (days_difference > 31) {
                $("#ErrortxtFromDate").html("You should not allow greter than 31 days");
            }
        });



        $('#tblContractorWiseMonthly').DataTable({
            //dom: 'Bfrtip',
            dom: '<"row"<"col-sm-4"B><"col-sm-4"l><"col-sm-4"f>>' + 't' + '<"row"<"col-sm-6"l><"col-sm-6">>',
            buttons: [
              {
                  extend: 'excel',
                  text: 'Excel',
                  customize: function (xlsx) {
                      var $sheet = $(xlsx.xl.worksheets['sheet1.xml']);

                      // Loop through each row in the sheet
                      $sheet.find('row').each(function (index) {
                          // Apply different styles to different rows
                          if (index == 0) {
                              $(this).find('c').attr('s', '2'); // Bold font
                          } else if (index == 1) {
                              $(this).find('c').attr('s', '5'); // Change background color
                          }
                          else {
                              $(this).find('c').attr('s', '25'); // Apply Border
                          }
                      });


                  }
              },
               'copy',
               'csv',
                'pdf',
                'print'
            ],
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
            select:true,

        });

    });//Ready Funcation
</script>


<script>
    function downloadExcelFile() {
        $(".Userloaderbg").css("display", "flex");
        //var CmpId = $("#ddlCmpId").val();
        //var BranchId = $("#ddlBranchId").val();
        //var FromDate = $("#txtFromDate").val();
        //var ToDate = $("#txtToDate").val();

        var FromDate = encodeURIComponent($("#txtFromDate").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        var CmpId = encodeURIComponent($("#ddlCmpId").val());
        var ToDate=encodeURIComponent($("#txtToDate").val());
        var url = `@Url.Action("DownloadExcelFile", "Reports_Attendance_ContractorWiseMonthlyHeadCount")?BranchId=${BranchId}&CmpId=${CmpId}&FromDate=${FromDate}&ToDate=${ToDate}`;

        // Create a full URL with query parameters
        //var url = '/Reports_Attendance_ContractorWiseMonthlyHeadCount/DownloadExcelFile?BranchId=' + encodeURIComponent(BranchId)+ '&CmpId=' + encodeURIComponent(CmpId)+'&FromDate='+encodeURIComponent(FromDate)+'&ToDate='+encodeURIComponent(ToDate);
        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertDateFormat(FromDate);
                var ToformattedDate = convertDateFormat(ToDate);

                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'ContractorWiseMonthlyHeadCount('+formattedDate +' - '+ ToformattedDate+').xlsx';
                anchorElement.click();
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }
</script>

