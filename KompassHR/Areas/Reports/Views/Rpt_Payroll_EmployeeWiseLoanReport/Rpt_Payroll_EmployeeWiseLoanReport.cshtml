<script>
    $(document).ready(function () {
        $('title').html("Yearly Month Wise Loan Report");
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlEmployeeId").select2();

        var Title = @Html.Raw(Json.Encode(TempData["Title"]));
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            $(".Userloaderbg").css("display","none");
            if (Message != null) {
                var Text = "Your Download File Path Is "+Title+"";
                Swal.fire({
                    title: Message,
                    icon: Icon,
                    text: Text,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500000)
                        return false
                    }
                });
            }
        }


        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            $("#GetFromYear").find("option").remove();
            $("#ddlEmployeeId").find("option").remove();
           // $("#ddlContractorId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Rpt_Payroll_EmployeeWiseLoanReport")',
                data: { CmpId: CmpId},
                success: function (data) {
                    debugger;
                    if (data.Branch !=null) {
                        $("#ddlBranchId").append("<option value=0>All </option>");
                        $.each(data.Branch, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    if (data.YearList !=null) {
                        $("#GetFromYear").append("<option value=0>--Select-- </option>");
                        $.each(data.YearList, function(i, p) {
                            $("#GetFromYear").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    if (data.Employee !=null) {
                        $("#ddlEmployeeId").append("<option value=0>--Select-- </option>");
                        $.each(data.Employee, function(i, p) {
                            $("#ddlEmployeeId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }

                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlBranchId").on("change", function () {
            debugger;
          //  $("#ddlBranchId").find("option").remove();
          //  $("#GetFromYear").find("option").remove();
            $("#ddlEmployeeId").find("option").remove();
           
            var CmpId = $("#ddlCmpId").val();
            var BranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployee", "Rpt_Payroll_EmployeeWiseLoanReport")',
                data: { CmpId: CmpId,BranchId:BranchId},
                success: function (data) {
                    debugger;
               
                    if (data.Employee !=null) {
                        $("#ddlEmployeeId").append("<option value=0>--Select-- </option>");
                        $.each(data.Employee, function(i, p) {
                            $("#ddlEmployeeId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }

                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


    });
</script>

<script>
 
        jQuery.validator.addMethod(
        "regex",
         function(value, element, regexp) {
             if (regexp.constructor != RegExp)
                 regexp = new RegExp(regexp);
             else if (regexp.global)
                 regexp.lastIndex = 0;
             return this.optional(element) || regexp.test(value);
         },"erreur expression reguliere"
      );

        $('#formMonthWiseBonus').validate({
            rules: {
                CmpId: {
                    required: true,
                },
                BranchId: {
                    required:true,
                },
                EmployeeId:{
                    required:true,
                  
                },
                FromDate:{
                    required:true,
                },
               
            },
            messages: {
                CmpId: {
                    required:"Company name is required",
                },
                BranchId: {
                   
                    required:"Buisness Unit is required",
                
                },
                EmployeeId: {
                    required:"Employee Name  is required",
                
                },
                FromDate:{
                    required:"Loan Year is required",
                }
               
            },
        });

        var form = $("#formMonthWiseBonus");
        form.validate();
        //$("#btnsubmit").click(function () {
        function ViewData() {
            debugger;

            form.valid();
            if(form.valid()==false)
            {
                $("#txtEstablishedDate").removeClass("error");
                return false;
            }

            var CmpId = encodeURIComponent($("#ddlCmpId").val());
            var BranchId = encodeURIComponent($("#ddlBranchId").val());
            var EmployeeId = encodeURIComponent($("#ddlEmployeeId").val());
            var FromYear = encodeURIComponent($("#GetFromYear").val());

            var url = '@Url.Action("ViewData", "Rpt_Payroll_EmployeeWiseLoanReport")'
                             + '?EmployeeId=' + EmployeeId
                             + '&FromYear=' + FromYear
                             + '&BranchId=' + BranchId
                             + '&CmpId=' + CmpId;
            window.location.href = url;
        }
</script>




