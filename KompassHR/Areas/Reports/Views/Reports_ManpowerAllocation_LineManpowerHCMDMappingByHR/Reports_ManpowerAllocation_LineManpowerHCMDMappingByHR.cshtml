@model KompassHR.Areas.ESS.Models.ESS_ManpowerAllocation.Manpower_HC_MDMapping

@{
    ViewBag.Title = "Reports_ManpowerAllocation_LineManpowerHCMDMappingByHR";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        color: black !important;
    }


    .select2-container--default .select2-selection--single .select2-selection__placeholder {
        color: black !important;
    }


    .select2-container--default .select2-results__option {
        color: black !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Line Manpower HC/MD Mapping Report By HR
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports_ManpowerAllocation_Menu", "Reports_ManpowerAllocation_Menu",  new {id =35, ScreenId=288, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title">Line Manpower HC/MD Mapping Report By HR</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Reports_ManpowerAllocation_ContractorWiseRate", "Reports_ManpowerAllocation_ContractorWiseRate", new { area = "Reports" })' id="SaveContractorWiseRate" method="post" enctype="multipart/form-data">

                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <div class="row mb-12px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "-- Select --", new { @class = "form-select", type = "text", name = "CmpId", id = "ddlCmpId" })
                                                <span id="ErrorddlCmpId" style="color:red"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <div class="row mb-12px">
                                            <label class="form-label col-form-label col-md-4">
                                                Buisness Unit
                                                <span class="important">*</span>
                                            </label>

                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "-- Select --", new { @class = "form-select", type = "text", name = "CmpId", id = "ddlBranchId", onchange = "OnBUChange()" })
                                                <span id="ErrorddlBranchId" style="color:red"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">                                    
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                 Date <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Date, new { @class = "form-control", name = "Date", type = "date", id = "txtDate" })
                                            </div>
                                        </div>
                                    </div>                                    
                                </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-10">
                                            </div>
                                            <div class="col-md-2">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                            <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        debugger
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Reports_ManpowerAllocation_LineManpowerHCMDMappingByHR")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            });
        });
    });



    function downloadExcelFile() {
        debugger;
        
        $(".Userloaderbg").css("display", "flex");
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var Date = $("#txtDate").val();
        var url = `@Url.Action("DownloadExcelFile", "Reports_ManpowerAllocation_LineManpowerHCMDMappingByHR")?CmpId=${CmpId}&BranchId=${BranchId}&Date=${Date}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function (data) {
                debugger;
                if (data.size == 0) {
                    debugger;
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                   $(".Userloaderbg").css("display", "none");
                    return false;
                }
                else {
                    var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                    // Create a temporary anchor element to initiate the download
                    var anchorElement = document.createElement('a');
                    var url = window.URL.createObjectURL(blob);
                    anchorElement.href = url;
                    anchorElement.download = 'Line_ManpowerCategoryHC_MDMapping.xlsx';
                    anchorElement.click();
                    // Clean up
                    window.URL.revokeObjectURL(url);
                    $(".Userloaderbg").css("display", "none");
                }
                
            },
            error: function (xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }
   
</script>