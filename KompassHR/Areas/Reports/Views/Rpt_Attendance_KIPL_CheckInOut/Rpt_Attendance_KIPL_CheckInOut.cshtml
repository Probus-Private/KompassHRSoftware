<script>
    function downloadExcelFile() {
    debugger
        $("#errCmpId, #errBranchId, #errEmployeeId, #errFromDate , #errToDate").text("");

        var isValid = true;

        // Get Values
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var EmployeeId = $("#ddlEmployeeId").val();
        var FromDate = $("#txtFromDate").val();
        var ToDate = $("#txtToDate").val();

        // Validations
        if (CmpId === "" || CmpId === null) {
            $("#errCmpId").text("Please select company");
            isValid = false;
        }

        if (BranchId === "" || BranchId === null || BranchId === "0") {
            $("#errBranchId").text("Please select business unit");
            isValid = false;
        }

        //if (EmployeeId === "" || EmployeeId === null) {
        //    $("#errEmployeeId").text("Please select Employee");
        //    isValid = false;
        //}

        if (FromDate === "" || FromDate === null) {
            $("#errFromDate").text("Please select  From Date");
            isValid = false;
        }

        if (ToDate === "" || ToDate === null) {
            $("#errToDate").text("Please select  To Date");
            isValid = false;
        }

        function parseDate(input) {
            var parts = input.split("-"); 
            return new Date(parts[0], parts[1] - 1, parts[2]); 
        }

        var today = new Date();
        today.setHours(0, 0, 0, 0);

        var from = parseDate(FromDate);
        var to = parseDate(ToDate);

        // From Date > Today
        if (from > today) {
            $("#errFromDate").text("From Date cannot be greater than today");
            isValid = false;
        }

        // To Date > Today
        if (to > today) {
            $("#errToDate").text("To Date cannot be greater than today");
            isValid = false;
        }

        // From > To
        if (from > to) {
            $("#errToDate").text("To Date cannot be earlier than From Date");
            isValid = false;
        }

        if (!isValid) {
            $(".Userloaderbg").css("display", "none");
            return;
        }

  //  $(".Userloaderbg").css("display", "flex");

    //var CmpId = encodeURIComponent($("#ddlCmpId").val());
    //var BranchId = encodeURIComponent($("#ddlBranchId").val());
    //var ContractorId = encodeURIComponent($("#ddlContractorId").val());
    //var InvoiceMonth = encodeURIComponent($("#txtInvoiceMonth").val());



    var url = `@Url.Action("DownloadExcelFile", "Rpt_Attendance_KIPL_CheckInOut")?BranchId=${BranchId}&EmployeeId=${EmployeeId}&CmpId=${CmpId}&FromDate=${FromDate}&ToDate=${ToDate}`;

    $.ajax({
        url: url,
        method: 'GET',
        xhrFields: { responseType: 'blob' },
        success: function (data, status, xhr) {

            $(".Userloaderbg").css("display", "none");

            // Check file name
            var disposition = xhr.getResponseHeader("Content-Disposition");
            if (disposition && disposition.indexOf("FileNotFound.txt") !== -1) {
                Swal.fire({ icon: 'error', text: 'Record Not Found' });
                return;
            }

            // Download normally
            var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
            var downloadUrl = URL.createObjectURL(blob);

            var a = document.createElement('a');
            a.href = downloadUrl;
            a.download = 'KIPLCheckInOutReport.xlsx';
            a.click();

            URL.revokeObjectURL(downloadUrl);
        },
        error: function (xhr, status, error) {
            console.error('Error downloading file:', error);
            $(".Userloaderbg").css("display", "none");
        }
    });
}
</script>