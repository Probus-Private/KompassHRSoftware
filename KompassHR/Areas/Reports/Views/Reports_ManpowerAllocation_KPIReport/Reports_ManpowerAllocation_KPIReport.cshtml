@model KompassHR.Areas.Reports.Models.DailyAttendanceReportFilter
@{
    ViewBag.Title = "Reports_ManpowerAllocation_KPIReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>


<style>
    .Col-md-2 {
        margin: 10px 0;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>
<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Reports/Reports_ManpowerAllocation_Menu/Reports_ManpowerAllocation_Menu">Report Menu</a></li>
    </ol>
    <h1 class="page-header"> KPI Report </h1>
    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ KPI Report  </h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row">
                            <div class="col-md-12">
                                <form role="form" action="/Reports/Reports_ManpowerAllocation_KPIReport/Reports_ManpowerAllocation_KPIReport" id="SaveKPIReport" method="post">
                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    Company Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-9">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtCmpId", type = "text", name = "CmpId" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                    Business Unit
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-9">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "txtBranchId", type = "text", name = "BranchId" })
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-3">
                                                  Month
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-9">
                                                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", id = "txtFromDate", type = "month", name = "FromDate" })
                                                </div>
                                            </div>
                                        </div>                                        
                                        <div class="col-md-2">
                                            <div class="row mb-15px">
                                                <div class="col-md-4">
                                                    <button type="button" class="btn btn-primary btn-sm" id="btnload" onclick="LoadEmployee()">
                                                        @*<i class="fa-solid fa-share-from-square"></i>*@ Show
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                              
                                <div class="row">
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="" style="width: 100%;">
                                                <thead>
                                                    <tr class="trheading">
                                                        <th class="text-nowrap text-center">Category </th>
                                                        <th colspan="2" class="text-nowrap text-center">R1 </th>
                                                        <th colspan="2" class="text-nowrap text-center">R2 </th>
                                                        <th colspan="2" class="text-nowrap text-center">R3 </th>
                                                        <th colspan="2" class="text-nowrap text-center">Average Of <br />R1,R2,R3</th>
                                                        <th colspan="2" class="text-nowrap text-center">Average Manpower <br />Used Per Day</th>
                                                        <th colspan="2" class="text-nowrap text-center">Total </th>
                                                        <th colspan="2" class="text-nowrap text-center">Average </th>
                                                        

                                                    </tr>
                                              
                                                    <tr class="trheading">
                                                        <th class="text-nowrap text-center"> </th>
                                                        <th class="text-nowrap text-center">From   </th>
                                                        <th class="text-nowrap text-center">To  </th>
                                                        <th class="text-nowrap text-center">From   </th>
                                                        <th class="text-nowrap text-center">To  </th>
                                                        <th class="text-nowrap text-center">From   </th>
                                                        <th class="text-nowrap text-center">To  </th>
                                                        <th class="text-nowrap text-center">From   </th>
                                                        <th class="text-nowrap text-center">To  </th>
                                                        <th class="text-nowrap text-center">   </th>
                                                        <th class="text-nowrap text-center">  </th>
                                                        <th class="text-nowrap text-center">   </th>
                                                        <th class="text-nowrap text-center">  </th>
                                                        <th class="text-nowrap text-center">   </th>
                                                        <th class="text-nowrap text-center">  </th>
                                                      
                                                    </tr>

                                              
                                                    <tr class="trheading">
                                                        <th class="text-nowrap text-center"> </th>
                                                        <th class="text-nowrap text-center">IED-HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">IED-MD<br /> (8 HRS.) </th>
                                                        <th class="text-nowrap text-center">IED-HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">IED-MD <br />(8 HRS.) </th>
                                                        <th class="text-nowrap text-center">IED-HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">IED-MD <br />(8 HRS.) </th>
                                                        <th class="text-nowrap text-center">IED-HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">IED-MD <br />(8 HRS.) </th>
                                                        <th class="text-nowrap text-center">Plant-HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">Plant-MD <br />(8 HRS.) </th>
                                                        <th class="text-nowrap text-center">HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">MD <br />(8 HRS.) </th>
                                                        <th class="text-nowrap text-center">HC <br />(12 HRS.)  </th>
                                                        <th class="text-nowrap text-center">MD <br />(8 HRS.) </th>
                                                        
                                                    </tr>
                                                </thead>
                                                <tbody id="tblKPIReports">
                                                    @*@foreach (var d in ViewBag.GetShortLeave)
                                                    {
                                                        <tr>
                                                           
                                                            <td class="text-nowrap">@d.ReqDate</td>
                                                            <td class="text-nowrap">@d.DocDate</td>
                                                            <td class="text-nowrap">@d.EmployeeNo</td>
                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                            <td class="text-nowrap">@d.DepartmentName</td>
                                                            <td class="text-nowrap">@d.DesignationName</td>
                                                            <td class="text-nowrap">@d.ShiftName</td>
                                                            <td class="text-nowrap">@d.Direction</td>
                                                            <td class="text-nowrap">@d.ForTime</td>
                                                            <td class="text-nowrap">@d.Reason</td>
                                                            <td class="text-nowrap">@d.ApprovedBy</td>
                                                            <td class="text-nowrap">@d.ApproveRejectDate</td>
                                                            <td class="text-nowrap">@d.ApproveRejectRemark</td>
                                                        </tr>
                                                    }*@
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        //$('#tblLateComing').DataTable({
        //    "dom": '<"search"f>i'
        //});
        $("#txtBranchId").select2();
        $("#txtCmpId").select2();

        $("#txtCmpId").on("change", function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#txtCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#txtBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
    })



    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveKPIReport').validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            FromDate: {
                required: true,
            },           
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            BranchId: {
                required: "Business unit is required",
            },
            FromDate: {
                required: "From date is required",
            },            

        },
    });

    var form = $("#SaveKPIReport");
    form.validate();
    function LoadEmployee() {
        debugger;
        form.valid();
        if (form.valid() == false) {
           
            $("#txtFromDate").removeClass("error");
            return false;
        }
        $("#SaveKPIReport").submit();
    }

</script>

