    function downloadExcelFile() {
        debugger;
        $(".Userloaderbg").css("display", "flex");
        var DepartmentId = encodeURIComponent($("#ddlDepartmentId").val());
        var SubDepartmentId = encodeURIComponent($("#ddlSubDepartmentId").val());
        var DesignationId = encodeURIComponent($("#ddlDesignationId").val());
        var GradeId = encodeURIComponent($("#ddlGradeId").val());
        var LineId = encodeURIComponent($("#ddlLineId").val());
        var SubUnitId = encodeURIComponent($("#ddlSubUnit").val());
        var EmployeeID = encodeURIComponent($("#ddlEmployeeID").val());
        var FromDate = encodeURIComponent($("#FromDate").val());
        var branchId = encodeURIComponent($("#ddlBranchId").val());
        var CmpID = encodeURIComponent($("#ddlCmpId").val());
        var ToDate=encodeURIComponent($("#ToDate").val());
        var ContractorId=encodeURIComponent($("#ddlContractorId").val());
        var url = `@Url.Action("DownloadExcelFile", "Rpt_Daily_Attendance")?BranchId=${branchId}&CmpID=${CmpID}&DepartmentId=${DepartmentId}&SubDepartmentId=${SubDepartmentId}&DesignationId=${DesignationId}&GradeId=${GradeId}&LineId=${LineId}&SubUnitId=${SubUnitId}&EmployeeID=${EmployeeID}&FromDate=${FromDate}&ToDate=${ToDate}&ContractorId=${ContractorId}`;

        // Create a full URL with query parameters
        //var url = '/Rpt_Daily_Attendance/DownloadExcelFile?BranchId=' + encodeURIComponent(BranchId) + '&FromDate=' + encodeURIComponent(FromDate) +'&CmpId='+ encodeURIComponent(CmpId) +'&DepartmentId='+encodeURIComponent(DepartmentId)+'&SubDepartmentId='+encodeURIComponent(SubDepartmentId)+'&DesignationId='+encodeURIComponent(DesignationId)+'&GradeId='+encodeURIComponent(GradeId)+'&LineId='+encodeURIComponent(LineId)+'&SubUnitId='+encodeURIComponent(SubUnitId)+'&EmployeeID='+encodeURIComponent(EmployeeID)+'&ToDate='+encodeURIComponent(ToDate);
        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertDateFormat(FromDate);
                var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'DailyAttendanceReport('+formattedDate +' - '+ ToformattedDate+').xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }

    function convertDateFormat(dateString) {
        // Create a Date object from the input string
        var dateParts = dateString.split('-');
        var year = dateParts[0];
        var month = dateParts[1];
        var day = dateParts[2];

        // Convert month number to month name abbreviation
        var monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                          "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        var monthName = monthNames[parseInt(month, 10) - 1]; // Adjust index to zero-based

        // Construct the formatted date string
        return day + ' ' + monthName + ' ' + year;
    }

    function Preview() {
        var DepartmentId = $("#ddlDepartmentId").val();
        var SubDepartmentId = $("#ddlSubDepartmentId").val();
        var DesignationId = $("#ddlDesignationId").val();
        var GradeId = $("#ddlGradeId").val();
        var LineId = $("#ddlLineId").val();
        var SubUnitId = $("#ddlSubUnit").val();
        var EmployeeID = $("#ddlEmployeeID").val();
        var FromDate = $("#FromDate").val();
        var branchId = $("#ddlBranchId").val();
        var CmpID = $("#ddlCmpId").val();
        var ToDate = $("#ToDate").val();
        var ContractorId = $("#ddlContractorId").val();
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            url: '@Url.Action("GetDailyAttendanceReport", "Rpt_Daily_Attendance")',
            type: "GET",
            data: {
                BranchId: branchId,
                CmpId: CmpID,
                DepartmentId: DepartmentId,
                SubDepartmentId: SubDepartmentId,
                DesignationId: DesignationId,
                GradeId: GradeId,
                LineId: LineId,
                SubUnitId: SubUnitId,
                EmployeeID: EmployeeID,
                FromDate: FromDate,
                ToDate: ToDate,
                ContractorId: ContractorId
            },
            success: function (response) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if (!response.success) {
                    Swal.fire({ icon: 'error', text: response.message || 'No records found' });
                    return;
                }
                if ($.fn.DataTable.isDataTable("#reportTable")) {
                    $("#reportTable").DataTable().clear().destroy();
                }
                $("#reportTable thead").empty();
                $("#reportTable tbody").empty();
                var data = response.data;
                var Title = response.Title;
                if (Title) {
                    $(".modal-title").text(Title);
                }

                // 1) Convert [{Key,Value}, ...] rows -> [{...}, {...}]
                var result = [];
                data.forEach(function (row) {
                    var obj = {};
                    row.forEach(function (item) {
                        obj[item.Key] = item.Value;
                    });
                    result.push(obj);
                });

                if (!result.length) {
                    Swal.fire({ icon: 'error', text: 'No records found' });
                    return;
                }

                // 2) Collect all unique columns
                var columns = [];
                result.forEach(function (r) {
                    for (var k in r) {
                        if (r.hasOwnProperty(k) && columns.indexOf(k) === -1) {
                            columns.push(k);
                        }
                    }
                });

                // 3) Build header
                var theadHtml = "<tr>";
                for (var i = 0; i < columns.length; i++) {
                    theadHtml += "<th>" + columns[i] + "</th>";
                }
                theadHtml += "</tr>";
                $("#reportTable thead").html(theadHtml);

                // 4) Build body
                var tbodyHtml = "";
                for (var r = 0; r < result.length; r++) {
                    tbodyHtml += "<tr>";
                    for (var c = 0; c < columns.length; c++) {
                        var col = columns[c];
                        var val = (result[r][col] === null || result[r][col] === undefined) ? "" : result[r][col];
                        tbodyHtml += "<td>" + val + "</td>";
                    }
                    tbodyHtml += "</tr>";
                }
                $("#reportTable tbody").html(tbodyHtml);

                // 5) Initialize DataTable (destroy first if exists)
                if ($.fn.DataTable.isDataTable("#reportTable")) {
                    $("#reportTable").DataTable().clear().destroy();
                }

                $("#reportTable").DataTable({
                    paging: true,
                    searching: true,   // 🔎 enables search box
                    ordering: true,
                    responsive: true,
                    lengthMenu: [10, 25, 50, 100, 500, 1000],
                    language: {
                        search: "Search:",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        infoEmpty: "No entries available"
                    }
                });

                // 6) Show modal
                $("#reportModal").modal("show");
            },
            error: function (xhr, status, error) {
                Swal.fire({ icon: 'error', text: 'Error: ' + error });
            }
        });
    }

   
</script>



