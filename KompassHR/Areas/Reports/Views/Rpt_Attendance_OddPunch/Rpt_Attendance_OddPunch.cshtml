<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formOddPunch').validate({
        rules: {
            EmployeeCardNo: {
                required: true,
            },
            
        },
        messages: {
            EmployeeCardNo: {
                required: "Employee card no is required",
            },
          
        },
    });

    var form = $("#formOddPunch");
    form.validate();
    function OddPunch() {
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#formOddPunch").submit();
    }
</script>