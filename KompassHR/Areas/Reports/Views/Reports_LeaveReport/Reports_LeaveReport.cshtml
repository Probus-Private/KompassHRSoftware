<script>
        jQuery.validator.addMethod(
        "regex",
         function(value, element, regexp) {
             if (regexp.constructor != RegExp)
                 regexp = new RegExp(regexp);
             else if (regexp.global)
                 regexp.lastIndex = 0;
             return this.optional(element) || regexp.test(value);
         },"erreur expression reguliere"
      );

        $('#formLeaveReport').validate({
            rules: {
                LeaveId: {
                    required: true,
                },
                YearId: {
                    required:true,
                },
              

            },
            messages: {
                LeaveId: {
                    required:"Leave name is required",
                },
                YearId: {

                    required:"Leave Year is required",

                },
               
            },

            errorPlacement: function (error, element) {
                if (element.hasClass("select2-hidden-accessible")) {
                    error.insertAfter(element.next('.select2'));
                } else {
                    error.insertAfter(element);
                }
            }
        });

        var form = $("#formLeaveReport");
        form.validate();
        $("#btnShow").click(function () {
            //function ViewData() {
            debugger;
            form.valid();
            if(form.valid()==false)
            {
                $("#txtEstablishedDate").removeClass("error");
                return false;
            }

            //var LeaveId = encodeURIComponent($("#ddlLeaveId").val());
            //var YearId = encodeURIComponent($("#ddlYearId").val());
            var LeaveId = $("#ddlLeaveId").val();
            var YearId = $("#ddlYearId").val();
          
            var url = '@Url.Action("Reports_LeaveReport", "Reports_LeaveReport")'
                             + '?LeaveId=' + LeaveId
                             + '&YearId=' + YearId;
                          
            window.location.href = url;
        });


    if (window.location.search.length > 0) {
        window.history.replaceState({}, document.title, window.location.pathname);
    }
</script>



