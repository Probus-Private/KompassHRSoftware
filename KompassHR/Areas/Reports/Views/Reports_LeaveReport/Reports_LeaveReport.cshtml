@model KompassHR.Areas.Reports.Models.LeaveReportFilter

@{
    ViewBag.Title = "Reports_LeaveReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Reports
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Report_MyAtttendance_RptMenu", "Report_MyAtttendance_RptMenu", new {id = 23, ScreenId=376, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Leave Report</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Leave Reports.
                    </p>
                </div>

                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" href="@Url.Action("Reports_LeaveReport", "Reports_LeaveReport" , new { area = "Reports" })" id="formLeaveReport" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Leave Year
                                            <span id="label" class="text-danger">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.YearId, new SelectList(ViewBag.YearName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "YearId", id = "ddlYearId" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Leave Name
                                            <span id="label" class="text-danger">*</span>

                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.LeaveId, new SelectList(ViewBag.LeaveName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "LeaveId", id = "ddlLeaveId" })
                                            <span id="ErrorddlBranchId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-10">
                                        </div>
                                        <div class="col-md-2">
                                            <div class="BtnBx">
                                                <div>
                                                    @*<button type="button" class="btn btn-success" id="btnShow">*@
                                                    <button type="button" class="btn btn-success" id="btnShow">
                                                        Show
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </form>

                    </div>
                </div>

                <!--Begin Data-->
               

                <table style="width:100%; border-collapse: collapse; border:1.5px solid #ccc;">
                    <thead></thead>
                    @*@{
                       
                        bool EmployeeData = ViewBag.Getdata == null || ViewBag.Getdata.Count == 0;
                    }*@

                    @if (ViewBag.Getdata == null || ViewBag.Getdata.Count == 0)
                    {

                    }
                    else
                    {
                        var header = ViewBag.Getdata[0];
                        var List = (IEnumerable<dynamic>)ViewBag.Getdata;
                        
                        var leaveGroups = from e in List group e by new { e.LeaveTypeShortName, e.LeaveYear } into g select g;
                        <tbody>
                            <tr>
                                <td style="padding:0 !important;">

                                    <table class="emi-table1" style="width:100%; border-collapse: collapse; border:1px solid #ccc; margin-bottom:25px;">
                                        <tbody>
                                            <tr>
                                                <td style="border:1px solid #ccc; padding:5px; text-align:center; font-weight:bold; background:#f5f5f5; height:40px; font-size:18px;" colspan="4">
                                                    @header.CompanyName
                                                </td>
                                            </tr>

                                            <tr>
                                                <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Employee No</td>
                                                <td style="border:1px solid #ccc; padding:5px;">@header.EmployeeNo</td>
                                                <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Employee Name</td>
                                                <td style="border:1px solid #ccc; padding:5px;">@header.EmployeeName</td>
                                            </tr>

                                            <tr>
                                                <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Leave Type </td>
                                                <td style="border:1px solid #ccc; padding:5px;">@header.LeaveTypeName</td>
                                                <td style="font-weight:bold; border:1px solid #ccc; padding:5px;">Leave Year</td>
                                                <td style="border:1px solid #ccc; padding:5px;">@header.LeaveYear</td>
                                            </tr>

                                        </tbody>
                                    </table>

                                    @foreach (var leaveGroup in leaveGroups)
                                    {
                                        var leaveHeader = leaveGroup.First();

                                        <table class="emi-table" style="width:100%; border-collapse: collapse; border:1px solid #ccc; margin-bottom:20px;">
                                            <thead>
                                                @{
                                                    int Sr_No = 1;
                                                }
                                                <tr>
                                                    <td style="border:1px solid #ccc; padding:5px; text-align:center; font-weight:bold; background:#f5f5f5; height:40px; font-size:18px;" colspan="9">
                                                        Leave Information
                                                    </td>
                                                </tr>

                                                <tr class="emi-header">
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center; width:50px;">Sr.No</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">Shift</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">Day</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">Leave type</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">Total Days</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">From Date</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">To Date</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">Status</th>
                                                    <th style="border:1px solid #ccc; padding:5px; text-align:center;">Approved/Rejected</th>

                                                </tr>
                                            </thead>

                                            <tbody>
                                                @foreach (var d in leaveGroup)
                                                {

                                                    <tr>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:right;">@Sr_No</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.LeaveMasterShiftName</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.LeaveMasterDayType</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:right;">@d.LeaveTypeShortName</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:right;">@d.TotalDays</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.FromDate</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.ToDate</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.Status</td>
                                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">@d.ApproveRejectBy</td>

                                                    </tr>
                                                    Sr_No++;
                                                }

                                            </tbody>
                                        </table>
                                        <br />
                                        }
                                </td>
                            </tr>
                        </tbody>
                        }
                </table>
               <!--End Data-->


            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


