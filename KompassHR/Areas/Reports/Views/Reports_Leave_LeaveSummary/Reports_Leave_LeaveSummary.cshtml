<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Summary Reports
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports_Leave_RptMenu", "Reports_Leave_RptMenu", new {id = 4, ScreenId=299, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Leave Summary Reports<b></b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        A leave summary report provides an overview of employee leave usage and trends.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action="@Url.Action("Reports_Leave_LeaveSummary", "Reports_Leave_LeaveSummary", new { area = "Reports" })" id="LeftEmployeeReport" method="post">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCmpId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit

                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetMasBranch, "Id", "Name"), new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Leave Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.LeaveYear, new SelectList(ViewBag.GetLeaveYear, "Id", "Name"), new { @class = "form-select", type = "text", name = "LeaveYear", id = "txtFromDate" })
                                                @*@Html.TextBoxFor(model => model.LeaveYear, new { @class = "form-control", type = "text", name = "LeaveYear", id = "txtFromDate", Maxlength = 4, onkeypress = " return numbervalidate(event)" })*@
                                                @Html.ValidationMessageFor(model => model.LeaveYear, "", new { @class = "help-block", @id = "ErrorLeaveYear", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.EmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "All", new { @class = "form-select", type = "text", name = "EmployeeId", id = "ddlEmployeeID" })
                                                <span id="ErrorEmployeeId" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-10">
                                            </div>
                                            <div class="col-md-2">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                            <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                        </button>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>

    $(document).ready(function () {
        //$('title').html("Leave Summary Reports");
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlEmployeeID").select2();
        $("#txtFromDate").select2();
        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            $("#ddlEmployeeID").find("option").remove();
            $("#txtFromDate").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            var GetFromDate = $("#txtFromDate").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetBusinessUnit", "Reports_Leave_LeaveSummary")',
                data: { CmpId: CmpId,GetFromDate:GetFromDate },
                success: function (data) {
                    if (data != null) {
                        //$("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    if (data != null) {
                        $("#ddlEmployeeID").append("<option value=''>All </option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $("#ddlEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    if (data != null) {
                        $.each(data.LeaveYearGet, function (i, p) {
                            $("#txtFromDate").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlEmployeeID").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            var CmpId = $("#ddlCmpId").val();
            var GetYear = $("#txtFromDate").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetUnit", "Reports_Leave_LeaveSummary")',
                data: { CmpId:CmpId, BranchId: BranchId,GetYear:GetYear },
                success: function (data) {
                    if (data != null) {
                        $("#ddlEmployeeID").append("<option value=''>All </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#txtFromDate").on("change", function () {
            debugger;
            $("#ddlEmployeeID").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            var CmpId = $("#ddlCmpId").val();
            var GetYear = $("#txtFromDate").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetMonthlyEmployeeNameDateWise", "Reports_Leave_LeaveSummary")',
                data: {  BranchId: BranchId,GetYear:GetYear },
                success: function (data) {
                    if (data != null) {
                        $("#ddlEmployeeID").append("<option value=''>All </option>");
                        $.each(data, function (i, p) {
                            $("#ddlEmployeeID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }

                });
            }
        }
        $("#formReset").click(function () {
            $("#LeftEmployeeReport")[0].reset();
        })

    });//ready function

    function downloadExcelFile() {
        debugger;
        $(".Userloaderbg").css("display", "flex");
        
        var LeaveYear = encodeURIComponent($("#txtFromDate").val());
        if (LeaveYear=="")
        {
            $("#ErrorLeaveYear").html("Leave year is required");return false;
        }
        else{
            $("#ErrorLeaveYear").html("");
        }
    
        var CmpId = encodeURIComponent($("#ddlCmpId").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        var LeaveYear = encodeURIComponent($("#txtFromDate").val());

        var EmployeeId = encodeURIComponent($("#ddlEmployeeID").val());
        var url = `@Url.Action("DownloadExcelFile", "Reports_Leave_LeaveSummary")?BranchId=${BranchId}&CmpId=${CmpId}&EmployeeId=${EmployeeId}&LeaveYear=${LeaveYear}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                //var formattedDate = convertDateFormat(FromDate);
                //var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'LeaveSummaryReport.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }

