                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Month/Year
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.Month, new { @class = "form-control", name = "Month", type = "month", id = "GetMonth" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <div class="col-md-2">
                                            <button type="button" class="btn btn-success btn-sm" id="btlExportToExcel" onclick="ShowDataHead()">
                                                Show
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                        <hr class="mt-15px">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="table-scroll">
                                    <div class="table-wrap">
                                        <div style="max-height: 400px; overflow-y: auto;">
                                            <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblSelectColumn" style="width: 100%;">
                                                <thead class="table-active horizontal-scroll Fixedtblhead" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="text-center">
                                                        <th style="text-align: center; justify-content: center;">ALL <input type="checkbox" class="form-check-input" style="font-size:10px" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                                        <th hidden class="text-center">Heads</th>
                                                        <th class="text-center">Heads</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tbodySelectColumn">
                                                    @foreach (var d in ViewBag.GetHeadName)
                                                    {
                                                        if (@d.Name == "CompanyId" || @d.Name == "BranchId" || @d.Name == "DepartmentId" || @d.Name == "SubDepartmentId" || @d.Name == "designationId" || @d.Name == "GradeId" || @d.Name == "LineId" || @d.Name == "EmployeeId" || @d.Name == "EmployeeId_Encrypted")
                                                        {
                                                            continue;
                                                        }
                                                        else
                                                        {
                                                            <tr>
                                                                <td class="text-center"><input type="checkbox" class="form-check-input" style="font-size:10px" /></td>
                                                                <td hidden>@d.ID</td>
                                                                <td>@d.Name</td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                        
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-9">
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered table-hover mb-0" id="tblCustomizeReport" style="width: 100%;">
                                            <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                                @if (ViewBag.GetColumnWiseData != null)
                                                {
                                                    <tr>
                                                        @foreach (var row in ViewBag.GetColumnWiseData)
                                                        {
                                                            foreach (var cell in row)
                                                            {
                                                                <th class="text-nowrap" style="border-color:black !important;">@cell.Key</th>
                                                            }
                                                            break;
                                                        }
                                                    </tr>
                                                }
                                            </thead>
                                            <tbody id="tblDeptWiseReport" class="table-body-scroll">
                                                @if (ViewBag.GetColumnWiseData != null)
                                                {
                                                    foreach (var row in ViewBag.GetColumnWiseData)
                                                    {
                                                        <tr>
                                                            @foreach (var cell in row)
                                                            {
                                                                <td class="text-nowrap">@cell.Value</td>
                                                            }
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-8">
                                    </div>
                                    <div class="col-md-4">
                                        <div class="BtnBx">
                                            <div>
                                                <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                    @*onclick="downloadExcelFile()"*@
                                                    <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                </button>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

