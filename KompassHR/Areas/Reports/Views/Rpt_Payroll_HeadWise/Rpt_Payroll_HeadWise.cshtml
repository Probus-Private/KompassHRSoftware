</script>
<script>
    function downloadExcelFile() {
        debugger;
        $(".Userloaderbg").css("display", "flex");
        var RecordList = new Array();
        $("#tbodySelectColumn").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");
            var ColumnNameID = currentRow.find("td:eq(1)").html();
            var ColumnNameName = currentRow.find("td:eq(2)").html();
            data.ColumnName = ColumnNameID  +' as '+ '['+ColumnNameName+']';
            RecordList.push(data.ColumnName);
        });
        
        
        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Please select atleaset one column name",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        //var GetList = JSON.stringify(RecordList);
        //var GetFinalData = JSON.parse(GetList);
        var GetFinalData = encodeURIComponent(RecordList.join(","));
        var Month = encodeURIComponent($("#GetMonth").val());
        var  CmpId= encodeURIComponent($('select#ddlCmpId option:selected').val());
        var BranchId=encodeURIComponent( $('select#ddlBranchId option:selected').val());
        var url = `@Url.Action("DownloadExcelFile", "Rpt_Payroll_HeadWise")?GetFinalData=${GetFinalData}&CmpId=${CmpId}&Month=${Month}&BranchId=${BranchId}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertMonthYearFormat(Month);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'HeadWise('+formattedDate+').xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }


</script>
<script>
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>
