@model KompassHR.Areas.Reports.Models.NotLogin

@{
    ViewBag.Title = "Reports_Onboarding_NotLogin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .font-bold {
        font-weight: 700 !important;
    }

/*#tblEmployees th:nth-child(2),
#tblEmployees td:nth-child(2) { 
    width: 270px; 
    max-width: 270px;
    white-space: nowrap;
    text-align: left;
}

#tblEmployees th:nth-child(6),
#tblEmployees td:nth-child(6) { 
    width: 180px; 
    max-width: 180px;
    white-space: nowrap;
    text-align: left;
}*/

</style>


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Not Login Employee Report
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports_Onboarding_Menu", "Reports_Onboarding_Menu", new {id = 41, ScreenId=275, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Not Login Employee Report</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Not Login Employee Report.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" href="@Url.Action("Reports_Onboarding_NotLogin", "Reports_Onboarding_NotLogin", new { area = "Reports" })" id="formAssetWiseReport" ,Method="Post">
                           
                            <div class="row mb-3">
                                <label class="col-md-1 col-form-label">Last</label>
                                <div class="col-md-3">
                                    @Html.TextBoxFor(model => model.day, new { @class = "form-control", type = "number", id = "txtnumber", name = "day" })
                                    <span id="Errortxtnumber" class="text-danger"></span>
                                </div>
                                <label class="col-md-1 col-form-label">Days</label>
                            </div>

                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-10">
                                        </div>
                                        <div class="col-md-2">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" class="btn btn-success" id="btnShow">
                                                        Show
                                                    </button>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </form>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-12">
                        <div class="table-scroll div1 mb-4">
                            <div class="table-wrap" style="min-height: 100px; height:fit-content; overflow-y: auto; border:1px solid lightgray;">
                                <table class="table mb-0 table-bordered table-hover  text-dark align-middle" id="tblEmployees" style="width:100%;">
                                    <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                        <tr class="text-center">
                                            <th class="text-nowrap">Employee No</th>
                                            <th class="text-nowrap">Employee Name</th>
                                            <th class="text-nowrap">Company</th>
                                            <th class="text-nowrap">Business Unit</th>
                                            <th class="text-nowrap">Department</th>
                                            <th class="text-nowrap">Designation</th>
                                            @*<th class="text-nowrap">Login Date</th>*@
                                            <th class="text-nowrap">Last Login Date</th>
                                            <th class="text-nowrap">Days of Last Login</th>
                                        </tr>
                                    </thead>
                                    <tbody class="table-scroll">
                                        @if (ViewBag.GetLoginList != null)
                                        {
                                            foreach (var item in ViewBag.GetLoginList)
                                            {
                                                <tr>
                                                    <td class="text-center-left">@item.EmployeeNo</td>
                                                    <td class="text-center-left">@item.EmployeeName</td>
                                                    <td class="text-center-left">@item.ShortName</td>
                                                    <td class="text-center-left">@item.BranchName</td>
                                                    <td class="text-center-left">@item.DepartmentName</td>
                                                    <td class="text-center-left">@item.DesignationName</td>
                                                    @*<td class="text-center">@item.LoginDateTime</td>*@
                                                    <td class="text-center-left">@item.LastLoginDateTime</td>
                                                    <td class="text-center-center">@item.DaysSinceLastLogin</td>
                                                    
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#btnShow").click(function () {
            var day = $("#txtnumber").val().trim();

            if (day === "" || day < 0) {
                $("#Errortxtnumber").text("Please enter a valid number of days");
                return;
            } else {
                $("#Errortxtnumber").text("");
            }
            window.location.href = '@Url.Action("Reports_Onboarding_NotLogin", "Reports_Onboarding_NotLogin")?day=' + day;
        });
    });
</script>

