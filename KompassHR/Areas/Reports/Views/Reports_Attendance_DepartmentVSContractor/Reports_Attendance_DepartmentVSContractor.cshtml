<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Department VS Contractor Report 
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Reports_Attendance_HeadCountSummary", "Reports_Attendance_HeadCountSummary", new {id = 5, ScreenId=342, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Department VS Contractor Report</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row justify-content-center">
                            @*<hr class="mt-15px">*@
                            <div class="row justify-content-center">
                                <form role="form" action="/Reports/Reports_Attendance_DepartmentVSContractor/Reports_Attendance_DepartmentVSContractor" id="rptDepartmentVSContractor" method="post">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Company
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @id = "ddlCompanyName", name = "CmpID", @class = "form-select", autocomplete = "off" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Business Unit
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BusinessUnit, "Id", "Name"), "All", new { @id = "txtBranchId", name = "LeaveOpeningBalanceBranchID", @class = "form-select", autocomplete = "off" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Grade
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.GradeId, new SelectList(ViewBag.GradeName, "Id", "Name"), new { id = "ddlGradeId", @class = "select2 m-b-10 select2-multiple", autocomplete = "off", name = "GradeId", @multiple = "multiple", style = "width:100%" })
                                                    @* @Html.DropDownListFor(model => model.GradeId, new SelectList(ViewBag.GradeName, "Id", "Name"), "All", new { @class = "form-select", type = "text", name = "GradeId", id = "ddlGradeId" })*@
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Date
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.Date, new { @class = "form-control", name = "Date", type = "date", id = "txtDate" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    From Time
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.FromTime, new { @class = "form-control", id = "txtFromTime", type = "time", name = "FromTime" })
                                                    <span id="ErrortxtFromDate" class="Error"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    To Time
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.ToTime, new { @class = "form-control", id = "txtToTime", type = "time", name = "ToTime" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-10">
                                                </div>
                                                <div class="col-md-2">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" class="btn btn-success" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                                <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                                            </button>

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                      
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $(document).ready(function () {
        debugger;

        $('title').html("Department VS Contractor Report");
        $("#ddlCompanyName").select2();
        $("#txtBranchId").select2();
        $("#ddlGradeId").select2();
        var CheckEmptyDate = document.getElementById('txtDate').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtDate').value = SetTodaysDate;
        }
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#txtBranchId").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Reports_Attendance_DepartmentVSContractor")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        $("#txtBranchId").append("<option value=0>All </option>");
                        $.each(data, function(i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        var ShowData = @Html.Raw(Json.Encode(TempData["ShowData"]));
        if(ShowData!=true)
        {
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Reports_Attendance_DepartmentVSContractor")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        // $("#txtBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#txtBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        }
    });//Ready Funcation

  function downloadExcelFile() {
    debugger;
    // Show loader
    $(".Userloaderbg").css("display", "flex");

    // Get values from the input fields
    var CmpId = encodeURIComponent($("#ddlCompanyName").val());
    var BranchId = encodeURIComponent($("#txtBranchId").val());
    var FromTime = encodeURIComponent($("#txtFromTime").val());
    var ToTime = encodeURIComponent($("#txtToTime").val());
    var txtDate = encodeURIComponent($("#txtDate").val());

    // Get selected GradeIds
    var GradeIds = [];
    for (var option of document.getElementById('ddlGradeId').options) {
        if (option.selected) {
            GradeIds.push(option.value);
        }
    }

    var GradeId = encodeURIComponent(GradeIds.join(',')); // Join array into a string

    // Construct the URL
    var url = `@Url.Action("DownloadExcelFile", "Reports_Attendance_DepartmentVSContractor")?BranchId=${BranchId}&CmpId=${CmpId}&FromTime=${FromTime}&ToTime=${ToTime}&GradeId=${GradeId}&txtDate=${txtDate}`;

    // Make AJAX request to download the Excel file
    $.ajax({
        url: url,
        method: 'GET',
        xhrFields: {
            responseType: 'blob' // Set the response type to blob
        },
        success: function (data) {
            debugger;
            if (data.size == 0) {
                Swal.fire({
                    icon: 'error',
                    text: 'Record Not Found',
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup();
                        popup.classList.remove('swal2-show');
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake');
                        });
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake');
                        }, 500);
                        return false;
                    }
                });
                $(".Userloaderbg").css("display", "none");
                return false;
            }

            // Format date for filename
            var formattedDate = convertDateFormat(txtDate);

            // Create a Blob from the response data
            var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
            var url = window.URL.createObjectURL(blob);

            // Create a temporary anchor element to initiate the download
            var anchorElement = document.createElement('a');
            anchorElement.href = url;
            anchorElement.download = `DepartmentVSContractor(${formattedDate}).xlsx`;
            anchorElement.click();

            // Clean up
            window.URL.revokeObjectURL(url);
            $(".Userloaderbg").css("display", "none");
        },
        error: function (xhr, status, error) {
            console.error('Error downloading file:', error);
            // Hide loader in case of error
            $(".Userloaderbg").css("display", "none");
        }
    });
}
</script>

