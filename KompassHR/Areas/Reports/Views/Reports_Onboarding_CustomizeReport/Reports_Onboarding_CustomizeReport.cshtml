<script>
    //Select All Checkboxes
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }




    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formDailyAttendanceeReport').validate({
        rules: {
            CmpId: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
        },
    });

    
    //var form = $("#formDailyAttendanceeReport");
    //form.validate();
    function ShowDataSelectedColumn() {
        //debugger;
        //form.valid();
        //if (form.valid() == false) {
        //    return false;
        //}
        var RecordList = new Array();
        $("#tbodySelectColumn").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");
            //data.DocID = currentRow.find("td:eq(0)").html();
            data.ColumnName = currentRow.find("td:eq(1)").html();
            RecordList.push(data.ColumnName);
        });
        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Please select atleaset one column name",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        var GetList = JSON.stringify(RecordList);
        var GetFinalData = JSON.parse(GetList);

        var dataArray = {
            CmpId : $('select#ddlCmpId option:selected').val(),
            BranchId : $('select#ddlBranchId option:selected').val(),
            DepartmentId : $('select#ddlDepartmentId option:selected').val(),
            SubDepartmentId : $('select#ddlSubDepartmentId option:selected').val(),
            DesignationId : $('select#ddlDesignationId option:selected').val(),
            GradeId : $('select#ddlGradeId option:selected').val(),
            LineId : $('select#ddlLineId option:selected').val(),
            EmployeeID : $('select#ddlEmployeeID option:selected').val(),
            Active_Deactive : $('select#ddlActive_Deactive option:selected').val(),
        }
        location.href = '@Url.Action("Reports_Onboarding_CustomizeReport", "Reports_Onboarding_CustomizeReport")?GetFinalData=' + GetFinalData + '&ArrrayData=' + encodeURIComponent(JSON.stringify(dataArray));
    }

</script>

