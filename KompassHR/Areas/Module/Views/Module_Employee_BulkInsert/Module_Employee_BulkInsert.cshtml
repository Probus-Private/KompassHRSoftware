    $("#btnDuplicateAadhaarNo").on("click", function () {
        $(".Userloaderbg").css("display","flex");
        var tblAadhaardata = [];
        $("#Tabledata tbody tr").each(function () {

            var row = $(this);
            var tblRowAadhaarData = {};
            tblRowAadhaarData.AadhaarNo = row.find("td").eq(19).find("input").val();
            tblAadhaardata.push(tblRowAadhaarData);
        });
        $.ajax({
            url: '@Url.Action("GetAadhaarDuplicate", "Module_Employee_BulkInsert")',
            method: "post",
            contentType: 'application/json',
            data: JSON.stringify(tblAadhaardata),
            success: function(data) {
                $(".Userloaderbg").css("display", "none");
                debugger;
                //var data=response[0];
                if (data && data.length > 0) {
                    // Check if the DataTable is already initialized and destroy it
                    if ($.fn.DataTable.isDataTable('#tblHeadEmployeeHistory')) {
                        $('#tblHeadEmployeeHistory').DataTable().clear().destroy();
                    }

                    // Initialize the DataTable
                    $('#tblHeadEmployeeHistory').DataTable({
                        data: data,
                        scrollY: 300,
                        scrollX: true,
                        searching: true, // Enable searching
                        info: true,
                        paging: false,
                        buttons: [
                            'excel' // Add Excel export button
                        ],
                        columns: [
                            { data: 'Company' },
                            { data: 'BU' },
                            { data: 'Employee' },
                            { data: 'EmployeeNo' },
                            { data: 'EmployeeCardNo' },
                            { data: 'Status' },
                            { data: 'ContractorName' },
                            { data: 'DepartmentName' },
                            { data: 'DesignationName' },
                            { data: 'GradeName' },
                            { data: 'AadhaarNo' },
                            { data: 'JoiningDate' },
                            { data: 'LeavingDate' },
                            { data: 'Duration' }
                        ],
                        dom: '<"row"<"col-sm-6"B><"col-sm-6"f>>' + // Add buttons to the left and search box to the right
                             '<"row"<"col-sm-12"tr>>' +
                             '<"row"<"col-sm-6"i><"col-sm-6"p>>', // Show info and pagination
                        initComplete: function() {
                            var tableInfo = this.api().page.info();
                            $('#tblHeadEmployeeHistory_info').append(` (Total rows: ${tableInfo.recordsTotal})`);
                        }
                    });

                    $('#myEmployeeHistoryNoModal').modal('show');
                } else {
                    $('#myEmployeeHistoryNoModal').modal('hide');
                }
            }
        });

    });
</script>



