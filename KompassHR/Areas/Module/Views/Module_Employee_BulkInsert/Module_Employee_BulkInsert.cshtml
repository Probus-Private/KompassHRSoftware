@model KompassHR.Areas.Module.Models.Module_Employee.Module_Employee_BulkInsert

@{
    ViewBag.Title = "Module_Employee_BulkInsert";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Required library for validation -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.0/xlsx.full.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }


    /*table Style End*/
    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }


    /*.tblInnerAddData td:nth-child(1) {
        display: none;
    }*/
    .dataTables_scrollBody::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
        margin-top: 20px;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .dataTables_scrollBody::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
        height: 10px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Bulk Insert
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Contractor_Menu", "ESS_Contractor_Menu",  new { id = 27,ScreenId=307, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Bulk Insert<b></b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        It enables HR personnel to efficiently input essential details for each new hire in a structured format, ensuring accuracy and consistency across all entries.

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Module_Employee_BulkInsert", "Module_Employee_BulkInsert", new { area = "Module" })' id="SaveBulkInsert" method="post" enctype="multipart/form-data" }>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.ComapnyProfile, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CmpId", id = "ddlCmpId" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyCompanyName">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeBranchId, new SelectList(""), "--Select--", new { @class = "form-select", type = "text", name = "BusinessUnit", id = "ddlBusinessUnit" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyBusinessUnit">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Contractor Name
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.ContractorID, new SelectList(ViewBag.ContractorNameList, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "ContractorName", id = "ddlContractorName" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyContractorName">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Qualification
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeQualificationID, new SelectList(ViewBag.QualificationName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeQualificationID", name = "EmployeeQualificationID", @class = "form-select", autocomplete = "off" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyHighestQualification">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Manpower Category

                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeAllocationCategoryId, new SelectList(ViewBag.EmployeeAllocationCategory, "Id", "Name"), "--Select--", new { id = "ddlEmployeeAllocationCategoryId", name = "EmployeeAllocationCategoryId", @class = "form-select", autocomplete = "off" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyEmployeeAllocationCategoryId">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Designation
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeDesignationID, new SelectList(ViewBag.DesignationList, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "Designation", id = "ddlDesignation" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyDesignation">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Department
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeDepartmentID, new SelectList(ViewBag.DepartmentList, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "Department", id = "ddlDepartment" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyDepartment">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Sub Department
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeSubDepartmentName, new SelectList(ViewBag.SubDepartmentList, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "SubDepartment", id = "ddlSubDepartment" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplySubDepartment">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Grade
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeGradeID, new SelectList(ViewBag.GradeList, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "Grade", id = "ddlGrade" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyGrade">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Line Master
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeLineID, new SelectList(""), "--Select--", new { @class = "form-select", type = "text", name = "LineName", id = "ddlLineName" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyLineName">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Shift Group
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EM_Atten_ShiftGroupId, new SelectList(""), "--Select--", new { @class = "form-select", type = "text", name = "ShiftGroupName", id = "ddlShiftGroupName" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyShiftGroupName">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Shift Rule
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EM_Atten_ShiftRuleId, new SelectList(""), "--Select--", new { @class = "form-select", type = "text", name = " ShiftRuleName", id = "ddlShiftRuleName" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyShiftRuleName">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Sub Unit
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeUnitID, new SelectList(""), "--Select--", new { @class = "form-select", type = "text", name = "Unit", id = "ddlUnit" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyUnit">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Assessment Level
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeLevelID, new SelectList(ViewBag.EmployeeLevel, "Id", "Name"), "--Select--", new { id = "ddlEmployeeLevelID", name = "EmployeeLevelID", @class = "form-select", autocomplete = "off" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyEmployeeLevelID">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Critical Stage Category
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeCriticalStageID, new SelectList(ViewBag.CriticalStageName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeCriticalStageID", name = "EmployeeCriticalStageID", @class = "form-control" })
                                                <span id="ErrortxtGetUserPolicyName" class="Error"></span>
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary" id="btnApplyEmployeeCriticalStageID">Apply</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Employee History
                                                <br>
                                                (Aadhar No)
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.DuplicateAddharNo, new { @class = "form-control", name = "DuplicateAddharNo", type = "text", id = "txtDuplicateAddharNo", autocomplete = "Off", Maxlength = 12, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.DuplicateAddharNo, "", new { @class = "help-block", @id = "ErrorDuplicateAddharNo", @style = "color:red" })

                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-success" id="btnDuplicateAddharNo">Show</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Choose File
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                <input type="file" name="AttachFile" class="form-control" id="txtAttachFile" onchange="ResetFile()" />
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-warning" id="btnChooseFile">Import</button>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <hr />
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="panel panel-inverse" data-sortable-id="index-1">
                                            <div style="overflow-y:auto; overflow-x:auto">
                                                <div class="panel-body">
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            @*<a href="~/assets/BulkUpload/Bulk_Insert_Template.xlsx">~/assets/BulkUpload/Bulk_Insert_Template.xlsx</a>*@
                                                            <a href="@Url.Content("~/assets/BulkUpload/Bulk_Insert_Template.xlsx")">
                                                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                                                    <i class="fa-solid fa-file-excel"></i> &nbsp; Export To Excel
                                                                </button>
                                                            </a>
                                                            <!-- BEGIN table-responsive -->
                                                            <div class="table-scroll div1">
                                                                <div class="table-wrap">
                                                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TabledataBulkClass" id="Tabledata">
                                                                        <thead class="table-active " style="background-color: rgba(233, 236, 239, 1) !important;">
                                                                            <tr>
                                                                                @if (ViewBag.count != null)
                                                                                {
                                                                                    <th class="fixed-side">Action</th>
                                                                                    <th class="fixed-side1">SrNo.</th>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <th>SrNo.</th>
                                                                                }
                                                                                <th class="fixed-side2">Company Name</th>
                                                                                <th class="fixed-side3">Business Unit</th>
                                                                                <th class="fixed-side4">Contractor Name</th>
                                                                                <th class="fixed-side5">Salutation</th>
                                                                                <th class="fixed-side6">Employee Name</th>
                                                                                <th class="fixed-side7">Employe No</th>
                                                                                <th class="fixed-side8">Employee CardNo</th>

                                                                                <th class="fixed-side15">Department</th>
                                                                                <th class="fixed-side16">Sub Department</th>
                                                                                <th class="fixed-side16">Manpower Category</th>
                                                                                <th class="fixed-side17">Designation</th>
                                                                                <th class="fixed-side18">Grade</th>
                                                                                <th class="fixed-side19">Critical Stage Applicable</th>
                                                                                <th class="fixed-side20">Critical Stage Category</th>
                                                                                <th class="fixed-side21">Line Master </th>
                                                                                <th class="fixed-side22">Assessment Level </th>
                                                                                <th class="fixed-side23">Sub Unit</th>
                                                                                <th class="fixed-side9">Aadhar No</th>
                                                                                <th class="fixed-side9">Name As Per Aadhar</th>
                                                                                <th class="fixed-side10">Mobile No (Optional)</th>
                                                                                <th class="fixed-side11">Gender</th>
                                                                                <th class="fixed-side12">Birth Date</th>
                                                                                <th class="fixed-side13">Marital Status</th>
                                                                                <th class="fixed-side14">Highest Qualification</th>
                                                                                <th class="fixed-side24">Joining Date</th>
                                                                                <th class="fixed-side25">I Weekly off</th>
                                                                                <th class="fixed-side26">Shift Group </th>
                                                                                <th class="fixed-side27">Shift Rule </th>
                                                                                <th class="fixed-side30">PF No (Optional)</th>
                                                                                <th class="fixed-side28">Father/Mother/Spouse Relation</th>
                                                                                <th class="fixed-side29">Father/Mother/Spouse Name</th>
                                                                                <th class="fixed-side30">UAN No</th>
                                                                                <th class="fixed-side29">ESIC No (Optional)</th>
                                                                                <th class="fixed-side30">Relation/Nominee1 (Optional)</th>
                                                                                <th class="fixed-side30">Relation/Nominee Name (Optional)</th>
                                                                                <th class="fixed-side28">Pincode (Optional)</th>
                                                                                <th class="fixed-side29">State Name (Optional)</th>
                                                                                <th class="fixed-side30-">District Name (Optional)</th>
                                                                                <th class="fixed-side31">Taluka Name (Optional)</th>
                                                                                <th class="fixed-side32">P/O Name (Optional)</th>
                                                                                <th class="fixed-side33">City Name (Optional)</th>
                                                                                <th class="fixed-side34">Postel Address (Optional)</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody id="tblTableBodyBulkInsert">
                                                                            @if (ViewBag.GetExceldata != null)
                                                                            {
                                                                                foreach (var d in ViewBag.GetExceldata)
                                                                                {
                                                                                    <tr>
                                                                                        <td>
                                                                                            <button type="button" class="btn btn-danger btnRemoveRow">Remove</button>
                                                                                        </td>

                                                                                        <td class="fixed-side">
                                                                                            @Html.TextBoxFor(Model => Model.SrNo, new { @class = "form-control", @Value = d.SrNo, @id = "SrNo" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.CmpID, new { @class = "form-control", @Value = d.CmpID, id = "CmpID", name = "CmpID", @style = "width:220px" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.EmployeeBranchId, new { @class = "form-control", @Value = d.EmployeeBranchId, id = "BusinessUnit", name = "BusinessUnit", @style = "width:150px" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.ContractorID, new { @class = "form-control", @Value = d.ContractorID, id = "ContractorNameId", name = "ContractorNameId", @style = "width:200px" })
                                                                                        </td>

                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.Salutation, new { @class = "form-control", @Value = d.Salutation, id = "Solutation", name = "Solutation" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.EmployeeName, new { @class = "form-control", @Value = d.EmployeeName, id = "EmployeeName", name = "datafieldName", @style = "width:220px" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.EmployeeNo, new { @class = "form-control", @Value = d.EmployeeNo, id = "EmployeNo", name = "EmployeNo", Maxlength = 10, type = "text", @style = "width:120px", oninput = "this.value = this.value.toUpperCase()" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.EmployeeCardNo, new { @class = "form-control", @Value = d.EmployeeCardNo, id = "EmployeeCardNo", name = "EmployeeCardNo", Maxlength = 10, type = "text", @style = "width:120px", oninput = "this.value = this.value.toUpperCase()" })
                                                                                        </td>

                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.EmployeeDepartmentID, new { @class = "form-control", @Value = d.EmployeeDepartmentID, id = "DepartmentId", name = "DepartmentId", @style = "width:220px" })
                                                                                        </td>
                                                                                        <td>
                                                                                            @Html.TextBoxFor(Model => Model.EmployeeSubDepartmentName, new { @class = "form-control", @Value = d.EmployeeSubDepartmentName, id = "SubDepartmentId", name = "SubDepartmentId", @style = "width:220px" })
