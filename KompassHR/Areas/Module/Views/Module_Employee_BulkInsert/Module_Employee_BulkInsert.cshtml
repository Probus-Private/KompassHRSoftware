        ////Remove Row From Table
        $(document).on("click", ".btnRemoveRow", function () {
            const Approved = Swal.mixin({
                customClass: {
                    cancelButton: ' btnpress',
                    confirmButton: ' btnpress'
                },
                buttonsStyling: true
            })
            Approved.fire({
                title: 'Are you sure you want to remove this row?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                showCancelButton: true,
                confirmButtonText: 'Yes submit!',
                cancelButtonText: 'No, cancel!',
                reverseButtons: false,

                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }

            }).then((result) => {
                if (result.isConfirmed) {
                    debugger;
                    $(this).closest("tr").remove();

                } else if (
                    /* Read more about handling dismissals below */
                        result.dismiss === Swal.DismissReason.cancel
                        ) {
                }
            })
        });

        //ddlCmpId
        $("#btnApplyCompanyName").click(function(){
            debugger;
            var Company= $("#ddlCmpId option:selected").text();
            if(Company=="--Select--")
            {
                var Message ="Select Company ! ";
                var Icon = "error";
            }
            else
            {
                var num= localStorage.getItem('Rowno');
                if(num=="undefined" || num==null)
                {
                    num=1;
                }
                var rowNumber = num;
                var $row = $('#Tabledata tbody tr:eq(' + (rowNumber - 1) + ')');
                $row.find("#CmpID").val(Company);

                var Message ="Changes applied On Company Successfully ! at SrNo "+rowNumber;
                var Icon = "success";
            }
            if(num!="undefined" )
            {
                debugger;
                if (Message != null) {
                    if (Icon != null) {
                        Swal.fire({
                            icon: Icon,
                            text: Message,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
