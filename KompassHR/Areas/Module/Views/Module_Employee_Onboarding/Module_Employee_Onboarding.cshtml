                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Employee_Onboarding")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    var Branch=data.BranchName;
                    if (Branch !=null) {
                        $.each(Branch, function(i, p) {
                            $("#txtBankBranchName").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    var UnitName=data.UnitName;
                    var List_LineMaster=data.List_LineMaster;
                    var EmployeeAllocationCategory= data.EmployeeAllocationCategory;
                    //var GetDesignationNameId= data.GetDesignationName;
                    if (UnitName !=null) {
                        $.each(UnitName, function(i, p) {
                            $("#txtEmployeeUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    debugger;
                    //if (List_LineMaster !=null) {
                    //    $.each(List_LineMaster, function(i, p) {
                    //        $("#ddlLineMasterID").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                    //    });
                    //}
                    //if (EmployeeAllocationCategory != null) {
                    //    $.each(EmployeeAllocationCategory, function (i, p) {
                    //        $("#ddlEmployeeAllocationCategoryId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                    //    });
                    //}

                    //else {
                    //    $('#ErrorESSPassword').html(" ");
                    //}
                }
            })
        });

        $("#txtBankBranchName").on("change", function () {
            isManualChange = true;
            $("#txtEmployeeUnit").find("option").remove();
            $("#ddlLineMasterID").find("option").remove();
            //$("#ddlEmployeeAllocationCategoryId").find("option").remove();
            //$("#txtEmployeeDesignationID").find("option").remove();
            var CmpId = $("#txtComapnyName").val();
            var UnitBranchId = $("#txtBankBranchName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetUnit", "Module_Employee_Onboarding")',
                data: { CmpId: CmpId,UnitBranchId:UnitBranchId },
                success: function (data) {
                    debugger;
                    if(data==false)
                    {
                        $("#ddlLineMasterID").find("option").remove();
                        $("#txtEmployeeUnit").find("option").remove();
                        $("#ddlContractorID").find("option").remove();
                        //$("#ddlEmployeeAllocationCategoryId").find("option").remove();
                        //$("#txtEmployeeDesignationID").find("option").remove();
                    }
                    else
                    {
                        $("#ddlLineMasterID").find("option").remove();
                        $("#txtEmployeeUnit").find("option").remove();
                        $("#ddlContractorID").find("option").remove();
                        //$("#ddlEmployeeAllocationCategoryId").find("option").remove();
                        //$("#txtEmployeeDesignationID").find("option").remove();
                        var UnitName=data.UnitName;
                        var List_LineMaster=data.List_LineMaster;
                        var ContractorDropdown=data.GetContractorDropdown;
                        var EmployeeAllocationCategory= data.EmployeeAllocationCategory;
                        //var GetDesignationNameId= data.GetDesignationName;
                        if (UnitName !=null) {
                            $.each(UnitName, function(i, p) {
                                $("#txtEmployeeUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                            });
                        }
                        debugger;
                        if (List_LineMaster != null) {
                            $.each(List_LineMaster, function (i, p) {
                                $("#ddlLineMasterID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });

                            // 👉 ONLY SELECT SAVED LINE MASTER IF USER DID NOT CHANGE COMPANY
                            if (!isManualChange && selectedLineMaster && selectedLineMaster != 0) {
                                $("#ddlLineMasterID").val(selectedLineMaster).trigger("change");
                            }
                        }


                        if (ContractorDropdown != null) {
                            $.each(ContractorDropdown, function (i, p) {
                                $("#ddlContractorID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });

                        }
                        //if (EmployeeAllocationCategory != null) {
                        //    $.each(EmployeeAllocationCategory, function (i, p) {
                        //        $("#ddlEmployeeAllocationCategoryId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        //    });
                        //}
                    }
                }
            })
        });

        $("#txtEmployeeDepartmentID").on("change", function () {
            debugger;
            $("#ddlEmployeeSubDepartmentName").find("option").remove();
            var DepartmentId = $("#txtEmployeeDepartmentID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetSubDepartment", "Module_Employee_Onboarding")',
                data: { DepartmentId: DepartmentId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlEmployeeSubDepartmentName").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlEmployeeSubDepartmentName").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
