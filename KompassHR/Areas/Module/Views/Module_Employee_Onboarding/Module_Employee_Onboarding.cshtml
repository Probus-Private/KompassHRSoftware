<script>
    $(document).ready(function () {
        debugger;
        $("#ddlEmployeeCountryId").select2();

        var isManualChange = false;
var selectedLineMaster = @Html.Raw(Json.Encode(Model.EmployeeLineID));

setTimeout(function () {
    $("#txtBankBranchName").trigger("change");
}, 300);
        $("#ddlEmployeeCriticalStageID").attr("disabled","disabled");
        $("#Hiddenleavingdate").hide();
        $("#ddlContractorID").select2();
        $('#ReportingModal').on('shown.bs.modal', function () {
            $('#ddlManagerName').select2({
                dropdownParent: $('#ReportingModal'),
                placeholder: "--Select--"
            });
        });
        var GetVal = @Html.Raw(Json.Encode(TempData["NoticePeriodMonthDays"]));
        $("#ddlNoticePeriodValue").val(GetVal);
        var getddlPType = $("#ddlNoticePeriodType").val();
        if (getddlPType === "ByPolicy")
       {
           $("#divNoticePeriodValue").hide();
       }
       if (getddlPType === "Month" || getddlPType === "Days")
       {
           $("#divNoticePeriodValue").show();
       }
       else
       {
           $("#divNoticePeriodValue").hide();
       }

       $("#ddlNoticePeriodType").on("change", function () {
            var val = $(this).val();
            if (val === "ByPolicy")
            {
                $("#divNoticePeriodValue").hide();
                $("#ddlNoticePeriodValue").find("option").remove();
                return false;
            }
            if (val === "Month" || val === "Days")
            {
                $("#divNoticePeriodValue").show();
            }
            else
            {
                $("#divNoticePeriodValue").hide();
                $("#txtNoticePeriodValue").val("");
            }


            $("#ddlNoticePeriodValue").find("option").remove();
            var NoticePeriodType = $("#ddlNoticePeriodType").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetNoticePeriodMonthDays", "Module_Employee_Onboarding")',
                data: { NoticePeriodType: NoticePeriodType },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlNoticePeriodValue").append("<option value=0>--Select-- </option>");
                        $.each(data.NoticePeriodMonthDays, function(i, p) {
                            $("#ddlNoticePeriodValue").append("<option value='" + p.Name +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        //$('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
        //var fromDateInputMin = document.getElementById("txtLeavingDate");
        //var currentDateMin = new Date();
        //var minDate = new Date();
        //minDate.setDate(currentDateMin.getDate() - 90);
        //var minDateString = minDate.toISOString().split('T')[0];
        //fromDateInputMin.setAttribute("min", minDateString);
        var TransferOrigin = @Html.Raw(Json.Encode(Session["TransferOrigin"]));
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false // Disable outside clicks
            }).then((result) => {
                if (result.isConfirmed) {
                    var TransferOrigin = localStorage.getItem('TransferOrigin');
                    if (TransferOrigin === "Trans_BU") {
                        window.location.href = '@Url.Action("Module_Employee_AttendanceInfo", "Module_Employee_AttendanceInfo", new { area= "Module" })';
                    } else {
                        window.location.href = '@Url.Action("Module_Employee_Onboarding", "Module_Employee_Onboarding", new { area= "Module" })';
                    }
                }
            });
        }

        var List = @Html.Raw(Json.Encode(ViewBag.PreOnboardList));
        debugger;
        if(List!=null)
        {
            $("#txtComapnyName").val(List[2].Value).select2();
            $("#txtBankBranchName").val(List[3].Value).select2();
            $("#txtEmployeeDesignationID").val(List[5].Value).select2();
            $("#txtEmployeeDepartmentID").val(List[4].Value).select2();
            $("#txtSalutationName").val(List[12].Value).select2();
            $("#txtSalutationName").val(List[12].Value).select2();
            $("#txtEmployeeName").val(List[9].Value);
        }
        else
        {

        }

        var TransferOrigin = @Html.Raw(Json.Encode(Session["TransferOrigin"]));
        if (TransferOrigin=="Trans_BU")
        {
            localStorage.setItem('TransferOrigin', TransferOrigin)

            var OnboardBranchId = @Html.Raw(Json.Encode(Session["OnboardBranchId"]));
            var OnboardCmpId = @Html.Raw(Json.Encode(Session["OnboardCmpId"]));


            $("#txtBankBranchName").val(OnboardBranchId).select2();
            $("#txtComapnyName").val(OnboardCmpId).select2();
            //$("#txtBankBranchName").attr('disabled', true);
            //$("#txtComapnyName").attr('disabled', true);
            $("#txtEmployeeName").attr('readOnly', true);
            $("#txtEmployeeNo").attr('readOnly', true);
            $("#txtEmployeeCardNo").attr('readOnly', true);
            $("#txtSalutationName").attr('disabled', true);
            document.querySelector('#txtBankBranchName').style.backgroundColor = '#eee';
            document.querySelector('#txtComapnyName').style.backgroundColor = '#eee';
            document.querySelector('#txtSalutationName').style.backgroundColor = '#eee';
            document.querySelector('#txtEmployeeCardNo').style.backgroundColor = '#eee';
            document.querySelector('#txtEmployeeName').style.backgroundColor = '#eee';
            document.querySelector('#txtEmployeeNo').style.backgroundColor = '#eee';
        }

        $("#txtComapnyName").on("change", function () {
            debugger;
            isManualChange = true;
            $("#txtBankBranchName").find("option").remove();
            $("#txtEmployeeUnit").find("option").remove();
           // $("#ddlLineMasterID").find("option").remove();
            //$("#ddlEmployeeAllocationCategoryId").find("option").remove();
            var CmpId = $("#txtComapnyName").val();
