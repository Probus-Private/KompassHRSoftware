@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_Fine_List
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    .div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }

    .fixed-side {
        position: sticky;
        left: 0;
    }

    .fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new { id = 6, area = "Module" })">Payroll Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Fine/Penalty </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Fine/Penalty  - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of fine/penalty  created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("GetList", "Module_Payroll_FineAndPenalty", new { area = "Module" })' id="SaveFineAndPenalty" method="post">
                        <div class="row">
                            <div class="col-md-2">
                                <div>
                                    <button type="button" id="btnAdd" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Paid Month /Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(model => model.PayrollFineMonthYear, new { @class = "form-control", type = "month", id = "datePayrollFineMonthYear", Name = "PayrollFineMonthYear" })

                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div>
                                    <button type="button" id="btnshow" onclick="GetList()" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-eye"></i> &nbsp; show
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <!-- BEGIN table-responsive -->
                            <table class="table table-bordered align-middle TablePage" id="fixed-header" style="width: 100%;">
                                <thead>
                                    <tr class="text-center">
                                        @*<th class="text-nowrap width-45">Update</th>*@
                                        <th class="text-nowrap width-45">Delete</th>
                                        <th class="text-nowrap">Doc date </th>
                                    
                                        <th class="text-nowrap">Company Name </th>
                                        <th class="text-nowrap">Business Unit </th>
                                        <th class="text-nowrap">Employee Name</th>
                                        <th class="text-nowrap">Amount</th>
                                        <th class="text-nowrap">Remark</th>

                                    </tr>
                                </thead>
                                <tbody id="tblFine">
                                    @foreach (var d in ViewBag.PayrollFine)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <button type="button" onclick="DeletePayrollFine('@d.PayrollFineID_Encrypted')" id="btnDelete"
                                                        class="btn btn-danger ListBtn btnpress">
                                                    <i class="fa-solid fa-trash-alt"></i>
                                                </button>
                                            </td>
                                            <td class="text-nowrap">@d.DocDate</td>
                                            <td class="text-nowrap">@d.CompanyName</td>
                                            <td class="text-nowrap">@d.branchname</td>
                                            <td class="text-nowrap">@d.EMPLOYEENAME</td>
                                            <td class="text-nowrap">@d.PayrollFineAmount</td>
                                            <td class="text-nowrap">@d.PayrollFineRemarks</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {

        $("#btnAdd").click(function () {
            var url = '@Url.Action("Module_Payroll_FineAndPenalty", "Module_Payroll_FineAndPenalty")';
            window.location.href = url;
        });
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

    });

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveFineAndPenalty').validate({
        rules: {
            PayrollFineMonthYear: {
                required: true,
            },
        },
        messages: {
            PayrollFineMonthYear: {
                required: "Paid Month /Year is required",
            },
        },
    });

    var form = $("#SaveFineAndPenalty");
    form.validate();
    function GetList() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#datePayrollFineMonthYear").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#SaveFineAndPenalty").submit();
    }




    function DeletePayrollFine(PayrollFineID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Payroll_FineAndPenalty")?PayrollFineID_Encrypted=' + PayrollFineID_Encrypted;

            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

</script>

