</div>

<div class="row">
    @Html.Action("Onboarding_SidebarMenu", "Module_Employee_PersonalInfo")
</div>

<script>
    $(document).ready(function () {
        $("#btnBack").click(function () {
            var url = '@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { area= "ESS" })';
            window.location.href = url;
        });
        $("#ddlLanguageID").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        var CountLanguageEmployeeID = @Html.Raw(Json.Encode(TempData["CountLanguageEmployeeID"]));
        
        var CheckPreboarding = @Html.Raw(Json.Encode(TempData["PreBoardFid"]));

        if(CountLanguageEmployeeID!=0)
        {
            $("#btnGet").hide();
        }
        else
        {
            if(CheckPreboarding!=0)
            {
                $("#btnGet").show();
            }
            else{
                $("#btnGet").hide();

            }
        }

        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });

    function GetDetails(Status) {
        debugger;

        var baseUrl = '@Url.Action("PreboardingGetDetails", "Module_Employee_LanguageInfo", new { area = "Module" })';
        //var url = baseUrl + '?Status=' + encodeURIComponent(Status);

        window.location.href = baseUrl;
    }
</script>

<script>
    function DeleteLanguage(LangEmpID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Employee_LanguageInfo")?LangEmpID_Encrypted=' + LangEmpID_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

<script>
      //use for add regex function
      jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );


      $("#SaveLanguageInformation").validate({
          rules: {
              LanguageID: {
                  required: true,
              },
          },
          messages: {
              LanguageID: {
                  required: "Language is required",
              },
          }
      });


      var form = $( "#SaveLanguageInformation" );
      form.validate();
      $("#btnSubmit").click(function () {
          if(form.valid()==false)
          {

              return false;

          }
          var LangEmpID_Encrypted=$("#LangEmpID_Encrypted").val();
          var LanguageID=$("#ddlLanguageID").val();

          $.ajax({
              url: '@Url.Action("IslanguageExists", "Module_Employee_LanguageInfo")',
              method:"get",
              data:{LangEmpID_Encrypted:LangEmpID_Encrypted,LanguageID:LanguageID},
              success:function(response){
                  debugger;
                  var Message1 = response.Message;
                  var Icon1 = response.Icon;
                  if (response.Icon=="error") {
                      if (Message1 != null) {
                          if (Message1 != null) {
                              Swal.fire({
                                  icon: Icon1,
                                  text: Message1,
                                  allowOutsideClick: () => {
                                      const popup = Swal.getPopup()
                                      popup.classList.remove('swal2-show')
                                      setTimeout(() => {
                                          popup.classList.add('animate__animated', 'animate__headShake')
                                      })
                                      setTimeout(() => {
                                          popup.classList.remove('animate__animated', 'animate__headShake')
                                      }, 500)
                                      return false
                                  }
                              });
                          }
                      }
                  }
                  else{
                      $("#SaveLanguageInformation").submit();

                  }
              }
          });
      });

</script>