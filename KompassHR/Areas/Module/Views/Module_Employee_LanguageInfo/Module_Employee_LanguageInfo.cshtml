                                            @foreach (var d in ViewBag.GetEmployeeLanguageList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button type="button" onclick="DeleteLanguage('@d.LangEmpID_Encrypted')" id="btnDelete"
