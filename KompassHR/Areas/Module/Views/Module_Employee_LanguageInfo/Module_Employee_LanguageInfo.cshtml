                                                    <td>@d.empRead</td>
                                                    <td>@d.empWrite</td>
                                                    <td>@d.empSpeak</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
