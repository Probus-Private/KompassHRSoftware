                            }

                                .dynamic-table td {
                                    text-align: left; /* Align text to the left */
                                    padding: 5px 8px; /* Add some padding for better readability */
                                    word-wrap: break-word; /* Break long words to fit within the cell */
                                    overflow-wrap: anywhere; /* Handle overflowing text gracefully */
                                    white-space: nowrap; /* Prevent text wrapping */
                                }

                                .dynamic-table th {
                                    text-align: left; /* Align header text to the left */
                                    padding: 8px; /* Add some padding for table headers */
