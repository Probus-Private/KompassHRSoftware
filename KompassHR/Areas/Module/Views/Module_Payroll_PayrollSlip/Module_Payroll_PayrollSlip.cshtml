@*@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_Lock*@
@model KompassHR.Areas.Reports.Models.MonthWiseFilter
@{
    ViewBag.Title = "Module_Payroll_PayrollSlip";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
<!-- Include dompurify -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/2.4.0/purify.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Payslip
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Report_Payroll_RptMenu", "Report_Payroll_RptMenu", new {id = 6, ScreenId=455, area = "Reports" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Payslip - List <b>@ViewBag.AddUpdateTitle</b></h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Payslip list!
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Payroll_PayrollLock", new { area = "Module" })' id="SavePayrollLock" method="post" data-parsley-validate="">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), new { @class = "form-select", name = "CompanyName", id = "ddlCmpId" })
                                                <span id="ErrorddlCmpId" class="Error"></span>
                                                @* @Html.HiddenFor(model => model.PayrollLockId_Encrypted, new { id = "PayrollLockId_Encrypted" })*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @*@Html.DropDownListFor(model => model.BranchId, new SelectList(""), "--Select--", new { id = "ddlPayrollLockBranchID", @class = "form-select", autocomplete = "off", name = "PayrollLockBranchID" })*@
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "All", new { @class = "form-select", name = "BranchId", id = "ddlBranchId" })
                                                <span id="ErrorddlBranchId" class="Error"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Month/Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @* @Html.TextBoxFor(model => model.PayrollLockMonthYear, new { @class = "form-control", type = "month", id = "datePayrollLockMonthYear", autocomplete = "Off", name = "PayrollLockMonthYear" })*@
                                                @Html.TextBoxFor(model => model.Month, new { @class = "form-control", name = "Month", type = "month", id = "GetMonth" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-4">
                                                <button type="button" id="btnLoadEmployee" onclick="EmpPaySlipDetails()" class="btn btn-primary btn-sm">
                                                    <i class="fa-thin fa-user-magnifying-glass"></i>Load Employee
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <!-- BEGIN table-responsive -->
                                        <div class="table-scroll div1">
                                            <div class="table-wrap">
                                                <table class="table table-bordered align-middle tblAddData TablePage2" id="fixed-header" style="width: 100%;">
                                                    <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                        <tr class="text-center">
                                                            <th class="text-center">Action</th>
                                                            <th hidden class="text-center">Salary Id</th>
                                                            <th hidden class="text-center">SalaryMonthYear</th>
                                                            <th class="text-center">Employee Name</th>
                                                            <th class="text-center">Employee No</th>
                                                            <th class="text-center">Department</th>
                                                            <th class="text-center">Designation</th>
                                                            <th class="text-center">Net Pay</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="tblEmployeeListEarning">
                                                        @if (ViewBag.GetPaySlipList != null)
                                                        {
                                                            foreach (var item in ViewBag.GetPaySlipList)
                                                            {
                                                                <tr class="text-center">
                                                                    <td class="text-center">
                                                                        <i class="fa-solid fa-eye fa-xl" style="color: #f59c1a; cursor: pointer;" onclick="ViewPaySlip(@item.SalaryID)" id="btnViewPaySlip"></i>
                                                                        &nbsp; | &nbsp;<i class="fas fa-file-pdf fa-xl" style="color: red; cursor: pointer;" onclick="ViewPaySlip(@item.SalaryID, 'PDF', '@item.SalaryEmployeeNo')" )"></i>
                                                                        <i class="fas fa-envelope fa-xl" style="color: #007bff; cursor: pointer;" onclick="ViewPaySlip('@item.SalaryID', 'Mail', '@item.SalaryEmployeeNo')"></i>

                                                                    </td>
                                                                    <td hidden>@item.SalaryID</td>
                                                                    <td hidden>@item.SalaryMonthYear</td>
                                                                    <td style="text-align:left">@item.SalaryEmployeeName</td>
                                                                    <td style="text-align:left">@item.SalaryEmployeeNo</td>
                                                                    <td style="text-align:left">@item.SalaryDepartment</td>
                                                                    <td style="text-align:left">@item.SalaryDesignation</td>
                                                                    <td style="text-align:right">@item.SalaryNetPay</td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<style>
    #PayslipMDL .modal-body,
    #PayslipMDL form,
    #PayslipMDL table {
        font-family: 'helvetica', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 13px; /* Optional: Set font size for better readability */
    }

    #spnCompanyName, #EmpName {
        white-space: pre-wrap !important;
    }
</style>

