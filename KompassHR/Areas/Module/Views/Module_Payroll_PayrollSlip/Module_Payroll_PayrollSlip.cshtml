<script>
    function ViewPaySlip(SalaryID, format, EmpNo) {
        debugger
        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            url: '@Url.Action("GetPaySlipDetails", "Module_Payroll_PayrollSlip")',
            data: { SalaryID: SalaryID },
            success: function (response) {
                debugger;
                const json = response.GetPersonal[0];
                const transformed = {
                    GetPersonal: Object.fromEntries(
                        json.map(item =>[item.Key, item.Value])
                    )
                };
                $(".Userloaderbg").css("display", "none");
                var GetData = transformed.GetPersonal;

                $("#EmpName").html(GetData.EmployeeName);
                $("#EmpNo").html(GetData.EmployeeNo);
                $("#EmpDepartment").html(GetData.Department);
                $("#EmpDesignation").html(GetData.Designation);
                $("#EmpGrade").html(GetData.Grade);
                $("#EmpDOJ").html(GetData.JoiningDate);
                $("#EmpBankName").html(GetData.BankName);
                //let bankname= GetData.BankName;

                //alert(bankname);
                $("#EmpBankAccountNo").html(GetData.AccountNo);
                $("#EmpIFSCCode").html(GetData.IFSCCode);
                $("#EmpPFNo").html(GetData.PFNo);
                $("#EmpUANNo").html(GetData.UAN);
                $("#EmpESICNo").html(GetData.ESIC);
                $("#EmpLINNo").html(GetData.LIN);
                $("#EmpAadhaarNo").html(GetData.AadhaarNo);
                $("#EmpPANNo").html(GetData.PAN);
                //$("#spnCompanyName").html(GetData.CompanyName.replace(/\u00A0/g, '&nbsp;'));
                $("#spnCompanyName").html(GetData.CompanyName);
                $("#spnBranchName").html(GetData.BranchName);
                $("#spnNetPay").html(GetData.NetPay);

                $("#spnMonth").html(GetData.SalaryMonthYear);
                $("#spnAddress").html(GetData.BranchAddress);

                $("#lblMonthDays").html(GetData.SalaryMonthDays);
                $("#lblPaidDays").html(GetData.SalaryPayableDays);

                $("#spnStandardAmt").html(GetData.TotalStandardGross);
                $("#spnEarningAmt").html(GetData.TotalGross);
                $("#spnDeductionAmt").html(GetData.TotalDeduction);
                $("#spnNetPayInWord").html(GetData.InWord);

                //BIND ATTENDANCE DETAILS
                var GetAttendanceData = response.GetAttendance;
                let html = "";
                let columnCount = 0; // Track the number of columns in a row

                GetAttendanceData.forEach((item) => {
                    if (columnCount === 0) {
                        html += "<tr>";
                    }
                    html += `<td class="attend-type"><b> ${item.AttenType} :</b></td><td>${item.Total}</td>`;
                    columnCount += 2; // Increment column count (2 columns per item)
                    // Close the current row after 4 columns (2 pairs of Head and DeductionAmt)
                    if (columnCount === 14) {
                        html += "</tr>";
                        columnCount = 0; // Reset column count for the next row
                    }
                });
                // Only add the last row if it contains exactly 4 columns
                if (columnCount !== 0) {
                    html += "</tr>";
                }
                document.getElementById("tblAttendanceInfo").innerHTML = html;

                var GetEarningData = response.GetEarning;
                var GetDeductionData = response.GetDeduction;

                var tableBody = $('#tblCombined tbody');
                tableBody.empty(); // Clear existing rows

                // Iterate over the longer array to ensure all data is displayed
                var maxLength = Math.max(GetEarningData.length, GetDeductionData.length);

                for (var i = 0; i < maxLength; i++) {
                    var earning = GetEarningData[i] || {}; // Default to empty object if out of bounds
                    var deduction = GetDeductionData[i] || {}; // Default to empty object if out of bounds

                    var row = $('<tr>');
                    row.append('<td style="text-align: left;">' + (earning.Head || '') + '</td>');
                    row.append('<td style="text-align: right;">' + (earning.StandardAmt || '') + '</td>');
                    row.append('<td style="text-align: right;">' + (earning.EarningAmt || '') + '</td>');
                    row.append('<td hidden>' + (earning.ArreasAmt || '') + '</td>');
                    row.append('<td style="text-align: left;">' + (deduction.Head || '') + '</td>');
                    row.append('<td style="text-align: right;">' + (deduction.DeductionAmt || '') + '</td>');

                    tableBody.append(row);
                }
                if (format == 'PDF') {
                    setTimeout(function () {
                        GeneratePDF();
                    }, 500);   // 500ms delay ensures DOM fully renders
                    return false;
                }
                else if (format == 'Mail') {
                    generateAndSendPDF(EmpNo);
                    return false;
                }
                else {
                    $('#PayslipMDL').modal('show');
                }
            }
        })
    }


</script>

<script>
    function generateAndSendPDF(EmpNo) {
        debugger;
        var empNumber = EmpNo;
        //$(".Userloaderbg").css("display", "flex");
        const jsPDF = window.jspdf.jsPDF;
        // Initialize jsPDF with A4 size
        const pdf = new jsPDF({
            orientation: 'portrait',
            unit: 'pt', // Points
            format: 'a4'
        });

        // Optional: browser preview logo (not used for email)
        var logoImg = new Image();
        logoImg.src = document.getElementById("CompanyLogo").src;

        logoImg.onload = function () {
            pdf.addImage(logoImg, 'PNG', 20, 20, 65, 65);
        };

        var printStyles = `
<style>
    body {
        font-family: 'helvetica', Tahoma, Geneva, Verdana, sans-serif !important;
        font-size: 13px !important;
    }
    #PayslipMDL .modal-body,
    #PayslipMDL form,
    #PayslipMDL table {
        font-family: 'helvetica', Tahoma, Geneva, Verdana, sans-serif !important;
        font-size: 13px !important;
    }
    #spnCompanyName, #EmpName {
        white-space: pre-wrap !important;
    }
</style>
`;
        const payslipContent = document.getElementById('payslip').innerHTML;
        const fullContent = printStyles + payslipContent;

        pdf.html(fullContent, {
            callback: function (doc) {
                //doc.save('Payslip.pdf');
            },
            x: 20,
            y: 100,
            width: 555,
            windowWidth: 800
        });

        // Get the content of the div and prepend the styles
        // Send content to server
        Swal.fire({
            title: 'Are you sure?',
            text: "Are yor sure for send mail!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, send it!',
            cancelButtonText: 'No, cancel!',
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("GenerateAndSendEmail", "Module_Payroll_PayrollSlip")',
                    //url: '/PDF/GenerateAndSendEmail',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ htmlContent: fullContent, EmpNo:empNumber }),
                    success: function (response) {
                        $(".Userloaderbg").css("display", "none");
                        if (response.success) {
                            Swal.fire({
                                icon: "success",
                                text: "Email sent successfully!",
                                allowOutsideClick: false // Disables click outside to close the alert
                            }).then(() => {
                                //window.location.reload();
                                return false;
                            });

                        } else {
                            Swal.fire({
                                icon: "error",
                                text: `Failed to send email: ${response.error}`,
                                allowOutsideClick: false
                            }).then(() => {
                                return false;
                            });
                        }
                    },
                    error: function () {
                        $(".Userloaderbg").css("display", "none");
                        alert("An error occurred while sending the email.");
                    }
                });
            }
        });
    }

</script>
<script>
    function GeneratePDF() {

        var element = document.getElementById('payslip');

        const opt = {
            margin: [0.3, 0.1, 0.3, 0.1], // smaller left & right margins
            filename: 'Payslip_' + document.getElementById('EmpNo').innerText + '.pdf',
            image: { type: 'png', quality: 0.98 },
            html2canvas: {
                scale: 2,
                useCORS: true,
                logging: false,
                scrollY: 0
            },
            jsPDF: {
                unit: 'in',
                format: 'a4',
                orientation: 'portrait'
            }
        };

        html2pdf()
            .set(opt)
            .from(element)
            .toPdf()
            .get('pdf')
            .then(function (pdf) {
                pdf.save(opt.filename);
            });
    }
</script>