                            <tfoot>
                                <tr>
                                    <td style="text-align:left"><strong>Total Earning</strong></td>
                                    <td style="text-align:right"><strong><span id="spnStandardAmt"></span></strong></td>
                                    <td style="text-align:right"><strong><span id="spnEarningAmt"></span></strong></td>
