                                <tr>
                                    <th>Earnings</th>
                                    <th>Standard Amount</th>
                                    <th>Earning Amount</th>
                                    <th hidden>Arrears Amount</th>
                                    <th>Deductions</th>
                                    <th>Deduction Amount</th>
                                </tr>
                            </thead>
                            <tbody>
