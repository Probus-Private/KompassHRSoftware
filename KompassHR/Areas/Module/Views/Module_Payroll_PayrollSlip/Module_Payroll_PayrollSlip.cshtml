                                border: 1px solid black; /* Adds a border to cells */
                            }
                    </style>
                </form>
                <div class="text-center" style="margin-top:5px;">

                    <div class="mb-4">This is a computer generated report and does not required signature </div>
                </div>
            </div>
        </div>
    </div>
</div>
