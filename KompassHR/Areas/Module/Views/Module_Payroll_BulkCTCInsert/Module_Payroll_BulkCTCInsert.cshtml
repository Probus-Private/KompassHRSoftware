<script>
    function downloadExcelFile() {
        debugger;

        var CmpID = encodeURIComponent($("#ddlCmpId").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        if (CmpID == "") {
            $("#errorCmpId").html("Company name is required");
            $("#errorCmpId").css("display", "flex"); return false;
        }
        else {
            $("#errorCmpId").html("");
        }
        //if (BranchId == "") {
        //    $("#errorBranchId").html("Business unit is required");
        //    $("#errorBranchId").css("display", "flex"); return false;
        //}
        //else {
        //    $("#errorBranchId").html("");
        //}
        $(".Userloaderbg").css("display", "flex");
        var url = `@Url.Action("DownloadExcelFile", "Module_Payroll_BulkCTCInsert")?CmpId=${CmpID}&BranchId=${BranchId}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function (data) {
                debugger;
                if (data.size == 0) {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }

                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'BulkCTCInsert.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function (xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }
    $('#SavePayroll_BulkCTCInsert').validate({
        rules: {
            AttachFile: {
                required: true,
            },
        },
        messages: {
            AttachFile: {
                required: "Choose a file",
            },
        },
    });
    var form = $("#SavePayroll_BulkCTCInsert");
    form.validate();

    $("#btnImport").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        //$("#DivSubmit").show();
        $("#SavePayroll_BulkCTCInsert").submit();
    });
</script>

<script>
    $("#btnSubmit").click(function () {
        debugger;

        var CmpID = encodeURIComponent($("#ddlCmpId").val());
        if (CmpID == "") {
            $("#errorCmpId").html("Company name is required");
            $("#errorCmpId").css("display", "flex"); return false;
        }
        else {
            $("#errorCmpId").html("");
        }
        var table = document.getElementById("tblTableBulkCTCInsert");
        var rowCount = table.rows.length;
        if (rowCount > 1) {
            $("#DivSubmit").show();
        }
        else {
            Swal.fire({
                icon: "error",
                text: "Insert a file",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)

                    return false
                }
            });
        }

        var ObjBulkCTCInsert = [];
        var headers = [];

        // Collect all table headers, skipping the first one (Delete)
        $('#tblTableBulkCTCInsert thead th').each(function (index) {
            if (index !== 0) {
                headers.push($(this).text().trim());
            }
        });

        // Iterate through each row in tbody
        $('#tblTableBulkCTCInsert tbody tr').each(function () {
            var rowData = {};
            var $cells = $(this).find('td');

            // Start from cell index 1 to skip the Delete column
            for (var i = 1; i < $cells.length; i++) {
                var headerKey = headers[i - 1]; // Adjusted because headers skipped first column
                var $input = $cells.eq(i).find('input');
                var value = $input.length > 0 ? $input.val() : $cells.eq(i).text().trim();

                rowData[headerKey] = value;
            }

            ObjBulkCTCInsert.push(rowData);
        });



        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpdate", "Module_Payroll_BulkCTCInsert")',
            data: JSON.stringify({ CmpId: CmpID, ObjBulkCTCInsert: ObjBulkCTCInsert }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var a = JSON.parse(response);
                var rownumber = 0;
                var Message1 = a.Message;
                var Icon1 = a.Icon;
                var rownumber = a.rowno;
                if (Icon1 != "success") {

                    localStorage.setItem('Rowno', rownumber)
                }
                else {
                    localStorage.setItem('Rowno', rownumber)
                }

                if (Icon1 == 'error') {
                    $(".Userloaderbg").css("display", "none");
                    if (a.GetData!=null)
                    {
                        debugger;
                        const data =a.GetData;
                        const modal = $('#myEmployeeCTCInsert');
                        const tableBody = $('#tblBodyEmployeeCTCInsert');

                        modal.modal(data.length > 0 ? 'show' : 'hide');
                        tableBody.empty(); // Clear existing rows

                        if (data) {
                            data.forEach(item => {
                                const row = $('<tr>');

                                const employeeNoCell = item.find(e => e.Key === "EmployeeNo");
                                const employeeNameCell = item.find(e => e.Key === "EmployeeName");
                                const RemarkCell = item.find(e => e.Key === "Remark");
                                const DescriptionCell = item.find(e => e.Key === "Description");
                                row.append(`<td>${employeeNoCell ? employeeNoCell.Value : ''}</td>`);
                                row.append(`<td>${employeeNameCell ? employeeNameCell.Value : ''}</td>`);
                                row.append(`<td>${RemarkCell ? RemarkCell.Value : ''}</td>`);
                                row.append(`<td>${DescriptionCell ? DescriptionCell.Value : ''}</td>`);

                                tableBody.append(row);
                            });
                        }
                    }
                    else{
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                            }
                        }
                    }
                }
                else {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    $('#tblTableBodyBulkInsert').not(function () { return !!$(this).has('th').length; }).remove();
                                    window.location.href = '@Url.Action("Module_Payroll_BulkCTCInsert", "Module_Payroll_BulkCTCInsert")';

                                } else if (
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })
                        }
                    }
                }
            }
        });
    });
</script>
