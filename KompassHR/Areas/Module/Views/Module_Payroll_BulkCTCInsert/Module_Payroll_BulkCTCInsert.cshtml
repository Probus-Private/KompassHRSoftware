        const BranchColumnIndex = $table.find('thead th').filter(function () {
            return $(this).text().trim().toLowerCase() === "business unit";
        }).index();

        if (BranchColumnIndex === -1) {
            return Swal.fire({ icon: "error", text: "Business unit column not found!" });
        }

        const $input = $row.find('td').eq(BranchColumnIndex).find('input');
        if (!$input.length) {
            return Swal.fire({ icon: "error", text: "Business unit input not found in SrNo " + rowNumber + "!" });
        }

        $input.val(BranchId);
