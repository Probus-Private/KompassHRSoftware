@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_BulkCTCInsert
@{
    ViewBag.Title = "Module_Payroll_BulkCTCInsert";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Required library for validation -->
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>

<style>
    .error {
        text-align: left;
        height: 35px;
        color: red;
        font-size: 12px;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 100px; /* Set the width for the first column */
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .select2.select2-container {
        width: 100% !important;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Bulk CTC Insert
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Bulk CTC Insert  </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>

                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-6 -backdrop-hue-rotate-15">
                                            @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { id = "ddlCmpId", @class = "form-select", name = "CmpId", autocomplete = "off" })
                                            <span id="errorCmpId" class="error" style="display:none"> </span>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" id="btnApplyCompanyName"
                                                    class="btn btn-primary btn-sm">
                                                @*<i class="fa-solid fa-floppy-disk"></i>*@ Apply
                                            </button>

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Business Unit
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--All--", new { id = "ddlBranchId", @class = "form-select", name = "CmpId", autocomplete = "off" })
                                            <span id="errorBranchId" class="error" style="display:none"> </span>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" id="btnApplyBusinessUnit"
                                                    class="btn btn-primary btn-sm">
                                                @*<i class="fa-solid fa-floppy-disk"></i>*@ Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <button type="button" id="btnExcelFile" onclick="downloadExcelFile()"
                                            class="btn btn-success btn-sm">
                                        @*<i class="fa-solid fa-floppy-disk"></i>*@ Export
                                    </button>
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Category Name
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.CategoryId, new SelectList(ViewBag.CTC_Category, "Id", "Name"), "--Select--", new { id = "ddlCategoryId", @class = "form-select", name = "CmpId", autocomplete = "off" })
                                            <span id="errorCategoryId" class="error" style="display:none"> </span>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" id="btnApplyCategoryName" onclick="ApplyFile()"
                                                    class="btn btn-primary btn-sm">
                                                @*<i class="fa-solid fa-floppy-disk"></i>*@ Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Salary Tranfer From Bank
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.SalaryBankTranfer, new SelectList(ViewBag.SalaryBankTranferName, "Id", "Name"), "--Select--", new { id = "ddlSalaryBankTranfer", @class = "form-select", name = "CmpId", autocomplete = "off" })
                                            <span id="errorSalaryBankTranfer" class="error" style="display:none"> </span>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" id="btnApplySalaryBankTranfer" onclick="ApplyFile()"
                                                    class="btn btn-primary btn-sm">
                                                @*<i class="fa-solid fa-floppy-disk"></i>*@ Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">

                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Salary Mode
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.SalaryModeId,new List<SelectListItem>
                                                {
                                                new SelectListItem { Text = "Bank-Salary", Value = "Bank-Salary" },
                                                new SelectListItem { Text = "Bank-NEFT", Value = "Bank-NEFT" },
                                                new SelectListItem { Text = "Cheque", Value = "Cheque" },
                                                new SelectListItem { Text = "Cash", Value = "Cash" },
                                                },
                                                new { id = "ddlSalaryModeId", @class = "form-select", autocomplete = "off", name = "RateSalaryMode" })
                                            <span id="errorSalaryModeId" class="error" style="display:none"> </span>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" id="btnApplySalaryMode" onclick="ApplyFile()"
                                                    class="btn btn-primary btn-sm">
                                                @*<i class="fa-solid fa-floppy-disk"></i>*@ Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Budget Name
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.BudgetId, new SelectList(ViewBag.BudgetName, "Id", "Name"), "--Select--", new { id = "ddlBudgetId", @class = "form-select", name = "CmpId", autocomplete = "off" })
                                            <span id="errorBudgetId" class="error" style="display:none"> </span>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" id="btnApplyBudgetName" onclick="ApplyFile()"
                                                    class="btn btn-primary btn-sm">
                                                @*<i class="fa-solid fa-floppy-disk"></i>*@ Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr />
                            <form role="form" action='@Url.Action("Module_Payroll_BulkCTCInsert", "Module_Payroll_BulkCTCInsert", new { area = "Module" })' id="SavePayroll_BulkCTCInsert" method="post" enctype="multipart/form-data" }>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Attach File
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                <input type="file" name="AttachFile" class="form-control" id="txtTreatmentOfSpecifiedDisease" onchange="ResetFile('TreatmentOfSpecifiedDisease')" />
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" id="btnImport"
                                                        class="btn btn-warning btn-sm">
                                                    @*<i class="fa-solid fa-floppy-disk"></i>*@ Import
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="panel panel-inverse" data-sortable-id="index-1">
                                        <div style="overflow-y:auto; overflow-x:auto">
                                            <div class="panel-body">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <!-- BEGIN table-responsive -->
                                                        <div class="table-scroll div1">
                                                            <div class="table-wrap">
                                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TableBulk" id="tblTableBulkCTCInsert">
                                                                    @{
                                                                        var headers = ViewBag.Headers as List<string>;
                                                                        var excelData = ViewBag.ExcelData as List<Dictionary<string, string>>;
                                                                    }

                                                                    @if (headers != null)
                                                                    {
                                                                        <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                                            <tr>
                                                                                <th>
                                                                                    Delete
                                                                                </th>
                                                                                @foreach (var header in headers)
                                                                                {
                                                                                    <th class="text-nowrap">@header</th>
                                                                                }
                                                                            </tr>
                                                                        </thead>
                                                                    }
                                                                    <tbody>
                                                                        @if (excelData != null && headers.Any() && excelData.Any())
                                                                        {
                                                                            foreach (var row in excelData)
                                                                            {
                                                                                <tr>
                                                                                    <td class="text-center">
                                                                                        <a onclick="DeleteROW()" id="btnDelete" style="cursor:pointer;">
                                                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                                        </a>
                                                                                    </td>
                                                                                    @{
                                                                                        int colIndex = 0;
                                                                                    }
                                                                                    @foreach (var header in headers)
                                                                                    {

                                                                                        string cellValue = row != null && row.ContainsKey(header) ? row[header] : "N/A";
                                                                                        bool isDateHeader = header.ToLower().Contains("date");

                                                                                        if (colIndex < 11)
                                                                                        {
                                                                                            <td class="text-nowrap">
                                                                                                <input type="@(isDateHeader ? "date" : "text")" class="form-control" style="height:23px;width:225px;" value="@(!string.IsNullOrWhiteSpace(cellValue) ? cellValue : (isDateHeader ? "" : "N/A"))" />
                                                                                            </td>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <td class="text-nowrap" style="width:150px;">@(!string.IsNullOrWhiteSpace(cellValue) ? cellValue : "N/A")</td>
                                                                                        }

                                                                                        colIndex++;
                                                                                    }
                                                                                </tr>
                                                                                            }
                                                                                        }

                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row" id="DivSubmit">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit"
                                                            class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- #Start modal-dialog -->
