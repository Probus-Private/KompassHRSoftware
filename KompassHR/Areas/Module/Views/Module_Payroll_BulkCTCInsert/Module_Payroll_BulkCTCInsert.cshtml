        }

        const $row = $table.find('tbody tr').eq(rowNumber - 1);

        const BudgetIdColumnIndex = $table.find('thead th').filter(function () {
            return $(this).text().trim().toLowerCase() === "budget";
        }).index();

        if (BudgetIdColumnIndex === -1) {
            return Swal.fire({ icon: "error", text: "Budget column not found!" });
        }

        const $input = $row.find('td').eq(BudgetIdColumnIndex).find('input');
        if (!$input.length) {
            return Swal.fire({ icon: "error", text: "Budget input not found in SrNo " + rowNumber + "!" });
        }

        $input.val(BudgetId);
        Swal.fire({ icon: "success", text: "Budget applied at SrNo " + rowNumber + "!" });
    });


</script>


