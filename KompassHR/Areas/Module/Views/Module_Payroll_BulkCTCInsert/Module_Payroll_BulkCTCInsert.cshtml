<script>
    //ddlCmpId
    $("#btnApplyCompanyName").click(function () {
        const Company = $("#ddlCmpId option:selected").text();
        if (Company === "--Select--") {
            return Swal.fire({ icon: "error", text: "Select Company!" });
        }

        let rowNumber = parseInt(localStorage.getItem('Rowno')) || 1;

        // Select the correct table — only the visible one
        const $table = $('#tblTableBulkCTCInsert:visible');

        // Check if table is found
        if (!$table.length) {
            return Swal.fire({ icon: "error", text: "Target table not found!" });
        }

        const $row = $table.find('tbody tr').eq(rowNumber - 1);

        const companyColumnIndex = $table.find('thead th').filter(function () {
            return $(this).text().trim().toLowerCase() === "company name";
        }).index();

        if (companyColumnIndex === -1) {
            return Swal.fire({ icon: "error", text: "Company Name column not found!" });
        }

        const $input = $row.find('td').eq(companyColumnIndex).find('input');
        if (!$input.length) {
            return Swal.fire({ icon: "error", text: "Company Name input not found in SrNo " + rowNumber + "!" });
        }

        $input.val(Company);
        Swal.fire({ icon: "success", text: "Company applied at SrNo " + rowNumber + "!" });
    });

    //ddlBranchId
    $("#btnApplyBusinessUnit").click(function () {
        const BranchId = $("#ddlBranchId option:selected").text();
        if (BranchId === "--Select--") {
            return Swal.fire({ icon: "error", text: "Select Company!" });
        }

