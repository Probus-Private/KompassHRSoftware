<script>

    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function (value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   }, "erreur expression reguliere"
);

    $("#SaveComplianceCalender").validate({

        rules: {
            ComplianceId:
                {
                required: true,
                },
            ComplianceCategoryId:
                {
                required: true,
                },
               Type:
                {
                    required: true,
                },
          
            EndDate:{
                required:true,
            },


        },
        messages: {

            ComplianceId: {
                required: "Enter the Compliance Name",
            },
            ComplianceCategoryId: {
                required: "Select the category",
            },
            Type: {
                required: "Type is required",
            },
            EndDate:{
                required:"End Date is required"
            },

        },
        errorPlacement: function (error, element) {
            if (element.hasClass("select2-hidden-accessible")) {
                error.insertAfter(element.next('.select2'));
            } else {
                error.insertAfter(element);
            }
        },

    });


    var form = $("#SaveComplianceCalender");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if (form.valid() == false) {
            return false;
        }
    //    form.submit();
    //});

   var ComplianceCalenderId_Encrypted = $("#txtComplianceCalenderId_Encrypted").val();
   var ComplianceId = $("#ddlComplianceName").val();
        var ComplianceCategoryId = $("#ddlComplianceCategoryId").val();
        var EndDate=$("#txtEndDate").val();
        var Type=$("#txtType").val();
        
       // var FinantialYear=$("#ddlFinantialYear").val();

        $.ajax({
            url: '@Url.Action("IsExists", "Module_Payroll_ESSComplianceCalender")',
            method: "get",
            data:
                {
                    ComplianceCalenderId_Encrypted: ComplianceCalenderId_Encrypted,
                    ComplianceId:ComplianceId,
                    ComplianceCategoryId:ComplianceCategoryId,
                    EndDate:EndDate,
                    Type:Type
                   // FinantialYear:FinantialYear
                },

            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: false
                        }).then(() => {
                            const p = Swal.getPopup();
                            p.classList.add('animate__headShake');
                            setTimeout(() => p.classList.remove('animate__headShake'), 500);
                        });
                    }
                }
                else
                {
                    debugger;
                    $("#SaveComplianceCalender").submit();
                }
            }
        });
    });


