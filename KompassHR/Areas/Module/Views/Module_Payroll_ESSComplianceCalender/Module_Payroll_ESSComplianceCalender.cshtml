
@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_ESSComplianceCalender

@{
    ViewBag.Title = "Module_Payroll_ESSComplianceCalender";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Payroll Compliance calender
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu",  new {id =6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Payroll Compliance calender- @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Payroll Compliance calender
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Payroll_ESSComplianceCalender", new { area = "Module" })' id="SaveComplianceCalender" method="post" enctype="multipart/form-data">
                                @Html.HiddenFor(model => model.ComplianceCalenderId_Encrypted, new { id = "txtComplianceCalenderId_Encrypted" })
                                @Html.HiddenFor(model => model.ComplianceCalenderId, new { id = "txtComplianceCalenderId" })

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Compliance Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ComplianceCategoryId, new SelectList(ViewBag.ComplianceCategory, "Id", "Name"), "Select", new { id = "ddlComplianceCategoryId", @class = "form-select", autocomplete = "off", name = "ComplianceCategoryId" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Compliance Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ComplianceId, new SelectList(ViewBag.ComplianceName, "Id", "Name"), "Select", new { id = "ddlComplianceName", @class = "form-select", autocomplete = "off", name = "ComplianceId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
  
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Type
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Type, new { id = "txtType", name = "Type", @class = "form-control", autocomplete = "off", @readonly = "readonly"})
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Remark
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Remark, new { id = "txtRemark", @class = "form-control", autocomplete = "off", name = "Remark" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Attachment
                                            </label>
                                            <div class="col-md-8">
                                                <div class="input-group">
                                                    <input type="file" class="form-control" id="Attachment" name="Attachment" accept=".pdf">
                                                </div>
                                            </div>

                                            @if (Model != null && !string.IsNullOrEmpty(Model.Attachment))
                                            {
                                                <a href="@Url.Action("DownloadAttachment", "ESS_Curve_Reminder", new { DownloadAttachment = Model.Attachment })"
                                                   class="btn btn-sm btn-link">
                                                    <i class="fas fa-download"></i><label class="form-label col-form-label col-md-12" id="fileUploadFile-lbltext">@TempData["Attachment"]</label>
                                                </a>
                                            }
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Submit Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @*@Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", id = "txtEndDate", name = "EndDate", autocomplete = "Off", type = "date", value = Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "" })*@
                                                @Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", id = "txtEndDate", name = "EndDate", autocomplete = "Off", type = "date" })
                                             </div>
                                        </div>
                                    </div>
                                    </div>

                                <div class="row">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("GetList", "Module_Payroll_ESSComplianceCalender", new { area = "Module" })">
                                                            <button type="button" class="btn btn-danger btn-sm" id="btnDesignationGetList">
                                                                <i class="fa-solid fa-share-from-square"></i> List
                                                            </button>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

