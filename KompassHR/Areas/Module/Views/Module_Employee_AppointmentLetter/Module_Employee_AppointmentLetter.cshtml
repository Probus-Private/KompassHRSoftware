<script>
    $("#btnShow").on("click", function (event) {
        event.preventDefault(); // Prevent form submission and page reload

        var EmployeeID = Number($("#ddlEmployeeName").val());
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: '@Url.Action("GetEmployeeDetails", "Module_Employee_AppointmentLetter")',
            data: { EmployeeID: EmployeeID },
            success: function (data) {
                const result = data[0].reduce((acc, item) => {
                    acc[item.Key] = item.Value;
                    return acc;
                }, {});

                // Now 'result' contains the formatted object
                console.log(result);
                $(".ContractorName").html(result.ContractorName);
                $(".ContractorAddress").html(result.ContractorAddress);
                $(".EmployeeCode").html(result.EmployeeNo);
                $(".EmployeeName").html(result.EmployeeName);
                $(".HusbandName").html(result.HusbandName);
                $(".PermanentAddress").html(result.PermanentAddress);
                var timestamp1 = result.DOB.match(/\d+/)[0];
                var date1 = new Date(parseInt(timestamp1));
                var formattedDate1 = date1.toLocaleDateString();
                $(".DOB").html(formattedDate1);
                var timestamp = result.DOJ.match(/\d+/)[0];
                var date = new Date(parseInt(timestamp));
                var formattedDate = date.toLocaleDateString();
                $(".DOJ").html(formattedDate);
                $(".EsicNo").html(result.EsicNo);
                $(".EPFNo").html(result.EPFNo);
                $(".UANNo").html(result.UANNo);
                $(".Department").html(result.Department);
                $(".Designation").html(result.Designation);
                $(".Salary").html(result.Salary);
                $(".Idtype").html(result.Idtype);
                $(".Idtypeno").html(result.Idtypeno);
                $(".ContactNo").html(result.ContactNo);
                $(".Companyname").html(result.Companyname);
                $(".CompanyAddress").html(result.CompanyAddress);
                $(".MaritalStatus").html(result.MaritalStatus);
                $(".NomineeName").html(result.NomineeName);
                $(".NomineeRelation").html(result.NomineeRelation);
                $(".NomineeAge").html(result.NomineeAge);
                $(".Grautitypercentage").html(result.Grautitypercentage);
                $(".Gender").html(result.Gender);
                $(".Religion").html(result.Religion);
                $(".CreatedBy").html(result.CreatedBy);
                $(".DeclarationWitness").html(result.DeclarationWitness);
                $(".DeclarationWitness2").html(result.DeclarationWitness2);

                $("#divPrint").show();
                $("#btnPrint").show();
            },
            error: function (xhr, status, error) {
                console.log("Error: " + error);
            }
        });
    });

</script>



<script>
    function printInvoice() {
        event.preventDefault();
        const divPrint = document.getElementById('divPrint').cloneNode(true); // Clone content

        // Create an invisible iframe
        const iframe = document.createElement('iframe');
        iframe.style.position = 'absolute';
        iframe.style.width = '0px';
        iframe.style.height = '0px';
        iframe.style.border = 'none';
        document.body.appendChild(iframe);

        const iframeDoc = iframe.contentWindow.document;
        iframeDoc.open();
        iframeDoc.write(`
        <html>
            <head>
                <title>Print</title>
                <style>
                    @@page { size: A4; margin: 10mm; }
                    body { font-family: Arial, sans-serif; font-size: 12px; margin: 0; padding: 0; }
                    table, th, td { border: 1px solid black; border-collapse: collapse; padding: 5px; text-align: center; }
                    /* Add page numbers */
                @@page {
                    @@bottom-center {
                    content: "Page " counter(page);
                    text-align: right;
                    }
        }
                </style>
            </head>
            <body>
                ${divPrint.innerHTML}
            </body>
        </html>
    `);
        iframeDoc.close();

        // Print using iframe
        iframe.contentWindow.focus();
        iframe.contentWindow.print();

        // Remove iframe after printing to prevent memory leaks
        iframe.contentWindow.onafterprint = () => document.body.removeChild(iframe);

        // Delay removal of iframe to avoid page reload
        iframe.contentWindow.onafterprint = () => {
            setTimeout(() => {
                document.body.removeChild(iframe);
            }, 500);
        };
    }
</script>

