<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        /*overflow: auto;*/
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    #tblInvoice {
        width: 100%;
        font-size: 11px;
        font-family: 'Arial', sans-serif;
        /*font-family: 'Montserrat', sans-serif;*/
    }

    .thcmphead {
        font-size: 14px;
        font-weight: bold;
    }

    #divPrint {
        display: none;
    }

    #btnPrint {
        display: none;
    }
</style>
<style>
    /* Apply styles to the table container */
    .table-container {
        max-height: 500px; /* Set max height for vertical scrolling */
        overflow: auto; /* Enable both horizontal and vertical scrolling */
        border: 1px solid #ccc;
        padding: 0px;
    }

        /* Scrollbar customization for WebKit browsers (Chrome, Edge, Safari) */
        .table-container::-webkit-scrollbar {
            width: 10px; /* Thin vertical scrollbar */
            height: 10px; /* Thin horizontal scrollbar */
        }

        /* Scrollbar track */
        .table-container::-webkit-scrollbar-track {
            background: #f1f1f1; /* Light background */
            border-radius: 10px; /* Round shape */
        }

        /* Scrollbar handle */
        .table-container::-webkit-scrollbar-thumb {
            background: #888; /* Darker scrollbar */
            border-radius: 10px; /* Rounded edges */
        }

            /* On hover */
            .table-container::-webkit-scrollbar-thumb:hover {
                background: #555; /* Darker on hover */
            }

    /* For Firefox */
    .table-container {
        scrollbar-width: thin; /* Small scrollbar */
        scrollbar-color: #888 #f1f1f1; /* Thumb and track color */
    }
</style>

