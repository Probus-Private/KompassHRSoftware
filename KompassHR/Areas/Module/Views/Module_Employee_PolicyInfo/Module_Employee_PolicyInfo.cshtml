<div class="row">
    @Html.Action("Onboarding_SidebarMenu", "Module_Employee_PersonalInfo")
</div>

<script>
    $(document).ready(function () {
        var CmpId = @Html.Raw(Json.Encode(TempData["CmpId"]));
        $.ajax({
            type: 'GET',
            dataType: 'JSON',
            contentType: "application/json; charset=utf-8",
            url: 'GetPolicy',
            data: { CmpId: CmpId },
            success: function (data) {
                //console.log(data);
                var Obj = data.GetList;
                var Obj1=data.PolicyList;
                if (data != null) {
                    debugger;
                    var table = document.getElementById("tblPolicyGroupdata");
                    $.each(Obj, function (data, value) {
                        var rowCount = table.rows.length;
                        var row = table.insertRow(rowCount);
                        var count = $('#tblPolicyGroupdata tr td').length;
                      
                        row.insertCell(0).innerHTML = "" + '<input id="chk" type="checkbox" name="checkBoxName" class="form-check-input chkPolicy" Value="' + value.PolicyLibraryId + '" >' + ""
                        row.insertCell(1).innerHTML = "" + value.PolicyName + "";
                        row.insertCell(2).innerHTML = "" + value.remark + "";
                        row.insertCell(3).innerHTML = "" + '<a href="' + value.DocumentPath + '"><i class="fa fa-download" style="font-size:large;color:blue"></i></a>' + "";

                    });      
                }
                else{

                }
            }
        })
    });
</script>

<script>
    function ApproveReject() {
        debugger;
        var RecordList = new Array();
        $(':checkbox:checked').each(function (i) {
            debugger;
            var datas = {};
            datas.PolicyId = $(this).val();

            RecordList.push(datas);
        });
        if (RecordList == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
        $.ajax({
            type: "POST",
            url: "SaveUpdate",
            data: JSON.stringify(RecordList),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                var datas = JSON.parse(data);
                if (datas != null) {

                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("PolicyInformation", "PolicyInformation")';
                        window.location.href = url;
                    });
                }
                }
        });
    }
</script>


