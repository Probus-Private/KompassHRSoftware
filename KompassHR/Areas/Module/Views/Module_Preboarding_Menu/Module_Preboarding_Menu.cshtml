
@{
    ViewBag.Title = "Module_Preboarding_Menu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ================== Icon Css ================== -->
<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />
<link href="~/assets/MyCSS/MenuImages.css" rel="stylesheet" />
<link href="~/Content/Site.css" rel="stylesheet" />
<!-- ================== End SWEEand css ================== -->


<div id="content" class="app-content">
    <div class="pageHeader d-flex align-items-center justify-content-between" style="flex-wrap:nowrap;">
        <h5 class="page-header text-center text-md-start">Preboarding</h5>
        <ol class="breadcrumb float-md-end mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                    <img src="~/assets/img/Icons/home-button.png" class="img-fluid" style="max-width: 40%;float:right" />
                </a>
            </li>
        </ol>

    </div>
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p> <b>Preboarding is</b> the period of time between an employee accepting their job offer and their first day. Essentially, it’s a subsection of the overarching onboarding process.</p>
                </div>

                <div class="panel-body">
                    <div class="row mb-20px">
                        <!-- BEGIN col-2 -->
                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-blue mb-7px">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-dollar-sign fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Preboarding Link</div>
                                    <div class="stats-number">
                                        @if (TempData["PreboardingLinkCount"] != null)
                                        {
                                            <a href="@Url.Action("GetList", "Module_Preboarding_CreateLink")"
                                               id="anchorApprovals"
                                               style="color:white;"
                                               onclick="Showdata('RECR03', 'Approvals pending with me'); return false;">
                                                @TempData["PreboardingLinkCount"]
                                            </a>
                                        }

                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 40.5%;"></div>
                                    </div>
                                    <div class="stats-desc">Open Raised by me</div>
                                </div>
                            </div>
                        </div>
                        <!-- END col-2 -->
                        <!-- BEGIN col-2 -->
                        <div class="col-lg-2 col-sm-6">
                            <div class="idget widget-stats bg-teal mb-7px">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-globe fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Pending For Verification</div>
                                    <div class="stats-number">
                                        @if (TempData["PendingforVerification"] != null)
                                        {
                                            <a href="@Url.Action("Module_Preboarding_VerificationList", "Module_Preboarding_VerificationList")"
                                               id="anchorApprovals"
                                               style="color:white;"
                                               onclick="Showdata('RECR03', 'Approvals pending with me'); return false;">
                                                @TempData["PendingforVerification"]
                                            </a>
                                        }

                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 40.5%;"></div>
                                    </div>
                                    <div class="stats-desc">Approvals pending with me</div>
                                </div>
                            </div>
                        </div>
                        <!-- END col-2 -->
                        <!-- BEGIN col-2 -->
                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-purple mb-7px">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-archive fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Approved Candidate</div>
                                    <div class="stats-number">
                                        @if (TempData["PendingforVerification"] != null)
                                        {
                                            <a href="@Url.Action("Module_Preboarding_VerificationList", "Module_Preboarding_VerificationList")"
                                               id="anchorApprovals"
                                               style="color:white;"
                                               onclick="Showdata('RECR03', 'Approvals pending with me'); return false;">
                                                @TempData["ApprovedCandidate"]
                                            </a>
                                        }
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 76.3%;"></div>
                                    </div>
                                    <div class="stats-desc">Approved candidate by me </div>
                                </div>
                            </div>
                        </div>
                        <!-- END col-2 -->
                        <!-- BEGIN col-4 -->
                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-dark mb-7px">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-comment-alt fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Rejected Candidate</div>
                                    <div class="stats-number">
                                        @if (TempData["PendingforVerification"] != null)
                                        {
                                            <a href="@Url.Action("Module_Preboarding_VerificationList", "Module_Preboarding_VerificationList")"
                                               id="anchorApprovals"
                                               style="color:white;"
                                               onclick="Showdata('RECR03', 'Approvals pending with me'); return false;">
                                                0
                                            </a>
                                        }
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 54.9%;"></div>
                                    </div>
                                    <div class="stats-desc"> Approved candidate by me</div>
                                </div>
                            </div>
                        </div>
                        <!-- END col-2 -->
                        <!-- BEGIN col-2 -->
                        <div class="col-lg-2 col-sm-6">
                            <div class="widget widget-stats bg-orange mb-7px">
                                <div class="stats-icon stats-icon-lg"><i class="fa fa-file-alt fa-fw"></i></div>
                                <div class="stats-content" style="height:100px;">
                                    <div class="stats-title">Onboarded Candidate</div>
                                    <div class="stats-number">
                                        @if (TempData["PendingforVerification"] != null)
                                        {
                                            <a href="@Url.Action("Module_Preboarding_VerificationList", "Module_Preboarding_VerificationList")"
                                               id="anchorApprovals"
                                               style="color:white;"
                                               onclick="Showdata('RECR03', 'Approvals pending with me'); return false;">
                                                @TempData["OnboardCandidate"]
                                            </a>
                                        }
                                    </div>
                                    <div class="stats-progress progress">
                                        <div class="progress-bar" style="width: 23.5%;"></div>
                                    </div>
                                    <div class="stats-desc">Onboarded candidate by me</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="gradientLine-Div">
                        <div class="gradientLine1"> </div>
                        <div><strong>Menu</strong></div>
                        <div class="gradientLine2"> </div>
                    </div>
                    <div class="row">

                        <div class="col-md-12">
                            <div class="row" style="padding: 0px 5px;">
                                @foreach (var item in ViewBag.GetUserMenuList)
                                {
                                    <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" class="col-md-2 col-3 d-flex" style="text-decoration:none !important; padding: 0px 5px;">

                                        <div class="quickLinks-box" style="margin-bottom: 10px;">
                                            <img src="~/assets/MenuImages/@item.Icon" width="50px" height="50px" />
                                            <h3>@item.ScreenDisplayMenuName</h3>
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

