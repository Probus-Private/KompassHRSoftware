@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_OtherEarning
@{
    ViewBag.Title = "Module_Payroll_OtherEarning";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /*.dataTables_wrapper .dataTables_scroll table.dataTable th, .dataTables_wrapper .dataTables_scroll tr.even td,
    .dataTables_wrapper .dataTables_scroll table.dataTable th, .dataTables_wrapper .dataTables_scroll tr.odd td{

          background-color:white !important;
        }*/
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Variable Earning
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Variable Earning  - Add @*<b>@ViewBag.AddUpdateTitle</b>*@  </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add variable earning here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Module_Payroll_OtherEarning", "Module_Payroll_OtherEarning", new { area = "Module" })' id="SaveOtherEarning" method="post" enctype="multipart/form-data" }">

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.VariableEarningCmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlCmpID", @class = "form-select", name = "CmpID" })
                                                @Html.ValidationMessageFor(model => model.VariableEarningCmpId, "", new { @class = "help-block", @id = "ErrorCmpID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.VariableEarningBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "All", new { id = "ddlOtherEarningBranchID", @class = "form-select", name = "OtherEarningBranchID" })
                                                @Html.ValidationMessageFor(model => model.VariableEarningBranchId, "", new { @class = "help-block", @id = "ErrorOtherEarningBranchID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Employee Name
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.VariableEarningEmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "All", new { id = "ddlOtherEarningEmployeeId", @class = "form-select", autocomplete = "off", name = "OtherEarningEmployeeId" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                Month /Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "month", id = "dateOtherEarningMonthYear", autocomplete = "Off", Name = "MonthYear" })
                                                @Html.ValidationMessageFor(model => model.MonthYear, "", new { @class = "help-block", @id = "ErrorOtherEarningMonthYear", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                Earning Name
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.VariableHead, new SelectList(ViewBag.GetHeadVariable, "Id", "Name"), "--Select--", new { id = "ddlOtherEarningEarningDeductionID", @class = "form-select", autocomplete = "off", name = "ddlOtherEarningEarningDeductionID" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Earning Sub-Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.OtherEarningName, new SelectList(ViewBag.GetOtherEarningName, "Id", "Name"), "--Select--", new { id = "ddlOtherEarningName", @class = "form-select", autocomplete = "off", name = "OtherEarningName" })
                                                @Html.ValidationMessageFor(model => model.OtherEarningName, "", new { @class = "help-block", @id = "ErrorOtherEarningEarningDeductionID", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" id="btnLoadEmployee" onclick="GetOtherEarning('Normal')"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-thin fa-user-magnifying-glass"></i>Load
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3"> Import File </label>
                                            <div class="col-md-9">
                                                <input type="file" name="AttachFile" class="form-control" id="FileVariableDeduction" onchange="ResetFile()" />
                                                <span id='validationMessage_' style='color: red;'></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-3">
                                                <button type="button" id="" onclick="GetOtherEarning('Excel')"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-solid fa-floppy-disk"></i> Import
                                                </button>
                                            </label>
                                            <label class="form-label col-form-label col-md-6">
                                                <a href="~/assets/BulkUpload/VariableEarning.xlsx" type="button" class="btn btn-success btn-sm">
                                                    <i class="fa-solid fa-download"></i>
                                                </a>
                                                Download Excel Format
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            <hr>
                            <div class="row">
                                <div class="col-md-12">
                                    <!-- BEGIN table-responsive -->
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle tblAddData TablePageEarning" id="tblOtherEarningHead" style="width: 100%;">
                                                <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="text-center">
                                                        <th class="text-center"><input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /> &nbsp; All</th>
                                                        <th class="text-nowrap"> Employee No</th>
                                                        <th class="text-nowrap"> Employee Name </th>
                                                        <th class="text-nowrap">Earning Name</th>
                                                        <th class="text-nowrap">Earning Sub-Category </th>
                                                        <th class="text-nowrap"> Amount</th>
                                                        <th class="text-nowrap"> Remarks</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tblEmployeeListOther">
                                                    @foreach (var d in ViewBag.GetOtherEarningEmployeeLoad)
                                                    {
                                                        <tr>
                                                            <td class="text-nowrap text-center"><input type="checkbox" class="form-check-input" /></td>
                                                            <td class="text-nowrap">@d.EmployeeNo</td>
                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                            <td class="text-nowrap">@d.CategoryName</td>
                                                            <td class="text-nowrap">@d.SubCategoryName</td>
                                                            @if (d.Amount != null)
                                                            {
                                                                <td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' onkeyup='AmountSum()' value="@d.Amount"></td>
                                                            }
                                                            else
                                                            {
                                                                <td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' onkeyup='AmountSum()'></td>
                                                            }
                                                            @if (d.Remark != null)
                                                            {
                                                                <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt' value="@d.Remark"></td>
                                                            }
                                                            else
                                                            {
                                                                <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt'></td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                @*<div class="col-md-4">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee No
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.OtherEarningAmount, new { @class = "form-control", type = "text", id = "txtOtherEarning", autocomplete = "Off", Name = "OtherEarningAmount" })
                                            </div>
                                        </div>
                                    </div>*@
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Total Record  :
                                        </label>

                                        <div class="col-md-9">
                                            <input type='text' id='lblTotalRecord' class='form-control' readonly="readonly" style="background:#eee">

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Total Amount :
                                        </label>
                                        <div class="col-md-9">
                                            <input type='text' id='lblTotalAmount' class='form-control' readonly="readonly" style="background:#eee">

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Amount
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.Amount, new { @class = "form-control totalAmount", type = "text", id = "txtOtherEarningAmount", Name = "OtherEarningAmount", @style = "text-align:right", onkeypress = " return numbervalidate(event)", autocomplete = "Off" })
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Remark
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", type = "text", id = "txtOtherEarningEarningremarks", autocomplete = "Off", Name = "txtOtherEarningEarningremarks" })

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnApply"
                                                    class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" onclick="funSave()"
                                                            class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "Module_Payroll_OtherEarning", new { area = "Module" })">
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnGetOtherEarningList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- #Start modal-dialog  myEmployeeNoModal-->
<div class="modal fade" id="myEmployeeNoModal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Variable earning for this category and month is already added.</h4>

            </div>
            <div style="height:400px; overflow-y:auto">
                <div class="modal-body">
                    <!-- BEGIN panel -->
                    <div class="modal-body-content">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="table-responsive">
                                    <table class="table table-bordered tblInnerAddData TabledataClass" id="tblHeadEmployeeNo" style="width: 100%">
                                        <caption hidden>Duplicate Employee No</caption>
                                        <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th class="text-nowrap">Company Name </th>
                                                <th class="text-nowrap">Business Unit </th>
                                                <th class="text-nowrap">Employee No</th>
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Department Name</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblEmployeeNo"></tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" onclick="tableToExcelEmployeeNo('testTable', 'EmployeeNo')" value="Export to Excel">
                    <i class="fa-solid fa-share-from-square"></i> Export to Excel
                </button>
                <button type="button" class="btn btn-danger btnpress CloseModel" id="CloseModel" data-bs-dismiss="modal" aria-hidden="true">
                    <i class="fa-solid fa-share-from-square"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    $(document).ready(function () {
        $("#ddlOtherEarningEmployeeId").select2();
        $("#ddlCmpID").select2();
        $("#ddlOtherEarningBranchID").select2();
        $("#ddlOtherEarningEarningDeductionID").select2();
        $("#ddlOtherEarningName").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }


        $("#ddlCmpID").on("change", function () {
            $("#ddlOtherEarningBranchID").find("option").remove();
            $("#ddlOtherEarningEarningDeductionID").find("option").remove();
            $("#ddlOtherEarningEmployeeId").find("option").remove();
            $("#ddlOtherEarningEmployeeId").append("<option value=0>All</option>");
            var CmpId = $("#ddlCmpID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Payroll_OtherEarning")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data.BranchName !=null) {
                        $("#ddlOtherEarningBranchID").append("<option value=''>All </option>");
                        $.each(data.BranchName, function(i, p) {
                            $("#ddlOtherEarningBranchID").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }

                    if (data.GetVeriableHead !=null) {
                        $("#ddlOtherEarningEarningDeductionID").append("<option value=''>--Select-- </option>");
                        $.each(data.GetVeriableHead, function(i, p) {
                            $("#ddlOtherEarningEarningDeductionID").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })


        $("#ddlOtherEarningBranchID").on("change", function () {
            debugger
            $("#ddlOtherEarningEmployeeId").find("option").remove();
            var BranchId = $("#ddlOtherEarningBranchID").val();
            var CmpID = $("#ddlCmpID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url:'@Url.Action("GetEmployeeName", "Module_Payroll_OtherEarning")',
                data: { BranchId: BranchId,CmpID:CmpID },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlOtherEarningEmployeeId").append("<option value=0>All</option>");
                        $.each(data, function(i, p) {
                            $("#ddlOtherEarningEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlOtherEarningEarningDeductionID").on("change", function () {
            $("#ddlOtherEarningName").find("option").remove();
            var VariableName = $("#ddlOtherEarningEarningDeductionID").val();
            var CmpId= $("#ddlCmpID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetOtherEarningName", "Module_Payroll_OtherEarning")',
                data: { VariableName: VariableName,CmpId:CmpId },
                success: function (data) {
                    if (data !=null) {
                        //   $("#ddlOtherEarningName").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlOtherEarningName").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })

        $('.TablePageEarning').DataTable({
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
        });

        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('dateOtherEarningMonthYear').value;
        if (CheckEmptyDate == "") {
            document.getElementById('dateOtherEarningMonthYear').value = defaultMonth;
        }

        var GetOtherEarningEmployeeLoad = @Html.Raw(Json.Encode(ViewBag.GetOtherEarningEmployeeLoad));
        var OtherEarninglength=GetOtherEarningEmployeeLoad.length;
        debugger;
