@model KompassHR.Areas.Module.Models.Module_Preboarding.Preboarding_Mas_Employee
@{
    ViewBag.Title = "Module_Preboarding_EmployeeApproval";
    Layout = "~/Views/Shared/_Layout.cshtml";
    //var Item = ViewBag.UploadDocumentList;
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>


<style>
    .important {
        margin-left: 3px;
        font-weight: 700;
        color: red;
    }

    .btnpress:focus-visible {
        outline: 0 !important;
    }

    .btnpress:active {
        transform: translateY(4px);
        color: #fff;
    }

    .BtnBx {
        display: flex;
        justify-content: end;
    }

        .BtnBx .btn {
            /* width: 80px; */
            margin: 5px 3px;
            font-size: 12px;
        }

    .table {
        font-weight: 600;
        font-size: 14px;
    }

    .trheading {
        background-color: rgba(233, 236, 239, 0.5);
    }

    .dataTables_scrollBody::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.1);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 6px;
        height: 5px;
        background-color: #fff;
    }

    .dataTables_scrollBody::-webkit-scrollbar-thumb {
        background-color: #777;
        height: 5px;
        border-radius: 10px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .head-bg-cyan {
        padding: .5rem .5rem;
    }


    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Employee CTC
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Preboarding_Menu", "Module_Preboarding_Menu", new {id = 2, ScreenId=137, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">Candidate Verification</h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Candidate Verification</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand">
                            <i class="fa fa-expand"></i>
                        </a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">


                    </p>
                </div>
                <div class="panel-body" style="overflow: auto !important;" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <form action='@Url.Action("SaveUpdatePersonalInfo", "Module_Preboarding_EmployeeApproval", new { area = "Module" })' id="SavePersonalDetails" method="post">
                                <div class="row mb-10px">
                                    <div class="col-lg-8 col-md-12 d-flex gap-4">
                                        <div class="imgbx">
                                            @*<img src="~/assets/img/user/user-1.jpg" style="width: 100%;" />*@
                                            <img id="fileData" style="height:150px; width: 130px;" src="@ViewBag.UploadPhoto" />
                                        </div>
                                        <div class="empbx">
                                            <span>
                                                <h4> <i class="fa-solid fa-user"></i>  @TempData["EmployeeName"]  </h4>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-briefcase"></i>  @TempData["DesignationName"] /  @TempData["DepartmentName"] </h6>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i>  @TempData["JoiningDate"]  </h6>
                                            </span>
                                        </div>
                                    </div>

                                    @*<div class="col-4" style="display:flex;justify-content: end; height: fit-content;">
                                            <button id="btnPrint" class="btn-primary btn-sm btn">Print</button>
                                        </div>*@
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <h5 class="text-white  head-bg-cyan mb-0 PersonalColor">
                                            Personal Details
                                        </h5>
                                    </div>
                                </div>

                                <div style="border:1px solid lightgray; padding:.5rem;">
                                    <div class="row mb-10px">
                                        <div class="col-md-12">
                                            <div class="card-row-title">
                                                Aadhar-Information
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">

                                        <div class="row mb-10px">
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">Aadhar No. </label>
                                                    <div class="col-md-10">
                                                        @Html.TextBoxFor(model => model.AadhaarNo, new { @class = "form-control", name = "AadhaarNo", type = "text", id = "txtAadhaarNo", autocomplete = "Off" })
                                                        @Html.HiddenFor(model => model.FID_Encrypted, new { id = "FID_Encrypted" })
                                                        @Html.HiddenFor(model => model.CmpId, new { id = "CmpId" })
                                                        @Html.HiddenFor(model => model.CmpId, new { id = "CmpId" })
                                                        @Html.HiddenFor(model => model.FID, new { id = "FID" })
                                                    </div>
                                                    <div class="col-md-2 DIVShowPanCard">
                                                        <div class="row mb-5px">
                                                            <label class="form-label col-form-label col-md-12">
                                                                @foreach (var d in ViewBag.UploadDocumentList)
                                                                {
                                                                    if (d.DocumentName == "Aadhr card")
                                                                    {
                                                                <a type="button" class="btn btn-success ListBtn btnpress" href="~/Module/Module_Preboarding_EmployeeApproval/UploadDocumentDownloadFile?UploadDocument=@d.UploadDocumentType " download>
                                                                    <i class="fa-solid fa-download"></i>
                                                                </a>
                                                                    }
                                                                    else
                                                                    {

                                                                    }

                                                                }

                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Name As Per Aadhar
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.NameAsPerAadhaar, new { @class = "form-control", name = "NameAsPerAadhaar", type = "text", id = "txtNameAsPerAadhaar", autocomplete = "Off" })
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <div class="row">
                                                        <label class="col-form-label"> </label>
                                                        <div class="col-md-8">
                                                            @Html.CheckBoxFor(model => model.AadhaarNoMobileNoLink, new { id = "chkAadhaarNoMobileNoLink" })
                                                            &nbsp; <label class="form-check-label form-label">
                                                                Is Mobile no.
                                                                link with Aadhar ?
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Aadhar Linked
                                                        Mobile No.
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.AadhaarNoMobileNo, new { @class = "form-control", name = "AadhaarNoMobileNo", type = "text", id = "txtAadhaarNoMobileNo", autocomplete = "Off" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="card-row-title">
                                                    PAN-Information
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-10px">
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">PAN </label>
                                                    <div class="col-md-10">
                                                        @Html.TextBoxFor(model => model.PanNo, new { @class = "form-control", name = "PanNo", type = "text", id = "txtPanNo", autocomplete = "Off" })
                                                    </div>
                                                    <div class="col-md-2 DIVShowPanCard">
                                                        <div class="row mb-5px">
                                                            <label class="form-label col-form-label col-md-12">
                                                                @foreach (var d in ViewBag.UploadDocumentList)
                                                                {
                                                                    if (d.DocumentName == "Pan Card")
                                                                    {
                                                                <a type="button" class="btn btn-success ListBtn btnpress" href="~/Module/Module_Preboarding_EmployeeApproval/UploadDocumentDownloadFile?UploadDocument=@d.UploadDocumentType " download>
                                                                    <i class="fa-solid fa-download"></i>
                                                                </a>
                                                                    }
                                                                    else
                                                                    {

                                                                    }

                                                                }

                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <div class="row">
                                                        <label class="col-form-label"> </label>
                                                        <div class="col-md-8">
                                                            @Html.CheckBoxFor(model => model.PANAadhaarLink, new { id = "chkPANAadhaarLink" })
                                                            &nbsp; <label class="form-check-label form-label">
                                                                PAN link with
                                                                Aadhar ?
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>


                                            <div class="col-md-12">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Name As Per PAN
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.NameAsPerPan, new { @class = "form-control", name = "NameAsPerPan", type = "text", id = "txtNameAsPerPan", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="card-row-title">
                                                    Contact-Information
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-10px">
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Primary Moblie
                                                        No.
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.Mobile1, new { @class = "form-control", name = "Mobile1", type = "text", id = "txtMobile1", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Secondary Moblie
                                                        No.
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.Mobile2, new { @class = "form-control", name = "Mobile2", type = "text", id = "txtMobile2", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        WhatsApp No.
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.WhatsAppNo, new { @class = "form-control", name = "WhatsAppNo", type = "text", id = "txtWhatsAppNo", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Personal Email Id
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.PersonalEmailID, new { @class = "form-control", name = "PersonalEmailID", type = "text", id = "txtPersonalEmailID", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="card-row-title">
                                                    Birth-Information
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-10px">
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Birth Date
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.BirthdayDate, new { @class = "form-control", name = "BirthdayDate", type = "date", id = "dateBirthdayDate", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Birth Place
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.BirthdayPlace, new { @class = "form-control", name = "BirthdayPlace", type = "text", id = "txtBirthdayPlace", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Birth Proof
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.DropDownListFor(model => model.BirthdayProofOfDocumentID, new SelectList(ViewBag.GetDocumentName, "Id", "Name"), "--Select--", new { id = "ddlBirthdayProofOfDocumentID", @class = "form-select", autocomplete = "off", name = "BirthdayProofOfDocumentID" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Document No.
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.BirthdayProofOfCertificateNo, new { @class = "form-control", name = "BirthdayProofOfCertificateNo", type = "text", id = "txtBirthdayProofOfCertificateNo", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="card-row-title">
                                                    Education-Information
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-10px">
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Highest Qualification
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.DropDownListFor(model => model.EmployeeQualificationID, new SelectList(ViewBag.GetQualificationName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeQualificationID", @class = "form-select", autocomplete = "off", name = "EmployeeQualificationID" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Specific Degree
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.QualificationRemark, new { @class = "form-control", name = "QualificationRemark", type = "text", id = "txtQualificationRemark", autocomplete = "Off", Maxlength = 70 })

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="card-row-title">
                                                    Gender / Marital And Other-Information
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-10px">
                                            <div class="col-md-4">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Gender
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.DropDownListFor(model => model.Gender, new List<SelectListItem> {
                                                        new SelectListItem { Text = "Male", Value = "Male"},
                                                        new SelectListItem { Text = "Female", Value = "Female"},
                                                        new SelectListItem { Text = "Other", Value = "Other"},
                                                        }, "--Select--", new { id = "ddlGender", @class = "form-select", autocomplete = "off", name = "Gender" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Blood Group
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.DropDownListFor(model => model.BloodGroup, new List<SelectListItem> {
                                                        new SelectListItem { Text = "A+ve", Value = "A+ve"},
                                                        new SelectListItem { Text = "A-ve", Value = "A-ve"},
                                                        new SelectListItem { Text = "AB+ve", Value = "AB+ve"},
                                                        new SelectListItem { Text = "AB-ve", Value = "AB-ve"},
                                                        new SelectListItem { Text = "B+ve", Value = "B+ve"},
                                                        new SelectListItem { Text = "B-ve", Value = "B-ve"},
                                                        new SelectListItem { Text = "O+ve", Value = "O+ve"},
                                                        new SelectListItem { Text = "O-ve", Value = "O-ve"},
                                                        }, "--Select--", new { id = "ddlBloodGroup", @class = "form-select", autocomplete = "off", name = "BloodGroup" })
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Marital Status
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.DropDownListFor(model => model.MaritalStatus, new List<SelectListItem> {
                                                        new SelectListItem { Text = "Married", Value = "Married"},
                                                        new SelectListItem { Text = "Unmarried", Value = "Unmarried"},
                                                        new SelectListItem { Text = "Widow", Value = "Widow"},
                                                        }, "--Select--", new { id = "ddlMaritalStatus", @class = "form-select", autocomplete = "off", name = "MaritalStatus" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="row mb-5px">
                                                    <label class="form-label col-form-label col-md-12">
                                                        Anniversary Date
                                                    </label>
                                                    <div class="col-md-12">
                                                        @Html.TextBoxFor(model => model.AnniversryDate, new { @class = "form-control", name = "AnniversryDate", type = "date", id = "dateAnniversryDate", autocomplete = "Off" })

                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="row mb-5px">
                                                    <div class="row">
                                                        <label class="col-form-label"> </label>
                                                        <div class="col-md-8">
                                                            @Html.CheckBoxFor(model => model.GenderNotDisclose, new { id = "chkGenderNotDisclose" })
                                                            &nbsp; <label class="form-check-label form-label">
                                                                No gender disclosure is desired by me
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="card-row-title">
                                                    Religion/Cast-Information
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row mb-10px">
                                            <div class="col-md-6">
