<script>
    $('#btnSearchBank').click(function () {
        debugger;
        var IFSCode = $('#txtPF_BankIFSC').val();
        if(IFSCode!=""){
            $.ajax({
                type: "GET",
                url: '@Url.Action("GetIFSCCode", "Module_Employee_BankInfo")',
                data: {IFSCode:IFSCode},
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    var data = JSON.parse(response);
                    if(data.data.length!=0)
                    {
                        var length = data.data.length
                        if(length==0)
                        {
                            $('#ErrortxtPF_BankIFSC').html("Please enter valid IFSC Code !"); $("#txtPF_BankIFSC").focus();  return false;
                        }
                        else
                        {
                            $('#ErrortxtPF_BankIFSC').html("");
                        }
                        if (length>0) {
                            $('#myModalPermanent').modal('show');
                        }
                        else
                        {
                            $('#myModalPermanent').modal('hide');
                        }
                        if (data.data != null) {
                            for (var i = 0; i <= data.data.length ; i++) {
                                var table = document.getElementById("tblIFSC_Code");
                                var rowCount = table.rows.length;
                                var row = table.insertRow(rowCount);
                                var count = $('#tblIFSC_Code tr').length;
                                var IFSCcodes=data.data[i];
                                for (var j = 0; j <= IFSCcodes.length-1; j++) {
                                    debugger;
                                    if (j >= IFSCcodes.length) { continue; }
                                    var IFSCKey=IFSCcodes[j].Key;
                                    var IFSCValue=IFSCcodes[j].Value;

                                    if(IFSCKey=="IFSCode")
                                    {
                                        row.insertCell(0).innerHTML ='<center><a href="javascript:;" class="CloseModel" data-bs-dismiss="modal" aria-hidden="true" id="CloseModel"><button type="button" id="btnOpenPopUp" class="btn btn-success ListBtn btnpress CloseModel"  onclick="EmployeeIFSCcodePermanent(this)">Select</button></a></center>';
                                        row.insertCell(1).innerHTML = "" + IFSCValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(1).innerHTML="";
                                    }
                                    if(IFSCKey=="BankName")
                                    {
                                        row.insertCell(2).innerHTML = "" + IFSCValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(2).innerHTML="";
                                    }
                                    if(IFSCKey=="BranchName")
                                    {
                                        row.insertCell(3).innerHTML = "" + IFSCValue+ "";
                                    }
                                    else
                                    {
                                        //row.insertCell(3).innerHTML="";
                                    }
                                    if(IFSCKey=="Address")
                                    {
                                        row.insertCell(4).innerHTML = "" + IFSCValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(4).innerHTML="";
                                    }
                                }
                            }
                        }
                    }
                    else{
                        var Message="IFSC Code is invalid !";
                        var Icon ="error";
                        if (Message != null) {
                            if (Message != null) {
                                Swal.fire({
                                    icon: Icon,
                                    text: Message,
                                    allowOutsideClick: false
                                });
                            }
                        }
                    }
                }
            });
        }
    });


    function EmployeeIFSCcodePermanent(tblRowPermanent)
    {
        debugger;
        var currentRow = $(tblRowPermanent).closest("tr");
        var BankName = currentRow.find("td:eq(2)").html();
        var BranchName = currentRow.find("td:eq(3)").html();
        var Address = currentRow.find("td:eq(4)").html();

        $("#txtPF_BankName").val(BankName);
        $(".CloseModel").click(function () {
            $('#tblIFSCcode tr').not(function () { return !!$(this).has('th').length; }).remove();
        })
    
    
        $.validator.addMethod("esicMedicalCheck", function(value, element) {
            var esic = $("#ddlESIC_Applicable").val();
            var medical = $("#ddlMedical_Insurance_Applicable").val();
            return !(esic === "true" && medical === "true");
        }, "ESIC Applicable and Medical Insurance Applicable both are not same.");
    
    }
</script>
