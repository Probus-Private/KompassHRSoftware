        }

    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    /*.div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }*/

    .fixed-side {
        position: sticky;
        left: 0px;
    }

    /*.fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .empbx h4 {
        margin-bottom: 5px;
    }

    .empbx h6 i {
        font-size: 1rem;
        margin-right: 5px;
    }

    .empbx {
        margin-bottom: 20px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Statutory Information
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new {id = 3, ScreenId=142, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">

                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Statutory Information - @ViewBag.AddUpdateTitle</h4>
                    @*<div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>*@
                </div>

                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Details regarding salary, wages, bonuses, benefits enrollment, retirement plans, insurance coverage, and other financial aspects of employment are recorded.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_StatutoryInfo", new { area = "Module" })' id="SaveStatutoryInfo" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="empbx">
                                            <span>
                                                <h4> <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"] </h4>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"] </h6>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"] </h6>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px" id="btnGet">
                                    <div class="col-md-6" style="width:fit-content;">
                                        <button type="button" id="btnGetPrebordingList" onclick="GetDetails('Pre')"
                                                class="btn btn-success btn-sm btnpress">
                                            <i class="fa-regular fa-copy"></i> Get
                                        </button>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            PT Code Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                PT Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.PT_Applicable, new List<SelectListItem>{
                                                 new SelectListItem {Text ="No", Value="false"},
                                                  new SelectListItem {Text ="Yes", Value="true"}
                                              }, new { @class = "form-select", name = "PT_Applicable", id = "ddlPT_Applicable", @onchange = "check()" })
                                                @Html.HiddenFor(model => model.StatutoryId_Encrypted, new { id = "StatutoryId_Encrypted" })

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                PT Code
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.PT_CodeId, new SelectList(ViewBag.GetPTStateCode, "Id", "Name"), "--Select--", new { id = "ddlPT_CodeId", @class = "form-select", autocomplete = "off", name = "PT_SettingID" })
                                                @Html.ValidationMessageFor(model => model.PT_CodeId, "", new { @class = "help-block", @id = "ErrorPT_SettingID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                PT Slab
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.PTSlab_MasterId, new SelectList(ViewBag.GetPTSlabMaster, "Id", "Name"), "--Select--", new { id = "ddlPTSlab_MasterId", @class = "form-select", autocomplete = "off", name = "PTSlab_MasterId" })
                                                @Html.ValidationMessageFor(model => model.PTSlab_MasterId, "", new { @class = "help-block", @id = "ErrorPTSlab_MasterId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            LWF Code Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                LWF Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.LWF_Applicable, new List<SelectListItem>{
                                                new SelectListItem {Text ="No", Value="false"},
                                                new SelectListItem {Text ="Yes", Value="true"}
                                              }, new { @class = "form-select", name = "LWF_Applicable", id = "ddlLWF_Applicable", @onchange = "check()" })

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                LWF Code
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.LWF_CodeId, new SelectList(ViewBag.GetLWFCode, "Id", "Name"), "--Select--", new { id = "ddlLWF_CodeId", @class = "form-select", name = "LWF_SettingID" })
                                                @Html.ValidationMessageFor(model => model.LWF_CodeId, "", new { @class = "help-block", @id = "ErrorLWF_SettingID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                LWF Slab
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.LWFSlab_MasterId, new SelectList(ViewBag.GetLWFSlabMaster, "Id", "Name"), "--Select--", new { id = "ddlLWF_SlabMasterId", @class = "form-select", autocomplete = "off", name = "LWF_SlabMasterId" })
                                                @Html.ValidationMessageFor(model => model.LWFSlab_MasterId, "", new { @class = "help-block", @id = "ErrorLWF_SlabMasterId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                LIN No
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.LWF_LIN, new { @class = "form-control", name = "LWF_LIN", type = "text", id = "txtLWF_LIN", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.LWF_LIN, "", new { @class = "help-block", @id = "ErrorLWF_LIN", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            ESIC-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                ESIC Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ESIC_Applicable, new List<SelectListItem>{
                                               new SelectListItem {Text ="No", Value="false"},
                                                new SelectListItem {Text ="Yes", Value="true"}
                                              }, new { @class = "form-select", name = "ESIC_Applicable", id = "ddlESIC_Applicable" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                ESIC No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.ESIC_NO, new { @class = "form-control", name = "ESIC_NO", type = "text", id = "txtESIC_NO", autocomplete = "Off", Maxlength = 50, onkeypress = "return isNumberKey(event)" })
                                                @Html.ValidationMessageFor(model => model.ESIC_NO, "", new { @class = "help-block", @id = "ErrorESIC_NO", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                ESIC Code
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ESIC_CodeId, new SelectList(ViewBag.GetESICCode, "Id", "Name"), "--Select--", new { id = "ddlESIC_CodeId", @class = "form-select", autocomplete = "off", name = "ESIC_SettingID" })
                                                @Html.ValidationMessageFor(model => model.ESIC_CodeId, "", new { @class = "help-block", @id = "ErrorESIC_SettingID", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                ESIC Closing Date
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.ESIC_ClosingDate, new { @class = "form-control", name = "ESIC_ClosingDate", type = "text", id = "txtESIC_ClosingDate", autocomplete = "Off", @readonly = "readonly", @style = "background-color:#eee" })
                                                @Html.ValidationMessageFor(model => model.ESIC_ClosingDate, "", new { @class = "help-block", @id = "ErrorESIC_ClosingDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Medical Insurance  Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Medical_Insurance_Applicable, new List<SelectListItem>{
                                                new SelectListItem {Text ="Yes", Value="true"},
                                                 new SelectListItem {Text ="No", Value="false"}
                                              }, "--Select--", new { @class = "form-select", name = "Medical_Insurance_Applicable", id = "ddlMedical_Insurance_Applicable" })
                                                @Html.ValidationMessageFor(model => model.Medical_Insurance_Applicable, "", new { @class = "help-block", @id = "ErrorMedical_Insurance_Applicable", @style = "color:red" })


                                              </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Accidental Policy Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Accidental_Policy_Applicable, new List<SelectListItem>{
                                               new SelectListItem {Text ="No", Value="false"},
                                               new SelectListItem {Text ="Yes", Value="true"}
                                              }, new { @class = "form-select", name = "Accidental_Policy_Applicable", id = "ddlAccidental_Policy_Applicable" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row" hidden>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Previous ESIC-No
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.ESIC_PreviousESICNo, new { @class = "form-control", name = "ESIC_PreviousESICNo", type = "text", id = "txtESIC_PreviousESICNo", autocomplete = "Off", onkeypress = "return isNumberKey(event)" })
                                                @Html.ValidationMessageFor(model => model.ESIC_PreviousESICNo, "", new { @class = "help-block", @id = "ErrorESIC_PreviousESICNo", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-12">
                                                <label class="form-label col-form-label col-md-6">
                                                    @Html.CheckBoxFor(model => model.ESIC_IS_LinkWithESIC, new { id = "ESIC_IS_LinkWithESIC" })
                                                    &nbsp;   Is Link with ESIC
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>



                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Gratuity-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Gratuity Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Gratuity_Applicable, new List<SelectListItem>{
                                                new SelectListItem {Text ="No", Value="false"},
                                               new SelectListItem {Text ="Yes", Value="true"}
                                              }, new { @class = "form-select", name = "ESIC_Applicable", id = "Gratuity_Applicable" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Gratuity No
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.Gratuity_No, new { @class = "form-control", name = "Gratuity_No", type = "text", id = "txtGratuity_No", autocomplete = "Off", @readonly = "readonly" })
                                                @Html.ValidationMessageFor(model => model.Gratuity_No, "", new { @class = "help-block", @id = "ErrorGratuity_No", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            PF-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                PF Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.PF_Applicable, new List<SelectListItem>{
                                                new SelectListItem {Text ="Yes", Value="true"},
                                                 new SelectListItem {Text ="No", Value="false"}
                                              }, "--Select--", new { @class = "form-select", name = "PF_Applicable", id = "ddlPF_Applicable", @onchange = "check()" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                PF Code

