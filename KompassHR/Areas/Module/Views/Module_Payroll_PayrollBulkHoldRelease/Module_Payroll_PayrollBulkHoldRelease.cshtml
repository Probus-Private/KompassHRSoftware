            event.preventDefault(); // Add this to prevent form submission
            debugger;

            form.valid();
            if (form.valid() == false) {
                $("#datePayroll_SalaryMonth").removeClass("error");
                return false;
            }

            $("#SelectAll").prop("checked", false);
            var CmpId= $("#ddlCmpId").val();
            var BranchId=  $("#ddlBranchId").val();
            if (BranchId ==''){BranchId=0;}
            var MonthYear=$("#datePayroll_SalaryMonth").val();
            var Type=$("#ddlType").val();
            var ObjHoldRelease = [];

            //var ObjHoldRelease = [];

            //$('#tblEmployeeHold :checkbox:checked').each(function () {
            //    var row = $(this).closest('tr');
            //    var data = {
            //        EmployeeNo: row.find('td').eq(1).text().trim(),      // EmployeeNo (index 1)
            //        Remark: row.find('td').eq(3).find('input').val().trim(), // Remark input (index 3)
            //        SalaryBranchId: row.find('td').eq(4).text().trim()   // Hidden BranchId (index 4)
            //    };
            //    ObjHoldRelease.push(data);

            //    // For debugging:
            //    console.log("Collected data:", data);
            //});

            var ObjHoldRelease = [];

            $('#tblEmployeeHold :checkbox:checked').each(function () {
                var row = $(this).closest('tr');
                var data = {
                    EmployeeNo: row.find('td').eq(1).text().trim(),      // EmployeeNo (2nd column)
                    Remark: row.find('.Remarktxt').val().trim(),         // Better selector for remark
                    SalaryBranchId: row.find('td').eq(4).text().trim()   // Hidden BranchId (5th column)
                };
                ObjHoldRelease.push(data);

                console.log("Processed row:", data); // Debugging
            });

            if (ObjHoldRelease.length==0)
            {
                var Message="Select atleast one employee";
                var Icon="error";
                if (Message != null) {
                    if (Message != null) {
                        Swal.fire({
                            icon: Icon,
                            text: Message,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)

                                return false
                            }
                        })
                        return false;
                    }
                }
            }
            $(".Userloaderbg").css("display", "flex");
            $.ajax({
                type: "POST",
                url: '@Url.Action("SaveUpdate", "Module_Payroll_PayrollBulkHoldRelease")',
                data: JSON.stringify({ ObjHoldRelease: ObjHoldRelease, CmpId: CmpId, BranchId: BranchId,MonthYear:MonthYear,Type:Type}),
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    var data = JSON.parse(response);
                    var Message1 = data.Message;
                    var Icon1 = data.Icon;
                    if (data != null) {
                        if (Icon1=="error")
                        {
                            $(".Userloaderbg").css("display", "none");
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                            }
                        }
                        else{
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("Module_Payroll_PayrollBulkHoldRelease", "Module_Payroll_PayrollBulkHoldRelease")';
                                    } else if (
                                        /* Read more about handling dismissals below */
                                        result.dismiss === Swal.DismissReason.cancel
                                    ) {

                                    }
                                })
                            }
                        }

                        // location.reload();
                    }
                }
            });
        }
    </script>
