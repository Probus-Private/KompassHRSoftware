        function downloadExcelFile() {
            // Get the table
            const table = document.getElementById("tblOtherEarningHead");
    
            // Clone the table to avoid modifying the original
            const tableClone = table.cloneNode(true);

            // Remove the checkbox column (first column)
            const rows = tableClone.querySelectorAll('tr');
            rows.forEach(row => {
                if (row.cells.length > 0) {
                    row.deleteCell(0); // Remove checkbox column
                }
            });

            // Replace input fields in the Remarks column with their current values
            const remarkInputs = tableClone.querySelectorAll('.Remarktxt');
            remarkInputs.forEach(input => {
                const value = input.value;
                const td = input.closest('td');
                td.innerHTML = value; // Replace input with its value
            });

            // Add a title row at the top
            const thead = tableClone.querySelector('thead');
            const titleRow = document.createElement('tr');
            const titleCell = document.createElement('th');
            titleCell.colSpan = 4; // Updated to span 4 columns (Employee No, Name, Remarks, BranchId)
            titleCell.textContent = "Bulk Hold/Release of Payroll for Employees";
            titleCell.style.textAlign = "center";
            titleCell.style.fontWeight = "bold";
            titleRow.appendChild(titleCell);
            thead.insertBefore(titleRow, thead.firstChild);

            // Convert the modified table to workbook
            const workbook = XLSX.utils.table_to_book(tableClone, {
                sheet: "Employee Hold Data",
                raw: true // Preserve raw values
            });

            // Get the worksheet
            const worksheet = workbook.Sheets["Employee Hold Data"];
    
            // Hide the BranchId column (column D) in Excel
            if (!worksheet['!cols']) worksheet['!cols'] = [];
            worksheet['!cols'][3] = { hidden: true }; // 0-based index (3 = column D)

            // Generate Excel file
            XLSX.writeFile(workbook, "BulkEmployeePayrollHoldRelease.xlsx", {
                bookType: 'xlsx',
                type: 'array'
            });
        }
    </script>

