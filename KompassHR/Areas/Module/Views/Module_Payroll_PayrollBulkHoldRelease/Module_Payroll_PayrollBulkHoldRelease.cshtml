@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_SalaryHold_Bulk
@{
    ViewBag.Title = "Module_Payroll_PayrollBulkHoldRelease";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

