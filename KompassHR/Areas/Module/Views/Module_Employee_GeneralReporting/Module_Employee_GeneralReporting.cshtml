@model KompassHR.Models.Mas_Employee
@{
    ViewBag.Title = "Module_Employee_GeneralReporting";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>        
  .text-nowrap {
            font-size: 12px;
        }

        tbody tr td {
            font-size: 12px;
            padding: 4px !important;
        }

        .ListBtn {
            background-color: transparent;
            color: #000;
            font-size: 15px !important;
            padding: 5px 8px !important;
            border: none;
        }

            .ListBtn:hover {
                background-color: transparent;
                color: #000;
            }

                .ListBtn:hover i {
                    transition: all 0.5s;
                    transform: scale(1.5);
                }



        .box2 {
            width: 100px;
            height: 100px;
            padding: 15px 0px;
            font-family: 'Montserrat', sans-serif;
            position: relative;
            z-index: 0;
            margin-bottom: 10px;
        }

            .box2:hover {
                border: 2px solid #ff9c19;
                border-radius: 10px;
                cursor: pointer;
                transform: translateY(-10px);
                box-shadow: 0 15px 25px rgba(0, 0, 0, 0.03), 0px -15px 25px rgba(0, 0, 0, 0.03), 0 15px 25px rgba(0, 0, 0, 0.05);
            }

                .box2:hover .info i {
                    color: #ff9c19;
                }


            .box2 .info i {
                font-size: 20px;
                width: 100%;
                text-align: center;
                margin-bottom: 5px;
                color: #007bff;
            }

            .box2 .info h7 {
                position: relative;
                font-size: 12px;
                text-align: center;
                display: flex;
                justify-content: center;
                font-weight: 900 !important;
                text-transform: capitalize;
                margin-bottom: 2px;
                padding: 0 10px;
                color: #444;
            }

        .FS-12PX {
            font-size: 12px !important;
        }
               
        .Tooltip {
            position: relative;
        }

            .Tooltip button {
                width: 35px;
            }

            .Tooltip:hover .Tooltip-text {
                display: flex;
                position: absolute;
            }

            .Tooltip .Tooltip-text {
                z-index: 1;
                min-width: 45px;
                max-width: fit-content;
                background-color: black;
                color: #fff;
                top: 40px;
                right: -18px;
                padding: 5px 8px;
                border-radius: 6px;
                display: none;
                justify-content: center;
                position: absolute;
                margin-right: 10px;
            }

                .Tooltip .Tooltip-text::after {
                    content: "";
                    position: absolute;
                    top: -20px;
                    right: 20px;
                    border-width: 10px;
                    border-style: solid;
                    border-color: transparent transparent black transparent;
                }

        .ListBtn {
            font-size: 10px !important;
            padding: 5px 8px !important;
            border: 1px solid lightgray !important;
        }
       
        .card-row-title {
            color: #e63c3c;
            font-size: 18px;
            font-weight: 600;
            text-transform: capitalize;
            border-bottom: #009ce7 1px solid;
        }

        label.error {
            text-align: left;
            height: 25px;
            color: red;
            font-size: 12px;
        }

        .error {
            text-align: left;
            height: 35px;
        }
       
        .empbx h4 {
            margin-bottom: 5px;
        }

        .empbx h6 i {
            font-size: 1rem;
            margin-right: 5px;
        }

        .empbx {
            margin-bottom: 20px;
        }
</style>

<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Dashboard", new { area = "Dashboard" })">Dashboard</a></li>
        <li class="breadcrumb-item active"><a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new { id = 3,ScreenId=142, area = "Module" })">Onboarding List</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">General Reporting Information </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ General Reporting Information - @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_GeneralReporting", new { area = "Module" })' id="SaveGeneralReporting" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="empbx">
                                            <span>
                                                <h4> <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"] </h4>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"] </h6>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"] </h6>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            General Reporting Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Reporting Manager 1
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ReportingManager1, new SelectList(ViewBag.ManagerLists, "Id", "Name"), "--Select--", new { id = "ddlReportingManager1", @class = "form-select", autocomplete = "off", name = "ReportingManager1" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Reporting Manager 2
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ReportingManager2, new SelectList(ViewBag.ManagerLists, "Id", "Name"), "--Select--", new { id = "ddlReportingManager2", @class = "form-select", autocomplete = "off", name = "ReportingManager2" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Reporting HR
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ReportingHR, new SelectList(ViewBag.ManagerLists, "Id", "Name"), "--Select--", new { id = "ddlReportingHR", @class = "form-select", autocomplete = "off", name = "ReportingHR" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-20px">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" data-bs-toggle="offcanvas"
                                                                href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn  btnpress ListBtn">
                                                            <i class="fa-solid fa-list"></i>
                                                        </button>
                                                        <button class="btn btn-primary btn-sm" id="btnSubmit" type="button">
                                                            <i class="fa-solid fa-floppy-disk"></i> Save
                                                        </button>
                                                        <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new { area = "Module" })">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm" id="btnBack">
                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- END panel -->
        </div>
    </div>
</div>

<div class="row">
    @Html.Action("Onboarding_SidebarMenu", "Module_Employee_PersonalInfo")
</div>

<script>
    $(document).ready(function () {
        $("#ddlReportingManager1").select2();
        $("#ddlReportingManager2").select2();
        $("#ddlReportingHR").select2();   
       
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));

        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });//ready


    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function(value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     },"erreur expression reguliere"
  );


    $('#SaveGeneralReporting').validate({
        rules: {
            ReportingManager1: {
                required: true,

            },
            ReportingManager2: {
                required: true,

            },
            ReportingHR: {
                required: true,
                //regex:/^[a-zA-Z0-9\s,\.\,\/\,(/)\&\_\-\ ]+$/
            },
          

        },
        messages: {
            ReportingManager1: {
                required: "Reporting Manager 1 is required",

            },
            ReportingManager2: {
                required: "Reporting Manager 2 is required",

            },
            ReportingHR: {
                required: "Reporting Hr is required",
                //regex:"Please enter only alphabet"
            },
          

        },
    });
    var form = $("#SaveGeneralReporting");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        $("#SaveGeneralReporting").submit();
    });
       
</script>
