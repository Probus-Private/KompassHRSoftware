                                                                    </td>
                                                                    <td>
                                                                        @Html.TextBoxFor(Model => Model.GradeName, new { @class = "form-control", @Value = d.GradeName, id = "GradeName", name = "GradeName", @style = "width:150px", @readonly = "readonly" })
                                                                    </td>
                                                                    <td>
                                                                        @Html.TextBoxFor(Model => Model.JoiningDate, new { @class = "form-control", @Value = d.JoiningDate, id = "JoiningDate", name = "JoiningDate", @style = "width:120px", @readonly = "readonly" })
                                                                    </td>
                                                                    <td>
                                                                        @Html.TextBoxFor(Model => Model.LeavingDate, new { @class = "form-control", @Value = d.LeavingDate, id = "LeavingDate", name = "LeavingDate", type = "date", @style = "width:140px" })
                                                                    </td>
                                                                    <td hidden>
