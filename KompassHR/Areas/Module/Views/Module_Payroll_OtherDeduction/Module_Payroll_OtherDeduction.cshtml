<script>
    $(document).ready(function () {
        $("#ddlOtherDeductionEmployeeId").select2();
        $("#ddlCmpID").select2();
        $("#ddlOtherDeductionBranchID").select2();
        $("#ddlOtherDeductionName").select2();
        $("#ddlVariableHead").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }

        $('.TablePageDeduction').DataTable({
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
        });

        $("#ddlCmpID").on("change", function () {
            $("#ddlOtherDeductionBranchID").find("option").remove();
            $("#ddlVariableHead").find("option").remove();
            var CmpId = $("#ddlCmpID").val();

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Payroll_OtherDeduction")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data.BranchName !=null) {
                        $("#ddlOtherDeductionBranchID").append("<option value=''>All</option>");
                        $.each(data.BranchName, function(i, p) {
                            $("#ddlOtherDeductionBranchID").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }

                    if (data.GetVeriableHead !=null) {
                        $("#ddlVariableHead").append("<option value=0>--Select-- </option>");
                        $.each(data.GetVeriableHead, function(i, p) {
                            $("#ddlVariableHead").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })


        $("#ddlVariableHead").on("change", function () {
            $("#ddlOtherDeductionName").find("option").remove();
            var VariableName = $("#ddlVariableHead").val();
            var CmpId= $("#ddlCmpID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetOtherDeductionName", "Module_Payroll_OtherDeduction")',
                data: { VariableName: VariableName,CmpId:CmpId },
                success: function (data) {
                    if (data !=null) {
                        //$("#ddlOtherDeductionName").append("<option value=0>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlOtherDeductionName").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })


        $("#ddlOtherDeductionBranchID").on("change", function () {
            debugger
            $("#ddlOtherDeductionEmployeeId").find("option").remove();
            var BranchId = $("#ddlOtherDeductionBranchID").val();
            var CmpId = $("#ddlCmpID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "Module_Payroll_OtherDeduction")',
                data: { BranchId: BranchId,CmpId:CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlOtherDeductionEmployeeId").append("<option value=''>All </option>");
                        $.each(data, function(i, p) {
                            $("#ddlOtherDeductionEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        var today = new Date();
