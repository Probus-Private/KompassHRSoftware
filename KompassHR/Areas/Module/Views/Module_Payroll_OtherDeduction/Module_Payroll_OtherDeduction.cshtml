@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_OtherDeduction
@{
    ViewBag.Title = "Module_Payroll_OtherDeduction";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /*.dataTables_wrapper .dataTables_scroll table.dataTable th, .dataTables_wrapper .dataTables_scroll tr.even td,
    .dataTables_wrapper .dataTables_scroll table.dataTable th, .dataTables_wrapper .dataTables_scroll tr.odd td{

          background-color:white !important;
        }*/
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Variable Deduction
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Variable Deduction </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add variable deduction here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Module_Payroll_OtherDeduction", "Module_Payroll_OtherDeduction", new { area = "Module" })' id="SaveOtherDeduction" method="post" enctype="multipart/form-data" }">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VariableDeductionCmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlCmpID", @class = "form-select", name = "VariableDeductionCmpId" })
                                                @Html.ValidationMessageFor(model => model.VariableDeductionCmpId, "", new { @class = "help-block", @id = "ErrorVariableDeductionCmpId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VariableDeductionBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "All", new { id = "ddlOtherDeductionBranchID", @class = "form-select", name = "VariableDeductionBranchId" })
                                                @Html.ValidationMessageFor(model => model.VariableDeductionBranchId, "", new { @class = "help-block", @id = "ErrorVariableDeductionBranchId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name

                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VariableDeductionEmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "All", new { id = "ddlOtherDeductionEmployeeId", @class = "form-select", autocomplete = "off", name = "VariableDeductionEmployeeId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Month /Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "month", id = "dateOtherEarningMonthYear", autocomplete = "Off", Name = "MonthYear" })
                                                @Html.ValidationMessageFor(model => model.MonthYear, "", new { @class = "help-block", @id = "ErrorMonthYear", @style = "color:red" })
                                                @Html.HiddenFor(model => model.VariableDeductionId_Encrypted, new { id = "VariableDeductionId_Encrypted" })
                                                @Html.HiddenFor(model => model.VariableDeductionId, new { id = "VariableDeductionId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Deduction Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.VariableHead, new SelectList(ViewBag.GetHeadVariable, "Id", "Name"), "--Select--", new { id = "ddlVariableHead", @class = "form-select", autocomplete = "off", name = "VariableHead" })
                                                @Html.ValidationMessageFor(model => model.VariableHead, "", new { @class = "help-block", @id = "ErrorVariableHead", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Deduction Sub-Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.DropDownListFor(model => model.OtherDeductionName, new SelectList(ViewBag.GetOtherDeductionName, "Id", "Name"), "--Select--", new { id = "ddlOtherDeductionName", @class = "form-select", autocomplete = "off", name = "OtherDeductionName" })
                                                @Html.ValidationMessageFor(model => model.OtherDeductionName, "", new { @class = "help-block", @id = "ErrorOtherDeductionName", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" id="btnLoadEmployee" onclick="GetOtherEarning('Normal')"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-thin fa-user-magnifying-glass"></i>Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4"> Import File </label>
                                            <div class="col-md-8">
                                                <input type="file" name="AttachFile" class="form-control" id="FileVariableDeduction" onchange="ResetFile()" />
                                                <span id='validationMessage_' style='color: red;'></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="row mb-15px">
                                            <div class="col-md-12">
                                                <button type="button" id="" onclick="GetOtherEarning('Excel')"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-solid fa-floppy-disk"></i> Import
                                                </button>
                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                @*<a href="~/assets/BulkUpload/VariableDeduction.xlsx">~/assets/BulkUpload/VariableDeduction.xlsx</a>*@
                                                <a href="~/assets/BulkUpload/VariableDeduction.xlsx" type="button" class="btn btn-success btn-sm">
                                                    <i class="fa-solid fa-download"></i>
                                                </a>
                                                Download Excel Format
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                @*<div class="row">
                                        <div class="col-md-6">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-6">
                                                    Download Excel Format
                                                    <a href="~/assets/BulkUpload/Candidate_Bulk_Upload.xlsx" type="button" class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-download"></i>
                                                    </a>
                                                </label>
                                            </div>
                                        </div>
                                    </div>*@

                            </form>
                            <hr>
                            <div class="row">
                                <div class="col-md-12">
                                    <!-- BEGIN table-responsive -->
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle tblAddData TablePageDeduction" id="tblOtherEarningHead" style="width: 100%;">
                                                <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="text-center">
                                                        <th class="text-center"><input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /> &nbsp; All</th>
                                                        <th class="text-nowrap"> Employee No</th>
                                                        <th class="text-nowrap"> Employee Name </th>
                                                        <th class="text-nowrap">Deduction Name </th>
                                                        <th class="text-nowrap">Deduction Sub-Category </th>
                                                        <th class="text-nowrap"> Amount</th>
                                                        <th class="text-nowrap"> Remarks</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tblEmployeeListOther">
                                                    @foreach (var d in ViewBag.GetOtherDeductionEmployeeLoad)
                                                    {
                                                        <tr>
                                                            <td class="text-nowrap text-center"><input type="checkbox" class="form-check-input" @*onchange="AmountSum()"*@/></td>
                                                            <td class="text-nowrap">@d.EmployeeNo</td>
                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                            <td class="text-nowrap">@d.CategoryName</td>
                                                            <td class="text-nowrap">@d.SubCategoryName</td>

                                                            @if (d.Amount != null)
                                                            {
                                                                <td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' @*onkeyup='AmountSum()'*@ value="@d.Amount"></td>
                                                            }
                                                            else
                                                            {
                                                                <td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' @*onkeyup='AmountSum()'*@></td>
                                                            }

                                                            @if (d.Remark != null)
                                                            {
                                                                <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt' value="@d.Remark"></td>
                                                            }
                                                            else
                                                            {
                                                                <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt'></td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Total Record  :
                                        </label>

                                        <div class="col-md-9">
                                            <input type='text' id='lblTotalRecord' class='form-control' readonly="readonly" style="background:#eee">

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Total Amount :
                                        </label>
                                        <div class="col-md-9">
                                            <input type='text' id='lblTotalAmount' class='form-control' readonly="readonly" style="background:#eee">

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Amount
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.Amount, new { @class = "form-control totalAmount", type = "text", id = "txtOtherDeductionAmount", Name = "Amount", @style = "text-align:right", onkeypress = " return numbervalidate(event)", autocomplete = "Off" })
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Remark
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", type = "text", id = "txtOtherDeductionRemarks", autocomplete = "Off", Name = "Remarks" })

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnApply" class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnTotal" onclick="AmountSum()" class="btn btn-secondary btn-sm">
                                                        <i class="fa-solid fa-calculator"></i> Calsulate Sum
                                                    </button>
                                                    <button type="button" id="btnSubmit" onclick="funSave()"class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "Module_Payroll_OtherDeduction", new { area = "Module" })">
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnGetOtherEarningList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- #Start modal-dialog  myEmployeeNoModal-->
