<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                TDS Deduction
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
   
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">TDS Deduction </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add TDS deduction here!
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Module_Payroll_TDSDeduction", "Module_Payroll_TDSDeduction", new { area = "Module" })' id="SaveTDSDeduction" method="post"enctype="multipart/form-data" }">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.TDSDeductionCmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlCmpID", @class = "form-select", name = "TDSDeductionCmpId" })
                                                @Html.ValidationMessageFor(model => model.TDSDeductionCmpId, "", new { @class = "help-block", @id = "ErrorVariableDeductionCmpId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.TDSBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--All--", new { id = "ddlTDSBranchId", @class = "form-select", name = "TDSBranchId" })
                                                @Html.ValidationMessageFor(model => model.TDSBranchId, "", new { @class = "help-block", @id = "ErrorVariableDeductionBranchId", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Employee Name
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.TDSEmployeeId, new SelectList(ViewBag.GetEmployeeList, "Id", "Name"), "All", new { id = "ddlTDSEmployeeId", @class = "form-select", autocomplete = "off", name = "TDSEmployeeId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Month /Year
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-6">
                                                @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "month", id = "txtMonthYear", autocomplete = "Off", Name = "MonthYear" })
                                                @Html.ValidationMessageFor(model => model.MonthYear, "", new { @class = "help-block", @id = "ErrorMonthYear", @style = "color:red" })
                                                @Html.HiddenFor(model => model.TDSDeductionId_Encrypted, new { id = "TDSDeductionId_Encrypted" })
                                                @Html.HiddenFor(model => model.TDSDeductionId, new { id = "TDSDeductionId" })
                                            </div>
                                            <div class="col-md-3">
                                                <button type="button" id="btnLoadEmployee" onclick="GetTDSDeduction('Normal')"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-thin fa-user-magnifying-glass"></i>Show
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3"> Import File </label>
                                            <div class="col-md-9">
                                                <input type="file" name="AttachFile" class="form-control" id="FileTDSDeduction" onchange="ResetFile()" />
                                                <span id='validationMessage_' style='color: red;'></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-15px">
                                            <div class="col-md-4">
                                                <button type="button" id="" onclick="GetTDSDeduction('Excel')"
                                                        class="btn btn-primary btn-sm">
                                                    <i class="fa-solid fa-floppy-disk"></i> Import
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                <a href="~/assets/BulkUpload/TDSDeduction.xlsx" type="button" class="btn btn-success btn-sm">
                                                    <i class="fa-solid fa-download"></i>
                                                </a>
                                                Download Excel Format
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            <hr>
                            <div class="row">
                                <div class="col-md-12">
                                    <!-- BEGIN table-responsive -->
                                    <div class="table-scroll div1">
                                        <div class="table-wrap">
                                            <table class="table table-bordered align-middle tblAddData TablePageDeduction" id="tblOtherEarningHead" style="width: 100%;">
                                                <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                    <tr class="text-center">
                                                        <th class="text-center"><input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /> &nbsp; All</th>
                                                        <th class="text-nowrap"> Employee No</th>
                                                        @*<th hidden class="text-nowrap"> Employee Id</th>*@
                                                        <th class="text-nowrap"> Employee Name </th>
                                                        <th class="text-nowrap"> Amount</th>
                                                        <th class="text-nowrap"> Remarks</th>
                                                        <th class="text-nowrap" hidden> EmployeeBranchId</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tblEmployeeListTDS">
                                                    @foreach (var d in ViewBag.GetTDSEmployeeLoad)
                                                    {
                                                        <tr>
                                                            <td class="text-nowrap text-center"><input type="checkbox" class="form-check-input" /></td>
                                                            <td class="text-nowrap">@d.EmployeeNo</td>
                                                            @*<td hidden class="text-nowrap">@d.EmployeeId</td>*@
                                                            <td class="text-nowrap">@d.EmployeeName</td>
                                                            @if (d.Amount != null)
                                                            {
                                                                <td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' onkeyup='AmountSum()' value="@d.Amount"></td>
                                                            }
                                                            else
                                                            {
                                                                <td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' onkeyup='AmountSum()'></td>
                                                            }
                                                            @if (d.Remark != null)
                                                            {
                                                                <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt' value="@d.Remark"></td>
                                                            }
                                                            else
                                                            {
                                                                <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt'></td>
                                                            }
                                                            @*<td class="text-nowrap"><input type='number' autocomplete='Off' id='txttableAmount' style="text-align:right; height:23px; width:100%" class='form-control Amounttxt' onkeyup='AmountSum()'></td>
                                                            <td class="text-nowrap"><input type="text" id='txttableRemark' style="height:23px;" maxlength="150" class='form-control Remarktxt'></td>*@
                                                            <td class="text-nowrap" hidden>@d.EmployeeBranchId</td>

                                                         </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Total Record  :
                                        </label>

                                        <div class="col-md-9">
                                            <input type='text' id='lblTotalRecord' class='form-control' readonly="readonly" style="background:#eee">

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Total Amount :
                                        </label>
                                        <div class="col-md-9">
                                            <input type='text' id='lblTotalAmount' class='form-control' readonly="readonly" style="background:#eee">

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Amount
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.Amount, new { @class = "form-control totalAmount", type = "text", id = "txtOtherDeductionAmount", Name = "Amount", @style = "text-align:right", onkeypress = " return numbervalidate(event)", autocomplete = "Off" })
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Remark
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", type = "text", id = "txtOtherDeductionRemarks", autocomplete = "Off", Name = "Remarks" })

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnApply"
                                                    class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Apply
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" id="btnSubmit" onclick="funSave()"
                                                            class="btn btn-primary btn-sm">
                                                        <i class="fa-solid fa-floppy-disk"></i> Submit
                                                    </button>
                                                    <a href="@Url.Action("GetList", "Module_Payroll_TDSDeduction", new { area = "Module" })">
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm" id="btnGetOtherEarningList">
                                                            <i class="fa-solid fa-share-from-square"></i>
                                                            List
                                                        </button>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlTDSEmployeeId").select2();
        $("#ddlCmpID").select2();
        $("#ddlTDSBranchId").select2();
        $("#ddlOtherDeductionName").select2();
        $("#ddlVariableHead").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)

                        return false
                    }
                });
            }
        }

        $('.TablePageDeduction').DataTable({
            scrollY: 300,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
        });

        $("#ddlCmpID").on("change", function () {
            $("#ddlTDSBranchId").find("option").remove();
            $("#ddlVariableHead").find("option").remove();
            var CmpId = $("#ddlCmpID").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Payroll_TDSDeduction")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlTDSBranchId").append("<option value=0>--All-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlTDSBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        })


        $("#ddlTDSBranchId").on("change", function () {
            debugger
            $("#ddlTDSEmployeeId").find("option").remove();
             var BranchId = $("#ddlTDSBranchId").val();
            var BranchId = $("#ddlTDSBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "Module_Payroll_TDSDeduction")',
                data: { BranchId: BranchId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlTDSEmployeeId").append("<option value=''>All </option>");
                        $.each(data, function(i, p) {
                            $("#ddlTDSEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('txtMonthYear').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtMonthYear').value = defaultMonth;
        }
        var GetOtherEarningEmployeeLoad = @Html.Raw(Json.Encode(ViewBag.GetTDSEmployeeLoad));
        var OtherEarninglength=GetOtherEarningEmployeeLoad.length;
        debugger;
        if(GetOtherEarningEmployeeLoad=="")
        {
            $("#lblTotalRecord").val("0");
        }
        else{
            $("#lblTotalRecord").val(OtherEarninglength);
        }


        if (GetOtherEarningEmployeeLoad != null && GetOtherEarningEmployeeLoad.length > 0) {
            debugger;

            // Initialize total amount
            var totalAmount = Number($("#lblTotalAmount").val()) || 0;

            // Loop through the array
            for (var i = 0; i < GetOtherEarningEmployeeLoad.length; i++) {
                debugger;

                // Parse the amount for the current item
                var groupAmount = Number(GetOtherEarningEmployeeLoad[i].Amount) || 0;

                // Add the amount to the total
                totalAmount += groupAmount;
            }

            // Update the label with the final total
            $("#lblTotalAmount").val(totalAmount);
        }

    });//Ready Funcation

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveTDSDeduction').validate({
        rules: {
            TDSDeductionCmpId: {
                required: true,
            },
            //TDSBranchId: {
            //    required: true,
            //},

            MonthYear: {
                required: true,
            },
        },
        messages: {
            TDSDeductionCmpId: {
                required: "Company name is required",
            },
            //TDSBranchId: {
            //    required: "Business unit is required",
            //},
            MonthYear: {
                required: "Month /Year is required",
            },
        },
    });

    var form = $("#SaveTDSDeduction");
    form.validate();
    //function GetTDSDeduction() {
    //    debugger;
    //    form.valid();
    //    if (form.valid() == false) {
    //        $("#txtMonthYear").removeClass("error");
    //        return false;
    //    }
    //    $(".Userloaderbg").css("display", "flex");
    //    $("#SaveTDSDeduction").submit();
    //}

    function GetTDSDeduction(Process) {
        debugger;
        $('#tblEmployeeListTDS tr').not(function () { return !!$(this).has('th').length; }).remove();
        if (Process!="Excel")
        {
            form.valid();
            if (form.valid() == false) {
                $("#txtMonthYear").removeClass("error");
                return false;
            }
        }
        else{
            var fileInput = document.getElementById('FileTDSDeduction');
            var files = fileInput.files;

            // Check if a file is selected
            if (files.length > 0) {
                var fileName = files[0].name;
                $("#validationMessage_").html("");
            } else {
                $("#validationMessage_").html("Choose a file");
                return false;
            }
        }

        $(".Userloaderbg").css("display", "flex");
        $("#SaveTDSDeduction").submit();
    }


</script>


<script>
    var form = $("#SaveTDSDeduction");
    form.validate();
    function funSave() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#txtMonthYear").removeClass("error");
            return false;
        }
        //$("#SelectAll").prop("checked", false);
        var CmpId = $("#ddlCmpID").val();
        var BranchID = $("#ddlTDSBranchId").val();
        var MonthYear = $("#txtMonthYear").val();
        // var DeductionCategory=$("#ddlOtherDeductionName").val();
        var ObjDeduction = [];

        // Iterate through checked checkboxes in the table body only
        $('#tblEmployeeListTDS :checkbox:checked').each(function () {
            var row = $(this).closest('tr'); // Get the closest row
            var data = {
                EmployeeNo: row.find('td').eq(1).text(), // Hidden column
                Amount: row.find('td').eq(3).find('input').val(),
                Remark: row.find('td').eq(4).find('input').val(),
                EmployeeBranchId: row.find('td').eq(5).text().trim()  ,
            };

            // Push the data object to the array
            ObjDeduction.push(data);
        });
        //  return false;
        if (ObjDeduction.length==0)
        {
            var Message="Select atleast one employee";
            var Icon="error";
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
