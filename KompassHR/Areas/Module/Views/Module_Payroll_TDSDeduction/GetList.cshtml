<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                TDS Deduction
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">TDS Deduction   - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of tds deduction created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("GetList", "Module_Payroll_TDSDeduction", new { area = "Module" })' id="SaveTDSDeduction" method="post">
                        <div class="row">
                            <div class="col-md-2">
                                <div>
                                    <button type="button" id="btnAdd" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Company Name
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.TDSDeductionCmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlTDSDeductionCmpId", @class = "form-select", name = "TDSDeductionCmpId" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Business Unit
                                    </label>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(model => model.TDSBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--All--", new { id = "ddlTDSBranchId", @class = "form-select", name = "TDSBranchId" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-4">
                                        Month /Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-6">
                                        @Html.TextBoxFor(model => model.MonthYear, new { @class = "form-control", type = "month", id = "txtMonthYear", Name = "MonthYear" })

                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" id="btnshow" onclick="GetList()" class="btn btn-primary btn-sm  mb-10px">
                                            Load
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </form>
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <!-- BEGIN table-responsive -->
                            <table id="data-table-combine15" class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass" style="width: 100%;">
                                <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                    <tr class="text-center">
                                        @*<th class="text-nowrap width-45">Delete</th>*@
                                        <th class="text-center"><input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" />  All</th>
                                        <th hidden class="text-nowrap">Id </th>
                                        <th class="text-nowrap">Company </th>
                                        <th class="text-nowrap">Business Unit </th>
                                        <th class="text-nowrap">Employee Name</th>
                                        <th class="text-nowrap">Month /Year  </th>
                                        <th class="text-nowrap">Amount</th>
                                        <th class="text-nowrap">Remark</th>

                                    </tr>
                                </thead>
                                <tbody id="tbltdsDeduction">
                                    @foreach (var d in ViewBag.TDSDeduction)
                                    {
                                        <tr>
                                            <td class="text-nowrap text-center"><input type="checkbox" class="form-check-input" /></td>
                                            <td hidden class="text-nowrap">@d.TDSDeductionId</td>
                                            <td class="text-nowrap">@d.CompanyName</td>
                                            <td class="text-nowrap">@d.BranchName</td>
                                            <td class="text-nowrap">@d.employeename</td>
                                            <td class="text-nowrap">@d.MonthYear</td>
                                            <td class="text-nowrap">@d.Amount</td>
                                            <td class="text-nowrap">@d.Remarks</td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="row">
                        <div class="LastShortLeaveBx">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="BtnBx">
                                        <div>
                                            <button type="button" id="btnSubmit" onclick="funDelete()"
                                                    class="btn btn-danger btn-sm">
                                                <i class="fa-solid fa-trash-alt"></i> Delete
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $("#ddlTDSDeductionCmpId").select2();
        $("#ddlTDSBranchId").select2();
        $("#btnAdd").click(function () {
            var url = '@Url.Action("Module_Payroll_TDSDeduction", "Module_Payroll_TDSDeduction")';
            window.location.href = url;
        });

        $('.TabledataBulkClass').DataTable({
            scrollY: 400,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
            stripeClasses: [] // Disable alternating row colors
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('txtMonthYear').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtMonthYear').value = defaultMonth;
        }
        $("#ddlTDSDeductionCmpId").on("change", function () {
            $("#ddlTDSBranchId").find("option").remove();
            var CmpId = $("#ddlTDSDeductionCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Payroll_TDSDeduction")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data !=null) {
                        $("#ddlTDSBranchId").append("<option value=''>--All-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlTDSBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                   
                }
            })
        })


    });

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveTDSDeduction').validate({
        rules: {
            TDSDeductionCmpId: {
                required: true,
            },
            //TDSBranchId: {
            //    required: true,
            //},
            MonthYear: {
                required: true,
            },
        },
        messages: {
            TDSDeductionCmpId: {
                required: "Company name is required",
            },
            //TDSBranchId: {
            //    required: "Business unit is required",
            //},
            MonthYear: {
                required: "TDS deduction month/year is required",
            },
        },
    });

    var form = $("#SaveTDSDeduction");
    form.validate();
    function GetList() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#txtMonthYear").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#SaveTDSDeduction").submit();
    }

    function funDelete() {
        //let table = document.getElementById("tblOtherDeduction");

        //// Get all <tbody> elements in the table
        //let tbodyCount = table.querySelectorAll("tbody").length;
        ////var table = document.getElementById("tblOtherDeduction");

        //// Get the number of rows
        //var rowCount = table.rows.length;
        //alert(rowCount);
        //return false;
        var ObjDelete = [];

        // Iterate through checked checkboxes in the table body only
        $('#tbltdsDeduction :checkbox:checked').each(function () {
            var row = $(this).closest('tr'); // Get the closest row
            var data = {
                TDSDeductionId: row.find('td').eq(1).text(), // Hidden column
            };

            // Push the data object to the array
            ObjDelete.push(data);
        });
        if (ObjDelete.length === 0) {
            Swal.fire({
                icon: "error",
                text: "Select at least one employee",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup();
                    popup.classList.remove('swal2-show');
                    popup.classList.add('animate__animated', 'animate__headShake');
                    setTimeout(() => popup.classList.remove('animate__headShake'), 500);
                    return false;
                }
            });
            return false;
        }

        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                debugger;
                var ObjDelete = [];

                // Iterate through checked checkboxes in the table body only
                $('#tbltdsDeduction :checkbox:checked').each(function () {
                    var row = $(this).closest('tr'); // Get the closest row
                    var data = {
                        TDSDeductionId: row.find('td').eq(1).text(), // Hidden column
                    };

                    // Push the data object to the array
                    ObjDelete.push(data);
                });
                if (ObjDelete.length==0)
                {
                    var Message="Select atleast one employee";
                    var Icon="error";
                    if (Message != null) {
                        if (Message != null) {
                            Swal.fire({
                                icon: Icon,
                                text: Message,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)

                                    return false
                                }
                            })
                            return false;
                        }
                    }
                }
                //return false;
                $(".Userloaderbg").css("display", "flex");
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("Delete", "Module_Payroll_TDSDeduction")',
                    data: JSON.stringify({ ObjDelete: ObjDelete }),
                    contentType: "application/json; charset=utf-8",
                    dataType: "text",
                    success: function (response) {
                        debugger;
                        var data = JSON.parse(response);
                        var Message1 = data.Message;
                        var Icon1 = data.Icon;
                        if (data != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '@Url.Action("GetList", "Module_Payroll_TDSDeduction")';
                                    } else if (
                                        /* Read more about handling dismissals below */
                                        result.dismiss === Swal.DismissReason.cancel
                                    ) {

                                    }
                                })
                            }
                            // location.reload();
                        }
                    }
                });

            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

</script>
