@model KompassHR.Areas.Module.Models.Module_Preboarding.Preboarding_Mas_Employee
@{
    ViewBag.Title = "CancelCandidate";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>


<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/ESS/ESS_AdminDashboard_Dashboard/ESS_AdminDashboard_Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Module/Module_Preboarding_CreateLink/GetList"> Preboarding List</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header">  Preboarding Cancel </h1>
    <!-- END page-header -->

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Preboarding Cancel</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default"
                           data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        
                        
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            @*<form role="form" action="/Module/Module_Preboarding_CreateLink/CancelCandidate" id="PreboardingCancel" method="post">*@
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc No.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocNo, new { @class = "form-control", name = "DocNo", type = "text", id = "txtDocNo", autocomplete = "Off",disabled = "disabled", Value = @ViewBag.ListCancel.DocNo })
                                                @Html.HiddenFor(model => model.FID_Encrypted,new { id="FID_Encrypted", Value = @ViewBag.ListCancel.FID_Encrypted })
                                                @Html.HiddenFor(model => model.FID, new { id = "FID", Value = @ViewBag.ListCancel.FID })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Doc Date                                              
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.DocDate, new { @class = "form-control", type = "text", id = "dateDocDate", autocomplete = "Off", Name = "DocDate", disabled = "disabled", Value = @ViewBag.ListCancel.DocDate })
                                            </div>
                                        </div>
                                    </div>
                                </div> 
                                
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.CmpId,new { id = "ddlCompanyName", @class = "form-control", autocomplete = "off", name = "CmpId", disabled = "disabled", Value = @ViewBag.ListCancel.CompanyName })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.BranchID, new { @class = "form-control", type = "text", id = "ddlBuniessUnit", autocomplete = "Off", Required = "", name = "BranchID", disabled = "disabled", Value = @ViewBag.ListCancel.BranchName })

                                            </div>
                                        </div>
                                    </div>
                                </div> 
                                
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                              Candidate Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EmployeeName, new { id = "txtEmployeeName", name = "EmployeeName", @class = "form-control", type = "text", autocomplete = "Off", disabled = "disabled", Value = @ViewBag.ListCancel.CandidateName })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                           Department 

                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EmployeeDepartmentId, new { id = "txtEmployeeName", name = "EmployeeName", @class = "form-control", type = "text", autocomplete = "Off", disabled = "disabled", Value = @ViewBag.ListCancel.DepartmentName })
                                            </div>
                                        </div>
                                    </div>
                                </div> 
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Designation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EmployeeDesignationId, new { id = "Designation", name = "PreboardRejectRemark", @class = "form-control", type = "text", autocomplete = "Off", disabled = "disabled", Value = @ViewBag.ListCancel.DesignationName })
                                            </div>
                                        </div>
                                    </div>
                                </div>                          
                                <hr>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                             Cancel Remark
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextAreaFor(model => model.Verify_FinalApproval_RejectRemark, new { id = "txtPreboardRejectRemarkCancel", name = "PreboardRejectRemark", @class = "form-control", type = "text", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>                                   
                                </div>            
                              
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="LastShortLeaveBx">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="BtnBx">
                                                            <div>
                                                                <button type="button" id="btnSubmit" onclick="CancelCandidate()"
                                                                        class="btn btn-primary btn-sm">
                                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                                </button>
                                                                <a href="/Module/Module_Preboarding_CreateLink/GetList">
                                                                    <button type="button" class="btn btn-danger btn-sm" id="btnGetPreboardingCreateLinkList">
                                                                        <i class="fa-solid fa-share-from-square"></i>Back
                                                                    </button>
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                           
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        var List  = @Html.Raw(Json.Encode(ViewBag.ListCancel));
        var CancelRemark=List[1].Value;
        if(CancelRemark==null)
        {
            $("#txtPreboardRejectRemarkCancel").html("")           
        }
        else{
            $("#txtPreboardRejectRemarkCancel").val(CancelRemark)         

        }
    })
</script>

<script>

    function CancelCandidate() {
        debugger;
        var FID_Encrypted = $("#FID_Encrypted").val();
        var EmailFID = $("#FID").val();
        var Verify_FinalApproval_RejectRemark = $("#txtPreboardRejectRemarkCancel").val();

        $.ajax({
            url: "CancelCandidateSubmit",
            method: "get",
            data: { FID_Encrypted: FID_Encrypted, Verify_FinalApproval_RejectRemark: Verify_FinalApproval_RejectRemark,EmailFID:EmailFID },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "success") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            })
                            .then(function () {
                                var url = '@Url.Action("GetList", "Module_Preboarding_CreateLink")';
                                window.location.href = url;
                            });       
                        }
                    }
                }
                else{
                    var Message1 = response.Message;
                    var Icon1 = response.Icon;
                    if (response.Icon == "error") {
                        if (Message1 != null) {
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                })
                                .then(function () {
                                    var url = '@Url.Action("GetList", "Module_Preboarding_CreateLink")';
                                    window.location.href = url;
                                });       
                            }
                        }
                    }
                }
            }
        })
    }
</script>



