                                            <label class="form-label col-form-label col-md-2">
                                                Candidate Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-2">
                                                @Html.DropDownListFor(model => model.SalutationName, new List<SelectListItem> {
                                                new SelectListItem { Text = "Mr.", Value = "Mr." },
                                                new SelectListItem { Text = "Ms.", Value = "Ms." },
                                                new SelectListItem { Text = "Mrs.", Value = "Mrs." },
                                               }, "--Select--", new { @class = "form-control", type = "text", name = "SalutationName", id = "txtSalutationName", autocomplete = "Off" })
                                            </div>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.EmployeeName, new { id = "txtEmployeeName", name = "EmployeeName", @class = "form-control", type = "text", autocomplete = "Off" })
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
