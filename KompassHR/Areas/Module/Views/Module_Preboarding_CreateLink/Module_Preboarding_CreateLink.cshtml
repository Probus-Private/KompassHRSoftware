<script>
    $(document).ready(function () {
        debugger;
        var today = new Date().toISOString().split('T')[0];
        document.getElementById("txtLink").setAttribute("min", today);
        //document.getElementById("txtDocDate").setAttribute("min", today);
        document.getElementById("dateJoiningDate").setAttribute("min", today);
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        $("#ddlReportingHR").select2();
        $("#ddlEmployeeDepartmentId").select2();
        $("#ddlEmployeeDesignationId").select2();
        $("#ddlEmployeeGradeID").select2();

        $("#ddlCompanyName").select2();
        $("#ddlBuniessUnit").select2();
        //$("#ddlCompanyName").attr("readonly", true);
        var OfferLetterGenId_Encrypted = @Html.Raw(Json.Encode(TempData["OfferLetterGenId_Encrypted"]));
        //if(OfferLetterGenId_Encrypted!="")
        //{
        //    $("#ddlCompanyName").select2("readonly", true);
        //}

        $("#ddlCompanyName").on("change", function () {
            debugger;
            $("#ddlBuniessUnit").find("option").remove();
            var CmpId = $("#ddlCompanyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Preboarding_CreateLink")',
                //url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data !=null) {
                        $("#ddlBuniessUnit").append("<option value=0>--Select--</option>");
                        $.each(data, function(i, p) {
                            debugger;
                            $("#ddlBuniessUnit").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })

        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $("#myModal").modal('show');

                    } else if (
                        result.dismiss === Swal.DismissReason.cancel
                    ) {

                    }
                })
            }
        }

        $("#btnGetPreboardingCreateLinkList").click(function () {
        window.location.href= '@Url.Action("GetList", "Module_Preboarding_CreateLink")';
    });
        var Applicable = @Html.Raw(Json.Encode(TempData["EM_PF_Applicable"]));
        var ESIC_Insurance = @Html.Raw(Json.Encode(TempData["ESIC_Insurance"]));
        var ValidDays = @Html.Raw(Json.Encode(TempData["ValidDays"]));
        debugger;
        if (Applicable == true) {
            $("#txtEM_PF_Applicable").val("true");
        }
        else if(Applicable == false) {
            $("#txtEM_PF_Applicable").val("false");
        }

        if(ESIC_Insurance==0)
        {
            $("#txtESIC_Insurance").val(0);
        }
        else if(ESIC_Insurance ==1) {
            $("#txtESIC_Insurance").val(1);
        }
        else if(ESIC_Insurance ==2) {
            $("#txtESIC_Insurance").val(2);
        }



        var ValidDays = @Html.Raw(Json.Encode(TempData["ValidDays"]));
        debugger;
        var start = new Date(document.getElementById('txtLink').value);
        var years = start.setDate(start.getDate() + ValidDays);
        var Fromdatedt =  millisecTodate(years);
        $("#txtLink").val(Fromdatedt);


        var Reporting = @Html.Raw(Json.Encode(ViewBag.ReportingHR));
        debugger;
        var Id=Reporting[0].Id;
        var Name=Reporting[0].Name;

        $("#ddlReportingHR").find("option").remove();
        $("#ddlReportingHR").append("<option value='" + Id +"'>" + Name +"</option>");


        var dt = @Html.Raw(Json.Encode(TempData["DocDate"]));
        var LinkExpiryDate = @Html.Raw(Json.Encode(TempData["LinkExpiryDate"]));
        var JoiningDate = @Html.Raw(Json.Encode(TempData["JoiningDate"]));
        console.log("JoiningDate:", JoiningDate);

        debugger;
        if(dt == null || dt == "" || LinkExpiryDate==null || LinkExpiryDate=="" ||JoiningDate==null|| JoiningDate=="")
        {
            var date = new Date();
            var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
            $("#txtDocDate").val(dateString);
            $("#dateJoiningDate").val(dateString);
            $("#txtLink").val(dateString);
        }
        else
        {
            debugger
            var JobdocDatedt =  convertDate(dt);
            var LinkExpiryDatedt =  convertDate(LinkExpiryDate);
            var JoiningDatedt =  convertDate1(JoiningDate);
            $("#txtDocDate").val(JobdocDatedt);
            $("#dateJoiningDate").val(JoiningDatedt);
            $("#txtLink").val(LinkExpiryDatedt);

        }
    });
</script>

