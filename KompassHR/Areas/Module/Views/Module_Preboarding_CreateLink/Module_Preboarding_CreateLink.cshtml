                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                PF
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.EM_PF_Applicable, new List<SelectListItem> {
                                                new SelectListItem { Text = "Not Applicable", Value = "false" },
                                                new SelectListItem { Text = "Applicable", Value = "true" },
                                               }, "--Select--", new { @class = "form-select", type = "text", name = "EM_PF_Applicable", id = "txtEM_PF_Applicable" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                ESIC/Insurance
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ESIC_Insurance, new List<SelectListItem> {
                                                new SelectListItem { Text = "Not Applicable", Value = "0", Selected=true},
                                                new SelectListItem { Text = "ESIC", Value = "1" },
                                                new SelectListItem { Text = "Insurance", Value = "2" },

                                                }, "--Select--", new { @class = "form-select", type = "text", name = "ESIC_Insurance", id = "txtESIC_Insurance", autocomplete = "Off" })
                                                @Html.ValidationMessageFor(model => model.ESIC_Insurance, "", new { @class = "help-block", @id = "ErrorESIC_Insurance", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Reporting HR
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.ReportingHR, new SelectList(ViewBag.ReportingHR, "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlReportingHR", autocomplete = "Off", name = "ReportingHR" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Reporting Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.JoiningDate, new { id = "dateJoiningDate", name = "JoiningDate", @class = "form-control", type = "date", autocomplete = "Off" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Compulsory Module
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.DropDownListFor(model => model.CompulsoryModuleId, new SelectList(ViewBag.GetCompulsoryModule, "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlCompulsoryModuleId", autocomplete = "Off", name = "CompulsoryModuleId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Username And Password
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Personal Email Id
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PersonalEmailID, new { @class = "form-control", type = "text", id = "txtPersonalEmailID", autocomplete = "Off", Required = "", name = "PersonalEmailID" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Password
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.Esspassword, new { id = "txtEsspassword", name = "Esspassword", @class = "form-control", type = "text", autocomplete = "Off", Maxlength = 8, placeholder = "Ex :- Pre@2025", Value = "Pre@2025" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="form-label col-form-label col-md-4">
                                                Link Expiry Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.LinkExpiryDate, new { @class = "form-control", type = "date", id = "txtLink", autocomplete = "Off", name = "LinkExpiryDate" })

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="LastShortLeaveBx">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="BtnBx">
                                                            <div>
                                                                <button type="button" id="btnSubmit"
                                                                        class="btn btn-primary btn-sm">
                                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                                </button>
                                                                <a href="@Url.Action("GetList", "Module_Preboarding_CreateLink", new { area = "Module" })">
                                                                    <button type="button" class="btn btn-danger btn-sm" id="btnGetPreboardingCreateLinkList">
                                                                        <i class="fa-solid fa-share-from-square"></i>List
                                                                    </button>
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>


