                                    </label>
                                    <div class="col-md-5">
                                        @Html.TextBoxFor(model => model.MonthYear, new { id = "GetMonth", @class = "form-control", name = "MonthYear", type = "month" })
                                    </div>
                                    <div class="col-md-3">
                                        <button type="button" id="btnShow"
                                                class="btn btn-success btn-sm mb-10px">
                                            <i class="fa-solid fa-eye"></i> Show
