<script>
    $(document).ready(function () {
        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm ;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('GetMonth').value;
        if (CheckEmptyDate == "") {
            document.getElementById('GetMonth').value = defaultMonth;
        }
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#GetMonth").on("change", function () {
            debugger;
            var MonthYear = $("#GetMonth").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetList", "Module_Payroll_ComplienceDocumentUpload")',
                data: { MonthYear: MonthYear },
                //success: function (data) {
                //    debugger;
                //    if (data.Branch != null) {
                //        $("#ddlBranchId").append("<option value=''>--Select--</option>");
                //        $.each(data.Branch, function (i, p) {
                //            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                //        });
                //    }

                //    else {
                //        $('#ErrorESSPassword').html(" ");
                //    }
                //}
            })
        });
    });
</script>

<script>
    function Update(ComplienceDocUploadId_Encrypted,MonthYear) {
        var url = '@Url.Action("Module_Payroll_ComplienceDocumentUpload", "Module_Payroll_ComplienceDocumentUpload")?ComplienceDocUploadId_Encrypted=' + ComplienceDocUploadId_Encrypted;
        window.location.href = url;
    }

    function Delete(ComplienceDocUploadId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Payroll_ComplienceDocumentUpload")?ComplienceDocUploadId_Encrypted=' + ComplienceDocUploadId_Encrypted;
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

    $("#btnShow").click(function () {
        debugger;
        var MonthYear=$("#GetMonth").val();
        var url = '@Url.Action("GetList", "Module_Payroll_ComplienceDocumentUpload")?MonthYear=' + MonthYear;
        window.location.href = url;
    });

</script>

