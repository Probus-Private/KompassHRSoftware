<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
    $(".CloseModel").click(function () {
        $('#tblIFSCcode tr').not(function () { return !!$(this).has('th').length; }).remove();
    })
</script>

<script>

    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveWorkerBank").validate({
        rules: {
            SalaryIFSC: {
                required: true,
            },
            SalaryBankName: {
                required: true,
            },
            
            SalaryAccountNo: {
                required: true,
            },
            SalaryConfirmAccountNo: {
                required: true,
            },
          
        },
        messages: {
            SalaryIFSC: {
                required: "IFSC code is required",
            },
            SalaryBankName: {
                required: "Bank name is required",
            },
           
            SalaryAccountNo: {
                required: "Account number is required",
            },
            SalaryConfirmAccountNo: {
                required: "Confirm account number is required",
            },
        }
    });

    var form = $("#SaveWorkerBank");
    form.validate();
    $("#btnSubmit").click(function(){
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var SalaryAccountNo= document.getElementById("txtSalaryAccountNo");
        var SalaryConfirmAccountNo= document.getElementById("txtSalaryConfirmAccountNo");
        if(SalaryAccountNo.value==SalaryConfirmAccountNo.value)
        {
            $('#ErrorSalaryConfirmAccountNo').html("");
        }
        else
        {
            $('#ErrorSalaryConfirmAccountNo').html("Account number is not matched !"); $("#PermanentConfirmAccountNo").focus();  return false;

        }
        $(".Userloaderbg").css("display","flex");
        $("#SaveWorkerBank").submit();
    })
</script>
<script>
    //Salary Account
    var togglePasswordSalary = document.querySelector('#togglePasswordSalary');
    var AccountNoSalary = document.querySelector('#txtSalaryAccountNo');
    $("#togglePasswordSalary" ).hover(
       function() {
           $( this ).addClass( "hover" );
           const type = AccountNoSalary.getAttribute('type') === 'password' ? 'text' : 'password';
           AccountNoSalary.setAttribute('type', type);
           // toggle the eye slash icon
           this.classList.toggle('fa-solid-eye-slash');
       }, function() {
           $( this ).removeClass( "hover" );
           const type = AccountNoSalary.getAttribute('type') === 'password' ? 'text' : 'password';
           AccountNoSalary.setAttribute('type', type);
           // toggle the eye slash icon
           this.classList.toggle('fa-solid-eye-slash');
       }
   );
    //Confirm Password hide show Salaty
    var togglePassword = document.querySelector('#togglePasswordSalaryConfirm');
    var passwordSalary = document.querySelector('#txtSalaryConfirmAccountNo');

    $("#togglePasswordSalaryConfirm" ).hover(
        function() {
            $( this ).addClass( "hover" );
            const type = passwordSalary.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordSalary.setAttribute('type', type);
            // toggle the eye slash icon
            this.classList.toggle('fa-solid-eye-slash');
        }, function() {
            $( this ).removeClass( "hover" );
            const type = passwordSalary.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordSalary.setAttribute('type', type);
            // toggle the eye slash icon
            this.classList.toggle('fa-solid-eye-slash');
        }
    );
</script>

<script>
    $('#btnSearch').click(function () {
        debugger;
        var IFSCode = $('#txtSalaryIFSC').val();
        if(IFSCode!=""){

            $.ajax({
                type: "GET",
                url: '@Url.Action("GetIFSCCode", "Module_Employee_BankInfo")',
                data: {IFSCode:IFSCode},
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    var data = JSON.parse(response);
                    if(data.data.length!=0)
                    {
                        var length = data.data.length
                        if(length==0)
                        {
                            $('#ErrorSalaryIFSC').html("Please enter valid IFSC Code !"); $("#SalaryIFSC").focus();  return false;
                        }
                        else
                        {
                            $('#ErrorSalaryIFSC').html("");
                        }
                        if (length>0) {
                            $('#myModal').modal('show');
                        }
                        else
                        {
                            $('#myModal').modal('hide');
                        }
                        if (data.data != null) {
                            for (var i = 0; i <= data.data.length ; i++) {
                                var table = document.getElementById("tblIFSCcode");
                                var rowCount = table.rows.length;
                                var row = table.insertRow(rowCount);
                                var count = $('#tblIFSCcode tr').length;
                                var IFSCcodes=data.data[i];
                                for (var j = 0; j <= IFSCcodes.length-1; j++) {
                                    debugger;
                                    if (j >= IFSCcodes.length) { continue; }
                                    var IFSCKey=IFSCcodes[j].Key;
                                    var IFSCValue=IFSCcodes[j].Value;

                                    if(IFSCKey=="IFSCode")
                                    {
                                        row.insertCell(0).innerHTML ='<center><a href="javascript:;" class="CloseModel" data-bs-dismiss="modal" aria-hidden="true" id="CloseModel"><button type="button" id="btnOpenPopUp" class="btn btn-success ListBtn btnpress CloseModel"  onclick="EmployeeIFSCcode(this)">Select</button></a></center>';
                                        row.insertCell(1).innerHTML = "" + IFSCValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(1).innerHTML="";
                                    }
                                    if(IFSCKey=="BankName")
                                    {
                                        row.insertCell(2).innerHTML = "" + IFSCValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(2).innerHTML="";
                                    }
                                    if(IFSCKey=="BranchName")
                                    {
                                        row.insertCell(3).innerHTML = "" + IFSCValue+ "";
                                    }
                                    else
                                    {
                                        //row.insertCell(3).innerHTML="";
                                    }
                                    if(IFSCKey=="Address")
                                    {
                                        row.insertCell(4).innerHTML = "" + IFSCValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(4).innerHTML="";
                                    }
                                }
                            }
                        }
                    }
                    else{
                        var Message="IFSC Code is invalid !";
                        var Icon ="error";
                        if (Message != null) {
                            if (Message != null) {
                                Swal.fire({
                                    icon: Icon,
                                    text: Message,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                            }
                        }
                    }

                }
            });
        }
    });

    function EmployeeIFSCcode(tblRow)
    {
        debugger;
        var currentRow = $(tblRow).closest("tr");
        var BankName = currentRow.find("td:eq(2)").html();
        var BranchName = currentRow.find("td:eq(3)").html();
        var Address = currentRow.find("td:eq(4)").html();

        $("#txtSalaryBankName").val(BankName);
        $("#txtSalaryBankBranchName").val(BranchName);
        $("#txtSalaryBankAddress").val(Address);
        $(".CloseModel").click(function () {
            $('#tblIFSCcode tr').not(function () { return !!$(this).has('th').length; }).remove();
        })
    }
</script>

