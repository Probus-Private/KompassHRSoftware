<script>
    function ShowImagePreviewFrontPage(input) {
        debugger;
        if (input.files && input.files[0]) {
            var fname = input.files[0].name;
            var re = /(\.jpg|\.jpeg|\.png)$/i;
            if (!re.exec(fname)) {
                swal({
                    title: "File not supported!",
                    text: "This file format not suported",
                    type: "error"
                });
                $("#EmployeeFrontPage").val("");
                return false;
            }
            else {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#fileDataFrontPage').prop('src', e.target.result);
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    }


    function ShowImagePreviewBackPage(input) {
        debugger;
        if (input.files && input.files[0]) {
            var fname = input.files[0].name;
            var re = /(\.jpg|\.jpeg|\.png)$/i;
            if (!re.exec(fname)) {
                swal({
                    title: "File not supported!",
                    text: "This file format not suported",
                    type: "error"
                });
                $("#EmployeeBackPage").val("");
                return false;
            }
            else {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#fileDataBackPage').prop('src', e.target.result);
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    }

</script>

<script>
    $(document).ready(function () {
        $("#ddlDocumentID").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#ddlDocumentID").change(function(){
            debugger;
            var DocumentId=  $("#ddlDocumentID option:selected").val();
            $.ajax({
                type: "Get",
                url: '@Url.Action("GetDocumentBackPage", "Module_Employee_WorkerDetails")',
                data: {DocumentId:DocumentId},
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response)
                {
                    debugger;
                    var data=JSON.parse(response);
                    for (var i = 0; i <= data.length ; i++) {
                        var IsBackPageKey=data[0].Key;
                        var IsBackPageValue=data[0].Value;

                        if(IsBackPageValue==true)
                        {
                            $("#fileDataBackPage").show();
                            $("#EmployeeBackPage").show();
                            $("#lblBackPage").show();
                            $("#spnBackpage").show();
                        }
                        else
                        {
                            $("#fileDataBackPage").hide();
                            $("#EmployeeBackPage").hide();
                            $("#lblBackPage").hide();
                            $("#spnBackpage").hide();
                        }
                    }
                }
            })
        })
    });


    var ListDocument = @Html.Raw(Json.Encode(ViewBag.EmployeeUploadDocumentList));
    debugger;
   if (ListDocument != null) {
    for (var i = 0; i < ListDocument.length; i++) {  // Fix boundary
        var table = document.getElementById("tblUploadDocument");
        var rowCount = table.rows.length;
        var row = table.insertRow(rowCount);  // Insert a new row at the end
        var Setdata = ListDocument[i];

        for (var j = 0; j < Setdata.length; j++) {  // Fix boundary
            var DocumentKey = Setdata[j].Key;
            var DocumentValue = Setdata[j].Value;

            if (DocumentKey == "DocumentPath") {
                row.insertCell(0).innerHTML = `<center><a id="btnDownload" href="/Module/Module_Employee_WorkerDetails/DownloadFile?UploadDocumentFile=${DocumentValue}" download><i class="fa-solid fa-download text-primary fa-lg"></i></a></center>`;
            }
            if (DocumentKey == "EmployeeUploadDocumentID_Encrypted") {
                row.insertCell(1).innerHTML = `<center><a id="btnDelete" onclick="DeleteDocument('${DocumentValue}')"><i class="fa-solid fa-trash-alt text-danger fa-lg"></i></a></center>`;
            }
            if (DocumentKey == "DocumentName") {
                row.insertCell(2).innerHTML = `${DocumentValue}`;
            }
            if (DocumentKey == "UploadDocumentName") {
                row.insertCell(3).innerHTML = `${DocumentValue}`;
            }
        }
    }
}




    function DeleteDocument(EmployeeUploadDocumentID_Encrypted) {
        debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500000)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("DocumentDelete", "Module_Employee_WorkerDetails")?EmployeeUploadDocumentID_Encrypted=' + EmployeeUploadDocumentID_Encrypted;
                //window.location.href = url;
                DeleteButtons.fire(
                    'Deleted!',
                    'Your file has been deleted.',
                    'success'
                )
            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

<script>
  


    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveWorkerUploadDocument").validate({
        rules: {
            DocumentID: {
                required: true,
            },
        },
        messages: {
            DocumentID: {
                required: "Document type is required",
            },
        }
    });
    var form = $("#SaveWorkerUploadDocument");
    form.validate();
    $("#btnSubmit").click(function(){
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        $("#SaveWorkerUploadDocument").submit();
    })
</script>