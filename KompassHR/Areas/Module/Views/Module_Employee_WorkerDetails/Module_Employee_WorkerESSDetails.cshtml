<script>
    $('#btnReplicationUser').on('click', function () {
        debugger;

        var FromUserCout=$("#FromUserCount").val();  txtToUserCount
        var ToUserCount=$("#txtToUserCount").val();
        if(FromUserCout==0 )
        {
            var Message = "No Employee Found For this Designation";
            var Icon = "warning";
            debugger;
            if (Message != null) {
                if (Icon != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            // return false
                        }
                    })//.then(function() {
                    //    window.location.reload();
                    //});
                }
            }

        }
        else if(ToUserCount==0 )
        {
            var Message = "User has Already Access";
            var Icon = "warning";
            debugger;
            if (Message != null) {
                if (Icon != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            // return false
                        }
                    })//.then(function() {
                    //    window.location.reload();
                    //});
                }
            }

        }
        else
        {
            $("#myModalFinal").modal('show');
        }

    });
    $(document).ready(function () {
        $(".title").text("Policy Access - List");
        $("#txtUserPolicyAccessId").select2();
        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        var OnboardEmployeeNo = @Html.Raw(Json.Encode(Session["OnboardEmployeeNo"]));
