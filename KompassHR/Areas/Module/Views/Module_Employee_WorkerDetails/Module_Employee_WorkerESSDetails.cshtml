<script>
    //Salary Account
    var toggleESSPassword = document.querySelector('#toggleESSPassword');
    var ESSPassword = document.querySelector('#txtESSPassword');
    $("#toggleESSPassword" ).hover(
       function() {
           $( this ).addClass( "hover" );
           const type = ESSPassword.getAttribute('type') === 'password' ? 'text' : 'password';
           ESSPassword.setAttribute('type', type);
           // toggle the eye slash icon
           this.classList.toggle('fa-solid-eye-slash');
       }, function() {
           $( this ).removeClass( "hover" );
           const type = ESSPassword.getAttribute('type') === 'password' ? 'text' : 'password';
           ESSPassword.setAttribute('type', type);
           // toggle the eye slash icon
           this.classList.toggle('fa-solid-eye-slash');
       }
   );
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveESSLoginInformation").validate({
        rules: {
            ESSLoginID: {
                required: true,
            },
            ESSPassword: {
                required: true,
            },
            UserAccessPolicyId: {
                required: true,
            },
        },
        messages: {
            ESSLoginID: {
                required: "LoginID is required",
            },
            ESSPassword: {
                required: "Password is required",
            },
            UserAccessPolicyId: {
                required: "User access policy is required",
