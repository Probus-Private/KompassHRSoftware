                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.PHApplicable, new List<SelectListItem> {
                                                   new SelectListItem { Text = "Yes", Value = "true"},
                                               new SelectListItem { Text = "No", Value = "false"},
                                                }, new { id = "ddlPHApplicable", @class = "form-select", autocomplete = "off", name = "PHApplicable" })


                                            </div>
                                        </div>
                                    </div>
