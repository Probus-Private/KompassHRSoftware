        $("#ddlEM_Atten_LocationRegistrationId").on("change", function () {
            var total = $("#ddlEM_Atten_LocationRegistrationId option").length;
            var selected = $("#ddlEM_Atten_LocationRegistrationId").val().length || 0;
            $("#selectAllLocations").prop("checked", total === selected);
        });

        $("form").submit(function () { debugger
            var selectedValues = $("#ddlEM_Atten_LocationRegistrationId").val();
            $("#SelectedLocations").val(selectedValues ? selectedValues.join(",") : "");
