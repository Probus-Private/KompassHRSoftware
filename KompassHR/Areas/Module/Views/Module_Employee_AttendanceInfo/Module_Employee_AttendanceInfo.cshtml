<script>
    $("#ddlEM_Atten_CoffApplicable").change(function(){
        debugger;
        var CoffApplicable=$("#ddlEM_Atten_CoffApplicable").val();
        var Atten_OT_Applicable=$("#ddlEM_Atten_OT_Applicable").val();

        if(CoffApplicable=="true")
        {

            if(Atten_OT_Applicable=="true")
            {
                $('#ErrorEM_Atten_CoffApplicable').html("Coff Cannot Applicable if OT Applicable"); $("#ErrorEM_Atten_CoffApplicable").focus();  return false;
            }
            else
            {
                $("#ddlEM_Atten_CoffSettingId").removeAttr("disabled");
                $('#ErrorEM_Atten_CoffApplicable').html("");
            }

        }
        else
        {
            $('#ErrorEM_Atten_CoffApplicable').html("");
            $("#ddlEM_Atten_CoffSettingId").val("");
            $("#ddlEM_Atten_CoffSettingId").attr("disabled", "disabled");
        }
    });

    $("#ddlEM_Atten_ShortLeaveApplicable").change(function(){
        debugger;
        var ShortLeaveApplicable=$("#ddlEM_Atten_ShortLeaveApplicable").val();

        if (ShortLeaveApplicable == "True")
        {
            $("#ddlEM_Atten_ShortLeaveSettingId").removeAttr("disabled");
        }
        else
        {
            $("#ddlEM_Atten_ShortLeaveSettingId").val("");
            $("#ddlEM_Atten_ShortLeaveSettingId").attr("disabled", "disabled");
        }
    });

    $("#ddlEM_Atten_PersonalGatepassApplicable").change(function(){
        debugger;
        var PersonalGatepassApplicable=$("#ddlEM_Atten_PersonalGatepassApplicable").val();

        if (PersonalGatepassApplicable == "True")
        {
            $("#ddlEM_Atten_Atten_PersonalGatepassSettingId").removeAttr("disabled");
        }
        else
