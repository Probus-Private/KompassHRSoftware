                                                &nbsp; <label class="form-check-label form-label">
                                                    IInd
                                                </label> &nbsp;
                                                @Html.CheckBoxFor(model => model.EM_Atten_WOFF_Check3, new { id = "EM_Atten_WOFF_Check3", @class = "chk" })
                                                &nbsp; <label class="form-check-label form-label">
                                                    IIIrd
                                                </label> &nbsp;
                                                @Html.CheckBoxFor(model => model.EM_Atten_WOFF_Check4, new { id = "EM_Atten_WOFF_Check4", @class = "chk" })
                                                &nbsp; <label class="form-check-label form-label">
                                                    IVth
                                                </label> &nbsp;
                                                @Html.CheckBoxFor(model => model.EM_Atten_WOFF_Check5, new { id = "EM_Atten_WOFF_Check5", @class = "chk" })
                                                &nbsp; <label class="form-check-label form-label">
                                                    Vth
                                                </label> &nbsp;
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
