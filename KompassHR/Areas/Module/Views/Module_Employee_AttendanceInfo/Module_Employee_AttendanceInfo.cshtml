                                                }, new { id = "ddlEM_Atten_WOPH_CoffApplicable", @class = "form-select", autocomplete = "off", name = "EM_Atten_WOPH_CoffApplicable" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
