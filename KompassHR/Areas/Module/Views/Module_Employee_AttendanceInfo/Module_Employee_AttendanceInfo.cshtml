                                                <h4> <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"] </h4>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"] </h6>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"] </h6>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            OT Setup
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                OT Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EM_Atten_OT_Applicable, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Yes", Value = "true"},
                                                    new SelectListItem { Text = "No", Value = "false"},
                                                }, "--Select--", new { id = "ddlEM_Atten_OT_Applicable", @class = "form-select", autocomplete = "off", name = "EM_Atten_OT_Applicable" })
                                                @Html.HiddenFor(model => model.AttendanceId_Encrypted)
                                                @Html.HiddenFor(model => model.AttendanceEmployeeId)
                                                @Html.ValidationMessageFor(model => model.EM_Atten_OT_Applicable, "", new { @class = "help-block", @id = "ErrorEM_Atten_OT_Applicable", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                OT Multiply By

                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EM_Atten_OTMultiplyBy, new List<SelectListItem> {
                                                    new SelectListItem { Text = "1", Value = "1"},
                                                    new SelectListItem { Text = "1.5", Value = "1.5"},
                                                     new SelectListItem { Text = "2", Value = "2"},
                                                }, "--Select--", new { id = "ddlEM_Atten_OTMultiplyBy", @class = "form-select", autocomplete = "off", name = "EM_Atten_OTMultiplyBy" })
                                                @Html.ValidationMessageFor(model => model.EM_Atten_OTMultiplyBy, "", new { @class = "help-block", @id = "ErrorEM_Atten_OTMultiplyBy", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Perday Shift Hrs.

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.EM_Atten_PerDayShiftHrs, new { id = "EM_Atten_OTMultiplyBy", name = "EM_Atten_OTMultiplyBy", @class = "form-control", autocomplete = "Off", onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.EM_Atten_PerDayShiftHrs, "", new { @class = "help-block", @id = "ErrorEM_Atten_PerDayShiftHrs", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
