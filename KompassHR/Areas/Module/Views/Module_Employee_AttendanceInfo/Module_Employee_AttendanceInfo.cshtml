                                            <label class="form-label col-form-label col-md-12">
                                                Coff Applicable
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EM_Atten_CoffApplicable, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Yes", Value = "true"},
                                                    new SelectListItem { Text = "No", Value = "false"},
                                                }, new { id = "ddlEM_Atten_CoffApplicable", @class = "form-select", autocomplete = "off", name = "EM_Atten_CoffApplicable" })
                                                @Html.ValidationMessageFor(model => model.EM_Atten_CoffApplicable, "", new { @class = "help-block", @id = "ErrorEM_Atten_CoffApplicable", @style = "color:red" })

                                            </div>
