@model KompassHR.Areas.Module.Models.Module_Employee.BulkUpdateReporting
@{
    ViewBag.Title = "Module_Employee_BulkUpdateReporting";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .table-bordered, .table-bordered th, .table-bordered td {
        border: 1px solid black;
        border-collapse: collapse;
        padding: 8px; /* Added padding */
    }

    .table, .table th, .table td {
        border: 1px solid black;
    }

    .table {
        border-collapse: collapse;
    }


    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    th:nth-child(2), td:nth-child(2) {
        width: 100px; /* Set the width for the first column */
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Bulk Update Reporting
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_Menu", "Module_Employee_Menu", new {id = 3, ScreenId=140, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
   
    <div class="row">
        <div class="col-lg-12 col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Bulk Update Reporting</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row justify-content-center">
                        <form role="form" action='@Url.Action("Module_Employee_BulkUpdateReporting", "Module_Employee_BulkUpdateReporting", new { area = "Module" })' id="formEmployees" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company Name <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.ComapnyName ?? new List<dynamic>(), "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlCmpId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Business Unit <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName ?? new List<dynamic>(), "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlBranchId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Manager Name <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.ManagerId, new SelectList(ViewBag.ManagerName ?? new List<dynamic>(), "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlManagerId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Model Name <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.ModelId, new SelectList(ViewBag.ModuleName ?? new List<dynamic>(), "Id", "Name"), new { @class = "form-select", id = "ddlModelId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Approval Level <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.LevelId, new SelectList(ViewBag.Levels ?? new List<dynamic>(), "Id", "Name"), new { @class = "form-select", id = "ddlLevelId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <div class="col-md-2">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" onclick="ShowEmployee()" id="btnShow" class="btn btn-sm btn-success btn-sm"> Show</button>
                                                    @*<button type="button" onclick="funEmployeeWiseReport()" class="btn btn-sm btn-success">Show</button>*@
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="LastShortLeaveBx">
                                    <div class="row">
                                        <div class="col-md-10">
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row mb-15px">
                                <label class="form-label col-form-label col-md-2">
                                </label>
                                <div class="col-md-7">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblEmployees" style="width:100%;">
                                        <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th hidden>EmployeeId</th>
                                                <th class="text-center"><label><input type="checkbox" name="checkbox" id="IsMenuCheckBox" value="value" onchange="checkAll(this)"> All</label></th>
                                                <th class="fixed-side1 text-center">Employee Name</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblBodyEmployees">
                                            @foreach (var d in ViewBag.GetEmployees)
                                            {
                                                <tr>
                                                    <td hidden>@d.Id</td>
                                                    <td class="text-center">
                                                        <input type="checkbox" id="txtContractorIdId" class="chk chkContractorId" Value="@d.Id" />
                                                    </td>
                                                    <td class="text-nowrap">@d.Name</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row mb-15px">
                                <label class="form-label col-form-label col-md-2">
                                    New Manager Name <span class="important">*</span>
                                </label>
                                <div class="col-md-4">
                                    @Html.DropDownListFor(model => model.NewManagerId, new SelectList(ViewBag.EmployeeName ?? new List<dynamic>(), "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlNewManagerId" })
                                    <span class="error" id="errorNewManagerId" style="color:red"></span>
                                </div>
                                <div class="col-md-6">
                                    <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                        Submit
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        $("#ddlManagerId").select2();
        $("#ddlModelId").select2();
        $("#ddlLevelId").select2();
        $("#ddlNewManagerId").select2();
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Employee_BulkUpdateReporting")',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlManagerId").find("option").remove();
            $("#ddlNewManagerId").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetManagerName", "Module_Employee_BulkUpdateReporting")',
                data: { BranchId: BranchId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlManagerId").append("<option value=''>--Select-- </option>");
                        $.each(data.ManagerName, function (i, p) {
                            $("#ddlManagerId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    if (data != null) {
                        $("#ddlNewManagerId").append("<option value=''>--Select-- </option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $("#ddlNewManagerId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#ddlManagerId").on("change", function () {
            $('#tblBodyEmployees tr').not(function () { return !!$(this).has('th').length; }).remove();
            $("#ddlNewManagerId").val('').select2();
        });


       
    });


</script>

<script>

    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formEmployees').validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            ManagerId: {
                required: true,
            },
            ModelId: {
                required: true,
            },
            LevelId: {
                required: true,
            },

        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            BranchId: {
                required: "Bussiness Unit is required",
            },
            ManagerId: {
                required: "Manager name is required",
            },
            ModelId: {
                required: "Model name is required",
            },
            LevelId: {
                required: "Level is required",
            },

        },
    });

    var form = $("#formEmployees");
    form.validate();
    function ShowEmployee() {
        debugger;
        form.valid();
        if (form.valid() == false) {

            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#formEmployees").submit();
    }


    $("#btnSubmit").click(function () {
        debugger;
        var NewManagerId = $("#ddlNewManagerId").val();
        var ManagerId = $("#ddlManagerId").val();
        if (NewManagerId == "")
        {
            $("#errorNewManagerId").html("New Manager Name is required"); return false;
        }
        else
        {
            $("#errorNewManagerId").html("");
        }
        var ModelId = $("#ddlModelId").val();
        var LevelId = $("#ddlLevelId").val();

        var BulkUpdateReporting = [];
        debugger;
        $("#tblBodyEmployees").find(':checkbox:checked').each(function (i) {
            var data = {};
            var currentRow = $(this).closest("tr");
            data.EmployeeId = currentRow[0].cells[0].innerText;
            data.ManagerId = ManagerId;
            data.NewManagerId = NewManagerId;
            data.ModelId = ModelId;
            data.LevelId = LevelId;
            BulkUpdateReporting.push(data);
        });

        if (BulkUpdateReporting == "") {
            debugger;
            Swal.fire({
                icon: "error",
                text: "Select atleast one record",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    return false;
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    window.location.reload();
                    return false
                }
            });
            return false;
        }
       // console.log(BulkUpdateReporting);

        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpdate", "Module_Employee_BulkUpdateReporting")',
            data: JSON.stringify({ BulkUpdateReporting: BulkUpdateReporting, ManagerId: ManagerId }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 == "error") {
                    $(".Userloaderbg").css("display", "none");
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        });
                    }
                }
                else {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '@Url.Action("Module_Employee_BulkUpdateReporting", "Module_Employee_BulkUpdateReporting")';
                            } else if (
                                result.dismiss === Swal.DismissReason.cancel
                            ) {
                            }
                        })
                    }
                }
            }
        });
    });

    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>