@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/assets/MyCDN/MenuFontStyle.css" rel="stylesheet" />

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    

    .table-scroll {
        width: 100%;
        overflow-x: auto; /* 🔵 Ensure wrapper scrolls */
    }

    .table-wrap {
        width: 100%;
        overflow-x: auto; /* 🔵 Main scrolling */
        overflow-y: hidden;
    }

        /* Scrollbar styling */
        .table-wrap::-webkit-scrollbar-track {
            background-color: #F5F5F5;
            border-radius: 10px;
        }

        .table-wrap::-webkit-scrollbar {
            width: 6px;
            height: 10px;
            background-color: #F5F5F5;
        }

        .table-wrap::-webkit-scrollbar-thumb {
            background-color: #777;
            border-radius: 10px;
        }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

  
    .table-scroll table {
        width: 100%;
        min-width: 1400px; /* 🔵 forces horizontal scroll */
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    th:nth-child(1), td:nth-child(1),
    th:nth-child(2), td:nth-child(2) {
        width: 40px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Leave Encashment
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("ESS_AdminDashboard_Dashboard", "ESS_AdminDashboard_Dashboard", new { id = 32, ScreenId = 121, area = "ESS" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>

                <li>
                    <a href="@Url.Action("Module_Payroll_LeaveEncashment", "Module_Payroll_LeaveEncashment", new { id = 6, ScreenId = 850, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">

            <div class="panel panel-inverse" data-sortable-id="index-1">

                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Leave Encashment</h4>
                </div>

                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of LeaveEncashment
                    </p>
                </div>

                <div class="panel-body">

                    <div class="row">
                        <div class="col-md-12">

                            <a href="@Url.Action("Module_Payroll_LeaveEncashment", "Module_Payroll_LeaveEncashment", new { area = "Module" })">
                                <button type="button" class="btn btn-primary btn-sm mb-3">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>

                            <!-- ------------------------------ -->
                            <!--  🔵 UPDATED HORIZONTAL SCROLL  -->
                            <!-- ------------------------------ -->
                            <div class="table-scroll">
                                <div class="table-wrap">

                                    <table class="table table-bordered align-middle TablePage" id="fixed-header">
                                        <thead>
                                            <tr class="text-center">
                                                <th>Update</th>
                                                <th>Delete</th>
                                                <th>Company Name</th>
                                                <th>Business Unit</th>
                                                <th>Employee Name</th>
                                                <th>Financial Year</th>
                                                <th>Amount</th>
                                                <th>Remark</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @foreach (var d in ViewBag.ListDetails)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <a onclick="Update('@d.LeaveEncashmentID_Encrypted')" style="cursor:pointer">
                                                            <i class="fa-solid fa-pen-to-square fa-lg text-dark"></i>
                                                        </a>
                                                    </td>

                                                    <td class="text-center">
                                                        <a onclick="Delete('@d.LeaveEncashmentID_Encrypted')" style="cursor:pointer">
                                                            <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                        </a>
                                                    </td>

                                                    <td>@d.CompanyName</td>
                                                    <td>@d.BranchName</td>
                                                    <td>@d.EmployeeName</td>
                                                    <td>@d.FinancialYear1</td>
                                                    <td class="text-end">@d.Amount</td>
                                                    <td>@d.Remark</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>

                                </div>
                            </div>



                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>

</div>


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(() => {
                window.location.reload();
            });
        }
    });
</script>

<script>
    function Update(LeaveEncashmentID_Encrypted) {
        var url = '@Url.Action("Module_Payroll_LeaveEncashment", "Module_Payroll_LeaveEncashment")?LeaveEncashmentID_Encrypted=' + LeaveEncashmentID_Encrypted;
        window.location.href = url;
    }

    function Delete(LeaveEncashmentID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        });

        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: false
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Payroll_LeaveEncashment")?LeaveEncashmentID_Encrypted=' + LeaveEncashmentID_Encrypted;
            }
        });
    }
</script>
