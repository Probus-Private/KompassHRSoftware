@model KompassHR.Areas.Module.Models.Module_Payroll.SalaryProcess  
@{
    ViewBag.Title = "Module_Payroll_SalaryProcess";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>


<style>
    .Col-md-2 {
        margin: 10px 0;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }
</style>

<div id="content" class="app-content">
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Module/Module_Payroll_Menu/Module_Payroll_Menu/?id=6">Paroll Menu</a></li>
    </ol>
    <h1 class="page-header"> Salary Process </h1>

    <div class="row">
        <div class="row">
            <div class="col-lg-12 col-md-12">
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Salary Process</h4>
                        <div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>
                    </div>
                    <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">

                        </p>
                    </div>
                    <div class="panel-body" style="max-height: fit-content;">
                        <div class="row justify-content-center">
                            @*<hr class="mt-15px">*@
                            <div class="row justify-content-center">
                                <form role="form" action="/Module/Module_Payroll_MonthlyAttendance/Module_Payroll_MonthlyAttendance" id="formSalaryProcess" method="post">

                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Company Name
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlCmpId", type = "text", name = "CmpId", autocomplete = "Off" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Business Unit
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-select", id = "ddlBranchId", type = "text", name = "BranchId", autocomplete = "Off" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-5">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Month/Year
                                                    <span class="important">*</span>
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.TextBoxFor(model => model.Month, new { @class = "form-control", name = "FromDate", type = "month", id = "FromDate" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="row mb-15px">
                                                <label class="form-label col-form-label col-md-6">
                                                    Load With Log
                                                </label>
                                                <div class="col-md-4">
                                                    @Html.CheckBoxFor(model => model.LoadWithLog, new { id = "chkLoadWithLog", style = "margin-top: 10px; margin-left: -25px;" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="row mb-15px">
                                                <div class="col-md-8">
                                                    <button type="button" onclick="funMonthlyAttendance()" class="btn btn-sm btn-success" style="margin-left: -110px;">Load Employee</button>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-1">
                                            <div class="row mb-15px">
                                                <div class="col-md-8">
                                                    <button type="button" onclick="funSave()" class="btn btn-sm btn-success" style="margin-left: -225px;">Save</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <hr class="mt-15px">
                        <div class="row">
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="tblsalaryProcess"
                                           style="width: 100%;" data-export-title="SM Auto Test">
                                        <thead>
                                            <tr class="trheading">
                                                <th class="text-nowrap text-center"> EmployeeId	</th>
                                                <th class="text-nowrap text-center"> EM_Atten_LeaveGroupId </th>
                                                <th class="text-nowrap text-center"> EmployeeName </th>
                                                <th class="text-nowrap text-center"> EmployeeNo </th>
                                                <th class="text-nowrap text-center"> EmployeeCardNo </th>
                                                <th class="text-nowrap text-center"> UnitName </th>
                                                <th class="text-nowrap text-center"> Mdays </th>
                                                <th class="text-nowrap text-center"> AA </th>
                                                <th class="text-nowrap text-center"> PP </th>
                                                <th class="text-nowrap text-center"> WO </th>
                                                <th class="text-nowrap text-center"> PH </th>
                                                <th class="text-nowrap text-center"> SL </th>
                                                <th class="text-nowrap text-center"> CL </th>
                                                <th class="text-nowrap text-center"> PL </th>
                                                <th class="text-nowrap text-center"> CO </th>
                                                <th class="text-nowrap text-center"> SPEL </th>
                                                <th class="text-nowrap text-center"> LWP </th>
                                                <th class="text-nowrap text-center"> OT </th>
                                                <th class="text-nowrap text-center"> LATEMARK </th>
                                                <th class="text-nowrap text-center"> ML </th>
                                                <th class="text-nowrap text-center"> EarlyGoing </th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbodySalaryProcess">
                                            @if(ViewBag.SalaryProcess !=null)
                                            {
                                            foreach (var d in ViewBag.SalaryProcess)
                                            {
                                                <tr>
                                                    <td class="text-nowrap"> @d.EmployeeId	</td>
                                                    <td class="text-nowrap"> @d.EM_Atten_LeaveGroupId </td>
                                                    <td class="text-nowrap"> @d.EmployeeName </td>
                                                    <td class="text-nowrap"> @d.EmployeeNo </td>
                                                    <td class="text-nowrap"> @d.EmployeeCardNo </td>
                                                    <td class="text-nowrap"> @d.UnitName </td>
                                                    <td class="text-nowrap"> @d.Mdays </td>
                                                    <td class="text-nowrap"> @d.AA </td>
                                                    <td class="text-nowrap"> @d.PP </td>
                                                    <td class="text-nowrap"> @d.WO </td>
                                                    <td class="text-nowrap"> @d.PH </td>
                                                    <td class="text-nowrap"> @d.SL </td>
                                                    <td class="text-nowrap"> @d.CL </td>
                                                    <td class="text-nowrap"> @d.PL </td>
                                                    <td class="text-nowrap"> @d.CO </td>
                                                    <td class="text-nowrap"> @d.SPEL </td>
                                                    <td class="text-nowrap"> @d.LWP </td>
                                                    <td class="text-nowrap"> @d.OT </td>
                                                    <td class="text-nowrap"> @d.LATEMARK </td>
                                                    <td class="text-nowrap"> @d.ML </td>
                                                    <td class="text-nowrap"> @d.EarlyGoing </td>
                                                </tr>
                                            }
                                            }
                                            
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: 'GetBusinessUnit',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlBranchId").append("<option value=0>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });
    });

</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#formSalaryProcess').validate({
        rules: {
            CmpId: {
                required: true,
            },
            BranchId: {
                required: true,
            },
            Month: {
                required: true,
            },
        },
        messages: {
            CmpId: {
                required: "Company name is required",
            },
            BranchId: {
                required: "Business unit is required",
            },
            Month: {
                required: "Month is required",
            },
        },
    });

    var form = $("#formSalaryProcess");
    form.validate();

    function funMonthlyAttendance() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#formSalaryProcess").submit();
    }
</script>


<script>
    function funSave() {
        debugger;

        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var Month = $("#FromDate").val();


        debugger;
        var table = document.getElementById("tblbodyMonthlyAttendance");
        var rowCount = table.rows.length;
        var ObjMonthlyAttendance = new Array();

        for (let i = 0; i <= rowCount - 1; i++) {
            var data = {};
            data.AttenEmployeeId = table.rows[i].cells[0].textContent;
            data.EM_Atten_LeaveGroupId = table.rows[i].cells[1].textContent;
            data.EmployeeName = table.rows[i].cells[2].textContent;
            data.AttenEmployeeNo = table.rows[i].cells[3].textContent;
            data.EmployeeCardNo = table.rows[i].cells[4].textContent;
            data.AttenUnitId = table.rows[i].cells[5].textContent;
            data.AttenMonthDays = table.rows[i].cells[6].textContent;
            data.AttenMonthYear = Month;
            data.AttenAB = table.rows[i].cells[7].textContent;
            data.AttenPP = table.rows[i].cells[8].textContent;
            data.AttenWO = table.rows[i].cells[9].textContent;
            data.AttenPH = table.rows[i].cells[10].textContent;
            data.AttenSL = table.rows[i].cells[11].textContent;
            data.AttenCL = table.rows[i].cells[12].textContent;
            data.AttenPL = table.rows[i].cells[13].textContent;
            data.AttenCO = table.rows[i].cells[14].textContent;
            data.AttenLWP = table.rows[i].cells[16].textContent;
            data.AttenLateMarkCount = table.rows[i].cells[18].textContent;
            data.AttenML = table.rows[i].cells[19].textContent;
            data.AttenEarlyMarkCount = table.rows[i].cells[20].textContent;

            data.AttenPayableDays = table.rows[i].cells[20].textContent;
            data.AttenOThrsDuration = table.rows[i].cells[20].textContent;
            data.AttenOThrsMin = table.rows[i].cells[20].textContent;
            data.AttenLateMarkCount = table.rows[i].cells[20].textContent;
            data.AttenLateMarkMin = table.rows[i].cells[20].textContent;
            data.AttenLateMarkDuration = table.rows[i].cells[20].textContent;
            data.AttenEarlyMarkCount = table.rows[i].cells[20].textContent;
            data.AttenEarlyMarkMin = table.rows[i].cells[20].textContent;
            data.AttenEarlyMarkDuration = table.rows[i].cells[20].textContent;
            data.AttenTotalShortLeaveCount = table.rows[i].cells[20].textContent;
            data.AttenTotalPersonalGatepassMin = table.rows[i].cells[20].textContent;
            ObjMonthlyAttendance.push(data);
        }

        debugger;
        $.ajax({
            type: "POST",
            url: "@Url.Action("SaveUpdate")",
            contentType: "application/json",
            dataType: "text",
            data: JSON.stringify({ ObjMonthlyAttendance: ObjMonthlyAttendance, CmpId: CmpId, BranchId: BranchId, Month: Month }),
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                // return false
                            }
                        }).then(function () {
                            location.reload();
                            $(".Userloaderbg").css("display", "none");
                        })
                    }
                }
            }
        });
    }
</script>

