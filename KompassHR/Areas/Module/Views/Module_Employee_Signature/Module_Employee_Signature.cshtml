<script>
    function ShowImagePreview(input) {
        debugger;
        if (input.files && input.files[0]) {
            var fname = input.files[0].name;
            var re = /(\.jpg|\.jpeg|\.png)$/i;
            if (!re.exec(fname)) {
                swal({
                    title: "File not supported!",
                    text: "This file format not suported",
                    type: "error"
                });
                $("#EmployeeSignature").val("");
                return false;
            }
            else {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#fileData').prop('src', e.target.result);
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    }
</script>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        var CountSignatureEmployeeId = @Html.Raw(Json.Encode(TempData["CountSignatureEmployeeId"]));
        var CheckPreboarding = @Html.Raw(Json.Encode(TempData["PreBoardFid"]));
        if(CountSignatureEmployeeId!=0)
        {
            $("#btnGet").hide();
        }
        else
        {
            if(CheckPreboarding!=0)
            {
                $("#btnGet").show();
            }
            else{
                $("#btnGet").hide();

            }

        }
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });

    function GetDetails(Status) {
        debugger;

        var baseUrl = '@Url.Action("PreboardingGetDetails", "Module_Employee_Signature", new { area = "Module" })';
        //var url = baseUrl + '?Status=' + encodeURIComponent(Status);

        window.location.href = baseUrl;
    }

    $('#EmployeeSignature').bind('change', function() {
        debugger;
        var fsize = (this.files[0].size);
        var FileUpload = fsize/1000;
        var FileSize=3000;
        if(FileUpload>=FileSize)
        {
            $("#ErrorEmployeeSignature").html("Please upload file size less than 3Mb");
            $('#ErrorEmployeeSignature').focus();
            $('#EmployeeSignature').val("");
            return false;
        }
        else{
            $("#ErrorEmployeeSignature").html("");
        }
    })

    function validatePhoto() {
        var fileInput = document.getElementById("EmployeeSignature");

        if (fileInput.files.length === 0) {
            $("#ErrorEmployeeSignature").html("Please upload file size less than 3Mb");
            $('#ErrorEmployeeSignature').focus();
            return false;
        }
        else
        {
            $("#ErrorEmployeeSignature").html("");
        }
        return true;
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const btn = document.getElementById("btnDownloadSignature");
        if (btn) {
            btn.addEventListener("click", function () {
                const base64Data = btn.getAttribute("data-base64");
                const fileName = btn.getAttribute("data-filename");

                if (!base64Data.startsWith("data:")) {
                    alert("Invalid Base64 format.");
                    return;
                }

                const link = document.createElement("a");
                link.href = base64Data;
                link.download = fileName || "download.jpg";
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }
    });
</script>