@model KompassHR.Areas.Module.Models.Module_Payroll.MonthlyAttendance
@{
    ViewBag.Title = "Module_Payroll_PremiumMonthlyAttendance";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var employees = ViewBag.MonthlyAttendance as IEnumerable<dynamic>;
    int hideColumnCount = 0;
    int monthDaysIndex = -1;

    if (employees != null && employees.Any())
    {
        var firstRow = employees.First() as IDictionary<string, object>;

        // First column value is hideColumnCount
        if (firstRow != null && firstRow.Values.Any())
        {
            int.TryParse(firstRow.Values.First()?.ToString(), out hideColumnCount);

            // Get the index of "Month Days"
            int idx = 0;
            foreach (var key in firstRow.Keys)
            {
                if (key.Trim().ToLower() == "payabledays")
                {
                    monthDaysIndex = idx;
                    break;
                }
                idx++;
            }
        }
    }
}


