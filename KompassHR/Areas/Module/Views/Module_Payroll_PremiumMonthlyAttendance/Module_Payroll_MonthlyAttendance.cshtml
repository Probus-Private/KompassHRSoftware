    function downloadExcelFile() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        //$(".Userloaderbg").css("display", "flex");

        //var CmpId = $("#ddlCmpId").val();
        //var Month = $("#FromDate").val();
        //var BranchId = $("#ddlBranchId").val();

        var CmpId = encodeURIComponent($("#ddlCmpId").val());
        var MonthYear = encodeURIComponent($("#FromDate").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        var ProcessCategoryId = $("#ddlProcessCategoryId").val();
        // var LeaveTypeId = encodeURIComponent($("#ddlLeaveTypeId").val());
        var url = `@Url.Action("DownloadMonthlyAttendnceExcelFile", "Module_Payroll_PremiumMonthlyAttendance")?CmpId=${CmpId}&BranchId=${BranchId}&MonthYear=${MonthYear}&ProcessCategoryId=${ProcessCategoryId}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                //var formattedDate = convertDateFormat(FromDate);
                //var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'MonthlyAttendance.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }


</script>

<script>
    function funSave() {
        $("#SelectAll").prop("checked", false);
        debugger;
        const CmpId = $("#ddlCmpId").val();
        const Month = $("#FromDate").val();
        const BranchId = $("#ddlBranchId").val();
        var ProcessCategoryId = $("#ddlProcessCategoryId").val();
        const ObjMonthlyAttendance = [];

        const $thead = $('#tblTableBulkCTCInsert thead th');

        $('#tblbodyMonthlyAttendance input.row-checkbox:checked').each(function () {
            const $row = $(this).closest('tr');
            const rowData = {};

            // Collect named inputs (excluding checkbox)
            $row.find('input[name]').not('.row-checkbox').each(function () {
                rowData[$(this).attr('name')] = $(this).val();
            });

            // Collect plain text cells
            $row.find('td').each(function () {
                if ($(this).find('input').length === 0) {
                    const colIndex = $(this).index();
                    const colName = $thead.eq(colIndex).text().trim() || 'Column' + colIndex;
                    if (!rowData.hasOwnProperty(colName)) {
                        rowData[colName] = $(this).text().trim();
                    }
                }
            });

            ObjMonthlyAttendance.push(rowData);
        });

        if (ObjMonthlyAttendance.length === 0) {
            return Swal.fire({
                icon: "error",
                text: "Select at least one employee",
                allowOutsideClick: () => animatePopup()
            });
        }

        const dataToSend = {
            model: {
                ObjMonthlyAttendance: ObjMonthlyAttendance
            },
            CmpId: parseInt(CmpId),
            Month: Month,
            BranchId: BranchId,
            ProcessCategoryId:ProcessCategoryId
        };
        $(".Userloaderbg").css("display", "flex");

        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpdate", "Module_Payroll_PremiumMonthlyAttendance")',
            data: JSON.stringify(dataToSend),
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                $(".Userloaderbg").hide();
                debugger;
                // var data = JSON.parse(response);
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response != null) {
                    if(Icon1=="error")
                    {
                        $(".Userloaderbg").css("display", "none");
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                    else{
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("Module_Payroll_PremiumMonthlyAttendance", "Module_Payroll_PremiumMonthlyAttendance")';
                                } else if (
                                    /* Read more about handling dismissals below */
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })
                        }
                    }
                }
            }
        });
    }

    function ResetFile()  {
        debugger;
        let allowedExtension = ['application/vnd.ms-excel'];
        let fileInput = document.getElementById('txtAttachFile');

        if (fileInput.files.length > 0) {
            let type = fileInput.files[0].type;

            if (allowedExtension.indexOf(type) === -1) {
                $("#ErrorFile").text('File type should be Excel (.xlsx)');
                fileInput.value = null;
                return false;
            }
        }

        $("#ErrorFile").text('');
    }

    var form = $("#formMonthlyAttendance");
    form.validate();

    $("#btnfileupload").click(function(){
        debugger;

        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }

        var fileInput = document.getElementById('txtAttachFile');
        if (fileInput.files.length === 0) {
