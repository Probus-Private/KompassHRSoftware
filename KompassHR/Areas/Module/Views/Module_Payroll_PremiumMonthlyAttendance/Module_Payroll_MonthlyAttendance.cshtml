                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        $('#tblbodyMonthlyAttendance').not(function(){return!!$(this).has('th').length;}).remove();
        $("#formMonthlyAttendance").submit();
    })
</script>

