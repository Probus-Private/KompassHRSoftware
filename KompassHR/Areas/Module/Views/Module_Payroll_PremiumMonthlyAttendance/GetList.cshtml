@model KompassHR.Areas.Module.Models.Module_Payroll.MonthlyAttendance
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    th:nth-child(1), td:nth-child(1) {
        width: 40px; /* Set the width for the first column */
    }

    th:nth-child(2), td:nth-child(2) {
        width: 40px; /* Set the width for the first column */
    }

    .tblAddData td:nth-child(7) {
        display: none;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 10px !important;
        background-color: #F5F5F5;
    }
    /* Horizontal scrollbar */
    .dataTables_scrollBody::-webkit-scrollbar {
        height: 10px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Premium Monthly Attendance
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Premium Monthly Attendance (Summary) - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of  Premium monthly attendance (summary) created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action="@Url.Action("GetList", "Module_Payroll_PremiumMonthlyAttendance")" id="SaveMonthlyAttendance">
                        <div class="row">
                            <div class="col-md-2">
                                <a href="@Url.Action("Module_Payroll_PremiumMonthlyAttendance", "Module_Payroll_PremiumMonthlyAttendance", new { area = "Module" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Month/Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-5">
                                        @Html.TextBoxFor(model => model.Month, new { id = "txtMonth", @class = "form-control", name = "Month", type = "month" })
                                    </div>
                                    <div class="col-md-3">
                                        <button type="button" id="btnshow" onclick="showList()" class="btn btn-success btn-sm  mb-10px">
                                            <i class="fa-solid fa-eye"></i> &nbsp; Show
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </form>

                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                   style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th class="text-nowrap">Show </th>
                                        <th class="text-nowrap">Export </th>
                                        <th class="text-nowrap">Company Name </th>
                                        <th class="text-nowrap">Business Unit</th>
                                        <th class="text-nowrap">Month Year</th>
                                        <th class="text-nowrap">Employee Count </th>
                                        <th class="text-nowrap"> Process Category Name </th>
                                        <th class="text-nowrap" hidden>Atten_ProcessCategoryId</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.GetMonthlyAttendance)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <a id="btnshow" onclick="ViewForEmployee('@d.AttenMonthlyBranchId' ,'@d.AttenMonthlyMonthYear','@d.Atten_ProcessCategoryId')"
                                                   style="cursor:pointer;">
                                                    <i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <a id="btnshow" onclick="downloadExcelFile('@d.AttenMonthlyBranchId' ,'@d.AttenMonthlyMonthYear','@d.Atten_ProcessCategoryId')"
                                                   style="cursor:pointer;">
                                                    <i class="fa-solid fa-download fa-lg text-primary"></i>

                                                </a>
                                            </td>
                                            <td>@d.ShortName</td>
                                            <td>@d.BranchName</td>
                                            <td>@d.MonthYear</td>
                                            <td>@d.EmployeeCount</td>
                                            <td>@d.ProcessCategoryName</td>
                                            <td hidden>@d.Atten_ProcessCategoryId</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- END panel -->
</div>

<!-- #Start modal-dialog -->
<div class="modal fade" id="myEmployeeAttendance" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Premium Monthly Attendance - List</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="row">
                                    <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass tblAddData" style="width: 100%;" id="tblEmployeeHistoryHead">
                                        <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th class="text-nowrap text-center">All <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>

                                                <th class="text-nowrap">Employee No </th>
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Business Unit</th>
                                                <th class="text-nowrap">Payable Days </th>
                                                <th class="text-nowrap">Is Salary Process</th>
                                                <th hidden class="text-nowrap">AttenMonthlyID </th>
                                                <th hidden class="text-nowrap">AttenMonthlyEmployeeID </th>
                                                <th class="text-nowrap">Created By</th>
                                                <th class="text-nowrap">Created Date</th>
                                                <th class="text-nowrap">Machine Name</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblBodyEmployeeAttendance"></tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
            <div class="modal-footer">
                <button type="button" id="btnEmployeeSubmit" onclick="funSave()"
                        class="btn btn-danger btn-sm">
                    <i class="fa-solid fa-trash-alt"></i> Delete
                </button>
                <button type="button" class="btn btn-primary btnpress btn-sm CloseModel" id="CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true">
                    <i class="fa-solid fa-share-from-square"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        var GetMonth = @Html.Raw(Json.Encode(TempData["MonthYear"]));
        if(GetMonth =="" || GetMonth == null)
        {
            var today = new Date();
            // Format the date as YYYY-MM (year-month)
            var yyyy = today.getFullYear();
            var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
            var defaultMonth = yyyy + '-' + mm;
            // Set the value of the input element to the default month
            var CheckEmptyDate = document.getElementById('txtMonth').value;
            if (CheckEmptyDate == "") {
                document.getElementById('txtMonth').value = defaultMonth;
            }
        }
        else
        {
            $("#txtMonth").val(GetMonth);
        }

        //$('.TabledataBulkClass').DataTable({
        //    scrollY: 300,
        //    scrollCollapse: true,
        //    paging: false,
        //    scrollX: true,
        //    searching: true, // Enable searching
        //});
        //$('#myEmployeeAttendance').on('shown.bs.modal', function () {
        //    var table = $('.TabledataBulkClass').DataTable({
        //        scrollY: 300,
        //        scrollCollapse: true,
        //        paging: false,
        //        scrollX: true,
        //        searching: true,
        //        autoWidth: false,
        //    });
        //    table.columns.adjust().draw(); // Ensure alignment
        //});

        $('#myEmployeeAttendance').on('shown.bs.modal', function () {
            var table = $('.TabledataBulkClass').DataTable();

            if ($.fn.DataTable.isDataTable('.TabledataBulkClass')) {
                table.destroy();
            }

            $('.TabledataBulkClass').DataTable({
                scrollY: 400,
                scrollCollapse: true,
                paging: false,
                scrollX: true,
                searching: true, // Enable searching
                stripeClasses: [] // Disable alternating row colors
            });

            //$('.TabledataBulkClass').DataTable({
            //    scrollY: 300,
            //    scrollCollapse: true,
            //    paging: false,
            //    scrollX: true,
            //    searching: true,
            //    autoWidth: false,
            //});
        });
    });//ready function


    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

    function showList() {
        $("#SaveMonthlyAttendance").submit();
    }

    $(".CloseModel").click(function () {
        var tableBody = $('#tblBodyEmployeeAttendance');
        tableBody.html(''); // Ensures the table rows are removed;
        //$('#tblPinCodeLocationPermanent tr').not(function () { return !!$(this).has('th').length; }).remove();
    })
</script>

