    function downloadExcelFile(AttenMonthlyBranchId, AttenMonthlyMonthYear,Atten_ProcessCategoryId) {
        $(".Userloaderbg").css("display", "flex");
        var txtMonth= $("#txtMonth").val();
        var BranchId = encodeURIComponent(AttenMonthlyBranchId);
        var MonthYear = encodeURIComponent(AttenMonthlyMonthYear);
        var url = `@Url.Action("DownloadExcelFile", "Module_Payroll_PremiumMonthlyAttendance")?BranchId=${BranchId}&MonthYear=${MonthYear}&Atten_ProcessCategoryId=${Atten_ProcessCategoryId}`;
        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                var formattedDate = convertMonthYearFormat(txtMonth);
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'Monthly Attendance('+formattedDate+').xlsx';
                anchorElement.click();
                window.URL.revokeObjectURL(url);
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
            }
        });
    }
</script>

