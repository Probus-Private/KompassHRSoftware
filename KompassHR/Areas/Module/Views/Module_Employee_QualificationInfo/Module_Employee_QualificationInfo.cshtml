                                            <label class="form-label col-form-label col-md-12">
                                                University/College
                                                Name <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.QualificationUniversity, new { @class = "form-control", name = "QualificationUniversity", type = "text", id = "txtQualificationUniversity", autocomplete = "Off", Maxlength = 50 })
                                            </div>
