                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <!-- BEGIN table-responsive -->
                                        <table class="table table-bordered align-middle" id="fixed-header"
                                               style="width: 100%;">
                                            <thead>
                                                <tr>
                                                    <th class="text-nowrap"> Action</th>
                                                    <th class="text-nowrap"> Qualification </th>
                                                    <th class="text-nowrap"> Passing Year</th>
                                                    <th class="text-nowrap"> Percentage(%)/Grade </th>
                                                    <th class="text-nowrap"> Course Type </th>
                                                    <th class="text-nowrap"> University / College Name </th>
                                                    <th class="text-nowrap"> PRN No </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetEmployeeQualificationList)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <button type="button" onclick="DeleteQualification('@d.QualificationID_Encrypted')" id="btnDelete"
                                                                    class="btn btn-danger btn-sm btnpress">
                                                                <i class="fa-solid fa-trash-alt"></i>
                                                            </button>
                                                        </td>
                                                        <td>@d.QualificationName</td>
                                                        <td>@d.QualificationPassingYear</td>
                                                        <td>@d.QualificationMark</td>
                                                        <td>@d.QualificationType</td>
                                                        <td>@d.QualificationUniversity</td>
                                                        <td>@d.QualificationRollNo</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<div class="row">
