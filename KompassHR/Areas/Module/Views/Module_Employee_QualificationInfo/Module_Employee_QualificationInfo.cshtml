</div>

<script>
    $(document).ready(function () {
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        var CountQualificationEmployeeID = @Html.Raw(Json.Encode(TempData["CountQualificationEmployeeID"]));


        var CheckPreboarding = @Html.Raw(Json.Encode(TempData["PreBoardFid"]));

        if(CountQualificationEmployeeID!=0)
        {
            $("#btnGet").hide();
        }
        else
        {
            if(CheckPreboarding!=0)
            {
                $("#btnGet").show();
            }
            else{
                $("#btnGet").hide();

            }
            
        }



        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });

    function GetDetails(Status) {
        debugger;

        var baseUrl = '@Url.Action("PreboardingGetDetails", "Module_Employee_QualificationInfo", new { area = "Module" })';
        //var url = baseUrl + '?Status=' + encodeURIComponent(Status);

        window.location.href = baseUrl;
    }
</script>

<script>
    function DeleteQualification(QualificationID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Employee_QualificationInfo")?QualificationID_Encrypted=' + QualificationID_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>

<script>
    function numbervalidate(key) {
        var presskeys = (key.which) ? key.which : key.presskeys;
        if (!(presskeys == 8 || presskeys == 46) && (presskeys < 48 || presskeys > 57)) {
            return false;
        }
    }
</script>

<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveQualificationsInformation").validate({
        rules: {
            QualificationName: {
                required: true,
                //regex: /^[a-zA-Z0-9\.\-\()\/ ]+$/,
            },
            QualificationPassingYear: {
                required: true,
                regex: /^[0-9]+$/,
            },
            QualificationMark: {
                required: true,
                //regex: /^[a-zA-Z0-9\.\+ ]+$/,
            },
            QualificationType: {
                required: true,
            },
            QualificationUniversity: {
                required: true,
              //  regex: /^[a-zA-Z\.\-\()\/ ]+$/,
            },
            //QualificationRollNo: {
            //    required: true,
            //    regex: /^[a-zA-Z0-9\.\-\()\/ ]+$/,
            //},
        },
        messages: {
            QualificationName: {
                required: "Qualification is required",
               // regex: "Please enter only alphabet",
            },
            QualificationPassingYear: {
                required: "Passing year is required",
                regex: "Please enter only digits",
            },
            QualificationMark: {
                required: "Percentage is required",
               // regex: "Please enter only alphabet",
            },
            QualificationType: {
                required: "Course type is required",
            },
            QualificationUniversity: {
                required: "University/College name is required",
               // regex: "Please enter only alphabet",
            },
            //QualificationRollNo: {
            //    required: "PRN No. \ Reg.No. \ Roll No. is required",
            //    regex: "Please enter only alphabet and digits",
            //},
        }
    });


    var form = $( "#SaveQualificationsInformation" );
    form.validate();
    $("#btnSubmit").click(function () {
        if(form.valid()==false)
        {
            return false;
        }
        var QualificationID_Encrypted=$("#QualificationID_Encrypted").val();
        var QualificationName=$("#txtQualificationName").val();

        $.ajax({
            url: '@Url.Action("IsQualificationExists", "Module_Employee_QualificationInfo")',
            method:"get",
            data:{QualificationID_Encrypted:QualificationID_Encrypted,QualificationName:QualificationName},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveQualificationsInformation").submit();

                }
            }
        });

    });
</script>

