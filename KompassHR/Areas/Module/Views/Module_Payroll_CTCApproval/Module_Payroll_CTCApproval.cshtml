@model KompassHR.Areas.Module.Models.Module_Payroll.Payroll_CTCApproval
@{
    ViewBag.Title = "Module_Payroll_CTCApproval";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>


<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

   /*tr td {
        padding: 4px !important;
        font-weight: 600;
    }*/

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    /*.table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }*/

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    /*.table-wrap {
        width: 100%;
        overflow: auto;
    }*/

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                CTC Approval
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">CTC Approval   - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of CTC Approval created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action='@Url.Action("Module_Payroll_CTCApproval", "Module_Payroll_CTCApproval", new { area = "Module" })' id="SaveCTCApproval" method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Company Name
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-9">
                                        @Html.DropDownListFor(model => model.CTCCmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlCTCCmpId", @class = "form-select", name = "CTCCmpId" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-3">
                                        Business Unit
                                        @*<span class="important">*</span>*@
                                    </label>
                                    <div class="col-md-7">
                                        @Html.DropDownListFor(model => model.CTCBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--All--", new { id = "ddlCTCBranchId", @class = "form-select", name = "CTCBranchId" })
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" id="btnshow" onclick="GetList()" class="btn btn-primary btn-sm  mb-10px">
                                            Load
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                    <hr/>
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            @if (ViewBag.CTCApproval != null)
                            {
                                <table id="data-table-combine15" class="table table-bordered align-middle tblAddData TabledataBulkClass" style="width: 100%;">
                                    <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                        @{ var dynamicList = ViewBag.CTCApproval as List<dynamic>; }
                                        <tr>
                                            <th class="text-center"><input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" />  All</th>
                                            @foreach (var Site in dynamicList)
                                            {
                                                foreach (var property in (IDictionary<string, object>)Site)
                                                {
                                                    var isHidden = property.Key == "EmployeeCTCId" ||
                                                                   property.Key == "EmployeeCTCId_Encrypted" ||
                                                                   property.Key == "CTCEmployeeId";
                                                    <td style="@(isHidden ? "display: none;" : "")">@property.Key</td>

                                                }
                                                break;
                                            }
                                        </tr>
                                    </thead>

                                    <tbody id="tblCTCApproval">
                                        @foreach (var Site in dynamicList)
                                        {
                                        <tr>
                                            @{
                                                    var dict = (IDictionary<string, object>)Site;
                                            }

                                            <td class="text-nowrap text-center"><input type="checkbox" class="form-check-input" /></td>

                                            @foreach (var property in dict)
                                                {
                                                    var isHidden = property.Key == "EmployeeCTCId" ||
                                                                   property.Key == "EmployeeCTCId_Encrypted" ||
                                                                    property.Key == "CTCEmployeeId"; ;
                                                <td style="@(isHidden ? "display: none;" : "")">@property.Value</td>
                                                }
                                        </tr>
                                                 }
                                    </tbody>
                                </table>
                                                }
                        </div>
                    </div>
                    <div class="row">
                        <div class="LastShortLeaveBx">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="BtnBx">
                                        <div>
                                            @*<button type="button" id="btnSubmit" onclick="funDelete()"
                                            class="btn btn-danger btn-sm">
                                        <i class="fa-solid fa-trash-alt"></i> Delete
                                    </button>*@
                                            <button type="button" id="btnSubmit" onclick="funSave()"
                                                    class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-floppy-disk"></i> Approve
                                            </button>
                                            <a href="@Url.Action("GetList", "Module_Payroll_CTCApproval", new { area = "Module" })">
                                                <button type="button" class="btn btn-danger btn-sm" id="btnGeCTCAprovalList">
                                                    <i class="fa-solid fa-share-from-square"></i> Approve List
                                                </button>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Employee CTC Details</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal" aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            From Date
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.FromDate, null, new { @class = "form-control", type = "date", id = "txtFromDate", onkeydown = "return false;" })
                                            @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            To Date
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.ToDate, null, new { @class = "form-control", type = "date", id = "txtToDate", onkeydown = "return false;", style = "background-color:#eee;", @readonly = "readonly" })
                                            @Html.ValidationMessage("ToDate", "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Category Name
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.CategoryId, new SelectList(ViewBag.CategoryName ?? new List<SelectListItem>(), "Id", "Name"), "--Select--", new { id = "ddlCategoryName", @class = "form-select", autocomplete = "off", name = "CategoryName" })
                                            @Html.ValidationMessage("CTC_CategoryId", "", new { @class = "help-block", id = "ErrorddlCategoryName", @style = "color:red" })
                                            @Html.HiddenFor(model => model.EmployeeCTCId_Encrypted, new { id = "hdnEncriptedId" })
                                            @Html.Hidden("Status", new { id = "hdnStatus" })
                                            @Html.Hidden("OBEmpId", Session["OnboardEmployeeId"], new { id = "hdnOBEmpId" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Monthly/Daily
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.DailyMonthly, new { id = "ddlDailyMonthly", @class = "form-control", autocomplete = "off", name = "DailyMonthly", style = "background-color:#eee;", @readonly = "readonly", Value = TempData["GetDailyOrMonthly"]?.ToString() ?? "" })

                                            @*@Html.DropDownListFor(model => model.DailyMonthly, new List<SelectListItem>
                                                {
                                                new SelectListItem { Text = "Monthly", Value = "Monthly" },
                                                new SelectListItem { Text = "Daily", Value = "Daily" },
                                                },
                                                //"--Select--",
                                                new { id = "ddlDailyMonthly", @class = "form-select", autocomplete = "off", name = "DailyMonthly" })*@
                                            @Html.ValidationMessage("DailyMonthly", "", new { @class = "help-block", id = "ErrortxtDailyMonthly", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Salary Transfer from Bank
                                            @*<span class="important">*</span>*@
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.RateCmpBankId, new SelectList(ViewBag.CompanyBankName ?? new List<SelectListItem>(), "Id", "Name"),
                                              //"--Select--",
                                              new { id = "ddlCompanyBankName", @class = "form-select", autocomplete = "off", name = "RateCmpBankId" })
                                            @Html.ValidationMessage("RateCmpBankId", "", new { @class = "help-block", id = "ErrorddlCompanyBankName", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Salary Mode
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.RateSalaryMode, new List<SelectListItem>
                                                {
                                                new SelectListItem { Text = "Bank", Value = "Bank" },
                                                new SelectListItem { Text = "Cheque", Value = "Cheque" },
                                                new SelectListItem { Text = "Cash", Value = "Cash" },
                                                },
                                                //"--Select--",
                                                new { id = "ddlRateSalaryMode", @class = "form-select", autocomplete = "off", name = "RateSalaryMode" })
                                            @Html.ValidationMessage("RateSalaryMode", "", new { @class = "help-block", id = "ErrorddlRateSalaryMode", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            OT Rate
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.RateOTRate, new { @class = "form-control", type = "text", id = "txtRateOTRate", Value = 0, oninput = "validateInput(this)" })
                                            @Html.ValidationMessage("RateOTRate", "", new { @class = "help-block", id = "ErrortxtRateOTRate", @style = "color:red" })
                                        </div>
                                    </div>
                                </div>



                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            CTC Budget
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(model => model.RateBudgetId, new SelectList(ViewBag.BudgetName ?? new List<SelectListItem>(), "Id", "Name"), "--Select--", new { id = "ddlCTCBudget", @class = "form-select", autocomplete = "off", name = "BudgetName" })
                                            @Html.ValidationMessage("RateBudgetId", "", new { @class = "help-block", id = "ErrorddlCTCBudget", @style = "color:red" })
                                        </div>

                                        @*<div class="col-md-7">
                                                @Html.TextBoxFor(model => model.RateBudgetId, new { @class = "form-control", type = "text", id = "txtCTCBudget", Value = 0 })
                                                @Html.ValidationMessage("RateBudgetId", "", new { @class = "help-block", id = "ErrortxtCTCBudget", @style = "color:red" })
                                            </div>*@
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <div class="col-md-12">
                                            <label class="form-label">PF : <span id="spnPF"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;
                                            <label class="form-label">ESIC : <span id="spnESIC"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;
                                            <label class="form-label">LWF : <span id="spnLWF"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;
                                            @*<label class="form-label">Gratuity : <span id="spnGratuity"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;*@
                                            <label class="form-label">PT : <span id="spnPT"></span></label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div id="dynamicTables">
                                            <div class="row">
                                                <!-- Part A -->
                                                <div class="col-md-6">
                                                    <div class="table-responsive">
                                                        <h5 style="background-color:lightgray; padding: 5px;">Part A</h5>
                                                        <table class="table table-bordered" id="partATable">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 10%;">Sr.No</th> <!-- Set width -->
                                                                    <th hidden style="width: 10%;">ColumnName</th> <!-- Set width -->
                                                                    <th style="width: 60%;">Head Name</th> <!-- Set width -->
                                                                    <th style="width: 30%;">Amount</th> <!-- Set width -->
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblPartA">
                                                                @if (ViewBag.MappedHeadPartA != null)
                                                                {
                                                                    int srNo = 1;
                                                                    foreach (var d in ViewBag.MappedHeadPartA)
                                                                    {
                                                                        <tr>
                                                                            <td>@srNo</td>
                                                                            <td hidden>@d.ID</td>
                                                                            <td style="text-align: left;">@d.Heads</td>
                                                                            <td><input type="text" Value=0 style="text-align: right;" class="form-control validate-number" name="value_@srNo" id="txt@(d.ID)"></td>
                                                                        </tr>
                                                                        srNo++;
                                                                    }
                                                                }
                                                            </tbody>
                                                            <tfoot>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Part A (Gross) Total =</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" id="txtRateTotalPartA" readonly style="text-align: right; background-color:#eee"></td>
                                                                </tr>
                                                            </tfoot>
                                                        </table>

                                                    </div>
                                                </div>
                                                <!-- Part B -->
                                                <div class="col-md-6">
                                                    <div class="table-responsive">
                                                        <h5 style="background-color:lightgray;padding: 5px;">Part B</h5>
                                                        <table class="table table-bordered" id="partBTable">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 10%;">Sr.No</th> <!-- Set width -->
                                                                    <th hidden style="width: 10%;">ColumnName</th> <!-- Set width -->
                                                                    <th style="width: 60%;">Head Name</th> <!-- Set width -->
                                                                    <th style="width: 30%;">Amount</th> <!-- Set width -->
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblPartB">
                                                                @if (ViewBag.MappedHeadPartB != null)
                                                                {
                                                                    int srNo = 1;
                                                                    foreach (var d in ViewBag.MappedHeadPartB)
                                                                    {
                                                                        <tr>
                                                                            <td>@srNo</td>
                                                                            <td hidden>@d.ID</td>
                                                                            <td style="text-align: left;">@d.Heads</td>
                                                                            <td><input type="text" Value=0 style="text-align: right;" class="form-control validate-number" name="value_@srNo" id="txt@(d.ID)"></td>
                                                                        </tr>
                                                                        srNo++;
                                                                    }
                                                                }
                                                            </tbody>
                                                            <tfoot>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Part B Total&nbsp;=&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" id="txtRateTotalPartB" readonly style="text-align: right; background-color:#eee"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>CTC (A + B)&nbsp;=&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" id="txtRateTotalPartAB" readonly style="text-align: right;background-color:#eee"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>VPF Amount &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" style="text-align: right;" id="txtRate_VPF"></td>
                                                                </tr>

                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Employee PF &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_PF"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Employee ESIC &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_ESIC"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>PT &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_PT"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Net Pay &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" readonly style="text-align: right;background-color:#eee" id="txtRate_NetPay"></td>
                                                                </tr>

                                                                @{
                                                                    var isAttenBonusApplicable = Convert.ToBoolean(TempData["GetAttenBonusIsApplicable"]);
                                                                }

                                                                @if (isAttenBonusApplicable)
                                                                {
                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right">
                                                                            <b>Attendance Bonus &nbsp;&nbsp;</b>
                                                                        </td>
                                                                        <td>
                                                                            <input type="checkbox" class="form-check-input" id="ChkRatePartB_AttendanceBonus_IsApplicable" />
                                                                        </td>
                                                                    </tr>
                                                                }

                                                                @*<tr>
                                                                        <td colspan="2" style="text-align:right"><b>Attendance Bonus &nbsp;&nbsp;</b></td>
                                                                        <td><input type="checkbox" class="form-check-input" id="ChkRatePartB_AttendanceBonus_IsApplicable"></td>
                                                                    </tr>*@
                                                            </tfoot>
                                                        </table>

