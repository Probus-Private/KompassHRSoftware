        $('#tblCTCApproval :checkbox:checked').each(function () {
            var row = $(this).closest('tr'); // Get the closest row
            var data = {

                EmployeeCTCId: row.find('td').eq(1).text(), // Hidden column

            };

            // Push the data object to the array
            ObjCTCApproval.push(data);
        });

       

        if (ObjCTCApproval.length==0)
        {
            var Message="Select atleast one employee";
            var Icon="error";
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)

                            return false
                        }
                    })
                    return false;
                }
            }
        }
        else{
            $(".Userloaderbg").css("display", "flex");
            $.ajax({
                type: "POST",
                url: '@Url.Action("SaveUpdate", "Module_Payroll_CTCApproval")',
                data: JSON.stringify({ ObjCTCApproval: ObjCTCApproval}),
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    var data = JSON.parse(response);
                    var Message1 = data.Message;
                    var Icon1 = data.Icon;
                    if (data != null) {
                        if(Icon1=="error")
                        {
                            $(".Userloaderbg").css("display", "none");
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
                                    }
                                });
                            }
                        }
                        else{
                            if (Message1 != null) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1,
                                    allowOutsideClick: () => {
                                        const popup = Swal.getPopup()
                                        popup.classList.remove('swal2-show')
                                        setTimeout(() => {
                                            popup.classList.add('animate__animated', 'animate__headShake')
                                        })
                                        setTimeout(() => {
                                            popup.classList.remove('animate__animated', 'animate__headShake')
                                        }, 500)
                                        return false
