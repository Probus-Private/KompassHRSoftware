                    $ddl.append(`<option value="${item.Id}">${item.Name}</option>`);
                });

                var $ddl = $('#ddlCTCBudget');
                $ddl.html('<option value="">--Select--</option>'); // Add default option
                $.each(GetBudgetName, (i, item) => {
                    $ddl.append(`<option value="${item.Id}">${item.Name}</option>`);
                });

                var $ddl = $('#ddlCompanyBankName');
                $ddl.html('<option value="">--Select--</option>'); // Add default option
