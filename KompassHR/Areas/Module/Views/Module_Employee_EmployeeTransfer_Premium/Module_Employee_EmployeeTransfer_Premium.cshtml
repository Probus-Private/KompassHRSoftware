@model KompassHR.Areas.Module.Models.Module_Employee.Employee_EmployeeTransfer_Premium

@{
    ViewBag.Title = "Module_Employee_EmployeeTransfer_Premium";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>

<style>
    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .note-editable {
        border: groove;
        font-size: 16px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Employee Transfer For Premium
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Contractor_Menu", "ESS_Contractor_Menu",  new {id =27, ScreenId=307, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading">
                    <h4 class="panel-title"> Employee Transfer For Premium- @ViewBag.AddUpdateTitle</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Employee Transfer For Premium
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_EmployeeTransfer_Premium", new { area = "Module" })' id="SaveEmployeeTransfer_Premium" method="post">
                                @Html.HiddenFor(model => model.EmployeeTransferId_Encrypted, new { id = "txtEmployeeTransferId_Encrypted" })
                                @Html.HiddenFor(model => model.EmployeeTransferId, new { id = "txtEmployeeTransferId" })

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.GetCompanyname, "Id", "Name"), "Select", new { id = "ddlCmpId", @class = "form-select", autocomplete = "off", name = "CmpId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "Select", new { id = "ddlBranchId", @class = "form-select", autocomplete = "off", name = "BranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.EmployeeId, new SelectList(ViewBag.GetEmployeeName, "Id", "Name"), "Select", new { id = "ddlEmployeeId", @class = "form-select", autocomplete = "off", name = "EmployeeId" })
                                        
                                             </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Branch Id
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.ToBranchId, new SelectList(ViewBag.GetToBranchName, "Id", "Name"), "Select", new { id = "ddlToBranchId", @class = "form-select", autocomplete = "off", name = "ToBranchId" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                             
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                               Transfer Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.TransferDate, new{id = "txtTransferDate", @class = "form-control", autocomplete = "off", type = "date" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                               Daily Monthly
                                            
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.DailyMonthly, new { id = "txtDailyMonthly", @class = "form-control", autocomplete = "off", name = "DailyMonthly" })
                                            </div>
                                        </div>
                                    </div>

                                    </div>


                               <div class="row">
                                        <div class="col-md-6 mb-2">
                                            <div class="row mb-12px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Attendance Bonus Applicable
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.CheckBoxFor(model => model.AttendanceBonusApplicable, new { @class = "form-check-input", id = "chkAttendanceBonusApplicable", name = "AttendanceBonusApplicable" })
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6 mb-2">
                                            <div class="row mb-12px">
                                                <label class="form-label col-form-label col-md-4">
                                                    Canteen Applicable
                                                </label>
                                                <div class="col-md-8">
                                                    @Html.CheckBoxFor(model => model.CanteenApplicable, new { @class = "form-check-input", id = "chkCanteenApplicable", name = "CanteenApplicable" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>


                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Attendance Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Shift Group
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.ShiftGroup, new SelectList(ViewBag.GetShiftGroupName, "Id", "Name"), "Select", new { id = "ddlShiftGroup", @class = "form-select", autocomplete = "off", name = "ShiftGroup" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                               Shift Rule
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.ShiftRule, new SelectList(ViewBag.GetShiftRuleName, "Id", "Name"), "Select", new { id = "ddlShiftRule", @class = "form-select", autocomplete = "off", name = "ShiftRule" })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                        <div class="LastShortLeaveBx">
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="BtnBx">
                                                        <div>
                                                            <button type="button" id="btnSubmit"
                                                                    class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-floppy-disk"></i> Submit
                                                            </button>
                                                            <a href="@Url.Action("GetList", "Module_Employee_EmployeeTransfer_Premium", new { area = "Module" })">
                                                                <button type="button" class="btn btn-danger btn-sm" id="btnDesignationGetList">
                                                                    <i class="fa-solid fa-share-from-square"></i> List
                                                                </button>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                           
                            </form>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>



<script>
    $(document).ready(function () {
        debugger;
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlEmployeeId").select2();
        $("#ddlToBranchId").select2();
        $("#ddlShiftGroup").select2();
        $("#ddlShiftRule").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(() => {
                window.location.reload();
            });
        }



        var dt = @Html.Raw(Json.Encode(TempData["TransferDate"]));
        if(dt == null || dt == "")
        {

        }
        else
        {
            var publicdt =  convertDate(dt);
            $("#txtTransferDate").val(publicdt);
        }



        $("#ddlCmpId").on("change", function () {
            debugger
            $("#ddlBranchId").empty();
            $("#ddlEmployeeId").empty();
            $("#ddlToBranchId").empty();
            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetBusinessUnit", "Module_Employee_EmployeeTransfer_Premium")',
                data: { CmpId: CmpId },
                success: function (data) {

                    if (data && data.Branch) {
                        $("#ddlBranchId").append("<option value=''>--Select--</option>");
                        $("#ddlToBranchId").append("<option value=''>--Select--</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            $("#ddlToBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    if (data && data.EmployeeName) {
                        $("#ddlEmployeeId").append("<option value=''>--Select--</option>");
                        $.each(data.EmployeeName, function (i, p) {
                            $("#ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            });
        });



        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlEmployeeId").find("option").remove();
            var BranchId = $("#ddlBranchId").val()||null;
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetEmployeeName", "Module_Employee_EmployeeTransfer_Premium")',
                data: { CmpId: CmpId, BranchId: BranchId },
                success: function (data) {
                    if (data != null) {
                        $("#ddlEmployeeId").append("<option value=''>--Select--</option>");
                        //$.each(data, function (i, p) {
                        //    $("#ddlBonusEmpId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        //});
                        $.each(data.EmployeeName, function (i, p) {   // <-- fixed here
                            $("#ddlEmployeeId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });


$("#ddlEmployeeId").on("change", function () {
    debugger;
    var EmployeeId = $("#ddlEmployeeId").val() || null;

    $.ajax({
        type: 'GET',
        dataType: 'JSON',
        url: '@Url.Action("GetCanteenApplicable", "Module_Employee_EmployeeTransfer_Premium")',
        data: { EmployeeId: EmployeeId },
        success: function (data) {
            if (data && data.IsCanteenApplicable !== undefined) {
                $("#chkCanteenApplicable").prop("checked", data.IsCanteenApplicable);
            }
            else {
                $("#chkCanteenApplicable").prop("checked", false);
            }

            if (data && data.IsAttenBonusApplicable !== undefined) {
                $("#chkAttendanceBonusApplicable").prop("checked", data.IsAttenBonusApplicable);
            }
            else {
                $("#chkAttendanceBonusApplicable").prop("checked", false);
            }


            if (data && data.DailyMonthly !== undefined && data.DailyMonthly !== null) {
                $("#txtDailyMonthly").val(data.DailyMonthly);
            } else {
                $("#txtDailyMonthly").val("");
            }


        }
    });
});




        $("#ddlToBranchId").on("change", function () {
            debugger
            $("#ddlShiftGroup").empty();
            $("#ddlShiftRule").empty();
          
            var ToBranchId = $("#ddlToBranchId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetShiftGroupOrRule", "Module_Employee_EmployeeTransfer_Premium")',
                data: { ToBranchId: ToBranchId },
                success: function (data) {

                    if (data && data.ShiftGroup) {
                        $("#ddlShiftGroup").append("<option value=''>--Select--</option>");
                     
                        $.each(data.ShiftGroup, function (i, p) {
                            $("#ddlShiftGroup").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }

                    if (data && data.ShiftRule) {
                        $("#ddlShiftRule").append("<option value=''>--Select--</option>");
                        $.each(data.ShiftRule, function (i, p) {
                            $("#ddlShiftRule").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            });
        });


    });
</script>

<script>

    $("#SaveEmployeeTransfer_Premium").validate({

        rules: {
            CmpId:
                {
                required: true,
                },
            BranchId:
                {
                required: true,
                },
            EmployeeId:
                {
                    required: true,
                },
            ToBranchId:{
                required:true,
            },
            TransferDate:
                {
                required:true,
            }


        },
        messages: {

            CmpId: {
                required: "Select the Company Name",
            },
            BranchId: {
                required: "Select the Buisness Unit",
            },
            EmployeeId: {
                required: "Select Employee Name",
            },
            ToBranchId:{
                required:"PleaseSelect Buisness Unit",
            },
            TransferDate:
             {
                 required:"select a Transfer Date",
             }

        },
        errorPlacement: function (error, element) {
            if (element.hasClass("select2-hidden-accessible")) {
                // Insert error after Select2's container
                error.insertAfter(element.next('.select2'));
            } else {
                error.insertAfter(element);
            }
        },

    });


    var form = $("#SaveEmployeeTransfer_Premium");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        form.valid();
        if (form.valid() == false) {
            return false;
        }
      //  $("#SaveEmployeeTransfer_Premium").submit();

        var EmployeeTransferId_Encrypted = $("#txtEmployeeTransferId_Encrypted").val();
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var EmployeeId=$("#ddlEmployeeId").val();
      

        $.ajax({
            url: '@Url.Action("IsExists", "Module_Employee_EmployeeTransfer_Premium")',
            method: "get",
            data:
                {
                    EmployeeTransferId_Encrypted: EmployeeTransferId_Encrypted,
                    CmpId:CmpId,
                    BranchId:BranchId,
                    EmployeeId:EmployeeId,
               
                },

            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: false
                        }).then(() => {
                            const p = Swal.getPopup();
                            p.classList.add('animate__headShake');
                            setTimeout(() => p.classList.remove('animate__headShake'), 500);
                        });
                    }
                }
                else
                {
                    debugger;
                    $("#SaveEmployeeTransfer_Premium").submit();
                }
            }
        });
    });
</script>