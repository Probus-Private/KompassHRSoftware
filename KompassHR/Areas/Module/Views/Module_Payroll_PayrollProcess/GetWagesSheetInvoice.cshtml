        // Prepare the print window
        var printWindow = window.open('', '', 'height=600,width=800');
        printWindow.document.write('<html><head><title>Print</title>');
        printWindow.document.write('<style>');
        // Set up A4 page size and portrait layout

        // Save the current body content
        const originalContent = document.body.innerHTML;

        // Set the body content to the cloned div content
        document.body.innerHTML = `
        <!DOCTYPE html>
        <html>
            <head>
                <title>Print</title>
                <style>
                    @@page {
                        size: A4 landscape;
                        margin: 10mm;
                    }
                    body {
                        font-family: Montserrat, sans-serif;
                        font-size: 12px;
                        margin: 0;
                        padding: 0;
                    }
                    table, th, td {
                        border: 1px solid black;
                        border-collapse: collapse;
                        padding: 5px;
                        text-align: center;
                    }
                    #tblInvoice {
                        width: 100%;
                    }
                    .thcmphead {
                        font-size: 14px;
                        font-weight: bold;
                    }
                </style>
            </head>
            <body>
                ${divPrint.innerHTML}
            </body>
        </html>
    `;

        // Trigger print
        window.print();

        // Restore the original body content
        document.body.innerHTML = originalContent;
    }

</script>

<script>
    function calculateColumnTotals() {
        // Get the table and its rows
        var table = document.getElementById("tblInvoice");
        var rows = table.getElementsByTagName("tbody")[0].getElementsByTagName("tr");
        var footerCells = table.getElementsByTagName("tfoot")[0].getElementsByClassName("sumTotal");

        // Initialize an array to store column totals
        var totals = new Array(footerCells.length).fill(0);

        // Loop through each row
        for (var i = 0; i < rows.length; i++) {
            var cells = rows[i].getElementsByTagName("td");

            // Loop through each cell (skip first two cells for SR.No and Employee details)
            for (var j = 2; j < cells.length; j++) {
                var cellValue = cells[j].innerText.trim().replace(/,/g, '');
                var value = parseFloat(cellValue) || 0;
                totals[j - 2] += value;
            }
        }

        // Insert the totals into the footer cells
        for (var k = 0; k < footerCells.length; k++) {
            footerCells[k].innerText = totals[k].toFixed(2);
        }
    }

    // Call the function on page load
    window.onload = calculateColumnTotals;
</script>
