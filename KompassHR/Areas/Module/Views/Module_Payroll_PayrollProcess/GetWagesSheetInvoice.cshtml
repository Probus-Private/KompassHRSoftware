@model KompassHR.Areas.Reports.Models.MonthWiseFilter
@{
    ViewBag.Title = "GetWagesSheetInvoice";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var Item = ViewBag.GetEmployeeDetails;
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    #tblInvoice {
        width: 100%;
        font-size: 11px;
        font-family: 'Arial', sans-serif;
        /*font-family: 'Montserrat', sans-serif;*/
    }

    .thcmphead {
        font-size: 14px;
        font-weight: bold;
    }
</style>

<style>
    /* Apply styles to the table container */
    .table-container {
        max-height: 500px; /* Set max height for vertical scrolling */
        overflow: auto; /* Enable both horizontal and vertical scrolling */
        border: 1px solid #ccc;
        padding: 0px;
    }

        /* Scrollbar customization for WebKit browsers (Chrome, Edge, Safari) */
        .table-container::-webkit-scrollbar {
            width: 10px; /* Thin vertical scrollbar */
            height: 10px; /* Thin horizontal scrollbar */
        }

        /* Scrollbar track */
        .table-container::-webkit-scrollbar-track {
            background: #f1f1f1; /* Light background */
            border-radius: 10px; /* Round shape */
        }

        /* Scrollbar handle */
        .table-container::-webkit-scrollbar-thumb {
            background: #888; /* Darker scrollbar */
            border-radius: 10px; /* Rounded edges */
        }

            /* On hover */
            .table-container::-webkit-scrollbar-thumb:hover {
                background: #555; /* Darker on hover */
            }

    /* For Firefox */
    .table-container {
        scrollbar-width: thin; /* Small scrollbar */
        scrollbar-color: #888 #f1f1f1; /* Thumb and track color */
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Wage Sheet - Print
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li class="breadcrumb-item active" id="backButton">
                    <a href="#">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Wage Sheet</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Wage Sheet - Print
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <div class="invoice">
                                <div class="invoice-company mb-3">
                                </div>
                                <form class="form">
                                    <div class="invoice-content">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="table-scroll div1">
                                                    <div class="table-wrap">
                                                        <div class="d-flex justify-content-end align-items-center mb-3 gap-3 flex-wrap">

                                                            <a href="@Url.Action("ExportToExcel", "Module_Payroll_PayrollProcess")"
                                                               class="btn btn-success btn-sm"
                                                               hidden>
                                                                Export to Excel
                                                            </a>

                                                            <div class="d-flex align-items-center">
                                                                <label for="pageSize" class="form-label me-2 mb-0 fs-6 fw-semibold" style="min-width: 60px;">Page Size:</label>
                                                                <select id="pageSize" class="form-select form-select-sm fs-6" style="min-width: 220px;">
                                                                    <!-- ISO A series Landscape -->
                                                                    <option value="A0 landscape">A0 Landscape</option>
                                                                    <option value="A1 landscape">A1 Landscape</option>
                                                                    <option value="A2 landscape">A2 Landscape</option>
                                                                    <option value="A3 landscape">A3 Landscape</option>
                                                                    <option value="A4 landscape" selected>A4 Landscape</option>
                                                                    <option value="A5 landscape">A5 Landscape</option>
                                                                    <option value="A6 landscape">A6 Landscape</option>
                                                                    <option value="A7 landscape">A7 Landscape</option>
                                                                    <option value="A8 landscape">A8 Landscape</option>
                                                                    <option value="A9 landscape">A9 Landscape</option>
                                                                    <option value="A10 landscape">A10 Landscape</option>

                                                                    <!-- North American Sizes - Landscape -->
                                                                    <option value="Letter landscape">Letter Landscape</option>
                                                                    <option value="Legal landscape">Legal Landscape</option>
                                                                    <option value="Tabloid landscape">Tabloid Landscape</option>
                                                                    <option value="Ledger landscape">Ledger Landscape</option>
                                                                </select>
                                                            </div>

                                                            <button onclick="printInvoice('divPrint')" class="btn btn-primary btn-sm">
                                                                <i class="fa-solid fa-print me-1"></i> Print
                                                            </button>
                                                        </div>

                                                        <br />
                                                        <style>
                                                            @@media print {
                                                                @@page {
                                                                    size: A4 landscape; /* Landscape Mode */
                                                                    margin: 10mm;
                                                                }

                                                                body {
                                                                    font-family: Arial, sans-serif;
                                                                }

                                                                #tblInvoice {
                                                                    width: 100%;
                                                                    font-size: 12px;
                                                                    font-family: 'Arial', sans-serif;
                                                                    /*font-family: 'Montserrat', sans-serif;*/
                                                                }
                                                            }

                                                            tbody {
                                                                width: 300px;
                                                                height: 200px; /* Set height for scroll */
                                                                overflow-y: auto; /* Enable vertical scrollbar */
                                                                border: 1px solid black;
                                                            }

                                                            table {
                                                                width: 100%;
                                                                border-collapse: collapse;
                                                            }

                                                            th, td {
                                                                border: 1px solid black;
                                                                padding: 8px;
                                                                text-align: left;
                                                            }

                                                            thead {
                                                                position: sticky;
                                                                top: 0;
                                                                background: #f1f1f1; /* Sticky header background */
                                                            }

                                                            .thead-fixed th {
                                                                position: sticky;
                                                                top: 0;
                                                                background: white;
                                                                z-index: 10;
                                                            }
                                                        </style>
                                                        <div class="invoice-container">
                                                            <div class="table-container" id="divPrint">
                                                                @{
                                                                    var firstRow = ((IEnumerable<dynamic>)ViewBag.Payroll_WageSheet)?.FirstOrDefault();
                                                                    var headers = firstRow != null
                                                                        ? ((IDictionary<string, object>)firstRow)
                                                                            .Where(x => x.Value != null)
                                                                            .Select(x => x.Key)
                                                                            .ToList()
                                                                        : new List<string>();

                                                                    // Earn + Rate mapping (columnPairs remains same)
                                                                    var columnPairs = new Dictionary<string, string>
                                                                    {
                                                                        { "SalaryEarn_RatePartA_Basic", "RatePartA_Basic" },
                                                                        { "SalaryEarn_RatePartA_DA", "RatePartA_DA" },
                                                                        { "SalaryEarn_RatePartA_HRA", "RatePartA_HRA" },
                                                                        { "SalaryEarn_RatePartA_A", "RatePartA_A" },
                                                                        { "SalaryEarn_RatePartA_C", "RatePartA_C" },
                                                                        { "SalaryEarn_RatePartA_B", "RatePartA_B" },
                                                                        { "SalaryEarn_RatePartA_F", "RatePartA_F" },
                                                                        { "SalaryEarn_RatePartA_D", "RatePartA_D" },
                                                                        { "SalaryEarn_RatePartM_A", "RatePartM_A" },
                                                                        { "SalaryEarn_RatePartA_E", "RatePartA_E" },

                                                                        { "SalaryEarn_RatePartA_G", "RatePartA_G" },
                                                                        { "SalaryEarn_RatePartA_H", "RatePartA_H" },
                                                                        { "SalaryEarn_RatePartA_I", "RatePartA_I" },
                                                                        { "SalaryEarn_RatePartA_J", "RatePartA_J" },
                                                                        { "SalaryEarn_RatePartA_K", "RatePartA_K" },
                                                                        { "SalaryEarn_RatePartA_L", "RatePartA_L" },
                                                                        { "SalaryEarn_RatePartA_M", "RatePartA_M" },
                                                                        { "SalaryEarn_RatePartA_N", "RatePartA_N" },
                                                                        { "SalaryEarn_RatePartA_O", "RatePartA_O" },
                                                                        { "SalaryEarn_RatePartA_P", "RatePartA_P" },
                                                                        { "SalaryEarn_RatePartA_Q", "RatePartA_Q" },
                                                                        { "SalaryEarn_RatePartA_R", "RatePartA_R" },
                                                                        { "SalaryEarn_RatePartA_S", "RatePartA_S" },
                                                                        { "SalaryEarn_RatePartA_T", "RatePartA_T" },

                                                                        { "SalaryEarn_OTAmt", "Prod Inc" },
                                                                        { "SalaryTotalGross", "TOT Earn" },
                                                                        { "SalaryDed_PTAmt", "P.T" },
                                                                        { "SalaryDed_ESICAmt", "ESI" },
                                                                        { "SalaryDed_PFAmt", "EPF" },
                                                                        { "SalaryDed_Advance", "Sal.Adv." },
                                                                        { "SalaryDed_TDS", "IT" },
                                                                        { "SalaryDed_Medical", "MEDI" }
                                                                    };

                                                                    // Dynamic display map from ViewBag.GetMapHeadName
                                                                    var displayMap = new Dictionary<string, string>();
                                                                    foreach (var col in columnPairs.Keys)
                                                                    {
                                                                        if (ViewBag.GetMapHeadName != null)
                                                                        {
                                                                            var mapHead = ((IDictionary<string, object>)ViewBag.GetMapHeadName);
                                                                            if (mapHead.ContainsKey(columnPairs[col]))
                                                                            {
                                                                                displayMap[col] = mapHead[columnPairs[col]]?.ToString() ?? col;
                                                                            }
                                                                            else
                                                                            {
                                                                                displayMap[col] = col; // fallback to column name
                                                                            }
                                                                        }
                                                                        else
                                                                        {
                                                                            displayMap[col] = col; // fallback if ViewBag is null
                                                                        }
                                                                    }

                                                                    // Active columns only (check IsApplicable as well)
                                                                    //var activeColumns = columnPairs
                                                                    //    .Where(cp => headers.Contains(cp.Key))   // Column exists in WageSheet
                                                                    //    .Where(cp =>
                                                                    //    {
                                                                    //        if (ViewBag.GetMapHeadName != null)
                                                                    //        {
                                                                    //            var mapHead = (IDictionary<string, object>)ViewBag.GetMapHeadName;

                                                                    //            var applicableKey = cp.Value + "_IsApplicable"; // Example: RatePartA_Basic_IsApplicable

                                                                    //             if (mapHead.ContainsKey(applicableKey))
                                                                    //            {
                                                                    //                return Convert.ToBoolean(mapHead[applicableKey]);
                                                                    //            }
                                                                    //        }
                                                                    //        return false; // If not found — do NOT show
                                                                    //    })
                                                                    //    .Select(cp => cp.Key)
                                                                    //    .ToList();

                                                                    var activeColumns = columnPairs
                                                                        .Where(cp => headers.Contains(cp.Key))
                                                                        .Select(cp => cp.Key)
                                                                        .ToList();

                                                                    // Totals dictionary
                                                                    var totals = new Dictionary<string, decimal>
                                                                    {
                                                                        ["AttenMonthlyPP"] = 0,
                                                                        ["AttenMonthlyWO"] = 0,
                                                                        ["AttenMonthlyEL"] = 0,
                                                                        ["AttenMonthlyPayableDays"] = 0,
                                                                        ["SalaryTotalDeduction"] = 0,
                                                                        ["SalaryNetPay"] = 0
                                                                    };
                                                                    foreach (var col in activeColumns)
                                                                    {
                                                                        totals[col] = 0;
                                                                        totals[columnPairs[col]] = 0;
                                                                    }
                                                                }
                                                                <table class="table table-bordered table-hover mb-0 text-dark align-middle" id="tblInvoice">
                                                                    <thead>
                                                                        <tr class="trheading">
                                                                            <th rowspan="2">SR.No</th>
                                                                            <th rowspan="2">Employee Name</th>
                                                                            <th rowspan="2">WD</th>
                                                                            <th rowspan="2">WO</th>
                                                                            <th rowspan="2">EL</th>
                                                                            <th rowspan="2">Ph Days</th>

                                                                            @foreach (var col in activeColumns)
                                                                            {
                                                                                <th class="text-center">@displayMap[col]</th>
                                                                            }

                                                                            <th rowspan="2">Total Dedu.</th>
                                                                            <th rowspan="2">Net Pay</th>
                                                                            <th rowspan="2">Employee Signature</th>
                                                                        </tr>
                                                                        <tr class="trheading">
                                                                            @foreach (var col in activeColumns)
                                                                            {
                                                                                <th class="text-center">@displayMap[col] Rt.</th>
                                                                            }
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @{
                                                                            int SrNo = 0;
                                                                        }
                                                                        @foreach (var d in ViewBag.Payroll_WageSheet)
                                                                        {
                                                                            var row = (IDictionary<string, object>)d;
                                                                            <tr>
                                                                                <td class="text-center">@(++SrNo)</td>
                                                                                <td>@row["SalaryEmployeeName"] <br /> @row["SalaryEmployeeNo"] / @row["SalaryDesignation"]</td>
                                                                                <td style="text-align:right">
                                                                                    @row["AttenMonthlyPP"] <br /> 0
                                                                                    @{ totals["AttenMonthlyPP"] += row["AttenMonthlyPP"] != null ? Convert.ToDecimal(row["AttenMonthlyPP"]) : 0; }
                                                                                </td>
                                                                                <td style="text-align:right">
                                                                                    @row["AttenMonthlyWO"] <br /> @row["AttenMonthlyPH"]
                                                                                    @{ totals["AttenMonthlyWO"] += row["AttenMonthlyWO"] != null ? Convert.ToDecimal(row["AttenMonthlyWO"]) : 0; }
                                                                                </td>
                                                                                <td style="text-align:right">
                                                                                    @row["AttenMonthlyEL"] <br /> @row["AttenMonthlyCO"]
                                                                                    @{ totals["AttenMonthlyEL"] += row["AttenMonthlyEL"] != null ? Convert.ToDecimal(row["AttenMonthlyEL"]) : 0; }
                                                                                </td>
                                                                                <td style="text-align:right">
                                                                                    @row["AttenMonthlyPayableDays"]
                                                                                    @{ totals["AttenMonthlyPayableDays"] += row["AttenMonthlyPayableDays"] != null ? Convert.ToDecimal(row["AttenMonthlyPayableDays"]) : 0; }
                                                                                </td>

                                                                                @foreach (var col in activeColumns)
                                                                                {
                                                                                    var rateCol = columnPairs[col];
                                                                                    decimal earnVal = row[col] != null ? Convert.ToDecimal(row[col]) : 0;
                                                                                    decimal rateVal = row.ContainsKey(rateCol) && row[rateCol] != null ? Convert.ToDecimal(row[rateCol]) : 0;

                                                                                    totals[col] += earnVal;
                                                                                    totals[rateCol] += rateVal;

                                                                                    <td style="text-align:right">
                                                                                        @earnVal <br /> @rateVal
                                                                                    </td>
                                                                                }

                                                                                <td style="text-align:right;vertical-align: middle;">@row["SalaryTotalDeduction"]</td>
                                                                                <td style="text-align:right;vertical-align: middle;">@row["SalaryNetPay"]</td>
                                                                                <td></td>

                                                                                @{ totals["SalaryTotalDeduction"] += row["SalaryTotalDeduction"] != null ? Convert.ToDecimal(row["SalaryTotalDeduction"]) : 0;
                                                                                    totals["SalaryNetPay"] += row["SalaryNetPay"] != null ? Convert.ToDecimal(row["SalaryNetPay"]) : 0; }
                                                                            </tr>
                                                                                    }
                                                                    </tbody>
                                                                    <tfoot>
                                                                        <tr class="trheading">
                                                                            <th colspan="2" style="text-align:right;">Total:</th>
                                                                            <th class="text-right">@totals["AttenMonthlyPP"]</th>
                                                                            <th class="text-right">@totals["AttenMonthlyWO"]</th>
                                                                            <th class="text-right">@totals["AttenMonthlyEL"]</th>
                                                                            <th class="text-right">@totals["AttenMonthlyPayableDays"]</th>

                                                                            @foreach (var col in activeColumns)
                                                                            {
                                                                                var rateCol = columnPairs[col];
                                                                                <th class="text-right">
                                                                                    @totals[col] <br /> @totals[rateCol]
                                                                                </th>
                                                                            }

                                                                            <th class="text-right">@totals["SalaryTotalDeduction"]</th>
                                                                            <th class="text-right">@totals["SalaryNetPay"]</th>
                                                                            <th></th>
                                                                        </tr>
                                                                        <tr class="tfootMakerCheker">
                                                                            <th class="text-Left" colspan="28" style="background-color:white!important"><strong>Maker Name :</strong>  @TempData["MakerName"] &nbsp;&nbsp; And &nbsp;&nbsp;  <strong> Checker Name : </strong> @TempData["CheckerName"]</th>
                                                                        </tr>
                                                                    </tfoot>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $('#tblInvoice tfoot .sumTotal').each(function (index) {
        let total = 0;
        $('#tblInvoice tbody tr').each(function () {
            let value = parseFloat($(this).find('td.sumColumn').eq(index).text()) || 0;
            total += value;
        });
        $(this).text(total.toFixed(2));
    });
</script>

<script>
    function printInvoice() {
        event.preventDefault();
        const pageSize = document.getElementById('pageSize').value;
        const divPrint = document.getElementById('divPrint').cloneNode(true); // Clone content
        const table = divPrint.querySelector('table#tblInvoice');
        if (!table) {
            console.error('Table with ID "tblInvoice" not found.');
            return;
        }

        // Create an invisible iframe
        const iframe = document.createElement('iframe');
        iframe.style.position = 'absolute';
        iframe.style.width = '0px';
        iframe.style.height = '0px';
        iframe.style.border = 'none';
        document.body.appendChild(iframe);

        const iframeDoc = iframe.contentWindow.document;
        iframeDoc.open();
        iframeDoc.write(`
        <html>
            <head>
                <title>Print</title>
                <style>
                @@page { size: ${pageSize}; margin: 10mm; }
                    body { font-family: Arial, sans-serif; font-size: 12px; margin: 0; padding: 0; }
                    table, th, td { border: 1px solid black; border-collapse: collapse; padding: 5px; text-align: center; }
                    #tblInvoice { font-family: Montserrat, sans-serif; font-size: 12px; }
                    .thcmphead { font-size: 20px; font-weight: bold; }
                </style>
            </head>
            <body>
                ${divPrint.innerHTML}
            </body>
        </html>
    `);
        iframeDoc.close();

        // Print using iframe
        iframe.contentWindow.focus();
        iframe.contentWindow.print();

        // Remove iframe after printing to prevent memory leaks
        iframe.contentWindow.onafterprint = () => document.body.removeChild(iframe);

        // Delay removal of iframe to avoid page reload
        iframe.contentWindow.onafterprint = () => {
            setTimeout(() => {
                document.body.removeChild(iframe);
            }, 500);
        };
    }

