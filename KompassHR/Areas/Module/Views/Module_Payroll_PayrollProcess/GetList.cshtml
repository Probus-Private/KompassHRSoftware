<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Payroll Process
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_Menu", "Module_Payroll_Menu", new {id = 6, ScreenId=159, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Payroll Process - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of payroll Process created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action="@Url.Action("GetList", "Module_Payroll_PayrollProcess")" id="SaveMonthlyAttendance">
                        <div class="row">
                            <div class="col-md-2">
                                <a href="@Url.Action("Module_Payroll_PayrollProcess", "Module_Payroll_PayrollProcess", new { area = "Module" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                            </div>
                            <div class="col-md-8">
                                <div class="row mb-15px">
                                    <label class="form-label col-form-label col-md-2">
                                        Month/Year
                                        <span class="important">*</span>
                                    </label>
                                    <div class="col-md-4">
                                        @Html.TextBoxFor(model => model.Month, new { id = "txtMonth", @class = "form-control", name = "Month", type = "month" })
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" id="btnshow" onclick="showList()" class="btn btn-success btn-sm  mb-10px">
                                            <i class="fa-solid fa-eye"></i> &nbsp; Show
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </form>

                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <table class="table table-bordered align-middle TablePage" id="fixed-header" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th class="text-nowrap">Pending List </th>
                                        <th class="text-nowrap">Approve List </th>
                                        <th class="text-nowrap">Reject List </th>
                                        <th class="text-nowrap">Export </th>
                                        <th hidden class="text-nowrap">Print </th>
                                        <th class="text-nowrap">Company Name </th>
                                        <th class="text-nowrap">Business Unit</th>
                                        <th class="text-nowrap">Month Year</th>
                                        <th class="text-nowrap">Employee Count </th>
                                        <th class="text-nowrap"> Salary Net Pay </th>
                                        <th class="text-nowrap"> Process Category Name </th>
                                        <th class="text-nowrap" hidden>SalaryProcessCategoryId</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ViewBag.GetMonthlyAttendance)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <a id="btnshow" class="pending-btn" onclick="SalaryEmployee('@d.SalaryBranchId' ,'@d.SalaryMonthYear','@d.SalaryProcessCategoryId')" style="cursor:pointer;">
                                                    <i class="fa-solid fa-check-double"></i>
                                                    <span>Pending</span>
                                                    <span class="doodle">@d.PendingCount</span>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <a id="btnApproveList" onclick="ApproveSalaryEmployee('@d.SalaryBranchId','@d.SalaryMonthYear','@d.SalaryProcessCategoryId')"
                                                   class="approve-btn" title="Approve">
                                                    <i class="fa-solid fa-circle-check"></i>
                                                    <span>Approve</span>
                                                    <span class="doodle">@d.ApprovedCount</span>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <a id="btnRejectList" onclick="RejectSalaryEmployee('@d.SalaryBranchId','@d.SalaryMonthYear','@d.SalaryProcessCategoryId')"
                                                   class="reject-btn" title="Reject">
                                                    <i class="fa-solid fa-circle-xmark"></i>
                                                    <span>Reject</span>
                                                    <span class="doodle">@d.RejectedCount</span>
                                                </a>
                                            </td>
                                            <td class="text-center">
                                                <a id="btnshow" onclick="downloadExcelFile('@d.SalaryBranchId' ,'@d.SalaryMonthYear','@d.SalaryCmpId','@d.SalaryProcessCategoryId')" style="cursor:pointer;">
                                                    <i class="fa-solid fa-download fa-lg text-primary" style="margin-top: 16px"></i>
                                                </a>
                                            </td>
                                            <td hidden class="text-center">
                                                <a id="btnshow" onclick="GetInvoice('@d.SalaryBranchId' ,'@d.SalaryMonthYear','@d.SalaryCmpId')" style="cursor:pointer;">
                                                    <i class="fas fa-file-invoice fa-xl" style="color: #4CAF50"></i>
                                                    @*<i class="fa-solid fa-solid fa-eye fa-lg text-danger"></i>*@
                                                </a>
                                            </td>
                                            <td class="align-middle">@d.ShortName</td>
                                            <td class="align-middle">@d.BranchName</td>
                                            <td class="align-middle">@d.MonthYear</td>
                                            <td class="align-middle text-end">@d.EmployeeCount</td>
                                            <td class="align-middle text-end">@d.SalaryNetPay</td>
                                            <td class="align-middle">@d.ProcessCategoryName</td>
                                            <td hidden>@d.SalaryProcessCategoryId</td>
                                            
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- END panel -->
</div>

<!-- #Start modal-dialog -->
<div class="modal fade" id="myEmployeeSalary" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Payroll Salary - List</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="row">
                                    <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass" style="width: 100%;" id="tblEmployeeHistoryHead">
                                        <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th class="text-nowrap text-center">All <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                                <th hidden class="text-nowrap">SalaryID </th>
                                                <th hidden class="text-nowrap">EmployeeId </th>
                                                <th class="text-nowrap">Business Unit</th>
                                                <th class="text-nowrap">Employee No </th>
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Payable Days </th>
                                                <th class="text-nowrap">OT Hrs </th>
                                                <th class="text-nowrap">Gross Pay </th>
                                                <th class="text-nowrap">Salary Net Pay </th>
                                                <th class="text-nowrap">Salary CTC</th>
                                                <th hidden class="text-nowrap">SalaryCheckerStatus</th>
                                                <th class="text-nowrap">ProcessCategoryName</th>
                                                <th class="text-nowrap">Approved/Reject By</th>
                                                <th class="text-nowrap">Approved/Reject Date</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblBodyEmployeeSalary"></tbody>
                                        </table>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnEmployeeSubmit" onclick="funSave()"
                            class="btn btn-danger btn-sm">
                        <i class="fa-solid fa-trash-alt"></i> Delete
                    </button>
                    <button type="button" class="btn btn-primary btnpress btn-sm CloseModelHistory" id="CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true">
                        <i class="fa-solid fa-share-from-square"></i> Close
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- #End modal-dialog -->


    <script>
        $(document).ready(function () {
            var Message = @Html.Raw(Json.Encode(TempData["Message"]));
            var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
            debugger;
            if (Message != null) {
                if (Message != null) {
                    Swal.fire({
                        icon: Icon,
                        text: Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    }).then(function() {
                        window.location.reload();
                    });
                }
            }
            var GetMonth = @Html.Raw(Json.Encode(TempData["MonthYear"]));
            if(GetMonth =="" || GetMonth == null)
            {
                var today = new Date();
                // Format the date as YYYY-MM (year-month)
                var yyyy = today.getFullYear();
                var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
                var defaultMonth = yyyy + '-' + mm;
                // Set the value of the input element to the default month
                var CheckEmptyDate = document.getElementById('txtMonth').value;
                if (CheckEmptyDate == "") {
                    document.getElementById('txtMonth').value = defaultMonth;
                }
            }
            else
            {
                $("#txtMonth").val(GetMonth);
            }

            $('#myEmployeeSalary').on('shown.bs.modal', function () {
                var table = $('.TabledataBulkClass').DataTable();

                if ($.fn.DataTable.isDataTable('.TabledataBulkClass')) {
                    table.destroy();
                }

                $('.TabledataBulkClass').DataTable({
                    scrollY: 400,
                    scrollCollapse: true,
                    paging: false,
                    scrollX: true,
                    searching: true,
                    stripeClasses: []
                });
            });
        });//ready function


        function checkAll(ele) {
            var checkboxes = document.getElementsByTagName('input');
            if (ele.checked) {
                for (var i = 0; i < checkboxes.length; i++) {
                    if (checkboxes[i].type == 'checkbox') {
                        checkboxes[i].checked = true;
                    }
                }
            } else {
                for (var i = 0; i < checkboxes.length; i++) {
                    console.log(i)
                    if (checkboxes[i].type == 'checkbox') {
                        checkboxes[i].checked = false;
                    }
                }
            }
        }

        function showList() {
            $("#SaveMonthlyAttendance").submit();
        }
    </script>

    <script>
        function SalaryEmployee(SalaryBranchId, SalaryMonthYear,SalaryProcessCategoryId) {
            $('#SelectAll').prop('hidden', false); // or $('#SelectAll').hide();

            var status= "Pending";
            $.ajax({
                type: "GET",
                url: '@Url.Action("GetSalary", "Module_Payroll_PayrollProcess")',
                data: { SalaryBranchId, SalaryMonthYear,status,SalaryProcessCategoryId },
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    const data = JSON.parse(response);
                    const modal = $('#myEmployeeSalary');
                    const tableBody = $('#tblBodyEmployeeSalary');

                    // Clear table body (except headers)
                    if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                        $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                    }

                    modal.modal(data.length > 0 ? 'show' : 'hide');
                    // tableBody.html(''); // Clear existing rows
                    if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                        $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                    }
                    if (data) {
                        debugger;
                        let convertedData = {};

                        // Flatten the original data
                        Object.keys(data).forEach(key => {
                            let flatObject = {};
                            data[key].forEach(item => {
                                flatObject[item.Key] = item.Value;
                            });
                            convertedData[key] = flatObject;
                        });

                        debugger;

                        // Clear table body first (important if appending dynamically multiple times)
                        $('#tblBodyEmployeeSalary').empty();

                        // Loop over the converted object
                        Object.values(convertedData).forEach(item => {
                            let row = `<tr>
                                    <td><center><input type="checkbox" class="form-check-input" /></center></td>
                                    <td hidden class="text-nowrap">${item.SalaryID || ''}</td>
                                    <td hidden class="text-nowrap">${item.SalaryEmployeeId || ''}</td>
                                    <td class="text-nowrap">${item.BranchName || ''}</td>
                                    <td class="text-nowrap">${item.EmployeeNo || ''}</td>
                                    <td class="text-nowrap">${item.EmployeeName || ''}</td>
                                    <td class="text-nowrap text-end">${item.PayableDays || '0'}</td>
                                    <td class="text-nowrap text-end">${item.SalaryOTHrs || '0'}</td>
                                    <td class="text-nowrap text-end">${item.SalaryTotalGross || '0'}</td>
                                    <td class="text-nowrap text-end">${item.SalaryNetPay || '0'}</td>
                                    <td class="text-nowrap text-end">${item.SalaryCTC || '0'}</td>
                                    <td hidden class="text-nowrap ">${item.SalaryCheckerStatus || ''}</td>
                                    <td class="text-nowrap">${item.ProcessCategoryName || ''}</td>
                                    <td class="text-nowrap">${item.ApprovedBy || ''}</td>
                                    <td class="text-nowrap">${item.SalaryCheckerApprovedDate || ''}</td>
                                      </tr>`;

                            $('#tblBodyEmployeeSalary').append(row);
                        });

                    } else {
                        modal.modal('hide');
                    }
                }
            });
        }


        function ApproveSalaryEmployee(SalaryBranchId, SalaryMonthYear,SalaryProcessCategoryId) {
            $('#SelectAll').prop('hidden', true); // or $('#SelectAll').hide();

            var status="Approved";
            $.ajax({
                type: "GET",
                url: '@Url.Action("GetSalary", "Module_Payroll_PayrollProcess")',
                data: { SalaryBranchId, SalaryMonthYear,status ,SalaryProcessCategoryId},
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    const data = JSON.parse(response);
                    const modal = $('#myEmployeeSalary');
                    const tableBody = $('#tblBodyEmployeeSalary');

                    // Clear table body (except headers)
                    if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                        $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                    }

                    modal.modal(data.length > 0 ? 'show' : 'hide');
                    // tableBody.html(''); // Clear existing rows
                    if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                        $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                    }
                    if (data) {
                        debugger;
                        let convertedData = {};

                        // Flatten the original data
                        Object.keys(data).forEach(key => {
                            let flatObject = {};
                            data[key].forEach(item => {
                                flatObject[item.Key] = item.Value;
                            });
                            convertedData[key] = flatObject;
                        });

                        debugger;

                        // Clear table body first (important if appending dynamically multiple times)
                        $('#tblBodyEmployeeSalary').empty();

                        // Loop over the converted object
                        Object.values(convertedData).forEach(item => {
                            let statusCol = '';

                            if (item.SalaryCheckerStatus === "Approved") {
                                statusCol = `<td><center><span class="text-success fw-bold">Approved</span></center></td>`;
                            }  else {
                                statusCol = `<td><center><input type="checkbox" class="form-check-input" /></center></td>`;
                            }

                            let row = `<tr>
                        ${statusCol}
                        <td hidden class="text-nowrap">${item.SalaryID || ''}</td>
                        <td hidden class="text-nowrap">${item.SalaryEmployeeId || ''}</td>
                        <td class="text-nowrap">${item.BranchName || ''}</td>
                        <td class="text-nowrap">${item.EmployeeNo || ''}</td>
                        <td class="text-nowrap">${item.EmployeeName || ''}</td>
                        <td class="text-nowrap text-end">${item.PayableDays || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryOTHrs || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryTotalGross || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryNetPay || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryCTC || '0'}</td>
                        <td hidden class="text-nowrap">${item.SalaryCheckerStatus || ''}</td>
                        <td class="text-nowrap">${item.ProcessCategoryName || '0'}</td>
                        <td class="text-nowrap">${item.ApprovedBy || ''}</td>
                        <td class="text-nowrap">${item.SalaryCheckerApprovedDate || ''}</td>
                    </tr>`;

                            $('#tblBodyEmployeeSalary').append(row);
                        });

                    } else {
                        modal.modal('hide');
                    }
                }
            });
        }

        function RejectSalaryEmployee(SalaryBranchId, SalaryMonthYear,SalaryProcessCategoryId) {
            $('#SelectAll').prop('hidden', false); // or $('#SelectAll').hide();

            var status="Rejected";
            $.ajax({
                type: "GET",
                url: '@Url.Action("GetSalary", "Module_Payroll_PayrollProcess")',
                data: { SalaryBranchId, SalaryMonthYear,status,SalaryProcessCategoryId },
                contentType: "application/json; charset=utf-8",
                dataType: "text",
                success: function (response) {
                    debugger;
                    const data = JSON.parse(response);
                    const modal = $('#myEmployeeSalary');
                    const tableBody = $('#tblBodyEmployeeSalary');

                    // Clear table body (except headers)
                    if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                        $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                    }

                    modal.modal(data.length > 0 ? 'show' : 'hide');
                    // tableBody.html(''); // Clear existing rows
                    if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                        $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                    }
                    if (data) {
                        debugger;
                        let convertedData = {};

                        // Flatten the original data
                        Object.keys(data).forEach(key => {
                            let flatObject = {};
                            data[key].forEach(item => {
                                flatObject[item.Key] = item.Value;
                            });
                            convertedData[key] = flatObject;
                        });

                        debugger;

                        // Clear table body first (important if appending dynamically multiple times)
                        $('#tblBodyEmployeeSalary').empty();

                        // Loop over the converted object
                        Object.values(convertedData).forEach(item => {
                            let row = `<tr>
                        <td><center><input type="checkbox" class="form-check-input" /></center></td>
                        <td hidden class="text-nowrap">${item.SalaryID || ''}</td>
                        <td hidden class="text-nowrap">${item.SalaryEmployeeId || ''}</td>
                        <td class="text-nowrap">${item.BranchName || ''}</td>
                        <td class="text-nowrap">${item.EmployeeNo || ''}</td>
                        <td class="text-nowrap">${item.EmployeeName || ''}</td>
                        <td class="text-nowrap text-end">${item.PayableDays || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryOTHrs || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryTotalGross || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryNetPay || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryCTC || '0'}</td>
                        <td hidden class="text-nowrap">${item.SalaryCheckerStatus || ''}</td>
                        <td class="text-nowrap">${item.ProcessCategoryName || ''}</td>
                        <td class="text-nowrap">${item.ApprovedBy || ''}</td>
                        <td class="text-nowrap">${item.SalaryCheckerApprovedDate || ''}</td>
                    </tr>`;

                            $('#tblBodyEmployeeSalary').append(row);
                        });

                    } else {
                        modal.modal('hide');
                    }
                }
            });
        }

        function downloadExcelFile(AttenMonthlyBranchId, AttenMonthlyMonthYear,SalaryCmpId,ProcessCategoryId) {
            $(".Userloaderbg").css("display", "flex");
            var txtMonth= $("#txtMonth").val();
            var BranchId = encodeURIComponent(AttenMonthlyBranchId);
            var MonthYear = encodeURIComponent(AttenMonthlyMonthYear);
            var url = `@Url.Action("DownloadExcelFile", "Module_Payroll_PayrollProcess")?BranchId=${BranchId}&MonthYear=${MonthYear}&SalaryCmpId=${SalaryCmpId}&ProcessCategoryId=${ProcessCategoryId}`;
            $.ajax({
                url: url,
                method: 'GET',
                xhrFields: {
                    responseType: 'blob' // Set the response type to blob
                },
                success: function(data) {
                    debugger;
                    $(".Userloaderbg").css("display", "none");
                    if(data.size==0)
                    {
                        Swal.fire({
                            icon: 'error',
                            text: 'Record Not Found',
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                                return false
                            }
                        });
                        $(".Userloaderbg").css("display", "none");
                        return false;
                    }
                    var formattedDate = convertMonthYearFormat(txtMonth);
                    var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                    var anchorElement = document.createElement('a');
                    var url = window.URL.createObjectURL(blob);
                    anchorElement.href = url;
                    anchorElement.download = 'PayrollWageSheet('+formattedDate+').xlsx';
                    anchorElement.click();
                    window.URL.revokeObjectURL(url);
                },
                error: function(xhr, status, error) {
                    console.error('Error downloading file:', error);
                }
            });
        }


        function GetInvoice(SalaryBranchId,SalaryMonthYear,SalaryCmpId)
        {
            var BranchId = encodeURIComponent(SalaryBranchId);
            var MonthYear = encodeURIComponent(SalaryMonthYear);
            var url = '@Url.Action("GetWagesSheetInvoice", "Module_Payroll_PayrollProcess")?BranchId=' + BranchId+'&MonthYear='+MonthYear + '&SalaryCmpId='+SalaryCmpId ;
            window.location.href = url;
        }
