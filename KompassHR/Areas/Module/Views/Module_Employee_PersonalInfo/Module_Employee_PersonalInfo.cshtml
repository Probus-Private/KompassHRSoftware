<script>

    function clearAadharModal() {
        // Clear input fields
        $('#AadharModel input[type="text"]').val('');
        $('#AadharModel input[type="checkbox"]').prop('checked', false);

        // Hide error messages
        $('.Error').hide();
        $('#ErrortxtAadharCaptchaInput').text('');

        // Hide OTP and footer sections
        $('#DivOTP').hide();
        $('#DivAadharFooter').hide();

        var table = document.getElementById("AadharTable");
        if (table) {
            var tbody = table.getElementsByTagName("tbody")[0];
            if (tbody) {
                // Remove all rows in tbody
                tbody.innerHTML = '';
            }
        }
        $('#AadharDetailsDiv').css("display", "none");
    }

    // Clear all fields in the PAN modal
    function clearPANModal() {
        // Clear input fields
        debugger;
        $('#PANModel input[type="text"]').val('');
        $('#PANModel input[type="checkbox"]').prop('checked', false);

        // Hide error messages
        $('.Error').hide();
        $('#error').hide();

        // Hide footer section
        $('#DivPANfooter').hide();

        var table = document.getElementById("PANTable");
        if (table) {
            var tbody = table.getElementsByTagName("tbody")[0];
            if (tbody) {
                // Remove all rows in tbody
                tbody.innerHTML = '';
            }
        }

        $('#PanDetailsDiv').css("display", "none");
    }

</script>

