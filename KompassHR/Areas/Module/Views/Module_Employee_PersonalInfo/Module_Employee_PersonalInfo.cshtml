<script>
    // Get TempData values from server-side
    const isAadhar = @(TempData["IsAadhar"]?.ToString().ToLower() ?? "false");
    const isPAN = @(TempData["IsPAN"]?.ToString().ToLower() ?? "false");

    // Function to show/hide buttons
    function toggleButtons() {
        document.getElementById('DivbtnAadhar').style.display = isAadhar ? 'block' : 'none';
        document.getElementById('DivbtnPAN').style.display = isPAN ? 'block' : 'none';
    }
    // Call function to hide/show buttons
    toggleButtons();
</script>

<script>
    $(".OnlyNumber").on("input", function() {
        // Remove any non-digit characters in real time.
        this.value = this.value.replace(/\D/g, '');
    });
    document.getElementById('ChkAadharDeclaration').addEventListener('change', function () {
        const label = document.getElementById('AadharDeclarationLabel');
        if (!this.checked) {
            label.classList.add('blink'); // Start blinking
            label.style.color = 'red';   // Change font color to red
        } else {
            label.classList.remove('blink'); // Stop blinking
            label.style.color = '';          // Reset font color
        }
    });

    const textbox1 = document.getElementById('txtAadharNo');
    const textbox2 = document.getElementById('txtAadharNo2');


    var AadharRefId="";
    function GetAadharOTP() {
        var aadharNo = $('#txtAadharNo').val();
        var aadharNo2 = $('#txtAadharNo2').val();
        if (!aadharNo) {
            $("#ErrortxtAadharNo").html("Enter aadhar number");
            $("#ErrortxtAadharNo").css("display", "flex");
            return false;
        }
        else
        {
            $("#ErrortxtAadharNo").html("");
            $("#ErrortxtAadharNo").css("display", "none");
        }

        if (!aadharNo2) {
            $("#ErrortxtAadharNo2").html("Re-Enter aadhar number");
            $("#ErrortxtAadharNo2").css("display", "flex");
            return false;
        }
        else
        {
            $("#ErrortxtAadharNo2").html("");
            $("#ErrortxtAadharNo2").css("display", "none");
        }

        if(aadharNo.length!=12)
        {
            $("#ErrortxtAadharNo").html("Enter 12 digit valid aadhar number");
            $("#ErrortxtAadharNo").css("display", "flex");
            return false;
        }
        else
        {
            $("#ErrortxtAadharNo").html("");
            $("#ErrortxtAadharNo").css("display", "none");
        }

        if(aadharNo2.length!=12)
        {
