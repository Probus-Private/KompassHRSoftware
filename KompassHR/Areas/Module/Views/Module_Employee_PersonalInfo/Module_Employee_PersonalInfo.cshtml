

@model KompassHR.Areas.Module.Models.Module_Employee.Mas_Employee_Personal
@{
    ViewBag.Title = "Module_Employee_PersonalInfo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<!-- Include Fontisto CSS from a CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fontisto/3.0.4/fontisto.min.css">
<script src="~/assets/js/CaptchaVerification.js"></script>

<style>
    .select2.select2-container {
        width: 100% !important;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }



    .box2 {
   

    text-align:center;
    position: relative;
    z-index: 0;
    margin-bottom: 10px;
  

    }
        .box2 .info {
       
            display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center; }

        .box2 .imgbx {
      width: 80px;
    height: 80px;
    padding:5px 0px;
    font-family:Open Sans,sans-serif;
          border: 1px solid #dedede;
    border-radius: 20px;
    box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.1);
    display:flex;
    justify-content:center;
    align-items:center;
        }

        /*.box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);
           
        }*/
        .box2 img {
             width: 50px;
    height: 50px;
    filter: brightness(1.2);
        }

            .box2:hover .info i {
                color: #ff9c19;
            }


        .box2 .info i {
           
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
           
            text-align: center;
            display: flex;
            justify-content: center;
  color:#000;
            text-transform: capitalize;
            margin-top: 5px;          
        }






    .div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }

    /*.div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }*/

    .fixed-side {
        position: sticky;
        left: 0px;
    }

    /*.fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .empbx h4 {
        margin-bottom: 5px;
    }

    .empbx h6 i {
        font-size: 1rem;
        margin-right: 5px;
    }

    .empbx {
        margin-bottom: 20px;
    }

    .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<style>
    .mainCaptcha {
        font-family: 'Courier New', Courier, monospace; /* or 'MyCaptchaFont', sans-serif */
        font-size: 20px;
        letter-spacing: 4px;
        transform: rotate(-2deg) skew(-5deg);
        text-shadow: 1px 1px 0 #fff;
        /* Remove background, border, and box-shadow */
        background: transparent;
        border: none;
        box-shadow: none;
        outline: none; /* removes focus outline */
        color: #333;
        padding: 1px;
    }
</style>

<style>
    .blink {
        animation: blinker 1s linear infinite;
    }

    @@keyframes blinker {
        50% {
            opacity: 0;
        }
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Personal Information
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new {id = 3, ScreenId=142, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">


                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@  Personal Information - @ViewBag.AddUpdateTitle</h4>
                    @*<div class="panel-heading-btn">
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                            <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                        </div>*@
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This includes the employee's full name, date of birth, gender, and employee identification number.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_PersonalInfo", new { area = "Module" })' id="SavePersonalInfromation" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="empbx">
                                            <span>
                                                <h4> <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"] </h4>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"] </h6>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"] </h6>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px" id="btnGet">
                                    <div class="col-md-6" style="width:fit-content;">
                                        <button type="button" id="btnGetPrebordingList" onclick="GetDetails('Pre')"
                                                class="btn btn-success btn-sm btnpress">
                                            <i class="fa-regular fa-copy"></i> Get
                                        </button>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title clearfix">
                                            Aadhar-Information
                                        </div>
                                    </div>
                                </div>


                                <div class="row" id="DivbtnAadhar">
                                    <div class="col-md-12">
                                        <div class="row mb-10px">
                                            <div class="col-md-12">
                                                <button type="button" class="btn btn-info btn-sm" style="padding: 2px 4px; margin:2px;" onclick="AadharVerify()">
                                                    Aadhar verify
                                                </button>
                                                <span style="color: #f6a835; font-weight: bold; margin-left: 10px;">
                                                    Click this button to verify your Aadhar number and confirm its validity.
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Aadhar No.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.AadhaarNo, new { @class = "form-control", @id = "AadhaarNo", Type = "text", name = "AadhaarNo", Maxlength = 12, autocomplete = "Off", onkeypress = "return isNumberKey(event)" })


                                                @Html.HiddenFor(model => model.PersonalId_Encrypted, new { id = "PersonalId_Encrypted" })
                                                @Html.HiddenFor(model => model.PersonalEmployeeId)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Name As Per
                                                Aadhar
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.NameAsPerAadhaar, new { @class = "form-control upper-text", name = "NameAsPerAadhaar", type = "text", id = "txtNameAsPerAadhaar", autocomplete = "Off", Maxlength = 70, oninput = "this.value = this.value.toUpperCase()" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="col-form-label"> </label>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.AadhaarNoMobileNoLink, new { id = "chkAadhaarNoMobileNoLink" })
                                                &nbsp; <label class="form-check-label form-label">
                                                    Mobile no.
                                                    link with Aadhar ?
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Aadhar Linked
                                                Mobile No.
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.AadhaarNoMobileNo, new { @class = "form-control", name = "AadhaarNoMobileNo", type = "text", id = "txtAadhaarNoMobileNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            PAN-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row" id="DivbtnPAN">
                                    <div class="col-md-12">
                                        <div class="row mb-10px">
                                            <div class="col-md-12">
                                                <button type="button" class="btn btn-info btn-sm" style="padding: 2px 4px; margin: 2px;" onclick="PANVerify()">
                                                    PAN verify
                                                </button>
                                                <span style="color: #f6a835; font-weight: bold; margin-left: 10px;">
                                                    Click this button to verify your PAN number and confirm its validity.
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                PAN
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PAN, new { @class = "form-control upper-text", name = "PAN", type = "text", id = "txtPAN", autocomplete = "Off", oninput = "this.value = this.value.toUpperCase()", Maxlength = 10 })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Name As Per PAN
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.NameAsPerPan, new { @class = "form-control upper-text", name = "NameAsPerPan", type = "text", id = "txtNameAsPerPan", autocomplete = "Off", Maxlength = 70, oninput = "this.value = this.value.toUpperCase()" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-6">
                                        <div class="row">
                                            <label class="col-form-label"> </label>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.PANAadhaarLink, new { id = "chkPANAadhaarLink" })
                                                &nbsp; <label class="form-check-label form-label">
                                                    PAN link with
                                                    Aadhar ?
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Contact-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Primary Moblie
                                                No.
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PrimaryMobile, new { @class = "form-control", name = "PrimaryMobile", type = "text", id = "txtPrimaryMobile", autocomplete = "Off", Maxlength = 15, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Secondary Moblie
                                                No.

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.SecondaryMobile, new { @class = "form-control", name = "SecondaryMobile", type = "text", id = "txtSecondaryMobile", autocomplete = "Off", Maxlength = 15, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                WhatsApp No.
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.WhatsAppNo, new { @class = "form-control", name = "WhatsAppNo", type = "text", id = "txtWhatsAppNo", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Personal Email Id
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PersonalEmailId, new { @class = "form-control capitalize-first", name = "PersonalEmailId", type = "text", id = "txtPersonalEmailId", autocomplete = "Off", Maxlength = 70, oninput = "this.value = this.value.charAt(0).toUpperCase() + this.value.slice(1).toLowerCase();" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Birth-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Birth Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.BirthdayDate, new { @class = "form-control", name = "BirthdayDate", type = "date", id = "dateBirthdayDate", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Birth Place
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.BirthdayPlace, new { @class = "form-control", name = "BirthdayPlace", type = "text", id = "txtBirthdayPlace", autocomplete = "Off", Maxlength = 50 })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Birth Proof
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.BirthdayProofOfDocumentID, new SelectList(ViewBag.GetVerificationName, "Id", "Name"), "--Select--", new { id = "ddlBirthdayProofOfDocumentID", @class = "form-select", autocomplete = "off", name = "BirthdayProofOfDocumentID" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Document No.
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.BirthdayProofOfCertificateNo, new { @class = "form-control", name = "BirthdayProofOfCertificateNo", type = "text", id = "txtBirthdayProofOfCertificateNo", autocomplete = "Off", Maxlength = 50 })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <label class="col-form-label"> </label>
                                            <div class="col-md-8">
                                                @Html.CheckBoxFor(model => model.IsDOBSpecial, new { id = "chkIsDOBSpecial" })
                                                &nbsp; <label class="form-check-label form-label">
                                                    Your DOB marks the start of your unique journey in life.
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Education-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Highest Qualification
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeQualificationID, new SelectList(ViewBag.GetQualificationName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeQualificationID", @class = "form-select", autocomplete = "off", name = "EmployeeQualificationID" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Specific Degree
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.EmployeeSpecificDegree, new { @class = "form-control", name = "EmployeeSpecificDegree", type = "text", id = "txtEmployeeSpecificDegree", autocomplete = "Off", Maxlength = 70 })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Gender / Marital And Other-Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Gender
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Gender, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Male", Value = "Male"},
