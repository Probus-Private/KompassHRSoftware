<script>
    $(document).ready(function () {debugger
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlDepartmentId").select2();
        $("#ddlDocAssignmentMasterId").select2();

        $('.TablePageAccess').DataTable({
            destroy: true,        // Allows the table to be reinitialized
            searching: true,      // Enables the search box
            paging: false,        // Disables pagination
            info: true,          // Disables the table information display (e.g., "Showing 1 to 10 of 50 entries")
            ordering: false,      // Disables column sorting
            bFilter: true         // Enables the filtering functionality (search box)
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#ddlCmpId").on("change", function () {debugger
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetMonthlyBusinessUnit", "Module_Employee_DocumentAssignment")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data.Branch != null) {
                        $("#ddlBranchId").append("<option value=''>--All--</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })
    });
</script>

<script>
    function ShowEmployee() {debugger

        var CmpId = $("#ddlCmpId").val();
        if(CmpId == "")
        {
            $("#ErrorCmpId").html("Company is Required");
            return false;
        }
        else{
            $("#ErrorCmpId").html("");
        }
        var BranchId = $("#ddlBranchId").val();
        var departmentId = $("#ddlDepartmentId").val();
        var DocAssignmentMasterId = $("#ddlDocAssignmentMasterId").val();
        if(DocAssignmentMasterId == "")
        {
            $("#ErrorDocAssignmentMasterId").html("Assignment Title is Required");
            return false;
        }
        else{
            $("#ErrorDocAssignmentMasterId").html("");
        }

        const url = '@Url.Action("Module_Employee_DocumentUploadedApproval", "Module_Employee_DocumentUploadedApproval", new { area = "Module" })';

        window.location.href = url +
            '?CmpId=' + CmpId +
            '&BranchId=' + BranchId +
            '&DepartmentId=' + departmentId +
            '&DocAssignmentMasterId=' + DocAssignmentMasterId;
    }
    function AllApproveReject(Status) {
        debugger;
        $("#SelectAll").prop("checked", false);
        debugger;
        const EmployeeList = [];
        var Remark = document.getElementById("txtApproveRejectRemark").value;

        $('#tblEmployee :checkbox:checked').each(function () {
            var data = {};
            var currentRow = $(this).closest("tr");

            data.EmployeeId = currentRow.find("td:eq(1)").html();
            data.DocAssignmentDetailsId = currentRow.find("td:eq(2)").html();
            EmployeeList.push(data);
        });

        if (EmployeeList.length === 0) {
            Swal.fire({
                text: 'Please select at least one employee.',
                icon: 'info',
                allowOutsideClick: false
            });
            $(".Userloaderbg").hide();
            return false;
        }

        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: "@Url.Action("MultipleApproveRejectRequest", "Module_Employee_DocumentUploadedApproval")",
            data: JSON.stringify({ EmployeeList: EmployeeList,
                Status:Status,
                Remark:Remark  }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (data) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                var datas = JSON.parse(data);
                if (datas != null) {
                    //$('#tblInbox').load();
                    Swal.fire({
                        icon: datas.Icon,
                        text: datas.Message,
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            return false;
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            window.location.reload();
                            return false
                        }
                    }).then(function () {
                        var url = '@Url.Action("Module_Employee_DocumentUploadedApproval", "Module_Employee_DocumentUploadedApproval")';
                        window.location.href = url;
                    });
                }
            }
        });
    }

    //Select All Checkboxes
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }
</script>
<script>
    function Description(encodedHtml)
    {debugger;
        $('#txtRemark').html('');
        const AssignDesc = decodeURIComponent(encodedHtml);
        $('#modal_basic3').modal('show');
        $('#modal_basic3').on('shown.bs.modal', function () {
            $('#txtRemark').html(AssignDesc);
            //$('#txtRemark').summernote('pasteHTML', WorkOnTask);
        });
    }

    function dismissModal(modalId) {
        $('#' + modalId).modal('hide');
    }

    function ApproveRejectList() {debugger

        var CmpId = $("#ddlCmpId").val();
        if(CmpId == "")
        {
            $("#ErrorCmpId").html("Company is Required");
            return false;
        }
        else{
            $("#ErrorCmpId").html("");
        }
        var BranchId = $("#ddlBranchId").val();
        var departmentId = $("#ddlDepartmentId").val();
        var DocAssignmentMasterId = $("#ddlDocAssignmentMasterId").val();
        if(DocAssignmentMasterId == "")
        {
            $("#ErrorDocAssignmentMasterId").html("Assignment Title is Required");
            return false;
        }
        else{
            $("#ErrorDocAssignmentMasterId").html("");
        }
        //var status="Approved";
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetApproveRejectList", "Module_Employee_DocumentUploadedApproval")',
            data: { CmpId, BranchId, departmentId,DocAssignmentMasterId},
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                const data = JSON.parse(response);
                const modal = $('#myEmployeeSalary');
                const tableBody = $('#tblBodyApproveRejectEmployeeDoc');

                // Clear table body (except headers)
                if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                    $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                }

                modal.modal(data.length > 0 ? 'show' : 'hide');

                if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                    $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                }

                if (!data || Object.keys(data).length === 0) {
                    return Swal.fire({
                        icon: "error",
                        text: "No Record Found",
                        allowOutsideClick: () => animatePopup()
                    });
                }


                if (data) {
                    debugger;
                    let convertedData = {};

                    // Flatten the original data
                    Object.keys(data).forEach(key => {
                        let flatObject = {};
                        data[key].forEach(item => {
                            flatObject[item.Key] = item.Value;
                        });
                        convertedData[key] = flatObject;
                    });

                    debugger;

                    // Clear table body first (important if appending dynamically multiple times)
                    $('#tblBodyApproveRejectEmployeeDoc').empty();

                    // Loop over the converted object
                    Object.values(convertedData).forEach(item => {
                        let row = `<tr>
                        <td class="text-left">${item.EmployeeName}</td>
                        <td class="text-left">${item.AssignmentTitle}</td>
                        <td class="text-left">${item.DocSubmitDate || ''}</td>
                        <td class="text-left">${item.ApproveRejectBy || ''}</td>
                        <td class="text-left">${item.ApproveRejectDate || ''}</td>
                            </tr>`;

                        $('#tblBodyApproveRejectEmployeeDoc').append(row);
                    });

                } else {
                    modal.modal('hide');
                }
            }
        });
    }
</script>