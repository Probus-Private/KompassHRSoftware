<script>

    $(document).ready(function () {
        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: false
                }).then(function() {
                    window.location.reload();
                });
            }
        }
        //$("#ddlFromUser").select2();
        //$("#ddlToUser").select2();
        var TransferOrigin = localStorage.getItem('TransferOrigin');
        if (TransferOrigin!="")
        {
            $("#btnActionList").hide();
        }
        var myArray = @Html.Raw(Json.Encode(ViewBag.SetReportintId));
        $('#tblRequestApproval tbody tr').each(function(index) {
            debugger;
            var row = $(this);
            var rowIndex = index + 1;
            row.find("td").eq(3).find('.ddlSelect2_'+rowIndex+'_1').select2();
            row.find("td").eq(4).find('.ddlSelect2_'+rowIndex+'_2').select2();
            row.find("td").eq(5).find('.ddlSelect2_'+rowIndex+'_3').select2();

            var ModuleIds = $.trim(row.find("td").eq(0).text());
            var ModuleId = Number(ModuleIds);
            myArray.forEach(function(item,arrayIndex) {
                if (item[0].Value == ModuleId) {
                    var level1Select = row.find("td").eq(3).find("select");
                    var level2Select = row.find("td").eq(4).find("select");
                    var level3Select = row.find("td").eq(5).find("select");

                    var Level1 = level1Select.val();
                    var Level2 = level2Select.val();
                    var Level3 = level3Select.val();

                    if (Level1 === "") {
                        level1Select.val(item[1].Value).trigger('change');
                        return;
                    }
                    if (Level2 === "") {
                        level2Select.val(item[1].Value).trigger('change');
                        return;
                    }
                    if (Level3 === "") {
                        level3Select.val(item[1].Value).trigger('change');
                        return;
                    }
                }
            });
        });

        if (Message && Icon) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false // Disable outside clicks
            }).then((result) => {
                if (result.isConfirmed) {
                    var TransferOrigin = localStorage.getItem('TransferOrigin');
                    if (TransferOrigin=="Trans_BU")
                    {
                        window.location.href = '@Url.Action("ESS_EmployeeTransfer_ForApproval", "ESS_EmployeeTransfer_ForApproval", new { area= "ESS" })';
                    }
                    else{
                        window.location.href = '@Url.Action("Module_Employee_Reporting", "Module_Employee_Reporting", new { area= "Module" })';
                    }
                }
            });
        }

    });//ready
</script>


<script>
    function OpenModal()
    {
        $("#myModal").modal('show');
        $("#ddlFromUser").select2({
            dropdownParent: $('#myModal')
        });

        $("#ddlToUser").select2({
            dropdownParent: $('#myModal')
        });
    }
    function UpdateReporting(ReportingID_Encrypted) {
        debugger
        var url = '@Url.Action("Module_Employee_Reporting", "Module_Employee_Reporting")?ReportingID_Encrypted=' + ReportingID_Encrypted;
        window.location.href = url;

    }
    function DeleteReporting(ReportingID_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Employee_Reporting")?ReportingID_Encrypted=' + ReportingID_Encrypted;
                //window.location.href = url;

            } else if (
                /* Read more about handling dismissals below */
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }

        })
    }


    $("#ddlApproverLevel").val($("#ddlApproverLevel").val() === "0" ? "" : $("#ddlApproverLevel").val());
    $('#ddlApproverLevel').on('input propertychange paste', function() {
        $("#ddlApproverLevel").val($("#ddlApproverLevel").val() === "0" ? "" : $("#ddlApproverLevel").val());
    });
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveReporting").validate({
        rules: {
            ReportingModuleID: {
                required: true,
            },
            ReportingManager1: {
                required: true,
            },
            ReportingHR: {
                required: true,
            },
        },
        messages: {
            ReportingModuleID: {
                required: "Module is required",
            },
            ReportingManager1: {
                required: "Manager 1 is required",
            },

            ReportingHR: {
                required: "HR is required",
            },
        }
    });

    var form = $("#SaveReporting");
    form.validate();
    $("#btnSubmit").click(function () {
        $(".Userloaderbg").css("display", "flex");
        debugger;
        form.valid();
        if(form.valid()==false)
        {
            return false;
        }
        var hasError=false;
        var RequestApproval = [];
        $("#tblRequestApproval tbody tr").each(function (index) {
            debugger;
            var row = $(this).closest("tr");
            var tblRowData = {};

            var rowNumber = row.find("td").eq(1).html(); // Assuming this gets the row number.
            tblRowData.ModuleId = row.find("td").eq(0).html();

            var level1 = row.find("td").eq(3).find("select").val();
            var level2 = row.find("td").eq(4).find("select").val();
            var level3 = row.find("td").eq(5).find("select").val();

            tblRowData.Level1ReportingManagerId = level1;
            tblRowData.Level2ReportingManagerId = level2;
            tblRowData.Level3ReportingManagerId = level3;

            // Check if the same employee is selected in all three dropdowns
            if ((level1 && level2 && level3) && (level1 === level2 && level2 === level3 && level1 === level3)) {
                Swal.fire({
                    icon: "error",
                    text: "Same employee cannot be selected for Level 1, Level 2, and Level 3 Reporting Managers in row " + (rowNumber) + ".",
                    allowOutsideClick: false
                }).then(function () {
                    $(".Userloaderbg").css("display", "none");
                    return false;
                });
                hasError = true;
                return false;
            }

            // Check if the same employee is selected in any two dropdowns
            if ((level1 === level2 && level1 !== '') || (level2 === level3 && level2 !== '') || (level1 === level3 && level1 !== '')) {
                Swal.fire({
                    icon: "error",
                    text: "Same employee cannot be selected for more than one reporting level in row " + (rowNumber) + ".",
                    allowOutsideClick: false
                }).then(function () {
                    $(".Userloaderbg").css("display", "none");
                    return false;
                });
                hasError = true;
                return false;
            }

            // Check if Level 3 is selected but Level 1 or Level 2 is not
            if (level3 && (!level1 || !level2)) {
                Swal.fire({
                    icon: "error",
                    text: "Level 1 and Level 2 Reporting Managers must be required before selecting Level 3 in row " + (rowNumber) + ".",
                    allowOutsideClick: false
                }).then(function () {
                    $(".Userloaderbg").css("display", "none");
                    return false;
                });
                hasError = true;
                return false;
            }

            // Check if Level 2 is selected but Level 1 is not
            if (level2 && !level1) {
                Swal.fire({
                    icon: "error",
                    text: "Level 1 Reporting Manager must be required before selecting Level 2 in row " + (rowNumber) + ".",
                    allowOutsideClick: false
                }).then(function () {
                    $(".Userloaderbg").css("display", "none");
                    return false;
                });
                hasError = true;
                return false;
            }

            // Add valid data to RequestApproval array
            if(level1 || level2 || level3) {
                RequestApproval.push(tblRowData);
            }

        });


        console.log(RequestApproval);
        if (hasError == true) {
            return false;
        }

        $.ajax({
            url: '@Url.Action("SaveUpdate", "Module_Employee_Reporting")',
            type: "POST",
            data: JSON.stringify({ RequestApproval: RequestApproval }),
            contentType: "application/json; charset=utf-8",
            dataType: "json", // ✅ Return parsed JSON
            success: function (response) {
                $(".Userloaderbg").css("display", "none"); // ✅ Always hide loader
                debugger;

                var Message1 = response.message;
                var Icon1 = response.Icon;

                if (Icon1 === "success") {
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: false
                    }).then((result) => {
                        if (result.isConfirmed) {
                            var TransferOrigin = localStorage.getItem('TransferOrigin');
                            if (TransferOrigin === "Trans_BU") {
                                window.location.href = '@Url.Action("ESS_EmployeeTransfer_ForApproval", "ESS_EmployeeTransfer_ForApproval", new { area= "ESS" })';
                            } else {
                                window.location.href = '@Url.Action("Module_Employee_Reporting", "Module_Employee_Reporting", new { area= "Module" })';
                            }
                        }
                    });
                } else {
                    // ❗ Show error/pending approval message
                    Swal.fire({
                        icon: Icon1 || "error",
                        text: Message1 || "Something went wrong",
                        allowOutsideClick: false
                    });
                }
            },
            error: function (xhr, status, error) {
                $(".Userloaderbg").css("display", "none"); // Always stop loader
                Swal.fire({
                    icon: "error",
                    text: "Server error: " + error,
                    allowOutsideClick: false
                });
            }
        });

    });
</script>


<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);
    $('#SaveReportingCopy').validate({
        rules: {
            FromUser: {
                required: true,
            },
            ToUser: {
                required: true,
            },


        },
        messages: {
