                required: "From employee is required"
            },
            ToUser: {
                required: "To employee is required",
            },

        }
    });
    var form = $("#SaveReportingCopy");
    form.validate();
    $("#btnSubmitReportingCopy").click(function () {
        debugger;
        form.valid();
        if (form.valid() == false) {
            return false;
