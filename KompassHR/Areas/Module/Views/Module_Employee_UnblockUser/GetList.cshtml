
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>


<style>
    .width-45 {
        width: 45px !important;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Blocked users List
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_Menu", "Module_Employee_Menu", new {id = 3, ScreenId=140, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">

                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Blocked users List</h4>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This list contains all blocked users whose account is temporarily locked.
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="false">
                    <div class="row">
                        <div class="col-md-12">
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="fixed-header"
                                           style="width: 100%;">
                                        <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr class="text-center">
                                                <th class="fixed-side">Unblock</th>
                                                <th class="fixed-side">Employee Name</th>
                                                <th class="fixed-side">Login Id</th>
                                                <th class="fixed-side">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetBlockeUserList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button type="button" onclick="UnblockUser('@d.EmployeeId','@d.EmployeeName','')" id="btnUpdate"
                                                                class="btn btn-success btnpress ListBtn">
                                                            <i class="fa-solid fa-check"></i>
                                                        </button>
                                                    </td>
                                                    <td>@d.EmployeeName</td>
                                                    <td>@d.ESSLoginID</td>
                                                    <td>@d.ESSIsLock</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>








<div class="modal fade" id="myModalFinal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">

            <!-- Header -->
            <div class="modal-header bg-success text-white rounded-top-4">
                <h5 class="modal-title">
                    <i class="fa-solid fa-user-check me-2"></i> Unblock Employee
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body text-center">

                <!-- Avatar -->
                <div class="mb-3">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center"
                         style="width:80px;height:80px;">
                        <i class="fa-solid fa-user fa-2x text-secondary"></i>
                    </div>
                </div>

                <!-- Employee Info -->
                <h5 id="empName" class="fw-bold mb-1"></h5>
               
                <input type="hidden" id="empId" />

                <!-- Confirmation Message -->
                <div class="alert alert-warning py-2">
                    Are you sure you want to unblock this user?
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer justify-content-center border-0">
                <button type="button" class="btn btn-success px-4" onclick="ConfirmUnblock()">
                    <i class="fa-solid fa-check me-1"></i> Yes, Unblock
                </button>
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>

        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    function UnblockUser(id, name) {
    $('#empId').val(id);
    $('#empName').text(name); 
    $('#myModalFinal').modal('show'); // Bootstrap 4    
    }


    function ConfirmUnblock() {
        var id = $('#empId').val();
        debugger
        $.ajax({
            url: "@Url.Action("SaveUpdate", "Module_Employee_UnblockUser")",
            type: 'POST',
            data: { EmployeeId: id },
            success: function (response) {
                debugger
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="success") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            })

                           // $("#myModalFinal").modal('hide')
                            //$("#txtApproveRejectRemark").val("")
                            .then((result) => {
                                debugger
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("GetList", "Module_Employee_UnblockUser")';
                                } else if (                                
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })
                        }
                    }
                }





            }
        });
    }
</script>