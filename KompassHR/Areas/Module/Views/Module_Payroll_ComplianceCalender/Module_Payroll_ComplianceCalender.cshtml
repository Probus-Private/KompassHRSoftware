    $('#txtYearlyDate').datepicker({
        format: "dd-mm",
        autoclose: true,
        todayHighlight: true,
        startView: "months",
        minViewMode: "days"
    });

    
    $('.quarterlyDate').not('.readonlyQuarter').datepicker({
        format: "dd-mm",
        autoclose: true,
        todayHighlight: true,
        startView: "months",
        minViewMode: "days"
    });

    $(document).on("change", "input[name='QuarterlyDateList[Q1]']", function () {
        let q1 = $(this).val(); 
        if (!q1) {
            $("input[name='QuarterlyDateList[Q2]']").val("");
            $("input[name='QuarterlyDateList[Q3]']").val("");
            $("input[name='QuarterlyDateList[Q4]']").val("");
            return;
        }

        let parts = q1.split("-");
        let day = parseInt(parts[0]);
        let month = parseInt(parts[1]);
        let baseDate = new Date(2000, month - 1, day);

        function addMonths(date, months) {
            let d = new Date(date);
            d.setMonth(d.getMonth() + months);
            let dd = ('0' + d.getDate()).slice(-2);
            let mm = ('0' + (d.getMonth() + 1)).slice(-2);
            return dd + "-" + mm;
        }

        $("input[name='QuarterlyDateList[Q2]']").val(addMonths(baseDate, 3));
        $("input[name='QuarterlyDateList[Q3]']").val(addMonths(baseDate, 6));
        $("input[name='QuarterlyDateList[Q4]']").val(addMonths(baseDate, 9));
    });

