        if (value !== "") {
            var num = parseInt(value);

            if (num < 1 || num > 31) {
                errorSpan.text("Please enter a valid date between 1 and 31.");
            } else {
                errorSpan.text(""); // clear error
            }
        } else {
            errorSpan.text("");
        }
