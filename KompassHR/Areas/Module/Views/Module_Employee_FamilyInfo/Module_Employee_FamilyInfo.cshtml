<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Family Information
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new {id = 3, ScreenId=142, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">

                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Family Information - @ViewBag.AddUpdateTitle</h4>
                    @*<div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>*@
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add employee family details.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_FamilyInfo", new { area = "Module" })' id="SaveFamilyInformation" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="empbx">
                                            <span>
                                                <h4>
                                                    <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"]
                                                </h4>
                                            </span>
                                            <span>
                                                <h6>
                                                    <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"]
                                                </h6>
                                            </span>
                                            <span>
                                                <h6>
                                                    <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"]
                                                </h6>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px" id="btnGet">
                                    <div class="col-md-6" style="width:fit-content;">
                                        <button type="button" id="btnGetPrebordingList" onclick="GetDetails('Pre')"
                                                class="btn btn-success btn-sm btnpress">
                                            <i class="fa-regular fa-copy"></i> Get
                                        </button>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Family Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Member Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.MemberName, new { @class = "form-control", name = "MemberName", type = "text", id = "txtMemberName", autocomplete = "Off", Maxlength = 50 })
                                                @Html.HiddenFor(model => model.FamilyId_Encrypted, new { id = "FamilyId_Encrypted" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Relation With
                                                Candidate
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Relation, new SelectList(ViewBag.GetRelationName, "RelationName", "RelationName"), "--Select--", new { id = "ddlRelation", @class = "form-select", autocomplete = "off", name = "Relation" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Date Of Birth

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.DOB, new { @class = "form-control", name = "DOB", type = "date", id = "dateDOB", autocomplete = "Off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Aadhar No.

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.AadharNo, new { @class = "form-control", name = "AadharNo", type = "number", onkeypress = "return event.charCode >=48", id = "txtAadharNo", autocomplete = "Off", Maxlength = 12 })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row mb-15px">
                                            <div class="col-md-3">
                                                <label class="col-form-label"> </label>
                                                <div class="col-md-6">
                                                    @Html.CheckBoxFor(model => model.ESIC_InsuranceType, new { id = "ESIC_InsuranceType" })
                                                    &nbsp;
                                                    <label class="form-check-label form-label">
                                                        ESIC Covered
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label col-form-label col-md-4" id="lblMemberResiding">
                                                    Member_Residing
                                                </label>
                                                <div class="col-md-12">
                                                    @Html.DropDownListFor(model => model.Member_Residing, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Yes", Value = "Yes"},
                                                    new SelectListItem { Text = "No", Value = "No"},
                                                }, "--Select--", new { id = "ddlMember_Residing", @class = "form-select", autocomplete = "off", name = "Member_Residing", @onchange = "check()" })
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label col-form-label col-md-6" id="lblTownName">
                                                    Town Name
                                                </label>
                                                <div class="col-md-12">
                                                    @Html.TextBoxFor(model => model.TownName, new { @class = "form-control", name = "TownName", type = "text", id = "txtTownName", autocomplete = "Off", Maxlength = 30 })
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label col-form-label col-md-4" id="lblStateName">
                                                    State Name
                                                </label>
                                                <div class="col-md-12">
                                                    @Html.TextBoxFor(model => model.StateName, new { @class = "form-control", name = "StateName", type = "text", id = "txtStateName", autocomplete = "Off", Maxlength = 30 })
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="row mb-20px">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" data-bs-toggle="offcanvas"
                                                                href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn  btnpress ListBtn">
                                                            <i class="fa-solid fa-list"></i>
                                                        </button>
                                                        <button class="btn btn-primary btn-sm" type="button" id="btnSubmit">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new { area = "Module" })">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm" id="btnBack">
                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row ShortNote pt-1">
                                            <label>
                                                Note : You can add multiple family member details upto 6
                                                members
                                            </label>
                                        </div>
                                        <!-- BEGIN table-responsive -->


                                        <table class="table table-bordered align-middle" id="fixed-header"
                                               style="width: 100%;">
                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                <tr class="text-center">
                                                    <th class="text-nowrap"> Action</th>
                                                    <th class="text-nowrap"> Member Name </th>
                                                    <th class="text-nowrap"> Relation</th>
                                                    <th class="text-nowrap"> Date Of Birth </th>
                                                    <th class="text-nowrap"> Aadhar No.</th>
                                                    <th class="text-nowrap"> ESIC Covered</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var d in ViewBag.GetEmployeeFamilyList)
                                                {
                                                    <tr>

                                                        <td class="text-center">
                                                            <button type="button" onclick="DeleteFamily('@d.FamilyId_Encrypted')" id="btnDelete"
                                                                    class="btn btn-danger btn-sm btnpress">
                                                                <i class="fa-solid fa-trash-alt"></i>
                                                            </button>
                                                        </td>
                                                        <td>@d.MemberName</td>
                                                        <td>@d.Relation</td>
                                                        <td>@d.DOB</td>
                                                        <td>@d.AadharNo</td>
                                                        <td>@d.ESIC_InsuranceType</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<div class="row">
    @Html.Action("Onboarding_SidebarMenu", "Module_Employee_PersonalInfo")
</div>

<script>
    $(document).ready(function () {
        $("#ddlRelation").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        var CountFamilyEmployeeId = @Html.Raw(Json.Encode(TempData["CountFamilyEmployeeId"]));

        var CheckPreboarding = @Html.Raw(Json.Encode(TempData["PreBoardFid"]));

        if(CountFamilyEmployeeId!=0)
        {
            $("#btnGet").hide();
        }
        else
        {
            if(CheckPreboarding!=0)
            {
                $("#btnGet").show();
            }
            else{
                $("#btnGet").hide();

            }
        }
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#ddlMember_Residing").hide();
        $("#lblMemberResiding").hide();
        $("#txtTownName").hide();
        $("#txtStateName").hide();
        $("#lblTownName").hide();
        $("#lblStateName").hide();

        $("#ESIC_InsuranceType").click(function(){
            debugger;
            var ESICValue = $("#ESIC_InsuranceType").val();
            if ($('#ESIC_InsuranceType').is(":checked")) {
                $("#ddlMember_Residing").show();
                $("#lblMemberResiding").show();
            }
            else
            {
                $("#ddlMember_Residing").hide();
                $("#lblMemberResiding").hide();
                $("#txtTownName").hide();
                $("#txtStateName").hide();
                $("#lblTownName").hide();
                $("#lblStateName").hide();
            }
        })
        $("#ddlMember_Residing").change(function(){
            var ddlCheck= $('#ddlMember_Residing :selected').val();
            if (ddlCheck== "No") {
                $("#txtTownName").show();
                $("#txtStateName").show();
                $("#lblTownName").show();
                $("#lblStateName").show();
            }
            else
            {
                $("#txtTownName").hide();
                $("#txtStateName").hide();
                $("#lblTownName").hide();
                $("#lblStateName").hide();
            }
        })
    });

    function GetDetails(Status) {
        debugger;

        var baseUrl = '@Url.Action("PreboardingGetDetails", "Module_Employee_FamilyInfo", new { area = "Module" })';
        //var url = baseUrl + '?Status=' + encodeURIComponent(Status);

        window.location.href = baseUrl;
    }
</script>
<script>
    function DeleteFamily(FamilyId_Encrypted) {
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,

            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }
        }).then((result) => {
            if (result.isConfirmed) {
               window.location.href = '@Url.Action("Delete", "Module_Employee_FamilyInfo")?FamilyId_Encrypted=' + FamilyId_Encrypted;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }
</script>
<script>
    //use for add regex function
    jQuery.validator.addMethod(
  "regex",
   function(value, element, regexp) {
       if (regexp.constructor != RegExp)
           regexp = new RegExp(regexp);
       else if (regexp.global)
           regexp.lastIndex = 0;
       return this.optional(element) || regexp.test(value);
   },"erreur expression reguliere"
);


    $("#SaveFamilyInformation").validate({
        rules: {
            MemberName: {
                required: true,
                regex: /^[a-zA-Z ]+$/,
            },
            Relation: {
                required: true,
            },
            //DOB: {
            //    required: true,

            //},
            //AadharNo: {
            //    required: true,
            //    regex: /^[0-9]+$/,
            //},
        },
        messages: {
            MemberName: {
                required: "Member name is required",
                regex: "Enter olny alphabate.",
            },
            Relation: {
                required: "Relation with candidate is required",

            },
            //DOB: {
            //    required: "Date of birth is required",
            //},
            //AadharNo: {
            //    required: "Aadhar number is required",
            //    regex: "Enter olny number.",
            //},
        }
    });

    var form = $( "#SaveFamilyInformation" );
    form.validate();
    $("#btnSubmit").click(function () {
        if(form.valid()==false)
        {
            $("#dateDOB").removeClass('error');
            return false;
        }
        var FamilyId_Encrypted=$("#FamilyId_Encrypted").val();
        var AadharNo=$("#txtAadharNo").val();

        $.ajax({
            url: '@Url.Action("IsFamilyExists", "Module_Employee_FamilyInfo")',
            method:"get",
            data:{FamilyId_Encrypted:FamilyId_Encrypted,AadharNo:AadharNo},
            success:function(response){
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon=="error") {
                    if (Message1 != null) {
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                }
                else{
                    $("#SaveFamilyInformation").submit();
                }
            }
        });
    });
</script>