                                                        </thead>
                                                        <tbody id="tblAadharDetails">
                                                            @if (ViewBag.GetAadhardata != null)
                                                            {
                                                                foreach (var d in ViewBag.GetAadhardata)
                                                                {
                                                                    <tr>
                                                                        <td class="text-center">
                                                                            <a class="btnRemoveRow" id="btnDelete" style="cursor:pointer;">
                                                                                <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                                            </a>
                                                                        </td>
                                                                        <td>@d.SrNo</td>
                                                                        <td>@d.EmployeeNo</td>
                                                                        <td>@d.EmployeeName</td>
                                                                        <td class="text-center">
                                                                            <input class="form-control" data-checked="email-checkbox" value="@d.AadhaarNo" id="txtnumber_" onchange="validateTextbox(this)" text="" type='text' min='0' step='0.5' MaxLength='12' onkeypress='return numbervalidate(event)'>
                                                                            <span id='validationMessage_' style='color: red;'></span>
                                                                        </td>
