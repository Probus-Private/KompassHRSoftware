<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Bulk Update
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Contractor_Menu", "ESS_Contractor_Menu",  new { id = 27,ScreenId=307, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

   
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Bulk Update<b></b> </h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        It enables HR personnel to efficiently input essential details for each new hire in a structured format, ensuring accuracy and consistency across all entries.

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("Module_Employee_BulkUpdate", "Module_Employee_BulkUpdate", new { area = "Module" })' id="SaveBulkUpdate" method="post" enctype="multipart/form-data" }>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Company Name
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.CompanyName, new SelectList(ViewBag.ComapnyProfile, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CmpId", id = "ddlCmpId" })
                                                @Html.ValidationMessageFor(model => model.CompanyName, "", new { @class = "help-block", @id = "ErrorCompanyName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Business Unit
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.BranchName, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "BusinessUnit", id = "ddlBusinessUnit" })
                                                @Html.ValidationMessageFor(model => model.BranchName, "", new { @class = "help-block", @id = "ErrorBranchName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Type
                                                <span class="important"></span>
                                            </label>
                                            <div class="col-md-9">
                                                @Html.DropDownListFor(model => model.Type, new SelectList(ViewBag.GetTypeName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "Type", id = "ddlType" })
                                                @*@Html.DropDownListFor(model => model.Type, new List<SelectListItem> {
                                                        new SelectListItem { Text = "Aadhar", Value = "Update Aadhar Details"},
                                                        new SelectListItem { Text = "UAN", Value = "Update Statutory Details"},
                                                        new SelectListItem { Text = "Address", Value = "Update Address Details"},
                                                        new SelectListItem { Text = "Contractor", Value = "Update Employee Contractor"},
                                                        new SelectListItem { Text = "Critical Stage Category", Value = "Update Critical Stage Category"},
                                                        new SelectListItem { Text = "Department", Value = "Update Department"},
                                                        new SelectListItem { Text = "Attendance", Value = "Update Attendance"},
                                                        new SelectListItem { Text = "Manpower Category", Value = "Update Manpower Category"},
                                                        new SelectListItem { Text = "Line Master", Value = "Update Line Master"},
                                                        new SelectListItem { Text = "Assessment Level", Value = "Update Assessment Level"},
                                                        new SelectListItem { Text = "Grade", Value = "Update Employee Grade"},
                                                        new SelectListItem { Text = "Designation", Value = "Update Employee Designation"},
                                                        new SelectListItem { Text = "Sub Unit", Value = "Update Sub Unit"},
                                                        new SelectListItem { Text = "Date Of Birth", Value = "Update Employee Date Of Birth"},
                                                        new SelectListItem { Text = "Gender", Value = "Update Employee Gender"},
                                                        new SelectListItem { Text = "Marital Status", Value = "Update Marital Status"},
                                                        new SelectListItem { Text = "Primary Mobile No", Value = "Update Employee Mobile No"},
                                                    }, "--Select--", new { id = "ddlType", @class = "form-select", autocomplete = "off", name = "Type" })*@
                                                @Html.ValidationMessageFor(model => model.Type, "", new { @class = "help-block", @id = "ErrorType", @style = "color:red" })
                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <button type="button" class="btn btn-primary btn-sm" id="btlExportToExcel">Export File</button>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Choose File
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-9">
                                                <input type="file" name="AttachFile" class="form-control" id="txtAttachFile" onchange="ResetFile()" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <button type="button" class="btn btn-warning btn-sm" id="btnChooseFile">Import</button>
                                    </div>
                                </div>
                            </form>

                            <div class="row" id="tblAadharData">
