                    <h4 class="panel-title"> Contractor Attendance (Summary) - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        This is the list of Contractor Attendance (summary) created.
                    </p>
                </div>
                <div class="panel-body">
                    <form role="form" action="@Url.Action("GetList", "Module_Employee_ContractorAttendanceSummary")" id="SaveMonthlyAttendance">
                        <div class="row">
                            <div class="col-md-2">
                                <a href="@Url.Action("Module_Employee_ContractorAttendanceSummary", "Module_Employee_ContractorAttendanceSummary", new { area = "Module" })">
                                    <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                        <i class="fa-solid fa-plus"></i> &nbsp; Add
                                    </button>
                                </a>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Company <span class="important">*</span>
                                        </label>
                                        <div class="col-md-9">
                                            @Html.DropDownListFor(model => model.CmpId, new SelectList(ViewBag.CompanyName, "Id", "Name"), "--Select--", new { @class = "form-select", name = "CmpId", id = "ddlCmpId" })
                                            <span class="text-danger" id="errCmpId"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Business Unit <span class="important">*</span>
                                        </label>
                                        <div class="col-md-9">
                                            @Html.DropDownListFor(model => model.BranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), "--Select--", new { @class = "form-select", type = "text", name = "BranchId", id = "ddlBranchId" })
                                            <span class="text-danger" id="errBranchId"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-3">
                                            Month/Year
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-9">
                                            @Html.TextBoxFor(model => model.InvoiceMonth, new { id = "txtMonth", @class = "form-control", name = "Month", type = "month" })
                                        </div>
                                    </div>
                                </div>
                                    <div class="col-md-3">
                                        <button type="button" onclick="showList()" class="btn btn-success btn-sm  mb-10px">
                                            <i class="fa-solid fa-eye"></i> &nbsp; Show
