                                                        @if (ViewBag.AttendanceSummary != null && ViewBag.AttendanceSummary.Count > 0)
                                                        {
                                                            var firstRow = ViewBag.AttendanceSummary[0];
                                                            var keys = ((IDictionary<string, object>)firstRow).Keys.ToList();
                                                            int hideCount = ViewBag.HideCount;


                                                            int visibleIndex = 0;

                                                            for (int i = 0; i < keys.Count; i++)  // ✅ NO @
                                                            {
                                                                if (keys[i] != "Hide")
                                                                {
                                                                    if (i < hideCount)
                                                                    {
                                                                        <th style="display:none">@keys[i]</th>
                                                                    }
                                                                    else
                                                                    {
                                                                        visibleIndex++;
                                                                        <th data-vindex="@visibleIndex">@keys[i]</th>
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    </tr>
                                                </thead>

                                                @*<tbody id="tblEmployee" style="max-height: 250px; overflow-y: auto;">*@
                                                <tbody id="tblEmployee">
                                                    @if (ViewBag.AttendanceSummary != null && ViewBag.AttendanceSummary.Count > 0)
                                                    {
                                                        foreach (var row in ViewBag.AttendanceSummary)
                                                        {
                                                            var rowDict = (IDictionary<string, object>)row;
                                                            var keys = rowDict.Keys.ToList();
                                                            int hideCount = ViewBag.HideCount;

                                                            <tr>
                                                                @{

                                                                    int visibleIndex = 0; // count visible columns only

                                                                    for (int i = 0; i < keys.Count; i++)
                                                                    {
                                                                        if (keys[i] != "Hide")
                                                                        {
                                                                            if (i < hideCount)
                                                                            {
                                                                                <td data-col="@keys[i]" style="display:none">@rowDict[keys[i]]</td>
                                                                            }
                                                                            else
                                                                            {
                                                                                visibleIndex++; // only visible columns increment

                                                                                <td data-col="@keys[i]" data-vindex="@visibleIndex">
                                                                                    @rowDict[keys[i]]
                                                                                </td>
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            </tr>
                                                                        }
