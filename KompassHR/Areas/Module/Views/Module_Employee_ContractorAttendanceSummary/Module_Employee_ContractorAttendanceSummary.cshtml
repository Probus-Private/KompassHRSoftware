               + '&ContractorId=' + encodeURIComponent(ContractorId)
              + '&InvoiceMonth=' + encodeURIComponent(InvoiceMonth);
        });
    });
</script>


<script>
    function funSave() {
        debugger;
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var ContractorId = $("#ddlContractorId").val();
        var InvoiceMonth = $("#txtInvoiceMonth").val();
        const ObjContractorAttendanceSummary = [];


        $('#tblEmployee tr').each(function () {
            const $row = $(this);
            const rowData = {};

            $row.find('td').each(function () {
                const colName = $(this).data('col'); // ✅ direct column name

                if (!colName) return;
                const $input = $(this).find('input');
                let value;
                if ($input.length > 0) {
                    value = $input.val(); // input or hidden input
                } else {
                    value = $(this).text().trim(); // plain text (visible + hidden)
                }

                rowData[colName] = value;
            });

            ObjContractorAttendanceSummary.push(rowData);
        });

        console.log(ObjContractorAttendanceSummary);

        const dataToSend = {
            model: {
                ObjContractorAttendanceSummary: ObjContractorAttendanceSummary
            },
            CmpId: parseInt(CmpId),
            BranchId: BranchId,
            ContractorId:ContractorId,
            InvoiceMonth: InvoiceMonth,
        };
        $(".Userloaderbg").css("display", "flex");

        $.ajax({
            type: "POST",
            url: '@Url.Action("SaveUpdate", "Module_Employee_ContractorAttendanceSummary")',
            data: JSON.stringify(dataToSend),
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                $(".Userloaderbg").hide();
                debugger;
                // var data = JSON.parse(response);
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response != null) {
                    if(Icon1=="error")
                    {
                        $(".Userloaderbg").css("display", "none");
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            });
                        }
                    }
                    else{
                        if (Message1 != null) {
                            Swal.fire({
                                icon: Icon1,
                                text: Message1,
                                allowOutsideClick: () => {
                                    const popup = Swal.getPopup()
                                    popup.classList.remove('swal2-show')
                                    setTimeout(() => {
                                        popup.classList.add('animate__animated', 'animate__headShake')
                                    })
                                    setTimeout(() => {
                                        popup.classList.remove('animate__animated', 'animate__headShake')
                                    }, 500)
                                    return false
                                }
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    window.location.href = '@Url.Action("Module_Employee_ContractorAttendanceSummary", "Module_Employee_ContractorAttendanceSummary")';
                                } else if (
                                    /* Read more about handling dismissals below */
                                    result.dismiss === Swal.DismissReason.cancel
                                ) {

                                }
                            })
                        }
                    }
                }
            }
        });
    }

    function ResetFile()  {
        debugger;
        let allowedExtension = ['application/vnd.ms-excel'];
        let fileInput = document.getElementById('txtAttachFile');

        if (fileInput.files.length > 0) {
            let type = fileInput.files[0].type;

            if (allowedExtension.indexOf(type) === -1) {
                $("#ErrorFile").text('File type should be Excel (.xlsx)');
                fileInput.value = null;
                return false;
            }
        }

        $("#ErrorFile").text('');
    }

    var form = $("#formMonthlyAttendance");
    form.validate();

    $("#btnfileupload").click(function(){
        debugger;

        form.valid();
        if (form.valid() == false) {
            $("#FromDate").removeClass("error");
            return false;
        }

        var fileInput = document.getElementById('txtAttachFile');
        if (fileInput.files.length === 0) {
            Swal.fire({
                icon:  "error",
                text: "Please import excel file",
                allowOutsideClick: () => {
                    const popup = Swal.getPopup()
                    popup.classList.remove('swal2-show')
                    setTimeout(() => {
                        popup.classList.add('animate__animated', 'animate__headShake')
                    })
                    setTimeout(() => {
                        popup.classList.remove('animate__animated', 'animate__headShake')
                    }, 500)
                    return false
                }
            });
            return false;
        }
        $(".Userloaderbg").css("display","flex");
        $('#tblbodyMonthlyAttendance').not(function(){return!!$(this).has('th').length;}).remove();
        $("#formMonthlyAttendance").submit();
    })
</script>

