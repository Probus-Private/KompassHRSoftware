<script>
    function downloadExcelFile() {
        debugger
        $("#errCmpId, #errBranchId, #errInvoiceMonth").text("");

        var isValid = true;

        // Get Values
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var ContractorId = $("#ddlContractorId").val();
        var InvoiceMonth = $("#txtInvoiceMonth").val();

        // Validations
        if (CmpId === "" || CmpId === null) {
            $("#errCmpId").text("Please select company");
            isValid = false;
        }

        if (BranchId === "" || BranchId === null || BranchId === "0") {
            $("#errBranchId").text("Please select business unit");
            isValid = false;
        }


        if (InvoiceMonth === "" || InvoiceMonth === null) {
            $("#errInvoiceMonth").text("Please select  month Year");
            isValid = false;
        }



    $(".Userloaderbg").css("display", "flex");

    var url = `@Url.Action("DownloadSummaryExcelFile", "Module_Employee_ContractorAttendanceSummary")?BranchId=${BranchId}&ContractorId=${ContractorId}&CmpId=${CmpId}&InvoiceMonth=${InvoiceMonth}`;

    $.ajax({
        url: url,
        method: 'GET',
        xhrFields: { responseType: 'blob' },
        success: function (data, status, xhr) {

            $(".Userloaderbg").css("display", "none");

            // Check file name
            var disposition = xhr.getResponseHeader("Content-Disposition");
            if (disposition && disposition.indexOf("FileNotFound.txt") !== -1) {
                Swal.fire({ icon: 'error', text: 'Record Not Found' });
                return;
            }

            // Download normally
            var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
            var downloadUrl = URL.createObjectURL(blob);

            var a = document.createElement('a');
            a.href = downloadUrl;
            a.download = 'AttendanceSummary.xlsx';
            a.click();

            URL.revokeObjectURL(downloadUrl);
        },
        error: function (xhr, status, error) {
            console.error('Error downloading file:', error);
            $(".Userloaderbg").css("display", "none");
        }
    });
}
</script>

<script>
    // LEFT CLICK highlight only
    $('.TabledataBulkClass tbody').on('click', 'tr', function (e) {
        if (e.which === 1) { // Left click
            $('.TabledataBulkClass tbody tr').removeClass('selected');
            $(this).addClass('selected');
        }
    });

    // Block RIGHT & MIDDLE CLICK from selecting
    $('.TabledataBulkClass tbody').on('mousedown', 'tr', function (e) {
        if (e.which === 2 || e.which === 3) { // Middle or Right click
            e.stopImmediatePropagation();
            e.preventDefault();
            return false;
        }
    });
</script>







