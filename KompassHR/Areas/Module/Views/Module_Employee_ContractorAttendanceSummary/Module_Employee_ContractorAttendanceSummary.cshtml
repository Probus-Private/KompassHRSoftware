<script>
    $(document).ready(function () {
        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlContractorId").select2();

        // Get current date and set default values
        var today = new Date();
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // getMonth() returns 0-11

        // Format as YYYY-MM (HTML5 month input format)
        var defaultMonthYear = yyyy + '-' + mm;

        // Set default values if empty
        if (!$('#txtInvoiceMonth').val()) {
            $('#txtInvoiceMonth').val(defaultMonthYear);
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Employee_ContractorAttendanceSummary")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlBranchId").append("<option value='0'>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });

        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlContractorId").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetContractor", "Module_Employee_ContractorAttendanceSummary")',
                data: { BranchId: BranchId,CmpId:CmpId},
                success: function (data) {
                    var $ContractorDropdown = $("#ddlContractorId");
                    $ContractorDropdown.empty();

                    if (data && data.length > 0) {
                        $ContractorDropdown.append("<option value=''>--All--</option>");
                        $.each(data, function (i, module) {
                            $ContractorDropdown.append(
                                $("<option>").val(module.Id).text(module.Name)
                            );
                        });
                    } else {
                        $ContractorDropdown.append("<option>--All--</option>");
                    }
                },
                error: function () {
                    console.error("Failed to fetch modules.");
                    $("#ddlContractorId").empty().append("<option>Error loading modules</option>");
                }
            });
        });
    });

</script>


<script>
    $(document).ready(function () {
        debugger
        $("#btnshow").click(function () {debugger
            var CmpId = $("#ddlCmpId").val();
