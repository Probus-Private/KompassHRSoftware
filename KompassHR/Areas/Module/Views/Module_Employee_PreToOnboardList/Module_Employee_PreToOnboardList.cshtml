
@{
    ViewBag.Title = "Module_Employee_PreToOnboardList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }   

    .fixed-side {
        position: sticky !important;
        left: 0;
        z-index: 1;
    }*/   
      .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    } 
</style>


<div id="content" class="app-content">
    <!-- BEGIN breadcrumb -->
    <ol class="breadcrumb float-xl-end">
        <li class="breadcrumb-item"><a href="/Dashboard/Dashboard/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Module/Module_Employee_Menu/Module_Employee_Menu"> Onboarding Menu</a></li>
    </ol>
    <!-- END breadcrumb -->
    <!-- BEGIN page-header -->
    <h1 class="page-header"> Preboarding To Onboarding List </h1>
    <!-- END page-header -->
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
               
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@  Preboarding To Onboarding List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                       
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row">
                        <div class="col-md-12">
                            
                            <!-- BEGIN table-responsive -->
                            <div class="table-scroll div1">
                                <div class="table-wrap">
                                    <table class="table table-bordered align-middle TablePage" id="data-table-combine"
                                           style="width: 100%;">

                                        <thead>
                                            <tr class="text-center">
                                                <th class="text-nowrap width-45 fixed-side">Onboard Candidate</th>                                               
                                                <th class="text-nowrap">DocNo</th>
                                                <th class="text-nowrap">DocDate</th>
                                                <th class="text-nowrap">Company Name</th>
                                                <th class="text-nowrap">Business Unit</th>
                                                <th class="text-nowrap">EmployeeName</th>                                                        
                                                <th class="text-nowrap">Department Name</th>
                                                <th class="text-nowrap">Desgination Name</th>
                                                <th class="text-nowrap">Grade Name</th>                                           
                                              
                                                <th class="text-nowrap">Final Submit Status</th>
                                                <th class="text-nowrap">Final Submit Date</th>
                                                <th class="text-nowrap">Final Approved By</th>
                                                <th class="text-nowrap">Final Reject Remark</th>                                             
                                              
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.PreOnboardList)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button type="button" onclick="OnboardCandidate('@d.FID_Encrypted','@d.FID')" id="btnOnboardCandidate"
                                                                class="btn btnpress ListBtn">
                                                            <i class="fa-solid fa-paper-plane text-dark"></i>
                                                        </button>
                                                    </td>                                                                                            
                                                    <td>@d.DocNo</td>
                                                    <td>@d.DocDate</td>
                                                    <td>@d.CompanyName</td>
                                                    <td>@d.BranchName</td>
                                                    <td>@d.CandidateName</td>                                               
                                                    <td>@d.DepartmentName</td>
                                                    <td>@d.DesignationName</td>
                                                    <td>@d.GradeName</td>                                                                                                                                         
                                                    <td>@d.Verify_FinalApproval_Status</td>
                                                    <td>@d.Verify_FinalApproval_Date</td>
                                                    <td>@d.FinalApprovalVerifierName</td>
                                                    <td>@d.Verify_FinalApproval_RejectRemark</td>                                                                                                     
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- END panel -->
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function OnboardCandidate(FID_Encrypted, FID) {
        var url = '@Url.Action("Module_Employee_Onboarding", "Module_Employee_Onboarding")?FID_Encrypted=' + FID_Encrypted + '&FID=' + FID;
        window.location.href = url;
    }
    </script>