<script>
    $("#txtFromDate").on("change", function () {
        debugger;

        let fromDate = $("#txtFromDate").val();
        let toDate = $("#txtToDate").val();

        // Clear previous error messages
        $("#ErrorFromDate").text("");
        $("#ErrorToDate").text("");

        let isValid = true;

        if (fromDate) {
            let fDate = new Date(fromDate + "T00:00:00"); 

            if (fDate.getDate() !== 1) {
                $("#ErrorFromDate").text("From Date must be the 1st day of the month.");
                isValid = false;
            }
        }

        return isValid;
    });

</script>

<script>
    $(document).ready(function () {
        debugger;
        $("#ddlMaleFemaleRateCmpid").select2();
        $("#ddlMaleFemaleRateBranchid").select2();

        @*var RateFromDate = @Html.Raw(Json.Encode(TempData["RateFromDate"]));
        $("#txtFromDate").val(RateFromDate);
        var RateTodate = @Html.Raw(Json.Encode(TempData["RateTodate"]));
        $("#txtToDate").val(RateTodate);*@

        var AddUpdateTitle = @Html.Raw(Json.Encode(ViewBag.AddUpdateTitle));

        if (AddUpdateTitle === "Add") {

            document.getElementById('txtToDate').value = "2999-12-31";

        } else {

            var FromDate = @Html.Raw(Json.Encode(TempData["RateFromDate"]));
            var Todate = @Html.Raw(Json.Encode(TempData["RateTodate"]));

            document.getElementById('txtFromDate').value = FromDate;
            document.getElementById('txtToDate').value = Todate;
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        if (Message) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            }).then(() => {
                window.location.reload();
            });
        }



        $("#ddlMaleFemaleRateCmpid").on("change", function () {
            debugger;
            $("#ddlMaleFemaleRateBranchid").find("option").remove();
            //$(".ddlEmployeeId").find("option").remove();
            var MaleFemaleRateCmpid = $("#ddlMaleFemaleRateCmpid").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Payroll_MaleFemaleRate")',
                data: { MaleFemaleRateCmpid: MaleFemaleRateCmpid },
                success: function (data) {
                    debugger;
                    if (data.Branch != null) {
                        $("#ddlMaleFemaleRateBranchid").append("<option value=''>Select</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlMaleFemaleRateBranchid").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

    });
</script>

<script>

    $("#SaveMaleFemaleRate").validate({

        rules: {
            MaleFemaleRateCmpid:
                {
                required: true,
                },
            MaleFemaleRateBranchid:
                {
                required: true,
                },
            Gender:
                {
                    required: true,
                },
            Rate:
                {
                    required: true,
                },
            RateFromDate:
                {
                    required: true,
                },
            RateTodate:
                {
                    required: true,
                },

        },
        messages: {

            MaleFemaleRateCmpid: {
                required: "Select the Company Name",
            },
            MaleFemaleRateBranchid: {
                required: "Select the Branch Name",
            },
            Gender: {
                required: "Select Gender",
            },
            Rate: {
                required: "Select Rate",
            },
            RateFromDate: {
                required: "Select Rate From Date",
            },
            RateTodate: {
                required: "Select Rate To Date",
            },


        },
        errorPlacement: function (error, element) {
            if (element.hasClass("select2-hidden-accessible")) {
                // Insert error after Select2's container
                error.insertAfter(element.next('.select2'));
            } else {
                error.insertAfter(element);
            }
        },

    });


    var form = $("#SaveMaleFemaleRate");
    form.validate();
    $("#btnSubmit").click(function () {
        debugger;

        //if (!validateDates()) {
        //    return false;
        //}

        form.valid();
        if (form.valid() == false) {
            return false;
        }

        var MaleFemaleRateId_Encrypted = $("#txtMaleFemaleRateId_Encrypted").val();
        var MaleFemaleRateCmpid = $("#ddlMaleFemaleRateCmpid").val();
        var MaleFemaleRateBranchid = $("#ddlMaleFemaleRateBranchid").val();

        var Gender = $("#ddlGender").val();
        var Rate = $("#txtRate").val();
        var InsumentRate = $("#txtInsumentRate").val();
        //var OtherEmpId = $("#ddlOtherEmpId").val();



        $.ajax({
            url: '@Url.Action("IsExists", "Module_Payroll_MaleFemaleRate")',
            method: "get",
            data:
                {
                MaleFemaleRateId_Encrypted: MaleFemaleRateId_Encrypted,
                MaleFemaleRateCmpid:MaleFemaleRateCmpid,
                MaleFemaleRateBranchid:MaleFemaleRateBranchid,
                Gender:Gender,
                Rate:Rate,
                InsumentRate:InsumentRate

                },
            success: function (response) {
                debugger;
                var Message1 = response.Message;
                var Icon1 = response.Icon;
                if (response.Icon == "error") {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: false
                        }).then(() => {
                            const p = Swal.getPopup();
                            p.classList.add('animate__headShake');
                            setTimeout(() => p.classList.remove('animate__headShake'), 500);
                        });
                    }
                }
                else
                {
                    debugger;
                    $("#SaveMaleFemaleRate").submit();
                }
            }
        });
    });
</script>