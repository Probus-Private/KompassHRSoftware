    function EditExperienceInformation(ExperienceEmployeeID) {
        debugger
        $.ajax({
            url: '@Url.Action("GetExperienceDetails", "Module_Employee_ExpInfo")',
            type: 'GET',
            data: { ExperienceEmployeeID: ExperienceEmployeeID },
            success: function(response) {
                debugger
                if (response.success) {
                    // Check if data is an array
                    if (Array.isArray(response.data) && response.data.length > 0) {
                        var experienceData = response.data[0];
                        // Now populate using experienceData
                        $("#ExperienceId_Encrypted").val(experienceData.ExperienceId_Encrypted);
                        $("#txtCompanyName").val(experienceData.CompanyName);
                        $("#txtIndustryType").val(experienceData.IndustryType);
                        $("#txtHRName").val(experienceData.HRName);
                        $("#txtManagerName").val(experienceData.ManagerName);
                        $("#txtHREmailID").val(experienceData.HREmailID);
                        $("#txtManagerEmailID").val(experienceData.ManagerEmailID);
                        $("#txtHRContact").val(experienceData.HRContact);
                        $("#txtManagerContact").val(experienceData.ManagerContact);
                        $("#txtCompanyAddress").val(experienceData.CompanyAddress);
                        $("#txtDesigantion").val(experienceData.Desigantion);
                        $("#txtDepartment").val(experienceData.Department);
                        $("#txtSalary").val(experienceData.Salary);
                        $("#txtJobDescription").val(experienceData.JobDescription);
                    } else {
                        console.error('Data is not in expected array format');
                    }

                    if (experienceData.StartDate) {
                        var startDate = parseDate(experienceData.StartDate);
                        if (startDate) {
                            $("#dateStartDate").val(formatDateForInput(startDate));
                        }
                    }
            
                    if (experienceData.EndDate) {
                        var endDate = parseDate(experienceData.EndDate);
                        if (endDate) {
                            $("#txtEndDate").val(formatDateForInput(endDate));
                        }
                    }
                    //$('html, body').animate({
                    //    scrollTop: $("#SaveExperienceInformation").offset().top
                    //}, 500);
                }
                
                
                else {
                    Swal.fire({
                        icon: 'error',
                        text: response.message || 'Failed to load experience details',
                        allowOutsideClick: () => false
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    text: 'An error occurred while loading experience details',
                    allowOutsideClick: () => false
                });
            }
        });
    }

    function parseDate(dateString) {
        if (!dateString) return null;
        if (dateString.startsWith('/Date(')) {
            var timestamp = parseInt(dateString.substr(6));
            return new Date(timestamp);
        }
        if (dateString.match(/^\d{4}-\d{2}-\d{2}$/)) {
            return new Date(dateString + 'T00:00:00');
        }
        var parsedDate = new Date(dateString);
        if (!isNaN(parsedDate.getTime())) {
            return parsedDate;
        }
    }

    function formatDateForInput(date) {
        if (!date) return '';
        return date.toISOString().split('T')[0];
    }
