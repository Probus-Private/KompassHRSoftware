                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TablePageAccess" id="tblTableBulkCTCInsert">
                                                            <thead>
                                                                <tr>


                                                                    @if (ViewBag.InvoiceData != null && ViewBag.InvoiceData.Count > 0)
                                                                    {
                                                                        var firstRow = ViewBag.InvoiceData[0];
                                                                        var keys = ((IDictionary<string, object>)firstRow).Keys.ToList();
                                                                        int hideCount = ViewBag.HideCount;

                                                                        for (int i = 0; i < keys.Count; i++)
                                                                        {
                                                                            if (i >= hideCount && keys[i] != "Hide")
                                                                            {

                                                                                <th>@keys[i]</th>

                                                                                
                                                                            }
                                                                        }
                                                                    }
                                                                </tr>
                                                            </thead>

                                                            <tbody id="tblEmployee" style="max-height: 250px; overflow-y: auto;">

                                                                @foreach (var row in ViewBag.InvoiceData)
                                                                {
                                                                    var rowDict = (IDictionary<string, object>)row;
                                                                    var keys = rowDict.Keys.ToList();
                                                                    int hideCount = ViewBag.HideCount;

                                                                    <tr>
                                                                        @for (int i = 0; i < keys.Count; i++)
                                                                        {
                                                                            if (i >= hideCount && keys[i] != "Hide")
                                                                            {

                                                                                <td>@rowDict[keys[i]]</td>
                                                                     
                                                                            }
                                                                        }
                                                                        
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                        
                                        <div class="row">
                                            <div class="LastShortLeaveBx">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="BtnBx">
                                                            <div>
                                                                <button type="submit" id="btnSubmit"
                                                                        class="btn btn-primary btn-sm">
                                                                    <i class="fa-solid fa-floppy-disk"></i> Submit
                                                                </button>


                                                                <a href="@Url.Action("GetList", "Module_Employee_ContractorInvoice", new { area = "Module" })">
                                                                    <button type="button" class="btn btn-danger btn-sm" id="btnDesignationGetList">
                                                                        <i class="fa-solid fa-share-from-square"></i> List
                                                                    </button>
                                                                </a>

                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>


                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    $(document).ready(function () {
        debugger
        $("#btnshow").click(function () {
            var CmpId = $("#ddlCmpId").val();
            var BranchId = $("#ddlBranchId").val();
            var ContractorId = $("#ddlContractorId").val();
            var InvoiceMonth = $("#txtInvoiceMonth").val();


          let isError = false;

          if (!CmpId) {
              $("#errCmpId").text("Please select Company");
              isError = true;
          }

          if (!BranchId) {
              $("#errBranchId").text("Please select Branch");
              isError = true;
          }

          if (!ContractorId) {
              $("#errContractorId").text("Please select Contractor Name");
              isError = true;
          }

          if (!InvoiceMonth) {
              $("#errInvoiceMonth").text("Please select Month");
              isError = true;
          }

          if (isError) {
              return false;
          }


            window.location.href = '@Url.Action("Module_Employee_ContractorInvoice", "Module_Employee_ContractorInvoice")'
                + '?CmpId=' + encodeURIComponent(CmpId)
                + '&BranchId=' + encodeURIComponent(BranchId)
               + '&ContractorId=' + encodeURIComponent(ContractorId)
              + '&InvoiceMonth=' + encodeURIComponent(InvoiceMonth);
        });
    });
</script>


<script>
    $(document).ready(function () {

        $("#ddlBranchId").select2();
        $("#ddlCmpId").select2();
        $("#ddlContractorId").select2();

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $("#ddlCmpId").on("change", function () {
            debugger;
            $("#ddlBranchId").find("option").remove();

            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Employee_ContractorInvoice")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlBranchId").append("<option value='0'>--Select-- </option>");
                        $.each(data, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });



        @*$("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlContractorId").find("option").remove();

            var BranchId = $("#ddlBranchId").val();

            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetContractorName", "Module_Employee_ContractorInvoice")',
                data: { CmpId: CmpId,BranchId:BranchId },
                success: function (data) {
                    debugger;
                    if (data != null) {
                        $("#ddlContractorId").append("<option value='0'>All </option>");
                        $.each(data, function (i, p) {
                            $("#ddlContractorId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                }
            })
        });*@


        $("#ddlBranchId").on("change", function () {
            debugger;
            $("#ddlContractorId").find("option").remove();
            var BranchId = $("#ddlBranchId").val();
            var CmpId = $("#ddlCmpId").val();

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetContractorName", "Module_Employee_ContractorInvoice")',
                data: { BranchId: BranchId,CmpId:CmpId},
                success: function (data) {
                    var $ContractorDropdown = $("#ddlContractorId");
                    $ContractorDropdown.empty();

                    if (data && data.length > 0) {
                        $ContractorDropdown.append("<option value=''>All</option>");
                        $.each(data, function (i, module) {
                            $ContractorDropdown.append(
                                $("<option>").val(module.Id).text(module.Name)
                            );
                        });
                    } else {
                        $ContractorDropdown.append("<option>--All--</option>");
                    }
                },
                error: function () {
                    console.error("Failed to fetch modules.");
                    $("#ddlContractorId").empty().append("<option>Error loading modules</option>");
                }
            });
        });


    });

</script>


<script>

$("#SaveContractorInvoice").validate({
    rules: {
        CmpId: { required: true }
    },
    messages: {
        CmpId: { required: "Select the Company Name" }
    },
    errorPlacement: function (error, element) {
        if (element.hasClass("select2-hidden-accessible")) {
            error.insertAfter(element.next('.select2'));
        } else {
            error.insertAfter(element);
        }
    }
});

var form = $("#SaveContractorInvoice");
form.validate();

$("#btnSubmit").click(function (e) {
    e.preventDefault();
    debugger;

    if (!form.valid()) {
        return false;
    }

    var employeeData = [];

    // -----------------------------
    // COLLECT TABLE ROW DATA
    // -----------------------------


    $('#tblEmployee tr').each(function () {
        debugger
        var $row = $(this);

        employeeData.push({

            ContractorMonthlyContractorId: $row.find('td:eq(0)').text().trim(),
           // ContractorMonthlyMonthYear: new Date($row.find('td:eq(1)').text().trim()),
            ContractorMonthlyMonthYear: $row.find('td:eq(1)').text().trim(),
            Contractor: $row.find('td:eq(2)').text().trim(),
            NoOfEmployee: parseFloat($row.find('td:eq(3)').text()),  
            NoOfDays: parseFloat($row.find('td:eq(4)').text()),

            Total_PerDayAmount: parseFloat($row.find('td:eq(5)').text()),
            Total_CanteenAmount: parseFloat($row.find('td:eq(6)').text()),

            Total_AttendanceBonusAmount: parseFloat($row.find('td:eq(7)').text()),
            Total_TransportAllowAmount: parseFloat($row.find('td:eq(8)').text()),
            Total_OtherRate1Amount: parseFloat($row.find('td:eq(9)').text()),
            Total_OtherRate2Amount: parseFloat($row.find('td:eq(10)').text()),

            TotalAmount: parseFloat($row.find('td:eq(11)').text()),
            ServiceCharges: parseFloat($row.find('td:eq(12)').text()),
            Rate: parseFloat($row.find('td:eq(13)').text()),
            Percentage: parseFloat($row.find('td:eq(14)').text()),

