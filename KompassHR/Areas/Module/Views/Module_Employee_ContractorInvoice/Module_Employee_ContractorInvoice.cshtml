    //        NoOfDays:$row.find('td:eq(4)').text().trim(),

    //        Total_PerDayAmount: $row.find('td:eq(5)').text().trim(),
    //        Total_CanteenAmount: $row.find('td:eq(6)').text().trim(),

    //        Total_AttendanceBonusAmount: $row.find('td:eq(7)').text().trim(),
    //        Total_TransportAllowAmount: $row.find('td:eq(8').text().trim(),
    //        Total_OtherRate1Amount: $row.find('td:eq(9)').text().trim(),
    //        Total_OtherRate2Amount: $row.find('td:eq(10)').text().trim(),

    //        TotalAmount: $row.find('td:eq(11)').text().trim(),

    //        ServiceCharges: $row.find('td:eq(12)').text().trim(),
    //        Rate: $row.find('td:eq(13)').text().trim(),
    //        Percentage: $row.find('td:eq(14)').text().trim(),

    //        //IsGross: $row.find('td:eq(15)').text().trim(),
    //        //IsOT: $row.find('td:eq(16)').text().trim(),

    //        IsGross: $row.find('td:eq(15)').text().trim() === "Yes",
    //        IsOT: $row.find('td:eq(16)').text().trim() === "Yes",

    //        SupervisorCharges: $row.find('td:eq(17)').text().trim(),

