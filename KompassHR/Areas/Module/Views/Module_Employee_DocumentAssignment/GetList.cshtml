<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>

<style>
        .Tooltip {
            position: relative;
        }

            .Tooltip button {
                width: 35px;
            }

            .Tooltip:hover .Tooltip-text {
                display: flex;
                position: absolute;
            }

            .Tooltip .Tooltip-text {
                z-index: 1;
                min-width: 45px;
                max-width: fit-content;
                background-color: black;
                color: #fff;
                top: 40px;
                right: -18px;
                padding: 5px 8px;
                border-radius: 6px;
                display: none;
                justify-content: center;
                position: absolute;
                margin-right: 10px;
            }

                .Tooltip .Tooltip-text::after {
                    content: "";
                    position: absolute;
                    top: -20px;
                    right: 20px;
                    border-width: 10px;
                    border-style: solid;
                    border-color: transparent transparent black transparent;
                }

        .ListBtn {
            font-size: 10px !important;
            padding: 5px 8px !important;
            border: 1px solid lightgray !important;
        }


        tr td {
            padding: 4px !important;
            font-weight: 600;
        }

        .table-striped > tbody > tr:nth-of-type(odd) > * {
            --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
        }

        .table-wrap::-webkit-scrollbar-track {
            -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
            background-color: #F5F5F5;
            border-radius: 10px;
        }

        .table-wrap::-webkit-scrollbar {
            width: 6px;
            height: 10px;
            background-color: #F5F5F5;
        }

        .table-wrap::-webkit-scrollbar-thumb {
            background-color: #777;
            border-radius: 10px;
        }

        /*table first column fixed*/
        .table-wrap {
            width: 100%;
            overflow: auto;
        }

        .table-scroll table {
            width: 100%;
            margin: auto;
            border-collapse: separate;
            border-spacing: 0;
        }

        .table-scroll th, .table-scroll td {
            padding: 5px 10px;
            border: 1px solid lightgray;
            background: #fff;
            white-space: nowrap;
            vertical-align: top;
        }

        .table-scroll th {
            background-color: rgba(233, 236, 239, 1) !important;
        }



        .approve-btn, .reject-btn, .pending-btn {
            display: flex;
            justify-content: center;
            padding: 5px 8px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            font-weight: 700;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            border: 1px solid white;
            letter-spacing: -0.5px;
            align-items: center;
        }


            .approve-btn, .approve-btn:hover {
                background-color: #ddf5df;
                color: #2e7d32;
                /*background: #2e7d32;
        /* background-color: #e8f5e9; */
            }

        .doodle {
            font-size: 12px !important;
            background: #fff;
            color: #2e7d32;
            padding: 0 2px;
            margin-left: 5px;
            border-radius: 50px;
        }

        .approve-btn .doodle {
            color: #2e7d32;
        }

        .reject-btn .doodle {
            color: #c62828 !important;
        }

        .pending-btn .doodle {
            color: #ab9808 !important;
        }

        .reject-btn {
            background-color: #ffebee;
            color: #c62828;
        }

        .pending-btn {
            background-color: #fffad5;
            color: #ab9808;
        }
        /*.approve-btn:hover {
        background-color: #c8e6c9;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }*/

        .reject-btn:hover {
            background-color: #ffebee;
            color: #c62828;
        }

        .approve-btn i, .reject-btn i, .pending-btn i {
            margin-right: 5px;
        }

        .approve-btn span, .reject-btn span, .pending-btn span {
            font-size: 0.9rem;
        }
</style>


<div id="content" class="app-content">
