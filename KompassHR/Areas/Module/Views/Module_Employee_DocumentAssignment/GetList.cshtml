                Document Assignment
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_DocumentAssignmentSubmenu", "Module_Employee_DocumentAssignmentSubmenu",  new { id = 3,ScreenId=913, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Document Assignment - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">

                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="@Url.Action("Module_Employee_DocumentAssignment", "Module_Employee_DocumentAssignment", new { area = "Module" })">
                                <button type="button" class="btn btn-primary btn-sm  mb-10px">
                                    <i class="fa-solid fa-plus"></i> &nbsp; Add
                                </button>
                            </a>
                        </div>

                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage" id="data-table-combine" style="width: 100%;">
                                    <thead>
                                        <tr class="trheading">
                                            <th class="fixed-side">Update</th>
                                            <th class="fixed-side">Delete</th>
                                            @*<th class="fixed-side1">View</th>*@
                                            <th class="text-nowrap">Pending List </th>
                                            <th class="text-nowrap">Approve List </th>
                                            <th class="text-nowrap">Reject List </th>
                                            <th class="text-nowrap text-center">Doc No</th>
                                            <th class="text-nowrap text-center">Doc Date</th>
                                            <th class="text-nowrap text-center">Assignment Title</th>
                                            <th class="text-nowrap">Descripion</th>
                                            <th class="text-nowrap">Instruction</th>
                                            <th class="text-nowrap text-center">Due Date</th>
                                            @*<th class="text-nowrap text-center">Created By</th>
                                            <th class="text-nowrap text-center">Created Date</th>*@
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in ViewBag.GetDocumentAssignmentList)
                                        {
                                            <tr>
                                                <td class="text-center" style="width: 80px;">
                                                    <a onclick="Update('@d.DocAssignmentMasterId_Encrypted')" id="btnUpdate" style="cursor:pointer;">
                                                        <i class="fa-solid fa-pen-to-square fa-lg text-Dark"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center">
                                                    <a onclick="Delete('@d.DocAssignmentMasterId')" id="btnDelete" style="cursor:pointer;">
                                                        <i class="fa-solid fa-trash-alt text-danger fa-lg"></i>
                                                    </a>
                                                </td>
                                                @*<td class="text-center" style="width: 80px;">
                                                    <a id="btnshow" onclick="ViewEmployeeList('@d.CmpId','@d.DocAssignmentMasterId')" style="cursor:pointer;">
                                                        <i class="fa-solid fa-eye fa-lg text-danger"></i>
                                                    </a>
                                                </td>*@
                                                <td class="text-center">
                                                    <a id="btnshow" class="pending-btn" onclick="PendingEmployeeDocument('@d.CmpId','@d.BranchId','@d.DepartmentId','@d.DocAssignmentMasterId')" style="cursor:pointer;">
                                                        <i class="fa-solid fa-check-double"></i>
                                                        <span>Pending</span>
                                                        <span class="doodle">@d.PendingCount</span>
                                                    </a>
                                                </td>
                                                <td class="text-center">
                                                    <a id="btnApproveList" onclick="ApproveEmployeeDocument('@d.CmpId','@d.BranchId','@d.DepartmentId','@d.DocAssignmentMasterId')"
                                                       class="approve-btn" title="Approve">
                                                        <i class="fa-solid fa-circle-check"></i>
                                                        <span>Approve</span>
                                                        <span class="doodle">@d.ApprovedCount</span>
                                                    </a>
                                                </td>
                                                <td class="text-center">
                                                    <a id="btnRejectList" onclick="RejectEmployeeDocument('@d.CmpId','@d.BranchId','@d.DepartmentId','@d.DocAssignmentMasterId')"
                                                       class="reject-btn" title="Reject">
                                                        <i class="fa-solid fa-circle-xmark"></i>
                                                        <span>Reject</span>
                                                        <span class="doodle">@d.RejectedCount</span>
                                                    </a>
                                                </td>
                                                <td class="text-center">@d.DocNo</td>
                                                <td class="text-nowrap">@d.DocDate</td>
                                                <td class="text-nowrap">@d.AssignmentTitle</td>
                                                <td class="text-start text-center">
                                                    <input type="hidden" id="hiddenDescription_@d.DocAssignmentMasterId" value="@d.Description" />
                                                    <i class="fa-solid fa-receipt fa-lg" onclick="Description(encodeURIComponent(document.getElementById('hiddenDescription_@d.DocAssignmentMasterId').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                </td>
                                                <td class="text-start text-center">
                                                    <input type="hidden" id="hiddenInstruction_@d.DocAssignmentMasterId" value="@d.Instruction" />
                                                    <i class="fa-solid fa-receipt fa-lg" onclick="Instruction(encodeURIComponent(document.getElementById('hiddenInstruction_@d.DocAssignmentMasterId').value))" style="cursor:pointer; color: #ff5b57;"></i>
                                                </td>
                                                <td class="text-nowrap">@d.DueDate</td>
                                                @*<td class="text-nowrap">@d.CreatedBy</td>
                                                <td class="text-nowrap">@d.CreatedDate</td>*@
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>

