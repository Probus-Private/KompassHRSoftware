<script>
    $(document).ready(function () {
        $('title').html("Document Assignment");
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>

<script>
    function Update(DocAssignmentMasterId_Encrypted) {
        debugger;
        var url = '@Url.Action("Module_Employee_DocumentAssignment", "Module_Employee_DocumentAssignment")' +
                  '?DocAssignmentMasterId_Encrypted=' + encodeURIComponent(DocAssignmentMasterId_Encrypted) ;
        window.location.href = url;
    }


    function Delete(DocAssignmentMasterId) {debugger;
        const DeleteButtons = Swal.mixin({
            customClass: {
                cancelButton: ' btnpress',
                confirmButton: ' btnpress'
            },
            buttonsStyling: true
        })
        DeleteButtons.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'No, cancel!',
            reverseButtons: false,
            allowOutsideClick: () => {
                const popup = Swal.getPopup()
                popup.classList.remove('swal2-show')
                setTimeout(() => {
                    popup.classList.add('animate__animated', 'animate__headShake')
                })
                setTimeout(() => {
                    popup.classList.remove('animate__animated', 'animate__headShake')
                }, 500)
                return false
            }

        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Delete", "Module_Employee_DocumentAssignment")?DocAssignmentMasterId=' + DocAssignmentMasterId;

            } else if (
                result.dismiss === Swal.DismissReason.cancel
            ) {

            }
        })
    }

   
</script>
<script>
    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

</script>
<script>
    function PendingEmployeeDocument(CmpId,BranchId,DepartmentId,DocAssignmentMasterId) {debugger
        $('#btnEmployeeSubmit').show();
        @*var downloadUrl = '@Url.Action("DownloadAttachment", "Module_Employee_DocumentAssignment")';*@
        var url = '@Url.Action("ShowEmployeeList", "Module_Employee_DocumentAssignment")';

        var Process="PendingEmployeeList";
        var Status="Pending"
        $.getJSON(url,
            {
                CmpId: CmpId,
                BranchId:BranchId,
                DepartmentId:DepartmentId,
                DocAssignmentMasterId: DocAssignmentMasterId,
                Process:Process,
                Status:Status
            }, function (data) {

                const jsonData = JSON.parse(data);

                $('#EmployeeListModel').modal('show');
                $('#EmployeeListTitle').text('Pending Employee List');
                $("#tbodyEmployeeList").empty();

                $.each(jsonData, function (index, item) {debugger
                 var row = `<tr>
                <td><center>
                    <input type="checkbox" value="${item.DocAssignmentDetailsId}"
                           class="form-check-input rowCheckbox" />
                </center></td>
                <td class="text-left">${item.EmployeeName}</td>
                <td class="text-left">${item.AssignmentTitle}</td>
                <td class="text-left">${item.DocSubmitDate || ''}</td>
                <td class="text-left">${item.ApproveRejectBy || ''}</td>
                <td class="text-left">${item.ApproveRejectDate || ''}</td>
            </tr>`;

                    $("#tbodyEmployeeList").append(row);
                });
            });
    }

    function ApproveEmployeeDocument(CmpId, BranchId,DepartmentId,DocAssignmentMasterId) {debugger
        $('#btnEmployeeSubmit').hide();
        @*var downloadUrl = '@Url.Action("DownloadAttachment", "Module_Employee_DocumentAssignment")';*@
        var url = '@Url.Action("ShowEmployeeList", "Module_Employee_DocumentAssignment")';

        var Process="ApproveEmployeeList";
        var Status="Approved";
        $.getJSON(url, {
            CmpId: CmpId,
            BranchId:BranchId,
            DepartmentId:DepartmentId,
            DocAssignmentMasterId: DocAssignmentMasterId,
            Process:Process,
            Status:Status
        }, function (data) {

            const jsonData = JSON.parse(data);

            $('#EmployeeListModel').modal('show');
            $('#EmployeeListTitle').text('Document Approved Employee List');
            $("#tbodyEmployeeList").empty();

            $.each(jsonData, function (index, item) {debugger
                let statusCol = '';

                if (item.Status === "Approved") {
                    statusCol = `<td><center><span class="text-success fw-bold">Approved</span></center></td>`;
                }  else {
                    statusCol = `<td><center><input type="checkbox" class="form-check-input" /></center></td>`;
                }
                var row = `<tr>
                 ${statusCol}
                <td class="text-left">${item.EmployeeName}</td>
                <td class="text-left">${item.AssignmentTitle}</td>
                <td class="text-left">${item.DocSubmitDate || ''}</td>
                <td class="text-left">${item.ApproveRejectBy || ''}</td>
                <td class="text-left">${item.ApproveRejectDate || ''}</td>
            </tr>`;

                $("#tbodyEmployeeList").append(row);
            });
        });
    }

    function RejectEmployeeDocument(CmpId, BranchId,DepartmentId,DocAssignmentMasterId) {debugger
        $('#btnEmployeeSubmit').hide();
        @*var downloadUrl = '@Url.Action("DownloadAttachment", "Module_Employee_DocumentAssignment")';*@
        var url = '@Url.Action("ShowEmployeeList", "Module_Employee_DocumentAssignment")';

        var Process="RejectEmployeeList";
        var Status="Rejected";
        $.getJSON(url, {
            CmpId: CmpId,
            BranchId:BranchId,
            DepartmentId:DepartmentId,
            DocAssignmentMasterId: DocAssignmentMasterId,
            Process:Process,
            Status:Status
        }, function (data) {

            const jsonData = JSON.parse(data);

            $('#EmployeeListModel').modal('show');
            $('#EmployeeListTitle').text('Document Reject Employee List');
            $("#tbodyEmployeeList").empty();

            $.each(jsonData, function (index, item) {

                let statusCol = '';

                if (item.Status === "Rejected") {
                    statusCol = `<td><center><span class="text-danger fw-bold">Rejected</span></center></td>`;
                }  else {
                    statusCol = `<td><center><input type="checkbox" class="form-check-input" /></center></td>`;
                }

                var row = `<tr>
                ${statusCol}
                <td class="text-left">${item.EmployeeName}</td>
                <td class="text-left">${item.AssignmentTitle}</td>
                <td class="text-left">${item.DocSubmitDate || ''}</td>
                <td class="text-left">${item.ApproveRejectBy || ''}</td>
                <td class="text-left">${item.ApproveRejectDate || ''}</td>
            </tr>`;

                $("#tbodyEmployeeList").append(row);
            });
        });
    }
</script>

<script>
    $("#btnEmployeeSubmit").click(function () {
        debugger
        $("#SelectAll").prop("checked", false);
        var EmployeeList = [];
        var table = $('#tblEmployeeLog').DataTable();
        table.rows().nodes().to$()
            .find('.rowCheckbox:checked')
            .each(function () {
                EmployeeList.push({
                    DocAssignmentDetailsId: $(this).val()
                });
            });

        if (EmployeeList.length === 0) {
            Swal.fire({
                text: 'Please select at least one employee.',
                icon: 'info',
                allowOutsideClick: false
            });
            $(".Userloaderbg").hide();
            return false;
        }

        $(".Userloaderbg").css("display", "flex");
        $.ajax({
            type: "POST",
            url: '@Url.Action("DeleteEmployee", "Module_Employee_DocumentAssignment")',
            data: JSON.stringify({
                EmployeeList: EmployeeList
            }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;
                if (Icon1 != null) {
                    if (Message1 != null) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1,
                            allowOutsideClick: () => {
                                const popup = Swal.getPopup()
                                popup.classList.remove('swal2-show')
                                setTimeout(() => {
                                    popup.classList.add('animate__animated', 'animate__headShake')
                                })
                                setTimeout(() => {
                                    popup.classList.remove('animate__animated', 'animate__headShake')
                                }, 500)
                            }
                        }).then(function () {
                            var url = '@Url.Action("GetList", "Module_Employee_DocumentAssignment")';
                            window.location.href = url;
                        })
                    }
                }
            }
        });
    });
</script>
