<script>
    $(document).ready(function () {debugger
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();
        $("#ddlDepartmentId").select2();

        if (employeeData != null) {
            BindEmployeeTable(employeeData);
        }

        debugger;
        var date = new Date();
        var dateString = new Date(date.getTime() - (date.getTimezoneOffset() * 60000 )).toISOString().split("T")[0];
        $("#txtDocDate").val(dateString);

        var DueDate = @Html.Raw(Json.Encode(TempData["DueDate"]));
        $("#txtDueDate").val(DueDate);

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;

        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        $("#ddlCmpId").on("change", function () {debugger
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetMonthlyBusinessUnit", "Module_Employee_DocumentAssignment")',
                data: { CmpId: CmpId },
                success: function (data) {
                    debugger;
                    if (data.Branch != null) {
                        $("#ddlBranchId").append("<option value=''>--All--</option>");
                        $.each(data.Branch, function (i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        })

        $('#txtDocDate,#txtDueDate').change(function () {
            debugger
            var DocDate= document.getElementById('txtDocDate').value;
            var DueDate= document.getElementById('txtDueDate').value;
            if(DocDate > DueDate)
            {
                $("#ErrortxtDueDate").html("Due date should not be less than from date.");
                $("#txtDueDate").val('');
            }
            else{
                $("#ErrortxtDueDate").html("");
            }
        });
    });
</script>
<script>
    // Select/Deselect all checkboxes
    $(document).on('change', '#AllCheckBox', function () {
        var table = $('#tblEmployees').DataTable();
        var isChecked = $(this).is(':checked');

        table.rows({ search: 'applied' }).nodes().each(function (row) {
            $(row).find('.rowCheckbox').prop('checked', isChecked);
        });
    });

    $(document).on('change', '.rowCheckbox', function () {
        const all = $('.rowCheckbox').length;
        const checked = $('.rowCheckbox:checked').length;
        $('#AllCheckBox').prop('checked', all === checked);
    });
</script>
<script>

    jQuery.validator.addMethod(
 "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SaveDocumentAssignment').validate({
        rules: {
            AssignmentTitle: {
                required: true,
            },
            Description: {
                required: true,
            },
            DueDate: {
                required: true,
            },
            CmpId: {
                required: true,
            },
        },
        messages: {
            AssignmentTitle: {
                required: "Assignment Title is required.",
            },
            Description: {
                required: "Description is required",
            },
            DueDate: {
                required: "Please Select Company",
            },
            CmpId: {
                required: "Please Select Company",
            },
        },
    });
    var form = $("#SaveDocumentAssignment");
    form.validate();

    function ShowEmployee() {
        debugger;
        form.valid();

        if (form.valid() == false) {
            $("#txtEstablishedDate").removeClass("error");
            return false;
        }

        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var departmentId = $("#ddlDepartmentId").val();
        var DocAssignmentMasterId =$("#DocAssignmentMasterId").val();

        $.ajax({
            url: '@Url.Action("GetEmployeeDetails", "Module_Employee_DocumentAssignment")',
            type: 'GET',
            data: {
                CmpId: CmpId,
                BranchId: BranchId,
                DepartmentId: departmentId,
                DocAssignmentMasterId:DocAssignmentMasterId
            },
            success: function (data) {
                debugger;

                if (data) {
                    let convertedData = {};

                    // Flatten the original data (Key / Value structure)
                    Object.keys(data).forEach(key => {
                        let flatObject = {};
                        data[key].forEach(item => {
                            flatObject[item.Key] = item.Value;
                        });
                        convertedData[key] = flatObject;
                    });

                    // Destroy existing DataTable instance
                    if ($.fn.DataTable.isDataTable('#tblEmployees')) {
                        $('#tblEmployees').DataTable().destroy();
                    }

                    var tbody = $('#tblLoadEmployee');
                    tbody.empty();
                    Object.values(convertedData).forEach(d => {
                        var checked = d.IsActive === 1 || d.IsActive === true ? 'checked' : '';
                        var row = `<tr>
                        <td class="text-center">
                            <input type="checkbox" class="rowCheckbox"  value="${d.EmployeeId}" id="chkIsActive_${d.EmployeeId || ''}" ${checked} style="cursor:pointer" />
                        </td>
                        <td hidden>${d.EmployeeId || ''}</td>
                        <td>${d.ShortName || ''}</td>
                        <td>${d.BranchName || ''}</td>
                        <td>${d.EmployeeName || ''}</td>
                        <td>${d.DepartmentName || ''}</td>
                        <td hidden>${d.CmpId || ''}</td>
                        <td hidden>${d.BranchId || ''}</td>
                        <td hidden>${d.DepartmentId || ''}</td>
                        </tr>`;

                        tbody.append(row);
                    });

                    $('#tblEmployees').DataTable({
                        paging: true,
                        searching: true,
                        ordering: false
                    });
                }
            },
            error: function (xhr, status, error) {
                console.error("Error loading employees:", error);
            }
        });
    }


    $("#btnSubmit").click(function () {
        debugger
        $(".Userloaderbg").css("display", "flex");
        var DocAssignmentMasterId =$("#DocAssignmentMasterId").val();
        var DocNo = $("#txtDocNo").val();
        var DocDate = $("#txtDocDate").val();
        var AssignmentTitle = $("#txtAssignmentTitle").val();
        var Description = $("#txtDescription").val();
        var Instruction = $('#txtInstruction').val();
        var DueDate = $("#txtDueDate").val();
        var CmpId = $("#ddlCmpId").val();
        var BranchId = $("#ddlBranchId").val();
        var DepartmentId = $("#ddlDepartmentId").val();

        var EmployeeList = [];
        var table = $('#tblEmployees').DataTable();
        table.rows().nodes().to$()
            .find('.rowCheckbox:checked')
            .each(function () {
                EmployeeList.push({
                    IsActive: true,
                    EmployeeId: $(this).val()
                });
            });

        if (EmployeeList.length === 0) {
            Swal.fire({
                text: 'Please select at least one employee.',
                icon: 'info',
                allowOutsideClick: false
            });
            $(".Userloaderbg").hide();
            return false;
        }
        // First AJAX: check if document assignment exists
        $.ajax({
            type: "POST",
            url: '@Url.Action("IsDocumentAssignExists", "Module_Employee_DocumentAssignment")',
            data: JSON.stringify({
                DocAssignmentMasterId: DocAssignmentMasterId,
                DocNo: DocNo,
                DocDate: DocDate,
                AssignmentTitle: AssignmentTitle,
                Description: Description,
                Instruction: Instruction,
                DueDate: DueDate,
                CmpId: CmpId,
                BranchId: BranchId,
                DepartmentId: DepartmentId
            }),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                var data = JSON.parse(response);
                var Message1 = data.Message;
                var Icon1 = data.Icon;

                if (Icon1 === "error") {
                    if (Message1) {
                        Swal.fire({
                            icon: Icon1,
                            text: Message1
                        }).then(function () {
                            window.location.href = '@Url.Action("Module_Employee_DocumentAssignment", "Module_Employee_DocumentAssignment")';
                        });
                    }
                } else {
                    // Second AJAX: Save/Update
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("SaveUpdate", "Module_Employee_DocumentAssignment")',
                        data: JSON.stringify({
                            EmployeeList: EmployeeList,
                            DocAssignmentMasterId: DocAssignmentMasterId,
                            DocNo: DocNo,
                            DocDate: DocDate,
                            AssignmentTitle: AssignmentTitle,
                            Description: Description,
                            Instruction: Instruction,
                            DueDate: DueDate,
                            CmpId: CmpId,
                            BranchId: BranchId,
                            DepartmentId: DepartmentId
                        }),
                        contentType: "application/json; charset=utf-8",
                        dataType: "text",
                        success: function (response) {
                            var data = JSON.parse(response);
                            var Message1 = data.Message;
                            var Icon1 = data.Icon;

                            if (Icon1 && Message1) {
                                Swal.fire({
                                    icon: Icon1,
                                    text: Message1
                                }).then(function () {
                                    window.location.href = '@Url.Action("Module_Employee_DocumentAssignment", "Module_Employee_DocumentAssignment")';
                                });
                            }
                        }
                    });
                }
            }
        });
    });

    function BindEmployeeTable(data) {debugger

        let convertedData = {};

        Object.keys(data).forEach(key => {
            let flatObject = {};
            data[key].forEach(item => {
                flatObject[item.Key] = item.Value;
            });
            convertedData[key] = flatObject;
        });

        if ($.fn.DataTable.isDataTable('#tblEmployees')) {
            $('#tblEmployees').DataTable().destroy();
        }

        var tbody = $('#tblLoadEmployee');
        tbody.empty();

        Object.values(convertedData).forEach(d => {

            var checked = d.IsActive === 1 || d.IsActive === true ? 'checked' : '';

            var row = `<tr>
            <td class="text-center">
                <input type="checkbox" class="rowCheckbox" value="${d.EmployeeId}" id="chkIsActive_${d.EmployeeId}" ${checked}/>
            </td>
            <td hidden>${d.EmployeeId}</td>
            <td>${d.ShortName || ''}</td>
            <td>${d.BranchName || ''}</td>
            <td>${d.EmployeeName || ''}</td>
            <td>${d.DepartmentName || ''}</td>
            <td hidden>${d.CmpId || ''}</td>
            <td hidden>${d.BranchId || ''}</td>
            <td hidden>${d.DepartmentId || ''}</td>
        </tr>`;

            tbody.append(row);
        });

        $('#tblEmployees').DataTable({
            paging: true,
            searching: true,
            ordering: false
        });
    }
</script>