<script>
    document.getElementById('tblPartA').addEventListener('input', function (e) {
        if (e.target.classList.contains('validate-number')) {
            validateInput(e.target);
        }
    });

    document.getElementById('tblPartB').addEventListener('input', function (e) {
        if (e.target.classList.contains('validate-number')) {
            validateInput(e.target);
        }
    });

    document.getElementById('txtRateOTRate').addEventListener('input', function (e) {
        if (e.target.classList.contains('validate-number')) {
            validateInput(e.target);
        }
    });

    document.querySelectorAll('.validate-number').forEach(function (element) {
        element.addEventListener('input', function () {
            validateInput(this);
        });
    });


    function validateInput(input) {
        const regex = /^\d*\.?\d{0,2}$/; // Regex: digits, optional dot, and up to 2 decimal places.
        const value = input.value;
        if (!regex.test(value)) {
            input.value = value.slice(0, -1); // Remove the last invalid character
        }
    }
</script>

<script>
    function updateNextIncrementDate(monthsToAdd) {
        var fromDate = document.getElementById('txtFromDate').value;
        var nextIncrementDate = document.getElementById('txtNextIncrementDate');

        // If no checkbox is checked, do nothing
        if (monthsToAdd > 0 && fromDate) {
            var fromDateObj = new Date(fromDate);
            fromDateObj.setMonth(fromDateObj.getMonth() + monthsToAdd);

            // Update Next Increment Date field
            var nextDate = fromDateObj.toISOString().split('T')[0]; // Format as YYYY-MM-DD
            nextIncrementDate.value = nextDate;
        }
    }
</script>



