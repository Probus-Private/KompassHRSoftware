                                    </div>
                                </div>
                            </div>
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_CTCInfo", new { area = "Module" })' id="SaveCTCInformation">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                From Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.FromDate, null, new { @class = "form-control", type = "date", id = "txtFromDate" })
                                                @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                To Date
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.ToDate, null, new { @class = "form-control", type = "date", id = "txtToDate", onkeydown = "return false;", style = "background-color:#eee;", @readonly = "readonly" })
                                                @Html.ValidationMessage("ToDate", "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Category Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.CategoryId, new SelectList(ViewBag.CategoryName ?? new List<SelectListItem>(), "Id", "Name"), "--Select--", new { id = "ddlCategoryName", @class = "form-select", autocomplete = "off", name = "CategoryName" })
                                                @Html.ValidationMessage("CTC_CategoryId", "", new { @class = "help-block", id = "ErrorddlCategoryName", @style = "color:red" })
                                                @Html.HiddenFor(model => model.EmployeeCTCId_Encrypted, new { id = "hdnEncriptedId" })
                                                @Html.Hidden("Status", new { id = "hdnStatus" })
                                                @Html.Hidden("OBEmpId", Session["OnboardEmployeeId"], new { id = "hdnOBEmpId" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Monthly/Daily
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.DailyMonthly, new { id = "ddlDailyMonthly", @class = "form-control", autocomplete = "off", name = "DailyMonthly", style = "background-color:#eee;", @readonly = "readonly", Value = TempData["GetDailyOrMonthly"]?.ToString() ?? "" })

                                                @*@Html.DropDownListFor(model => model.DailyMonthly, new List<SelectListItem>
                                                    {
                                                    new SelectListItem { Text = "Monthly", Value = "Monthly" },
                                                    new SelectListItem { Text = "Daily", Value = "Daily" },
                                                    },
                                                    //"--Select--",
                                                    new { id = "ddlDailyMonthly", @class = "form-select", autocomplete = "off", name = "DailyMonthly" })*@
                                                @Html.ValidationMessage("DailyMonthly", "", new { @class = "help-block", id = "ErrortxtDailyMonthly", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Salary Transfer from Bank
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.RateCmpBankId, new SelectList(ViewBag.CompanyBankName ?? new List<SelectListItem>(), "Id", "Name"),
                                              //"--Select--",
                                              new { id = "ddlCompanyBankName", @class = "form-select", autocomplete = "off", name = "RateCmpBankId" })
                                                @Html.ValidationMessage("RateCmpBankId", "", new { @class = "help-block", id = "ErrorddlCompanyBankName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                Salary Mode
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.RateSalaryMode, new List<SelectListItem>
                                                {
                                                new SelectListItem { Text = "Bank-Salary", Value = "Bank-Salary" },
                                                new SelectListItem { Text = "Bank-NEFT", Value = "Bank-NEFT" },
                                                new SelectListItem { Text = "Cheque", Value = "Cheque" },
                                                new SelectListItem { Text = "Cash", Value = "Cash" },
                                                },
                                                //"--Select--",
                                                new { id = "ddlRateSalaryMode", @class = "form-select", autocomplete = "off", name = "RateSalaryMode" })
                                                @Html.ValidationMessage("RateSalaryMode", "", new { @class = "help-block", id = "ErrorddlRateSalaryMode", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                OT Rate
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.TextBoxFor(model => model.RateOTRate, new { @class = "form-control", type = "text", id = "txtRateOTRate", Value = 0, oninput = "validateInput(this)" })
                                                @Html.ValidationMessage("RateOTRate", "", new { @class = "help-block", id = "ErrortxtRateOTRate", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>



                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-4">
                                                CTC Budget
                                                <span class="important">*</span>
                                            </label>

                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.RateBudgetId, new SelectList(ViewBag.BudgetName ?? new List<SelectListItem>(), "Id", "Name"), "--Select--", new { id = "ddlCTCBudget", @class = "form-select", autocomplete = "off", name = "BudgetName" })
                                                @Html.ValidationMessage("RateBudgetId", "", new { @class = "help-block", id = "ErrorddlCTCBudget", @style = "color:red" })
                                            </div>

                                            @*<div class="col-md-7">
                                                    @Html.TextBoxFor(model => model.RateBudgetId, new { @class = "form-control", type = "text", id = "txtCTCBudget", Value = 0 })
                                                    @Html.ValidationMessage("RateBudgetId", "", new { @class = "help-block", id = "ErrortxtCTCBudget", @style = "color:red" })
                                                </div>*@
                                        </div>
                                    </div>
                                </div>


    <hr />


@{
    var list = ViewBag.GetCommonColumn as IEnumerable<dynamic>;
    int i = 0;
}

@if (list != null)
{
    <div class="row">
        @foreach (var item in list)
        {
            <div class="col-md-4 d-flex align-items-center mb-2">
                <label class="form-label me-2 mb-0 flex-shrink-0" style="min-width:120px">
                    @item.Heads
                </label>

                <input type="text"
                       name="RateValues[@i].Value"
                       class="form-control flex-grow-1"
                       value="0"
                       id="txt@(item.ID)" />

                <input type="hidden"
                       name="RateValues[@i].RateId"
                       value="@item.ID" />
            </div>
            i++;
        }
    </div>
}


<br />







                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <div class="col-md-12">
                                                <label class="form-label">PF : <span id="spnPF"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;
                                                <label class="form-label">ESIC : <span id="spnESIC"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;
                                                <label class="form-label">LWF : <span id="spnLWF"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;
                                                @*<label class="form-label">Gratuity : <span id="spnGratuity"></span> &nbsp; &nbsp; &nbsp; |</label> &nbsp; &nbsp;&nbsp;*@
                                                <label class="form-label">PT : <span id="spnPT"></span></label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6" hidden>
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-3">
                                                Template Name <span class="important">*</span>
                                            </label>
                                            <div class="col-md-7">
                                                @Html.DropDownListFor(model => model.TemplateId, new SelectList(ViewBag.TemplateName ?? new List<SelectListItem>(), "Id", "Name"), "--Select--", new { id = "ddlTemplateName", @class = "form-select", autocomplete = "off", name = "TemplateId", onchange = "onTemplateChange(this)" })
                                                @Html.ValidationMessage("TemplateId", "", new { @class = "help-block", id = "ErrorddlTemplateName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="row mb-15px">
                                        <div class="col-md-12">
                                            <div id="dynamicTables">
                                                <div class="row">
                                                    <!-- Part A -->
                                                    <div class="col-md-6">
                                                        <div class="table-responsive">
                                                            <h5 style="background-color:lightgray; padding: 5px;">Part A</h5>
                                                            <table class="table table-bordered" id="partATable">
                                                                <thead>
                                                                    <tr>
                                                                        <th style="width: 10%;">Sr.No</th> <!-- Set width -->
                                                                        <th hidden style="width: 10%;">ColumnName</th> <!-- Set width -->
                                                                        <th style="width: 60%;">Head Name</th> <!-- Set width -->
                                                                        <th style="width: 30%;">Amount</th> <!-- Set width -->
                                                                    </tr>
                                                                </thead>
                                                                <tbody id="tblPartA">
                                                                    @if (ViewBag.MappedHeadPartA != null)
                                                                    {
                                                                        int srNo = 1;
                                                                        foreach (var d in ViewBag.MappedHeadPartA)
                                                                        {
                                                                            <tr>
                                                                                <td>@srNo</td>
                                                                                <td hidden>@d.ID</td>
                                                                                <td style="text-align: left;">@d.Heads</td>
                                                                                <td><input type="text" Value=0 style="text-align: right;" class="form-control validate-number" name="value_@srNo" id="txt@(d.ID)"></td>
                                                                            </tr>
                                                                            srNo++;
                                                                        }
                                                                    }
                                                                </tbody>
                                                                <tfoot>
                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right"><b>Part A (Gross) Total =</b></td>
                                                                        <td><input type="text" Value=0 class="form-control validate-number" id="txtRateTotalPartA" readonly style="text-align: right; background-color:#eee"></td>
                                                                    </tr>
                                                                </tfoot>
                                                            </table>

                                                        </div>
                                                    </div>
                                                    <!-- Part B -->
                                                    <div class="col-md-6">
                                                        <div class="table-responsive">
                                                            <h5 style="background-color:lightgray;padding: 5px;">Part B</h5>
                                                            <table class="table table-bordered" id="partBTable">
                                                                <thead>
                                                                    <tr>
                                                                        <th style="width: 10%;">Sr.No</th> <!-- Set width -->
                                                                        <th hidden style="width: 10%;">ColumnName</th> <!-- Set width -->
                                                                        <th style="width: 60%;">Head Name</th> <!-- Set width -->
                                                                        <th style="width: 30%;">Amount</th> <!-- Set width -->
                                                                    </tr>
                                                                </thead>
                                                                <tbody id="tblPartB">
                                                                    @if (ViewBag.MappedHeadPartB != null)
                                                                    {
                                                                        int srNo = 1;
                                                                        foreach (var d in ViewBag.MappedHeadPartB)
                                                                        {
                                                                            <tr>
                                                                                <td>@srNo</td>
                                                                                <td hidden>@d.ID</td>
                                                                                <td style="text-align: left;">@d.Heads</td>
                                                                                <td><input type="text" Value=0 style="text-align: right;" class="form-control validate-number" name="value_@srNo" id="txt@(d.ID)"></td>
                                                                            </tr>
                                                                            srNo++;
                                                                        }
                                                                    }
                                                                </tbody>
                                                                <tfoot>
                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right"><b>Part B Total&nbsp;=&nbsp;</b></td>
                                                                        <td><input type="text" Value=0 class="form-control validate-number" id="txtRateTotalPartB" readonly style="text-align: right; background-color:#eee"></td>
                                                                    </tr>
                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right"><b>CTC (A + B)&nbsp;=&nbsp;</b></td>
                                                                        <td><input type="text" Value=0 class="form-control validate-number" id="txtRateTotalPartAB" readonly style="text-align: right;background-color:#eee"></td>
                                                                    </tr>
                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right"><b>VPF Amount &nbsp;&nbsp;</b></td>
                                                                        <td><input type="text" Value=0 class="form-control validate-number" style="text-align: right;" id="txtRate_VPF"></td>
                                                                    </tr>

                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right"><b>Employee PF &nbsp;&nbsp;</b></td>
                                                                        <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_PF"></td>
                                                                    </tr>
                                                                    <tr>
                                                                        <td colspan="2" style="text-align:right"><b>Employee ESIC &nbsp;&nbsp;</b></td>
                                                                        <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_ESIC"></td>
