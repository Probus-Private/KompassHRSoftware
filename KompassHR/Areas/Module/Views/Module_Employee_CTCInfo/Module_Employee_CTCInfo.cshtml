<script type="text/javascript">
    function calculateFunction() {
        debugger;
        var StartDate = $("#txtFromDate").val();
        var DailyMonthly = $("#ddlDailyMonthly").val();
        var OBEmployeeId = $("#hdnOBEmpId").val();
        let partAData = {};
        $('#partATable tbody tr').each(function () {
            let headName = $(this).find('td:eq(1)').text().trim();
            let value = $(this).find('input[type="text"]').val().trim();
            if (headName) {
                partAData[headName] = value;
            }
        });
        var partATotal = $("#txtRateTotalPartA").val();

        // Create request payload
        let requestData1 = {
            data1: { partA: partAData },
            FromDate: StartDate,
            DailyMonthly: DailyMonthly,
            partATotal: partATotal
        };

        console.log(requestData1);

        $.ajax({
            url: '@Url.Action("CalculateDatas", "Module_Employee_CTCInfo", new { area = "Module" })',
            type: 'POST',
            data: JSON.stringify(requestData1),
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response)
            {
                debugger;
                var json = JSON.parse(response);
                // Access the innermost array within GetCalculte
                const transformed = {
                    GetCalculte: Object.fromEntries(
                        json.GetCalculte[0].map(item => [item.Key, item.Value]) // Properly map Key and Value
                    )
                };
                // Access the transformed data
                var GetData = transformed.GetCalculte;
                if (GetData) {
                    $("#txtRatePartB_PFEmployer").val(GetData.RatePartB_PFEmployer != null ? GetData.RatePartB_PFEmployer : 0);
                    $("#txtRatePartB_ESICEmployer").val(GetData.RatePartB_ESICEmployer != null ? GetData.RatePartB_ESICEmployer : 0);
                    $("#txtRatePartB_Gratuity").val(GetData.RatePartB_Gratuity != null ? GetData.RatePartB_Gratuity : 0);
                    $("#txtRatePartB_A").val(GetData.RatePartB_A != null ? GetData.RatePartB_A : 0);

                    $("#txtRatePartB_PF").val(GetData.RatePartB_PFEmployee != null ? GetData.RatePartB_PFEmployee : 0);
                    $("#txtRatePartB_ESIC").val(GetData.RatePartB_ESICEmployee != null ? GetData.RatePartB_ESICEmployee : 0);
                    $("#txtRatePartB_PT").val(GetData.tb_SalaryDed_PTAmt != null ? GetData.tb_SalaryDed_PTAmt : 0);

                    $("#txtRate_NetPay").val(GetData.Rate_NetPay != null ? GetData.Rate_NetPay : 0);
                }

                //var GetData = transformed.GetCalculte;
                //$("#txtRatePartB_PFEmployer").val(GetData.RatePartB_PFEmployer);
                //$("#txtRatePartB_ESICEmployer").val(GetData.RatePartB_ESICEmployer);
                //$("#txtRatePartB_Gratuity").val(GetData.RatePartB_Gratuity);
                //$("#txtRatePartB_A").val(GetData.RatePartB_A);

                //var pf = $("#txtRatePartB_PF").val(GetData.RatePartB_PFEmployee);
                //var esic = $("#txtRatePartB_ESIC").val(GetData.RatePartB_ESICEmployee);
                //var pt = $("#txtRatePartB_PT").val(GetData.tb_SalaryDed_PTAmt);
                //$("#txtRate_NetPay").val(GetData.Rate_NetPay);
                $("#ChkRatePartB_AttendanceBonus_IsApplicable").prop("checked", GetData.RatePartB_AttendanceBonus_IsApplicable == 1);

                // Parse values for calculation
                var pf = parseFloat(GetData.RatePartB_PFEmployee) || 0;
                var esic = parseFloat(GetData.RatePartB_ESICEmployee) || 0;
                var pt = parseFloat(GetData.tb_SalaryDed_PTAmt) || 0;

                let MLWF = Number($("#txtRatePartB_MLWF").val());
                let GetHead_A =Number($("#txtRatePartB_Head_A").val());
                let GetHead_B = Number($("#txtRatePartB_Head_B").val());

                var RateTotalPartA = parseFloat($('#txtRateTotalPartA').val()) || 0;
                // Calculate Net Pay
                var netPay = RateTotalPartA - (pf + esic + pt + MLWF + GetHead_A + GetHead_B );
                $('#txtRate_NetPay').val(netPay);

                calculatePartBTotal();
                updateOverallTotal();
                if (response!= null) {
                    debugger;
                }
                else {
                    alert(response.message || "An error occurred.");
                }
            },
            error: function (xhr, status, error) {
                debugger;
                alert(response.Message || "An error occurreds.");
            }
        });
    }

</script>

<script>
    // Attach input change event for Part A inputs
    $('#partATable tbody').on('input', 'input[type="text"]', function () {
        calculatePartATotal();
    });
    // Attach input change event for Part B inputs
    $('#partBTable tbody input[type="text"]').on('input', function () {
        calculatePartBTotal();
    });

    // Function to calculate the total for Part A
    function calculatePartATotal() {
        let total = 0;
        $('#partATable tbody input[type="text"]').each(function () {
            let value = parseFloat($(this).val()) || 0; // Parse value or use 0 if NaN
            total += value;
        });

        $('#txtRateTotalPartA').val(total); // Set total value in the Total field

        // Update the overall total
        updateOverallTotal();
    }

    // Function to calculate the total for Part B
    function calculatePartBTotal() {
        let total = 0;

        $('#partBTable tbody input[type="text"]').each(function () {
            let value = parseFloat($(this).val()) || 0;
            total += value;
        });

        $('#txtRateTotalPartB').val(total); // Set total value in the Total field

        // Update the overall total
        updateOverallTotal();
    }

    // Function to update the overall total of Part A and Part B
    function updateOverallTotal() {
        let partATotal = parseFloat($('#txtRateTotalPartA').val()) || 0;
        let partBTotal = parseFloat($('#txtRateTotalPartB').val()) || 0;
        let overallTotal = partATotal + partBTotal;

        $('#txtRateTotalPartAB').val(overallTotal); // Set total value in the overall Total field
    }
</script>

