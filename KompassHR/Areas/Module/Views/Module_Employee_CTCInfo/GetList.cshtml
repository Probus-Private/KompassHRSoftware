<script>
    var CheckEmpInStatutory = @Html.Raw(Json.Encode(TempData["CheckEmpInStatutory"]));

    $('#btnAddEmpCTC').click(function () {
        debugger;
        if (CheckEmpInStatutory<1) {
            Swal.fire({
                icon: "error",
                text: "Please add statutory compliances details for this employee",
                allowOutsideClick: false,
                didOpen: () => {
                    const popup = Swal.getPopup();
                    popup.classList.add('animate__animated', 'animate__headShake');
                    setTimeout(() => popup.classList.remove('animate__headShake'), 500);
                }
            });
            return  false;
        }
        var obEmployeeId = $("#hdnOBEmpId").val();
        var url = '@Url.Action("Module_Employee_CTCInfo", "Module_Employee_CTCInfo")?obEmployeeId=' + obEmployeeId;
        window.location.href = url;

        @*var url = '@Url.Action("Module_Employee_CTCInfo", "Module_Employee_CTCInfo", new { area = "Module" })';
        window.location.href = url;*@
    });
</script>



