
@{
    ViewBag.Title = "GetList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/bower_components/moment/moment.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>



<style>
    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        background-color: transparent;
        color: #000;
        font-size: 15px !important;
        padding: 5px 8px !important;
        border: none;
    }

        .ListBtn:hover {
            background-color: transparent;
            color: #000;
        }

            .ListBtn:hover i {
                transition: all 0.5s;
                transform: scale(1.5);
            }

    .box2 {
        text-align: center;
        position: relative;
        z-index: 0;
        margin-bottom: 10px;
    }

        .box2 .info {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .box2 .imgbx {
            width: 80px;
            height: 80px;
            padding: 5px 0px;
            font-family: Open Sans,sans-serif;
            border: 1px solid #dedede;
            border-radius: 20px;
            box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: center;
            align-items: center;
        }

            /*.box2:hover {
            border: 2px solid #ff9c19;
            border-radius: 10px;
            cursor: pointer;
            transform: translateY(-10px);

        }*/
            .box2 .imgbx img {
                width: 50px;
                height: 50px;
                filter: brightness(1.2);
            }

        .box2:hover .info i {
            color: #ff9c19;
        }


        .box2 .info i {
            width: 100%;
            text-align: center;
            margin-bottom: 5px;
            color: #007bff;
        }

        .box2 .info h7 {
            position: relative;
            text-align: center;
            display: flex;
            justify-content: center;
            color: #000;
            text-transform: capitalize;
            margin-top: 5px;
        }

    /*.div1 td:nth-child(1) {
        position: sticky;
        left: 0;
    }*/

    /*.div1 td:nth-child(2) {
        position: sticky;
        left: 62px;
    }*/

    /*.fixed-side {
        position: sticky;
        left: 0px;
    }*/

    /*.fixed-side1 {
        position: sticky;
        left: 62px;
    }*/
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .empbx h4 {
        margin-bottom: 5px;
    }

    .empbx h6 i {
        font-size: 1rem;
        margin-right: 5px;
    }

    .empbx {
        margin-bottom: 20px;
    }

    #partATable input[type="text"] {
        height: 25px; /* Adjust the height as needed */
    }

    #partBTable input[type="text"] {
        height: 25px; /* Adjust the height as needed */
    }
</style>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Payroll CTC List</title>
</head>
<body>
    <div id="content" class="app-content">
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
                <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                    Payroll CTC List
                </h1>
                <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                    <li style="margin-right: 10px;">
                        <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                            <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new {id = 3, ScreenId=142, area = "Module" })">
                            <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                        </a>
                    </li>
                </ol>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <!-- BEGIN panel -->
                <div class="panel panel-inverse" data-sortable-id="index-1">
                    <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                        <h4 class="panel-title">Payroll CTC - List</h4>
                        @*<div class="panel-heading-btn">
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                                <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                            </div>*@
                    </div> <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                        <p class="pb-0">
                            Detailed list of payroll employee CTC.
                        </p>
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="empbx">
                                    <span>
                                        <h4> <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"] </h4>
                                    </span>
                                    <span>
                                        <h6> <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"] </h6>
                                    </span>
                                    <span>
                                        <h6> <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"] </h6>
                                    </span>
                                    <hr>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-15px">
                            <div class="col-md-12">
                                <div class="d-flex justify-content-start">
                                    <button type="button" data-bs-toggle="offcanvas" href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn btnpress ListBtn me-2">
                                        <i class="fa-solid fa-list"></i>
                                    </button>

                                    <button type="button" class="btn btn-primary btn-sm me-2" id="btnAddEmpCTC">
                                        <i class="fas fa-external-link-alt"></i> Add
                                    </button>

                                    <button type="button" class="btn btn-success btn-sm" id="btnIncrement">
                                        @*style="display:none"*@
                                        <i class="fa fa-inr fa-xl"></i> Increment
                                        @Html.Hidden("OBEmpId", Session["OnboardEmployeeId"], new { id = "hdnOBEmpId" })
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <!-- BEGIN table-responsive -->
                                <div class="table-scroll div1">
                                    <div class="table-wrap">
                                        <table class="table table-bordered align-middle TablePage1" id="tblCTCEmployee" style="width: 100%;">
                                            <thead>
                                                <tr class="trheading">
                                                    <th class="text-center">Update</th>
                                                    <th class="text-center">View</th>
                                                    @*<th class="text-center">CTCEmployeeId</th>*@
                                                    <th class="text-center">From Date</th>
                                                    <th class="text-center">To Date</th>
                                                    <th class="text-center">Is-Increment</th>
                                                    <th class="text-center">CTC</th>
                                                    @*<th class="text-center">RateOTRate</th>*@
                                                    <th class="text-center">Category Name</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblCTCBody">
                                                @foreach (var d in ViewBag.GetEmployeeCTCList)
                                                {
                                                    <tr>
                                                        @if (d.ToDate.Year == 2999)
                                                        {
                                                            <td class="text-center">
                                                                <i class="fa-solid fa-pen-to-square fa-lg text-Dark" style="cursor: pointer;" onclick="UpdateRow('@d.EmployeeCTCId_Encrypted')" id="btnUpdate"></i>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td class="text-center">
                                                                <i class="fa-solid fa-xmark fa-xl" style="color: red; display:inline-block; cursor: pointer;"></i>
                                                            </td>
                                                        }

                                                        <td class="text-center">
                                                            <i class="fa-solid fa-eye fa-lg" style="color: #f59c1a; cursor: pointer;" id="btnView" data-ctc-id="@d.EmployeeCTCId_Encrypted"></i>

                                                            @*<i  class="fa-solid fa-eye fa-lg" style="color: #f59c1a;" onclick="GetEmpCTCDetails('@d.EmployeeCTCId_Encrypted')" id="btnUpdate"></i>*@
                                                        </td>
                                                        @*<td>@d.CTCEmployeeId</td>*@
                                                        <td>@d.FromDate.ToString("dd-MM-yyyy")</td>
                                                        <td>@d.ToDate.ToString("dd-MM-yyyy")</td>
                                                        <td>@(d.IsIncrement ? "Yes" : "No")</td>
                                                        <td>@d.RateTotalPartAB</td>
                                                        @*<td>@d.DailyMonthly</td>*@
                                                        @*<td>@d.RateOTRate</td>*@
                                                        <td>@d.CategoryName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</body>
</html>

<!-- #Start Appprove Reject Modal -dialog -->
<div class="modal fade" id="myModalFinal" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Employee CTC Details</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger btnClear" data-bs-dismiss="modal" aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="row mb-15px">
                                    <div class="col-md-6" style="display: flex; align-items: center;">
                                        <label for="txtFromDate" class="form-label" style="margin-right: -6px;width:150px;">From Date</label>
                                        @Html.TextBox("FromDate", null, new { @class = "form-control", type = "date", id = "txtFromDate", style = "flex: 1; width: auto;", @readonly = "readonly" }) &nbsp;&nbsp;
                                        @Html.ValidationMessage("FromDate", "", new { @class = "help-block", id = "ErrortxtFromDate", @style = "color:red" })
                                    </div>
                                    <div class="col-md-6" style="display: flex; align-items: center;">
                                        <label for="txtToDate" class="form-label" style="margin-right: 10px;width:110px;">To Date</label>
                                        @Html.TextBox("ToDate", null, new { @class = "form-control", type = "date", id = "txtToDate", style = "flex: 1; width: auto;", @readonly = "readonly" })
                                        @Html.ValidationMessage("ToDate", "", new { @class = "help-block", id = "ErrortxtToDate", @style = "color:red" })
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="row mb-15px">
                                    <div class="col-md-6" style="display: flex; align-items: center;">
                                        <label for="txtOTRate" class="form-label" style="margin-right: 63px;width:150px;">OT Rate</label>
                                        @Html.TextBox("RateOTRate", null, new { @class = "form-control", type = "text", id = "txtRateOTRate", @readonly = "readonly" }) &nbsp;&nbsp;
                                        @Html.ValidationMessage("RateOTRate", "", new { @class = "help-block", id = "ErrortxtRateOTRate", @style = "color:red" })
                                    </div>
                                    <div class="col-md-6" style="display: flex; align-items: center;">
                                        <label for="txtToDate" class="form-label" style="margin-right: 25px;width:150px;">Category Name</label>
                                        @Html.DropDownList("CategoryId", new SelectList(ViewBag.CategoryName ?? new List<SelectListItem>(), "Id", "Name"), "--Select--", new { id = "ddlCategoryName", @class = "form-select", autocomplete = "off", name = "CategoryName", style = "background-color:#fff", @disabled = "disabled" })
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="row mb-15px">
                                    <div class="col-md-6" style="display: flex; align-items: center;">
                                        <label for="txtOTRate" class="form-label" style="margin-right: 65px;width:150px;">Monthly/Daily</label>
                                        @Html.DropDownList("DailyMonthly", new List<SelectListItem>
                                          {
                                              new SelectListItem { Text = "Monthly", Value = "Monthly" },
                                              new SelectListItem { Text = "Daily", Value = "Daily" },
                                          },
                                          //"--Select--",
                                          new { id = "ddlDailyMonthly", @class = "form-select", autocomplete = "off", name = "DailyMonthly", @readonly = "readonly", style = "background-color:#fff", @disabled = "disabled" })
                                    </div>
                                </div>
                                @{

                                }
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div id="dynamicTables">
                                            <div class="row">
                                                <!-- Part A -->
                                                <div class="col-md-6">
                                                    <div class="table-responsive">
                                                        <h5 style="background-color:lightgray; padding: 5px;">Part A</h5>
                                                        <table class="table table-bordered" id="partATable">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 10%;">Sr.No</th> <!-- Set width -->
                                                                    <th hidden style="width: 10%;">ColumnName</th> <!-- Set width -->
                                                                    <th style="width: 60%;">Head Name</th> <!-- Set width -->
                                                                    <th style="width: 30%;">Amount</th> <!-- Set width -->
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblPartA">
                                                                @if (ViewBag.MappedHeadPartA != null)
                                                                {
                                                                    int srNo = 1;
                                                                    foreach (var d in ViewBag.MappedHeadPartA)
                                                                    {
                                                                        <tr>
                                                                            <td>@srNo</td>
                                                                            <td hidden>@d.ID</td>
                                                                            <td style="text-align: left;">@d.Heads</td>
                                                                            <td><input type="text" style="text-align: right;" class="form-control validate-number" name="value_@srNo" id="txt@(d.ID)" readonly></td>
                                                                        </tr>
                                                                        srNo++;
                                                                    }
                                                                }
                                                            </tbody>
                                                            <tfoot>
                                                                <tr>
                                                                    <td colspan="2"><b>Part A (Gross) Total =</b></td>
                                                                    <td><input type="text" class="form-control validate-number" id="txtRateTotalPartA" readonly style="text-align: right; background-color:#eee"></td>
                                                                </tr>
                                                            </tfoot>
                                                        </table>

                                                    </div>
                                                </div>
                                                <!-- Part B -->
                                                <div class="col-md-6">
                                                    <div class="table-responsive">
                                                        <h5 style="background-color:lightgray;padding: 5px;">Part B</h5>
                                                        <table class="table table-bordered" id="partBTable">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 10%;">Sr.No</th> <!-- Set width -->
                                                                    <th hidden style="width: 10%;">ColumnName</th> <!-- Set width -->
                                                                    <th style="width: 60%;">Head Name</th> <!-- Set width -->
                                                                    <th style="width: 30%;">Amount</th> <!-- Set width -->
                                                                </tr>
                                                            </thead>
                                                            <tbody id="tblPartB">
                                                                @if (ViewBag.MappedHeadPartB != null)
                                                                {
                                                                    int srNo = 1;
                                                                    foreach (var d in ViewBag.MappedHeadPartB)
                                                                    {
                                                                        <tr>
                                                                            <td>@srNo</td>
                                                                            <td hidden>@d.ID</td>
                                                                            <td style="text-align: left;">@d.Heads</td>
                                                                            <td><input type="text" style="text-align: right;" class="form-control validate-number" name="value_@srNo" id="txt@(d.ID)" readonly></td>
                                                                        </tr>
                                                                        srNo++;
                                                                    }
                                                                }
                                                            </tbody>
                                                            <tfoot>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Part B Total =</b></td>
                                                                    <td><input type="text" class="form-control validate-number" id="txtRateTotalPartB" readonly style="text-align: right; background-color:#eee" readonly></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>CTC (A + B)</b></td>
                                                                    <td><input type="text" class="form-control validate-number" id="txtRateTotalPartAB" readonly style="text-align: right;background-color:#eee" readonly></td>
                                                                </tr>

                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>VPF Amount &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" style="text-align: right;" id="txtRate_VPF"></td>
                                                                </tr>

                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Employee PF &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" readonly style="text-align: right;" id="txtRatePartB_PF"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Employee ESIC &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" readonly style="text-align: right;" id="txtRatePartB_ESIC"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>PT &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" readonly style="text-align: right;" id="txtRatePartB_PT"></td>
                                                                </tr>

                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>LWF &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_MLWF"></td>
                                                                </tr>
                                                                <tr style="@(TempData["CTC_RatePartB_Head_A"] == "" ? "display:none;" : "")">
                                                                    <td colspan="2" style="text-align:right"><b>@TempData["CTC_RatePartB_Head_A"] &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_Head_A"></td>
                                                                </tr>
                                                                <tr style="@(TempData["CTC_RatePartB_Head_B"] == "" ? "display:none;" : "")">
                                                                    <td colspan="2" style="text-align:right"><b>@TempData["CTC_RatePartB_Head_B"] &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number NetPay" style="text-align: right;" id="txtRatePartB_Head_B"></td>
                                                                </tr>

                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Net Pay &nbsp;&nbsp;</b></td>
                                                                    <td><input type="text" Value=0 class="form-control validate-number" readonly style="text-align: right;background-color:#eee" id="txtRate_NetPay"></td>
                                                                </tr>
                                                                <tr>
                                                                    <td colspan="2" style="text-align:right"><b>Attendance Bonus &nbsp;&nbsp;</b></td>
                                                                    <td><input type="checkbox" class="form-check-input" id="ChkRatePartB_AttendanceBonus_IsApplicable"></td>
                                                                </tr>
                                                            </tfoot>
                                                        </table>

                                                    </div>
                                                </div>
                                            </div>


                                            <div class="row">
                                                <div class="col-md-12">
                                                    <div class="d-flex align-items-center">
                                                        <label>Next Increment</label>
                                                        <div class="ms-3">
                                                            @Html.TextBox("NextIncrementDate", null, new { @class = "form-control", type = "date", id = "txtNextIncrementDate", style = "width: 120px; background-color:#eee", onkeydown = "return false;", @readonly = "readonly" })
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @*<div class="modal-footer">
                    <button type="button" id="btnCancel" class="btn btn-danger btnpress CloseModel" data-bs-dismiss="modal">
