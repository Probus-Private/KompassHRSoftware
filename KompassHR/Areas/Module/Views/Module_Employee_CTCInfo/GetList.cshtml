<script>
    $(document).ready(function () {
        debugger;
        $('td:contains("No data available in table")').parent().remove();
        var tableBody = document.getElementById("tblCTCEmployee");

        if (tableBody.rows.length-1 === 0) {
            btnAddEmpCTC.style.display = "block";  // Show
            btnIncrement.style.display = "none";  // hide
        }
        else {
            btnAddEmpCTC.style.display = "none";  // hide
            btnIncrement.style.display = "block";  // hide
        }
        //var rows = $("#tblCTCEmployee tbody tr");
        //rows.each(function (index) {
        //    var $btnEdit = $(this).find("#btnEdit");
        //    var $icon = $(this).find(".fa-pen-to-square");

        //    if (index === rows.length - 1) {
        //        $icon.css("display", "inline-block") // Ensure the update icon is visible
        //             .removeClass("fa-eye") // Remove any previous class that may conflict
        //             .off("click change"); // Remove any event handlers (cleanup)
        //    } else {
        //        $icon.removeClass("fa-pen-to-square") // Remove the edit class
        //             .addClass("fa-solid fa-xmark") // Add the view-only class
        //            .prop("onclick", null)
        //             .css({
        //                 "display": "inline-block",
        //                 "color": "red"
        //             });

        //    }
        //});

        debugger;
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != "") {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }

        $(document).on('click', '#btnView', function () {
            var employeeCTCIdEncrypted = $(this).data('ctc-id');
            GetEmpCTCDetails(employeeCTCIdEncrypted);
        });

        function GetEmpCTCDetails(EmployeeCTCId_Encrypted) {
            debugger
            $.ajax({
                type: 'GET',
                dataType: 'text', // Expecting JSON response from server
                url: '@Url.Action("GetEmployeeCTCDetails", "Module_Employee_CTCInfo")',
                data: { EmployeeCTCId_Encrypted: EmployeeCTCId_Encrypted },
                success: function (response) {
                    debugger;
                    $("#myModalFinal").modal('show');
                    const json = JSON.parse(response);
                    const transformed = {
                        GetEmpCTC: Object.fromEntries(
                            json.GetEmpCTC.map(item =>[item.Key, item.Value])
                        )
                    };

                    var GetData = transformed.GetEmpCTC;
                    var FromDate = convertDate(GetData.FromDate);
                    var ToDate = convertDate(GetData.ToDate);
                    $("#txtFromDate").val(FromDate);
                    $("#txtToDate").val(ToDate);
                    $("#ddlCategoryName").val(GetData.CategoryId);
                    $("#txtRateOTRate").val(GetData.RateOTRate);
                    $("#txtRatePartA_Basic").val(GetData.RatePartA_Basic);
                    $("#txtRatePartA_DA").val(GetData.RatePartA_DA);
                    $("#txtRatePartA_HRA").val(GetData.RatePartA_HRA);
                    $("#txtRatePartA_A").val(GetData.RatePartA_A);
                    $("#txtRatePartA_B").val(GetData.RatePartA_B);
                    $("#txtRatePartA_C").val(GetData.RatePartA_C);
                    $("#txtRatePartA_D").val(GetData.RatePartA_D);
                    $("#txtRatePartA_E").val(GetData.RatePartA_E);
                    $("#txtRatePartA_F").val(GetData.RatePartA_F);
                    $("#txtRatePartA_G").val(GetData.RatePartA_G);
                    $("#txtRatePartA_H").val(GetData.RatePartA_H);
                    $("#txtRatePartA_I").val(GetData.RatePartA_I);
                    $("#txtRatePartA_J").val(GetData.RatePartA_J);
                    $("#txtRatePartA_K").val(GetData.RatePartA_K);
                    $("#txtRatePartA_L").val(GetData.RatePartA_L);
                    $("#txtRatePartA_M").val(GetData.RatePartA_M);
                    $("#txtRatePartA_N").val(GetData.RatePartA_N);
                    $("#txtRatePartA_O").val(GetData.RatePartA_O);
                    $("#txtRatePartA_P").val(GetData.RatePartA_P);
                    $("#txtRatePartA_Q").val(GetData.RatePartA_Q);
                    $("#txtRatePartA_R").val(GetData.RatePartA_R);
                    $("#txtRatePartA_S").val(GetData.RatePartA_S);
                    $("#txtRatePartA_T").val(GetData.RatePartA_T);

                    $("#txtRatePartB_PFEmployer").val(GetData.RatePartB_PFEmployer);
                    $("#txtRatePartB_ESICEmployer").val(GetData.RatePartB_ESICEmployer);
                    $("#txtRatePartB_LWFEmployer").val(GetData.RatePartB_LWFEmployer);
                    $("#txtRatePartB_Bonus").val(GetData.RatePartB_Bonus);
                    $("#txtRatePartB_Gratuity").val(GetData.RatePartB_Gratuity);
                    $("#txtRatePartB_A").val(GetData.RatePartB_A);
                    $("#txtRatePartB_B").val(GetData.RatePartB_B);
                    $("#txtRatePartB_C").val(GetData.RatePartB_C);
                    $("#txtRatePartB_D").val(GetData.RatePartB_D);
                    $("#txtRatePartB_E").val(GetData.RatePartB_E);
                    $("#txtRateTotalPartA").val(GetData.RateTotalPartA);
                    $("#txtRateTotalPartB").val(GetData.RateTotalPartB);

                    $("#txtRateTotalPartAB").val(GetData.RateTotalPartA + GetData.RateTotalPartB);

                    var NextIncrementDate = convertDate(GetData.NextIncrementDate);
                    $("#txtNextIncrementDate").val(NextIncrementDate);
                    $("#txtRemark").val(GetData.Remark);


                    $("#txtRatePartB_PF").val(GetData.RatePartB_PFEmployee);
                    $("#txtRatePartB_ESIC").val(GetData.RatePartB_ESICEmployee);
                    $("#txtRatePartB_PT").val(GetData.RatePartB_PTEmployee);

                    $("#txtRatePartB_MLWF").val(GetData.RatePartB_MLWF != null ? GetData.RatePartB_MLWF : 0);
                    $("#txtRatePartB_Head_A").val(GetData.RatePartB_Head_A != null ? GetData.RatePartB_Head_A : 0);
                    $("#txtRatePartB_Head_B").val(GetData.RatePartB_Head_B != null ? GetData.RatePartB_Head_B : 0);


                    var MLWF = parseInt($('#txtRatePartB_MLWF').val()) || 0;
                    var GetHead_A = parseInt($('#txtRatePartB_Head_A').val()) || 0;
                    var GetHead_B = parseInt($('#txtRatePartB_Head_B').val()) || 0;


                    //$("#txtRate_NetPay").val(GetData.Rate_NetPay);
                    $("#ChkRatePartB_AttendanceBonus_IsApplicable").prop("checked", GetData.RatePartB_AttendanceBonus_IsApplicable == 1);
                    // Parse values for calculation
                    var pf = parseInt(GetData.RatePartB_PFEmployee) || 0;
                    var esic = parseInt(GetData.RatePartB_ESICEmployee) || 0;
                    var pt = parseInt(GetData.RatePartB_PTEmployee) || 0;
                    var RateTotalPartA = parseInt($('#txtRateTotalPartA').val()) || 0;

                    // Calculate Net Pay
                    var netPay = RateTotalPartA - (pf + esic + pt + MLWF + GetHead_A + GetHead_B);
                    $('#txtRate_NetPay').val(netPay);
                },
            });
        }

    });
</script>

