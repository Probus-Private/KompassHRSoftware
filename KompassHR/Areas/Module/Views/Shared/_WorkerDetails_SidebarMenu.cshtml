            $("#Bond_NotSubmit").show();
            $("#Bond_Submit").hide();

            $("#UploadDocument_NotSubmit").show();
            $("#UploadDocument_Submit").hide();

            $("#GeneralReporting_NotSubmit").show();
            $("#GeneralReporting_Submit").hide();
        }
        else{
            var ListLength=List[0].length;
            for (var i = 0; i < ListLength; i++) {
                var SetUpValue = List[0][i].Value;
                var SetUpkey = List[0][i].Key;
                if (SetUpkey=="SetupAdmin") {
                    if (SetUpValue == true)
                    {
                        $("#Admin_Submit").show();
                        $("#Admin_NotSubmit").hide();
                    }
                    else
                    {
