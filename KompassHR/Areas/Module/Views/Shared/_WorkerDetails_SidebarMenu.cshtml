            $("#Assets_Submit").hide();

            $("#Insurance_NotSubmit").show();
            $("#Insurance_Submit").hide();

            $("#MedicalHistory_NotSubmit").show();
            $("#MedicalHistory_Submit").hide();

            $("#Address_NotSubmit").show();
            $("#Address_Submit").hide();

            $("#Bank_NotSubmit").show();
            $("#Bank_Submit").hide();

            $("#Reference_NotSubmit").show();
            $("#Reference_Submit").hide();

            $("#Family_NotSubmit").show();
            $("#Family_Submit").hide();

