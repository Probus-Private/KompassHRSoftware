                    }
                    else {
                        $("#ESS_NotSubmit").show();
                        $("#ESS_Submit").hide();
                    }
                }

                if (SetUpkey=="SetupBank") {
                    if (SetUpValue == true) {
                        $("#Bank_Submit").show();
                        $("#Bank_NotSubmit").hide();
                    }
                    else {
                        $("#Bank_NotSubmit").show();
                        $("#Bank_Submit").hide();
                    }
                }
                if (SetUpkey=="SetupStatutory") {
                    if (SetUpValue == true) {
                        $("#Statutory_Submit").show();
                        $("#Statutory_NotSubmit").hide();
                    }
                    else {
                        $("#Statutory_NotSubmit").show();
                        $("#Statutory_Submit").hide();
                    }
                }
                if (SetUpkey=="SetupFamily") {
                    if (SetUpValue == true) {
                        $("#Family_Submit").show();
