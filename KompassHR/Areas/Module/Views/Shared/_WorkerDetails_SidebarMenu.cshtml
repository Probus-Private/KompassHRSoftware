                    }
                }

                if (SetUpkey=="SetupUploadDocument") {
                    if (SetUpValue == true) {
                        $("#UploadDocument_Submit").show();
                        $("#UploadDocument_NotSubmit").hide();
                    }
                    else {
                        $("#UploadDocument_NotSubmit").show();
                        $("#UploadDocument_Submit").hide();
                    }
                }
            }
        }

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Message != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        return false
                    }
                });
            }
        }
    });
</script>