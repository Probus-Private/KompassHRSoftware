<script>
    $(document).ready(function () {
        $("#txtEmployeeDepartmentID").select2();
        $("#ddlEmployeeSubDepartmentName").select2();
        $("#txtEmployeeDesignationID").select2();
        $("#txtEmployeeUnit").select2();
        $("#txtComapnyName").select2();
        $("#txtBankBranchName").select2();
        $("#ddlContractorID").select2();
        $("#ddlEmployeeCriticalStageID").select2();
        $("#ddlEM_Atten_ShiftGroupId").select2();
        $("#ddlEM_Atten_ShiftRuleId").select2();
        $("#ddlLineMasterID").select2();
        $("#ddlEmployeeGradeID").select2();
        $("#ddlEmployeeLevelID").select2();
        $("#ddlEmployeeQualificationID").select2();
        $("#ddlEmployeeAllocationCategoryId").select2();
        $("#ddlPF_FSType").select2();
        //$(".DivHidden").hide();

        $("#DivHiddenLeavingDate").hide();

        $("#txtEmployeeNo").on("keyup", function () {
            debugger;
            var EmployeeNumber= $("#txtEmployeeNo").val();
            $("#txtEmployeeCardNo").val(EmployeeNumber);

        });

        $("#txtComapnyName").on("change", function () {
            debugger;
            $("#txtBankBranchName").find("option").remove();

            var CmpId = $("#txtComapnyName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Employee_AddWorkers", new { area = "Module" })',
                data: { CmpId: CmpId },
                success: function (data) {
                    if (data != null) {
                        $("#txtEmployeeUnit").find("option").remove();
                        $("#ddlLineMasterID").find("option").remove();
                        $("#ddlContractorID").find("option").remove();
                        $("#ddlEM_Atten_ShiftRuleId").find("option").remove();
                        $("#ddlEM_Atten_ShiftGroupId").find("option").remove();
                        var BusinessUnit = data.BusinessUnit;
                        var UnitName = data.Masunit;
                        var List_LineMaster = data.MasLineMasterit;
                        var ShiftGroupFName = data.AttenShiftGroups;
                        var ShiftRuleName = data.AttenShiftRule;
                        var GetContractorDropdown = data.GetContractorDropdown;
                        var EmployeeAllocationCategory= data.EmployeeAllocationCategory;
                        //$("#txtBankBranchName").append("<option value=0>--Select-- </option>");
                        $.each(BusinessUnit, function (i, p) {
                            $("#txtBankBranchName").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                        });
                        //var GetDesignationNameId= data.GetDesignationName;
                        if (UnitName != null) {
                            //$("#txtEmployeeUnit").append("<option value=0>--Select-- </option>");
                            $.each(UnitName, function (i, p) {
                                $("#txtEmployeeUnit").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }
                        debugger;
                        if (List_LineMaster != null) {
                            // $("#ddlLineMasterID").append("<option value=0>--Select-- </option>");
                            $.each(List_LineMaster, function (i, p) {
                                $("#ddlLineMasterID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }

                        if (ShiftGroupFName != null) {
                            //$("#ddlEM_Atten_ShiftGroupId").append("<option value=0>--Select-- </option>");
                            $.each(ShiftGroupFName, function (i, p) {
                                $("#ddlEM_Atten_ShiftGroupId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }

                        if (ShiftRuleName != null) {
                            //$("#ddlEM_Atten_ShiftRuleId").append("<option value=0>--Select-- </option>");
                            $.each(ShiftRuleName, function (i, p) {
                                $("#ddlEM_Atten_ShiftRuleId").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                        }

                        if (GetContractorDropdown != null) {
                            //$("#ddlEM_Atten_ShiftRuleId").append("<option value=0>--Select-- </option>");
                            $.each(GetContractorDropdown, function (i, p) {
                                $("#ddlContractorID").append("<option value='" + p.Id + "'>" + p.Name + "</option>");
                            });
                            //$("#ddlContractorID").val(1).select2();
                        }
                       
                    }
                    else {
                        $('#ErrorESSPassword').html(" ");
                    }
                }
            })
        });

        $("#txtBankBranchName").on("change", function () {
            $("#txtEmployeeUnit").find("option").remove();
            $("#ddlLineMasterID").find("option").remove();
            $("#ddlContractorID").find("option").remove();
            $("#ddlEM_Atten_ShiftRuleId").find("option").remove();
            $("#ddlEM_Atten_ShiftGroupId").find("option").remove();
            //$("#txtEmployeeDesignationID").find("option").remove();
            var CmpId = $("#txtComapnyName").val();
            var BranchId = $("#txtBankBranchName").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
