<script>
    $('#btnPincodeSearch').click(function () {
        debugger;
        $('#tblPinCodeLocation tr').not(function(){ return !!$(this).has('th').length; }).remove();
        var PinCode = $('#txtPresentPin').val();
        if(PinCode!=""){
            var PinCodeSixDigit = /^\d{6}$/;
            if (PinCode.match(PinCodeSixDigit)) {
                $("#ErrorPresentPin").html("");
                $.ajax({
                    type: "GET",
                    url: '@Url.Action("GetPincode", "Module_Employee_AddWorkers")',
                    //url: "GetPincode",
                    data: {PinCode:PinCode},
                    contentType: "application/json; charset=utf-8",
                    dataType: "text",
                    success: function (response) {
                        debugger;
                        var data = JSON.parse(response);
                        var length = data.data.length
                        if (length>0) {
                            $('#myModal').modal('show');
                        }
                        else
                        {
                            $('#myModal').modal('hide');
                        }
                        if (data.data != null) {
                            for (var i = 0; i <= data.data.length; i++) {
                                var table = document.getElementById("tblPinCodeLocation");
                                var rowCount = table.rows.length;
                                var row = table.insertRow(rowCount);
                                var count = $('#tblPinCodeLocation tr').length;
                                var Pin=data.data[i];
                                for (var j = 0; j <= Pin.length; j++) {
                                    debugger;
                                    if (j >= Pin.length) { continue; }
                                    var PinKey=Pin[j].Key;
                                    var PinValue=Pin[j].Value;

                                    if(PinKey=="PinCode")
                                    { row.insertCell(0).innerHTML ='<center><a href="javascript:;" class="CloseModel" data-bs-dismiss="modal" aria-hidden="true" id="CloseModel"><button type="button" id="btnOpenPopUp" class="btn btn-success ListBtn btnpress CloseModel"  onclick="EmployeeDetails(this)">Select</button></a></center>';
                                        row.insertCell(1).innerHTML = "" + PinValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(1).innerHTML="";
                                    }
                                    if(PinKey=="StateName")
                                    {
                                        row.insertCell(2).innerHTML = "" +PinValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(2).innerHTML="";
                                    }
                                    if(PinKey=="DistrictName")
                                    {
                                        row.insertCell(3).innerHTML = "" + PinValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(3).innerHTML="";
                                    }
                                    if(PinKey=="TalukaName")
                                    {
                                        row.insertCell(4).innerHTML = "" + PinValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(4).innerHTML="";
                                    }
                                    if(PinKey=="OfficeName")
                                    {
                                        row.insertCell(5).innerHTML = "" + PinValue + "";
                                    }
                                    else
                                    {
                                        //row.insertCell(5).innerHTML="";
                                    }
                                }

                            }
                        }
                    }
                });

            }
            else{
                $("#ErrorPresentPin").html("Enter 6 digit Pincode");
            }
        }
        else{
            $("#ErrorPresentPin").html("Enter Pincode");
        }
    });

