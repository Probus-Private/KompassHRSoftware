@model KompassHR.Models.Mas_AddEmployeeWorker
@{
    ViewBag.Title = "Module_Employee_AddWorkers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/jquery-1.10.2.min.js"></script>
<script src="~/scripts/jquery.validate.js"></script>
<script src="~/scripts/jquery.validate.min.js"></script>
<script src="~/assets/plugins/sweetalert/dist/sweetalert.min.js"></script>
<script src="~/assets/plugins/parsleyjs/dist/parsley.min.js"></script>
<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/assets/plugins/select2/dist/js/select2.min.js"></script>

<style>
    .Tooltip {
        position: relative;
    }

        .Tooltip button {
            width: 35px;
        }

        .Tooltip:hover .Tooltip-text {
            display: flex;
            position: absolute;
        }

        .Tooltip .Tooltip-text {
            z-index: 1;
            min-width: 45px;
            max-width: fit-content;
            background-color: black;
            color: #fff;
            top: 40px;
            right: -18px;
            padding: 5px 8px;
            border-radius: 6px;
            display: none;
            justify-content: center;
            position: absolute;
            margin-right: 10px;
        }

            .Tooltip .Tooltip-text::after {
                content: "";
                position: absolute;
                top: -20px;
                right: 20px;
                border-width: 10px;
                border-style: solid;
                border-color: transparent transparent black transparent;
            }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
        border: 1px solid lightgray !important;
    }

    /*.trheading {
        background-color: rgba(233, 236, 239, 0.5) !important;
    }*/

    tr td {
        padding: 4px !important;
        font-weight: 600;
    }

    .table-striped > tbody > tr:nth-of-type(odd) > * {
        --bs-table-accent-bg: rgba(233, 236, 239, 0.3) !important;
    }

    .table-wrap::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
        background-color: #F5F5F5;
        border-radius: 10px;
    }

    .table-wrap::-webkit-scrollbar {
        width: 6px;
        height: 10px;
        background-color: #F5F5F5;
    }

    .table-wrap::-webkit-scrollbar-thumb {
        background-color: #777;
        border-radius: 10px;
    }

    label.error, .Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }

    .error {
        text-align: left;
        height: 35px;
    }

    /*table first column fixed*/
    .table-wrap {
        width: 100%;
        overflow: auto;
    }

    .table-scroll table {
        width: 100%;
        margin: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table-scroll th, .table-scroll td {
        padding: 5px 10px;
        border: 1px solid lightgray;
        background: #fff;
        white-space: nowrap;
        vertical-align: top;
    }

    .table-scroll th {
        background-color: rgba(233, 236, 239, 1) !important;
    }

    .card-row-title {
        color: #e63c3c;
        font-size: 18px;
        font-weight: 600;
        text-transform: capitalize;
        border-bottom: #009ce7 1px solid;
    }

    .width-45 {
        width: 45px !important;
    }

    .table {
        --bs-table-striped-bg: rgba(0, 0, 255, 0.02);
    }

    .text-nowrap {
        font-size: 12px;
    }

    tbody tr td {
        font-size: 12px;
        padding: 4px !important;
    }

    .ListBtn {
        font-size: 10px !important;
        padding: 5px 8px !important;
    }
</style>


<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Add Worker
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Contractor_Menu", "ESS_Contractor_Menu",  new { id = 27,ScreenId=307, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">Add Worker</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Please fill out this form to record the attendance of workers. Include details such as name, date, time in/out, and any relevant notes.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_AddWorkers", new { area = "Module" })' id="SaveWorker" method="post">
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Employee Information
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Company Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.CmpID, new SelectList(ViewBag.ComapnyName, "Id", "Name"), new { id = "txtComapnyName", name = "CmpID", @class = "form-select", autocomplete = "off" })
                                                @Html.HiddenFor(model => model.EmployeeId_Encrypted, new { id = "txtEmployeeId_Encrypted" })
                                                @Html.HiddenFor(model => model.PersonalId_Encrypted, new { id = "txtPersonalId_Encrypted" })
                                                @Html.HiddenFor(model => model.AddressId_Encrypted, new { id = "txtAddressId_Encrypted" })
                                                @Html.HiddenFor(model => model.AttendanceId_Encrypted, new { id = "txtAttendanceId_Encrypted" })
                                                @Html.HiddenFor(model => model.PersonalEmployeeId, new { id = "txtPersonalEmployeeId" })
                                                @Html.HiddenFor(model => model.AddressEmployeeId, new { id = "txtAddressEmployeeId" })
                                                @Html.HiddenFor(model => model.AttendanceEmployeeId, new { id = "txtAttendanceEmployeeId" })
                                                @Html.HiddenFor(model => model.EmployeeId, new { id = "txtEmployeeId" })
                                                @Html.HiddenFor(model => model.EmployeeLeft, new { id = "txtEmployeeLeft" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Business Unit
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeBranchId, new SelectList(ViewBag.BranchName, "Id", "Name"), new { id = "txtBankBranchName", name = "BankBranchName", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Contractor
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.ContractorID, new SelectList(ViewBag.ContractorName, "Id", "Name"), new { id = "ddlContractorID", name = "ContractorID", @class = "form-control select2" })

                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-1">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Salutation
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Salutation, new List<SelectListItem>{
                                                new SelectListItem { Text = "Mr.", Value = "Mr." },
                                                new SelectListItem { Text = "Ms.", Value = "Ms." },
                                                new SelectListItem { Text = "Mrs.", Value = "Mrs." },
                                              }, new { @class = "form-select", name = "SalutationName", @id = "txtSalutationName" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-5">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Employee Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.EmployeeName, new { name = "EmployeeName", @class = "form-control", id = "txtEmployeeName", Type = "text", autocomplete = "Off", Maxlength = 100, oninput = "this.value = this.value.toUpperCase()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Employee No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.EmployeeNo, new { id = "txtEmployeeNo", name = "EmployeeNo", @class = "form-control", autocomplete = "Off", Maxlength = 10, oninput = "this.value = this.value.toUpperCase()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Employee Card No
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.EmployeeCardNo, new { id = "txtEmployeeCardNo", name = "EmployeeCardNo", @class = "form-control", autocomplete = "Off", Maxlength = 10, oninput = "this.value = this.value.toUpperCase()" }) @*style = "background-color:#eee"*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Aadhar No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-11">
                                                @Html.TextBoxFor(model => model.AadhaarNo, new { id = "txtAadhaarNo", name = "AadhaarNo", @class = "form-control", type = "text", autocomplete = "Off", Maxlength = 12, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.AadhaarNo, "", new { @class = "help-block", @id = "ErrorAadhaarNo", @style = "color:red" })
                                            </div>
                                            <div class="col-md-1">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnEmployeeHistory" onclick="ViewEmployeeHistory()">
                                                    <i class="fa-solid fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Employee Name As Per Aadhar
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.NameAsPerAadhaar, new { name = "NameAsPerAadhaar", @class = "form-control", id = "txtNameAsPerAadhaar", Type = "text", autocomplete = "Off", Maxlength = 100, oninput = "this.value = this.value.toUpperCase()" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Date of birth
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.BirthdayDate, new { id = "txtBirthdayDate", name = "BirthdayDate", @class = "form-control", type = "date", autocomplete = "Off" })
                                                <span class="Error" id="ErrortxtBirthdayDate"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Gender
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.Gender, new List<SelectListItem> {
                                                    new SelectListItem { Text = "Male", Value = "Male"},
                                                    new SelectListItem { Text = "Female", Value = "Female"},
                                                     new SelectListItem { Text = "Other", Value = "Other"},
                                                }, new { id = "ddlGender", @class = "form-select", autocomplete = "off", name = "Gender" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Highest Qualification
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeQualificationID, new SelectList(ViewBag.QualificationName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeQualificationID", name = "EmployeeQualificationID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Marital Status
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.MaritalStatus, new List<SelectListItem> {
                                                  new SelectListItem { Text = "Unmarried", Value = "Unmarried"},
                                                  new SelectListItem { Text = "Married", Value = "Married"},
                                                     new SelectListItem { Text = "Widow", Value = "Widow"},
                                                }, new { id = "ddlMaritalStatus", @class = "form-select", autocomplete = "off", name = "MaritalStatus" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Mobile No
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PrimaryMobile, new { id = "txtPrimaryMobile", name = "PrimaryMobile", @class = "form-control", type = "text", autocomplete = "Off", Maxlength = 10, onkeypress = " return numbervalidate(event)" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Statutory Infromation
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Father/Mother/Spouse
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.PF_FSType, new List<SelectListItem>{
                                                 new SelectListItem {Text ="Father", Value="Father"},
                                                new SelectListItem {Text ="Mother", Value="Mother"},
                                                 new SelectListItem {Text ="Spouse", Value="Spouse"}
                                              }, new { @class = "form-select", name = "PF_FSType", id = "ddlPF_FSType" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Father/Mother/Spouse Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PF_FS_Name, new { @class = "form-control", name = "PF_FS_Name", type = "text", id = "txtPF_FS_Name", autocomplete = "Off", Maxlength = 50 })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                UAN No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PF_UAN, new { @class = "form-control", name = "PF_UAN", type = "text", id = "txtPF_UAN", autocomplete = "Off", Maxlength = 12, onkeypress = " return numbervalidate(event)" })
                                                @Html.ValidationMessageFor(model => model.PF_UAN, "", new { @class = "help-block", @id = "ErrorPF_UAN", @style = "color:red" })
                                                @*<b>    Note :If the UAN number is not available, mark it as "Pending."</b>*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                ESIC No
                                                @*<span class="important">*</span>*@
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.ESIC_NO, new { @class = "form-control", name = "ESIC_NO", type = "text", id = "txtESIC_NO", autocomplete = "Off", Maxlength = 17 })
                                                @Html.ValidationMessageFor(model => model.ESIC_NO, "", new { @class = "help-block", @id = "ErrorESIC_NO", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <hr />
                                <div class="row mb-10px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Admin Information
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Department
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeDepartmentID, new SelectList(ViewBag.DepartmentName, "Id", "Name"), "--Select--", new { id = "txtEmployeeDepartmentID", name = "EmployeeDepartmentID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Sub - Department
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeSubDepartmentName, new SelectList(ViewBag.SubDepartmentName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeSubDepartmentName", name = "EmployeeSubDepartmentName", @class = "form-control select2" })
                                                @Html.ValidationMessageFor(model => model.EmployeeSubDepartmentName, "", new { @class = "help-block", @id = "ErrorEmployeeSubDepartmentName", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Grade
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeGradeID, new SelectList(ViewBag.GradeName, "Id", "Name"), "--Select--", new { id = "ddlEmployeeGradeID", name = "EmployeeGradeID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Manpower Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeAllocationCategoryId, new SelectList(ViewBag.EmployeeAllocationCategory, "Id", "Name"),"--Select--", new { id = "ddlEmployeeAllocationCategoryId", name = "EmployeeAllocationCategoryId", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Designation
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeDesignationID, new SelectList(ViewBag.Designation, "Id", "Name"), "--Select--", new { id = "txtEmployeeDesignationID", name = "EmployeeDesignationID", @class = "form-select", autocomplete = "off" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Line Master
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeLineID, new SelectList(ViewBag.LineMasterName, "Id", "Name"), new { id = "ddlLineMasterID", name = "LineMasterID", @class = "form-control select2" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Critical Stage Applicable
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.IsCriticalStageApplicable, new List<SelectListItem>{
                                                  new SelectListItem {Text ="No", Value="false"},
                                               new SelectListItem {Text ="Yes", Value="true"},

                                              }, new { @class = "form-select", name = "IsCriticalStageApplicable", @id = "ddlIsCriticalStageApplicable" })

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="row mb-10px">
                                            <label class="form-label col-form-label col-md-12">
                                                Critical Stage Category
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.DropDownListFor(model => model.EmployeeCriticalStageID, new SelectList(ViewBag.CriticalStageName, "Id", "Name"), new { id = "ddlEmployeeCriticalStageID", name = "EmployeeCriticalStageID", @class = "form-control" })
                                                @Html.ValidationMessageFor(model => model.IsCriticalStageApplicable, "", new { @class = "help-block", @id = "ErrorIsCriticalStageApplicable", @style = "color:red" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="row mb-10px">
