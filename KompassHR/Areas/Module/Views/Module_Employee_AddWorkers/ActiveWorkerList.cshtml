<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Active Worker
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_Contractor_Menu", "ESS_Contractor_Menu",  new { id = 27,ScreenId=307, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>


    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Active Worker - List</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Below is a list of all active worker employees.
                    </p>
                </div>
                <div class="panel-body">
                    <a href="@Url.Action("Module_Employee_AddWorkers", "Module_Employee_AddWorkers", new { area = "Module" })">
                        <button type="button" class="btn btn-primary btn-sm  mb-10px">
                            <i class="fa-solid fa-plus"></i> &nbsp; Add
                        </button>
                    </a>
                    <!-- BEGIN table-responsive -->
                    <div class="table-scroll div1">
                        <div class="table-wrap">
                            <div class="row">
                                <div class="col-md-12">
                                    <!-- BEGIN table-responsive -->
                                    <table class="table table-bordered table-hover mb-0 text-dark align-middle TablePage EmployeeDetails" id="tblEmployeeDetails"
                                           style="width: 100%;">
                                        <thead>
                                            <tr class="text-center">
                                                <th class="fixed-side">Action</th>

                                                <th class="text-nowrap width-45">Employee Name</th>
                                                <th class="fixed-side">Employee No.</th>
                                                <th class="text-nowrap width-45">Employee Card No.</th>
                                                <th class="text-nowrap width-45">Business Unit</th>
                                                <th class="text-nowrap width-45">Contractor Name</th>
                                                <th class="text-nowrap width-45">Department Name</th>
                                                <th class="text-nowrap width-45">Designation Name</th>
                                                <th class="text-nowrap width-45">Joining Date</th>

                                                <th hidden class="text-nowrap width-45">EmployeeId</th>
                                                <th hidden class="text-nowrap width-45">CmpID</th>
                                                <th hidden class="text-nowrap width-45">EmployeeBranchId</th>
                                                <th hidden class="text-nowrap width-45">EmployeeDepartmentID</th>
                                                <th hidden class="text-nowrap width-45">EmployeeDesignationID</th>
                                                <th hidden class="text-nowrap width-45">FirstName</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ViewBag.GetActiveWorkerList)
                                            {
                                                <tr>
                                                    @*<td class="text-center">
                                                            <button type="button" onclick="UpdateActiveWorker('@d.EmployeeId','@d.EmployeeId_Encrypted','Update')" id="btnUpdate"
                                                                    class="btn btn-success btnpress ListBtn">
                                                                <i class="fa-solid fa-pencil-alt"></i>
                                                            </button>
                                                        </td>*@
                                                    <td class="text-center">
                                                        <button type="button" data-bs-toggle="offcanvas"
                                                                href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn  btnpress ListBtn">
                                                            <i class="fa-solid fa-list"></i>
                                                        </button>
                                                    </td>
                                                    <td class="text-nowrap 1">@d.employeename</td>
                                                    <td class="text-nowrap 2">@d.employeeno</td>
                                                    <td class="text-nowrap 6">@d.employeecardno</td>
                                                    <td class="text-nowrap 8">@d.BusinessUnit</td>
                                                    <td class="text-nowrap 9">@d.ContractorName</td>
                                                    <td class="text-nowrap 10">@d.departmentname</td>
                                                    <td class="text-nowrap 11">@d.designationname</td>
                                                    <td class="text-nowrap 15">@d.joiningdate</td>

                                                    <td hidden class="text-nowrap 15">@d.EmployeeId</td>
                                                    <td hidden class="text-nowrap 15">@d.CmpID</td>
                                                    <td hidden class="text-nowrap 15">@d.EmployeeBranchId</td>
                                                    <td hidden class="text-nowrap 15">@d.EmployeeDepartmentID</td>
                                                    <td hidden class="text-nowrap 15">@d.EmployeeDesignationID</td>
                                                    <td hidden class="text-nowrap 15">@d.FirstName</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Start panel -->
<div class="row">
    <div class="offcanvas offcanvas-end" id="offcanvasExample" data-bs-backdrop="false" data-bs-scroll=true style="width:210px">
        <div class="offcanvas-header" style="border-bottom: 1px solid #d3d3d38a;">
            <h6 class="offcanvas-title text-center" id="EmpName1"
                style="width: 100%;">
                <span id="EmpName">@Session["WorkerFirstName"]</span>
            </h6>
            <button type="button" class="btn-close text-reset"
                    data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div class="row">
                @foreach (var item in ViewBag.GetUserMenuList)
                {
                    <div class="col-md-12 d-flex justify-content-center">
                        <a href="@Url.Action(item.ViewName.ToString(), item.ControllerName.ToString(), new { area = item.AreaName.ToString(), id = item.ModuleID, ScreenId = item.ScreenId })" style="text-decoration:none !important;">
                            <div class="box2">
                                <div class="info">
                                    <i class="@item.Icon"></i>
                                    <h7><b>@item.ScreenDisplayMenuName</b></h7>
                                    <div class="box2Checkmark">
                                        <i class="fa-regular fa-circle-check text-green FS-12PX" id="@($"{item.ScreenSourceMenuName}_Submit")"></i>
                                        <i class="fa-regular fa-circle-xmark text-red FS-12PX" id="@($"{item.ScreenSourceMenuName}_NotSubmit")"></i>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- END panel -->
