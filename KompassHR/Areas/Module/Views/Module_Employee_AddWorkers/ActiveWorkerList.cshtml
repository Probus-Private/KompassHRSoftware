<script>
    $(document).ready(function () {
        $('title').html("Active Worker List");
        var table = $('#tblEmployeeDetails').DataTable();
        table.search('').draw();
        });

    function UpdateActiveWorker(EmployeeId, EmployeeId_Encrypted,GetUpdate) {
        var url = '@Url.Action("Module_Employee_AddWorkers", "Module_Employee_AddWorkers")?EmployeeId_Encrypted=' + EmployeeId_Encrypted + '&EmployeeId=' + EmployeeId + '&GetUpdate=' + GetUpdate;
        window.location.href = url;
    }

</script>


<script>
    function EmployeeDetails(tblRow) {
        debugger;
        var currentRow = $(tblRow).closest("tr");
        var EmpId = currentRow.find("td:eq(9)").html();
        var CmpId = currentRow.find("td:eq(10)").html();
        var BranchId = currentRow.find("td:eq(11)").html();
        var EmpName = currentRow.find("td:eq(1)").html();
        var EmployeeNo = currentRow.find("td:eq(2)").html();
        var EmpDepartment = currentRow.find("td:eq(6)").html();
        var EmpDesignation = currentRow.find("td:eq(7)").html();
        var EmpDoj = currentRow.find("td:eq(8)").html();
        var EmpDepartmentId = currentRow.find("td:eq(12)").html();
        var FirstName = currentRow.find("td:eq(14)").html();
        var ContractorName = currentRow.find("td:eq(5)").html();
        $("#EmpName").html(FirstName);
        $.ajax({
            type: "GET",
            url: '@Url.Action("WorkerOnboardingForm", "Module_Employee_AddWorkers")',
            data: { EmpId: EmpId, CmpId: CmpId, BranchId: BranchId, EmpName: EmpName, EmpDoj: EmpDoj, EmpDepartment: EmpDepartment, EmpDesignation: EmpDesignation, EmployeeNo: EmployeeNo, EmpDepartmentId: EmpDepartmentId, FirstName: FirstName, ContractorName: ContractorName },
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                var data = JSON.parse(response);
                if (data == 0) {
                    $("#Admin_NotSubmit").show();
                    $("#Admin_Submit").hide();

                    $("#Personal_NotSubmit").show();
                    $("#Personal_Submit").hide();

                    $("#Reporting_NotSubmit").show();
                    $("#Reporting_Submit").hide();

                    $("#Attendance_NotSubmit").show();
                    $("#Attendance_Submit").hide();

                    $("#CTC_NotSubmit").show();
                    $("#CTC_Submit").hide();

                    $("#ESS_NotSubmit").show();
                    $("#ESS_Submit").hide();

                    $("#JobDescription_NotSubmit").show();
                    $("#JobDescription_Submit").hide();

                    $("#Verfication_NotSubmit").show();
                    $("#Verfication_Submit").hide();

                    $("#VMS_NotSubmit").show();
                    $("#VMS_Submit").hide();

                    $("#Checklist_NotSubmit").show();
                    $("#Checklist_Submit").hide();

                    $("#Policy_NotSubmit").show();
                    $("#Policy_Submit").hide();

                    $("#Assets_NotSubmit").show();
                    $("#Assets_Submit").hide();

                    $("#Insurance_NotSubmit").show();
                    $("#Insurance_Submit").hide();

                    $("#MedicalHistory_NotSubmit").show();
                    $("#MedicalHistory_Submit").hide();

                    $("#Address_NotSubmit").show();
                    $("#Address_Submit").hide();

                    $("#Bank_NotSubmit").show();
                    $("#Bank_Submit").hide();

                    $("#Reference_NotSubmit").show();
                    $("#Reference_Submit").hide();

                    $("#Family_NotSubmit").show();
                    $("#Family_Submit").hide();

                    $("#Statutory_NotSubmit").show();
                    $("#Statutory_Submit").hide();

                    $("#PreEmployeer_NotSubmit").show();
                    $("#PreEmployeer_Submit").hide();

                    $("#Qualifications_NotSubmit").show();
                    $("#Qualifications_Submit").hide();

                    $("#Skill_NotSubmit").show();
                    $("#Skill_Submit").hide();

                    $("#Language_NotSubmit").show();
                    $("#Language_Submit").hide();

                    $("#Signature_NotSubmit").show();
                    $("#Signature_Submit").hide();

                    $("#Documents_NotSubmit").show();
                    $("#Documents_Submit").hide();

                    $("#UploadPhoto_NotSubmit").show();
                    $("#UploadPhoto_Submit").hide();

                    $("#Bond_NotSubmit").show();
                    $("#Bond_Submit").hide();

                    $("#UploadDocument_NotSubmit").show();
                    $("#UploadDocument_Submit").hide();

                    $("#GeneralReporting_NotSubmit").show();
                    $("#GeneralReporting_Submit").hide();
                }
                else {
                    var data = JSON.parse(response);
                    var SetUpAdmin = data[0][1].Value;
                    if (SetUpAdmin == true) {
                        $("#Admin_Submit").show();
                        $("#Admin_NotSubmit").hide();
                    }
                    else {
                        $("#Admin_NotSubmit").show();
                        $("#Admin_Submit").hide();
                    }

                    var SetUpPersonal = data[0][0].Value;
                    if (SetUpPersonal == true) {
                        $("#Personal_Submit").show();
                        $("#Personal_NotSubmit").hide();
                    }
                    else {
                        $("#Personal_NotSubmit").show();
                        $("#Personal_Submit").hide();
                    }

                    var SetUpAttendence = data[0][5].Value;
                    if (SetUpAttendence == true) {
                        $("#Attendance_Submit").show();
                        $("#Attendance_NotSubmit").hide();
                    }
                    else {
                        $("#Attendance_NotSubmit").show();
                        $("#Attendance_Submit").hide();
                    }

                    var SetUpESS = data[0][7].Value;
                    if (SetUpESS == true) {
                        $("#ESS_Submit").show();
                        $("#ESS_NotSubmit").hide();
                    }
                    else {
                        $("#ESS_NotSubmit").show();
                        $("#ESS_Submit").hide();
