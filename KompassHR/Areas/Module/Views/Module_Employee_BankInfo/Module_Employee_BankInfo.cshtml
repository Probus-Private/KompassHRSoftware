<script>
    $(document).ready(function () {
        $('.upper-case').on('input', function () {
            this.value = this.value.toUpperCase();
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        var CountEmployeeBankEmployeeId = @Html.Raw(Json.Encode(TempData["CountEmployeeBankEmployeeId"]));
        var CheckPreboarding = @Html.Raw(Json.Encode(TempData["PreBoardFid"]));
        if(CountEmployeeBankEmployeeId!=0)
        {
            $("#btnGet").hide();
        }
        else
        {
            if(CheckPreboarding!=0)
            {
                $("#btnGet").show();
            }
            else{
                $("#btnGet").hide();

            }
        }
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }
    });
    $(".CloseModel").click(function () {
        $('#tblIFSCcode tr').not(function () { return !!$(this).has('th').length; }).remove();
    })

