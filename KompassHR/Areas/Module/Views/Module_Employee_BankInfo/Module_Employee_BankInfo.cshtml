        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Bank List</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModel" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModel">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-responsive">
                                <table class="table table-bordered tblAddData" id="tblIFSCcodeHeading" style="width: 100%">
                                    <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                        <tr class="text-center">
                                            <th class="text-nowrap">Action </th>
                                            <th class="text-nowrap">IFSC Code </th>
                                            <th class="text-nowrap">Bank Name</th>
