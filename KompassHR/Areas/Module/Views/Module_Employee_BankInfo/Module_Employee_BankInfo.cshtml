        debugger;

        var baseUrl = '@Url.Action("Module_Employee_BankInfo", "Module_Employee_BankInfo", new { area = "Module" })';
        var url = baseUrl + '?Status=' + encodeURIComponent(Status);

        window.location.href = url;
    }

</script>

