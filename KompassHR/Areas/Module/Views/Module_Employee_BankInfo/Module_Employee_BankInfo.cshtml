<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Bank Information
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new {id = 3, ScreenId=142, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">

                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title">@*@i.SET_MODULES.FormName*@ Bank Information - @ViewBag.AddUpdateTitle </h4>
                    @*<div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>*@
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                        Add employee bank details.
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-md-12">
                            <form role="form" action='@Url.Action("SaveUpdate", "Module_Employee_BankInfo", new { area = "Module" })' id="SaveBankInformation" method="post">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="empbx">
                                            <span>
                                                <h4> <i class="fa-solid fa-user"></i> @Session["OnboardEmployeeName"] -  @Session["OnboardEmployeeNo"] </h4>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-briefcase"></i>  @Session["OnboardEmpDepartment"] / @Session["OnboardEmpDesignation"] </h6>
                                            </span>
                                            <span>
                                                <h6> <i class="fa-solid fa-calendar"></i> @Session["OnboardEmpDoj"] </h6>
                                            </span>
                                            <hr>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px" id="btnGet">
                                    <div class="col-md-6" style="width:fit-content;">
                                        <button type="button" id="btnGetPrebordingList"  onclick="GetDetails('Pre')"
                                                class="btn btn-success btn-sm btnpress">
                                            <i class="fa-regular fa-copy"></i> Get
                                        </button>
                                    </div>
                                </div>
                         


                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Personal Bank Information
                                        </div>
                                    </div>
                                </div>
                            

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                IFSC Code
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.PermanentIFSC, new { @class = "form-control", name = "PermanentIFSC", type = "text", id = "txtPermanentIFSC", autocomplete = "Off", oninput = "this.value = this.value.toUpperCase()", Maxlength = 50 })
                                                @Html.ValidationMessageFor(model => model.PermanentIFSC, "", new { @class = "help-block", @id = "ErrorPermanentIFSC", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnSearchPersonal">
                                                    <i class="fa-solid fa-magnifying-glass"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Bank Name

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PermanentBankName, new { @class = "form-control upper-case", name = "PermanentBankName", type = "text", id = "txtPermanentBankName", autocomplete = "Off", Maxlength = 100 })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Branch Name

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PermanentBankBranchName, new { @class = "form-control", name = "PermanentBankBranchName", type = "text", id = "txtPermanentBankBranchName", autocomplete = "Off", Maxlength = 100 })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Bank Address

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PermanentBankAddress, new { @class = "form-control", name = "PermanentBankAddress", type = "text", id = "txtPermanentBankAddress", autocomplete = "Off", Maxlength = 500 })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Account No

                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.PermanentAccountNo, new { @class = "form-control", name = "PermanentAccountNo", type = "password", id = "txtPermanentAccountNo", autocomplete = "Off", Maxlength = 50 })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-default btnpress" id="togglePasswordPermanentAccountNo">
                                                    <i class="fa-solid fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Confirm Account
                                                No

                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.PermanentConfirmAccountNo, new { @class = "form-control", name = "PermanentConfirmAccountNo", type = "password", id = "txtPermanentConfirmAccountNo", autocomplete = "Off", Maxlength = 50 })
                                                @Html.ValidationMessageFor(model => model.PermanentConfirmAccountNo, "", new { @class = "help-block", @id = "ErrorPermanentConfirmAccountNo", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-default btnpress" id="togglePasswordPermanentConfirmAccountNo">
                                                    <i class="fa-solid fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Name As Per Bank

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.PermanentNameAsPerBank, new { @class = "form-control", name = "PermanentNameAsPerBank", type = "text", id = "txtPermanentNameAsPerBank", autocomplete = "Off", Maxlength = 70 })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-15px">
                                    <div class="col-md-12">
                                        <div class="card-row-title">
                                            Salary Bank Information
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-15px">
                                    <div class="col-md-6" style="width:fit-content;">
                                        <button type="button" id="btnCopy"
                                                class="btn btn-success btn-sm btnpress">
                                            <i class="fa-regular fa-copy"></i> Copy
                                        </button>

                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                IFSC Code
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(model => model.SalaryIFSC, new { @class = "form-control", name = "SalaryIFSC", type = "text", id = "txtSalaryIFSC", autocomplete = "Off", oninput = "this.value = this.value.toUpperCase()", Maxlength = 50 })
                                                @Html.HiddenFor(model => model.EmployeeBankId_Encrypted)
                                                @Html.HiddenFor(model => model.EmployeeBankEmployeeId)
                                                @Html.ValidationMessageFor(model => model.SalaryIFSC, "", new { @class = "help-block", @id = "ErrorSalaryIFSC", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-primary btn-sm" id="btnSearch">
                                                    <i class="fa-solid fa-magnifying-glass"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Bank Name
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.SalaryBankName, new { @class = "form-control upper-case", name = "SalaryBankName", type = "text", id = "txtSalaryBankName", autocomplete = "Off", Maxlength = 100 })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Branch Name

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.SalaryBankBranchName, new { @class = "form-control", name = "SalaryBankBranchName", type = "text", id = "txtSalaryBankBranchName", autocomplete = "Off", Maxlength = 100 })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Bank Address

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.SalaryBankAddress, new { @class = "form-control", name = "SalaryBankAddress", type = "text", id = "txtSalaryBankAddress", autocomplete = "Off", Maxlength = 500 })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Account No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.SalaryAccountNo, new { @class = "form-control", name = "SalaryAccountNo", type = "password", id = "txtSalaryAccountNo", autocomplete = "Off", Maxlength = 50 })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-default btnpress" id="togglePasswordSalary">
                                                    <i class="fa-solid fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Confirm Account
                                                No
                                                <span class="important">*</span>
                                            </label>
                                            <div class="col-md-10">
                                                @Html.TextBoxFor(model => model.SalaryConfirmAccountNo, new { @class = "form-control", name = "SalaryConfirmAccountNo", type = "password", id = "txtSalaryConfirmAccountNo", autocomplete = "Off", Maxlength = 50 })
                                                @Html.ValidationMessageFor(model => model.SalaryConfirmAccountNo, "", new { @class = "help-block", @id = "ErrorSalaryConfirmAccountNo", @style = "color:red" })
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-default btnpress" id="togglePasswordSalaryConfirm">
                                                    <i class="fa-solid fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-12">
                                                Name As Per Bank

                                            </label>
                                            <div class="col-md-12">
                                                @Html.TextBoxFor(model => model.SalaryNameAsPerBank, new { @class = "form-control", name = "SalaryNameAsPerBank", type = "text", id = "txtSalaryNameAsPerBank", autocomplete = "Off", Maxlength = 50 })
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="row mb-20px">
                                    <div class="LastShortLeaveBx">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="BtnBx">
                                                    <div>
                                                        <button type="button" data-bs-toggle="offcanvas"
                                                                href="#offcanvasExample" id="btnActionList" onclick="EmployeeDetails(this)" class="btn  btnpress ListBtn">
                                                            <i class="fa-solid fa-list"></i>
                                                        </button>
                                                        <button type="button" id="btnSubmit"
                                                                class="btn btn-primary btn-sm">
                                                            <i class="fa-solid fa-floppy-disk"></i> Submit
                                                        </button>
                                                        <a href="@Url.Action("Module_Employee_EmployeeList", "Module_Employee_EmployeeList", new { area = "Module" })">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm" id="btnBack">
                                                                <i class="fa-solid fa-share-from-square"></i>
                                                                List
                                                            </button>
                                                        </a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>

<div class="row">
    @Html.Action("Onboarding_SidebarMenu", "Module_Employee_PersonalInfo")
</div>


