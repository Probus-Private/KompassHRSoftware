
@{
    ViewBag.Title = "Module_Employee_OrganisationChart_Mapping";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Reduce Dropdown Height and Adjust Padding */
    .form-select {
        height: 25px !important;
        padding: 2px 3px !important; /* Adjust padding */
        font-size: 10px;
    }

    /* Table Header Fix */
    #tblOrgChartList thead {
        position: sticky;
        top: 0;
        background-color: rgba(233, 236, 239, 1) !important;
        z-index: 100;
    }

    /* Ensure table wrapper allows scrolling */
    .table-container {
        max-height: 400px; /* Adjust height as needed */
        overflow-y: auto;
        border: 1px solid #ddd;
    }

    /* Adjust padding for table cells */
    #tblOrgChartList th, #tblOrgChartList td {
        padding: 2px 3px !important; /* Adjust padding */
        text-align: center;
    }

    #tblOrgChartList .select2.select2-container .selection .select2-selection.select2-selection--single {
        height: calc(1.0em + .875rem + 2px);
        display: flex;
        align-items: center;
    }

    label.error,.Error {
        text-align: left;
        height: 25px;
        color: red;
        font-size: 12px;
    }
</style>

<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Organisation Chart Mapping
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ESS_HRSpaceMenu", "ESS_HRSpaceMenu", new {id = 41, ScreenId=651, area = "ESS" })">
                        <img src="~/assets/MenuImages/Back.png" style="max-width: 100%; height: auto;" alt="Back">
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12 col-md-12">
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Organisation Chart Mapping</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <form class="form">
                                <div class="invoice-content">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="table-scroll div1">
                                                <div class="table-wrap">
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            <div class="row mb-15px">
                                                                <label class="form-label col-form-label col-md-2">
                                                                    Chart Type
                                                                    <span class="important">*</span>
                                                                </label>
                                                                <div class="col-md-4">
                                                                    @Html.DropDownList("OrganisationType", new SelectList(ViewBag.OrganisationType, "Id", "Name"),
                                                                            "--Select--", // Optional: Default option
                                                                            new
                                                                            {
                                                                                @class = "form-select",
                                                                                id = "ddlOrganisationType",

                                                                            })

                                                                    <span id="ErrorOrganisationType" class="Error"></span>
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <button type="button" id="btnShow" class="btn btn-primary btn-sm" onclick="GetDateFunction()">
                                                                        Show
                                                                    </button>

                                                                </div>

                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="panel-body">
                                                        <div class="row">
                                                            <div class="col-md-12">
                                                                <!-- BEGIN table-responsive -->
                                                                <div class="table-scroll div1">
                                                                    <div class="table-wrap">
                                                                        <table class="table table-bordered table-hover mb-0 text-dark align-middle tblAddData TablePageAccess" id="tblOrgChartList">
                                                                            <thead style="background-color: rgba(233, 236, 239, 1) !important;">
                                                                                <tr class="trheading">
                                                                                    <th class="fixed-side text-nowrap">Leavel</th>
                                                                                    <th class="fixed-side1 text-nowrap">Title</th>
                                                                                    <th class="fixed-side1 text-nowrap">Remark</th>
                                                                                    <th class="fixed-side text-nowrap">EmployeeName</th>
                                                                                    <th hidden>OrgChartId</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody id="tblLoadModule">
                                                                                @{
                                                                                    int serialNumber = 1; // Initialize the serial number
                                                                                }
                                                                                @if (ViewBag.OrganisationList != null)
                                                                                {
                                                                                    foreach (var d in ViewBag.OrganisationList)
                                                                                    {
                                                                                        <tr>
                                                                                            <td class="text-nowrap">@(d.OrganisationLevel ?? "N/A")</td>
                                                                                            <td style="text-align:left">@(d.OrganisationTitle ?? "N/A")</td>
                                                                                            <td style="text-align:left">@(d.OrganisationRemark ?? "N/A")</td>
                                                                                            <td>
                                                                                                @Html.DropDownList($"EmployeeName_{serialNumber}", new SelectList(ViewBag.AllEmployeeName, "Id", "Name"), "--Select--", new { @class = $"form-select ddlSelect2_{serialNumber}", type = "text", name = "EmployeeName", autocomplete = "Off", style = "width:100%; height: 25px; padding:0px; padding-left: 10px !important" })
                                                                                                @*@Html.DropDownList("EmployeeName", new SelectList(ViewBag.AllEmployeeName ?? new List<SelectListItem>(), "Id", "Name"), "-- Select --", new { @class = "form-control EmployeeName", id = "ddlEmployeeName" })*@
                                                                                                <span id="ddltblEmpId"></span>
                                                                                            </td>
                                                                                            <td hidden>@(d.OrganisationChartId ?? 0)</td>
                                                                                        </tr>
                                                                                        serialNumber++;
                                                                                    }
                                                                                }
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="row">
                                                        <div class="row">
                                                            <div class="col-md-12">
                                                                <div class="BtnBx">
                                                                    <div>
                                                                        <button type="button" id="btnSubmit" class="btn btn-primary btn-sm">
                                                                            Submit
                                                                        </button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#ddlOrganisationType").select2();
        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            Swal.fire({
                icon: Icon,
                text: Message,
                allowOutsideClick: false
            });
        }

        debugger;
        var SelectedNo = @Html.Raw(Json.Encode(ViewBag.SelectedTypeId));
        if (SelectedNo!=null) {
            $("#ddlOrganisationType").val(SelectedNo).select2();
        }

        var empDataArray = @Html.Raw(Json.Encode(ViewBag.OrganisationList));
        debugger;
        var formattedData = empDataArray.map(itemArray => {
            let obj = {};
            itemArray.forEach(item => {
                obj[item.Key] = item.Value;
            });
            return obj;
        });
        // Now, loop through each row and assign the correct Employee ID
        $('#tblOrgChartList tbody tr').each(function(index) {
            var row = $(this);
            var selectElement = row.find("td").eq(3).find("select");
            if (index < formattedData.length) {
                selectElement.val(formattedData[index].OrganisationEmployeeId).trigger('change'); // Set the value
            }
            selectElement.select2(); // Re-initialize select2
        });
    });
</script>

<script>
    function GetDateFunction() {
        debugger;
        var selectedValue = $("#ddlOrganisationType").val();

        if (!selectedValue || selectedValue === "") {
            $("#ErrorOrganisationType").html("Please select an organisation type.");
            return false
        } else {
            $("#ErrorOrganisationType").html("").hide();
        }
        var selectedTypeId = document.getElementById('ddlOrganisationType').value;
        window.location.href = '@Url.Action("Module_Employee_OrganisationChart_Mapping", "Module_Employee_OrganisationChart_Mapping")' + '?TypeId=' + selectedTypeId;
    }

    $("#btnSubmit").click(function () {
        //$(".Userloaderbg").css("display", "flex");
        debugger;
        var selectedValue = $("#ddlOrganisationType").val();

        if (!selectedValue || selectedValue === "") {
            $("#ErrorOrganisationType").html("Please select an organisation type.");
            return false
        } else {
            $("#ErrorOrganisationType").html("").hide();
        }
        var RequestArray = [];

        //    $("#tblOrgChartList tbody tr").each(function () {
        //    var row = $(this);
        //    var tblRowData = {};
        //    // Fetch values from table cells
        //    tblRowData.OrganisationLevel = row.find("td").eq(0).text().trim(); // Organisation Level
        //    tblRowData.OrganisationRemark = row.find("td").eq(1).text().trim(); // Remark
        //    var employeeSelect = row.find("td").eq(2).find("select"); // Dropdown element
        //    tblRowData.EmployeeId = employeeSelect.val(); // Selected Employee ID
        //    tblRowData.OrgChartId = row.find("td").eq(3).text().trim(); // Hidden OrgChartId

        //    // Validation check: If EmployeeId is null or empty
        //    if (!tblRowData.EmployeeId || tblRowData.EmployeeId === "0") {
        //        employeeSelect.css("border", "2px solid red"); // Highlight the dropdown with red border
        //        return false;
        //    } else {
        //        employeeSelect.css("border", ""); // Remove border if value is valid
        //    }

        //    RequestArray.push(tblRowData);
        //});

        var isValid = true;
        $("#tblOrgChartList tbody tr").each(function () {
            var row = $(this);
            var tblRowData = {};

            // Fetch values from table cells
            tblRowData.OrganisationLevel = row.find("td").eq(0).text().trim(); 
            tblRowData.OrganisationTitle = row.find("td").eq(1).text().trim(); 
            tblRowData.OrganisationRemark = row.find("td").eq(2).text().trim();

            var employeeSelect = row.find("td").eq(3).find("select");
            tblRowData.EmployeeId = employeeSelect.val(); 

            tblRowData.OrgChartId = row.find("td").eq(4).text().trim(); // Hidden OrgChartId

            var errorSpan = row.find("td").eq(3).find("span#ddltblEmpId"); // Find error span in the same row

            // Validation check: If EmployeeId is null or empty
            //if (!tblRowData.EmployeeId || tblRowData.EmployeeId === "0") {
            //    errorSpan.text("Select Employee").css("color", "red"); // Show error message
            //    employeeSelect.focus();
            //    isValid =false;
            //} else {
            //    errorSpan.text(""); // Clear error message if valid
            //}

            RequestArray.push(tblRowData);
        });

        debugger;
        //console.log(RequestArray); // Debugging
        if (!isValid) {
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        // AJAX Call to send data to the controller
        $.ajax({
            url: '@Url.Action("SaveRequest", "Module_Employee_OrganisationChart_Mapping")',
            type: "POST",
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(RequestArray),
            success: function (response) {
                debugger;
                $(".Userloaderbg").css("display", "none");
                if (response.success == true) {
                    var Message1 = response.message;
                    var Icon1 = response.icon;
                    Swal.fire({
                        icon: Icon1,
                        text: Message1,
                        allowOutsideClick: false
                    }).then((result) => {
                        if (result.isConfirmed) {
                            location.reload(); 
                        }
                    });
                }

            },
            error: function (xhr, status, error) {
                console.log("Error: " + error);
                alert("Something went wrong! Check console for details.");
            }
