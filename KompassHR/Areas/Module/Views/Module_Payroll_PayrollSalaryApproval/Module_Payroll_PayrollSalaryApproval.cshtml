        //var Month = $("#FromDate").val();
        //var BranchId = $("#ddlBranchId").val();

        var CmpId = encodeURIComponent($("#ddlCmpId").val());
        var MonthYear = encodeURIComponent($("#txtMonthYear").val());
        var BranchId = encodeURIComponent($("#ddlBranchId").val());
        var ProcessCategoryId = $("#ddlProcessCategoryId").val();
        // var LeaveTypeId = encodeURIComponent($("#ddlLeaveTypeId").val());
        var url = `@Url.Action("DownloadMonthlyAttendnceExcelFile", "Module_Payroll_PayrollSalaryApproval")?CmpId=${CmpId}&BranchId=${BranchId}&MonthYear=${MonthYear}&ProcessCategoryId=${ProcessCategoryId}`;

        $.ajax({
            url: url,
            method: 'GET',
            xhrFields: {
                responseType: 'blob' // Set the response type to blob
            },
            success: function(data) {
                debugger;
                if(data.size==0)
                {
                    Swal.fire({
                        icon: 'error',
                        text: 'Record Not Found',
                        allowOutsideClick: () => {
                            const popup = Swal.getPopup()
                            popup.classList.remove('swal2-show')
                            setTimeout(() => {
                                popup.classList.add('animate__animated', 'animate__headShake')
                            })
                            setTimeout(() => {
                                popup.classList.remove('animate__animated', 'animate__headShake')
                            }, 500)
                            return false
                        }
                    });
                    $(".Userloaderbg").css("display", "none");
                    return false;
                }
                //var formattedDate = convertDateFormat(FromDate);
                //var ToformattedDate = convertDateFormat(ToDate);
                // Create a Blob from the response data
                var blob = new Blob([data], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                // Create a temporary anchor element to initiate the download
                var anchorElement = document.createElement('a');
                var url = window.URL.createObjectURL(blob);
                anchorElement.href = url;
                anchorElement.download = 'PayrollSalaryApproval.xlsx';
                anchorElement.click();
                // Clean up
                window.URL.revokeObjectURL(url);
                $(".Userloaderbg").css("display", "none");
            },
            error: function(xhr, status, error) {
                console.error('Error downloading file:', error);
                // Handle error scenarios here
            }
        });
    }


    function ApproveRejectList() {debugger
        form.valid();
        if (form.valid() == false) {
            $("#MonthYear").removeClass("error");
            return false;
        }
        var CmpId = encodeURIComponent($("#ddlCmpId").val());
        var SalaryMonthYear = encodeURIComponent($("#txtMonthYear").val());
        var SalaryBranchId = encodeURIComponent($("#ddlBranchId").val());
        var SalaryProcessCategoryId = $("#ddlProcessCategoryId").val();
        //var status="Approved";
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetApproveRejectList", "Module_Payroll_PayrollSalaryApproval")',
            data: { SalaryBranchId, SalaryMonthYear, SalaryProcessCategoryId},
            contentType: "application/json; charset=utf-8",
            dataType: "text",
            success: function (response) {
                debugger;
                const data = JSON.parse(response);
                const modal = $('#myEmployeeSalary');
                const tableBody = $('#tblBodyEmployeeSalary');

                // Clear table body (except headers)
                if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                    $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                }

                modal.modal(data.length > 0 ? 'show' : 'hide');
               
                if ($.fn.DataTable.isDataTable('#tblEmployeeHistoryHead')) {
                    $('#tblEmployeeHistoryHead').DataTable().clear().destroy();
                }

                if (!data || Object.keys(data).length === 0) {
                    return Swal.fire({
                        icon: "error",
                        text: "No Record Found",
                        allowOutsideClick: () => animatePopup()
                    });
                }


                if (data) {
                    debugger;
                    let convertedData = {};

                    // Flatten the original data
                    Object.keys(data).forEach(key => {
                        let flatObject = {};
                        data[key].forEach(item => {
                            flatObject[item.Key] = item.Value;
                        });
                        convertedData[key] = flatObject;
                    });

                    debugger;

                    // Clear table body first (important if appending dynamically multiple times)
                    $('#tblBodyEmployeeSalary').empty();

                    // Loop over the converted object
                    Object.values(convertedData).forEach(item => {
                        let row = `<tr>
                        <td><center><input type="checkbox" class="form-check-input" /></center></td>
                        <td hidden class="text-nowrap">${item.SalaryID || ''}</td>
                        <td hidden class="text-nowrap">${item.SalaryEmployeeId || ''}</td>
                        <td class="text-nowrap">${item.BranchName || ''}</td>
                        <td class="text-nowrap">${item.EmployeeNo || ''}</td>
                        <td class="text-nowrap">${item.EmployeeName || ''}</td>
                        <td class="text-nowrap text-end">${item.PayableDays || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryOTHrs || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryTotalGross || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryNetPay || '0'}</td>
                        <td class="text-nowrap text-end">${item.SalaryCTC || '0'}</td>
                        <td class="text-nowrap">${item.SalaryCheckerStatus || ''}</td>
                        <td class="text-nowrap">${item.ProcessCategoryName || '0'}</td>
                        <td class="text-nowrap">${item.ApprovedBy || ''}</td>
                        <td class="text-nowrap">${item.SalaryCheckerApprovedDate || ''}</td>
                    </tr>`;

                        $('#tblBodyEmployeeSalary').append(row);
                    });

                } else {
                    modal.modal('hide');
                }
            }
        });
    }
