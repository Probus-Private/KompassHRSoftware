<div id="content" class="app-content">
    <div class="row" style="margin-bottom: 10px;">
        <div class="col-md-12" style="display: flex; justify-content: space-between; align-items: center;">
            <h1 style="font-size: 18px; font-family: roboto; transform: translateY(4px); margin: 0;">
                Payroll Approval
            </h1>
            <ol style="list-style: none; padding: 0; margin: 0; display: flex;">
                <li style="margin-right: 10px;">
                    <a href="@Url.Action("Dashboard", "Dashboard", new { area = "" })">
                        <img src="~/assets/MenuImages/Home.png" style="max-width: 100%; height: auto;" alt="Home">
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Module_Payroll_PayrollSalaryRequestApproval", "Module_Payroll_PayrollSalaryRequestApproval", new { id = 6, ScreenId = 745, area = "Module" })">
                        <img src="~/assets/MenuImages/Back.png" class="img-fluid" style="max-width: 100%;float:right" />
                    </a>
                </li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- BEGIN panel -->
            <div class="panel panel-inverse" data-sortable-id="index-1">
                <div class="panel-heading" style="background-color:@Session["HeaderColor"]; color:@Session["HeaderTextColor"]">
                    <h4 class="panel-title"> Payroll Approval</h4>
                    <div class="panel-heading-btn">
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-default" data-toggle="panel-expand"><i class="fa fa-expand"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-success" data-toggle="panel-reload"><i class="fa fa-redo"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-warning" data-toggle="panel-collapse"><i class="fa fa-minus"></i></a>
                        <a href="javascript:;" class="btn btn-xs btn-icon btn-danger" data-toggle="panel-remove"><i class="fa fa-times"></i></a>
                    </div>
                </div>
                <div class="alert alert-yellow rounded-0 pb-0 d-flex align-items-center mb-0 text-black">
                    <p class="pb-0">
                    </p>
                </div>
                <div class="panel-body" data-scrollbar="true">
                    <div class="row justify-content-center">
                        <form role="form" href="@Url.Action("Module_Payroll_PayrollSalaryApproval", "Module_Payroll_PayrollSalaryApproval" , new { area = "Module" })" id="SavePayrollsalary" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Company
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.SalaryCmpId, new SelectList(ViewBag.GetCompanyName, "Id", "Name"), "--Select--", new { id = "ddlCmpId", @class = "form-select", name = "SalaryCmpId" })
                                            <span id="ErrorddlCmpId" class="Error"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Business Unit<span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.DropDownListFor(model => model.SalaryBranchId, new SelectList(ViewBag.GetBranchName, "Id", "Name"), "--Select--", new { id = "ddlBranchId", @class = "form-select", name = "SalaryBranchId" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Month/Year
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-8">
                                            @Html.TextBoxFor(model => model.SalaryMonthYear, new { id = "txtMonthYear", @class = "form-control", name = "Month", type = "month" })
                                        </div>

                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="row mb-15px">
                                        <label class="form-label col-form-label col-md-4">
                                            Salary Process (Category)
                                            <span class="important">*</span>
                                        </label>
                                        <div class="col-md-3">
                                            @Html.DropDownListFor(model => model.SalaryProcessCategoryId, new SelectList(ViewBag.SalaryProcess, "Id", "Name"), new { @class = "form-select", id = "ddlProcessCategoryId", type = "text", name = "ProcessCategoryId", autocomplete = "Off" })
                                        </div>
                                        @*<div class="col-md-1">

                                            </div>*@
                                        <div class="col-md-5">
                                            <button type="button" id="btnshow" onclick="showList()" class="btn btn-success btn-sm  mb-10px">
                                                Show
                                            </button>
                                            <button type="button" class="btn btn-sm btn-primary mb-10px" id="btlExportToExcel" onclick="downloadExcelFile()">
                                                <i class="fa-regular fa-file-excel fa-xl"></i> Export To Excel
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr />
                        </form>

                        <!-- BEGIN table-responsive -->
                        <div class="table-scroll div1">
                            <div class="table-wrap">
                                @if (ViewBag.PayrollSalaryRequest != null && ((List<object>)ViewBag.PayrollSalaryRequest).Count > 1)
                                {
                                    <table id="data-table-combine15" class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass" style="width: 100%;">
                                        <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                            @{ var dynamicList = ViewBag.PayrollSalaryRequest as List<dynamic>; }
                                            <tr>
                                                <th class="text-nowrap text-center">All <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                                @foreach (var Site in dynamicList)
                                                {
                                                    foreach (var property in (IDictionary<string, object>)Site)
                                                    {
                                                        var isHidden = property.Key == "SalaryID" ||
                                                                       property.Key == "SalaryEmployeeId" ||
                                                                       property.Key == "SalaryMonthYear" ||
                                                                       property.Key == "SalaryCmpId" ||
                                                                       property.Key == "SalaryBranchId";
                                                        <td style="@(isHidden ? "display: none;" : "")">@property.Key</td>

                                                    }
                                                    break;
                                                }
                                            </tr>
                                        </thead>

                                        <tbody id="tbodyApproveReject">
                                            @foreach (var Site in dynamicList)
                                            {
                                                <tr>
                                                    @{
                                                        var dict = (IDictionary<string, object>)Site;
                                                        var salaryId = dict.ContainsKey("SalaryID") ? dict["SalaryID"] : null;

                                                    }


                                                    <td style="text-align:center">
                                                        <input type="checkbox" name="selectedRows" value="@salaryId" />
                                                    </td>

                                                    @foreach (var property in dict)
                                                    {
                                                        if (property.Key.StartsWith("View"))
                                                        {
                                                            continue;
                                                        }

                                                        var isHidden = property.Key == "SalaryID" ||
                                                                       property.Key == "SalaryEmployeeId" ||
                                                                       property.Key == "SalaryMonthYear" ||
                                                                       property.Key == "SalaryCmpId" ||
                                                                       property.Key == "SalaryBranchId";
                                                        <td style="@(isHidden ? "display: none;" : "")">@property.Value</td>
                                                    }
                                                </tr>
                                                        }
                                        </tbody>
                                    </table>
                                                        }
                            </div>

                        </div>

                        <div class="row mb-20px">
                            <div class="LastShortLeaveBx">
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="row mb-15px">
                                            <label class="form-label col-form-label col-md-2">
                                                Remark
                                            </label>
                                            <div class="col-md-10">
                                                <textarea id="txtApproveRejectRemark" class="form-control" rows="1"></textarea>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="row mb-15px">
                                            <div class="BtnBx">
                                                <div>
                                                    <button type="button" class="btn btn-primary btn-sm" id="btnAllApprove" onclick="AllApproveReject('Approved')">
                                                        <i class="fa-solid fa-floppy-disk"></i> Approve
                                                    </button>
                                                    @*<button href="#modal-dialogForHoldReject1" onclick="OpenModule('Reject')" type="button" class="btn btn-danger btn-sm" id="btnmodal-dialog1" value="Rejected">Reject</button>*@

                                                    <button type="button" class="btn btn-danger btn-sm" id="btnAllApprove" onclick="AllApproveReject('Rejected')">
                                                        <i class="fa-solid fa-floppy-disk"></i> Reject
                                                    </button>
                                                    <button type="button" class="btn btn-success btn-sm" onclick="ApproveRejectList()">
                                                        <i class="fa-solid fa-share-from-square"></i> Approve Reject List
                                                    </button>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- END panel -->
        </div>
    </div>
</div>
!-- #Start modal-dialog -->
<div class="modal fade" id="myEmployeeSalary" data-bs-backdrop="static" data-bs-keyboard="true" data-bs-theme="dark">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-black text-white">
                <h4 class="modal-title">Payroll Salary Approved  - List</h4>
                <div class="panel-heading-btn">
                    <a href="javascript:;" class="btn btn-icon btn-danger CloseModelHistory" data-bs-dismiss="modal"
                       aria-hidden="true" id="CloseModelHistory">
                        <i class="fa fa-xmark"></i>
                    </a>
                </div>
            </div>
            <div class="modal-body">
                <!-- BEGIN panel -->
                <div class="modal-body-content">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="table-scroll div1">
                                <div class="row">
                                    <table class="table table-bordered mb-0 text-dark align-middle TabledataBulkClass" style="width: 100%;" id="tblEmployeeHistoryHead">
                                        <thead class="table-active horizontal-scroll" style="background-color: rgba(233, 236, 239, 1) !important;">
                                            <tr>
                                                <th class="text-nowrap text-center">All <input type="checkbox" class="form-check-input" data-checked="all-checkbox" id="SelectAll" onchange="checkAll(this)" /></th>
                                                <th hidden class="text-nowrap">SalaryID </th>
                                                <th hidden class="text-nowrap">EmployeeId </th>
                                                <th class="text-nowrap">Business Unit</th>
                                                <th class="text-nowrap">Employee No </th>
                                                <th class="text-nowrap">Employee Name</th>
                                                <th class="text-nowrap">Payable Days </th>
                                                <th class="text-nowrap">OT Hrs </th>
                                                <th class="text-nowrap">Gross Pay </th>
                                                <th class="text-nowrap">Salary Net Pay </th>
                                                <th class="text-nowrap">Salary CTC</th>
                                                <th class="text-nowrap">Status</th>
                                                <th class="text-nowrap">ProcessCategoryName</th>
                                                <th class="text-nowrap">Approved/Reject By</th>
                                                <th class="text-nowrap">Approved/Reject Date</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblBodyEmployeeSalary"></tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                    <hr/>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row mb-15px">
                                <label class="form-label col-form-label col-md-4">
                                    Salary Checker Status
                                    <span class="important">*</span>
                                </label>
                                <div class="col-md-6">
                                    @Html.DropDownListFor(model => model.SalaryCheckerStatus,
                                                new List<SelectListItem>{
                                                    new SelectListItem { Text = "Pending", Value = "Pending" },
                                                    //new SelectListItem { Text = "Approved to Pending", Value = "true" }
                                                }, new { @class = "form-select", name = "SalaryCheckerStatus", id = "ddlSalaryCheckerStatus" })
                                    <span id="ErrorddlBranchId" class="Error"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 text-end">
                            <button type="button" id="btnEmployeeSubmit" class="btn btn-primary btn-sm">
                                <i class="fa-solid fa-floppy-disk"></i> Submit
                            </button>

                            <button type="button" class="btn btn-danger btnpress btn-sm CloseModelHistory" id="CloseModelHistory" data-bs-dismiss="modal" aria-hidden="true">
                                <i class="fa-solid fa-share-from-square"></i> Close
                            </button>
                        </div>
                    </div>
                </div>
                <!-- END panel -->
            </div>
        </div>
    </div>
</div>
<!-- #End modal-dialog -->


<script>
    $(document).ready(function () {
        $("#ddlCmpId").select2();
        $("#ddlBranchId").select2();

        var table = $('.TabledataBulkClass').DataTable();

        if ($.fn.DataTable.isDataTable('.TabledataBulkClass')) {
            table.destroy();
        }

        $('.TabledataBulkClass').DataTable({
            scrollY: 400,
            scrollCollapse: true,
            paging: false,
            scrollX: true,
            searching: true, // Enable searching
            stripeClasses: [] // Disable alternating row colors
        });

        $('#myEmployeeSalary').on('shown.bs.modal', function () {
            var table = $('.TabledataBulkClass').DataTable();

            if ($.fn.DataTable.isDataTable('.TabledataBulkClass')) {
                table.destroy();
            }

            $('.TabledataBulkClass').DataTable({
                scrollY: 350,
                scrollCollapse: true,
                paging: false,
                scrollX: true,
                searching: true,
                stripeClasses: []
            });
        });

        var Message = @Html.Raw(Json.Encode(TempData["Message"]));
        var Icon = @Html.Raw(Json.Encode(TempData["Icon"]));
        debugger;
        if (Message != null) {
            if (Icon != null) {
                Swal.fire({
                    icon: Icon,
                    text: Message,
                    allowOutsideClick: () => {
                        const popup = Swal.getPopup()
                        popup.classList.remove('swal2-show')
                        setTimeout(() => {
                            popup.classList.add('animate__animated', 'animate__headShake')
                        })
                        setTimeout(() => {
                            popup.classList.remove('animate__animated', 'animate__headShake')
                        }, 500)
                        // return false
                    }
                }).then(function() {
                    window.location.reload();
                });
            }
        }

        var today = new Date();
        // Format the date as YYYY-MM (year-month)
        var yyyy = today.getFullYear();
        var mm = String(today.getMonth() + 1).padStart(2, '0'); // January is 0!
        var defaultMonth = yyyy + '-' + mm;
        // Set the value of the input element to the default month
        var CheckEmptyDate = document.getElementById('txtMonthYear').value;
        if (CheckEmptyDate == "") {
            document.getElementById('txtMonthYear').value = defaultMonth;
        }

        $("#ddlCmpId").on("change", function () {debugger
            $("#ddlBranchId").find("option").remove();
            var CmpId = $("#ddlCmpId").val();
            $.ajax({
                type: 'GET',
                dataType: 'JSON',
                contentType: "application/json; charset=utf-8",
                url: '@Url.Action("GetBusinessUnit", "Module_Payroll_PayrollSalaryApproval")',
                data: { CmpId: CmpId },
                success: function (data) {debugger
                    if (data !=null) {debugger
                        $("#ddlBranchId").append("<option value=''>--Select-- </option>");
                        $.each(data, function(i, p) {
                            $("#ddlBranchId").append("<option value='" + p.Id +"'>" + p.Name +"</option>");
                        });
                    }
                }
            })
        })

    });




    //use for add regex function
    jQuery.validator.addMethod(
    "regex",
     function (value, element, regexp) {
         if (regexp.constructor != RegExp)
             regexp = new RegExp(regexp);
         else if (regexp.global)
             regexp.lastIndex = 0;
         return this.optional(element) || regexp.test(value);
     }, "erreur expression reguliere"
  );

    $('#SavePayrollsalary').validate({
        rules: {
            SalaryCmpId: {
                required: true,
            },
            SalaryBranchId: {
                required: true,
            },
            SalaryMonthYear: {
                required: true,
            },
        },
        messages: {
            SalaryCmpId: {
                required: "Company name is required",
            },
            SalaryBranchId: {
                required: "Business Unit name is required",
            },
            SalaryMonthYear: {
                required: "Month/year is required",
            },
        },
    });

    var form = $("#SavePayrollsalary");
    form.validate();

    function showList() {
        debugger;
        form.valid();
        if (form.valid() == false) {
            $("#MonthYear").removeClass("error");
            return false;
        }
        $(".Userloaderbg").css("display", "flex");
        $("#SavePayrollsalary").submit();
    }

    function checkAll(ele) {
        var checkboxes = document.getElementsByTagName('input');
        if (ele.checked) {
            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = true;
                }
            }
        } else {
            for (var i = 0; i < checkboxes.length; i++) {
                console.log(i)
                if (checkboxes[i].type == 'checkbox') {
                    checkboxes[i].checked = false;
                }
            }
        }
    }

    //function checkAll(ele) {
    //    // Get all checkboxes inside tbody except the last row
    //    var checkboxes = document.querySelectorAll(
    //        "#data-table-combine15 tbody tr:not(:last-child) input[type='checkbox']"
    //    );

    //    checkboxes.forEach(function (cb) {
    //        cb.checked = ele.checked;
    //    });
    //}

</script>
